import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
ws = wb["Sheet1"]

max_row = ws.max_row
print("Using max_row:", max_row)

# Build and print the formula template for inspection
sample_formula_r2 = (
    f'=IF(COUNTIFS($A$2:$A${max_row},A2,$D$2:$D${max_row},"No Show")*'
    f'COUNTIFS($A$2:$A${max_row},A2,$D$2:$D${max_row},"Sch")>0,'
    f'"NS/SCHED",IF(D2="Sch","FUTURE",IF(AND(D2="No Show",E2<>""),"NO ACTION NEEDED",IF(AND(D2="No Show",E2=""),"CALL PT",""))))'
)
print("Sample formula for row 2:")
print(sample_formula_r2)

# Show current target area before writing
print("\nBefore writing, F12:F20:")
for r in range(12, 21):
    print(r, ws[f"A{r}"].value, ws[f"D{r}"].value, ws[f"E{r}"].value, ws[f"F{r}"].value)

# Fill only blank target cells in column F
written_rows = []
for r in range(2, max_row + 1):
    if ws[f"F{r}"].value in (None, ""):
        formula = (
            f'=IF(COUNTIFS($A$2:$A${max_row},A{r},$D$2:$D${max_row},"No Show")*'
            f'COUNTIFS($A$2:$A${max_row},A{r},$D$2:$D${max_row},"Sch")>0,'
            f'"NS/SCHED",IF(D{r}="Sch","FUTURE",IF(AND(D{r}="No Show",E{r}<>""),"NO ACTION NEEDED",IF(AND(D{r}="No Show",E{r}=""),"CALL PT",""))))'
        )
        ws[f"F{r}"] = formula
        written_rows.append((r, formula))

print("\nRows written:", [r for r, _ in written_rows])
print("First few written formulas:")
for r, formula in written_rows[:5]:
    print(r, formula)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet name if needed
orig_sheetnames = ["Sheet1"]
wb_chk = load_workbook(outfile)
print("Sheet names after recalc:", wb_chk.sheetnames)
if wb_chk.sheetnames != orig_sheetnames:
    for i, old_name in enumerate(wb_chk.sheetnames[:len(orig_sheetnames)]):
        wb_chk[old_name].title = orig_sheetnames[i]
    wb_chk.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify values with data_only=True
wb_val = load_workbook(outfile, data_only=True)
ws_val = wb_val["Sheet1"]

print("\nVerification rows 2:20 (A,D,E,F):")
for r in range(2, 21):
    print(r, ws_val[f"A{r}"].value, ws_val[f"D{r}"].value, ws_val[f"E{r}"].value, ws_val[f"F{r}"].value)

# Also inspect formulas persisted in original workbook
wb_form = load_workbook(outfile, data_only=False)
ws_form = wb_form["Sheet1"]
print("\nFormula check F12:F20:")
for r in range(12, 21):
    print(r, ws_form[f"F{r}"].value)
