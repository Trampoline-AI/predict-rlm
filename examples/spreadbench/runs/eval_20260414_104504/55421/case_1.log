import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers:", headers)
    # also inspect row 2 in case headers start there
    row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
    print("Row 2:", row2)
    # sample first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Explicitly inspect columns A, D, E, F and any existing formulas/values in F
for ws in wb.worksheets:
    print(f"\nTarget inspection for sheet {ws.title}")
    for r in range(1, min(ws.max_row, 25) + 1):
        a = ws[f"A{r}"].value
        d = ws[f"D{r}"].value
        e = ws[f"E{r}"].value
        f = ws[f"F{r}"].value
        if any(v is not None for v in [a, d, e, f]):
            print(f"Row {r}: A={a!r}, D={d!r}, E={e!r}, F={f!r}")
    # show formulas in F if present
    formulas = []
    for r in range(1, ws.max_row + 1):
        v = ws[f"F{r}"].value
        if isinstance(v, str) and v.startswith("="):
            formulas.append((r, v))
    print("Formula cells in col F (first 20):", formulas[:20])
