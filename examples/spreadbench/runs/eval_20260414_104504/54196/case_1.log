from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet two"]

print("Sheet two dims:", ws.max_row, ws.max_column)
print("Target column E index:", column_index_from_string("E"))

# Determine actual data extents
def row_nonempty(r, cols=None):
    cols = cols or range(1, ws.max_column + 1)
    return any(ws.cell(r, c).value not in (None, "") for c in cols)

be_rows = [r for r in range(1, ws.max_row + 1) if row_nonempty(r, range(2, 6))]  # B:E
fg_rows = [r for r in range(1, ws.max_row + 1) if row_nonempty(r, range(6, 8))]  # F:G
lookup_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, 2).value not in (None, "") and ws.cell(r, 3).value not in (None, "")]
print("Rows with data in B:E:", be_rows[:5], "...", be_rows[-5:], "count", len(be_rows))
print("Rows with data in F:G:", fg_rows[:5], "...", fg_rows[-5:], "count", len(fg_rows))
print("Lookup rows B:C usable:", lookup_rows[:5], "...", lookup_rows[-5:], "count", len(lookup_rows))
print("Last row B:E:", max(be_rows), "Last row F:G:", max(fg_rows), "Last row lookup B:C:", max(lookup_rows))

# Print first and last relevant rows with formulas in E
for r in list(range(1, 8)) + list(range(max(be_rows)-4, max(be_rows)+1)):
    vals = {f"{get_column_letter(c)}{r}": ws.cell(r, c).value for c in range(1, 8)}
    print(r, vals)

# Count formulas in E and sample values in G that should match B
formula_rows_e = [(r, ws[f"E{r}"].value) for r in range(2, ws.max_row + 1) if isinstance(ws[f"E{r}"].value, str) and ws[f"E{r}"].value.startswith("=")]
print("Formula count in E:", len(formula_rows_e), "first few:", formula_rows_e[:5], "last few:", formula_rows_e[-5:])

# Build mapping B->C and inspect sample matches for G
mapping = {}
for r in lookup_rows:
    mapping[str(ws.cell(r,2).value).strip()] = ws.cell(r,3).value

samples = []
for r in range(2, min(ws.max_row, 20)+1):
    g = ws.cell(r,7).value
    samples.append((r, g, mapping.get(str(g).strip()) if g is not None else None))
print("Sample G -> expected C:", samples)

# Compute overall match stats for rows with G values
match_rows = []
no_match_rows = []
for r in range(2, max(fg_rows)+1):
    g = ws.cell(r,7).value
    f = ws.cell(r,6).value
    if g not in (None, "") or f not in (None, ""):
        expected = mapping.get(str(g).strip()) if g is not None else None
        if expected is None:
            no_match_rows.append((r, f, g))
        else:
            match_rows.append((r, f, g, expected))
print("Rows needing output based on F/G:", len(match_rows) + len(no_match_rows))
print("Matched rows:", len(match_rows), "Unmatched rows:", len(no_match_rows))
print("First 10 unmatched:", no_match_rows[:10])
print("Last 10 matched:", match_rows[-10:])

# Apply fix: populate E2:E_last_fg with correct formula using explicit range
last_lookup = max(lookup_rows)
last_target = max(fg_rows)
formula_preview = f'=IFERROR(VLOOKUP(G2,$B$2:$C${last_lookup},2,FALSE),"")'
print("Formula to write, preview E2:", formula_preview)

for r in range(2, last_target + 1):
    f = ws.cell(r, 6).value
    g = ws.cell(r, 7).value
    # Fill E for rows that belong to F:G table extent; blank only if row truly empty in F:G
    if f in (None, "") and g in (None, ""):
        ws.cell(r, 5).value = None
    else:
        ws.cell(r, 5).value = f'=IFERROR(VLOOKUP(G{r},$B$2:$C${last_lookup},2,FALSE),"")'

# Save
import os
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Restore sheet names if changed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
print("Names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify data_only values
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet two"]
print("Verification target cells in E:")
for r in [2,3,4,5,10,100,1000,last_target-4,last_target-3,last_target-2,last_target-1,last_target]:
    if 1 <= r <= last_target:
        print(r, {"G": wsv[f"G{r}"].value, "E": wsv[f"E{r}"].value})

# Also verify formula strings on non-data_only workbook
