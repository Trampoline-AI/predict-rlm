import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Re-open and inspect target row/cells closely
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

print("Before write, row 4:", [ws.cell(4,c).value for c in range(1, ws.max_column+1)])
for c in range(1, ws.max_column+1):
    print(f"Cell {get_column_letter(c)}4 current value:", ws.cell(4,c).value)

# Build per-animal rankings from rows 1 and 2
animals = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
nums = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]

groups = {}
for idx, (animal, num) in enumerate(zip(animals, nums), start=1):
    if animal is None or num is None:
        continue
    groups.setdefault(str(animal).strip(), []).append((idx, num))

print("Groups:", groups)

# Rank descending within each animal
placements = {}
for animal, items in groups.items():
    items_sorted = sorted(items, key=lambda x: x[1], reverse=True)
    for rank, (col_idx, num) in enumerate(items_sorted, start=1):
        if rank <= 2:  # first and second largest
            placements[col_idx] = f"{animal}{rank}"

print("Planned placements:", placements)

# Only fill empty cells or keep existing matching answers
for col_idx, label in placements.items():
    cell = ws.cell(4, col_idx)
    if cell.value in (None, ""):
        cell.value = label
    elif str(cell.value).strip() == label:
        pass
    else:
        print(f"Non-empty conflicting value at {get_column_letter(col_idx)}4: {cell.value!r}, replacing with {label!r}")
        cell.value = label

print("After write, row 4:", [ws.cell(4,c).value for c in range(1, ws.max_column+1)])

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Check sheet names after recalc and restore if changed
orig_names = wb.sheetnames
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    for i, old_name in enumerate(orig_names):
        wb2.worksheets[i].title = old_name
    wb2.save(outfile)
    print("Restored sheet names:", orig_names)

# Verify with reload
verify_wb = load_workbook(outfile, data_only=True)
verify_ws = verify_wb[orig_names[0]]
print("Verified row 4:", [verify_ws.cell(4,c).value for c in range(1, verify_ws.max_column+1)])
print("Verified target cells:", {f"{get_column_letter(c)}4": verify_ws.cell(4,c).value for c in range(1, verify_ws.max_column+1)})
