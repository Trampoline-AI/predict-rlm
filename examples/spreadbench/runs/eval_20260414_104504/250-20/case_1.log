```repl
import os, shutil
from collections import defaultdict
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["RNM"]
ws_exp = wb["Desired outcome"]

def true_last_row(ws):
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            return r
    return 0

for s in [ws, ws_exp]:
    tlr = true_last_row(s)
    print(s.title, "true_last_row", tlr, "max_row", s.max_row)

def collect_rows(ws):
    tlr = true_last_row(ws)
    rows = []
    for r in range(2, tlr + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            rows.append((r, vals))
    return rows

rnm_rows = collect_rows(ws)
exp_rows = collect_rows(ws_exp)

pairs = defaultdict(list)
for r, vals in rnm_rows:
    key = (vals[1], vals[2])  # B,C
    pairs[key].append((r, vals[9], vals))

dupes = {k:v for k,v in pairs.items() if len(v) > 1}
print("Total non-empty RNM data rows:", len(rnm_rows))
print("Unique B/C keys:", len(pairs))
print("Duplicate key count:", len(dupes))
for k, v in sorted(dupes.items(), key=lambda kv: (str(kv[0][0]), kv[0][1])):
    print("RNM dup key", k, "rows", [x[0] for x in v], "J values", [x[1] for x in v], "sum", sum((x[1] or 0) for x in v))

exp_pairs = defaultdict(list)
for r, vals in exp_rows:
    exp_pairs[(vals[1], vals[2])].append((r, vals[9], vals))
print("Desired outcome rows:", len(exp_rows))
for k in sorted(dupes):
    print("Desired rows for", k, exp_pairs.get(k))

# Build transformed data: keep first occurrence order, sum J within each B/C group
seen = set()
out_rows = []
for r, vals in rnm_rows:
    key = (vals[1], vals[2])
    if key in seen:
        continue
    seen.add(key)
    new_vals = list(vals)
    new_vals[9] = sum((item[1] or 0) for item in pairs[key])  # col J
    out_rows.append(new_vals)

print("Transformed row count should be:", len(out_rows))
print("First 12 transformed rows:")
for i, vals in enumerate(out_rows[:12], start=2):
    print(i, vals)
print("Last 5 transformed rows:")
for vals in out_rows[-5:]:
    print(vals)

# Apply to RNM sheet only
for r_idx, vals in enumerate(out_rows, start=2):
    for c_idx, v in enumerate(vals, start=1):
        ws.cell(r_idx, c_idx).value = v

# Clear remaining old rows through true last used row
old_last = true_last_row(ws)
new_last = len(out_rows) + 1
for r in range(new_last + 1, old_last + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalc
result = await recalculate(out_path)
print("Recalculate:", result)

# reload and fix sheet names if changed
wb2 = load_workbook(out_path)
orig_names = ["RNM", "Desired outcome"]
if wb2.sheetnames != orig_names:
    print("Sheet names changed after recalc:", wb2.sheetnames)
    for i, expected in enumerate(orig_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = expected
    wb2.save(out_path)
    wb2 = load_workbook(out_path)
print("Final sheet names:", wb2.sheetnames)

# verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver["RNM"]
print("Verified RNM true_last_row:", true_last_row(vws))
print("Verified first 12 rows:")
for r in range(1, min(true_last_row(vws), 13) + 1):
    print(r, [vws.cell(r,c).value for c in range(1, vws.max_column + 1)])
print("Verified target duplicate keys in RNM:")
for r in range(2, true_last_row(vws) + 1):
    b = vws.cell(r,2).value
    c = vws.cell(r,3).value
    if (b,c) in dupes:
        print(r, b, c, "J=", vws.cell(r,10).value)

final_pairs = defaultdict(int)
final_counts = defaultdict(int)
for r in range(2, true_last_row(vws)+1):
    key = (vws.cell(r,2).value, vws.cell(r,3).value)
    if key != (None, None):
        final_counts[key] += 1
        final_pairs[key] = vws.cell(r,10).value
print("Final counts for former dupes:", {k: final_counts[k] for k in dupes})
print("Final J for former dupes:", {k: final_pairs[k] for k in dupes})
```
