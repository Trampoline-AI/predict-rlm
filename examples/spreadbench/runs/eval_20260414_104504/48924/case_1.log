import os, shutil
from datetime import datetime, timedelta
from openpyxl import load_workbook

# Reload clean workbook for manipulation
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
orig_sheet_names = wb.sheetnames[:]

# Determine actual non-empty rows in column A and C
a_nonempty = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None and v != "":
        a_nonempty.append((r, v))

c_nonempty = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 3).value
    if v is not None and v != "":
        c_nonempty.append((r, v))

print("Non-empty A rows:", a_nonempty)
print("Non-empty C rows before write:", c_nonempty)

# Normalize dates from column A
dates_a = []
for r, v in a_nonempty:
    if isinstance(v, datetime):
        dates_a.append(v.date())
    else:
        # in case Excel stores as date-like type
        try:
            dates_a.append(v.date())
        except Exception:
            dates_a.append(v)

sorted_dates = sorted(dates_a)
print("Column A date count:", len(sorted_dates))
print("Min/Max:", sorted_dates[0], sorted_dates[-1])

# Compute missing dates between min and max inclusive
present = set(sorted_dates)
cur = sorted_dates[0]
missing = []
while cur <= sorted_dates[-1]:
    if cur not in present:
        missing.append(cur)
    cur += timedelta(days=1)

print("Computed missing dates:", missing)

# Compare with existing C examples
existing_c_dates = []
for r, v in c_nonempty:
    if isinstance(v, datetime):
        existing_c_dates.append(v.date())
    else:
        try:
            existing_c_dates.append(v.date())
        except Exception:
            existing_c_dates.append(v)
print("Existing C dates normalized:", existing_c_dates)
print("Existing prefix matches computed?:", existing_c_dates == missing[:len(existing_c_dates)])

# Write missing dates to column C starting at row 2, preserving correct existing values
for i, d in enumerate(missing, start=2):
    cell = ws.cell(i, 3)
    existing = cell.value
    new_dt = datetime.combine(d, datetime.min.time())
    if existing is None or existing == "":
        cell.value = new_dt
    else:
        # preserve if already same date, otherwise replace with correct date
        exd = existing.date() if isinstance(existing, datetime) else existing
        if exd != d:
            cell.value = new_dt
    cell.number_format = "m/d/yyyy"

# Clear any stale extra values below the needed list in column C
for r in range(2 + len(missing), ws.max_row + 1):
    if ws.cell(r, 3).value not in (None, ""):
        ws.cell(r, 3).value = None

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and repair sheet names if recalc changed them
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for idx, old in enumerate(orig_sheet_names):
        wb2.worksheets[idx].title = old
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_sheet_names[0]]

verified_c = []
for r in range(1, 2 + len(missing)):
    verified_c.append((r, wsv.cell(r, 3).value))
print("Target C range after save:", verified_c)

output_spreadsheet = out_path
```
