from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import column_index_from_string
import os, shutil

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Confirm target columns based on inspected workbook
print("Using target output column BF because workbook ends at BL and BF is labeled 'Expected Result in BG'.")
print("Columns:", {"AY": column_index_from_string("AY"), "BF": column_index_from_string("BF"), "BG": column_index_from_string("BG"), "BL": column_index_from_string("BL")})

target_bg_texts = {
    "OCOGS - Spares - Transfer Price Overhead",
    "OFSS - ORCL Consulting Prod Cost I/C",
}
target_ay_texts = {"BOA_033E", "BOA_011G"}
fill = PatternFill(start_color="FF0070C0", end_color="FF0070C0", fill_type="solid")

changed_rows = []
filled_rows = []

for r in range(2, ws.max_row + 1):
    ay = ws[f"AY{r}"].value
    bg = ws[f"BG{r}"].value
    bl = ws[f"BL{r}"].value
    bf_cell = ws[f"BF{r}"]
    bl_cell = ws[f"BL{r}"]
    
    if bl == "LAG" and bg in target_bg_texts:
        new_val = "OCOGS - Spares - Transfer Price Overhead" if ay in target_ay_texts else "OFSS - ORCL Consulting Prod Cost I/C"
        old_val = bf_cell.value
        if old_val != new_val:
            bf_cell.value = new_val
            changed_rows.append((r, old_val, new_val, ay, bg, bl))
        # Ensure BL fill when BL is LAG and BF populated
        if bf_cell.value not in (None, ""):
            bl_cell.fill = fill
            filled_rows.append(r)

print("Changed rows count:", len(changed_rows))
print("Changed rows detail:", changed_rows)
print("Filled BL rows count:", len(set(filled_rows)))
print("Filled BL rows:", sorted(set(filled_rows)))

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored original sheet names:", orig_sheetnames)

# Verification with data_only and style workbook
wb_val = load_workbook(outfile, data_only=True)
ws_val = wb_val[orig_sheetnames[0]]
wb_style = load_workbook(outfile)
ws_style = wb_style[orig_sheetnames[0]]

verify_rows = []
for r in range(2, ws_val.max_row + 1):
    ay = ws_val[f"AY{r}"].value
    bg = ws_val[f"BG{r}"].value
    bl = ws_val[f"BL{r}"].value
    bf = ws_val[f"BF{r}"].value
    style_fill = ws_style[f"BL{r}"].fill
    fill_rgb = style_fill.start_color.rgb if style_fill and style_fill.fill_type == "solid" else None
    if bl == "LAG" and bg in target_bg_texts:
        expected = "OCOGS - Spares - Transfer Price Overhead" if ay in target_ay_texts else "OFSS - ORCL Consulting Prod Cost I/C"
        verify_rows.append((r, ay, bg, bl, bf, expected, fill_rgb, bf == expected, fill_rgb == "FF0070C0"))

print("Verification rows:")
