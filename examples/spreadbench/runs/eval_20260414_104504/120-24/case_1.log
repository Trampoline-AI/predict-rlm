path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

# Helper functions
def row_values(ws, row, max_col=None):
    max_col = max_col or ws.max_column
    return [ws.cell(row=row, column=c).value for c in range(1, max_col+1)]

def nonempty_row_count(ws):
    cnt = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            cnt += 1
    return cnt

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n=== Sheet: {sname} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column, "nonempty_rows:", nonempty_row_count(ws))
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:")
    for i, v in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)} ({i}): {v}")
    
    # Also inspect row 2 in case headers are there instead
    row2 = row_values(ws, 2, ws.max_column)
