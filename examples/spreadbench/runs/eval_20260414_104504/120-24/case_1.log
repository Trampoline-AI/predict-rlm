    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    seen = set()
    print("\nSample rows:")
    for r in first_rows + last_rows:
        if r in seen:
            continue
        seen.add(r)
        vals = row_values(ws, r, min(ws.max_column, 20))
        print(f"Row {r} first 20 cols: {vals}")
    
    # Print relevant columns AY, BG, BL and nearby columns if available
    for col in ["AY", "AZ", "BA", "BB", "BC", "BD", "BE", "BF", "BG", "BH", "BI", "BJ", "BK", "BL", "BM", "BN"]:
        idx = column_index_from_string(col)
        if idx <= ws.max_column:
            print(f"{col} row1={ws.cell(1, idx).value!r}, row2={ws.cell(2, idx).value!r}")
    
    print("\nRelevant rows AY/BG/BL preview (first 10 and last 5):")
    for r in sorted(seen):
        preview = {}
        for col in ["AX","AY","AZ","BF","BG","BH","BK","BL","BM"]:
