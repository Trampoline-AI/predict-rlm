import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Contact List"]

# Inspect target area and determine actual rows to fill
print("Sheet names before:", wb.sheetnames)
for r in range(3, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 12)]
    if any(v is not None and v != "" for v in vals):
        print(f"Nonempty row {r}: {vals}")

print("Existing target column J values/formulas around header/data:")
for r in range(3, min(ws.max_row, 12) + 1):
    print(r, "H=", ws[f"H{r}"].value, "I=", ws[f"I{r}"].value, "J=", ws[f"J{r}"].value)

# Identify rows that actually need output:
target_rows = []
for r in range(4, ws.max_row + 1):
    # write only on meaningful data rows, not blank template rows
    row_has_data = any(ws.cell(r, c).value not in (None, "") for c in range(1, 10))  # A:I
    if row_has_data:
        target_rows.append(r)

print("Target rows:", target_rows)

# Preserve style by only writing formulas to target cells
for r in target_rows:
    current = ws[f"J{r}"].value
    print(f"Before J{r}: {current!r}")
    # If H within last 30 days and I YES => HOLD
    # If H more than 30 days ago and I YES => TOUCH BASE
    # Else NO ACTION
    formula = f'=IF(AND(H{r}>=(TODAY()-30),UPPER(TRIM(I{r}))="YES"),"HOLD",IF(AND(H{r}<(TODAY()-30),UPPER(TRIM(I{r}))="YES"),"TOUCH BASE","NO ACTION"))'
    ws[f"J{r}"] = formula
    print(f"Written J{r} formula:", ws[f"J{r}"].value)

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and repair sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc reload:", wb_after.sheetnames)
original_names = ['Contact List', 'Data']
if wb_after.sheetnames != original_names:
    for i, expected in enumerate(original_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Renamed sheets back to:", wb_after.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula["Contact List"]
wsv = wb_values["Contact List"]

for r in target_rows:
    print(f"Verify J{r} formula:", wsf[f'J{r}'].value)
    print(f"Verify J{r} cached value:", wsv[f'J{r}'].value)
