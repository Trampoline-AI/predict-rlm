```repl
import os, shutil
from openpyxl import load_workbook

# Reopen workbook and inspect exact headers / counts for all sheets
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
print("Original sheet names:", orig_sheetnames)

for s in wb.sheetnames:
    ws = wb[s]
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print(f"{s}: rows={ws.max_row}, cols={ws.max_column}")
    print(" headers:", headers)
    # print first 3 and last 3 data rows for any source sheet
    if ws.max_row >= 2:
        for r in list(range(2, min(ws.max_row, 4) + 1)) + [x for x in range(max(2, ws.max_row-2), ws.max_row+1) if x > min(ws.max_row, 4)]:
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"  row {r}: {vals}")

combined = wb["combined"]
combined_headers = [combined.cell(1, c).value for c in range(1, combined.max_column + 1)]
print("Combined target headers:", combined_headers)
print("Combined A1:O2 before write:")
for r in range(1, 3):
    print(r, [combined.cell(r, c).value for c in range(1, 16)])

# Gather rows from all other sheets, mapped by header name to ensure correct order
source_sheets = [s for s in wb.sheetnames if s != "combined"]
all_rows = []
for s in source_sheets:
    ws = wb[s]
    src_headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    header_to_col = {h: i+1 for i, h in enumerate(src_headers)}
    missing = [h for h in combined_headers if h not in header_to_col]
    extra = [h for h in src_headers if h not in combined_headers]
    print(f"{s} missing vs combined:", missing, "extra:", extra)
    for r in range(2, ws.max_row + 1):
        row_vals = [ws.cell(r, header_to_col[h]).value if h in header_to_col else None for h in combined_headers]
        # only append genuinely non-empty rows
        if any(v not in (None, "") for v in row_vals):
            all_rows.append(row_vals)

print("Total rows to write into combined:", len(all_rows))

# Clear existing combined data rows from row 2 downward within used columns
for r in range(2, combined.max_row + 1):
    for c in range(1, len(combined_headers) + 1):
        combined.cell(r, c).value = None

# Write data starting A2
for i, row_vals in enumerate(all_rows, start=2):
    for c, val in enumerate(row_vals, start=1):
        combined.cell(i, c).value = val

print("Combined after write sample:")
for r in list(range(1, min(6, combined.max_row) + 1)) + ([combined.max_row-4, combined.max_row-3, combined.max_row-2, combined.max_row-1, combined.max_row] if combined.max_row > 6 else []):
    if 1 <= r <= combined.max_row:
        print(r, [combined.cell(r, c).value for c in range(1, 16)])

# Save to output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(out_path)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename sheets back by position
    for idx, expected in enumerate(orig_sheetnames):
        wb2.worksheets[idx].title = expected
    wb2.save(out_path)
    print("Renamed sheets back to original names:", wb2.sheetnames)

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv["combined"]
print("Verified combined dimensions:", wsv.max_row, wsv.max_column)

# Verify target range and no blanks in written rows for first/last samples
verify_rows = list(range(1, min(6, wsv.max_row) + 1))
if wsv.max_row > 6:
    verify_rows += list(range(max(2, wsv.max_row-4), wsv.max_row+1))
seen = set()
for r in verify_rows:
    if r not in seen:
        seen.add(r)
        print(f"combined row {r}:", [wsv.cell(r, c).value for c in range(1, 16)])

print("A2 value:", wsv["A2"].value)
print("O2 value:", wsv["O2"].value)
print("Last data row first/last cells:", wsv.cell(wsv.max_row, 1).value, wsv.cell(wsv.max_row, 15).value)

output_spreadsheet = out_path
