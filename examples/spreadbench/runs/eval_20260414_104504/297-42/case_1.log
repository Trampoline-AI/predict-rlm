from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Original sheet names:", wb.sheetnames)

def nonempty_rows_cols(ws):
    max_r, max_c = ws.max_row, ws.max_column
    # detect actual non-empty bounds roughly
    last_r = 0
    last_c = 0
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value not in (None, ""):
                row_has = True
                last_c = max(last_c, cell.column)
        if row_has:
            last_r = row[0].row
    return last_r, last_c

for s in wb.sheetnames:
    ws = wb[s]
    last_r, last_c = nonempty_rows_cols(ws)
    headers1 = [ws.cell(1, c).value for c in range(1, min(last_c, ws.max_column, 20)+1)]
