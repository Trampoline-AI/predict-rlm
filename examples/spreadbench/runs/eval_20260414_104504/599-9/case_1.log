```repl
import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws_before = wb["Before"]
ws_after = wb["After"]

# Inspect relevant area more carefully
for ws in [ws_before, ws_after]:
    print(f"\nSheet {ws.title}")
    for r in range(2, min(ws.max_row, 21) + 1):
        if r <= 10 or r >= 17:
            g = ws.cell(r, 7)
            k = ws.cell(r, 11)
            l = ws.cell(r, 12) if ws.max_column >= 12 else None
            print(
                f"Row {r}: G={g.value!r} ({type(g.value).__name__}), "
                f"K={k.value!r} ({type(k.value).__name__}), "
                f"G_fmt={g.number_format!r}, K_fmt={k.number_format!r}, "
                f"K_formula={isinstance(k.value, str) and k.value.startswith('=')}"
                + (f", L={l.value!r}" if l else "")
            )

# Apply update to Before sheet only
updated_rows = []
preserved_rows = []
for r in range(2, ws_before.max_row + 1):
    g = ws_before.cell(r, 7)
    k = ws_before.cell(r, 11)
    # only act on actual data rows; if G has a value, transfer to K
    if g.value is not None and g.value != "":
        if k.value != g.value:
            updated_rows.append((r, k.value, g.value))
        ws_before.cell(r, 11).value = g.value
        ws_before.cell(r, 11).number_format = g.number_format
    else:
        preserved_rows.append((r, k.value))

print("\nUpdated rows count:", len(updated_rows))
print("First updated rows:", updated_rows[:10])
print("Preserved rows with blank G and existing/blank K (sample):", preserved_rows[:10])

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalc:", result)

# Restore sheet names if altered
orig_names = ["Before", "After"]
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed after recalc:", wb2.sheetnames)
    for i, name in enumerate(orig_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to", orig_names)

# Verify output values
ver = load_workbook(out_path, data_only=True)
print("Verified sheet names:", ver.sheetnames)
vws = ver["Before"]
for r in [2,3,4,5,9,19,20,21]:
    print(f"Before row {r}: G={vws.cell(r,7).value!r}, K={vws.cell(r,11).value!r}")
