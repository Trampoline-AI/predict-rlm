import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load and modify
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before change:")
print("A1:", ws["A1"].value)
print("B1:", ws["B1"].value)
print("C1:", ws["C1"].value)

ws["C1"] = "=LEFT(A1,2)&RIGHT(A1,5)"

print("Written formula to C1:", ws["C1"].value)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # rename sheets back by position
    for i, expected in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formula and cached value
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Final formula in C1:", ws_formula["C1"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("Verified values:")
print("A1:", ws_values["A1"].value)
print("B1:", ws_values["B1"].value)
print("C1:", ws_values["C1"].value)

final_output_spreadsheet = output_path
```
