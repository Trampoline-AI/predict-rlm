import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)
print("Input file:", input_spreadsheet)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 values / headers:", headers)
    
    sample_first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, sample_first_end + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
    
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
    
    # Explicitly inspect columns A:C and formulas/current values
    print("Inspect A:C cells:")
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = []
        for c in range(1, min(3, ws.max_column) + 1):
            cell = ws.cell(r, c)
            vals.append((f"{get_column_letter(c)}{r}", cell.value))
        print(vals)
