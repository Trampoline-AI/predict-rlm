def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # find actual non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("first non-empty row:", nonempty_rows[0], "last non-empty row:", nonempty_rows[-1])
    
    headers1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print("Row 1 values:", headers1)
    if headers2:
        print("Row 2 values:", headers2)
    
    # sample first 10 rows
    print("First 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, row)
    
    # sample last 5 rows
    print("Last 5 rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, row)
    
    # inspect column A specifically
    print('Rows where column A == "Code":')
    code_rows = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if isinstance(v, str) and v.strip() == "Code":
            code_rows.append(r)
    print(code_rows[:50], "count=", len(code_rows))
    
    # show neighborhoods around first several Code rows
    for r in code_rows[:10]:
        print(f"Neighborhood around row {r}:")
        for rr in range(max(1, r-3), min(ws.max_row, r+3) + 1):
            vals = [ws.cell(rr, c).value for c in range(1, min(ws.max_column, 6) + 1)]
            print(" ", rr, vals)

for ws in wb.worksheets:
    sheet_summary(ws)
