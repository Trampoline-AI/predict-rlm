ws = wb[wb.sheetnames[0]]

print("Inspect R/S/U rows 11-20 with formulas/types:")
for r in range(11, ws.max_row + 1):
    rv = ws[f"R{r}"].value
    sv = ws[f"S{r}"].value
    uv = ws[f"U{r}"].value
    print(r, {"R": rv, "R_type": type(rv).__name__, "S": sv, "U": uv})

# Determine rows needing output: rows where S or U has data, excluding header
target_rows = []
for r in range(2, ws.max_row + 1):
    if ws[f"S{r}"].value is not None or ws[f"U{r}"].value is not None:
        target_rows.append(r)
