```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb["Sheet1"]

# determine actual data range in A:B excluding header row
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if ws[f"A{r}"].value is not None or ws[f"B{r}"].value is not None:
        last_data_row = r
        break

print("Data rows for A:B:", 2, "to", last_data_row)
for r in range(2, last_data_row + 1):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

print("Target area before write:")
for r in range(5, 9):
    print(r, ws[f"E{r}"].value, ws[f"F{r}"].value)

# compute expected counts in Python for verification
items = [ws[f"E{r}"].value for r in range(6, 9)]
py_counts = {}
for item in items:
    count = 0
    for r in range(2, last_data_row + 1):
        a = ws[f"A{r}"].value
        b = ws[f"B{r}"].value
        if b == item or (b in (None, "") and a == item):
            count += 1
    py_counts[item] = count
print("Python expected counts:", py_counts)

# write formulas in F6:F8
for r in range(6, 9):
    formula = f'=COUNTIF($B$2:$B${last_data_row},E{r})+COUNTIFS($B$2:$B${last_data_row},"",$A$2:$A${last_data_row},E{r})'
    ws[f"F{r}"] = formula
    print(f"Writing F{r}:", formula)

outfile = "/sandbox/output/output_spreadsheet/" + os.path.basename(infile)
wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# reload and restore sheet names if needed
orig_names = wb.sheetnames
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    # rename by position
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_names)

# verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formulas now:")
for r in range(6, 9):
    print(f"F{r} formula:", wsf[f"F{r}"].value)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
print("Verified target values:")
for r in range(6, 9):
    print(f"E{r}={wsv[f'E{r}'].value!r}, F{r}={wsv[f'F{r}'].value!r}")

output_spreadsheet = outfile
```
