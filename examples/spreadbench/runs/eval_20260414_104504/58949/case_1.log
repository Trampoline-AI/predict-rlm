```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
src = wb["Extract"]
dst = wb["Desired Result"]

# Reconfirm target area and headers
headers = [dst.cell(1, c).value for c in range(1, dst.max_column + 1)]
people_existing = [dst.cell(r, 1).value for r in range(2, dst.max_row + 1)]
print("Target sheet:", dst.title)
print("Headers:", headers)
print("Existing person rows:", people_existing)

# Build mapping from Extract
records = {}
people_order = []
for r in range(2, src.max_row + 1):
    person = src.cell(r, 1).value
    car = src.cell(r, 2).value
    val = src.cell(r, 3).value
    if person not in records:
        records[person] = {}
        people_order.append(person)
    records[person][car] = val

print("Source mapping:", records)

# Ensure row count can hold all people already in source
needed_rows = 1 + len(people_order)
if dst.max_row < needed_rows:
    for r in range(dst.max_row + 1, needed_rows + 1):
        dst.cell(r, 1).value = people_order[r - 2]

# Write people column based on source order
for i, person in enumerate(people_order, start=2):
    dst.cell(i, 1).value = person

# Fill matrix according to predefined headers; use empty string for missing values
for r, person in enumerate(people_order, start=2):
    for c in range(2, dst.max_column + 1):
        car = dst.cell(1, c).value
        value = records.get(person, {}).get(car, "")
        dst.cell(r, c).value = value

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    for ws_obj, orig_name in zip(wb_check.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify with data_only view
wb_vals = load_workbook(outfile, data_only=True)
dst_vals = wb_vals["Desired Result"]
print("Verified Desired Result range:")
for r in range(1, dst_vals.max_row + 1):
    print(r, [dst_vals.cell(r, c).value for c in range(1, dst_vals.max_column + 1)])

output_spreadsheet = outfile
```
