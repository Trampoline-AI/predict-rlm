import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INSTRUCTION:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # detect non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, min(ws.max_row, 200) + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("First non-empty rows (up to 20 shown):", nonempty_rows[:20])

    headers1 = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    headers2 = [ws.cell(2,c).value for c in range(1, ws.max_column+1)] if ws.max_row >= 2 else []
    print("Row1:", headers1)
    if headers2:
        print("Row2:", headers2)

    # print first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        row = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, row)

    print("Last 5 rows:")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        row = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, row)

for ws in wb.worksheets:
    sheet_info(ws)
