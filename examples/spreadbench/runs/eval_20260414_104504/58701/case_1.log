```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
entry = wb["Entry Tab"]
table = wb["Table Tab"]

# Build mapping from Table Tab
mapping = {}
for r in range(2, table.max_row + 1):
    loc = table.cell(r, 1).value
    code = table.cell(r, 2).value
    if loc not in (None, ""):
        mapping[str(loc).strip()] = code

print("Mapping:", mapping)

# Show target area before writing
print("Before writing target area:")
for r in range(1, entry.max_row + 1):
    print(r, [entry.cell(r, c).value for c in range(1, 6)])

# Populate Entry Tab office code column E from location column B
for r in range(2, entry.max_row + 1):
    loc = entry.cell(r, 2).value
    target = entry.cell(r, 5)
    if loc not in (None, ""):
        key = str(loc).strip()
        target.value = mapping.get(key, target.value)

wb.save(output_path)
print("Saved", output_path)

recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Restore original sheet names if changed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb_after.sheetnames, "->", orig_sheet_names)
    for i, name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = name
    wb_after.save(output_path)

# Verify final output
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
entry_v = wb_verify["Entry Tab"]
for r in range(2, entry_v.max_row + 1):
    print(f"Row {r}: B{r}={entry_v[f'B{r}'].value!r}, E{r}={entry_v[f'E{r}'].value!r}")

final_output = output_path
```
