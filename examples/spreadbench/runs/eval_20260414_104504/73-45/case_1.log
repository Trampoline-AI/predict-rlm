```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
from openpyxl.utils import get_column_letter, column_index_from_string
import re, os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Verify target/supporting areas before modifying
print("Sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)
print("BD header/current target:", ws["BD1"].value)
print("Editable-area candidate F:BC headers:", [(get_column_letter(c), ws.cell(1,c).value) for c in range(6, 16)], "...", [(get_column_letter(c), ws.cell(1,c).value) for c in range(49, 56)])

for r in range(1, 8):
    vals = {f"{get_column_letter(c)}{r}": ws.cell(r,c).value for c in range(6, 11)}
    vals.update({f"BD{r}": ws.cell(r,56).value})
    print(vals)

# inspect existing styles in BD sample rows
for r in [2,3,4,25,33,34,35]:
    c = ws[f"BD{r}"]
    print(f"BD{r}: value={c.value!r}, style_id={c.style_id}, fill={c.fill.fill_type}/{c.fill.fgColor.rgb}, bold={c.font.bold}, color_type={c.font.color.type if c.font.color else None}, color_rgb={c.font.color.rgb if c.font.color and c.font.color.type=='rgb' else None}")

# Use existing blank area F column onward as editable pattern list.
# Seed a starter list from the sample texts/examples in instruction so the workbook becomes usable/editable.
starter_patterns = [
    "led","jumped","urged","dominant","win","too","good","imp","strong","finish",
    "tried hard","tough","ran away","too strong","no finish","no danger","battled",
    "faded","fought","would not lie down","tkld","tuff","grnd","closed well"
]

# Only write starter patterns into empty cells, preserving any existing user data
written = []
for i, pat in enumerate(starter_patterns, start=2):
    cell = ws.cell(i, 6)  # column F
    if cell.value in (None, ""):
        cell.value = pat
        written.append(f"F{i}")
print("Starter patterns written to F:", written[:10], "count", len(written))

# Read pattern list from F:BC rows 2:max_row
raw_patterns = []
for c in range(6, 56):  # F:BC
    for r in range(2, ws.max_row + 1):
        v = ws.cell(r, c).value
        if v is None:
            continue
        s = str(v).strip()
        if s:
            raw_patterns.append(s)

# de-duplicate preserving order
patterns = []
seen = set()
for p in raw_patterns:
    key = p.casefold()
    if key not in seen:
        seen.add(key)
        patterns.append(p)

print("Pattern count from editable list F:BC:", len(patterns))
print("First patterns:", patterns[:15])

# Whole-word aware matcher:
# - if pattern contains spaces, punctuation, or digits, search literal substring allowing anywhere
# - if pattern is letters only, require word boundaries so 'too' won't match 'took'
def compile_pattern(p):
    esc = re.escape(p)
    if re.fullmatch(r"[A-Za-z]+", p):
        return re.compile(rf"(?i)(?<![A-Za-z0-9]){esc}(?![A-Za-z0-9])")
    else:
        return re.compile(esc, re.IGNORECASE)

compiled = [(p, compile_pattern(p)) for p in patterns]

# Highlight matched BD cells directly (robust in LibreOffice)
yellow = PatternFill(start_color="FFFFFF00", end_color="FFFFFF00", fill_type="solid")
red_bold = Font(b=True, color="FFFF0000", name=ws["BD2"].font.name or "Calibri", size=ws["BD2"].font.sz or 11)

matched_rows = []
for r in range(2, ws.max_row + 1):
    cell = ws.cell(r, 56)  # BD
    text = cell.value
    if text in (None, ""):
        continue
    s = str(text)
    found = [p for p, rx in compiled if rx.search(s)]
    if found:
        cell.fill = yellow
        cell.font = red_bold
        matched_rows.append((r, s, found[:8]))

print("Matched BD rows:", len(matched_rows))
print("First matched examples:")
for item in matched_rows[:10]:
    print(item)

# Save, recalc, reload, verify
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved:", out_path)

res = await recalculate(out_path)
print("Recalc:", res)

# Restore sheet name if changed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# Verification after save
check = load_workbook(out_path, data_only=False)
wsv = check[orig_names[0]]
print("Verify target header:", wsv["BD1"].value)
for addr in ["F2","F3","F4","F5","BD2","BD3","BD8","BD25","BD33"]:
    c = wsv[addr]
    print(addr, "value=", c.value, "fill=", c.fill.fgColor.rgb, "bold=", c.font.bold, "font_rgb=", c.font.color.rgb if c.font.color and c.font.color.type=="rgb" else None)

output_spreadsheet = out_path
```
