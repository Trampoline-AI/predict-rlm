        continue
    matches = [cats.get(category) for _, w, m, cats in data_rows if w == work and m == material]
    # Based on sample structure, take the non-zero matching value if present; otherwise 0 if rows exist, else blank
    val = None
    if matches:
        nonzero = [x for x in matches if x not in (None, 0, 0.0, "")]
        val = nonzero[0] if nonzero else 0
    ws.cell(r,4).value = val
    print(f"Row {r}: work={work}, cat={category}, material={material}, matches={matches} -> write {val}")

out_dir = "/sandbox/output/output_spreadsheet"
