import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # headers from first 3 rows for inspection
    for r in range(1, min(4, ws.max_row)+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", vals)
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # last 5 rows
    print("Last rows:")
    start = max(1, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # print formulas/nonempty cells in compact range
    print("Non-empty/formula cells in used range:")
    for r in range(1, ws.max_row+1):
        row_items = []
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if v is not None:
                if isinstance(v, str) and v.startswith("="):
                    row_items.append(f"{get_column_letter(c)}{r}={v}")
                else:
                    row_items.append(f"{get_column_letter(c)}{r}={v}")
        if row_items:
            print(" | ".join(row_items[:20]))

for ws in wb.worksheets:
    sheet_info(ws)
