# Build lookup from actual data table
headers = [ws.cell(4,c).value for c in range(1,6)]
cat_headers = headers[2:5]
print("Category headers:", cat_headers)

data_rows = []
for r in range(5, 11):
    work = ws.cell(r,1).value
    material = ws.cell(r,2).value
    cats = {ws.cell(4,c).value: ws.cell(r,c).value for c in range(3,6)}
    data_rows.append((r, work, material, cats))
print("Parsed data rows:", data_rows)

# Compute expected values and write them into D17:D22
for r in range(17, ws.max_row + 1):
    work = ws.cell(r,1).value
    category = ws.cell(r,2).value
    material = ws.cell(r,3).value
