import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Reload fresh workbook for modification
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]

modifications = []
for ws in wb.worksheets:
    first_match = None
    for r in range(1, ws.max_row + 1):
        val = ws.cell(r, 1).value
        if val is not None and str(val).strip().lower() == "invoice no.":
            first_match = r
            break
    if first_match and first_match > 1:
        print(f"Deleting rows 1:{first_match-1} on sheet {ws.title}")
        ws.delete_rows(1, first_match - 1)
        modifications.append((ws.title, first_match))
    else:
        print(f"No deletion needed on sheet {ws.title}; first_match={first_match}")

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Ensure sheet names preserved after recalculation
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheet_names)
    # rename sheets positionally if counts match
    if len(wb_check.sheetnames) == len(orig_sheet_names):
        for ws, orig_name in zip(wb_check.worksheets, orig_sheet_names):
            ws.title = orig_name
        wb_check.save(outfile)
    else:
        print("Warning: sheet count mismatch; not renaming automatically")
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify with data_only reload
verify_wb = load_workbook(outfile, data_only=True)
print("Verification sheet names:", verify_wb.sheetnames)
for ws in verify_wb.worksheets:
    print(f"Sheet {ws.title}: max_row={ws.max_row}, max_col={ws.max_column}")
    top_rows = []
    for r in range(1, min(ws.max_row, 5) + 1):
        top_rows.append((r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]))
    print("Top rows after deletion:", top_rows)
    print("A1 value:", ws["A1"].value)

output_spreadsheet = outfile
