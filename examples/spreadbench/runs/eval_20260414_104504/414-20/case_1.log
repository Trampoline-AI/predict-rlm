        if isinstance(val, str) and val.strip().lower() == "invoice no.":
            match_rows.append(r)
        elif val is not None and str(val).strip().lower() == "invoice no.":
            match_rows.append(r)
    print("Matching 'Invoice No.' rows in col A:", match_rows[:10], "count=", len(match_rows))
    if match_rows:
        first_match = match_rows[0]
