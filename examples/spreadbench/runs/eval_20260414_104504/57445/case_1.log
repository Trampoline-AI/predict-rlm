import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Inspect existing formulas/values more precisely
wb = load_workbook(infile)
ws = wb["Pricing"]
lookup = wb["Package & Weight Data"]

print("Existing Pricing E cells before change:")
for r in range(2, ws.max_row + 1):
    print(r, {
        "C": ws[f"C{r}"].value,
        "D": ws[f"D{r}"].value,
        "E": ws[f"E{r}"].value,
        "E_data_type": ws[f"E{r}"].data_type
    })

# Determine actual populated lookup range
last_lookup_row = 1
for r in range(lookup.max_row, 0, -1):
    if any(lookup.cell(r, c).value is not None for c in range(1, 5)):
        last_lookup_row = r
        break
print("Last populated lookup row:", last_lookup_row)

# Write formula to ALL populated data rows in Pricing column E
# Use INDEX/MATCH on boolean-product criteria, compatible with LibreOffice after recalc.
for r in range(2, ws.max_row + 1):
    if ws[f"A{r}"].value is None and ws[f"B{r}"].value is None and ws[f"C{r}"].value is None and ws[f"D{r}"].value is None:
        continue
    formula = (
        f'=IF(OR(C{r}="",D{r}=""),"",'
        f'INDEX(\'Package & Weight Data\'!$D$2:$D${last_lookup_row},'
        f'MATCH(1,('
        f'\'Package & Weight Data\'!$A$2:$A${last_lookup_row}=C{r})*'
        f'(D{r}>=\'Package & Weight Data\'!$B$2:$B${last_lookup_row})*'
        f'(D{r}<=\'Package & Weight Data\'!$C$2:$C${last_lookup_row}),0)))'
    )
    ws[f"E{r}"] = formula

print("\nFormulas written to Pricing!E2:E5:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"E{r}"].value)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if needed
orig_names = ["Pricing", "Package & Weight Data"]
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    for i, expected in enumerate(orig_names):
        wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Renamed sheets back to:", wb2.sheetnames)

# Verify with data_only=True
