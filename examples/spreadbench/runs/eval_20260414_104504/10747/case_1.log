Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Inspect computed values for sanity
wb_formula = load_workbook(infile)
ws = wb_formula[wb_formula.sheetnames[0]]
wb_values = load_workbook(infile, data_only=True)
wsv = wb_values[wb_values.sheetnames[0]]

print("Original sheet names:", wb_formula.sheetnames)
print("Target cell K6 current formula:", ws["K6"].value)
print("Lookup criteria I3, J3:", ws["I3"].value, ws["J3"].value)
print("Base table A3:C8 values with computed net profit:")
for r in range(3, 9):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, wsv[f"C{r}"].value, "formula:", ws[f"C{r}"].value)

# Determine expected sum from current cached values
year = ws["I3"].value
share = ws["J3"].value
expected = 0
matches = []
for r in range(3, 9):
    if ws[f"A{r}"].value == year and ws[f"B{r}"].value == share:
        val = wsv[f"C{r}"].value
        matches.append((r, val))
        if isinstance(val, (int, float)):
            expected += val
print("Matching rows for I3/J3:", matches, "expected sum:", expected)

# Copy workbook and fix formula in the same target cell
shutil.copy(infile, outfile)
wb = load_workbook(outfile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Correct formula: sum net profit in C by matching year in A and share no in B
ws["K6"] = '=SUMIFS($C$3:$C$8,$A$3:$A$8,$I$3,$B$3:$B$8,$J$3)'
print("Written K6 formula:", ws["K6"].value)

wb.save(outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# If recalculation changed sheet names, rename back
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)

# Verify output
wb_check_formula = load_workbook(outfile)
print("Verified sheet names:", wb_check_formula.sheetnames)
wsf = wb_check_formula[orig_sheetnames[0]]
print("Final K6 formula:", wsf["K6"].value)

wb_check = load_workbook(outfile, data_only=True)
wsc = wb_check[orig_sheetnames[0]]
print("Final K6 cached value:", wsc["K6"].value)
print("K3,K4 existing outputs:", wsc["K3"].value, wsc["K4"].value)
print("I3,J3 values:", wsc["I3"].value, wsc["J3"].value)
print("Expected sum from matching rows:", expected)

output_spreadsheet = outfile
```
