import os, shutil
from openpyxl import load_workbook

# Reopen and inspect all matching/nonmatching rows explicitly
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

ref = ws["G2"].value
print("Reference from G2:", ref)

matches = []
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    cde = [ws.cell(r, col).value for col in range(3, 6)]
    is_match = (a == ref) or (b == ref)
    if is_match:
        matches.append((r, a, b, cde))
print("Matching rows:")
for item in matches:
    print(item)

total = 0
included = []
excluded = []
for r, a, b, cde in matches:
    for idx, v in enumerate(cde, start=3):
        if isinstance(v, (int, float)) and not isinstance(v, bool):
            total += v
            included.append((r, idx, v))
        else:
            if v is not None:
                excluded.append((r, idx, v, type(v).__name__))

print("Included numeric cells:", included)
print("Excluded non-numeric/nonfilled cells (non-None only):", excluded)
print("Computed total:", total)

# Confirm target cell before writing
print("Before write H2:", ws["H2"].value)

ws["H2"] = total

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# recalc
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Ensure sheet names preserved after recalc
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames:
    sheets = wb_after.sheetnames[:]
    for i, old_name in enumerate(sheets):
        wb_after[old_name].title = wb.sheetnames[i]
    wb_after.save(out_path)
    print("Renamed sheets back to:", wb.sheetnames)

# Verify with data_only
verify_wb = load_workbook(out_path, data_only=True)
verify_ws = verify_wb[wb.sheetnames[0]]
print("Verified G2:", verify_ws["G2"].value)
print("Verified H2:", verify_ws["H2"].value)

output_spreadsheet = out_path
```
