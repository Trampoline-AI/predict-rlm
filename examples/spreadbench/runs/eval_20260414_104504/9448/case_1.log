import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print("\n=== SHEET ===", s)
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    # first 10 rows
    first_n = min(ws.max_row, 10)
