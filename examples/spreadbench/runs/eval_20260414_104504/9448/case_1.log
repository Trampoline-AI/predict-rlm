Code:
```repl
from openpyxl import load_workbook
from datetime import datetime
import os

path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))

wb = load_workbook(path)
ws = wb["Data"]

# Inspect exact target area before modification
print("Pre-write U8:U18:")
for r in range(8, 19):
    print(r, ws.cell(r, 21).value, ws.cell(r, 21).number_format)

print("Headers I:T row6/year and row7/month:")
years_raw = [ws.cell(6, c).value for c in range(9, 21)]
months = [ws.cell(7, c).value for c in range(9, 21)]
print("row6:", years_raw)
print("row7:", months)

# Forward-fill year headers across I:T
effective_years = []
current_year = None
for v in years_raw:
    if isinstance(v, int):
        current_year = v
    effective_years.append(current_year)
print("effective_years:", effective_years)

month_map = {
    "January": 1, "February": 2, "March": 3, "April": 4, "May": 5, "June": 6,
    "July": 7, "August": 8, "September": 9, "October": 10, "November": 11, "December": 12
}

# Determine actual data rows
last_row = 8
for r in range(9, ws.max_row + 1):
    if ws.cell(r, 7).value is not None or ws.cell(r, 8).value is not None:
        last_row = r
print("last_row:", last_row)

# Print source rows G:U
print("Source rows 9:last_row, G:U")
for r in range(9, last_row + 1):
    print(r, [ws.cell(r, c).value for c in range(7, 22)])

# Write literal dates in U based on last positive sale (>0) from I:T
for r in range(9, last_row + 1):
    sales = [ws.cell(r, c).value for c in range(9, 21)]
    last_idx = None
    for i, v in enumerate(sales):
        if isinstance(v, (int, float)) and v > 0:
            last_idx = i
    if last_idx is None:
        ws.cell(r, 21).value = None
    else:
        yr = effective_years[last_idx]
        mo_name = months[last_idx]
        mo_num = month_map.get(mo_name)
        dt = datetime(yr, mo_num, 1)
        ws.cell(r, 21).value = dt
        ws.cell(r, 21).number_format = "m/d/yy"
        print(f"Row {r}: last positive sale at {chr(73+last_idx)} -> {mo_name} {yr} -> U{r}={dt.date()}")

wb.save(out_path)
print("Saved:", out_path)

res = await recalculate(out_path)
print("Recalc:", res)

# Restore original sheet names if recalculation changed them
orig_names = wb.sheetnames
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names:
    print("Renaming sheets back:", wb_check.sheetnames, "->", orig_names)
    for i, nm in enumerate(orig_names):
        wb_check.worksheets[i].title = nm
    wb_check.save(out_path)

# Verify
wbf = load_workbook(out_path, data_only=False)
wbv = load_workbook(out_path, data_only=True)
wsf = wbf["Data"]
wsv = wbv["Data"]

print("Post-write verification U8:U18:")
for r in range(8, last_row + 1):
    print(
        r,
        "formula/value=", wsf.cell(r, 21).value,
        "cached=", wsv.cell(r, 21).value,
        "fmt=", wsf.cell(r, 21).number_format
    )

output_spreadsheet = out_path
```
