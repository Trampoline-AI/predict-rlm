import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        print("Header row 2:", row_values(ws, 2, ws.max_column))
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("First rows sample:")
    for r in first_rows:
        print(r, row_values(ws, r, ws.max_column))
    print("Last rows sample:")
    for r in last_rows:
        print(r, row_values(ws, r, ws.max_column))

    # inspect column A and find numeric-heavy columns
    numeric_counts = {}
    for c in range(1, ws.max_column + 1):
        count = 0
        samples = []
        for r in range(2, ws.max_row + 1):
            v = ws.cell(r, c).value
            if isinstance(v, (int, float)) and not isinstance(v, bool):
                count += 1
                if len(samples) < 5:
                    samples.append(v)
        numeric_counts[c] = (count, samples)
    print("Numeric counts by column:")
    for c in range(1, ws.max_column + 1):
        count, samples = numeric_counts[c]
        print(get_column_letter(c), headers[c-1], "->", count, "sample", samples)

    print("Column A current values sample:")
    for r in list(range(1, min(ws.max_row, 10)+1)) + [rr for rr in range(max(1, ws.max_row-4), ws.max_row+1) if rr > 10]:
        print(f"A{r} =", ws[f"A{r}"].value)
