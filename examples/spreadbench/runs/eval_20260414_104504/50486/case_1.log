import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Re-open and inspect exact target area/formulas
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Target sheet:", ws.title)
for coord in ["A1","C1","D1","A2","C2","D2","A3","C3","D3","A4","C4","D4","A5","C5","D5"]:
    print(coord, "=", ws[coord].value)

# Check formulas in relevant columns
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    formula_flags = [isinstance(v, str) and v.startswith("=") for v in vals]
    if any(v is not None for v in vals):
        print(f"Row {r} values={vals} formulas={formula_flags}")

# Apply logic only to rows with actual data in CHEP/LOSCAM columns
changed = []
for r in range(2, ws.max_row + 1):
    c_val = ws.cell(r, 3).value  # CHEP
    d_val = ws.cell(r, 4).value  # LOSCAM
    a_cell = ws.cell(r, 1)

    has_c_num = isinstance(c_val, (int, float)) and not isinstance(c_val, bool)
    has_d_num = isinstance(d_val, (int, float)) and not isinstance(d_val, bool)

    # Leave fully empty rows untouched
    if not has_c_num and not has_d_num:
        continue

    desired = None
    if has_c_num and not has_d_num:
        desired = "Chep"
    elif has_d_num and not has_c_num:
        desired = "Loscam"
    elif has_c_num and has_d_num:
        # Not present here; preserve/choose CHEP-first if both numeric
        desired = "Chep"

    current = a_cell.value
    if current != desired:
        a_cell.value = desired
        changed.append((r, current, desired, c_val, d_val))

print("Changed rows:", changed)

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position back to original names
    for i, sname in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = sname
    wb2.save(outfile)
    print("Restored sheet names:", orig_sheetnames)

# Verify final values using data_only
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_sheetnames[0]]
for coord in ["A1","A2","A3","A4","A5","C2","D2","C3","D3","C4","D4","C5","D5"]:
    print("VERIFY", coord, "=", wsv[coord].value)

output_spreadsheet = outfile
