import os, shutil
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load original workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Unmerge all merged cells first
merged_ranges = [str(rng) for rng in ws.merged_cells.ranges]
print("Unmerging:", merged_ranges)
for rng in merged_ranges:
    ws.unmerge_cells(rng)

def unique_count(values):
    seen = set()
    for v in values:
        if v not in (None, ""):
            seen.add(v)
    return len(seen)

# Compute counts from exact requested ranges
count1 = unique_count([ws[f"E{r}"].value for r in range(2, 11)])
count2 = unique_count([ws[f"E{r}"].value for r in range(11, 21)])
count3 = unique_count([ws[f"E{r}"].value for r in range(21, 25)])
print("Computed counts:", count1, count2, count3)

# Write to exact target cells
ws["H10"] = count1
ws["H20"] = count2
ws["H24"] = count3

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice renamed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Restored sheet names:", original_sheetnames)

# Verification with data_only after recalculation
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]
for coord in ["H10", "H20", "H24"]:
    print(coord, "=", wsv[coord].value)

output_spreadsheet = outfile
