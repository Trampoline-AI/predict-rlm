import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and preserve original sheet names
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify target header/cells before writing
print("Target header E5:", ws["E5"].value)
for r in range(6, 14):
    print(f"Before E{r}: B{r}={ws[f'B{r}'].value!r}, E{r}={ws[f'E{r}'].value!r}")

# Write formula to all relevant rows E6:E13
for r in range(6, 14):
    ws[f"E{r}"] = f'=IF(B{r}="Deposit","Revenue",IF(B{r}="Withdrawal","Expenses",""))'

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheetnames after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # rename back by position
    for i, old_name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = old_name
    wb_check.save(outfile)
    print("Restored sheet names:", original_sheetnames)

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Formulas in E6:E13:")
for r in range(6, 14):
    print(r, ws_formula[f"E{r}"].value)

# Verify recalculated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("Verified values in E6:E13:")
for r in range(6, 14):
    print(r, f"B{r}={ws_values[f'B{r}'].value!r}", f"E{r}={ws_values[f'E{r}'].value!r}")

output_spreadsheet = outfile
