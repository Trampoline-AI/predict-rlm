if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify final values after recalculation
