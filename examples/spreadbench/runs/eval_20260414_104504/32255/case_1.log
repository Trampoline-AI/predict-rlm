for r in range(2, 14):
    print(r, "A=", wsv[f"A{r}"].value, "D=", wsv[f"D{r}"].value)

# Load workbook for editing
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print existing formulas in target column D
print("\nExisting formulas in D2:D13:")
for r in range(2, 14):
    print(r, ws[f"D{r}"].value)

