import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]

whp = wb["WHP"]
data = wb["WHP DATA"]

# Build mapping from WHP DATA: site -> (EEG, Dis, LTU)
site_map = {}
for r in range(1, data.max_row + 1):
    site = data.cell(r, 2).value  # col B
    eeg = data.cell(r, 3).value   # col C
    dis = data.cell(r, 4).value   # col D
    ltu = data.cell(r, 5).value   # col E
    if isinstance(site, str):
        s = site.strip()
        # data rows are those with a site name and numeric values in C:E
        if s and s.lower() not in {"go live 1/3/18", "local london partnership", "central london forward", "total", "referral type"}:
            if any(v is not None for v in (eeg, dis, ltu)):
                site_map[s] = (eeg, dis, ltu)

print("Source site_map:", site_map)

# Verify targets before writing
print("Before write WHP rows 7-8:")
for r in range(7, whp.max_row + 1):
    print(r, [whp.cell(r, c).value for c in range(3, 9)])

# Fill WHP rows based on site names in column C
written = []
for r in range(7, whp.max_row + 1):
    site = whp.cell(r, 3).value  # C
    label = whp.cell(r, 4).value # D
    if isinstance(site, str) and site.strip() in site_map:
        eeg, dis, ltu = site_map[site.strip()]
        whp.cell(r, 5).value = eeg   # E
        whp.cell(r, 6).value = dis   # F
        whp.cell(r, 7).value = ltu   # G
        whp.cell(r, 8).value = f"=SUM(E{r}:G{r})"  # H YTD
        written.append((r, site, eeg, dis, ltu, whp.cell(r, 8).value))

print("Written rows:", written)

wb.save(outfile)
print("Saved to:", outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify with data_only after recalc
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
vwhp = wbv["WHP"]
print("Final target cells C6:H8:")
for r in range(6, 9):
