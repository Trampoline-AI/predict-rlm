from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.styles import numbers
from datetime import datetime
import os, shutil

# Re-inspect exact target area and formats before modifying
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Target table rows 11:16 cols F:J before write")
for r in range(11, 17):
    row = []
    for c in range(6, 11):
        cell = ws.cell(r, c)
        v = cell.value
        try:
            from openpyxl.worksheet.formula import ArrayFormula
            if isinstance(v, ArrayFormula):
                v = f"ArrayFormula({v.text})"
        except Exception:
            pass
        row.append((f"{get_column_letter(c)}{r}", v, cell.number_format))
    print(row)

# Show source data summary and unique products/dates
products = sorted({ws.cell(r, 3).value for r in range(4, ws.max_row + 1) if ws.cell(r, 3).value is not None})
dates = []
for r in range(4, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None and v not in dates:
        dates.append(v)
print("Unique products:", products)
print("Unique dates:", dates)

# Build formulas in optimal table G12:J15; skip last row because no next date exists
last_data_row = ws.max_row
src_start = 4
src_end = last_data_row

target_rows = range(12, 16)  # rows with current date and a next date in F
target_cols = range(7, 11)   # G:J products from headers row 11

for r in target_rows:
    current_date = ws[f"F{r}"].value
    next_date = ws[f"F{r+1}"].value
    print(f"Row {r}: current={current_date}, next={next_date}")
    for c in target_cols:
        header = ws.cell(11, c).value
        addr = f"{get_column_letter(c)}{r}"
        print("Before", addr, ws[addr].value, "header", header)
        if current_date is None or next_date is None or header is None:
            ws[addr] = None
            continue
        # cumulative subtraction with dynamic product header and next-row date end boundary
        formula = (
            f'=SUMPRODUCT((($A$4:$A${src_end}+$B$4:$B${src_end})>=F{r}+$F$1)'
            f'*(($C$4:$C${src_end})={get_column_letter(c)}$11)'
            f'*($D$4:$D${src_end}))'
            f'-SUMPRODUCT((($A$4:$A${src_end}+$B$4:$B${src_end})>F{r+1}+$F$2)'
            f'*(($C$4:$C${src_end})={get_column_letter(c)}$11)'
            f'*($D$4:$D${src_end}))'
        )
        ws[addr] = formula

# Ensure last date row does not calculate
for c in target_cols:
    ws.cell(16, c).value = None

# Change formatting of G12:J15 from accounting to currency
currency_fmt = '$#,##0.00'
for r in range(12, 16):
    for c in range(7, 11):
        ws.cell(r, c).number_format = currency_fmt

# Save
infile = os.path.basename(input_spreadsheet)
outpath = os.path.join("/sandbox/output/output_spreadsheet", infile)
wb.save(outpath)
print("Saved to", outpath)

# Recalculate
result = await recalculate(outpath)
print("Recalculate:", result)

# Restore original sheet names if needed
orig_names = load_workbook(input_spreadsheet).sheetnames
wb2 = load_workbook(outpath)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(outpath)

# Verify formulas and calculated values
wb_formula = load_workbook(outpath, data_only=False)
wsf = wb_formula[orig_names[0]]
print("Formulas written G12:J16")
for r in range(12, 17):
    print(r, [(f"{get_column_letter(c)}{r}", wsf.cell(r, c).value, wsf.cell(r, c).number_format) for c in range(7, 11)])

wb_val = load_workbook(outpath, data_only=True)
wsv = wb_val[orig_names[0]]
print("Calculated values G12:J16")
for r in range(12, 17):
    print(r, [(f"{get_column_letter(c)}{r}", wsv.cell(r, c).value) for c in range(7, 11)])

output_spreadsheet = outpath
