import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def nonempty_row_count(ws):
    last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            last = r
    return last

def headers_for_row(ws, r):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    return vals

for s in wb.sheetnames:
    ws = wb[s]
    nr = nonempty_row_count(ws)
    print(f"\n--- Sheet: {s} ---")
    print("max_row/max_col:", ws.max_row, ws.max_column, "nonempty_rows:", nr)
    for hr in [1,2,3]:
        if hr <= ws.max_row:
            vals = headers_for_row(ws, hr)
            print(f"Row {hr} values:", vals[:min(15, len(vals))])
    # print first 10 rows and last 5 nonempty rows, trimmed
    rows_to_show = list(range(1, min(nr, 10) + 1))
    tail_start = max(1, nr - 4)
    for r in range(tail_start, nr + 1):
        if r not in rows_to_show:
            rows_to_show.append(r)
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"R{r}:", vals[:min(20, len(vals))])

# Also inspect tables and named ranges for clues
