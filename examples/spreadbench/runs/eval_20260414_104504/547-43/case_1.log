for s in wb.sheetnames:
    ws = wb[s]
    if ws.tables:
        print("Sheet", s, "tables:", list(ws.tables.keys()))
        for tname, tbl in ws.tables.items():
            print(" ", tname, tbl.ref)
    else:
        print("Sheet", s, "tables: none")

print("Defined names:")
for dn in wb.defined_names.definedName:
    print(dn.name, "->", dn.attr_text)
