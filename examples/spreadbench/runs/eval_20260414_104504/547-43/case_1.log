import os, shutil
from openpyxl import load_workbook

# Reload for clean manipulation
wb = load_workbook(input_spreadsheet)
print("Sheets:", wb.sheetnames)

# Inspect Expected fully enough to confirm target and formulas
ws_exp = wb["Expected"]
print("Expected dimensions:", ws_exp.max_row, ws_exp.max_column)
for r in range(1, ws_exp.max_row + 1):
    vals = [ws_exp.cell(r, c).value for c in range(1, ws_exp.max_column + 1)]
    if r <= 10 or r > ws_exp.max_row - 5:
        print(f"Expected R{r}:", vals)

# Check for formulas in Expected target area
formula_cells = []
for r in range(1, ws_exp.max_row + 1):
    for c in range(1, ws_exp.max_column + 1):
        v = ws_exp.cell(r, c).value
        if isinstance(v, str) and v.startswith("="):
            formula_cells.append((r, c, v))
print("Formula cells in Expected:", formula_cells[:10], "count:", len(formula_cells))

ws_emp = wb["Emp"]
ws_lookup = wb["Lookup"]

# Identify headers and exact columns
emp_headers = [ws_emp.cell(1, c).value for c in range(1, ws_emp.max_column + 1)]
lookup_headers = [ws_lookup.cell(1, c).value for c in range(1, ws_lookup.max_column + 1)]
expected_headers = [ws_exp.cell(1, c).value for c in range(1, ws_exp.max_column + 1)]
print("Emp headers:", emp_headers)
print("Lookup headers:", lookup_headers)
print("Expected headers:", expected_headers)

id_cols = ["seqno", "Empno", "ename", "Jobid"]
var_cols = emp_headers[4:]  # verified from sheet structure
print("Identifier columns:", id_cols)
print("Variable columns to transpose:", var_cols)

# Build lookup map
lookup_map = {}
for r in range(2, ws_lookup.max_row + 1):
    variable = ws_lookup.cell(r, 1).value
    category = ws_lookup.cell(r, 2).value
    subcategory = ws_lookup.cell(r, 3).value
    if variable not in (None, ""):
        lookup_map[str(variable).strip()] = (category, subcategory)
print("Lookup map:", lookup_map)

# Generate transformed rows
output_rows = []
for r in range(2, ws_emp.max_row + 1):
    row_data = {emp_headers[c-1]: ws_emp.cell(r, c).value for c in range(1, ws_emp.max_column + 1)}
    # skip empty source rows
    if all(row_data.get(h) in (None, "") for h in emp_headers):
        continue
    for var in var_cols:
        cat, subcat = lookup_map.get(str(var).strip(), (None, None))
        output_rows.append([
            row_data["seqno"],
            row_data["Empno"],
            row_data["ename"],
            row_data["Jobid"],
            var,
            cat,
            subcat,
            row_data[var],
        ])

print("Generated row count:", len(output_rows))
print("First 8 generated rows:")
for row in output_rows[:8]:
    print(row)
print("Last 5 generated rows:")
for row in output_rows[-5:]:
    print(row)

# Write into EXISTING Expected sheet
# Clear existing body rows only
for r in range(2, ws_exp.max_row + 1):
    for c in range(1, ws_exp.max_column + 1):
        ws_exp.cell(r, c).value = None

for out_r, vals in enumerate(output_rows, start=2):
    for c, val in enumerate(vals, start=1):
        ws_exp.cell(out_r, c).value = val

# Save to output path with same filename
out_dir = "/sandbox/output/output_spreadsheet"
