import os, re
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Reload original input to avoid carrying forward wrong values
wb = load_workbook(infile)
ws = wb["Sheet3"]

print("Re-inspection of target area before fix:")
for r in range(3, 15):
    bval = ws[f"B{r}"].value
    print(r, "A=", ws[f"A{r}"].value, "B=", bval, "D=", ws[f"D{r}"].value, "E=", ws[f"E{r}"].value)

# Read named ranges exactly
def read_named_range_values(wb, name):
    dn = wb.defined_names[name]
    vals = []
    for sheet_name, cell_range in dn.destinations:
        rng = wb[sheet_name][cell_range]
        for row in rng:
            for cell in row:
                vals.append(cell.value)
    return vals

codes = [str(v).strip() for v in read_named_range_values(wb, "codes2") if v is not None]
months = [str(v).strip() for v in read_named_range_values(wb, "month") if v is not None]
mapping = dict(zip(codes, months))
print("Exact code->month mapping:", mapping)

# Correct logic: extract underscore-delimited parts and match exact token, not substring anywhere
filled = []
for r in range(3, ws.max_row + 1):
    a_val = ws[f"A{r}"].value
    if a_val is None or str(a_val).strip() == "":
        continue
    text = str(a_val).strip()
    tokens = text.split("_")
    print(f"Row {r} tokens:", tokens)

    found_code = None
    # Prefer exact token match against codes2
    for tok in tokens:
        if tok in mapping:
            found_code = tok
            break

    # fallback: 2-digit token regex if needed
    if found_code is None:
        m = re.search(r'(?<!\d)(0[1-9]|1[0-2])(?!\d)', text)
        if m and m.group(1) in mapping:
            found_code = m.group(1)

    if found_code is not None:
        ws[f"B{r}"] = mapping[found_code]
        filled.append((r, text, found_code, mapping[found_code]))
    else:
        ws[f"B{r}"] = None
        filled.append((r, text, None, None))

print("Filled results:")
for item in filled:
    print(item)

wb.save(outfile)
print("Saved fixed workbook to:", outfile)

orig_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if needed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    print("Restoring sheet names:", wb2.sheetnames, "->", orig_sheetnames)
    for wsi, orig in zip(wb2.worksheets, orig_sheetnames):
        wsi.title = orig
    wb2.save(outfile)

# Verify output after recalc
ver = load_workbook(outfile, data_only=True)
vws = ver["Sheet3"]
print("Verification B3:B14:")
for r in range(3, 15):
    print(r, vws[f"A{r}"].value, "=>", vws[f"B{r}"].value)

output_spreadsheet = outfile
