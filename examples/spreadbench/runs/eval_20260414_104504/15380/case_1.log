print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

print("\nDefined names:")
for name, dn in wb.defined_names.items():
    try:
        print(" -", name, "=>", dn.attr_text)
    except Exception:
        print(" -", name, "=>", dn)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    row1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1:", row1)

    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

    print("Last rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

    print("Key cells:")
    for coord in ["A1","A2","A3","B1","B2","B3","C1","C2","C3","D1","D2","D3"]:
        print(coord, "=", ws[coord].value)

def print_named_range(name):
    print(f"\nNamed range: {name}")
    dn = wb.defined_names.get(name)
    if dn is None:
        print("Not found")
        return
    try:
        destinations = list(dn.destinations)
    except Exception as e:
        print("Could not get destinations:", e)
        print("Raw:", dn)
        return
    print("destinations:", destinations)
    for sheet_name, cell_range in destinations:
        ws = wb[sheet_name]
        cells = ws[cell_range]
        vals = []
        if isinstance(cells, tuple):
            for row in cells:
                if isinstance(row, tuple):
                    for cell in row:
                        vals.append((cell.coordinate, cell.value))
                else:
                    vals.append((row.coordinate, row.value))
        else:
            vals.append((cells.coordinate, cells.value))
        print(sheet_name, cell_range, vals)

for nm in ["codes2", "month"]:
    print_named_range(nm)
