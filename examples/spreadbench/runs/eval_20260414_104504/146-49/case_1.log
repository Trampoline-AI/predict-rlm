from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Check row 1 data nature and target cells:")
for coord in ["A1","B1","C1","D1","E1","F1","G1","H1","G2","H2"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "data_type=", cell.data_type)

print("\nSample rows around top (A:H):")
for r in range(1, 16):
    print(r, [ws.cell(r,c).value for c in range(1,9)])

print("\nSample rows around bottom (A:H):")
for r in range(ws.max_row-10, ws.max_row+1):
    print(r, [ws.cell(r,c).value for c in range(1,9)])

# inspect formulas in G:H if any
print("\nG:H existing non-empty cells and formulas?")
for r in range(1, min(ws.max_row, 20)+1):
    for col in [7,8]:
        v = ws.cell(r,col).value
        if v is not None:
            print(f"{get_column_letter(col)}{r}:", repr(v), "data_type", ws.cell(r,col).data_type)

# Compute candidate pairs from col A
words = []
for r in range(1, ws.max_row+1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

wordset = set(words)
vowels = "AEIOU"
pairs = []
for w in words:
    if "S" not in w:
        continue
    for v in vowels:
        w2 = w.replace("S", v)
        if w2 != w and w2 in wordset:
            pair = (w2, w)  # example suggests vowel-version first, S-version second
            pairs.append(pair)

pairs_unique = sorted(set(pairs))
print("\nTotal words:", len(words))
print("Total matching pairs:", len(pairs_unique))
print("First 20 pairs:", pairs_unique[:20])
print("Last 20 pairs:", pairs_unique[-20:])
print("Example pair present?", ("KAGOULE","KAGOULS") in pairs_unique)
