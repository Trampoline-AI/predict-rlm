Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Gather dictionary words from column A
words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

wordset = set(words)
vowels = "AEIOU"

# Compute pairs: vowel-version first, S-version second
pairs = sorted({
    (w.replace("S", vowel), w)
    for w in words if "S" in w
    for vowel in vowels
    if w.replace("S", vowel) != w and w.replace("S", vowel) in wordset
})

print("Computed pairs:", len(pairs))
print("Current example in G1:H1:", ws["G1"].value, ws["H1"].value)

# Write starting at G2/H2; exclude example pair if already in G1:H1 to avoid duplicate
existing_top = (ws["G1"].value, ws["H1"].value)
pairs_to_write = [p for p in pairs if p != existing_top]
print("Pairs to write from row 2:", len(pairs_to_write))

# Clear existing output area in G:H rows 2..max_row
for r in range(2, ws.max_row + 1):
    ws.cell(r, 7).value = None
    ws.cell(r, 8).value = None

# Write results starting at row 2
for i, (a, b) in enumerate(pairs_to_write, start=2):
    ws.cell(i, 7).value = a
    ws.cell(i, 8).value = b

last_result_row = 1 + len(pairs_to_write)
print("Last result row before sort:", last_result_row)

# Sort entire used result range G1:H[last_result_row] together
result_rows = [(ws.cell(r, 7).value, ws.cell(r, 8).value) for r in range(1, last_result_row + 1)]
result_rows = [row for row in result_rows if row[0] is not None or row[1] is not None]
result_rows_sorted = sorted(result_rows, key=lambda x: ((x[0] or ""), (x[1] or "")))

for idx, (a, b) in enumerate(result_rows_sorted, start=1):
    ws.cell(idx, 7).value = a
    ws.cell(idx, 8).value = b

# Clear any leftover rows below sorted data
for r in range(len(result_rows_sorted) + 1, ws.max_row + 1):
    if ws.cell(r, 7).value is not None or ws.cell(r, 8).value is not None:
        ws.cell(r, 7).value = None
        ws.cell(r, 8).value = None

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
else:
    print("Sheet names preserved:", wb2.sheetnames)

# Verification reload
ver = load_workbook(outfile, data_only=True)
print("Verified sheet names:", ver.sheetnames)
vws = ver["Sheet1"]

print("Top 15 result rows G:H after sort:")
for r in range(1, min(15, len(result_rows_sorted)) + 1):
    print(r, vws.cell(r, 7).value, vws.cell(r, 8).value)

print("Bottom 10 result rows G:H after sort:")
start = max(1, len(result_rows_sorted) - 9)
for r in range(start, len(result_rows_sorted) + 1):
    print(r, vws.cell(r, 7).value, vws.cell(r, 8).value)

print("Cell G1/H1:", vws["G1"].value, vws["H1"].value)
print("Cell G2/H2:", vws["G2"].value, vws["H2"].value)
print("Final result count:", len(result_rows_sorted))
```
