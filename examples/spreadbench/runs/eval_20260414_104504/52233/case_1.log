import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and inspect target formulas again
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before modification:")
for r in range(7, 11):
    print(f"A{r}={ws[f'A{r}'].value}, B{r}={ws[f'B{r}'].value}")

# Use corrected formula with fixed row block and variable matched column
for r in range(7, 11):
    ws[f"B{r}"] = f'=SUM(INDEX($B$3:$Z$5,0,MATCH(A{r},$B$2:$Z$2,0)))'

print("\nAfter modification (formula strings):")
for r in range(7, 11):
    print(f"B{r}={ws[f'B{r}'].value}")

wb.save(outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("\nRecalculate result:", recalc_result)

# restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify with data_only
ver = load_workbook(outfile, data_only=True)
vws = ver[orig_sheetnames[0]]
print("\nVerified cached values in target range:")
for r in range(7, 11):
    print(f"A{r}={vws[f'A{r}'].value}, B{r}={vws[f'B{r}'].value}")

output_spreadsheet = outfile
