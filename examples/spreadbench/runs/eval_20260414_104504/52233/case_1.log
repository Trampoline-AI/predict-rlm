import os, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2,c).value for c in range(1, ws.max_column+1)]
        print("Row2 values:", headers2)
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # last 5 rows if distinct
    start_last = max(1, ws.max_row-4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, vals)

    # search formulas / cells with A7,B2:Z2 or INDEX/MATCH or SUM(INDEX
    hits = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                s = v.upper()
                if any(k in s for k in ["INDEX(", "MATCH(", "SUM(INDEX", "$B$2:$Z$2", "B3:B5", "A7"]):
                    hits.append((cell.coordinate, v))
    print("Relevant formula hits:", hits[:20], "count", len(hits))

    # print specific referenced cells if present
    for coord in ["A7","B2","C2","B3","B4","B5","C3","C4","C5"]:
        if ws.max_row >= int(''.join(filter(str.isdigit, coord))) and ws.max_column >= ord(''.join(filter(str.isalpha, coord)).upper())-64:
            try:
                print(coord, "=", ws[coord].value)
            except:
                pass
