import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Reinspect exact source and target before overwriting
last_h = 1
source_vals = []
for r in range(2, ws.max_row + 1):
    v = ws[f"H{r}"].value
    if v not in (None, ""):
        last_h = r
        source_vals.append(v)

unique_sorted = sorted(set(source_vals))
print("Source H2:H%d values:" % last_h, source_vals)
print("Unique sorted values to place in Q2:V2:", unique_sorted)
print("Current Q2:V2 before fix:", [ws[f"{c}2"].value for c in ["Q","R","S","T","U","V"]])

# Write exact target cells
target_cols = ["Q","R","S","T","U","V"]
for col, val in zip(target_cols, unique_sorted):
    ws[f"{col}2"] = val

# Clear any extra target cells beyond produced values within Q2:V2
for col in target_cols[len(unique_sorted):]:
    ws[f"{col}2"] = None

wb.save(outfile)
print("Saved fixed workbook:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore original sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != original_sheetnames:
