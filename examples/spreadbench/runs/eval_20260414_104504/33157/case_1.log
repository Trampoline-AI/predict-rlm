import os, shutil
from openpyxl import load_workbook

# Focused inspection of "list" sheet and formulas/target area before modifying
wb = load_workbook(input_spreadsheet)
print("Original sheets:", wb.sheetnames)

if "list" in wb.sheetnames:
    ws_list = wb["list"]
    print("\nlist sheet dims:", ws_list.max_row, ws_list.max_column)
    for r in range(1, ws_list.max_row + 1):
        print("list row", r, [ws_list.cell(r, c).value for c in range(1, ws_list.max_column + 1)])

ws = wb["Sheet1"]
print("\nTarget area before write:")
for r in range(1, ws.max_row + 1):
    print(r, {
        "B": ws[f"B{r}"].value, "C": ws[f"C{r}"].value,
        "D": ws[f"D{r}"].value, "E": ws[f"E{r}"].value,
        "F": ws[f"F{r}"].value, "G": ws[f"G{r}"].value,
        "H": ws[f"H{r}"].value, "I": ws[f"I{r}"].value,
        "J": ws[f"J{r}"].value, "K": ws[f"K{r}"].value,
    })

# Write formulas to K only for populated data rows where K is blank
for r in range(2, ws.max_row + 1):
    name = ws[f"A{r}"].value
    if name in (None, ""):
        continue
    current_k = ws[f"K{r}"].value
    if current_k not in (None, ""):
        continue
    # Compare J to the date columns and return the header label from row 1.
    # Guard blank J and use IFERROR to avoid issues.
    formula = (
        f'=IF(J{r}="","",'
        f'IF(J{r}=C{r},B$1,'
        f'IF(J{r}=E{r},D$1,'
        f'IF(J{r}=G{r},F$1,'
        f'IF(J{r}=I{r},H$1,"")))))'
    )
    ws[f"K{r}"] = formula

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore sheet names if recalc renamed them
wb_after = load_workbook(out_path)
current_names = wb_after.sheetnames
original_names = ["Sheet1", "list"]
print("Sheet names after recalc:", current_names)
if current_names != original_names and len(current_names) == len(original_names):
    for idx, s in enumerate(wb_after.worksheets):
        s.title = original_names[idx]
    wb_after.save(out_path)
    print("Renamed sheets back to:", original_names)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nFormulas in K:")
for r in range(2, wsf.max_row + 1):
    print(r, "J=", wsf[f"J{r}"].value, "K=", wsf[f"K{r}"].value)

wb_vals = load_workbook(out_path, data_only=True)
wsv = wb_vals["Sheet1"]
print("\nVerified cached values K2:K6 and supporting cols:")
for r in range(2, wsv.max_row + 1):
    print(r, {
        "Name": wsv[f"A{r}"].value,
        "J": wsv[f"J{r}"].value,
        "K": wsv[f"K{r}"].value,
        "C": wsv[f"C{r}"].value,
        "E": wsv[f"E{r}"].value,
        "G": wsv[f"G{r}"].value,
        "I": wsv[f"I{r}"].value,
    })

final_output_path = out_path
