from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title, "rows", ws.max_row, "cols", ws.max_column)

# print formulas in K column with actual text
for r in range(1, min(ws.max_row, 15) + 1):
    cell = ws[f"K{r}"]
    v = cell.value
    if isinstance(v, ArrayFormula):
        print(f"K{r} ArrayFormula text:", v.text, "ref:", v.ref)
    else:
        print(f"K{r} value:", v)

# inspect all used rows C:I with fills
def fill_repr(cell):
    f = cell.fill
    return (f.fill_type, f.fgColor.type, f.fgColor.rgb, f.patternType)

print("\nRows with values/fills in C:I")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r,c).value for c in range(3,10)]
    if any(v is not None for v in vals):
        rowparts = []
        for c in range(3,10):
            cell = ws.cell(r,c)
            rowparts.append(f"{get_column_letter(c)}{r}={cell.value!r}|fill={fill_repr(cell)}")
        print(" || ".join(rowparts))

# collect non-empty green-filled cells
greens = []
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r,c)
        if cell.value is not None:
            rgb = cell.fill.fgColor.rgb
            if cell.fill.fill_type == "solid" and rgb:
                greens.append((cell.coordinate, cell.value, rgb))
print("\nNon-empty solid-filled cells:")
for item in greens:
    print(item)

# inspect list of names and target left cells
print("\nName list / target area K:L")
for r in range(1, ws.max_row + 1):
    if ws[f"L{r}"].value is not None or ws[f"K{r}"].value is not None:
        kv = ws[f"K{r}"].value
        if isinstance(kv, ArrayFormula):
            kv = f"ArrayFormula(text={kv.text}, ref={kv.ref})"
        print(r, "K=", kv, "L=", ws[f"L{r}"].value)
