import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Thorough compact inspection of all non-empty rows and green-filled cells
def fill_rgb(cell):
    try:
        return cell.fill.fgColor.rgb
    except Exception:
        return None

print("Sheet names:", wb.sheetnames)
print("Sheet:", ws.title, "max_row:", ws.max_row, "max_col:", ws.max_column)
print("Headers row1:", [ws.cell(1,c).value for c in range(1, ws.max_column+1)])

print("\nFirst 10 rows:")
for r in range(1, min(10, ws.max_row)+1):
    print(r, [ws.cell(r,c).value for c in range(1, ws.max_column+1)])

print("\nLast 5 rows:")
for r in range(max(1, ws.max_row-4), ws.max_row+1):
    print(r, [ws.cell(r,c).value for c in range(1, ws.max_column+1)])

green_rows = []
green_cells = []
for r in range(1, ws.max_row+1):
    row_green = []
    for c in range(3, min(9, ws.max_column)+1):  # C:I
        cell = ws.cell(r,c)
        if cell.value is not None and cell.fill.fill_type == "solid" and fill_rgb(cell) == "FF92D050":
            row_green.append(cell.coordinate)
            green_cells.append((cell.coordinate, cell.value))
    if row_green:
        green_rows.append(r)

print("\nGreen rows detected:", green_rows)
print("Green non-empty cells:", green_cells)

print("\nTarget area K:L before write:")
for r in range(2, 9):
    kv = ws[f"K{r}"].value
    if hasattr(kv, "text"):
        kv = kv.text
    print(f"K{r}={kv} | L{r}={ws[f'L{r}'].value}")

# Determine contiguous green ranges in columns C:G only (where names appear)
name_ranges = []
for r in green_rows:
    vals = [ws.cell(r,c).value for c in range(3,8)]
    if any(v is not None for v in vals):
        name_ranges.append(f"C{r}:G{r}")

print("\nName ranges to count across:", name_ranges)

# Show expected counts from Python for verification
names = [ws[f"L{r}"].value for r in range(2,9)]
expected = {}
for name in names:
    count = 0
    for r in green_rows:
        for c in range(3,8):
            v = ws.cell(r,c).value
            if isinstance(v, str) and name and name.lower() in v.lower():
                count += 1
    expected[name] = count
print("Expected Python counts:", expected)

# Write formulas into K2:K8 (left of names list), replacing old array formulas
# Since color tests are not feasible in native formulas, count across the actual green-highlighted assignment rows.
for r in range(2, 9):
    formula_parts = [f'SUMPRODUCT(--ISNUMBER(SEARCH(L{r},{rng})))' for rng in name_ranges]
    formula = "=" + "+".join(formula_parts) if formula_parts else "=0"
    ws[f"K{r}"] = formula

print("\nTarget formulas written:")
for r in range(2, 9):
    print(f"K{r} -> {ws[f'K{r}'].value}")

# Save
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("\nRecalc:", recalc_result)

# Restore sheet names if recalculation changed them
orig_names = wb.sheetnames[:]
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for i, nm in enumerate(orig_names):
        wb2.worksheets[i].title = nm
    wb2.save(outfile)
    print("Restored sheet names:", orig_names)

# Verify with data_only
ver = load_workbook(outfile, data_only=False)
verd = load_workbook(outfile, data_only=True)
wsf = ver[orig_names[0]]
wsd = verd[orig_names[0]]

print("\nVerification K2:L8:")
for r in range(2, 9):
    print(
        r,
        "name=", wsf[f"L{r}"].value,
        "formula=", wsf[f"K{r}"].value,
        "value=", wsd[f"K{r}"].value,
        "expected=", expected[wsf[f"L{r}"].value]
    )

output_spreadsheet = outfile
