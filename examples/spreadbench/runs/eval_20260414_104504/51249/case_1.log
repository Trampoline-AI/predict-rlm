import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Reconfirm target cells/rows before writing
targets = []
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 3).value == "Result:":
        targets.append(r)

print("Target result rows based on column C == 'Result:':", targets)
for r in targets:
    print(f"Row {r}: B{r}={ws[f'B{r}'].value!r}, B{r+1}={ws[f'B{r+1}'].value!r}, current D{r}={ws[f'D{r}'].value!r}")

fill = PatternFill(start_color="E2EFDA", end_color="E2EFDA", fill_type="solid")

# Write formulas to D cells for each target row
for r in targets:
    formula = (
        f'=IF(AND(B{r}="Description A",B{r+1}=""),"Single A",'
        f'IF(AND(B{r}="Description B",B{r+1}=""),"Single B",'
        f'IF(AND(B{r}="Description A",B{r+1}="Description B"),"Multiple","")))'
    )
    ws[f"D{r}"] = formula
    ws[f"D{r}"].fill = fill
    print(f"Wrote D{r} formula:", formula)

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if necessary
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "restoring to", orig_sheetnames)
    for i, old_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)

# Verify with formulas visible
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula[orig_sheetnames[0]]
print("Verification formulas:")
for r in targets:
    print(f"D{r} formula/value:", wsf[f'D{r}'].value)

# Verify cached values after recalculation
wb_verify_values = load_workbook(outfile, data_only=True)
wsv = wb_verify_values[orig_sheetnames[0]]
print("Verification cached values:")
for r in targets:
    cell = wsv[f"D{r}"]
    print(f"D{r} cached value:", cell.value)

# Verify fills from non-data_only workbook
for r in targets:
    c = wsf[f"D{r}"]
    print(f"D{r} fill:", c.fill.fill_type, c.fill.start_color.rgb, c.fill.end_color.rgb)

output_spreadsheet = outfile
```
