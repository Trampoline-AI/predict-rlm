import os, shutil
from collections import defaultdict
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# determine true last used row
last_row = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
        last_row = r

# group rows by employee in encountered order
emp_rows = defaultdict(list)
for r in range(2, last_row + 1):
    emp = ws.cell(r, 1).value
    month = ws.cell(r, 3).value
    hours = ws.cell(r, 4).value
    if emp is None and month is None and hours is None:
        continue
    emp_rows[emp].append((r, hours))

# fill columns E and F for all relevant rows
for emp, items in emp_rows.items():
    for idx, (r, hours) in enumerate(items):
        if idx < 3:
            ws.cell(r, 5).value = "n/a"
            ws.cell(r, 6).value = "n/a - less that 4 weeks"
        else:
            avg = sum(items[j][1] for j in range(idx - 3, idx + 1)) / 4
            if float(avg).is_integer():
                val = int(avg)
            else:
                val = avg
            ws.cell(r, 5).value = val
            ws.cell(r, 6).value = "More than 48" if avg > 48 else "Less that 48"

wb.save(outfile)
print("Saved:", outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# restore original sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
else:
    print("Sheet names unchanged.")

# verify results with data_only
ver = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", ver.sheetnames)
vws = ver[orig_sheetnames[0]]

print("Target headers:", [vws.cell(1, c).value for c in range(1, 7)])
for r in range(2, last_row + 1):
    print(r, [vws.cell(r, c).value for c in range(1, 7)])

output_spreadsheet = outfile
