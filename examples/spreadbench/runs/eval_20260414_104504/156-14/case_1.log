infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Load and modify
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
targets = ["99250", "99251", "99252"]
deleted_summary = {}

for s in targets:
    ws = wb[s]
    rows_to_delete = []
    for r in range(6, ws.max_row + 1):
        v = ws.cell(r, 6).value
        txt = "" if v is None else str(v).strip().lower()
        if "to be processed" in txt:
            rows_to_delete.append(r)
    deleted_summary[s] = rows_to_delete[:]
    print(f"{s} rows marked for deletion:", rows_to_delete)
    for r in reversed(rows_to_delete):
        ws.delete_rows(r, 1)

wb.save(outfile)
print("Saved initial output to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for i, expected in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification with formulas/values cached
