def sheet_info(ws, sample_head=10, sample_tail=5, max_cols=12):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers[:max_cols])
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)]
        print("Row2 values:", headers2[:max_cols])
    # print first rows
    end_head = min(ws.max_row, sample_head)
    print(f"First {end_head} rows:")
    for r in range(1, end_head+1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols)+1)]
        print(r, vals)
    # print last rows
    start_tail = max(1, ws.max_row - sample_tail + 1)
    if start_tail <= ws.max_row:
        print(f"Last rows {start_tail}:{ws.max_row}:")
        for r in range(start_tail, ws.max_row+1):
            vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols)+1)]
            print(r, vals)

for s in wb.sheetnames:
    sheet_info(wb[s], sample_head=8, sample_tail=5, max_cols=10)

targets = ["99250", "99251", "99252"]
for s in targets:
    if s in wb.sheetnames:
        ws = wb[s]
        print(f"\n### Detailed inspection for target sheet {s}")
        for r in range(1, min(ws.max_row, 15)+1):
            print("row", r, "F:", ws[f"F{r}"].value)
        # print rows 6 onward where F has text
        matches = []
        processed = []
        accepted = []
        for r in range(6, ws.max_row+1):
            v = ws.cell(r, 6).value
            if v is not None and str(v).strip() != "":
                processed.append((r, v))
                txt = str(v).strip().lower()
                if "to be processed" in txt:
                    matches.append((r, v))
                if "accepted" in txt:
                    accepted.append((r, v))
        print("Nonblank F from row 6 onward (first 20):", processed[:20])
        print('Rows where F contains "to be processed":', matches[:50], "count=", len(matches))
        print('Rows where F contains "accepted":', accepted[:50], "count=", len(accepted))
    else:
