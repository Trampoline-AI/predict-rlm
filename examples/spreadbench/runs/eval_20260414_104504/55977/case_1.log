import os
from datetime import datetime
from openpyxl import load_workbook

infile = input_spreadsheet
orig_wb = load_workbook(infile)
orig_sheetnames = orig_wb.sheetnames[:]
ws = orig_wb["WEEKDAY"]

# Verify expected weekday names from actual dates before writing
print("Preview expected values from Python:")
for r in range(2, min(ws.max_row, 8) + 1):
    dt = ws[f"A{r}"].value
    if dt:
        py_day_no = dt.weekday() + 1  # Monday=1
        py_day_name = dt.strftime("%A")
        print(r, dt.date(), py_day_no, py_day_name, "existing:", ws[f"B{r}"].value, ws[f"C{r}"].value)

# Fill all rows that have a date in column A
for r in range(2, ws.max_row + 1):
    if ws[f"A{r}"].value not in (None, ""):
        ws[f"B{r}"] = f"=WEEKDAY(A{r},2)"
        ws[f"C{r}"] = f'=CHOOSE(B{r},"Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday")'

outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
orig_wb.save(outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore original sheet names if recalc changed them
check_wb = load_workbook(outfile)
if check_wb.sheetnames != orig_sheetnames:
    print("Sheet names changed:", check_wb.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        check_wb.worksheets[i].title = name
    check_wb.save(outfile)

# Verify formulas exist in target cells
verify_formula_wb = load_workbook(outfile, data_only=False)
vwsf = verify_formula_wb["WEEKDAY"]
print("Formula check B2:C6:")
for r in range(2, 7):
    print(r, vwsf[f"B{r}"].value, "|", vwsf[f"C{r}"].value)

# Verify computed values after recalculation
verify_wb = load_workbook(outfile, data_only=True)
vws = verify_wb["WEEKDAY"]
print("Computed verification rows 2:16:")
all_ok = True
for r in range(2, vws.max_row + 1):
    a = vws[f"A{r}"].value
    b = vws[f"B{r}"].value
    c = vws[f"C{r}"].value
    print(r, a.date() if hasattr(a, "date") else a, b, c)
    if a not in (None, "") and (b in (None, "") or c in (None, "")):
        all_ok = False

print("All target cells populated:", all_ok)
final_output_path = outfile
