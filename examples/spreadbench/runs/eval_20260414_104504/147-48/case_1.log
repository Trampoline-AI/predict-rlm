print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    for idx, name in enumerate(orig_sheet_names):
        if idx < len(wb2.worksheets):
            wb2.worksheets[idx].title = name
