import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Detect contiguous nonblank groups in column A
groups = []
start = None
items = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v not in (None, ""):
        if start is None:
            start = r
            items = [v]
        else:
            items.append(v)
    else:
        if start is not None:
            groups.append((start, r - 1, items[:]))
            start = None
            items = []
if start is not None:
    groups.append((start, ws.max_row, items[:]))

print("Detected groups:", len(groups))
for i, (s, e, vals) in enumerate(groups, 1):
    print(f"group {i}: A{s}:A{e} -> output row {i}, values={vals}")

max_group_len = max(len(vals) for _, _, vals in groups)
print("Max group length:", max_group_len, "=> target columns C to", get_column_letter(2 + max_group_len))

# Inspect current target area before writing
print("\nCurrent target area before writing:")
for out_r in range(1, len(groups) + 1):
    vals = [ws.cell(out_r, c).value for c in range(3, 3 + max_group_len)]
    print(f"row {out_r} C:{get_column_letter(2+max_group_len)} -> {vals}")

# Write transposed groups into C onward, preserving already-correct values
writes = []
for i, (_, _, vals) in enumerate(groups, 1):
    for j, val in enumerate(vals, start=3):
        cell = ws.cell(i, j)
        if cell.value != val:
            writes.append((cell.coordinate, cell.value, val))
            cell.value = val

print("\nPlanned/actual writes:", len(writes))
for w in writes:
    print(w)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
