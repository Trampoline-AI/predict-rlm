ws1["C2"] = '=SUMIF(Sheet2!$A$2:$A$363,A2,Sheet2!$R$2:$R$363)'

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if needed after recalc
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for ws, orig_name in zip(wb_check.worksheets, original_sheetnames):
        ws.title = orig_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formula and cached value
