# Write robust formulas into column G for the other 2 tables
# Also update top example block to consistent working formula.
blocks = [(4, 6), (11, 13), (20, 22)]
for start, end in blocks:
    for r in range(start, end + 1):
        ws[f"G{r}"] = f'=COUNTIFS($A${start}:$A${end},D{r},$B${start}:$B${end},">="&E{r})>0'

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved:", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore original sheet names if recalc changed them
orig_names = wb.sheetnames[:]
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names and len(wb_check.sheetnames) == len(orig_names):
    print("Renaming sheets back:", wb_check.sheetnames, "->", orig_names)
    for i, nm in enumerate(orig_names):
        wb_check.worksheets[i].title = nm
    wb_check.save(out_path)

# Verify formulas and cached results
