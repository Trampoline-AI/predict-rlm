print("Sheet names:", wb.sheetnames)
print("max_row/max_col:", ws.max_row, ws.max_column)

# Safe table inspection
print("Table names:", list(ws.tables.keys()))
for name in ws.tables.keys():
    tbl = ws.tables[name]
    print("table", name, "type", type(tbl), "ref", getattr(tbl, "ref", None))

# Inspect relevant rows/cells thoroughly
for r in range(10, 23):
    vals = [ws.cell(r, c).value for c in range(1, 8)]
    print(f"R{r}:", vals)

for cell in ["G4","G5","G6","G11","G12","G13","G20","G21","G22"]:
