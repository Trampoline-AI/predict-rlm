import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Determine true last data row from columns A/B
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_data_row = r
        break

print("True last data row:", last_data_row)

# Preview source rows and expected non-zero Types
source = []
nonzero_types = []
for r in range(2, last_data_row + 1):
    t = ws.cell(r, 1).value
    q = ws.cell(r, 2).value
    source.append((r, t, q, ws.cell(r, 5).value, ws.cell(r, 7).value, ws.cell(r, 8).value))
    if q not in (None, "", 0):
        nonzero_types.append(t)

print("First 12 source rows (row, Type, Qty, E formula, G formula, H formula):")
for row in source[:12]:
    print(row)
print("Last 8 source rows:")
for row in source[-8:]:
    print(row)

print("Expected non-zero Type list:", nonzero_types)
print("Target range: H2:H%d" % last_data_row)
for r in range(2, min(last_data_row, 15) + 1):
    print(f"H{r} current:", ws[f"H{r}"].value)

# Replace H formulas only, preserve everything else
green_fill = PatternFill(start_color="FF92D050", end_color="FF92D050", fill_type="solid")
for r in range(2, last_data_row + 1):
    formula = f'=IFERROR(INDEX($A$2:$A${last_data_row},MATCH(ROW()-ROW($H$1),$E$2:$E${last_data_row},0)),"")'
    ws.cell(r, 8).value = formula
    ws.cell(r, 8).fill = green_fill

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore sheet names if recalculate changed them
orig_names = ["Sheet1"]
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_names)
    while len(wb_check.sheetnames) > 0 and len(orig_names) > 0:
        for i, nm in enumerate(orig_names):
            if i < len(wb_check.worksheets):
                wb_check.worksheets[i].title = nm
    wb_check.save(out_path)

# Verify values after recalc
wbv = load_workbook(out_path, data_only=False)
wsv = wbv["Sheet1"]
wbv_data = load_workbook(out_path, data_only=True)
wsv_data = wbv_data["Sheet1"]

print("Verification formulas and values in H2:H15:")
for r in range(2, min(last_data_row, 15) + 1):
    print(
        r,
        "formula=", wsv[f"H{r}"].value,
        "value=", wsv_data[f"H{r}"].value,
        "fill=", wsv[f"H{r}"].fill.fgColor.rgb
    )

output_spreadsheet = out_path
