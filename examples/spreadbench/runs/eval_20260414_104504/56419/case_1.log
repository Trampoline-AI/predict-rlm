import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r,c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = row_vals(ws, 1, ws.max_column)
    headers2 = row_vals(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    # print non-empty headers by row 1/2
    print("Column letters and row1 values:")
    for c in range(1, ws.max_column+1):
        print(get_column_letter(c), repr(ws.cell(1,c).value))
    # samples first 10 and last 5
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_vals(ws, r, ws.max_column))
    print("Last rows:")
    start = max(1, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        print(r, row_vals(ws, r, ws.max_column))
    # print formulas / interesting cells
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r,c,v))
    print("Formula cells count:", len(formulas))
    print("First 20 formulas:", formulas[:20])

# Also inspect fills / current values around used area for first sheet
ws = wb[wb.sheetnames[0]]
print("\nInspect fills on first sheet used range:")
for r in range(1, min(ws.max_row, 15)+1):
    row = []
    for c in range(1, ws.max_column+1):
        cell = ws.cell(r,c)
        row.append((f"{get_column_letter(c)}{r}", cell.value, cell.fill.fill_type, cell.fill.fgColor.rgb))
    print(row)
