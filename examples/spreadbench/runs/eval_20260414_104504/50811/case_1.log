import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Relevant lookup table rows 4:15, cols A:T")
for r in range(4, 16):
    vals = [ws.cell(r,c).value for c in range(1, 21)]
    print(r, vals)

print("\nTarget area rows 20:23, cols B:D with formulas/fills")
for r in range(20, 24):
    row = []
    for c in range(2, 5):
        cell = ws.cell(r,c)
        row.append((cell.coordinate, cell.value, cell.data_type, cell.fill.fill_type, cell.fill.fgColor.type, cell.fill.fgColor.rgb, cell.fill.fgColor.indexed))
    print(row)

# Confirm expected answers from source data
lookup_checks = [("Bob Vanderlei","KLM Company"), ("Brett Marker","NOP Company"), ("Craig Smith","TUV Company")]
data = []
for r in range(5, 16):
    client = ws[f"C{r}"].value
    reps_pcts = [
        (ws[f"F{r}"].value, ws[f"H{r}"].value),
        (ws[f"I{r}"].value, ws[f"K{r}"].value),
        (ws[f"L{r}"].value, ws[f"N{r}"].value),
        (ws[f"O{r}"].value, ws[f"Q{r}"].value),
        (ws[f"R{r}"].value, ws[f"T{r}"].value),
    ]
    data.append((client, reps_pcts))

for rep, client in lookup_checks:
    found = []
    for cl, reps_pcts in data:
        if cl == client:
            for rp, pct in reps_pcts:
                if rp == rep:
                    found.append(pct)
    print("Lookup check:", rep, client, "->", found)

# Write INDEX/MATCH formulas into D21:D23
# Use MATCH(1,(client match)*(rep match across each rep column),0) pattern
for r in range(21, 24):
    formula = (
        f'=INDEX($H$5:$H$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$F$5:$F$15),0))'
        f'+INDEX($K$5:$K$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$I$5:$I$15),0))'
        f'+INDEX($N$5:$N$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$L$5:$L$15),0))'
        f'+INDEX($Q$5:$Q$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$O$5:$O$15),0))'
        f'+INDEX($T$5:$T$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$R$5:$R$15),0))'
    )
    # wrap with IFERROR to avoid #N/A from non-matching positions
    formula = (
        f'=IFERROR(INDEX($H$5:$H$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$F$5:$F$15),0)),0)'
        f'+IFERROR(INDEX($K$5:$K$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$I$5:$I$15),0)),0)'
        f'+IFERROR(INDEX($N$5:$N$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$L$5:$L$15),0)),0)'
        f'+IFERROR(INDEX($Q$5:$Q$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$O$5:$O$15),0)),0)'
        f'+IFERROR(INDEX($T$5:$T$15,MATCH(1,($C{r}=$C$5:$C$15)*($B{r}=$R$5:$R$15),0)),0)'
    )
    ws[f"D{r}"] = formula

print("\nWritten formulas:")
for r in range(21,24):
    print(r, ws[f"D{r}"].value)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
wb.close()

recalc_result = await recalculate(out_path)
print("\nRecalc:", recalc_result)

# Restore original sheet names if needed
orig_names = ["Sheet1"]
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(out_path)
wb2.close()

# Verify data_only values
vwb = load_workbook(out_path, data_only=True)
vws = vwb["Sheet1"]
