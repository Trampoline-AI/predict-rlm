import os, json, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
print("Original sheet names:", orig_sheet_names)

def sheet_preview(ws, n_first=8, n_last=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    # also inspect row2 in case headers are there
    row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
    print("Row 2:", row2)
    first_rows = list(range(1, min(ws.max_row, n_first) + 1))
    last_rows = list(range(max(1, ws.max_row - n_last + 1), ws.max_row + 1))
    shown = []
    for r in first_rows + [x for x in last_rows if x not in first_rows]:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        shown.append((r, vals))
    for r, vals in shown:
        print(f"Row {r}: {vals}")
    if ws.max_column >= 5:
        print("Sample current values in column E:")
        sample_e = []
        for r in range(1, min(ws.max_row, 20) + 1):
            sample_e.append((r, ws.cell(r, 5).value))
        print(sample_e)
        tail_e = [(r, ws.cell(r, 5).value) for r in range(max(1, ws.max_row-10), ws.max_row+1)]
        print("Tail column E:", tail_e)
        # find rows matching patterns
        matches = []
        for r in range(1, ws.max_row + 1):
            v = ws.cell(r, 5).value
            s = str(v).strip() if v is not None else ""
            if s.startswith("Z1") or s.startswith("X1"):
                matches.append((r, s))
        print("Rows where col E starts with Z1/X1 (up to 50 shown):", matches[:50], "count=", len(matches))

for ws in wb.worksheets:
    sheet_preview(ws)
