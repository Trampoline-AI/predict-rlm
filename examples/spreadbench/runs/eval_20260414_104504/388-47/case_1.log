import os, shutil
from openpyxl import load_workbook

# Re-open and inspect active sheet / any auto-filter metadata before changing
wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)
print("Active sheet title:", wb.active.title)
for ws in wb.worksheets:
    print(f"{ws.title}: auto_filter.ref={ws.auto_filter.ref}, max_row={ws.max_row}, max_col={ws.max_column}")
    # print any formulas in used range
    formulas = []
    for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print(f"Formulas found in {ws.title}:", formulas[:20], "count=", len(formulas))

# Modify only the first/active worksheet, preserving the "Original Data" sheet
target_ws = wb[wb.sheetnames[0]]
print("\nTarget worksheet for deletion:", target_ws.title)

# Show exact target range in column E before deletion
before_e = [(r, target_ws.cell(r, 5).value) for r in range(1, target_ws.max_row + 1)]
print("Column E before deletion:", before_e)

rows_to_delete = []
for r in range(2, target_ws.max_row + 1):  # preserve header
    v = target_ws.cell(r, 5).value
    s = str(v).strip() if v is not None else ""
    if s.startswith("Z1") or s.startswith("X1"):
        rows_to_delete.append(r)

print("Rows to delete from target sheet:", rows_to_delete)

for r in reversed(rows_to_delete):
    target_ws.delete_rows(r, 1)

print("Target sheet row count after deletion (in-memory):", target_ws.max_row)
print("Column E after deletion (in-memory):", [(r, target_ws.cell(r, 5).value) for r in range(1, target_ws.max_row + 1)])

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != wb.sheetnames:
    print("Sheet names changed; restoring originals")
    for i, orig in enumerate(wb.sheetnames):
        wb_check.worksheets[i].title = orig
    wb_check.save(out_path)
    wb_check = load_workbook(out_path)

print("Final sheet names:", wb_check.sheetnames)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
print("\nVerification:")
for ws in wb_verify.worksheets:
    print(f"Sheet {ws.title}: max_row={ws.max_row}, max_col={ws.max_column}")
    e_vals = [(r, ws.cell(r, 5).value) for r in range(1, ws.max_row + 1)]
    print("Column E values:", e_vals)
    matches = []
    for r in range(2, ws.max_row + 1):
        v = ws.cell(r, 5).value
        s = str(v).strip() if v is not None else ""
        if s.startswith("Z1") or s.startswith("X1"):
            matches.append((r, s))
    print("Remaining Z1/X1 matches:", matches)

output_spreadsheet = out_path
print("Prepared output_spreadsheet:", output_spreadsheet)
