import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]

dash = wb["Dashboard"]
data_ws = wb["Data"]

last_row = data_ws.max_row

# Write formula to exact target cell C4
formula = (
    f'=IF(COUNTIF($C$11:$C$13,"All")>0,'
    f'SUMIF(Data!$A$2:$A${last_row},$C$2,Data!$C$2:$C${last_row}),'
    f'SUMPRODUCT((Data!$A$2:$A${last_row}=$C$2)*'
    f'ISNUMBER(MATCH(Data!$B$2:$B${last_row},$C$11:$C$13,0))*'
    f'(Data!$C$2:$C${last_row})))'
)
dash["C4"] = formula

print("Written formula to Dashboard!C4:", dash["C4"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if changed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, desired in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = desired
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify target cells/formula and cached value
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)

print("Formula in Dashboard!C4:", wb_formula["Dashboard"]["C4"].value)
print("Cached value in Dashboard!C4:", wb_values["Dashboard"]["C4"].value)
print("Selectors:", wb_values["Dashboard"]["C2"].value, wb_values["Dashboard"]["C11"].value, wb_values["Dashboard"]["C12"].value, wb_values["Dashboard"]["C13"].value)

# Also sanity-check expected current result in Python
product = wb_values["Dashboard"]["C2"].value
selected = [wb_values["Dashboard"][c].value for c in ["C11", "C12", "C13"]]
rows = [(data_ws[f"A{r}"].value, data_ws[f"B{r}"].value, data_ws[f"C{r}"].value) for r in range(2, last_row+1)]
if "All" in selected:
    expected = sum(v for p, reg, v in rows if p == product)
else:
    expected = sum(v for p, reg, v in rows if p == product and reg in [x for x in selected if x not in (None, "")])
print("Expected current value from Python:", expected)
