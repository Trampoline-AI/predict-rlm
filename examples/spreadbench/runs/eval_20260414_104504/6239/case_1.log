import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INSTRUCTION:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- SHEET: {s} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find first 3 non-empty rows for header/context
    nonempty_rows = []
    for r in range(1, min(ws.max_row, 15)+1):
        vals = row_vals(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append((r, vals))
    print("First non-empty rows (up to 5):")
    for r, vals in nonempty_rows[:5]:
        print(r, vals)
    
    # Header candidates
    for r in range(1, min(ws.max_row, 5)+1):
        vals = row_vals(ws, r, ws.max_column)
        print(f"Row {r} headers/sample:", vals)
    
    # First 10 rows
    print("First 10 rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        print(r, row_vals(ws, r, ws.max_column))
    
    # Last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_vals(ws, r, ws.max_column))
    
    # Column letters and row1 values
    print("Columns:")
    for c in range(1, ws.max_column + 1):
        print(c, get_column_letter(c), ws.cell(1, c).value)
    
    # Look for formulas in used range
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formula cells count:", len(formulas))
    for item in formulas[:20]:
        r, c, v = item
        print("Formula", f"{get_column_letter(c)}{r}", v)

# Search workbook for keywords
keywords = ["goal", "variance", "metric", "incentive", "%", "bucket", "achieved"]
print("\nKeyword scan:")
for s in wb.sheetnames:
    ws = wb[s]
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                low = v.lower()
                if any(k in low for k in keywords):
                    print(s, f"{get_column_letter(c)}{r}", v)
