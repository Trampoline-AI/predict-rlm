import os, shutil
from collections import defaultdict
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Re-open and inspect all data rows fully
wb = load_workbook(infile)
ws = wb["Before"]

print("Full data rows before modification:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])

# Compute max amount per ID and identify first row where max occurs
id_max = {}
id_max_row = {}
for r in range(2, ws.max_row + 1):
    idv = ws.cell(r, 1).value
    amt = ws.cell(r, 2).value
    if idv is None or amt is None:
        continue
    if (idv not in id_max) or (amt > id_max[idv]):
        id_max[idv] = amt
        id_max_row[idv] = r

print("Computed maxima:", id_max)
print("Rows holding maxima:", id_max_row)

# Write outputs to existing column D, no header
ws["D1"] = None
for r in range(2, ws.max_row + 1):
    idv = ws.cell(r, 1).value
    if idv is None:
        ws.cell(r, 4).value = None
    elif id_max_row.get(idv) == r:
        ws.cell(r, 4).value = id_max[idv]
    else:
        ws.cell(r, 4).value = ""

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and restore sheet names if needed
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_chk = load_workbook(outfile)
if wb_chk.sheetnames != orig_names:
    print("Sheet names changed:", wb_chk.sheetnames, "-> restoring", orig_names)
    while len(wb_chk.sheetnames) > len(orig_names):
        break
    for i, name in enumerate(orig_names):
        wb_chk.worksheets[i].title = name
    wb_chk.save(outfile)

# Verify after recalc
wb_val = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)
ws_val = wb_val[orig_names[0]]

print("Target range D1:D13 after save/recalc:")
for r in range(1, ws_val.max_row + 1):
    print(f"D{r} =", ws_val.cell(r, 4).value)

print("Final rows A:D:")
for r in range(1, ws_val.max_row + 1):
    print(r, [ws_val.cell(r, c).value for c in range(1, 5)])
```
