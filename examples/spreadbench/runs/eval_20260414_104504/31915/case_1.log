import os
from openpyxl import load_workbook

infile = input_spreadsheet
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]

ws = wb["Sheet2"]

print("Inspect target sheet:", ws.title)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Determine true last non-empty row among A:C
last_row = 1
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 4)):
        last_row = r
        break
print("True last row:", last_row)

# Print target cells with current formulas/values
for r in range(2, last_row + 1):
    print(f"Row {r}: A={ws[f'A{r}'].value!r}, B={ws[f'B{r}'].value!r}, C={ws[f'C{r}'].value!r}")

# Fill/repair column C based on first instance of each serial
for r in range(2, last_row + 1):
    serial = ws[f"A{r}"].value
    price = ws[f"B{r}"].value
    current = ws[f"C{r}"].value
    if serial in (None, "") and price in (None, ""):
        continue

    if r == 2:
        formula = f'=SUMIF($A$2:$A${last_row},A{r},$B$2:$B${last_row})'
    else:
        formula = f'=IF(A{r}<>A{r-1},SUMIF($A$2:$A${last_row},A{r},$B$2:$B${last_row}),"")'

    # Preserve plausible existing first-instance totals; write blanks/formulas elsewhere as needed
    prev_serial = ws[f"A{r-1}"].value if r > 2 else None
    is_first = (r == 2) or (serial != prev_serial)
    if is_first:
        if not (isinstance(current, (int, float)) and current not in (None, "")):
            ws[f"C{r}"] = formula
        else:
            # keep existing plausible value
            pass
    else:
        if current not in (None, ""):
            ws[f"C{r}"] = ""
        else:
            ws[f"C{r}"] = ""

print("After writing formulas/blanking duplicates:")
for r in range(2, last_row + 1):
    print(f"C{r} -> {ws[f'C{r}'].value!r}")

# Save
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename by position back to original names
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Restored sheet names:", orig_sheetnames)

# Verify computed values
wb_val = load_workbook(outfile, data_only=True)
ws_val = wb_val["Sheet2"]
print("Verified target range A:C")
for r in range(2, last_row + 1):
    print(r, ws_val[f"A{r}"].value, ws_val[f"B{r}"].value, ws_val[f"C{r}"].value)

output_spreadsheet = outfile
