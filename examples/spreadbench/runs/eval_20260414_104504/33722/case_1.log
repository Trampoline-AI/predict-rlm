import os, statistics
from openpyxl import load_workbook
from openpyxl.styles import Border, Side, Alignment

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Determine actual data extent from non-empty rows in B and C
data_rows = []
for r in range(2, ws.max_row + 1):
    mc = ws.cell(r, 2).value
    pct = ws.cell(r, 3).value
    if mc is not None and pct is not None:
        data_rows.append((r, float(mc), float(pct)))

print("Target cells before write:", {f"E{r}": ws[f"E{r}"].value for r in range(2, 7)})

# Compute medians for successive 1% bands: 0-1%, 1-2%, ..., 4-5%
results = {}
for out_row in range(2, 7):
    i = out_row - 2
    lo = i / 100
    hi = (i + 1) / 100
    vals = [mc for _, mc, pct in data_rows if lo <= pct < hi]
    med = statistics.median(vals) if vals else None
    results[out_row] = med
    ws[f"E{out_row}"] = med

# Apply formatting to E2:E6
thin = Side(style="thin", color="000000")
border = Border(left=thin, right=thin, top=thin, bottom=thin)
for r in range(2, 7):
    cell = ws[f"E{r}"]
    cell.border = border
    cell.alignment = Alignment(horizontal="left")
    cell.number_format = "0"

wb.save(outfile)
print("Written results:", results)

# recalc/save workflow
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# restore original sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# verification
wbv = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", wbv.sheetnames)
wsv = wbv[orig_sheetnames[0]]
verified = {f"E{r}": wsv[f"E{r}"].value for r in range(2, 7)}
print("Verified E2:E6:", verified)

# also verify formatting from normal load
wbf = load_workbook(outfile)
wsf = wbf[orig_sheetnames[0]]
fmt = {f"E{r}": {"numfmt": wsf[f"E{r}"].number_format, "align": wsf[f"E{r}"].alignment.horizontal} for r in range(2, 7)}
print("Formatting E2:E6:", fmt)

output_spreadsheet = outfile
```
