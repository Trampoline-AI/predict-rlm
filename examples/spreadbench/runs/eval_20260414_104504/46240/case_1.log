orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Target sheet:", ws.title)
print("Existing J formulas/values before change:")
for r in range(2, ws.max_row + 1):
    print(r, "H=", ws.cell(r, 8).value, "J=", ws.cell(r, 10).value)

# Replace formulas in existing target cells J2:Jlast
for r in range(2, ws.max_row + 1):
    h = ws.cell(r, 8).value
    j = ws.cell(r, 10)
    # Write into same column J
    j.value = f'=IF(H{r}="N/A","N/A",IF(H{r}="","No",IF(OR(H{r}="Yes",ISNUMBER(H{r})),"Yes","No")))'

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename by position
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Restored sheet names:", orig_sheetnames)

# Verify results with data_only
