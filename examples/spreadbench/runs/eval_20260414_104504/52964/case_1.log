import os, shutil
from openpyxl import load_workbook

# Reload and inspect exact relevant row extents
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

last_a = 0
last_q = 0
for r in range(2, ws.max_row + 1):
    if ws[f"A{r}"].value not in (None, ""):
        last_a = r
    if ws[f"Q{r}"].value not in (None, ""):
        last_q = r

print("Last used row in A:", last_a)
print("Last used row in Q:", last_q)

# Check match coverage and a few rows with both U and Y populated
missing_matches = []
both_dates = []
for r in range(2, last_a + 1):
    a = ws[f"A{r}"].value
    if a in (None, ""):
        continue
    match_row = None
    for rr in range(2, last_q + 1):
        if ws[f"Q{rr}"].value == a:
            match_row = rr
            break
    if match_row is None:
        missing_matches.append(r)
    else:
        u = ws[f"U{match_row}"].value
        y = ws[f"Y{match_row}"].value
        if u is not None and y is not None:
            both_dates.append((r, match_row, a, u, y, (y-u).days if hasattr(y-u, "days") else y-u))

print("Missing match rows count:", len(missing_matches), "sample:", missing_matches[:10])
print("Rows with both U and Y populated (sample):", both_dates[:10])

# Write formulas into C2:C[last_a]
# Using Y-U because the existing header explicitly says "( GERIATRIC SURG LOG Y-U )"
for r in range(2, last_a + 1):
    if ws[f"A{r}"].value in (None, ""):
        continue
    ws[f"C{r}"] = (
        f'=IF(A{r}="","",'
        f'IFERROR('
        f'INDEX($Y$2:$Y${last_q},MATCH($A{r},$Q$2:$Q${last_q},0))'
        f'-INDEX($U$2:$U${last_q},MATCH($A{r},$Q$2:$Q${last_q},0))'
        f',""))'
    )

print("Written formula C2:", ws["C2"].value)
print("Written formula C3:", ws["C3"].value)
print("D2 preserved:", ws["D2"].value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
