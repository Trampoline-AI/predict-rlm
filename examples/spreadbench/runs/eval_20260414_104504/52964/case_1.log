import os
from openpyxl import load_workbook

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

wb = load_workbook(out_path)
ws = wb["Sheet1"]

last_a = 15
last_q = 124

for r in range(2, last_a + 1):
    ws[f"C{r}"] = (
        f'=IF(A{r}="","",'
        f'IF(INDEX($Y$2:$Y${last_q},MATCH($A{r},$Q$2:$Q${last_q},0))="","",'
        f'INDEX($Y$2:$Y${last_q},MATCH($A{r},$Q$2:$Q${last_q},0))'
        f'-INDEX($U$2:$U${last_q},MATCH($A{r},$Q$2:$Q${last_q},0))))'
    )

print("Updated C2 formula:", ws["C2"].value)
print("Updated C3 formula:", ws["C3"].value)
print("D2 still:", ws["D2"].value)

wb.save(out_path)
print("Saved:", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

ver = load_workbook(out_path, data_only=True)
vws = ver["Sheet1"]

for coord in ["C2", "C3", "C4", "C5", "D2"]:
    print(coord, "=>", vws[coord].value)

final_output_path = out_path
