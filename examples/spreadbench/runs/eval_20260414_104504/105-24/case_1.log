    for r in range(1, first_end + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last rows
    start_tail = max(1, ws.max_row - tail_n + 1)
    if start_tail <= ws.max_row:
        print(f"Last rows {start_tail}:{ws.max_row}:")
        for r in range(start_tail, ws.max_row + 1):
