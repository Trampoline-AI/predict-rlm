        continue
    if r == 1:
        last_a_to_copy = None
        continue

    if a not in (None, ""):
        last_a_to_copy = a
    else:
        if last_a_to_copy not in (None, "") and f not in (None, ""):
            ws[f"A{r}"] = last_a_to_copy
