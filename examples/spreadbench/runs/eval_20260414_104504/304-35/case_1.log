from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os, json

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_info = {}
for ws in wb.worksheets:
    headers = row_values(ws, 1, ws.max_column)
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
    }
    print(f"\n--- Sheet: {ws.title} ---")
    print("Rows:", ws.max_row, "Cols:", ws.max_column)
    print("Headers row 1:", headers)
    # print first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))
    print("Last rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))

# inspect yellow-ish cells and A/E/F columns for each sheet
for ws in wb.worksheets:
    yellow_cells = []
    for row in ws.iter_rows():
        for cell in row:
            fill = cell.fill
            if fill and fill.fill_type == "solid":
                color = fill.start_color.rgb or fill.start_color.indexed or fill.start_color.value
                if isinstance(color, str) and ("FFFF00" in color.upper() or color.upper() in {"FFFFFF00", "FFFF00"}):
                    yellow_cells.append((cell.coordinate, cell.value))
    print(f"\nYellow cells in {ws.title} (up to 30):", yellow_cells[:30])

    if ws.max_column >= 6:
        print(f"A/E/F sample for {ws.title}:")
        for r in range(1, min(ws.max_row, 35)+1):
            print(r, ws[f"A{r}"].value, ws[f"E{r}"].value, ws[f"F{r}"].value)
