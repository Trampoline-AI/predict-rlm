from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from collections import defaultdict
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["RS.Food"]

# Inspect mapping area N:O and relevant columns near target, plus duplicate candidates
print("Headers row 5 A:Q")
print([ws.cell(5, c).value for c in range(1, 18)])

print("\nSample mapping area N:O rows 5:35")
for r in range(5, 36):
    print(r, {"N": ws[f"N{r}"].value, "O": ws[f"O{r}"].value})

# Build item class mapping from O (Group/Menu item names looked up from A) to N (Type/Item Class)
mapping = {}
for r in range(5, ws.max_row + 1):
    key = ws[f"O{r}"].value
    val = ws[f"N{r}"].value
    if key not in (None, "") and val not in (None, "") and key not in mapping:
        mapping[str(key)] = val

print("\nMapping size:", len(mapping))
print("First 20 mappings:", list(mapping.items())[:20])

# Determine active rows and preview duplicate groups using derived item class
rows_info = []
for r in range(6, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    j = ws[f"J{r}"].value
    derived_class = mapping.get(str(a)) if a not in (None, "") else None
    rows_info.append((r, a, b, j, derived_class))

print("\nFirst 25 target-region rows with derived class:")
for x in rows_info[:25]:
    print(x)

dupes = defaultdict(list)
for r, a, b, j, cls in rows_info:
    if cls not in (None, "") and j not in (None, ""):
        dupes[(cls, b)].append(r)

dup_groups = [(k, v) for k, v in dupes.items() if len(v) > 1]
print("\nDuplicate groups count:", len(dup_groups))
for grp, rs in dup_groups[:15]:
    print(grp, rs, [ws[f"A{r}"].value for r in rs], [ws[f"K{r}"].value for r in rs])

# Compute sequential category rank within each item class ordered by Net Sales desc, tie-break by row order
class_rows = defaultdict(list)
for r, a, b, j, cls in rows_info:
    if cls not in (None, "") and j not in (None, "") and isinstance(b, (int, float)):
        class_rows[cls].append((r, b))

new_ranks = {}
for cls, items in class_rows.items():
    items_sorted = sorted(items, key=lambda t: (-t[1], t[0]))  # row order breaks ties sequentially
    for rank, (r, b) in enumerate(items_sorted, start=1):
        new_ranks[r] = rank

print("\nPreview of new ranks for first 40 rows with outputs:")
for r in range(6, 46):
    if r in new_ranks or ws[f"K{r}"].value is not None:
        print(r, {
            "A": ws[f"A{r}"].value,
            "B": ws[f"B{r}"].value,
            "derived_class": mapping.get(str(ws[f'A{r}'].value)) if ws[f"A{r}"].value not in (None, "") else None,
            "oldK": ws[f"K{r}"].value,
            "newK": new_ranks.get(r)
        })

# Write only K column values; preserve blanks where no rank should exist
for r in range(6, ws.max_row + 1):
    if r in new_ranks:
        ws[f"K{r}"] = new_ranks[r]
    else:
        # mimic old logic = blank if no J/class
        ws[f"K{r}"] = None

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate and reload
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore original sheet names if needed
orig_names = ['RS.Food', 'Sheet1']
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring")
    for i, name in enumerate(orig_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = name
    wb_check.save(out_path)

# Verify output
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["RS.Food"]
print("\nVerification sample K rows 6:30")
for r in range(6, 31):
    print(r, {"A": wsv[f"A{r}"].value, "B": wsv[f"B{r}"].value, "K": wsv[f"K{r}"].value})

print("\nVerification duplicate groups after rewrite:")
shown = 0
for (cls, b), rs in dup_groups[:10]:
    print("Group", cls, b, [(r, wsv[f"A{r}"].value, wsv[f"K{r}"].value) for r in rs])
    shown += 1

