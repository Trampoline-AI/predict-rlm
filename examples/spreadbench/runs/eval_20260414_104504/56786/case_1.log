import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine actual last data row based on cols A/B
data_rows = []
for r in range(4, ws.max_row + 1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        data_rows.append(r)

first_data_row = min(data_rows)
last_data_row = max(data_rows)
print("Writing formulas in C from", first_data_row, "to", last_data_row)

# Print existing formulas/values in target range sample before overwrite
for r in [4,5,6,70,71,72,80,99,200]:
    print("Before", r, ws[f"C{r}"].value)

# Fill rolling 12-month average formulas in column C
for r in range(first_data_row, last_data_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is not None and b is not None:
        ws[f"C{r}"] = f'=AVERAGEIFS($B$4:B{r},$A$4:A{r},">="&A{r}-365,$A$4:A{r},"<="&A{r})'
    else:
        ws[f"C{r}"] = None

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    for i, old_name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = old_name
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify by reloading data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

for r in [4,5,6,70,71,72,80,99,200]:
    print("After", r, {"A": wsv[f"A{r}"].value, "B": wsv[f"B{r}"].value, "C": wsv[f"C{r}"].value})

# Also inspect formula text in normal mode
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
for r in [70,71,72,80,99]:
    print("Formula", r, wsf[f"C{r}"].value)

output_spreadsheet = outfile
