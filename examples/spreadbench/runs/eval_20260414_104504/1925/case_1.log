from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet

# Load both formula view and data_only to inspect actual row-5 dates
wb = load_workbook(path)
wb_vals = load_workbook(path, data_only=True)

ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
ws2v = wb_vals["Sheet2"]

print("Target output cells on Sheet1:", [f"C{r}" for r in range(6, ws1.max_row + 1)])
print("Existing formula in C6:", ws1["C6"].value)

print("\nSheet2 row 5 actual dates/formulas across C:M")
for c in range(3, 14):
    coord = f"{get_column_letter(c)}5"
    print(coord, "formula=", ws2[coord].value, "cached=", ws2v[coord].value)

print("\nSheet1 key cells:")
print("C5 date:", ws1["C5"].value)
for r in range(6, 12):
    print(f"B{r}={ws1[f'B{r}'].value}, C{r}={ws1[f'C{r}'].value}")

# Write corrected dynamic formula to C6:C31
for r in range(6, ws1.max_row + 1):
    item_cell = f"B{r}"
    target = f"C{r}"
    formula = (
        f'=_xlfn.IFNA('
        f'INDEX(Sheet2!$C$6:$M$23,'
        f'MATCH({item_cell},INDEX(Sheet2!$C$6:$M$23,0,MATCH($C$5,Sheet2!$C$5:$M$5,0)),0),'
        f'MATCH($C$5,Sheet2!$C$5:$M$5,0)'
        f'),"NEW")'
    )
    ws1[target] = formula

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(path)
wb.save(out_path)
print("\nSaved:", out_path)

# recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# restore original sheet names if needed
orig_names = ['Sheet1', 'Sheet2']
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names and len(wb_check.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Restored sheet names:", wb_check.sheetnames)

# verify with data_only
ver = load_workbook(out_path, data_only=True)
print("\nVerified sheet names:", ver.sheetnames)
v1 = ver["Sheet1"]
print("Verified C5:", v1["C5"].value)
for r in range(6, 32):
    print(r, v1[f"B{r}"].value, "->", v1[f"C{r}"].value)

output_spreadsheet = out_path
