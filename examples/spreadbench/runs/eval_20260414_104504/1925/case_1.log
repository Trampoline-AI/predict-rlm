import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # gather row1-6 values to infer headers/layout
    for r in range(1, min(ws.max_row, 8) + 1):
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"Row {r}:", vals)
    # sample first 10 and last 5 rows, first 12 cols
    sample_rows = list(range(1, min(ws.max_row, 10)+1))
    tail_rows = list(range(max(1, ws.max_row-4), ws.max_row+1))
    print("First rows sample:")
    for r in sample_rows:
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(r, vals)
    print("Last rows sample:")
    for r in tail_rows:
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Inspect specific referenced cells / regions
for sname in ["Sheet1", "Sheet2"]:
    if sname in wb.sheetnames:
        ws = wb[sname]
        print(f"\nSpecific checks for {sname}:")
        for coord in ["B6", "C5", "F5", "F6", "E5", "G5"]:
            print(coord, "=", ws[coord].value)
        # Print row 5 across used columns
        row5 = [ws.cell(5,c).value for c in range(1, ws.max_column+1)]
        print("Row 5 full:", row5[:50])
        # Print columns A-L for rows 5-12
        for r in range(5, min(ws.max_row, 12)+1):
            vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
            print(f"r{r}:", vals)

# Search for formulas in Sheet1 around likely output area
if "Sheet1" in wb.sheetnames:
    ws = wb["Sheet1"]
    print("\nFormulas in Sheet1 rows 1-20 cols A-L:")
    for r in range(1, min(20, ws.max_row)+1):
        rowf = []
        for c in range(1, min(12, ws.max_column)+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                rowf.append((f"{get_column_letter(c)}{r}", v))
        if rowf:
            print(rowf)
