for r in range(5, 29):
    print(r, "A", ws[f"A{r}"].value, "B", ws[f"B{r}"].value, "C", ws[f"C{r}"].value)

# Compute expected ascending day gaps by prior occurrence of same name
last_date = {}
expected = {}
for r in range(5, 29):
    dt = ws[f"A{r}"].value
    name = ws[f"B{r}"].value
    if name in last_date:
        expected[r] = (dt - last_date[name]).days
    else:
        expected[r] = 0
    last_date[name] = dt

print("\nExpected ascending differences:")
for r in range(5, 29):
    print(r, ws[f"B{r}"].value, ws[f"A{r}"].value.date(), expected[r])

# Write corrected formulas to same cells C5:C28
# Use IFERROR around prior match, with fallback 0 for first sale
for r in range(5, 29):
    formula = f'=IFERROR(A{r}-INDEX($A$4:$A{r-1},MATCH(B{r},$B$4:$B{r-1},0),1),0)'
    ws[f"C{r}"] = formula
    ws[f"C{r}"].number_format = '$#,##0.00_);($#,##0.00)'  # accounting-like numeric format

# Save
