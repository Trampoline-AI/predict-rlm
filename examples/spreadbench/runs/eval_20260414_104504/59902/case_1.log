import os
from openpyxl import load_workbook

path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))

wb = load_workbook(path)
ws = wb["Sheet1"]

# Inspect existing target + comparison formatting
print("C/H formulas and number formats before fix:")
for r in range(5, 10):
    print(
        r,
        "C", ws[f"C{r}"].value, ws[f"C{r}"].number_format,
        "| H", ws[f"H{r}"].value, ws[f"H{r}"].number_format
    )

# Compute correct "days since last sale" for ascending data in A:B -> C
last_date = {}
results = {}
for r in range(5, 29):
    dt = ws[f"A{r}"].value
    name = ws[f"B{r}"].value
    if dt is None and name is None:
        continue
    if name in last_date:
        results[r] = (dt - last_date[name]).days
    else:
        results[r] = 0
    last_date[name] = dt

print("Computed results:", results)

# Use same/general numeric/accounting-ish format consistently
target_number_format = ws["H5"].number_format if ws["H5"].number_format not in (None, "", "General") else '$* #,##0.00_);($* #,##0.00)'
print("Using number format:", target_number_format)

for r, val in results.items():
    ws[f"C{r}"] = val
    ws[f"C{r}"].number_format = target_number_format

wb.save(out_path)
print("Saved:", out_path)

orig_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore sheet names if changed
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_sheetnames:
    print("Restoring sheet names:", wb_check.sheetnames, "->", orig_sheetnames)
    for i, nm in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = nm
    wb_check.save(out_path)

# Verify after recalc
vwb = load_workbook(out_path, data_only=True)
vws = vwb[orig_sheetnames[0]]
print("Verified C5:C28 values:")
for r in range(5, 29):
    print(r, vws[f"A{r}"].value, vws[f"B{r}"].value, vws[f"C{r}"].value)

# also verify non-data workbook formula/value and format
fmt_wb = load_workbook(out_path)
fmt_ws = fmt_wb[orig_sheetnames[0]]
print("Post-save C5:C10 raw values + format:")
for r in range(5, 11):
    print(r, fmt_ws[f"C{r}"].value, fmt_ws[f"C{r}"].number_format)

output_spreadsheet = out_path
