import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def display(v):
    try:
        if hasattr(v, "text"):
            return f"FORMULA_OBJ:{v.text}"
    except Exception:
        pass
    return v

for ws in wb.worksheets:
    print("\n--- SHEET ---")
    print("Name:", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find non-empty rows/cols more accurately
    nonempty_rows = set()
    nonempty_cols = set()
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                nonempty_rows.add(cell.row)
                nonempty_cols.add(cell.column)
    print("Non-empty row count:", len(nonempty_rows), "from", (min(nonempty_rows) if nonempty_rows else None), "to", (max(nonempty_rows) if nonempty_rows else None))
    print("Non-empty col count:", len(nonempty_cols), "cols:", [get_column_letter(c) for c in sorted(nonempty_cols)])
    
    # Headers from first few rows
    for r in range(1, min(ws.max_row, 4) + 1):
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # Assume row 1 header if populated
    headers = [display(ws.cell(1, c).value) for c in range(1, ws.max_column + 1)]
    print("Column headers row1:", headers)
    
    # Sample first 10 rows
    print("First rows sample:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"  R{r}:", vals)
    
    # Last 5 rows
    print("Last rows sample:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"  R{r}:", vals)
    
    # Print cells containing formulas / text clues
    formula_cells = []
    text_cells = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((cell.coordinate, v))
            elif isinstance(v, str) and any(k in v.lower() for k in ["sum", "month", "zero", "criteria", "ignore"]):
                text_cells.append((cell.coordinate, v))
    print("Formula cells found:", formula_cells[:20], "count:", len(formula_cells))
    print("Relevant text clue cells:", text_cells[:20], "count:", len(text_cells))
