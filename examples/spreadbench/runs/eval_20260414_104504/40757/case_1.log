Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify exact target area before writing
for coord in ["A9", "B9", "A10", "B10", "A11", "B11"]:
    print(coord, "=", ws[coord].value)

# Determine actual data rows from rows under header row 2
data_rows = []
for r in range(3, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is not None and b is not None:
        data_rows.append(r)
print("Data rows:", data_rows)

start_row = min(data_rows)
end_row = max(data_rows)

# Write formulas into existing target cells B10:B11
for r in [10, 11]:
    month_label = ws.cell(r, 1).value
    current = ws.cell(r, 2).value
    print(f"Before write B{r}:", current, "month label:", month_label)
    formula = f'=IF(SUMPRODUCT((TEXT($A${start_row}:$A${end_row},"MMMM")=A{r})*($B${start_row}:$B${end_row}))=0,"",SUMPRODUCT((TEXT($A${start_row}:$A${end_row},"MMMM")=A{r})*($B${start_row}:$B${end_row})))'
    ws.cell(r, 2).value = formula
    print(f"Wrote B{r} formula:", formula)

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("Final formulas:")
for coord in ["B10", "B11"]:
    print(coord, "formula =", wsf[coord].value)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[orig_sheetnames[0]]
print("Verified values:")
for coord in ["A10", "B10", "A11", "B11"]:
    print(coord, "=", wsv[coord].value)

output_spreadsheet = outfile
