import os, shutil
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Sheet1"]

# Build Source 2 lookup maps
src2_dates = {}
for c in range(3, 8):  # C:G on row 7
    dt = ws.cell(7, c).value
    if dt is not None:
        src2_dates[dt] = c

src2_rows = {}
for r in range(8, ws.max_row + 1):
    name = ws.cell(r, 2).value
    if name is not None:
        src2_rows[name] = r

print("Source2 dates:", src2_dates)
print("Source2 rows:", src2_rows)

# Fill result area J:N for rows 3:5 based on Source1 rows/dates
for r in range(3, 6):
    result_name = ws.cell(r, 9).value   # I
    src1_name = ws.cell(r, 2).value     # B
    for c_res, c_src1 in zip(range(10, 15), range(3, 8)):  # J:N vs C:G
        date_hdr = ws.cell(2, c_res).value
        src1_val = ws.cell(r, c_src1).value

        if result_name is None or date_hdr is None or src1_name is None:
            continue

        if src1_name in src2_rows and date_hdr in src2_dates:
            src2_val = ws.cell(src2_rows[src1_name], src2_dates[date_hdr]).value
            result = (src1_val == src2_val)
        else:
            result = False

        cell = ws.cell(r, c_res)
        # preserve existing style and fill blanks / keep consistency by writing all target result cells
        cell.value = result

print("Filled result area preview before save:")
for r in range(2, 6):
    print(r, [ws.cell(r, c).value for c in range(9, 15)])

wb.save(outfile)
print("Saved:", outfile)

recalc_status = await recalculate(outfile)
print("Recalc:", recalc_status)

# Reload and verify
wb2 = load_workbook(outfile, data_only=True)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"]:
    # rename back if changed
    ws2 = wb2[wb2.sheetnames[0]]
    ws2.title = "Sheet1"
    wb2.save(outfile)
    print("Renamed sheet back to Sheet1 and saved.")
    wb2 = load_workbook(outfile, data_only=True)

wsv = wb2["Sheet1"]
print("Verified target range I2:N5:")
for r in range(2, 6):
    print(r, [wsv.cell(r, c).value for c in range(9, 15)])

output_spreadsheet = outfile
```
