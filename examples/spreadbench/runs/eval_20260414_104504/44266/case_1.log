    print(f"{get_column_letter(c)}4 -> {data_ws.cell(4,c).value}")

print("\nData row 14 values by column:")
for c in range(1, data_ws.max_column + 1):
    print(f"{get_column_letter(c)}14 -> {data_ws.cell(14,c).value}")

print("\nLookup target area before writing:")
for r in range(1, lookup_ws.max_row + 1):
    print(f"A{r}={lookup_ws[f'A{r}'].value!r}, B{r}={lookup_ws[f'B{r}'].value!r}")

# Determine exact output range: column B under 'Total Expenses', rows with years/formulas in col A
target_rows = []
for r in range(2, lookup_ws.max_row + 1):
    a_val = lookup_ws.cell(r, 1).value
    if a_val is not None:
        target_rows.append(r)

print("Target rows:", target_rows)

# Write INDEX/MATCH formulas in Lookup!B rows.
