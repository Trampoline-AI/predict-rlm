```repl
import os, shutil
from collections import Counter
from copy import copy
from openpyxl import load_workbook

# Re-open for detailed inspection
wb = load_workbook(input_spreadsheet)
src = wb["Imported Data"]
dup = wb["Duplicates"]

print("Imported Data dimensions:", src.max_row, src.max_column)
print("Duplicates dimensions:", dup.max_row, dup.max_column)

# Detailed headers and target cells
print("Headers Imported Data:", [src.cell(1,c).value for c in range(1, src.max_column+1)])
print("Headers Duplicates:", [dup.cell(1,c).value for c in range(1, dup.max_column+1)])

# Inspect example styles/number formats/alignment in Duplicates
for r in range(1, min(4, dup.max_row)+1):
    vals = [dup.cell(r,c).value for c in range(1, dup.max_column+1)]
    fmts = [dup.cell(r,c).number_format for c in range(1, dup.max_column+1)]
    aligns = [(dup.cell(r,c).alignment.horizontal, dup.cell(r,c).alignment.vertical) for c in range(1, dup.max_column+1)]
    print(f"Duplicates row {r} values:", vals)
    print(f"Duplicates row {r} formats:", fmts)
    print(f"Duplicates row {r} align:", aligns)

# Find true used rows in Imported Data (exclude fully blank)
used_rows = []
for r in range(2, src.max_row+1):
    vals = [src.cell(r,c).value for c in range(1, src.max_column+1)]
    if any(v is not None for v in vals):
        used_rows.append(r)

refs = [src.cell(r,3).value for r in used_rows]
counts = Counter(refs)
dupe_keys = sorted([k for k,v in counts.items() if k is not None and v > 1])
print("Duplicate keys in column C / Reference:", dupe_keys)
print("Counts:", {k: counts[k] for k in dupe_keys})

dupe_rows = []
for r in used_rows:
    key = src.cell(r,3).value
    if key in dupe_keys:
        row_vals = [src.cell(r,c).value for c in range(1, src.max_column+1)]
        dupe_rows.append((r, row_vals))
print("All duplicate source rows before sort:")
for item in dupe_rows:
    print(item[0], item[1])

# Sort ascending by Balance then Invoiced Date; convert dates robustly for sort only
def sort_date(v):
    if hasattr(v, "year"):
        return (v.year, v.month, v.day)
    if isinstance(v, str):
        parts = v.split("/")
        if len(parts) == 3:
            d,m,y = map(int, parts)
            return (y,m,d)
    return (9999, 12, 31)

sorted_dupe_rows = sorted(
    dupe_rows,
    key=lambda t: (float(t[1][4]) if t[1][4] is not None else float("inf"), sort_date(t[1][3]))
)
print("Sorted duplicate rows:")
for item in sorted_dupe_rows:
    print(item[0], item[1])

# Write output file
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

owb = load_workbook(out_path)
osheet = owb["Imported Data"]
dsheet = owb["Duplicates"]

# Clear existing duplicate data rows below header
for r in range(2, dsheet.max_row+1):
    for c in range(1, dsheet.max_column+1):
        dsheet.cell(r,c).value = None

# Ensure header preserved; if missing, copy from source
for c in range(1, osheet.max_column+1):
    if dsheet.cell(1,c).value is None:
        dsheet.cell(1,c).value = osheet.cell(1,c).value
    # copy header style from existing source if desired
    dsheet.cell(1,c)._style = copy(osheet.cell(1,c)._style)
    dsheet.cell(1,c).number_format = osheet.cell(1,c).number_format
    dsheet.cell(1,c).alignment = copy(osheet.cell(1,c).alignment)
    dsheet.cell(1,c).font = copy(osheet.cell(1,c).font)
    dsheet.cell(1,c).fill = copy(osheet.cell(1,c).fill)
    dsheet.cell(1,c).border = copy(osheet.cell(1,c).border)

# Copy duplicate rows with values and styles from source rows
out_row = 2
for src_r, vals in sorted_dupe_rows:
    for c in range(1, osheet.max_column+1):
        s = osheet.cell(src_r, c)
        d = dsheet.cell(out_row, c)
        d.value = s.value
        d._style = copy(s._style)
        d.number_format = s.number_format
        d.alignment = copy(s.alignment)
        d.font = copy(s.font)
        d.fill = copy(s.fill)
        d.border = copy(s.border)
    out_row += 1

# Match column widths from source
for key, dim in osheet.column_dimensions.items():
    dsheet.column_dimensions[key].width = dim.width

owb.save(out_path)
print("Saved:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

vwb = load_workbook(out_path, data_only=False)
print("Sheet names after recalc:", vwb.sheetnames)
if vwb.sheetnames != wb.sheetnames:
    # rename back if needed
    current_titles = vwb.sheetnames[:]
    for i, old_name in enumerate(wb.sheetnames):
        if i < len(vwb.worksheets):
            vwb.worksheets[i].title = old_name
    vwb.save(out_path)
    print("Renamed sheets back to:", wb.sheetnames)

check = load_workbook(out_path, data_only=True)
dcheck = check["Duplicates"]
print("Verified Duplicates rows:")
for r in range(1, dcheck.max_row+1):
    print(r, [dcheck.cell(r,c).value for c in range(1, dcheck.max_column+1)])

output_spreadsheet = out_path
