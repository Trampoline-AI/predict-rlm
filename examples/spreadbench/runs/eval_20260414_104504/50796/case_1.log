import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", headers)
    
    # find last non-empty row/col more accurately
    last_row = 0
    last_col = 0
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                last_col = max(last_col, c)
        if row_has:
            last_row = r
    print("Detected last non-empty row:", last_row, "last non-empty col:", last_col)
    
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, min(max(last_col, ws.max_column), 12) + 1)]
    
    first_rows = list(range(1, min(last_row, 10) + 1))
    last_rows = list(range(max(1, last_row - 4), last_row + 1)) if last_row else []
    print("First rows sample:")
    for r in first_rows:
        print(r, row_vals(r))
    print("Last rows sample:")
    for r in last_rows:
        print(r, row_vals(r))
    
    # print formulas in used range (first 15 cols, first 20 rows)
    print("Formula cells in first 20 rows x first 15 cols:")
    found = 0
    for r in range(1, min(last_row, 20) + 1):
        for c in range(1, min(max(last_col, ws.max_column), 15) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                print(f"{get_column_letter(c)}{r} = {v}")
                found += 1
    if not found:
        print("No formulas found in inspected area.")

for ws in wb.worksheets:
    sheet_info(ws)
```
