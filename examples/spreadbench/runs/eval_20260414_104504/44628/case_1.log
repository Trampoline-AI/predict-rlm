Code:
```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook and inspect target/formulas before writing
wb = load_workbook(infile)
orig_sheets = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Pre-write target headers D2:G2:", [ws[c].value for c in ["D2","E2","F2","G2"]])
print("Pre-write target values D3:G3:", [ws[c].value for c in ["D3","E3","F3","G3"]])
print("Existing formulas in D3:G3:", [ws[c].value for c in ["D3","E3","F3","G3"]])

# Compute sums by first letter from actual data rows
totals = defaultdict(float)
data_rows = []
for r in range(2, ws.max_row + 1):
    product = ws.cell(r, 1).value
    qty = ws.cell(r, 2).value
    if product is None or qty is None:
        continue
    first = str(product).strip()[0] if str(product).strip() else None
    if first is None:
        continue
    try:
        num = float(qty)
    except Exception:
        continue
    totals[first] += num
    data_rows.append((r, product, qty, first))

print("Data rows used:", data_rows)
print("Computed totals:", dict(totals))

# Write results exactly to D3:G3 based on D2:G2 headers
for col in range(4, 8):  # D:G
    header = ws.cell(2, col).value
    val = totals.get(str(header).strip(), 0) if header is not None else None
    # preserve integer appearance if whole number
    if isinstance(val, float) and val.is_integer():
        val = int(val)
    ws.cell(3, col).value = val

os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheets:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheets)
    # rename by position
    for i, name in enumerate(orig_sheets):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = name
    wb_check.save(outfile)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheets[0]]
print("Verified D2:G3:")
for r in [2, 3]:
    print(r, [wsv.cell(r, c).value for c in range(4, 8)])

output_spreadsheet = outfile
```
