Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Target sheet:", ws.title)
print("Pre-write target range B5:E7:")
for r in range(5, 8):
    print(r, [ws.cell(r, c).value for c in range(2, 6)])

# Write formulas to B5:E7
for c in range(2, 6):  # B:E
    col = get_column_letter(c)
    for r in range(5, 8):  # 5:7
        formula = (
            f'=IF(INDEX({col}$1:{col}$3,MATCH($A{r},$A$1:$A$3,0))=MAX({col}$1:{col}$3),'
            f'IF(COUNTIF({col}$1:{col}$3,MAX({col}$1:{col}$3))=1,6,'
            f'IF(COUNTIF({col}$1:{col}$3,MAX({col}$1:{col}$3))=2,3,2)),0)'
        )
        ws.cell(r, c).value = formula

# Show formulas written
print("Written formulas B5:E7:")
for r in range(5, 8):
    print(r, [ws.cell(r, c).value for c in range(2, 6)])

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore original sheet names if recalculation changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify data_only results
vwb = load_workbook(outfile, data_only=True)
vws = vwb[orig_sheetnames[0]]
print("Verified values B5:E7 after recalc:")
for r in range(5, 8):
    print(f"Row {r} label {vws.cell(r,1).value}:", [vws.cell(r, c).value for c in range(2, 6)])

output_spreadsheet = outfile
```
