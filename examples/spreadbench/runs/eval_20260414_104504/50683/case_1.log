import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

print("Sheetnames:", wb.sheetnames)
print("Table names raw:", list(ws.tables.keys()))
print("ws.tables type:", type(ws.tables))

# safe table inspection
for name in ws.tables.keys():
    tbl = ws.tables[name]
    print("table", name, "object type:", type(tbl), "repr:", tbl)

# inspect relevant area A:Q
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print("Row", r, vals)

print("\nHeaders with indices:")
for c in range(1, ws.max_column + 1):
    print(c, get_column_letter(c), ws.cell(1, c).value)

# compute intended last-4 nonblank averages
score_cols = list(range(2, 15))  # B:N
computed = {}
for r in range(2, ws.max_row + 1):
    scores = []
    for c in score_cols:
        v = ws.cell(r, c).value
        if isinstance(v, (int, float)):
            scores.append(v)
    if scores:
        last4 = scores[-4:]
        avg4 = sum(last4) / len(last4)
    else:
        last4 = []
        avg4 = None
    computed[r] = avg4
    print(f"Row {r} golfer {ws.cell(r,1).value}: scores={scores} last4={last4} avg4={avg4}")

# write results to existing target column Q under 'last 4 trend'
print("\nPre-write Q values:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"Q{r}"].value)

for r, avg4 in computed.items():
    ws[f"Q{r}"] = avg4

# save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to", outfile)

# recalc
result = await recalculate(outfile)
print("Recalculate:", result)

# reload and restore sheet names if needed
orig_names = wb.sheetnames[:]
wb2 = load_workbook(outfile)
print("Post-recalc sheetnames:", wb2.sheetnames)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Renamed sheets back to", orig_names)

# verify with data_only
ver = load_workbook(outfile, data_only=True)
wsv = ver[orig_names[0]]
print("\nVerified target cells Q1:Q{}".format(wsv.max_row))
for r in range(1, wsv.max_row + 1):
