import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # headers from first 3 rows to detect actual header row
    for r in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    # choose first row as provisional headers for display
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row1:", [(get_column_letter(i+1), headers[i]) for i in range(len(headers))])
    # sample first 10 rows
    first_n = min(10, ws.max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # sample last 5 rows
    start = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# extra targeted scan for columns around A:I and formulas
for ws in wb.worksheets:
    print(f"\nTargeted A:I scan for {ws.title}")
    for r in range(1, min(ws.max_row, 20) + 1):
        vals = []
        for c in range(1, min(ws.max_column, 12) + 1):
            v = ws.cell(r, c).value
            vals.append(v)
        print(r, vals)
    # find formulas in first 30 rows
    formulas = []
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formulas in first 30 rows:", formulas[:20], "count:", len(formulas))
