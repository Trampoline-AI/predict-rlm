```repl
import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Identify active data rows: rows with any unit/residual values before blank separator and excluding min/max rows
data_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    units = [ws.cell(r, c).value for c in range(2, 7)]
    resid = ws.cell(r, 9).value
    if a in ("min", "max"):
        continue
    if any(v is not None for v in units) or resid is not None:
        if any(v is not None for v in units) and isinstance(resid, (int, float)):
            data_rows.append(r)
print("Data rows:", data_rows)

mins = {c: ws.cell(20, c).value for c in range(2,7)}
maxs = {c: ws.cell(21, c).value for c in range(2,7)}
print("Min constraints:", mins)
print("Max constraints:", maxs)

# simulate and print all rows
sim_results = []
for r in data_rows:
    orig = {c: ws.cell(r, c).value for c in range(2,7)}
    resid = ws.cell(r, 9).value
    vals = orig.copy()
    remaining = resid
    if resid > 0:
        order = range(2,7)   # add unit1 -> unit5
        for c in order:
            v = vals[c]
            if v == 0:
                continue
            cap = maxs[c] - v
            delta = min(cap, remaining)
            vals[c] += delta
            remaining -= delta
            if remaining == 0:
                break
    elif resid < 0:
        need = -resid
        order = range(6,1,-1)  # subtract unit5 -> unit1
        for c in order:
            v = vals[c]
            if v == 0:
                continue
            cap = v - mins[c]
            delta = min(cap, need)
            vals[c] -= delta
            need -= delta
            if need == 0:
                break
        remaining = -need
    sim_results.append((r, orig, resid, vals, remaining))

for item in sim_results:
    r, orig, resid, vals, remaining = item
    print(f"Row {r}: residual {resid}, before {[orig[c] for c in range(2,7)]}, after {[vals[c] for c in range(2,7)]}, leftover {remaining}")

# Apply in place
for r, orig, resid, vals, remaining in sim_results:
    for c in range(2,7):
        ws.cell(r, c).value = vals[c]
    ws.cell(r, 9).value = 0  # set Column I to 0 at the end

# save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalc and preserve sheet names
orig_names = wb.sheetnames[:]
res = await recalculate(out_path)
print("Recalc:", res)
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back:", wb2.sheetnames)

# verify
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("Verification target rows:")
for r in data_rows:
    print(r, [vws.cell(r,c).value for c in range(2,7)], "I=", vws.cell(r,9).value)
print("Min/max rows remain:", [vws.cell(20,c).value for c in range(1,10)], [vws.cell(21,c).value for c in range(1,10)])

output_spreadsheet = out_path
