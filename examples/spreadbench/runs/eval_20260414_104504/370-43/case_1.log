import os, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws):
    max_r, max_c = ws.max_row, ws.max_column
    headers1 = [ws.cell(1,c).value for c in range(1, max_c+1)]
    headers2 = [ws.cell(2,c).value for c in range(1, max_c+1)] if max_r >= 2 else []
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", max_r, "max_col:", max_c)
    print("Row1:", headers1)
    if headers2:
        print("Row2:", headers2)
    # print rows 1-10 and last 5
    rows_to_show = list(range(1, min(max_r, 10)+1))
    tail_start = max(1, max_r-4)
    for r in range(tail_start, max_r+1):
        if r not in rows_to_show:
            rows_to_show.append(r)
    for r in rows_to_show:
        vals = [ws.cell(r,c).value for c in range(1, max_c+1)]
        print(f"R{r}: {vals}")

for ws in wb.worksheets:
    sheet_summary(ws)

# Specifically inspect A7:A30 (and around any Xs) on each sheet
for ws in wb.worksheets:
    print(f"\nInspecting Column A in {ws.title}, rows 1:40")
    vals = []
    for r in range(1, min(ws.max_row, 40)+1):
        vals.append((r, ws[f"A{r}"].value))
    print(vals)
    x_rows = [r for r in range(7, min(ws.max_row, 1000)+1) if str(ws[f"A{r}"].value).strip().upper() == "X"]
    print("X rows in A7:A1000:", x_rows[:50], "count=", len(x_rows))
    for r in x_rows[:10]:
        lo, hi = max(1, r-2), min(ws.max_row, r+2)
        print(f"Around row {r}:")
        for rr in range(lo, hi+1):
            print(rr, [ws.cell(rr,c).value for c in range(1, ws.max_column+1)])
```
