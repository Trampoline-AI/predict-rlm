print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    orig = wb.sheetnames
    for i, name in enumerate(orig):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to original names:", wb2.sheetnames)

wbv = load_workbook(out_path, data_only=False)
wsv = wbv["Before Insert Row"]

# Verify blank inserted rows and shifted X rows
