import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Before Insert Row"]

# Further inspection: merged cells, row dimensions, styles around target rows
print("Merged ranges:", list(ws.merged_cells.ranges)[:20], "count", len(ws.merged_cells.ranges))
target_rows = [r for r in range(7, min(ws.max_row, 1000)+1) if str(ws[f"A{r}"].value).strip().upper() == "X"]
print("Target X rows before:", target_rows)

for r in target_rows:
    print(f"\nDetailed around row {r}:")
    for rr in range(r-1, r+2):
        vals = [ws.cell(rr,c).value for c in range(1, 15)]
        print(rr, vals)
    print("Row heights:", {rr: ws.row_dimensions[rr].height for rr in range(r-1, r+2)})
    print("Styles A:N ids:", {rr: [ws.cell(rr,c).style_id for c in range(1,15)] for rr in range(r-1, r+2)})

# Create output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))

# Perform insertion bottom-up
for r in sorted(target_rows, reverse=True):
    ws.insert_rows(r, 1)

wb.save(out_path)
print("\nSaved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalc:", result)

# Reload and verify
