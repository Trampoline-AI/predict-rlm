import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula

infile = input_spreadsheet
orig_wb = load_workbook(infile)
ws = orig_wb["Sheet1"]
original_sheetnames = orig_wb.sheetnames[:]

print("Inspecting target cells/formulas in column B and matching rows...")
for r in range(2, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    d = ws[f"D{r}"].value
    b_display = b.text if isinstance(b, ArrayFormula) else b
    print(r, {"A": a, "B": b_display, "C": c, "D": d})

# Show which A models actually exist in column C and expected returned values
c_to_d = {}
for r in range(2, ws.max_row + 1):
    c_to_d[ws[f"C{r}"].value] = ws[f"D{r}"].value

matches = []
nonmatches = []
for r in range(2, ws.max_row + 1):
    model = ws[f"A{r}"].value
    if model in c_to_d:
        matches.append((r, model, c_to_d[model]))
    else:
        nonmatches.append((r, model))
print("Matching A values found in C:", matches)
print("First few nonmatches:", nonmatches[:10], "count:", len(nonmatches))

# Also inspect cached values if workbook opened data_only
data_wb = load_workbook(infile, data_only=True)
dws = data_wb["Sheet1"]
print("Current cached B values before modification:")
for r in range(2, ws.max_row + 1):
    print(f"B{r} cached:", dws[f"B{r}"].value)

# Write corrected formulas to exact target cells B2:B19
outfile = "/sandbox/output/output_spreadsheet/" + os.path.basename(infile)
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Sheet1"]
last_row = ws.max_row

for r in range(2, last_row + 1):
    formula = f'=IFERROR(INDEX($D$2:$D${last_row},MATCH(A{r},$C$2:$C${last_row},0)),"")'
    ws[f"B{r}"] = formula

wb.save(outfile)
print("Saved formulas to", outfile)

result = await recalculate(outfile)
print("Recalculate:", result)

# Reload and restore sheet names if LibreOffice changed them
chk = load_workbook(outfile)
if chk.sheetnames != original_sheetnames:
    print("Sheet names changed:", chk.sheetnames, "-> restoring", original_sheetnames)
    # Rename by position
    for i, name in enumerate(original_sheetnames):
        chk.worksheets[i].title = name
    chk.save(outfile)
else:
    print("Sheet names preserved:", chk.sheetnames)

# Verify output after recalc
verify = load_workbook(outfile, data_only=True)
vws = verify[original_sheetnames[0]]
print("Verified target cells B2:B19 after recalc:")
for r in range(2, vws.max_row + 1):
    print(f"Row {r}: A={vws[f'A{r}'].value}, B={vws[f'B{r}'].value}, C={vws[f'C{r}'].value}, D={vws[f'D{r}'].value}")

output_spreadsheet = outfile
```
