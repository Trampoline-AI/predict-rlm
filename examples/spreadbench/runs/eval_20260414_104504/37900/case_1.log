import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = "/sandbox/output/output_spreadsheet/" + os.path.basename(infile)

# Reload and inspect exact target cells/range
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

for cell in ["D4","E4","D5","E5","A5","B5","A16","B16"]:
    print(cell, "=>", ws[cell].value)

# Write dynamic formulas
ws["E4"] = "=TODAY()"
ws["E5"] = '=IFERROR(VLOOKUP(DATE(YEAR(E4),MONTH(E4),1),$A$5:$B$16,2,FALSE),"")'

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("Formulas after save:", {"E4": wsf["E4"].value, "E5": wsf["E5"].value})

wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals[orig_sheetnames[0]]
print("Cached values:", {"E4": wsv["E4"].value, "E5": wsv["E5"].value})
print("Final sheet names:", wb_vals.sheetnames)

output_spreadsheet = outfile
