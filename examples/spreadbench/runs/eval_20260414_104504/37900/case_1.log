```repl
import os, json, math, statistics, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)
print("Input file:", input_spreadsheet)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def nonempty_row_count(ws):
    count = 0
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            count += 1
    return count

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for s in wb.sheetnames:
    ws = wb[s]
    print("\n" + "="*80)
    print(f"Sheet: {s}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}, nonempty_rows={nonempty_row_count(ws)}")
    headers = row_values(ws, 1)
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row 2:", row_values(ws, 2))
    first_n = min(10, ws.max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r))
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r))

    # print formulas / interesting cells
    formula_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells found (up to 20):", formula_cells[:20], "total:", len(formula_cells))
```
