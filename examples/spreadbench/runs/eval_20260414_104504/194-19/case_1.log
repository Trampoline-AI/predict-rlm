from openpyxl import load_workbook
from collections import defaultdict
from pathlib import Path
import shutil, os

# Load workbook
infile = input_spreadsheet
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1 = wb[orig_sheetnames[0]]
ws2 = wb[orig_sheetnames[1]]

# Build source mapping from Sheet2 using date + meet + day + race#
# H on Sheet1 = source Top from Sheet2 col I
# I on Sheet1 = rank position 1..n based on whether Sheet1 Tab matches Sheet2 cols J onward
source_map = {}
src_headers = [ws2.cell(1, c).value for c in range(1, ws2.max_column + 1)]
print("Sheet2 headers:", src_headers)

for r in range(2, ws2.max_row + 1):
    date_val = ws2.cell(r, 2).value
    meet = ws2.cell(r, 4).value
    day = ws2.cell(r, 6).value
    race = ws2.cell(r, 8).value
    top = ws2.cell(r, 9).value
    picks = [ws2.cell(r, c).value for c in range(10, ws2.max_column + 1)]
    rank_map = {}
    for idx, num in enumerate(picks, start=1):
        if num not in (None, ""):
            rank_map[num] = idx
    key = (date_val, meet, day, race)
    source_map[key] = {"top": top, "rank_map": rank_map, "picks": picks}

print("Total source keys:", len(source_map))

# Verify some missing targets before write
print("\nSample target rows before write (first 25 rows and some later blanks):")
sample_rows = list(range(2, 26))
later_blank_rows = []
for r in range(2, ws1.max_row + 1):
    if (ws1.cell(r, 8).value in (None, "") or ws1.cell(r, 9).value in (None, "")) and r > 25:
        later_blank_rows.append(r)
        if len(later_blank_rows) >= 12:
            break
for r in sample_rows + later_blank_rows:
    print(r, [ws1.cell(r, c).value for c in range(2, 11)])

# Fill Sheet1 columns H and I
updated_h = 0
updated_i = 0
missing_keys = []
rows_without_rank = 0

for r in range(2, ws1.max_row + 1):
    key = (ws1.cell(r, 2).value, ws1.cell(r, 4).value, ws1.cell(r, 6).value, ws1.cell(r, 7).value)
    src = source_map.get(key)
    if not src:
        missing_keys.append((r, key))
        continue

    # Column H: fill Top, but don't overwrite existing nonblank values
    if ws1.cell(r, 8).value in (None, "") and src["top"] not in (None, ""):
        ws1.cell(r, 8).value = src["top"]
        updated_h += 1

    # Column I: fill rank based on Tab matching one of Sheet2 J:M/(further right if present)
    tab = ws1.cell(r, 10).value
    rank = src["rank_map"].get(tab)
    if ws1.cell(r, 9).value in (None, "") and rank is not None:
        ws1.cell(r, 9).value = rank
        updated_i += 1
    elif ws1.cell(r, 9).value in (None, "") and rank is None:
        rows_without_rank += 1

print("\nUpdated H cells:", updated_h)
print("Updated I cells:", updated_i)
print("Rows with matching meet/race but no rank match for Tab:", rows_without_rank)
print("Missing source keys count:", len(missing_keys))
print("First 10 missing keys:", missing_keys[:10])

# Inspect exact target area after write
print("\nSample target rows after write:")
for r in sample_rows + later_blank_rows:
    print(r, [ws1.cell(r, c).value for c in range(2, 11)])

# Save
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / Path(infile).name
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate as required
recalc_result = await recalculate(str(outfile))
print("Recalc:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)

# Verification with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws1 = wb_verify[orig_sheetnames[0]]

# Verify target columns H and I on representative rows
print("\nVerification rows (H and I values):")
verify_rows = sample_rows + later_blank_rows + [ws1.max_row-5, ws1.max_row-4, ws1.max_row-3, ws1.max_row-2, ws1.max_row-1, ws1.max_row]
seen = set()
for r in verify_rows:
    if 2 <= r <= vws1.max_row and r not in seen:
        seen.add(r)
        print(r, "Meet=", repr(vws1.cell(r,4).value), "Race=", vws1.cell(r,7).value, "H=", vws1.cell(r,8).value, "I=", vws1.cell(r,9).value, "Tab=", vws1.cell(r,10).value)

output_spreadsheet = str(outfile)
```
