import os, json, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row1 headers/values:", headers)
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))
    print("Last rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))

if "dashboard" in wb.sheetnames:
    ws = wb["dashboard"]
    print("\n--- dashboard targeted cells ---")
    for coord in ["B5", "B6", "B8", "A5", "A6", "A8", "C5", "C6", "C8"]:
