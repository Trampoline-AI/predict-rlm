import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Dashboard"]

print("Before change:")
for coord in ["B5","B6","B7","B8","A8","C8"]:
    c = ws[coord]
    print(coord, "value=", c.value, "numfmt=", c.number_format)

# Inspect style references around target
print("Style ids:", {coord: ws[coord].style_id for coord in ["B5","B6","B7","B8"]})

# Write formula to B8
formula = '=IFERROR(TEXT(VALUE(LEFT(B6,FIND(" ",B6)-1))/VALUE(LEFT(B5,FIND(" ",B5)-1)),"0%")&" WIN RATE","")'
ws["B8"] = formula

# Copy style from nearby metric cells if B8 had default/no style
ws["B8"]._style = ws["B7"]._style

print("Written formula to B8:", ws["B8"].value, "style_id", ws["B8"].style_id, "numfmt", ws["B8"].number_format)

orig_sheetnames = wb.sheetnames[:]
wb.save(outfile)

calc_result = await recalculate(outfile)
print("Recalculate:", calc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Dashboard"]
print("Final formula B8:", wsf["B8"].value)

wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals["Dashboard"]
print("Verified values:")
for coord in ["B5","B6","B8"]:
    print(coord, repr(wsv[coord].value))

output_spreadsheet = outfile
