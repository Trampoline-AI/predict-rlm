import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Extra inspection around target cells/styles/formulas
print("Merged ranges:", list(ws.merged_cells.ranges))
for r in range(1, ws.max_row + 1):
    print(
        r,
        {"A": ws[f"A{r}"].value, "C": ws[f"C{r}"].value, "D": ws[f"D{r}"].value, "E": ws[f"E{r}"].value,
         "F": ws[f"F{r}"].value, "G": ws[f"G{r}"].value, "H": ws[f"H{r}"].value}
    )
print("H styles before:")
for r in range(3, 8):
    c = ws[f"H{r}"]
    print(r, "value", c.value, "style_id", c.style_id, "numfmt", c.number_format)

# Apply formula to asset rows only (3 to row before Total)
for r in range(3, ws.max_row):
    a = ws[f"A{r}"].value
    if a is None or str(a).strip().lower() == "total":
        continue
    # if loss, ITV adjusted by loss; else if profit < cost, full profit; else cost - ITV
    ws[f"H{r}"] = f'=IF(F{r}<0,E{r}+F{r},IF(F{r}<C{r},F{r},C{r}-E{r}))'

# Preserve total formula if present/appropriate
ws[f"H{ws.max_row}"] = f"=SUM(H3:H{ws.max_row-1})"

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

res = await recalculate(out_path)
print("Recalc:", res)

# Restore sheet names if changed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, nm in enumerate(orig_names):
        wb2.worksheets[i].title = nm
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
print("Formulas in H3:H7:")
