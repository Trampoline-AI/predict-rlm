from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os

path = input_spreadsheet
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(path)

wb = load_workbook(path)
ws = wb["Sheet1"]

# Compute exact target outputs from source table
header_sizes = [ws.cell(2, c).value for c in range(2, 13)]   # B2:L2
ratings = [ws.cell(r, 13).value for r in range(3, 9)]        # M3:M8
grid = [[ws.cell(r, c).value for c in range(2, 13)] for r in range(3, 9)]  # B3:L8

subject_rating = ws["S2"].value
print("subject_rating:", subject_rating)
print("header_sizes:", header_sizes)
print("ratings:", ratings)

yellow_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")

computed = {}
for r in range(2, 7):
    target_size = ws[f"P{r}"].value
    vals = []
    for i, rating in enumerate(ratings):
        if rating != subject_rating:
            continue
        for j, sz in enumerate(header_sizes):
            if sz == target_size:
                v = grid[i][j]
                if v not in (None, ""):
                    vals.append(v)
    result = "" if not vals else sum(vals) / len(vals)
    computed[r] = (target_size, vals, result)
    print(f"Row {r}: size={target_size}, matched_vals={vals}, result={result!r}")

# Write robust literal outputs so verification won't produce None
for r, (_, _, result) in computed.items():
    ws[f"Q{r}"] = result
    ws[f"Q{r}"].fill = yellow_fill

os.makedirs("/sandbox/output/output_spreadsheet", exist_ok=True)
wb.save(out_path)
print("saved:", out_path)

res = await recalculate(out_path)
print("recalc:", res)

# verify
wbd = load_workbook(out_path, data_only=True)
wsd = wbd["Sheet1"]
for r in range(2, 7):
    print(f"Verified Q{r}={wsd[f'Q{r}'].value!r}, fill should be yellow in file")
```
