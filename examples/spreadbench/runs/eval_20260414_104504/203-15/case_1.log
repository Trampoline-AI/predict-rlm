import os
from collections import OrderedDict, defaultdict
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws_main = wb["Main"]
ws_out = wb["Output Required"]

# Build exact target headers:
main_headers_ag = [ws_main.cell(1, c).value for c in range(1, 8)]  # A:G
allowance_headers = []
for r in range(2, ws_main.max_row + 1):
    desc = ws_main.cell(r, 8).value
    if desc not in (None, "") and desc not in allowance_headers:
        allowance_headers.append(desc)

target_headers = main_headers_ag + allowance_headers + ["Total"]
print("Target headers for Output Required:", target_headers)  # A:M expected
print("Target columns count:", len(target_headers))

# Group rows by staff no. preserving order
staff_order = []
staff_rows = OrderedDict()
for r in range(2, ws_main.max_row + 1):
    staff = ws_main.cell(r, 1).value
    if staff in (None, ""):
        continue
    if staff not in staff_rows:
        staff_order.append(staff)
        staff_rows[staff] = []
    staff_rows[staff].append(r)

print("Staff order:", staff_order)

# Clear existing output sheet values in a reasonable used range
for row in ws_out.iter_rows(min_row=1, max_row=max(ws_out.max_row, len(staff_order)+5), min_col=1, max_col=13):
    for cell in row:
        cell.value = None

# Write headers A:M
for c, header in enumerate(target_headers, start=1):
    ws_out.cell(1, c).value = header

# Populate one row per staff
allowance_col_map = {name: idx for idx, name in enumerate(allowance_headers, start=8)}  # H onward
print("Allowance to output column map:", allowance_col_map)

for out_r, staff in enumerate(staff_order, start=2):
    rows = staff_rows[staff]
    first_r = rows[0]
    # Copy A:G from first occurrence
    for c in range(1, 8):
        ws_out.cell(out_r, c).value = ws_main.cell(first_r, c).value
    
    # Fill allowances from H/I in Main into H:L in Output
    for src_r in rows:
        desc = ws_main.cell(src_r, 8).value
        amt = ws_main.cell(src_r, 9).value
        if desc in allowance_col_map:
            ws_out.cell(out_r, allowance_col_map[desc]).value = amt
    
    # Total in M
    ws_out.cell(out_r, 13).value = f"=SUM(H{out_r}:L{out_r})"

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if changed
wb_chk = load_workbook(outfile)
print("Sheet names after recalc:", wb_chk.sheetnames)
if wb_chk.sheetnames != orig_sheet_names:
    # rename by position to original names
    for i, expected_name in enumerate(orig_sheet_names):
        if i < len(wb_chk.worksheets):
            wb_chk.worksheets[i].title = expected_name
    wb_chk.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vout = wb_verify["Output Required"]

print("\nVerified Output Required A1:M{}:".format(vout.max_row))
for r in range(1, vout.max_row + 1):
    print(r, [vout.cell(r, c).value for c in range(1, 14)])

# Additional targeted checks
print("\nTarget header row A1:M1:", [vout.cell(1, c).value for c in range(1, 14)])
for r in range(2, vout.max_row + 1):
    print(f"Row {r} key fields:", {
        "staff": vout.cell(r, 1).value,
        "H_to_M": [vout.cell(r, c).value for c in range(8, 14)]
    })

output_spreadsheet = outfile
