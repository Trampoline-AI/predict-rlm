import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and compute last non-empty entry in A1:A11
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

vals = [ws[f"A{r}"].value for r in range(1, 12)]
last_nonempty = None
last_row = None
for r in range(1, 12):
    v = ws[f"A{r}"].value
    if v not in (None, ""):
        last_nonempty = v
        last_row = r

day_num = last_nonempty.day
print("Last non-empty row in A1:A11:", last_row, "value:", last_nonempty, "day:", day_num)
print("Current B1 before write:", ws["B1"].value)

# Write static number to B1
ws["B1"] = int(day_num)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[orig_sheetnames[0]]
print("Verification target cells:")
for r in range(1, 12):
    print(f"Row {r}: A{r}={wsv[f'A{r}'].value!r}, B{r}={wsv[f'B{r}'].value!r}")

output_spreadsheet = outfile
