Code:
```repl
from openpyxl import load_workbook
import os

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Verify nearby relevant data and expected result
print("Dates/sales near end:")
for r in range(max(2, ws.max_row - 7), ws.max_row + 1):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

# Compute expected sum in Python for the last 4 weekday dates up to I4, inclusive
target_date = ws["I4"].value
pairs = []
for r in range(2, ws.max_row + 1):
    d = ws.cell(r, 1).value
    v = ws.cell(r, 2).value
    if d is not None and v is not None and d <= target_date:
        pairs.append((d, v, r))
pairs_sorted = sorted(pairs, key=lambda x: x[0])
last4 = pairs_sorted[-4:]
print("Last 4 dates <= I4:", last4)
expected_sum = sum(v for _, v, _ in last4)
print("Expected sum:", expected_sum)

# Write formula to I6
# Uses LARGE to find the 4th most recent date <= I4, then SUMIFS between that date and I4 inclusive.
formula = '=SUMIFS(B:B,A:A,">="&LARGE($A$2:$A$31*($A$2:$A$31<=$I$4),4),A:A,"<="&$I$4)'
# Because LARGE with array multiplication may be risky in Calc without CSE, safer to use SUMPRODUCT/ROWless? 
# Better use INDEX/MATCH on sorted weekday-only data:
# Find position of I4 in A, then sum B from 3 rows above through matched row.
formula = '=SUM(INDEX($B$2:$B$31,MATCH($I$4,$A$2:$A$31,0)-3):INDEX($B$2:$B$31,MATCH($I$4,$A$2:$A$31,0)))'
print("Old I6:", ws["I6"].value)
ws["I6"] = formula
print("New I6 formula:", ws["I6"].value)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
orig_sheetnames = wb.sheetnames[:]
wb.save(out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore sheet names if recalculate changed them
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for ws_obj, orig_name in zip(wb2.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)
else:
    print("Sheet names after recalc:", wb2.sheetnames)

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_sheetnames[0]]
print("Verified target cells:")
print("I4 =", wsv["I4"].value)
print("I6 =", wsv["I6"].value)
print("Expected sum =", expected_sum)

# Also inspect formula workbook
wbf = load_workbook(out_path, data_only=False)
print("Stored formula in I6:", wbf[orig_sheetnames[0]]["I6"].value)

final_output_path = out_path
```
