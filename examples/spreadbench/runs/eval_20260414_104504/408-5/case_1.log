orig_path = input_spreadsheet
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(orig_path))

# Reload ORIGINAL workbook to rebuild cleanly
wb = load_workbook(orig_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Inspect target/current values again
