sum_zero = 0.0
for r in range(2, ws.max_row + 1):
    e = ws.cell(r, 5).value
    d = ws.cell(r, 4).value
    if e == 0 and isinstance(d, (int, float)):
        sum_zero += d
print("Computed sum_zero:", sum_zero)

# Build compact output rows
new_rows = []
new_rows.append([ws.cell(1, c).value for c in range(1, 6)])  # header

for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    is_blank = all(v is None for v in vals)
    if is_blank:
        continue

    ref = ws.cell(r, 3).value
    e = ws.cell(r, 5).value

    # Delete all rows where E == 0 except BR1 Sales reference row
    if e == 0:
        if ref is not None and "BR1 Sales" in str(ref):
            vals[3] = sum_zero  # put result into column D on BR1 Sales row
            new_rows.append(vals)
        else:
            continue
    else:
        # preserve other nonblank rows
        new_rows.append(vals)

# If there's a Total Zero row, align it to the same computed value (preserve existing helper row)
for row in new_rows:
    if row[2] == "Total Zero":
        row[3] = sum_zero

print("New rows count:", len(new_rows))
for i, row in enumerate(new_rows, start=1):
    print("OUT", i, row)

# Clear all existing cells then write compact rows
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

for r_idx, row_vals in enumerate(new_rows, start=1):
    for c_idx, v in enumerate(row_vals, start=1):
        ws.cell(r_idx, c_idx).value = v

# Physically delete trailing blank rows
current_max = ws.max_row
if current_max > len(new_rows):
    ws.delete_rows(len(new_rows) + 1, current_max - len(new_rows))

wb.save(out_path)
print("Saved cleaned workbook:", out_path)

# Recalculate
res = await recalculate(out_path)
