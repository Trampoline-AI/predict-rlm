import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Reload original workbook for writing
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify target and existing state before writing
print("Writing to target cell D2. Current value:", ws["D2"].value)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Data extent rows 2 to", ws.max_row)

# Write actual Excel formula
formula = f'=SUMIF(A2:A{ws.max_row},111111,B2:B{ws.max_row})'
ws["D2"] = formula
print("Written formula in D2:", ws["D2"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename by position back to original names
    for i, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formula and cached value
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("Verified formula in D2:", ws_formula["D2"].value)

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]
print("Verified cached value in D2:", ws_values["D2"].value)
print("A2:A12:", [ws_values[f"A{r}"].value for r in range(2, 13)])
print("B2:B12:", [ws_values[f"B{r}"].value for r in range(2, 13)])

output_spreadsheet = outfile
