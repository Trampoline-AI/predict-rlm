from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# inspect style/format near example cells to mimic if possible
print("Before writing, sample A/E styles:")
for coord in ["A3","A8","E8","E9","E21"]:
    c = ws[coord]
    print(coord, "value=", c.value, "numfmt=", c.number_format, "style=", c.style_id)

# determine last relevant row based on any nonblank in B/F/E/A, but mostly B
last_relevant = 0
for r in range(ws.max_row, 0, -1):
    if ws.cell(r, 2).value not in (None, "") or ws.cell(r, 5).value not in (None, "") or ws.cell(r, 6).value not in (None, ""):
        last_relevant = r
        break
print("last_relevant:", last_relevant)

# write formulas in A3:A(last_relevant)
for r in range(3, last_relevant + 1):
    formula = f'=IF(B{r}="","",$B$2&"-02-"&TEXT(COUNTIF($B$3:B{r},"?*")+9,"000"))'
    ws.cell(r, 1).value = formula
    # copy style from E same row if present, else from A3 existing/default
    ws.cell(r, 1)._style = ws.cell(r, 5)._style

wb.save(outfile)
print("Saved to", outfile)

# recalculate
res = await recalculate(outfile)
print("Recalc:", res)

# restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("\nFormulas in A8:A12, A18:A24:")
for r in [8,9,10,11,12,18,19,20,21,22,23,24,28,29,32,34,36]:
