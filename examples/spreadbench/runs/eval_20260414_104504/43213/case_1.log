from openpyxl import load_workbook
from openpyxl.styles import numbers
from openpyxl.utils import column_index_from_string
import os, shutil

# Further inspect exact target/source area
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Column A/B rows 9:16:")
for r in range(9, 17):
    print(r, "A=", ws[f"A{r}"].value, "B=", ws[f"B{r}"].value, "A_fmt=", ws[f"A{r}"].number_format, "B_fmt=", ws[f"B{r}"].number_format)

print("Target column index for B:", column_index_from_string("B"))
print("Last non-empty row in col A and B:")
last_a = max(r for r in range(1, ws.max_row + 1) if ws[f"A{r}"].value not in (None, ""))
last_b_nonempty = [r for r in range(1, ws.max_row + 1) if ws[f"B{r}"].value not in (None, "")]
print("last_a", last_a, "nonempty B rows", last_b_nonempty)

# Write formulas for rows 12 through last non-empty data row in A
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy(input_spreadsheet, out_path)

wb2 = load_workbook(out_path)
ws2 = wb2[wb2.sheetnames[0]]

for r in range(12, last_a + 1):
    # average of A11:Ar, shown in column B
    ws2[f"B{r}"] = f'=AVERAGE($A$11:A{r})'
    ws2[f"B{r}"].number_format = "0.000"

wb2.save(out_path)
print("Saved to", out_path)

# recalc
result = await recalculate(out_path)
print("Recalculate:", result)

# restore sheet name if changed
orig_names = wb.sheetnames
chk = load_workbook(out_path)
print("Sheet names after recalc:", chk.sheetnames)
if chk.sheetnames != orig_names:
    while len(chk.sheetnames) > len(orig_names):
        pass
    for i, nm in enumerate(orig_names):
        chk[chk.sheetnames[i]].title = nm
    chk.save(out_path)
    print("Renamed sheets back to", orig_names)

# verify formulas and computed values
ver_formula = load_workbook(out_path, data_only=False)
ver_values = load_workbook(out_path, data_only=True)
wsf = ver_formula[orig_names[0]]
wsv = ver_values[orig_names[0]]

print("Verification B12:B15")
for r in range(12, last_a + 1):
    print(r, "formula=", wsf[f"B{r}"].value, "value=", wsv[f"B{r}"].value, "fmt=", wsf[f"B{r}"].number_format)

output_spreadsheet = out_path
