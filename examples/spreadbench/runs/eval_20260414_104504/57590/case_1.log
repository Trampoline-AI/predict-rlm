from openpyxl import load_workbook
import os

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Rows 24-37, cols A-C:")
for r in range(24, 38):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

print("Existing formulas/values in B26:B37:")
for r in range(26, 38):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

# Apply formula to B26:B37 where month names are present in col A
for r in range(26, 38):
    month_name = ws[f"A{r}"].value
    if month_name:
        ws[f"B{r}"] = f'=SUMPRODUCT((TEXT($C$2:$C${ws.max_row},"MMMM")=A{r})*($I$2:$I${ws.max_row}))'

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

result = await recalculate(out_path)
print("Recalculate:", result)

# Reload after recalc, restore sheet names if needed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    # Only one sheet here, restore simple case
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
print("Formula check B26:B37:")
for r in range(26, 38):
    print(r, wsf[f"B{r}"].value)

wb_vals = load_workbook(out_path, data_only=True)
wsv = wb_vals[orig_names[0]]
print("Cached values B26:B37:")
for r in range(26, 38):
    print(r, wsv[f"A{r}"].value, wsv[f"B{r}"].value)

output_spreadsheet = out_path
