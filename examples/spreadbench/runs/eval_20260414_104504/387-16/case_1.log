import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find actual non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    for r in range(1, min(ws.max_row, 5)+1):
        row_vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", row_vals)

    # headers candidates first 3 rows
    for hr in range(1, min(4, ws.max_row+1)):
        headers = [ws.cell(hr,c).value for c in range(1, ws.max_column+1)]
        print(f"Header candidate row {hr}:", headers)

    # first 10 and last 5 nonempty rows
    sample_rows = nonempty_rows[:10] + [r for r in nonempty_rows[-5:] if r not in nonempty_rows[:10]]
    print("Sample rows:")
    for r in sample_rows:
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"R{r}:", vals)

    # search relevant text
    keywords = ["value", "values", "binaries", "result", "solver", "difference"]
    found = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r,c).value
            if isinstance(v, str):
                lv = v.lower()
                if any(k in lv for k in keywords):
                    found.append((r,c,v))
    print("Keyword cells:", found[:50])

for ws in wb.worksheets:
    sheet_summary(ws)

# inspect formulas/current values in entire used range if small
for ws in wb.worksheets:
    print(f"\nFormulas in {ws.title}:")
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r,c,v))
    print(formulas[:100], "count=", len(formulas))
