from openpyxl import load_workbook
from collections import Counter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Inspect exact relevant ranges
vals = []
for r in range(3, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    d = ws[f"D{r}"].value
    vals.append((r, a, b, d))
print("Relevant rows R3:R21 as (row, A=Value, B=Binaries, D=Result values):")
for row in vals:
    print(row)

value_list = [ws[f"A{r}"].value for r in range(3, ws.max_row + 1) if ws[f"A{r}"].value not in (None, "")]
binary_list = [ws[f"B{r}"].value for r in range(3, ws.max_row + 1) if ws[f"A{r}"].value not in (None, "")]
result_values = [ws[f"D{r}"].value for r in range(5, ws.max_row + 1) if ws[f"D{r}"].value not in (None, "")]
print("Value list:", value_list)
print("Binary list:", binary_list)
print("Result values:", result_values)
print("Value counts:", Counter(value_list))
print("Result counts:", Counter(result_values))
print("Existing formulas H2/K2:", ws["H2"].value, ws["K2"].value)

# Remove only one instance per result value from A/B pairs, preserving order
remaining_pairs = list(zip(value_list, binary_list))
for target in result_values:
    for i, (v, b) in enumerate(remaining_pairs):
        if v == target:
            remaining_pairs.pop(i)
            break

print("Remaining pairs after removal:", remaining_pairs)
print("Remaining values sum:", sum(v for v, b in remaining_pairs))

# Apply changes
for r in range(3, ws.max_row + 1):
    idx = r - 3
    if idx < len(remaining_pairs):
        ws[f"A{r}"] = remaining_pairs[idx][0]
        ws[f"B{r}"] = remaining_pairs[idx][1]
    else:
        ws[f"A{r}"] = None
        ws[f"B{r}"] = None

# Update formulas exactly as instructed
last_row = ws.max_row
ws["H2"] = f"=SUM(A3:A{last_row})"
ws["K2"] = "=H2-E2"

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload, restore sheet name if changed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    # rename first sheet(s) back by position
    for i, orig_name in enumerate(wb.sheetnames):
        wb2.worksheets[i].title = orig_name
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# Verify with formulas and data_only
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["Sheet1"]
wb_data = load_workbook(out_path, data_only=True)
wsd = wb_data["Sheet1"]

print("Post-write A/B rows 3:21:")
for r in range(3, 22):
    print(r, wsf[f"A{r}"].value, wsf[f"B{r}"].value)

print("Formulas now H2/K2:", wsf["H2"].value, wsf["K2"].value)
print("Cached values E2/H2/K2:", wsd["E2"].value, wsd["H2"].value, wsd["K2"].value)
