import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string
from datetime import time

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Edit"]

start_col = column_index_from_string("F")
end_col = column_index_from_string("AT")

print("Target sheet:", ws.title)
print("Writing results to columns B:E for rows 2:", ws.max_row)

def find_blocks(row):
    mcols = [c for c in range(start_col, end_col + 1) if ws.cell(row, c).value == "m"]
    blocks = []
    if not mcols:
        return blocks
    s = p = mcols[0]
    for c in mcols[1:]:
        if c == p + 1:
            p = c
        else:
            blocks.append((s, p))
            s = p = c
    blocks.append((s, p))
    return blocks[:2]

# fill B:E
for r in range(2, ws.max_row + 1):
    blocks = find_blocks(r)
    values = [None, None, None, None]
    if len(blocks) >= 1:
        s1, e1 = blocks[0]
        values[0] = ws.cell(1, s1).value
        values[1] = ws.cell(1, e1).value
    if len(blocks) >= 2:
        s2, e2 = blocks[1]
        values[2] = ws.cell(1, s2).value
        values[3] = ws.cell(1, e2).value

    for idx, c in enumerate(range(2, 6)):
        ws.cell(r, c).value = values[idx]
        ws.cell(r, c).number_format = "h:mm"

# save
wb.save(outfile)
print("Saved to:", outfile)

# recalc
res = await recalculate(outfile)
print("Recalculate:", res)

# reload and restore sheet names if needed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename in order
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# verify
wbv = load_workbook(outfile, data_only=True)
print("Verified sheets:", wbv.sheetnames)
wsv = wbv["Edit"]

for r in range(2, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 6)]
    print(r, vals)

output_spreadsheet = outfile
```
