```repl
import os, shutil, re
from openpyxl import load_workbook

# Re-open clean workbook for modification
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

keywords = [
    "Core Activation",
    "Core Design",
    "Mobile Terminology",
    "Mobile Design",
    "Mobile Integration",
    "Testing Layer",
    "Testing Offshore",
    "Carrier",
    "Barrier",
]
keywords_lower = [k.lower() for k in keywords]

def matches_keyword(val):
    if val is None:
        return False
    s = str(val).lower()
    return any(k in s for k in keywords_lower)

# Print full matching analysis before writing
analysis = []
for r in range(2, ws.max_row + 1):  # skip header row
    d = ws.cell(r, 4).value
    f = ws.cell(r, 6).value
    if d not in (None, ""):
        m = matches_keyword(d)
        analysis.append((r, d, f, m))

matches = [x for x in analysis if x[3]]
nonmatches = [x for x in analysis if not x[3]]

print("Total data rows with populated D:", len(analysis))
print("Matched rows count:", len(matches))
print("Matched rows:")
for row in matches:
    print(row)
print("Sample non-matches first 10:")
for row in nonmatches[:10]:
    print(row)
print("Sample non-matches last 5:")
for row in nonmatches[-5:]:
    print(row)

# Apply updates to column F only where needed
changed = []
for r, d, f, m in analysis:
    target = "Billing PO" if m else None
    current = ws.cell(r, 6).value
    if m:
        if current != "Billing PO":
            ws.cell(r, 6).value = "Billing PO"
            changed.append((r, current, "Billing PO"))
    else:
        # leave blank if no match
        if current not in (None, ""):
            ws.cell(r, 6).value = None
            changed.append((r, current, None))

print("Changed rows:", changed)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculate changed them
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    for i, orig_name in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = orig_name
    wb_check.save(out_path)
else:
    print("Sheet names preserved.")

# Verify output using data_only
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

print("Verification of target rows in D/F:")
for r in range(2, wsv.max_row + 1):
    d = wsv.cell(r, 4).value
    f = wsv.cell(r, 6).value
    if d not in (None, ""):
        if matches_keyword(d):
            print("MATCH", r, repr(d), "->", repr(f))
        elif r <= 12 or r >= wsv.max_row - 4:
            print("NONMATCH", r, repr(d), "->", repr(f))

output_spreadsheet = out_path
