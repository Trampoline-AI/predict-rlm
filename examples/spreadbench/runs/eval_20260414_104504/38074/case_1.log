from openpyxl import load_workbook
from openpyxl.styles import numbers
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = f"/sandbox/output/output_spreadsheet/{filename}"

# Compute expected results in Python for exact verification
wb = load_workbook(infile)
ws = wb["Sheet1"]

data = []
for r in range(2, ws.max_row + 1):
    row = {
        "row": r,
        "type": ws[f"A{r}"].value,
        "profit": ws[f"B{r}"].value or 0,
        "e1": ws[f"C{r}"].value or 0,
        "e2": ws[f"E{r}"].value or 0,
        "e3": ws[f"G{r}"].value or 0,
    }
    data.append(row)

print("Expected results by exact case-sensitive match:")
expected = {}
for r in range(2, 6):
    key = ws[f"J{r}"].value
    total = sum((d["profit"] - d["e1"] - d["e2"] - d["e3"]) for d in data if d["type"] == key)
    expected[r] = total
    matches = [d["row"] for d in data if d["type"] == key]
    print(f"J{r}={key!r}, matching rows={matches}, expected={total}")

# Write vectorized case-sensitive formulas into K2:K5
last_row = ws.max_row
for r in range(2, 6):
    formula = (
        f'=SUMPRODUCT(--EXACT($A$2:$A${last_row},J{r}),'
        f'(N($B$2:$B${last_row})-N($C$2:$C${last_row})-N($E$2:$E${last_row})-N($G$2:$G${last_row})))'
    )
    ws[f"K{r}"] = formula
    ws[f"K{r}"].number_format = '0'
    print(f"K{r} formula:", formula)

wb.save(outfile)
print("Saved to", outfile)

res = await recalculate(outfile)
print("Recalc:", res)

# Restore original sheet names if recalc changed them
orig_names = load_workbook(infile).sheetnames
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify results after recalculation
wbv = load_workbook(outfile, data_only=False)
wsv = wbv["Sheet1"]
print("Formulas in K2:K5 after save:")
for r in range(2, 6):
    print(r, wsv[f"K{r}"].value, "format", wsv[f"K{r}"].number_format)

wbd = load_workbook(outfile, data_only=True)
wsd = wbd["Sheet1"]
print("Cached values K2:K5 after recalc:")
for r in range(2, 6):
    print(r, "J=", wsd[f"J{r}"].value, "K=", wsd[f"K{r}"].value, "expected=", expected[r])
```
