```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Re-open fresh workbook for modification
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames
print("Original sheet names:", orig_sheetnames)

# Identify list sheet case-insensitively
list_sheet_name = next((s for s in wb.sheetnames if s.lower() == "list"), None)
assert list_sheet_name is not None, "No LIST/list sheet found"
list_ws = wb[list_sheet_name]

# Compute sums for each non-list sheet, scanning actual non-empty data rows
summary = []
for s in wb.sheetnames:
    if s == list_sheet_name:
        continue
    ws = wb[s]
    import_sum = 0
    export_sum = 0
    contributing_rows = []
    for r in range(2, ws.max_row + 1):
        a = ws.cell(r, 1).value
        b = ws.cell(r, 2).value
        c = ws.cell(r, 3).value
        d = ws.cell(r, 4).value
        if all(v is None for v in (a, b, c, d)):
            continue
        if isinstance(c, (int, float)):
            import_sum += c
        if isinstance(d, (int, float)):
            export_sum += d
        contributing_rows.append((r, c, d))
    summary.append((s, import_sum, export_sum, contributing_rows))

print("Computed per-sheet sums:")
for s, imp, exp, rows in summary:
    print(s, "IMPORT=", imp, "EXPORT=", exp, "sample contributing rows:", rows[:5], "count:", len(rows))

# Inspect target area before clearing
print("\nLIST target area before clearing/writing (A1:E10):")
for r in range(1, min(10, list_ws.max_row) + 1):
    vals = [list_ws.cell(r, c).value for c in range(1, 6)]
    print(r, vals)

# Clear existing data in list sheet below header in columns A:E
clear_until = max(list_ws.max_row, len(summary) + 2)
for r in range(2, clear_until + 5):
    for c in range(1, 6):
        list_ws.cell(r, c).value = None

# Write refreshed listing
start_row = 2
for idx, (s, imp, exp, _) in enumerate(summary, start=1):
    r = start_row + idx - 1
    list_ws.cell(r, 1).value = idx
    list_ws.cell(r, 2).value = s
    list_ws.cell(r, 3).value = imp
    list_ws.cell(r, 4).value = exp
    list_ws.cell(r, 5).value = f"=C{r}-D{r}"

total_row = start_row + len(summary)
list_ws.cell(total_row, 2).value = "TOTAL"
list_ws.cell(total_row, 3).value = f"=SUM(C{start_row}:C{total_row-1})"
list_ws.cell(total_row, 4).value = f"=SUM(D{start_row}:D{total_row-1})"
list_ws.cell(total_row, 5).value = f"=C{total_row}-D{total_row}"

print("\nLIST target area after writing formulas/values (A1:E10):")
for r in range(1, total_row + 1):
    vals = [list_ws.cell(r, c).value for c in range(1, 6)]
    print(r, vals)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    for i, orig in enumerate(orig_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only
verify_wb = load_workbook(out_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
verify_list = verify_wb[list_sheet_name]

print("\nVerified LIST values A1:E{}:".format(total_row))
for r in range(1, total_row + 1):
    vals = [verify_list.cell(r, c).value for c in range(1, 6)]
    print(r, vals)

output_spreadsheet = out_path
