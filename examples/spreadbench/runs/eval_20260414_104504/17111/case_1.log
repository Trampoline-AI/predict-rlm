import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column+1)]
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)]
        print("Row 2 values:", headers2)
    # detect likely header row
    nonempty1 = sum(v is not None and v != "" for v in headers)
    nonempty2 = sum(ws.cell(2, c).value is not None and ws.cell(2, c).value != "" for c in range(1, ws.max_column+1)) if ws.max_row >= 2 else 0
    likely_header_row = 1 if nonempty1 >= nonempty2 else 2
    print("Likely header row:", likely_header_row)
    hdrs = [ws.cell(likely_header_row, c).value for c in range(1, ws.max_column+1)]
    print("Likely headers with letters:", [(get_column_letter(c), hdrs[c-1]) for c in range(1, ws.max_column+1)])
    # first 10 rows
    first_end = min(ws.max_row, 10)
    print(f"First {first_end} rows:")
    for r in range(1, first_end+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, ws.max_row-4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # formulas
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formula cells found:", len(formulas))
    for item in formulas[:20]:
        r,c,v = item
        print("Formula", f"{get_column_letter(c)}{r}", "=", v)
    # blanks in header row
    print("Blank columns in likely header row:", [get_column_letter(c) for c in range(1, ws.max_column+1) if ws.cell(likely_header_row, c).value in (None, "")])

for ws in wb.worksheets:
    sheet_summary(ws)
```
