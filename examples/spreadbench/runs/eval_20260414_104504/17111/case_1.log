Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Summary"]
src = wb["Sheet1"]

last_row = src.max_row  # 28
print("Using Sheet1 last row:", last_row)

# Write corrected formulas into the existing target cells B2:C6
for r in range(2, 7):
    for c in range(2, 4):  # B:C
        type_header_ref = f"{ws.cell(1, c).coordinate}"
        name_ref = f"$A{r}"
        formula = (
            f"=SUM("
            f'SUMIFS(Sheet1!$D$2:$D${last_row},Sheet1!$B$2:$B${last_row},Summary!{name_ref},Sheet1!$C$2:$C${last_row},Summary!${type_header_ref[0]}$1,Sheet1!$A$2:$A${last_row},Summary!$F$2),'
            f'SUMIFS(Sheet1!$D$2:$D${last_row},Sheet1!$B$2:$B${last_row},Summary!{name_ref},Sheet1!$C$2:$C${last_row},Summary!${type_header_ref[0]}$1,Sheet1!$A$2:$A${last_row},Summary!$F$3)'
            f")"
        )
        ws.cell(r, c).value = formula
        print(f"{ws.cell(r,c).coordinate} <- {formula}")

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for i, s in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = s
    wb_check.save(outfile)
    print("Restored original sheet names:", original_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula["Summary"]
wsv = wb_values["Summary"]

print("\nVerified target cells B2:C6:")
for r in range(2, 7):
    row_out = []
    for c in range(1, 7):
        row_out.append(wsv.cell(r, c).value)
    print("values row", r, row_out)

print("\nFormula strings in B2:C6:")
for r in range(2, 7):
    print(r, wsf[f"B{r}"].value, " | ", wsf[f"C{r}"].value)

# Explicit target value checks against expected based on F2/F3 = Completed + Not Completed
for cell in ["B2","C2","B3","C3","B4","C4","B5","C5","B6","C6"]:
    print(cell, "cached=", wsv[cell].value)

output_spreadsheet = outfile
