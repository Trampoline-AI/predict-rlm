from collections import defaultdict
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet, data_only=False)
ws_sum = wb["Summary"]
ws1 = wb["Sheet1"]

# Print explicit target-area inspection in Summary
print("Summary detailed cells A1:F9")
for r in range(1, 10):
    vals = [ws_sum.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

# Current formulas and cached values
wb_vals = load_workbook(input_spreadsheet, data_only=True)
ws_sum_vals = wb_vals["Summary"]
print("\nSummary formula cells with cached values:")
for cell in ["B2","C2","B3","C3","B4","C4","B5","C5","B6","C6"]:
    print(cell, "formula=", ws_sum[cell].value, "cached=", ws_sum_vals[cell].value)

# Inspect Sheet1 thoroughly
rows = []
for r in range(2, ws1.max_row + 1):
    status = ws1.cell(r, 1).value
    name = ws1.cell(r, 2).value
    typ = ws1.cell(r, 3).value
    amt = ws1.cell(r, 4).value
    if any(v is not None for v in [status, name, typ, amt]):
        rows.append((r, status, name, typ, amt))

print("\nSheet1 non-empty row count:", len(rows))
