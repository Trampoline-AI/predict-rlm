from openpyxl import load_workbook
import os
from collections import defaultdict

path = input_spreadsheet
wb = load_workbook(path)
base = wb["Base"]
streets = wb["Streets"]

def norm_text(x):
    return None if x is None else str(x).strip().casefold()

def to_num(x):
    try:
        if x in (None, ""):
            return None
        return float(x)
    except Exception:
        return None

# Build street rows grouped by normalized street name
grouped = defaultdict(list)
for r in range(2, streets.max_row + 1):
    street = streets.cell(r, 2).value
    start = to_num(streets.cell(r, 3).value)
    end = to_num(streets.cell(r, 4).value)
    assistant = streets.cell(r, 6).value
    if street is not None and start is not None:
        grouped[norm_text(street)].append({
            "row": r,
            "street": street,
            "start": start,
            "end_raw": end,
            "assistant": "" if assistant is None else str(assistant).strip()
        })

# Derive effective end: if end blank and a later start exists for same street, use next_start - 1
usable = []
print("Derived effective ranges:")
for st, items in grouped.items():
    items.sort(key=lambda x: (x["start"], x["row"]))
    for i, item in enumerate(items):
        next_start = items[i+1]["start"] if i + 1 < len(items) else None
        if item["end_raw"] is not None:
            eff_end = item["end_raw"]
        elif next_start is not None:
            eff_end = next_start - 1
        else:
            eff_end = None  # truly open-ended
        item["effective_end"] = eff_end
        usable.append((st, item["start"], eff_end, item["assistant"], item["row"]))
        print(item["row"], item["street"], item["start"], item["end_raw"], "=>", eff_end, item["assistant"])

# Rewrite Base!E
results = []
for r in range(2, base.max_row + 1):
    street = base.cell(r, 3).value
    num = to_num(base.cell(r, 4).value)
    out = ""
    matched_row = None
    stn = norm_text(street)
    if stn is not None and num is not None:
        for st, start, eff_end, assistant, sr in usable:
            if st != stn:
                continue
            if num >= start and (eff_end is None or num <= eff_end):
                out = assistant
                matched_row = sr
                break
    base.cell(r, 5).value = out
    results.append((r, street, num, out, matched_row, base.cell(r, 6).value))

print("\nWritten results:")
for x in results:
    print(x)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved:", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# restore names if needed
wb_check = load_workbook(out_path)
orig_names = ["Base", "Streets"]
if wb_check.sheetnames != orig_names and len(wb_check.worksheets) == len(orig_names):
    for ws, nm in zip(wb_check.worksheets, orig_names):
        ws.title = nm
    wb_check.save(out_path)
    print("Restored sheet names:", wb_check.sheetnames)
else:
    print("Sheet names after recalc:", wb_check.sheetnames)

# verify
wbv = load_workbook(out_path, data_only=True)
basev = wbv["Base"]
mismatches = []
print("\nVerify Base!E2:F26")
for r in range(2, basev.max_row + 1):
    e = basev.cell(r, 5).value
    f = basev.cell(r, 6).value
    print(r, {"E": e, "F": f})
    if f not in (None, "") and (e or "") != f:
        mismatches.append((r, e, f))
print("Mismatch count:", len(mismatches))
print("Mismatches:", mismatches)

