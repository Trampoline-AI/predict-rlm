from openpyxl import load_workbook
import os

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Build and preview FIFO ending inventory unit cost formula for column M.
# Layers from newest to oldest: J/K, H/I, F/G, D/E, B/C
def fifo_formula(r):
    return (
        f"=("
        f"MIN(L{r},J{r})*K{r}+"
        f"MAX(MIN(L{r}-J{r},H{r}),0)*I{r}+"
        f"MAX(MIN(L{r}-J{r}-H{r},F{r}),0)*G{r}+"
        f"MAX(MIN(L{r}-J{r}-H{r}-F{r},D{r}),0)*E{r}+"
        f"MAX(MIN(L{r}-J{r}-H{r}-F{r}-D{r},B{r}),0)*C{r}"
        f")/L{r}"
    )

for r in range(2, ws.max_row + 1):
    print("Row", r, "existing M:", ws[f"M{r}"].value, "new formula:", fifo_formula(r))

# Apply to rows with actual items/current inventory
for r in range(2, ws.max_row + 1):
    item = ws[f"A{r}"].value
    curr = ws[f"L{r}"].value
    if item not in (None, "") and curr not in (None, ""):
        ws[f"M{r}"] = fifo_formula(r)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

res = await recalculate(out_path)
print("Recalculate:", res)

# Reload verify sheet names and values/formulas
wb2 = load_workbook(out_path)
print("Post-recalc sheetnames:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    orig_names = wb.sheetnames
    for idx, name in enumerate(orig_names):
        wb2.worksheets[idx].title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_names)

wbv = load_workbook(out_path, data_only=False)
wsv = wbv[wsv_name] if False else wbv[wb.sheetnames[0]]
wbd = load_workbook(out_path, data_only=True)
wsd = wbd[wb.sheetnames[0]]

