import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Inspect merged rows / target rows more carefully before writing
merged_rows = []
for mr in ws.merged_cells.ranges:
    if mr.min_col <= 2 and mr.max_col >= 8:
        merged_rows.append((mr.min_row, str(mr)))
merged_rows = sorted(merged_rows)[:20]
print("Sample merged ranges spanning B:H:", merged_rows)

numeric_rows = []
text_rows = []
for r in range(12, ws.max_row + 1):
    b = ws.cell(r, 2).value
    if isinstance(b, (int, float)) and b in range(1, 8):
        numeric_rows.append(r)
    elif b not in (None, ""):
        text_rows.append((r, b))
print("Numeric day row count:", len(numeric_rows), "first10:", numeric_rows[:10], "last10:", numeric_rows[-10:])
print("Sample non-numeric B rows:", text_rows[:12])

# Show current target area before writing
for r in [12, 13, 14, 17, 18, 19, 20, 21, 24, 285, 297, 301]:
    vals = [ws.cell(r, c).value for c in range(1, 9)]
    print("Before", r, vals)

# Write formulas for ALL numeric day rows in C:H
for r in numeric_rows:
    for c in range(3, 9):  # C:H
        col = get_column_letter(c)
        formula = f'=IFERROR(INDEX({col}$2:{col}$8,MATCH($B{r},$B$2:$B$8,0)),"")'
        ws.cell(r, c).value = formula

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_chk = load_workbook(outfile)
if wb_chk.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_chk.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_chk.worksheets[i].title = name
    wb_chk.save(outfile)
    wb_chk = load_workbook(outfile)

print("Final sheet names:", wb_chk.sheetnames)

# Verify formulas present in target cells
wsf = wb_chk[orig_sheetnames[0]]
for coord in ["C12","D12","E12","F12","G12","H12","C13","D13","H14","C17","H20","C297","H300"]:
