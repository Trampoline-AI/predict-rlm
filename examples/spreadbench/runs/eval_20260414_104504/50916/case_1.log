def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row2 values:", headers2)
    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # print last 5 rows if enough
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}..{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Also print formulas / non-empty cells coordinates for smaller sheets to infer target
for ws in wb.worksheets:
    print(f"\nNon-empty/formula scan for {ws.title}:")
    count = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                if isinstance(cell.value, str) and cell.value.startswith("="):
                    print(cell.coordinate, "FORMULA", cell.value)
                count += 1
    print("Non-empty cell count:", count)
