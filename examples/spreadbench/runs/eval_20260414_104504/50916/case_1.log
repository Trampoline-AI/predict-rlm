Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = "/sandbox/output/output_spreadsheet/" + os.path.basename(infile)

wb = load_workbook(outfile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Rewrite formulas so blank source cells stay blank instead of 0
numeric_rows = []
for r in range(12, ws.max_row + 1):
    b = ws.cell(r, 2).value
    if isinstance(b, (int, float)) and b in range(1, 8):
        numeric_rows.append(r)

for r in numeric_rows:
    for c in range(3, 9):  # C:H
        col = get_column_letter(c)
        formula = (
            f'=IF(COUNTIF({col}$2:{col}$8,INDEX({col}$2:{col}$8,MATCH($B{r},$B$2:$B$8,0)))=0,'
            f'IF(INDEX({col}$2:{col}$8,MATCH($B{r},$B$2:$B$8,0))="","",INDEX({col}$2:{col}$8,MATCH($B{r},$B$2:$B$8,0))),'
            f'INDEX({col}$2:{col}$8,MATCH($B{r},$B$2:$B$8,0)))'
        )
        # Simpler explicit blank-preserving formula
        formula = (
            f'=IFERROR(IF(INDEX({col}$2:{col}$8,MATCH($B{r},$B$2:$B$8,0))="","",'
            f'INDEX({col}$2:{col}$8,MATCH($B{r},$B$2:$B$8,0))),"")'
        )
        ws.cell(r, c).value = formula

wb.save(outfile)
print("Resaved", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    for i, nm in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = nm
    wb2.save(outfile)

# verify formulas and values
wbf = load_workbook(outfile)
wsf = wbf[orig_sheetnames[0]]
for coord in ["C12","D12","E12","F12","G12","H12","D13","D14","H18","H285"]:
    print("Formula", coord, "=", wsf[coord].value)

wbv = load_workbook(outfile, data_only=True)
wsv = wbv[orig_sheetnames[0]]
for r in [12,13,14,17,18,19,20,285,297,300,301]:
    print("Row", r, [wsv.cell(r,c).value for c in range(1,9)])

output_spreadsheet = outfile
```
