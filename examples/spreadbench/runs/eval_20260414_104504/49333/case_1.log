from openpyxl import load_workbook
import re, os, shutil
from collections import defaultdict

# Reload both formula and data_only views
wb = load_workbook(input_spreadsheet)
wbv = load_workbook(input_spreadsheet, data_only=True)

ws1 = wb["Sheet1"]
ws1v = wbv["Sheet1"]
ws3 = wb["Sheet3"]

def norm(s):
    if s is None:
        return None
    s = str(s)
    # remove apostrophes and periods, trim, collapse spaces, lowercase
    s = s.replace("'", "").replace(".", "")
    s = re.sub(r"\s+", " ", s).strip().lower()
    return s

# Inspect current cached values and formulas in target cells G:I
print("Sheet1 target cells formulas / cached values:")
for r in range(2, ws1.max_row + 1):
    vals = [ws1.cell(r,c).value for c in range(6,10)]
    cached = [ws1v.cell(r,c).value for c in range(7,10)]
    print(r, "NAME=", ws1.cell(r,6).value, "formula cells=", vals[1:], "cached=", cached)

# Build normalized lookup table from Sheet3
lookup = defaultdict(list)
for r in range(2, ws3.max_row + 1):
    name = ws3.cell(r,1).value
    if name is None:
        continue
    rowvals = [ws3.cell(r,c).value for c in range(1,5)]
    lookup[norm(name)].append((r, rowvals))

print("\nPotential matches for Sheet1 names:")
for r in range(2, ws1.max_row + 1):
    name = ws1.cell(r,6).value
    key = norm(name)
    matches = lookup.get(key, [])
    print(r, repr(name), "->", key, "matches:", matches[:3])

# Print any Sheet3 near-matches by token overlap if no exact normalized match
sheet3_names = [(r, ws3.cell(r,1).value, norm(ws3.cell(r,1).value)) for r in range(2, ws3.max_row + 1)]
for r in range(2, ws1.max_row + 1):
    name = ws1.cell(r,6).value
    key = norm(name)
    if key not in lookup:
        toks = set(key.split())
        candidates = []
        for rr, nm, nk in sheet3_names:
            score = len(toks & set(nk.split()))
            if score:
                candidates.append((score, rr, nm))
        candidates = sorted(candidates, reverse=True)[:5]
        print("No exact for", name, "candidates:", candidates)
