```repl
import os, re, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws3 = wb["Sheet3"]

def norm(s):
    if s is None:
        return None
    s = str(s).replace("'", "").replace(".", "")
    s = re.sub(r"\s+", " ", s).strip().lower()
    return s

# Build lookup from Sheet3 NAME -> columns B:D
lookup = {}
duplicates = {}
for r in range(2, ws3.max_row + 1):
    name = ws3.cell(r, 1).value
    if name is None or str(name).strip() == "":
        continue
    key = norm(name)
    vals = [ws3.cell(r, c).value for c in range(2, 5)]
    if key in lookup:
        duplicates.setdefault(key, []).append((r, vals))
    else:
        lookup[key] = (r, vals)

print("Target area before write:")
for r in range(2, ws1.max_row + 1):
    print(r, ws1.cell(r, 6).value, [ws1.cell(r, c).value for c in range(7, 10)])

written = []
for r in range(2, ws1.max_row + 1):
    name = ws1.cell(r, 6).value
    if name is None or str(name).strip() == "":
        continue
    key = norm(name)
    if key in lookup:
        src_row, vals = lookup[key]
        for idx, c in enumerate(range(7, 10)):
            ws1.cell(r, c).value = vals[idx]
        written.append((r, name, src_row, vals))
    else:
        print("No match found for row", r, repr(name), "normalized as", key)

print("\nWritten matches:")
for item in written:
    print(item)

wb.save(outfile)

# recalc
result = await recalculate(outfile)
print("\nRecalculate:", result)

# restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
current_names = wb_check.sheetnames[:]
if current_names != orig_sheetnames and len(current_names) == len(orig_sheetnames):
    for i, ws in enumerate(wb_check.worksheets):
        ws.title = orig_sheetnames[i]
    wb_check.save(outfile)
    print("Restored sheet names:", orig_sheetnames)
else:
    print("Sheet names after recalc:", current_names)

# verify
wbv = load_workbook(outfile, data_only=True)
print("\nVerification Sheet1 G:I:")
for r in range(2, ws1.max_row + 1):
    vals = [wbv["Sheet1"].cell(r, c).value for c in range(7, 10)]
    print(r, wbv["Sheet1"].cell(r, 6).value, vals)

output_spreadsheet = outfile
```
