Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Result"]

# Write robust lookup formulas into the exact target cells G10:L10
for c in range(7, 13):  # G:L
    col_letter = chr(64 + c)
    item_ref = f"{col_letter}$2"
    month_ref = f"{col_letter}$3"
    formula = (
        f'=IFERROR('
        f'INDEX(\'Master-RM\'!$I$1:$I$22, MATCH({item_ref}, \'Master-RM\'!$A$1:$A$22, 0)),'
        f'IFERROR('
        f'INDEX(\'Master-RM\'!$K$1:$K$22, MATCH({item_ref}, \'Master-RM\'!$A$1:$A$22, 0)), ""))'
    )
    # Make month-sensitive exactly as requested: I for Shrawan, K for Bhadra
    formula = (
        f'=IFERROR(IF({month_ref}="Shrawan",'
        f'INDEX(\'Master-RM\'!$I$1:$I$22, MATCH({item_ref}, \'Master-RM\'!$A$1:$A$22, 0)),'
        f'IF({month_ref}="Bhadra",'
        f'INDEX(\'Master-RM\'!$K$1:$K$22, MATCH({item_ref}, \'Master-RM\'!$A$1:$A$22, 0)),"")), "")'
    )
    ws.cell(10, c).value = formula

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    if len(wb2.worksheets) == len(orig_sheetnames):
        for ws2, orig_name in zip(wb2.worksheets, orig_sheetnames):
            ws2.title = orig_name
        wb2.save(outfile)
else:
    print("Sheet names preserved.")

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Result"]
print("Written formulas G10:L10:")
for c in range(7, 13):
    print(wsf.cell(10, c).coordinate, "=", wsf.cell(10, c).value)

wb_val = load_workbook(outfile, data_only=True)
wsv = wb_val["Result"]
print("Verified cached values G10:L10:")
for c in range(7, 13):
    print(
        wsv.cell(10, c).coordinate,
        "item=", wsv.cell(2, c).value,
        "month=", wsv.cell(3, c).value,
        "value=", wsv.cell(10, c).value
    )

output_spreadsheet = outfile
```
