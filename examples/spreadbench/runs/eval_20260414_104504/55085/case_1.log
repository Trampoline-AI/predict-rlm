import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Sheets:", wb.sheetnames)

def sheet_info(ws, sample_head=10, sample_tail=5, max_cols=20):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1,c).value for c in range(1, min(ws.max_column, max_cols)+1)]
    print("Row1 headers/sample:", headers)
    if ws.max_row >= 2:
        row2 = [ws.cell(2,c).value for c in range(1, min(ws.max_column, max_cols)+1)]
        print("Row2:", row2)
    if ws.max_row >= 3:
        row3 = [ws.cell(3,c).value for c in range(1, min(ws.max_column, max_cols)+1)]
        print("Row3:", row3)
    head_rows = list(range(1, min(ws.max_row, sample_head)+1))
    tail_start = max(sample_head+1, ws.max_row-sample_tail+1)
    tail_rows = list(range(tail_start, ws.max_row+1)) if ws.max_row > sample_head else []
    for r in head_rows + tail_rows:
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, max_cols)+1)]
        print(f"R{r}:", vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Specific inspection
for sname in ["Result", "Master-RM"]:
    if sname in wb.sheetnames:
        ws = wb[sname]
        print(f"\nDetailed {sname}:")
        # print columns A:L rows 1:15
        for r in range(1, min(ws.max_row, 15)+1):
            vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
            print(f"{sname} R{r}:", vals)

if "Result" in wb.sheetnames:
