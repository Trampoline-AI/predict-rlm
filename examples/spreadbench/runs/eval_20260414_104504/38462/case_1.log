import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column+1)]
    print("Row 1 headers/values:", headers)
    # also row2 in case headers start there
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)]
        print("Row 2 values:", headers2)
    sample_rows = list(range(1, min(ws.max_row, 10)+1))
    tail_rows = list(range(max(1, ws.max_row-4), ws.max_row+1))
    seen = []
    for r in sample_rows + [x for x in tail_rows if x not in sample_rows]:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        seen.append((r, vals))
    for r, vals in seen:
        print(f"Row {r}: {vals}")

for ws in wb.worksheets:
    sheet_info(ws)

# find cells containing long [h]:mm-like strings or formulas mentioning hour/minute/round
print("\nSearching for relevant cells...")
for ws in wb.worksheets:
    matches = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                low = v.lower()
                if ":" in v and any(ch.isdigit() for ch in v):
                    if len(matches) < 20:
                        matches.append((cell.coordinate, v))
                if any(k in low for k in ["hour", "hours", "minute", "round", "ceil", "[h]:mm"]):
                    if len(matches) < 20:
                        matches.append((cell.coordinate, v))
    print(ws.title, "matches:", matches[:20])
