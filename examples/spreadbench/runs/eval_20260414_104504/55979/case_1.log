from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Original sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # print first 10 rows x all used cols (capped at 12 cols for readability)
    max_c = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_c+1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, max_c+1)]
        print("Row2 values:", headers2)
    sample_rows = list(range(1, min(ws.max_row, 10)+1))
    if ws.max_row > 10:
        sample_rows += list(range(max(1, ws.max_row-4), ws.max_row+1))
    seen = set()
    for r in sample_rows:
        if r in seen: 
            continue
        seen.add(r)
        vals = [ws.cell(r, c).value for c in range(1, max_c+1)]
        print(f"Row {r}:", vals)

for ws in wb.worksheets:
    sheet_info(ws)

if "Calculation" in wb.sheetnames:
    ws = wb["Calculation"]
    for coord in ["A10","B7","A7","B10","A1","B1"]:
        print("Calculation", coord, "=", ws[coord].value)
    # print nearby area
    for r in range(1, 15):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column,8)+1)]
        print(f"Calc row {r}:", vals)
