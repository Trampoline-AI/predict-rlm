Code:
```repl
from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames
ws = wb["Calc"]

# Inspect exact target area and existing formulas/values
print("Original sheetnames:", orig_sheetnames)
for r in range(6, 11):
    print("Calc row", r, [ws.cell(r, c).value for c in range(1, 7)])
print("Target B7 current value:", ws["B7"].value)
print("Input A10 current value:", ws["A10"].value)
print("B10 formula:", ws["B10"].value)
print("C10 formula:", ws["C10"].value)
print("D10 formula:", ws["D10"].value)
print("E10 formula:", ws["E10"].value)

# Write supplier-identification formula to B7
formula_b7 = '=IF(COUNTIF(Supplier_1!A2:A10,$A$10)>0,"Supplier_1",IF(COUNTIF(Supplier_2!A2:A10,$A$10)>0,"Supplier_2",IF(COUNTIF(Supplier_3!A2:A10,$A$10)>0,"Supplier_3","")))'
ws["B7"] = formula_b7
print("Written B7 formula:", ws["B7"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(outfile)
print("Sheetnames after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for old, new in zip(wb2.sheetnames, orig_sheetnames):
        if old != new:
            wb2[old].title = new
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Calc"]
print("Final B7 formula:", wsf["B7"].value)

# Verify cached/evaluated result
wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals["Calc"]
for coord in ["A10", "B7", "B10", "C10", "D10", "E10", "F10"]:
    print(f"Calc {coord} =", wsv[coord].value)

output_spreadsheet = outfile
```
