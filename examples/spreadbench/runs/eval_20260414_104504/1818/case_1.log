from openpyxl.utils import get_column_letter, column_index_from_string
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
data_ws = wb["Data"]
sum_ws = wb["Summary"]

# Inspect exact target columns / rows
print("Summary headers and target area:")
for r in range(1, 8):
    print(r, [sum_ws.cell(r, c).value for c in range(1, sum_ws.max_column + 1)])
