for r in range(start_row, sum_ws.max_row + 1):
    b_formula = f'=IFERROR(INDEX(Data!$B$2:$B${last_data_row},SMALL(IF(Data!$D$2:$D${last_data_row}="Lowest Performing",ROW(Data!$B$2:$B${last_data_row})-ROW(Data!$B$2)+1),ROWS(B$3:B{r}))),"")'
    c_formula = f'=IFERROR(INDEX(Data!$C$2:$C${last_data_row},SMALL(IF(Data!$D$2:$D${last_data_row}="Lowest Performing",ROW(Data!$C$2:$C${last_data_row})-ROW(Data!$C$2)+1),ROWS(C$3:C{r}))),"")'
    sum_ws.cell(r, 2).value = b_formula
    sum_ws.cell(r, 3).value = c_formula

