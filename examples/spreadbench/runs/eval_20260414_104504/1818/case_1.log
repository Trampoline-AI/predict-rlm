```repl
from openpyxl import load_workbook
import os

path = input_spreadsheet
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(path)

# Reload original input to avoid carrying bad formulas forward
wb = load_workbook(path)
data_ws = wb["Data"]
sum_ws = wb["Summary"]

# Determine matches from Data
matches = []
for r in range(2, data_ws.max_row + 1):
    if data_ws.cell(r, 4).value == "Lowest Performing":
        matches.append((data_ws.cell(r, 2).value, data_ws.cell(r, 3).value, r))

print("Match count:", len(matches))
print("Matches sample:", matches[:5], matches[-5:])

# Clear Summary target/helper area A:C from row 3 downward through enough rows
end_row = max(sum_ws.max_row, 2 + len(matches) + 5)
for r in range(3, end_row + 1):
    for c in range(1, 4):
        sum_ws.cell(r, c).value = None

# Try robust formula approach using helper column A with AGGREGATE
last_data_row = data_ws.max_row
for idx, r in enumerate(range(3, 3 + len(matches) + 5), start=1):
    # helper row number in Data sheet
    sum_ws.cell(r, 1).value = (
        f'=IFERROR(_xlfn.AGGREGATE(15,6,ROW(Data!$D$2:$D${last_data_row})/'
        f'(Data!$D$2:$D${last_data_row}="Lowest Performing"),ROWS($A$3:A{r})),"")'
    )
    sum_ws.cell(r, 2).value = f'=IF($A{r}="","",INDEX(Data!$B:$B,$A{r}))'
    sum_ws.cell(r, 3).value = f'=IF($A{r}="","",INDEX(Data!$C:$C,$A{r}))'

print("Formula preview:")
for r in range(3, 8):
    print(r, sum_ws.cell(r,1).value, sum_ws.cell(r,2).value, sum_ws.cell(r,3).value)

wb.save(out_path)
print("Saved formula version:", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Verify formula results
wbv = load_workbook(out_path, data_only=True)
wbf = load_workbook(out_path, data_only=False)
sv = wbv["Summary"]
sf = wbf["Summary"]

vals = []
for r in range(3, 3 + len(matches)):
    vals.append((r, sv.cell(r,1).value, sv.cell(r,2).value, sv.cell(r,3).value))
print("Verified values first 10:", vals[:10])

formula_ok = True
for i, (num, name, srcrow) in enumerate(matches, start=3):
    b = sv.cell(i,2).value
    c = sv.cell(i,3).value
    if b != num or c != name:
        formula_ok = False
        print("Mismatch at row", i, "expected", num, name, "got", b, c)
        break

# Fallback to static values if formulas incompatible
if not formula_ok:
    print("Formula approach incompatible after recalc; falling back to static values.")
    wb = load_workbook(path)
    sum_ws = wb["Summary"]
    for r in range(3, end_row + 1):
        for c in range(1, 4):
            sum_ws.cell(r, c).value = None
    for out_r, (num, name, srcrow) in enumerate(matches, start=3):
        sum_ws.cell(out_r, 2).value = num
        sum_ws.cell(out_r, 3).value = name
    wb.save(out_path)
    print("Saved static fallback.")

    recalc_result2 = await recalculate(out_path)
    print("Recalc fallback:", recalc_result2)

    wbv2 = load_workbook(out_path, data_only=True)
    sv2 = wbv2["Summary"]
    print("Final verification rows 2-20:")
    for r in range(2, min(20, 3 + len(matches) + 2)):
        print(r, sv2.cell(r,1).value, sv2.cell(r,2).value, sv2.cell(r,3).value)

    # keep path for submission
    final_output_path = out_path
else:
    print("Formula approach verified successfully.")
    print("Final verification rows 2-20:")
    for r in range(2, min(20, 3 + len(matches) + 2)):
        print(r, sv.cell(r,1).value, sv.cell(r,2).value, sv.cell(r,3).value)
    final_output_path = out_path
```
