for r in range(2, data_ws.max_row + 1):
    perf = data_ws.cell(r, 4).value  # D
    if perf == "Lowest Performing":
        matches.append((r, data_ws.cell(r, 2).value, data_ws.cell(r, 3).value, perf))

print("Lowest Performing count:", len(matches))
print("First matches:", matches[:10])
print("Last matches:", matches[-5:])

# Write formula solution into Summary, row 3 downward
# Excel 2013-compatible non-FILTER approach:
# B3: =IFERROR(INDEX(Data!$B$2:$B$66,SMALL(IF(Data!$D$2:$D$66="Lowest Performing",ROW(Data!$B$2:$B$66)-ROW(Data!$B$2)+1),ROWS(B$3:B3))),"")
# C3 analogous
