from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def display(val):
    if val is None:
        return None
    return val

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # print first few rows
    rows_to_show_start = list(range(1, min(ws.max_row, 10) + 1))
    rows_to_show_end = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in rows_to_show_start + rows_to_show_end:
        if r not in seen:
            seen.add(r)
            rows_to_show.append(r)
    
    # infer simple headers from first non-empty row among first 3 rows
    header_candidate = None
    for r in range(1, min(3, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v is not None and v != "" for v in vals)
        if nonempty:
            header_candidate = r
            break
    if header_candidate:
        headers = [ws.cell(header_candidate, c).value for c in range(1, ws.max_column + 1)]
        print(f"Header candidate row {header_candidate}:", headers)
    
    for r in rows_to_show:
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")

    # inspect formulas in used range
    formula_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append(f"{get_column_letter(c)}{r}={v}")
    print(f"Formula cells count: {len(formula_cells)}")
    if formula_cells:
        print("First formulas:", formula_cells[:20])

# extra inspection for Summary sheet if present
if "Summary" in wb.sheetnames:
    ws = wb["Summary"]
    print("\nDetailed Summary sheet inspection:")
    for r in range(1, min(ws.max_row, 20) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Summary Row {r}: {vals}")
```
