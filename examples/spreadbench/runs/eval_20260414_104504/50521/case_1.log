import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find actual used rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    actual_last_row = nonempty_rows[-1] if nonempty_rows else 0
    print("actual_last_row:", actual_last_row)
    
    # print first 10 rows and last 5 rows
    first_n = min(10, actual_last_row)
    print("First rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))
    print("Last rows:")
    for r in range(max(1, actual_last_row - 4), actual_last_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))
    
    # infer header row candidates first 3 rows
    for r in range(1, min(4, ws.max_row + 1)):
        print(f"Header candidate row {r}:", row_values(ws, r, min(ws.max_column, 20)))
    
    # print column letters + row1/row2 headers
    headers = []
    for c in range(1, ws.max_column + 1):
        headers.append((get_column_letter(c), ws.cell(1,c).value, ws.cell(2,c).value))
    print("Columns (letter, row1, row2) first 30:", headers[:30])
    
    # sample formulas / nonempty cells in first 15 rows and all cols
    formula_cells = []
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((ws.title, f"{get_column_letter(c)}{r}", v))
    print("Formula cells found first 30 rows:", formula_cells[:50])
