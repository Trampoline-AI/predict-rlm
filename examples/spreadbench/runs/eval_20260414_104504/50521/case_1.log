    print(coord, "value=", cell.value, "style=", cell.style_id)

# compute intended results in Python for all customer rows
def calc_gap(vals):
    nums = [(i, v) for i, v in enumerate(vals, start=1) if isinstance(v, (int, float)) and v is not None]
    if not nums:
        return None
    first_idx, first_val = nums[0]
    if first_val > 1:
        return 1
    if len(nums) < 2:
        return None
    second_idx, _ = nums[1]
    return second_idx - first_idx  # inclusive months between first and second numeric entries in example

for r in range(4, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(2, ws.max_column + 1)]
    print("Row", r, ws.cell(r,1).value, vals, "=>", calc_gap(vals))
