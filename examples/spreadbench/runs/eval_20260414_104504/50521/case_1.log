import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing:")
for coord in ["N3", "N4", "N5", "N6"]:
    print(coord, ws[coord].value)

# Write header in designated output column N
ws["N3"] = "Gap to 2nd numeric"

# Apply formula to all populated customer rows starting at row 4
# Data range is B:M
for r in range(4, ws.max_row + 1):
    row_has_customer = ws.cell(r, 1).value not in (None, "")
    row_vals = [ws.cell(r, c).value for c in range(2, 14)]
    if not row_has_customer or all(v in (None, "") for v in row_vals):
        continue
    
    formula = (
        f'=IFERROR('
        f'IF('
        f'INDEX(B{r}:M{r},1,MATCH(TRUE,INDEX(ISNUMBER(B{r}:M{r}),0),0))>1,'
        f'1,'
        f'MATCH(TRUE,INDEX(ISNUMBER('
        f'INDEX(B{r}:M{r},1,MATCH(TRUE,INDEX(ISNUMBER(B{r}:M{r}),0),0)+1):M{r}'
        f'),0),0)'
        f'),'
        f'""'
        f')'
    )
    ws[f"N{r}"] = formula
    print(f"N{r} formula:", formula)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = s
    wb_after.save(outfile)
    print("Restored original sheet names:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
print("Formulas written:")
for coord in ["N3", "N4", "N5", "N6"]:
    print(coord, ws_formula[coord].value)

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]
print("Verified cached values:")
for coord in ["N3", "N4", "N5", "N6"]:
    print(coord, ws_values[coord].value)

output_spreadsheet = outfile
