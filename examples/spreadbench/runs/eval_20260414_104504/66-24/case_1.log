from openpyxl import load_workbook
from copy import copy
from datetime import datetime, timedelta
import os

infile = input_spreadsheet
wb = load_workbook(infile)
src = wb["Imported Data"]
tgt = wb["Items Older than 30 days"]

# Deeper inspection of target layout and source full rows
print("Source dimensions:", src.max_row, src.max_column)
print("Target dimensions before:", tgt.max_row, tgt.max_column)

print("\nSource full relevant rows (A:T):")
for r in range(1, src.max_row + 1):
    vals = [src.cell(r, c).value for c in range(1, src.max_column + 1)]
    print(r, vals)

print("\nTarget sheet rows 1-6 cols A:Z before changes:")
for r in range(1, min(6, tgt.max_row) + 1):
    vals = [tgt.cell(r, c).value for c in range(1, 27)]
    print(r, vals)

# Determine threshold
dates = []
for r in range(2, src.max_row + 1):
    v = src.cell(r, 5).value
    if isinstance(v, datetime):
        dates.append(v)
    elif v:
        dates.append(v)
max_date = max(dates)
threshold = max_date - timedelta(days=30)
matching_rows = [r for r in range(2, src.max_row + 1) if isinstance(src.cell(r,5).value, datetime) and src.cell(r,5).value < threshold]
print("Max date:", max_date, "Threshold:", threshold, "Matching rows:", matching_rows)

# Write output workbook
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Clear target data area A:T only (keep other helper columns until deletion)
for r in range(1, tgt.max_row + 1):
    for c in range(1, src.max_column + 1):
        tgt.cell(r, c).value = None
        # keep styles? we'll copy over for used rows

# Copy header row and matching rows from source to target A:T
rows_to_copy = [1] + matching_rows
out_r = 1
for src_r in rows_to_copy:
    for c in range(1, src.max_column + 1):
        s = src.cell(src_r, c)
        d = tgt.cell(out_r, c)
        d.value = s.value
        if s.has_style:
            d._style = copy(s._style)
        if s.number_format:
            d.number_format = s.number_format
        if s.font:
            d.font = copy(s.font)
        if s.fill:
            d.fill = copy(s.fill)
        if s.border:
            d.border = copy(s.border)
        if s.alignment:
            d.alignment = copy(s.alignment)
        if s.protection:
            d.protection = copy(s.protection)
    out_r += 1

print("Copied rows to target:", rows_to_copy, "ending at target row", out_r - 1)
print("Target A:T before deleting Z:")
for r in range(1, out_r):
    print(r, [tgt.cell(r, c).value for c in range(1, src.max_column + 1)], "E fmt", tgt.cell(r,5).number_format)

# Delete column Z in sheet 2
tgt.delete_cols(26, 1)
print("Target dimensions after deleting Z:", tgt.max_row, tgt.max_column)
print("Row1 cols T:Y after delete:", [tgt.cell(1, c).value for c in range(20, min(tgt.max_column, 25)+1)])

wb.save(outfile)
print("Saved to", outfile)

# recalc and verify
result = await recalculate(outfile)
print("Recalculate:", result)

# Restore sheet names if needed
wb2 = load_workbook(outfile)
orig_names = ['Imported Data', 'Items Older than 30 days']
if wb2.sheetnames != orig_names:
    for i, nm in enumerate(orig_names):
        wb2.worksheets[i].title = nm
    wb2.save(outfile)
    print("Renamed sheets back:", wb2.sheetnames)

verify = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", verify.sheetnames)
vt = verify["Items Older than 30 days"]
print("Verified target rows A:T:")
for r in range(1, 4):
    print(r, [vt.cell(r, c).value for c in range(1, 21)])
print("Verified target E formats cannot be read data_only, re-open normal for formats:")
verifyf = load_workbook(outfile)
vtf = verifyf["Items Older than 30 days"]
for r in range(1, 3):
    print("row", r, "E value", vtf.cell(r,5).value, "fmt", vtf.cell(r,5).number_format)
print("Post-delete max_column:", vtf.max_column)
print("Current last visible helper cols X:Y?", [vtf.cell(1,c).value for c in range(max(1, vtf.max_column-3), vtf.max_column+1)])
