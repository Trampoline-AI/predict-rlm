import os
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Relevant source rows 1-7:")
for r in range(1, 8):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

print("\nCalculation area rows 9-13 before change:")
for r in range(9, 14):
    vals = [ws.cell(r, c).value for c in range(1, 4)]
    print(r, vals, " | B formula/value repr:", repr(ws[f"B{r}"].value))

# Determine true source data extent above blank row
last_data_row = 1
for r in range(2, ws.max_row + 1):
    if any(ws.cell(r, c).value is not None for c in range(1, 4)):
        if r < 8:  # source section before calculations starts
            last_data_row = r
print("Detected source data rows: 2 to", last_data_row)

for r in range(11, 14):
    dept_cell = f"A{r}"
    out_cell = f"B{r}"
    formula = (
        f'=IF('
        f'COUNTIFS($A$2:$A${last_data_row},{dept_cell},$B$2:$B${last_data_row},"In Progress",$C$2:$C${last_data_row},">=6")'
        f'+COUNTIFS($A$2:$A${last_data_row},{dept_cell},$B$2:$B${last_data_row},"In Review",$C$2:$C${last_data_row},">=6")=0,'
        f'"",'
        f'('
        f'SUMIFS($C$2:$C${last_data_row},$A$2:$A${last_data_row},{dept_cell},$B$2:$B${last_data_row},"In Progress",$C$2:$C${last_data_row},">=6")'
        f'+SUMIFS($C$2:$C${last_data_row},$A$2:$A${last_data_row},{dept_cell},$B$2:$B${last_data_row},"In Review",$C$2:$C${last_data_row},">=6")'
        f')/('
        f'COUNTIFS($A$2:$A${last_data_row},{dept_cell},$B$2:$B${last_data_row},"In Progress",$C$2:$C${last_data_row},">=6")'
        f'+COUNTIFS($A$2:$A${last_data_row},{dept_cell},$B$2:$B${last_data_row},"In Review",$C$2:$C${last_data_row},">=6")'
        f'))'
    )
    ws[out_cell] = formula
    ws[out_cell].number_format = "General"
    print(f"Set {out_cell} for department {ws[dept_cell].value} to formula:\n{formula}")

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(path)
wb.save(out_path)
print("Saved to:", out_path)

result = await recalculate(out_path)
print("Recalculate:", result)

# reload and restore sheet name if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != ["Sheet1"]:
    ws0 = wb_after[wb_after.sheetnames[0]]
    ws0.title = "Sheet1"
    wb_after.save(out_path)
    print("Renamed sheet back to Sheet1")

wb_verify = load_workbook(out_path, data_only=False)
wsv = wb_verify["Sheet1"]
print("\nFormulas now in B11:B13:")
for r in range(11, 14):
    print(r, repr(wsv[f"B{r}"].value), "number_format:", wsv[f"B{r}"].number_format)

wb_vals = load_workbook(out_path, data_only=True)
