import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load and inspect exact source/target area again
wb = load_workbook(infile)
ws = wb["Sheet1"]

print("Before fix:")
for r in range(1, 6):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

exclude_item = ws["A2"].value
source_items = [ws[f"B{r}"].value for r in range(2, ws.max_row + 1)]
kept_items = [x for x in source_items if x is not None and x != exclude_item]

print("Exclude item:", exclude_item)
print("Source items:", source_items)
print("Kept items:", kept_items)

# Write exact target cells C2:C4 with final desired results; keep C5 blank
targets = ["C2", "C3", "C4"]
for coord, val in zip(targets, kept_items):
    ws[coord] = val
if len(kept_items) < len(targets):
    for coord in targets[len(kept_items):]:
        ws[coord] = None
ws["C5"] = None

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Ensure sheet names preserved
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != ["Sheet1"]:
    for i, name in enumerate(["Sheet1"]):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Renamed back:", wb_check.sheetnames)

# Verify final output values
wb_val = load_workbook(outfile, data_only=True)
wsv = wb_val["Sheet1"]
print("Verified target cells:")
for coord in ["C2", "C3", "C4", "C5"]:
    print(coord, repr(wsv[coord].value))

output_spreadsheet = outfile
```
