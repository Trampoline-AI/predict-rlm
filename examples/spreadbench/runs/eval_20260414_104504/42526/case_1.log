from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os, shutil

# Reload workbook for modification
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Identify data extent in column A under header
data_rows = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None and v != "":
        data_rows.append(r)

print("Target columns verified:")
print("A = values, B = scoring output, C = ranking output")
print("Rows to process:", data_rows)
print("Current B2:C16 before writing:")
for r in data_rows:
    print(r, ws.cell(r, 2).value, ws.cell(r, 3).value)

# Determine scaling anchors from actual data
values = [ws.cell(r, 1).value for r in data_rows]
max_pos = max(v for v in values if isinstance(v, (int, float)) and v >= 0)
min_neg = min(v for v in values if isinstance(v, (int, float)) and v <= 0)
print("max_pos:", max_pos, "min_neg:", min_neg)

def score_value(x):
    if x is None or x == "":
        return None
    x = float(x)
    if x > 0:
        return x / max_pos * 5
    elif x < 0:
        return x / abs(min_neg) * 5
    else:
        return 0.0

scores = {}
for r in data_rows:
    x = ws.cell(r, 1).value
    scores[r] = score_value(x)

# Competition ranking descending on score: same score gets same rank, gaps after ties
sorted_scores_desc = sorted([scores[r] for r in data_rows], reverse=True)
rank_map = {}
for idx, s in enumerate(sorted_scores_desc, start=1):
    if s not in rank_map:
        rank_map[s] = idx

# Apply fill and write values
fill = PatternFill(start_color="A6A6A6", end_color="A6A6A6", fill_type="solid")

for r in data_rows:
    b = ws.cell(r, 2)
    c = ws.cell(r, 3)
    s = scores[r]
    b.value = s
    b.fill = fill
    # Number format: integer -> 0 decimals; exactly 1 decimal if representable with 1 dp; else 11 decimals
    if s is None:
        pass
    elif abs(s - round(s)) < 1e-12:
        b.number_format = "0"
    elif abs(s * 10 - round(s * 10)) < 1e-10:
        b.number_format = "0.0"
    else:
        b.number_format = "0.00000000000"
    c.value = rank_map[s]

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != ["Sheet1"]:
    # rename first sheet back if necessary and if only locale rename happened
    if len(wb_after.sheetnames) == 1:
        wb_after[wb_after.sheetnames[0]].title = "Sheet1"
        wb_after.save(out_path)
        print("Renamed sheet back to Sheet1")

# Verify with data_only
verify_wb = load_workbook(out_path, data_only=True)
verify_ws = verify_wb["Sheet1"]

print("Verified target range A2:C16:")
for r in data_rows:
    print(r, verify_ws.cell(r,1).value, verify_ws.cell(r,2).value, verify_ws.cell(r,3).value, verify_ws.cell(r,2).number_format)

output_spreadsheet = out_path
```
