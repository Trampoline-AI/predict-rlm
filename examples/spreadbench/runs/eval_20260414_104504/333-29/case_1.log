from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from shutil import copyfile
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
copyfile(infile, outfile)

wb = load_workbook(outfile)
wsA = wb["A"]
wsB = wb["B"]

# Inspect exact target and nearby area before writing
print("Pre-write B!F4:", wsB["F4"].value)
for r in range(1, wsB.max_row + 1):
    print("B row", r, [wsB.cell(r, c).value for c in range(1, wsB.max_column + 1)])

# Compute target date per instruction
first_yes_na_row = None
for r in range(3, wsA.max_row + 1):  # data rows
    val = wsA[f"P{r}"].value
    if isinstance(val, str) and val.strip().upper() in {"YES", "NA"}:
        first_yes_na_row = r
        break

if first_yes_na_row is None:
    target_date = wsA["F3"].value
    print("No Yes/NA found; fallback to A!F3:", target_date)
else:
    print("First Yes/NA row in A!P:", first_yes_na_row, "value:", wsA[f"P{first_yes_na_row}"].value)
    last_100_row = None
    for r in range(3, first_yes_na_row):
        if wsA[f"L{r}"].value == 100:
            last_100_row = r
    print("Last row above first Yes/NA where A!L=100:", last_100_row)
    target_date = wsA[f"F{last_100_row}"].value if last_100_row else wsA["F3"].value
    print("Chosen target date:", target_date)

# Match A!F1 against B!C and write to matching row(s); verify expected F4
lookup_name = wsA["F1"].value
match_rows = []
for r in range(1, wsB.max_row + 1):
    if wsB[f"C{r}"].value == lookup_name:
        match_rows.append(r)
        wsB[f"F{r}"] = target_date

print("Lookup name A!F1:", lookup_name)
print("Matched rows in B!C:", match_rows)

# Ensure active sheet is A
wb.active = wb.sheetnames.index("A")
wb.save(outfile)

orig_names = ["A", "B"]
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    # rename by position back to original
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.active = wb2.sheetnames.index("A")
    wb2.save(outfile)
    print("Renamed sheets back to:", wb2.sheetnames)

# Verify output using data_only after recalculation
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
print("Verified B!F4:", wbv["B"]["F4"].value)
print("Verified row 4 in B:", [wbv["B"].cell(4, c).value for c in range(1, wbv["B"].max_column + 1)])
print("Verified A active target exists; A!F1:", wbv["A"]["F1"].value)
