import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)
print("Input file exists:", os.path.exists(input_spreadsheet), input_spreadsheet)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def show_sheet(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # collect headers from first 3 rows to detect actual header row
    for hr in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {hr}:", vals)
    # non-empty row counts heuristic
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        rowvals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in rowvals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:5], nonempty_rows[-5:] if nonempty_rows else []))
    # sample first 10 non-empty rows and last 5 non-empty rows
    sample_rows = nonempty_rows[:10]
    tail_rows = [r for r in nonempty_rows[-5:] if r not in sample_rows]
    for r in sample_rows + tail_rows:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Sample row {r}:", vals)
    # print formulas / values map for used range
    formula_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells count:", len(formula_cells))
    print("First formula cells:", formula_cells[:20])

for ws in wb.worksheets:
    show_sheet(ws)
