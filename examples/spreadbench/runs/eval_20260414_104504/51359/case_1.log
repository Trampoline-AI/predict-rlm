from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet2"]

# Print the exact target area and all column sequences involved
for c in range(1, ws.max_column + 1):
    col_vals = [ws.cell(r, c).value for r in range(1, ws.max_row + 1)]
    print(get_column_letter(c), col_vals[:18])

print("Target row 15 values:", [ws.cell(15, c).value for c in range(1, 6)])

def count_consecutive_ones_total(vals):
    total = 0
    run = 0
    runs = []
    for v in vals + [0]:
        vv = 0 if v in (None, "") else int(v)
        if vv == 1:
            run += 1
        else:
            if run >= 2:
                total += run
            if run:
                runs.append(run)
            run = 0
    return total, runs

results = {}
for c in range(2, 6):  # B:E
    vals = [ws.cell(r, c).value for r in range(3, 15)]  # rows 3:14 data region
    total, runs = count_consecutive_ones_total(vals)
    results[c] = total
    print(f"Column {get_column_letter(c)} rows 3:14 =", vals, "runs=", runs, "counted total=", total, "existing answer=", ws.cell(15, c).value)

# Fill only blank answer cells in row 15 under the existing columns
written = []
for c in range(2, 6):
    ans_cell = ws.cell(15, c)
    if ans_cell.value in (None, ""):
        ans_cell.value = results[c]
        written.append((ans_cell.coordinate, results[c]))
print("Written:", written)

