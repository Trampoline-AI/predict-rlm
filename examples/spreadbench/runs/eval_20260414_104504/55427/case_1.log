from openpyxl import load_workbook
from collections import defaultdict, Counter
import os, shutil

wb = load_workbook(input_spreadsheet)
compiled = wb['Compiled and located schools da']
lookup = wb['URN lookup']
ks4 = wb['KS4 data']

def norm(x):
    if x is None:
        return None
    s = str(x).strip()
    return " ".join(s.split()).upper()

# Build lookup indexes
lookup_rows = []
for r in range(2, lookup.max_row + 1):
    row = {
        "urn": lookup.cell(r,1).value,
        "la": lookup.cell(r,2).value,
        "estab": lookup.cell(r,4).value,
        "name": lookup.cell(r,6).value,
        "street": lookup.cell(r,7).value,
        "locality": lookup.cell(r,8).value,
        "addr3": lookup.cell(r,9).value,
        "town": lookup.cell(r,10).value,
        "postcode": lookup.cell(r,11).value,
        "r": r,
    }
    lookup_rows.append(row)

by_post = defaultdict(list)
by_name_post = defaultdict(list)
by_name = defaultdict(list)
for row in lookup_rows:
    by_post[norm(row["postcode"])].append(row)
    by_name_post[(norm(row["name"]), norm(row["postcode"]))].append(row)
    by_name[norm(row["name"])].append(row)

# Inspect duplicates / ambiguity
post_dups = sum(1 for k,v in by_post.items() if k and len(v)>1)
namepost_dups = sum(1 for k,v in by_name_post.items() if k[0] and k[1] and len(v)>1)
print("Lookup rows:", len(lookup_rows), "duplicate postcodes:", post_dups, "duplicate name+postcode:", namepost_dups)

# Build KS4 by URN
ks4_by_urn = {}
for r in range(2, ks4.max_row + 1):
    urn = ks4.cell(r,3).value
    if urn is not None:
        ks4_by_urn[urn] = [ks4.cell(r,c).value for c in range(1,13)]

print("KS4 rows keyed by URN:", len(ks4_by_urn))

# Match compiled rows
sample = []
matched = 0
filled_before = 0
for r in range(2, compiled.max_row + 1):
    name = compiled.cell(r,5).value
    postcode = compiled.cell(r,12).value
    dfe_existing = compiled.cell(r,3).value
    if dfe_existing is not None:
        filled_before += 1
    candidates = []
    key_np = (norm(name), norm(postcode))
    if key_np in by_name_post:
        candidates = by_name_post[key_np]
    elif norm(postcode) in by_post and len(by_post[norm(postcode)]) == 1:
        candidates = by_post[norm(postcode)]
    elif norm(name) in by_name and len(by_name[norm(name)]) == 1:
        candidates = by_name[norm(name)]
    if len(candidates) == 1:
        cand = candidates[0]
        matched += 1
        compiled.cell(r,1).value = cand["urn"]
        compiled.cell(r,2).value = cand["estab"]   # DFES check / ESTAB
        if compiled.cell(r,3).value is None:
            compiled.cell(r,3).value = cand["estab"]
        # fill KS4 outputs if URN available
        urn = cand["urn"]
        if urn in ks4_by_urn:
            vals = ks4_by_urn[urn]
            # cols S:AJ correspond to headers in compiled:
            # S FSM, T ABS, U READPROG, V WRITPROG, W MATPROG remain absent from KS4
            # AC:AJ correspond ATT8SCR..EBACCAPS from KS4 E:L
            for dest_col, src_idx in zip(range(29, 37), range(5, 13)):  # AC:AJ <- E:L
                compiled.cell(r, dest_col).value = vals[src_idx-1]
        if len(sample) < 12:
            sample.append((r, name, postcode, cand["urn"], cand["estab"], urn in ks4_by_urn))
    else:
        if len(sample) < 12:
            sample.append((r, name, postcode, f"{len(candidates)} candidates", None, False))

print("Compiled rows:", compiled.max_row-1, "rows with existing DfE:", filled_before, "matched uniquely:", matched)
print("Sample matches/failures:")
for x in sample:
