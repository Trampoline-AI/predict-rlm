from openpyxl import load_workbook
from collections import defaultdict
import os

in_path = input_spreadsheet
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

# Start from original input to avoid keeping bad postcode-only assignments
wb = load_workbook(in_path)
compiled = wb['Compiled and located schools da']
lookup = wb['URN lookup']
ks4 = wb['KS4 data']
orig_sheetnames = wb.sheetnames[:]

def norm(x):
    if x is None:
        return None
    s = " ".join(str(x).strip().split())
    return s.upper() if s else None

# Build lookup indexes
lookup_rows = []
by_name_post = defaultdict(list)
by_name = defaultdict(list)
by_estab = defaultdict(list)

for r in range(2, lookup.max_row + 1):
    row = {
        "urn": lookup.cell(r, 1).value,
        "laname": lookup.cell(r, 2).value,
        "la": lookup.cell(r, 3).value,
        "estab": lookup.cell(r, 4).value,
        "laestab": lookup.cell(r, 5).value,
        "name": lookup.cell(r, 6).value,
        "postcode": lookup.cell(r, 11).value,
        "r": r,
    }
    lookup_rows.append(row)
    by_name_post[(norm(row["name"]), norm(row["postcode"]))].append(row)
    by_name[norm(row["name"])].append(row)
    by_estab[row["estab"]].append(row)

# Build KS4 by URN
ks4_by_urn = {}
for r in range(2, ks4.max_row + 1):
    urn = ks4.cell(r, 3).value
    if urn is not None:
        ks4_by_urn[urn] = {
            29: ks4.cell(r, 5).value,   # AC ATT8SCR
            30: ks4.cell(r, 6).value,   # AD P8PUP
            31: ks4.cell(r, 7).value,   # AE P8MEA
            32: ks4.cell(r, 8).value,   # AF P8CILOW
            33: ks4.cell(r, 9).value,   # AG P8CIUPP
            34: ks4.cell(r,10).value,   # AH P8MEA_ORIG
            35: ks4.cell(r,11).value,   # AI PTL2BASICS_95
            36: ks4.cell(r,12).value,   # AJ EBACCAPS
        }

# Apply only high-confidence matches
counts = defaultdict(int)
samples = []

for r in range(2, compiled.max_row + 1):
    name = compiled.cell(r, 5).value
    postcode = compiled.cell(r, 12).value
    existing_c = compiled.cell(r, 3).value

    match = None
    source = None

    # 1) Best: exact name + postcode
    np_matches = by_name_post.get((norm(name), norm(postcode)), [])
    if len(np_matches) == 1:
        match = np_matches[0]
        source = "name+postcode"
    # 2) Existing DfE Number/ESTAB in col C uniquely identifies lookup row
    elif existing_c is not None and len(by_estab.get(existing_c, [])) == 1:
        match = by_estab[existing_c][0]
        source = "existing_estab"
    # 3) Exact name only if unique
    elif len(by_name.get(norm(name), [])) == 1:
        match = by_name[norm(name)][0]
        source = "name_only"

    # Clear broken formulas / uncertain output cells first
    compiled.cell(r, 1).value = None
    compiled.cell(r, 2).value = None
    # preserve existing C values; only fill if blank
    for c in range(29, 37):
        compiled.cell(r, c).value = None

    if match:
        compiled.cell(r, 1).value = match["urn"]     # URN
        compiled.cell(r, 2).value = match["estab"]   # DFES check / ESTAB
        if compiled.cell(r, 3).value is None:
            compiled.cell(r, 3).value = match["estab"]
        if match["urn"] in ks4_by_urn:
            for c, val in ks4_by_urn[match["urn"]].items():
                compiled.cell(r, c).value = val
            counts["ks4_filled"] += 1
        counts[source] += 1
        if len(samples) < 15:
            samples.append((r, source, name, postcode, match["urn"], match["estab"]))
    else:
        counts["unmatched"] += 1
        if len(samples) < 15:
            samples.append((r, "unmatched", name, postcode, None, existing_c))

os.makedirs("/sandbox/output/output_spreadsheet", exist_ok=True)
wb.save(out_path)

recalc_result = await recalculate(out_path)

# Restore original sheet names if recalculation changed them
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_sheetnames:
    for i, sname in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = sname
    wb_check.save(out_path)

# Verify
vwb = load_workbook(out_path, data_only=True)
vws = vwb['Compiled and located schools da']

print("Saved:", out_path)
print("Recalc:", recalc_result)
print("Sheet names:", vwb.sheetnames)
print("Counts:", dict(counts))
print("Sample rows:")
for x in samples:
    print(x)

print("Verify problematic rows 2,4,5,7,28 and a couple with KS4:")
for r in [2,4,5,7,28,12,14]:
    print(r, [vws.cell(r,c).value for c in [1,2,3,5,12,29,30,31,32,33,34,35,36]])

print("Filled counts:",
      {
          "A": sum(1 for r in range(2, vws.max_row+1) if vws.cell(r,1).value is not None),
          "B": sum(1 for r in range(2, vws.max_row+1) if vws.cell(r,2).value is not None),
          "C": sum(1 for r in range(2, vws.max_row+1) if vws.cell(r,3).value is not None),
          "AC:AJ": {c: sum(1 for r in range(2, vws.max_row+1) if vws.cell(r,c).value is not None) for c in range(29,37)}
      })

output_spreadsheet = out_path
