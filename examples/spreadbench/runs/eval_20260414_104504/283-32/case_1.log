def nonempty_bounds(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # find actual non-empty rows/cols
    last_row = 0
    last_col = 0
    for r in ws.iter_rows():
        row_has = False
        for c in r:
            if c.value not in (None, ""):
                row_has = True
                last_col = max(last_col, c.column)
        if row_has:
            last_row = r[0].row
    return last_row, last_col

for s in wb.sheetnames:
