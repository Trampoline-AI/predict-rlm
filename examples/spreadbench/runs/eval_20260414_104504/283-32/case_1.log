from openpyxl import load_workbook
from collections import Counter
from copy import copy
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1, ws2, ws3, ws4 = wb["Sheet1"], wb["Sheet2"], wb["Sheet3"], wb["Sheet4"]

def get_data_rows(ws, start_row=9, end_col=7):
    rows = []
    for r in range(start_row, ws.max_row + 1):
        vals = tuple(ws.cell(r, c).value for c in range(1, end_col + 1))
        if any(v not in (None, "") for v in vals):
            rows.append(vals)
    return rows

rows1 = get_data_rows(ws1)
rows2 = get_data_rows(ws2)

# multiset difference, then dedupe per instruction/example
sub_rows = list((Counter(rows1) - Counter(rows2)).elements())
add_rows = list((Counter(rows2) - Counter(rows1)).elements())

def unique_preserve_order(rows):
    seen = set()
    out = []
    for row in rows:
        if row not in seen:
            seen.add(row)
            out.append(row)
    return out

sub_rows_u = unique_preserve_order(sub_rows)
add_rows_u = unique_preserve_order(add_rows)

print("Computed subtract rows:", len(sub_rows_u), sub_rows_u)
print("Computed add rows:", len(add_rows_u), add_rows_u)

# inspect target sheets before writing
print("Before write Sheet3 row1-5:", [[ws3.cell(r,c).value for c in range(1,8)] for r in range(1,6)])
print("Before write Sheet4 row1-5:", [[ws4.cell(r,c).value for c in range(1,8)] for r in range(1,6)])

def clear_sheet_values(ws, cols=7):
    for r in range(1, ws.max_row + 1):
        for c in range(1, cols + 1):
            ws.cell(r, c).value = None

def write_rows(ws, rows, source_ws):
    clear_sheet_values(ws, 7)
    # copy widths from source
    for col_letter, dim in source_ws.column_dimensions.items():
        ws.column_dimensions[col_letter].width = dim.width
    for out_r, vals in enumerate(rows, start=1):
        for c, v in enumerate(vals, start=1):
            ws.cell(out_r, c).value = v
            # copy number format/alignment/font/fill/border from a representative data row in source
            src = source_ws.cell(9 if source_ws.max_row >= 9 else 1, c)
            dst = ws.cell(out_r, c)
            dst.number_format = copy(src.number_format)
            dst.alignment = copy(src.alignment)
            dst.font = copy(src.font)
            dst.fill = copy(src.fill)
            dst.border = copy(src.border)

write_rows(ws3, sub_rows_u, ws1)
write_rows(ws4, add_rows_u, ws2)

wb.save(outfile)
print("Saved to", outfile)

result = await recalculate(outfile)
print("Recalculate:", result)

# restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, target in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = target
    wb2.save(outfile)

# verify
ver = load_workbook(outfile, data_only=True)
print("Verified sheet names:", ver.sheetnames)
for s in ["Sheet3", "Sheet4"]:
    ws = ver[s]
    vals = []
    for r in range(1, max(5, ws.max_row) + 1):
        row = [ws.cell(r, c).value for c in range(1, 8)]
        vals.append(row)
    print(s, "rows1-5:", vals[:5])

output_spreadsheet = outfile
