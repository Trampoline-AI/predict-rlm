import os, json, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

print("Instruction:", instruction)

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
print("Original sheet names:", orig_sheetnames)

def last_nonempty_row(ws):
    last = 0
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            last = r
            break
    return last

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for ws in wb.worksheets:
    lnr = last_nonempty_row(ws)
    headers = row_values(ws, 1)
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row/max_column:", ws.max_row, ws.max_column, "last_nonempty_row:", lnr)
    print("Headers row 1:", headers)
    # sample first 10 rows and last 5 rows
    first_end = min(10, lnr)
    print("First rows:")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))
    print("Last rows:")
    for r in range(max(1, lnr - 4), lnr + 1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))
    
    # Inspect columns A-C and Q specifically
    print("Column letters/names around target:",
