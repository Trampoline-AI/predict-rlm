import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook for editing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Fill Q for rows meeting conditions, preserving existing nonblank values
updated_rows = []
preserved_rows = []
for r in range(2, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    q = ws[f"Q{r}"].value
    if a == "Government" and b == "Germany" and c == "Carretera":
        if q in (None, ""):
            ws[f"Q{r}"] = "Volkswagen"
            updated_rows.append(r)
        else:
            preserved_rows.append((r, q))

wb.save(output_path)
print("Saved initial output to:", output_path)
print("Updated rows:", updated_rows)
print("Preserved existing rows:", preserved_rows)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # Rename sheets back by position
    for i, original_name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only after recalculation
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[orig_sheetnames[0]]

matching_verify = []
blanks = []
for r in range(2, wsv.max_row + 1):
    a = wsv[f"A{r}"].value
    b = wsv[f"B{r}"].value
    c = wsv[f"C{r}"].value
    q = wsv[f"Q{r}"].value
    if a == "Government" and b == "Germany" and c == "Carretera":
        matching_verify.append((r, q))
        if q in (None, ""):
            blanks.append(r)

print("Verified matching rows and Q values:", matching_verify)
print("Any blank target cells remaining?", blanks)
print("Final sheet names:", wb_verify.sheetnames)

final_output_path = output_path
