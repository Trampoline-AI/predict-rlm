```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Print relevant current values around target and fills to confirm exact target.
for coord in ["A1","A2","C1","C2","E1","E2","G1","G2","I1","I2"]:
    print(coord, repr(ws[coord].value), color_info(ws[coord]))

modified = []
for r in range(1, ws.max_row + 1):
    g = ws.cell(r, 7)
    info = color_info(g)
    is_yellow = info and info["fill_type"] == "solid" and info["fg_rgb"] in ("FFFFFF00", "FFFF00", "00FFFF00")
    if is_yellow and isinstance(g.value, str):
        old = g.value
        new = old
        # Only add // before the opening bracket in formula output pattern if not already present
        if '"//["' in old or "'//[" in old:
            pass
        elif '"["' in old:
            new = old.replace('"["', '"//["', 1)
        elif "'[" in old:
            new = old.replace("'[", "'//[", 1)
        elif '("[",' in old:
            new = old.replace('("[",', '("//[",', 1)
        if new != old:
            print(f"Modifying G{r}\nOLD: {old}\nNEW: {new}")
            g.value = new
            modified.append((r, old, new))

wb.save(outfile)
print("Saved:", outfile, "modified rows:", [r for r,_,_ in modified])

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalc; restore original sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for idx, name in enumerate(orig_sheetnames):
        wb2.worksheets[idx].title = name
    wb2.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula[orig_sheetnames[0]]
wsv = wb_values[orig_sheetnames[0]]

print("Post-save formula G1:", wsf["G1"].value)
print("Post-save formula G2:", wsf["G2"].value)
print("Post-recalc cached G1:", wsv["G1"].value)
print("Post-recalc cached G2:", wsv["G2"].value)

output_spreadsheet = outfile
