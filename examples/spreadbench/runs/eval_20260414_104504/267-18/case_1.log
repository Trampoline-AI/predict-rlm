import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Sheets:", wb.sheetnames)

def color_info(cell):
    fill = cell.fill
    if fill is None:
        return None
    fg = fill.fgColor
    bg = fill.bgColor
    return {
        "fill_type": fill.fill_type,
        "fg_type": fg.type,
        "fg_rgb": fg.rgb,
        "fg_indexed": fg.indexed,
        "fg_tint": fg.tint,
        "bg_type": bg.type,
        "bg_rgb": bg.rgb,
        "bg_indexed": bg.indexed,
    }

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row2 sample/header?:", headers2)
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Inspect column G specifically
    if ws.max_column >= 7:
        print("Column G values/formulas and fill for rows 1..min(20,max_row):")
        for r in range(1, min(20, ws.max_row) + 1):
            cell = ws.cell(r, 7)
            print(f"G{r}:", repr(cell.value), color_info(cell))
    
    # Find rows with yellow-ish fill in any cell and print row + G cell/fill
    yellow_rows = []
    for r in range(1, ws.max_row + 1):
        row_has_yellow = False
        row_colors = []
        for c in range(1, ws.max_column + 1):
            info = color_info(ws.cell(r, c))
            if info and info["fill_type"] == "solid":
                rgb = info["fg_rgb"]
                idx = info["fg_indexed"]
                row_colors.append((c, rgb, idx))
                if rgb in ("FFFFFF00", "FFFF00", "00FFFF00") or idx in (5, 6, 13):
                    row_has_yellow = True
        if row_has_yellow:
            yellow_rows.append(r)
    print("Yellow candidate rows:", yellow_rows[:50], "count=", len(yellow_rows))
    for r in yellow_rows[:20]:
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print("Yellow row", r, "values:", row_vals)
        if ws.max_column >= 7:
            print("  G value:", repr(ws.cell(r,7).value), "G fill:", color_info(ws.cell(r,7)))
