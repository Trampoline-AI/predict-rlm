    max_segments = max(max_segments, len(parts))

print("max_segments:", max_segments)
for r, parts in row_segments.items():
    print(r, parts)

start_col = 3  # C
needed_last_col = start_col + max_segments - 1  # should be M for 11 segments

# Create/fill row 2 headers only; do not touch merged row 1
template_col = 11  # K
for c in range(start_col, needed_last_col + 1):
    if c > ws.max_column:
        pass
    cell = ws.cell(2, c)
    if cell.value is None:
