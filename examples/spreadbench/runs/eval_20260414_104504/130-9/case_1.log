# Apply corrected explicit mapping based on Expected
# dest cols: A<-A, B<-B, C<-C, D<-D, E<-I, F<-F, G<-G, H blank, I Credit Note, J<-J, K<-K,
# L<-negative L, M<-negative M, N<-N, O<-O, P<-P, Q<-Q, R<-R, S<-S, T<-T, U<-U, V<-V
