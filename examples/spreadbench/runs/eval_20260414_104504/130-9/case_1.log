        start_row = r
        break
if start_row is None:
    start_row = odest.max_row + 1
print("\nWriting starts at row:", start_row)

template_row = start_row - 1 if start_row > 5 else 5
print("Template row for styles:", template_row)

# Collect source non-empty rows
osrc_rows = [r for r in range(5, osrc.max_row+1) if any(osrc.cell(r,c).value is not None for c in range(1, osrc.max_column+1))]
print("Rows to append:", len(osrc_rows))

# Copy rows aligned by header text
for idx, sr in enumerate(osrc_rows):
    dr = start_row + idx

    # copy row styles/number formats from template row to entire destination row
    for c in range(1, odest.max_column + 1):
        src_style_cell = odest.cell(template_row, c)
        target_cell = odest.cell(dr, c)
        if src_style_cell.has_style:
            target_cell._style = copy.copy(src_style_cell._style)
        if src_style_cell.number_format:
            target_cell.number_format = src_style_cell.number_format
        if src_style_cell.font:
