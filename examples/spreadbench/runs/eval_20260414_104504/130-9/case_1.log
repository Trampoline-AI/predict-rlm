owb = load_workbook(out_path)
osrc = owb["cdnr"]
odest = owb["b2b, sez, de"]

# Rebuild header maps from output wb
osrc_headers = [osrc.cell(4, c).value for c in range(1, osrc.max_column+1)]
odest_headers = [odest.cell(4, c).value for c in range(1, odest.max_column+1)]
