        if src_style_cell.alignment:
            target_cell.alignment = copy.copy(src_style_cell.alignment)
        if src_style_cell.protection:
            target_cell.protection = copy.copy(src_style_cell.protection)

    # write common headers by matching text
    for h in common_headers:
        dc = odest_map[h]
        sc = osrc_map[h]
        odest.cell(dr, dc).value = osrc.cell(sr, sc).value

    # Override per instruction
    odest.cell(dr, 8).value = None              # H blank
    odest.cell(dr, 9).value = "Credit Note"     # I
    # L and M negative values, preserving numeric if present
    for c in [12, 13]:
        val = odest.cell(dr, c).value
        if isinstance(val, (int, float)):
            odest.cell(dr, c).value = -abs(val)
        elif val is None or val == "":
            odest.cell(dr, c).value = val
        else:
            try:
                num = float(val)
                odest.cell(dr, c).value = -abs(num)
            except Exception:
                pass

# Save
