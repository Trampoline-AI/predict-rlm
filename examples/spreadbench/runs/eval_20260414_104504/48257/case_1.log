def sheet_info(ws):
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # find non-empty rows/cols rough scan
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    # print first 10 row values with coordinates
    for r in range(1, min(ws.max_row, 10) + 1):
        row = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            row.append(v)
        print(f"Row {r}:", row)
    if ws.max_row > 10:
        print("... last 5 rows ...")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}:", row)
    # headers guess first 3 rows
    for hr in range(1, min(3, ws.max_row) + 1):
        headers = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Header candidate row {hr}:", headers)
    # formulas / interesting cells
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("formula cell count:", len(formulas))
    if formulas[:20]:
        print("first formulas:", formulas[:20])

for ws in wb.worksheets:
    sheet_info(ws)
