import os, re, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Target column/header:", ws["C1"].value)
for r in range(2, ws.max_row + 1):
    print(f"Row {r}: A={ws[f'A{r}'].value!r}, B={ws[f'B{r}'].value!r}, C={ws[f'C{r}'].value!r}")

def parse_amount(text):
    if text is None:
        return None
    s = str(text).strip()
    # keep digits, separators, minus
    s = re.sub(r"[^\d,.\- ]", "", s)
    s = s.strip()
    if not s:
        return None
    # remove spaces (thousands separators)
    s_nospace = s.replace(" ", "")
    # choose decimal sign as the rightmost of comma/dot if present
    last_comma = s_nospace.rfind(",")
    last_dot = s_nospace.rfind(".")
    if last_comma == -1 and last_dot == -1:
        cleaned = re.sub(r"[^\d\-]", "", s_nospace)
        return float(cleaned) if cleaned not in ("", "-") else None
    if last_comma > last_dot:
        decimal_sign = ","
        thousands_sign = "."
    else:
        decimal_sign = "."
        thousands_sign = ","
    cleaned = s_nospace.replace(thousands_sign, "")
    if decimal_sign != ".":
        cleaned = cleaned.replace(decimal_sign, ".")
    # collapse accidental extra minus signs except leading
    if cleaned.count("-") > 1:
        cleaned = "-" + cleaned.replace("-", "")
    return float(cleaned)

# fill only blanks in target column
for r in range(2, ws.max_row + 1):
    source = ws.cell(r, 2).value
    target = ws.cell(r, 3)
    if source not in (None, "") and target.value in (None, ""):
        target.value = parse_amount(source)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
