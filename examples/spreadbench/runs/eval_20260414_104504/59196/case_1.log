from openpyxl import load_workbook
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Inspect target area and existing formulas/values
wb = load_workbook(infile)
ws = wb["Sheet1"]

for r in range(2, ws.max_row + 1):
    print(f"Row {r} D:H values:", [ws.cell(r, c).value for c in range(4, 9)])
    print("H cell raw:", ws.cell(r, 8).value)

# Write formula to MAX column for actual data rows under header
for r in range(3, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(4, 8)]
    if all(v is None or v == "" for v in row_vals):
        continue
    ws.cell(r, 8).value = f'=INDEX($D$2:$G$2,1,MATCH(MAX(D{r}:G{r}),D{r}:G{r},0))'

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
result = await recalculate(outfile)
print("Recalculate:", result)

# Check/restore sheet names if changed
orig_names = wb.sheetnames
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    # rename by position back to original
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names to:", orig_names)

# Verify with formulas visible
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["Sheet1"]
print("Formulas in H3:H5:", [wsf[f"H{r}"].value for r in range(3, min(5, wsf.max_row)+1)])

# Verify cached values
wbd = load_workbook(outfile, data_only=True)
wsd = wbd["Sheet1"]
for r in range(3, wsd.max_row + 1):
    print(f"Verified row {r} D:G -> H:", [wsd.cell(r, c).value for c in range(4, 8)], "->", wsd.cell(r, 8).value)
