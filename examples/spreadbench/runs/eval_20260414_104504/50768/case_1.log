import os
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Detailed matrix area D12:H16")
for r in range(12, 17):
    row = []
    for c in range(4, 9):  # D:H
        coord = f"{get_column_letter(c)}{r}"
        row.append((coord, ws.cell(r, c).value))
    print(row)

# Also inspect a slightly wider area just in case
print("\nWider area C11:H16")
for r in range(11, 17):
    vals = []
    for c in range(3, 9):
        coord = f"{get_column_letter(c)}{r}"
        vals.append((coord, ws.cell(r, c).value))
    print(vals)

# Source table rows and grouped mapping
print("\nSource table A3:C9")
source_rows = []
for r in range(4, ws.max_row + 1):
    rid = ws.cell(r, 1).value
    impact = ws.cell(r, 2).value
    likelihood = ws.cell(r, 3).value
    if rid is not None and impact is not None and likelihood is not None:
        source_rows.append((r, rid, impact, likelihood))
print(source_rows)

groups = defaultdict(list)
for _, rid, impact, likelihood in source_rows:
    groups[(impact, likelihood)].append(str(rid))

print("\nGrouped IDs by (Impact, Likelihood):")
for k in sorted(groups):
    print(k, ", ".join(groups[k]))

# infer exact matrix body cells from labels
print("\nExisting body cells and labels:")
print("Impact labels at E12:E14:", [ws[f"E{r}"].value for r in range(12, 15)])
print("Likelihood labels F15:H15:", [ws[f"{col}15"].value for col in ["F","G","H"]])
print("Current body F12:H14:")
for r in range(12, 15):
    print(r, [ws.cell(r, c).value for c in range(6, 9)])

# Write output into matrix body based on labels
impact_rows = {}
for r in range(12, 15):
    impact_rows[ws.cell(r, 5).value] = r  # E column labels
likelihood_cols = {}
for c in range(6, 9):
    likelihood_cols[ws.cell(15, c).value] = c  # row 15 labels

print("impact_rows:", impact_rows)
print("likelihood_cols:", likelihood_cols)

# Fill all 3x3 body cells, preserving only labels outside body
for imp, rr in impact_rows.items():
    for lik, cc in likelihood_cols.items():
        val = ", ".join(groups.get((imp, lik), []))
        ws.cell(rr, cc).value = val if val != "" else None

# save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to", out_path)

# recalc and verify
res = await recalculate(out_path)
print("Recalculate:", res)

wb2 = load_workbook(out_path)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    # rename back if needed
    for idx, original_name in enumerate(wb.sheetnames):
        wb2.worksheets[idx].title = original_name
    wb2.save(out_path)
    print("Renamed sheets back to original:", wb.sheetnames)

wbv = load_workbook(out_path, data_only=True)
wsv = wbv[wb.sheetnames[0]]
print("\nVerified matrix body F12:H14 after save/recalc:")
for r in range(12, 15):
    print(r, [wsv.cell(r, c).value for c in range(6, 9)])

output_spreadsheet = out_path
