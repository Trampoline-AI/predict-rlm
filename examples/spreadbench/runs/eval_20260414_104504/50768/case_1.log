import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook path:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n=== SHEET: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect non-empty rows/cols more accurately
    nonempty_rows = []
    nonempty_cols = set()
    for r in ws.iter_rows():
        has = False
        for c in r:
            if c.value not in (None, ""):
                has = True
                nonempty_cols.add(c.column)
        if has:
            nonempty_rows.append(r[0].row)
    print("non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("first non-empty row:", nonempty_rows[0], "last non-empty row:", nonempty_rows[-1])
    headers = []
    if ws.max_row >= 1:
        for c in range(1, ws.max_column+1):
            v = ws.cell(1, c).value
            headers.append(v)
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)]
        print("Row2 values:", row2)
    
    # print first up to 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    
    # print last 5 rows
    start_last = max(1, ws.max_row-4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    
    # print formulas if any in used range
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells found (up to 30):", formulas[:30], "count:", len(formulas))

for ws in wb.worksheets:
    sheet_info(ws)

# Search workbook-wide for likely relevant labels/headers
keywords = ["risk", "impact", "likelihood", "matrix", "assessment", "id"]
matches = []
for ws in wb.worksheets:
