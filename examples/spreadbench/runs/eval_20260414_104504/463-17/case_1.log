Code:
```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Build repeated list from columns A and B, stopping when both A and B are blank
repeated = []
source_rows = []
for r in range(2, ws.max_row + 1):
    company = ws.cell(r, 1).value
    count = ws.cell(r, 2).value
    if company is None and count is None:
        continue
    if company is None or count is None:
        print(f"Skipping incomplete source row {r}: A={company!r}, B={count!r}")
        continue
    n = int(count)
    repeated.extend([company] * n)
    source_rows.append((r, company, n))

print("Source rows used:", source_rows)
print("Total repeated entries expected:", len(repeated))
print("First 15 expected:", repeated[:15])
print("Last 10 expected:", repeated[-10:])

# Inspect existing target values in D
existing = [ws.cell(r, 4).value for r in range(2, max(ws.max_row, len(repeated)+1) + 1)]
print("Existing D first 20 rows from D2:", existing[:20])

# Write repeated list to column D starting at row 2
for i, name in enumerate(repeated, start=2):
    ws.cell(i, 4).value = name

# Clear any extra old values below the needed output range in column D
for r in range(len(repeated) + 2, ws.max_row + 1):
    if ws.cell(r, 4).value is not None:
        ws.cell(r, 4).value = None

wb.save(output_path)
print("Saved to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    for idx, name in enumerate(orig_sheetnames):
        wb2.worksheets[idx].title = name
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only
check = load_workbook(output_path, data_only=True)
wsv = check[orig_sheetnames[0]]
vals = [wsv.cell(r, 4).value for r in range(2, len(repeated) + 2)]
print("Verified D2:D{} count={}".format(len(repeated)+1, len(vals)))
print("Verified first 20:", vals[:20])
print("Verified last 10:", vals[-10:])
print("Any blanks in target?", any(v in (None, "") for v in vals))
print("Output max_row/max_col:", wsv.max_row, wsv.max_column)
```
