from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Sheet names:", wb.sheetnames)
print("Dimensions:", ws.max_row, ws.max_column)
print("Column BE index:", column_index_from_string("BE"))

# Print all rows succinctly with key columns C, D:BD, BE and any formulas in BE
for r in range(1, ws.max_row + 1):
    row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(r, row)

print("\nSpecific target/header cells:")
for cell in ["B2","D2","E2","BC2","BD2","BE1","BE2","BE3","BE4","BE5","BE6","BE7","BE8","BE9","BE10","BE11","BE12","BE13","BE14"]:
    print(cell, ws[cell].value)

print("\nFormula cells:")
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if isinstance(v, str) and v.startswith("="):
            print(f"{get_column_letter(c)}{r}: {v}")

# Write streamlined formula into BE for data rows where label in C exists
for r in range(3, ws.max_row + 1):
    label = ws.cell(r, 3).value
    if label not in (None, ""):
        # Sum across D:BC when row 2 week headers are >= current week in B2
        formula = f'=SUMPRODUCT(($D$2:$BC$2>=$B$2)*(D{r}:BC{r}))'
        print(f"Writing BE{r}:", formula, "previous:", ws[f'BE{r}'].value)
        ws[f"BE{r}"] = formula

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalc
res = await recalculate(out_path)
print("Recalc:", res)

# restore sheet names if needed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "restoring to", orig_names)
    for i, nm in enumerate(orig_names):
        wb2.worksheets[i].title = nm
    wb2.save(out_path)

# verify with data_only
ver = load_workbook(out_path, data_only=False)
verd = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
vwsd = verd[orig_names[0]]

print("\nVerification formulas and values in BE:")
for r in range(3, ws.max_row + 1):
    if vws.cell(r,3).value not in (None, ""):
        print(r, "label", vws.cell(r,3).value, "formula", vws[f"BE{r}"].value, "value", vwsd[f"BE{r}"].value)

output_spreadsheet = out_path
