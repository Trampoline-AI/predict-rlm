import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]

# Choose target sheet: only sheet present, and it contains the relevant Column E data
ws = wb[original_sheetnames[0]]
print("Using target sheet:", ws.title)

# Inspect target cells before modifying
print("Before deletion - rows 1 to", ws.max_row)
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

def to_num(v):
    if v is None or v == "":
        return None
    if isinstance(v, (int, float)):
        return float(v)
    try:
        return float(str(v).strip())
    except:
        return None

# Identify rows to delete based on column E values < 1, excluding header
rows_to_delete = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 5).value
    n = to_num(v)
    if n is not None and n < 1:
        rows_to_delete.append(r)

print("Rows marked for deletion:", rows_to_delete)

# Delete from bottom up to keep row references valid
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring:", original_sheetnames)
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Final sheet names:", wb_check.sheetnames)

# Verify with data_only after recalc
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("After deletion - rows 1 to", wsv.max_row)
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

print("Final Column E values:")
for r in range(1, wsv.max_row + 1):
    print(f"E{r} =", wsv.cell(r, 5).value)

result_path = output_path
