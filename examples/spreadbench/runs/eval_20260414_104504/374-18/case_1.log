from openpyxl.utils import get_column_letter

print("Instruction:", instruction)
print("Input file exists:", os.path.exists(input_spreadsheet), input_spreadsheet)

wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
print("Original sheet names:", original_sheetnames)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print("Headers row 1:", headers1)
    print("Row 2:", headers2)
    first_n = min(ws.max_row, 8)
    print("First rows sample:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    start_last = max(1, ws.max_row - 4)
    print("Last rows sample:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

# find likely target sheet by normalized title
def norm(s):
    return "".join(ch.lower() for ch in str(s) if ch.isalnum())

target = None
for ws in wb.worksheets:
    if norm(ws.title) == norm("Imported Data"):
        target = ws
        break
if target is None:
    # fallback: contains imported or data
    candidates = [ws for ws in wb.worksheets if "import" in ws.title.lower() or "data" in ws.title.lower()]
    print("Candidate target sheets:", [ws.title for ws in candidates])
    target = candidates[0] if candidates else wb.worksheets[0]

print("\nChosen target sheet:", target.title)
print("Target sheet dimensions:", target.max_row, target.max_column)
print("Column letters+headers:", [(get_column_letter(c), target.cell(1,c).value) for c in range(1, target.max_column+1)])

# inspect column E specifically
print("\nColumn E detailed sample:")
for r in range(1, min(target.max_row, 15) + 1):
    cell = target.cell(r, 5)
    print(f"E{r}={cell.value!r}, type={cell.data_type}")

def to_num(v):
    if v is None or v == "":
        return None
    if isinstance(v, (int, float)):
        return float(v)
    try:
        return float(str(v).strip())
    except:
        return None

vals = [(r, target.cell(r, 5).value) for r in range(2, target.max_row + 1)]
lt1 = [(r, v) for r, v in vals if to_num(v) is not None and to_num(v) < 1]
ge1 = [(r, v) for r, v in vals if to_num(v) is not None and to_num(v) >= 1]
nonnum = [(r, v) for r, v in vals if v not in (None, "") and to_num(v) is None]
blank = [(r, v) for r, v in vals if v in (None, "")]
print("Rows with numeric E < 1:", lt1[:20], "count:", len(lt1))
print("Rows with numeric E >= 1:", ge1[:10], "count:", len(ge1))
print("Rows with nonnumeric nonblank E:", nonnum[:10], "count:", len(nonnum))
print("Blank E rows:", blank[:10], "count:", len(blank))
