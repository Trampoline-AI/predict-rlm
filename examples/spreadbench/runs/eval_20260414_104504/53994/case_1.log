```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["TEST_SHEET"]

# Inspect referenced date cells/current values
for ref in ["B4","C4","B5","C5","C10","D10","C11","D11","C12","D12"]:
    v = ws[ref].value
    if hasattr(v, "text"):
        v = v.text
    print(ref, "=>", v)

# Compute summary totals in Python from repeating 3-row blocks.
start_date = ws["C4"].value
end_date = ws["C5"].value
print("Date range:", start_date, "to", end_date)

phases = {}
for c in range(12, 24):  # L:W
    phases[c] = ws.cell(16, c).value

machines = [ws[f"B{r}"].value for r in range(10, 13)]
summary = {(m, p): 0 for m in machines for p in ["SETUP", "RUN"]}

for machine_row in range(17, 29, 3):  # 17,20,23,26
    person_row = machine_row + 1
    time_row = machine_row + 2
    dr = ws.cell(machine_row, 9).value   # I
    dd = ws.cell(machine_row, 10).value  # J
    in_range = (dr is not None and dd is not None and dr >= start_date and dd <= end_date)
    print(f"Block rows {machine_row}-{time_row}: dates=({dr},{dd}) in_range={in_range}")
    if not in_range:
        continue
    for c in range(12, 24):
        machine = ws.cell(machine_row, c).value
        phase = phases[c]
        time_val = ws.cell(time_row, c).value
        # evaluate simple numeric formulas by cached result? openpyxl stores string, so handle literal =a*b if needed
        if isinstance(time_val, str) and time_val.startswith("="):
            expr = time_val.lstrip("=").replace("+", "")
            try:
                time_val = eval(expr, {"__builtins__": {}})
            except Exception:
                pass
        if machine in machines and phase in ("SETUP", "RUN") and isinstance(time_val, (int, float)):
            summary[(machine, phase)] += time_val

print("Computed summary:", summary)

# Write exact target cells
for r in range(10, 13):
    machine = ws[f"B{r}"].value
    ws[f"C{r}"] = summary[(machine, "SETUP")]
    ws[f"D{r}"] = summary[(machine, "RUN")]

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate and preserve sheet names if needed
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_after = load_workbook(out_path)
if wb_after.sheetnames != orig_names:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring", orig_names)
    # rename positionally
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)

# Verify values after recalc
verify = load_workbook(out_path, data_only=True)
vws = verify[orig_names[0]]
for ref in ["C10","D10","C11","D11","C12","D12"]:
    print("Verified", ref, "=", vws[ref].value)

output_spreadsheet = out_path
