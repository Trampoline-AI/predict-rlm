Code:
```repl
import os, shutil
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Inspect exact target range before modification
print("Before modification E1:E9:")
for r in range(1, 10):
    print(r, ws[f"E{r}"].value)

# Build occurrence-based mapping from source A:B
occ_map = defaultdict(list)
for r in range(2, ws.max_row + 1):
    prod = ws[f"A{r}"].value
    typ = ws[f"B{r}"].value
    if prod is not None:
        occ_map[str(prod)].append(typ)

print("Source occurrence map:", dict(occ_map))

# Fill target E column using same-row occurrence of product in D
seen = defaultdict(int)
written = {}
for r in range(2, ws.max_row + 1):
    prod = ws[f"D{r}"].value
    if prod is None or prod == "":
        continue
    key = str(prod)
    seen[key] += 1
    idx = seen[key] - 1
    value = occ_map.get(key, [None] * seen[key])[idx] if idx < len(occ_map.get(key, [])) else None
    ws[f"E{r}"] = value
    written[f"E{r}"] = value

# Apply formatting E2:E9
fill = PatternFill(start_color="FCE4D6", end_color="FCE4D6", fill_type="solid")
font = Font(name="Calibri")
for r in range(2, 10):
    cell = ws[f"E{r}"]
    cell.fill = fill
    cell.font = font
    # Show numeric 0 as blank; text unaffected
    cell.number_format = 'General;General;;@'

wb.save(outfile)
print("Saved to", outfile)

res = await recalculate(outfile)
print("Recalculate:", res)

# Reload and verify sheet names; rename back if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    mapping = {}
    for i, old in enumerate(wb.sheetnames):
        if i < len(wb2.sheetnames):
            mapping[wb2.sheetnames[i]] = old
    for current, desired in mapping.items():
        wb2[current].title = desired
    wb2.save(outfile)
    print("Renamed sheets back:", wb.sheetnames)

# Verify values and formatting
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]
print("Verified E1:E9 values after recalc (data_only):")
for r in range(1, 10):
    print(r, wsv[f"E{r}"].value)

# verify styles from normal load
wbs = load_workbook(outfile)
wss = wbs["Sheet1"]
print("Verified styles E2:E9:")
for r in range(2, 10):
    c = wss[f"E{r}"]
    print(r, c.value, c.fill.fill_type, c.fill.start_color.rgb, c.font.name, c.number_format)

output_spreadsheet = outfile
