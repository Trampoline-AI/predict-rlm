import os, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)

print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    # find actual used rows/cols with content
    max_r, max_c = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_c+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", max_r, "max_column:", max_c)
    print("Headers row1:", headers)
    
    # collect non-empty rows
    nonempty_rows = []
    for r in range(1, max_r+1):
        vals = [ws.cell(r, c).value for c in range(1, max_c+1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    print("First non-empty rows:", nonempty_rows[:15])
    print("Last non-empty rows:", nonempty_rows[-15:])
    
    # sample first 10 rows and last 5 rows
    first_rows = list(range(1, min(max_r, 10)+1))
    last_rows = list(range(max(1, max_r-4), max_r+1))
    print("First sample rows:")
    for r in first_rows:
        vals = [ws.cell(r, c).value for c in range(1, max_c+1)]
        print(r, vals)
    print("Last sample rows:")
    for r in last_rows:
        vals = [ws.cell(r, c).value for c in range(1, max_c+1)]
        print(r, vals)

for s in wb.sheetnames:
    sheet_info(wb[s])

# extra focused inspection for SH and CP if present
for target in ["SH", "CP"]:
    if target in wb.sheetnames:
        ws = wb[target]
        print(f"\nFocused inspection for {target}:")
        for r in range(1, ws.max_row+1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
            is_blank = not any(v not in (None, "") for v in vals)
            if r <= 20 or r > ws.max_row - 10:
                print(f"Row {r}: blank={is_blank} values={vals}")
