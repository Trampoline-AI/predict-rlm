import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and inspect target before modification
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["SH"]

def row_is_blank(ws, r):
    return all(ws.cell(r, c).value in (None, "") for c in range(1, ws.max_column + 1))

blank_rows_before = [r for r in range(1, ws.max_row + 1) if row_is_blank(ws, r)]
print("Blank rows before:", blank_rows_before)

# Delete fully blank rows bottom-up so remaining rows shift upward
for r in range(ws.max_row, 1, -1):  # preserve header row 1
    if row_is_blank(ws, r):
        ws.delete_rows(r, 1)

print("After deletion max_row:", ws.max_row)
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename sheets back by position
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)

# Verification with data_only
ver = load_workbook(outfile, data_only=True)
print("Verified sheet names:", ver.sheetnames)
vws = ver["SH"]
blank_rows_after = [r for r in range(1, vws.max_row + 1) if row_is_blank(vws, r)]
print("Blank rows after:", blank_rows_after)
print("Final max_row:", vws.max_row)
for r in range(1, vws.max_row + 1):
    print("Row", r, [vws.cell(r, c).value for c in range(1, vws.max_column + 1)])
