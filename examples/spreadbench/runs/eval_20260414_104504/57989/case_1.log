from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # find actual used rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            nonempty_rows.append(r)
    nonempty_cols = []
    for c in range(1, ws.max_column + 1):
        if any(ws.cell(r, c).value is not None for r in range(1, ws.max_row + 1)):
            nonempty_cols.append(c)
    print("nonempty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("nonempty col range:", (min(nonempty_cols), max(nonempty_cols)) if nonempty_cols else None)
    
    # print first 10 rows and last 5 rows across used columns
    max_c = max(nonempty_cols) if nonempty_cols else ws.max_column
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, max_c + 1)]
    
    print("First 10 rows:")
