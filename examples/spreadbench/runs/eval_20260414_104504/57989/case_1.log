from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect exact target area and formulas
print("Target area headers row 24:", [ws.cell(24, c).value for c in range(1, 9)])
print("Driver rows 25:43 names:", [ws.cell(r, 1).value for r in range(25, 44)])

for r in range(25, 30):
    vals = []
    for c in range(1, 9):
        cell = ws.cell(r, c)
        v = cell.value
        if isinstance(v, ArrayFormula):
            vals.append((f"{get_column_letter(c)}{r}", "ArrayFormula", v.text))
        else:
            vals.append((f"{get_column_letter(c)}{r}", v))
    print("Row", r, vals)

# Compute expected counts in Python to verify intended logic
source_driver_rows = range(3, 22)
source_day_cols = range(2, 22)
weekday_headers = {c: ws.cell(1, c).value for c in source_day_cols}
py_counts = {}
for r in source_driver_rows:
    driver = ws.cell(r, 1).value
    counts = {}
    for synth_c in range(2, 9):
        day = ws.cell(24, synth_c).value
        count = 0
        for c in source_day_cols:
            if weekday_headers[c] == day and ws.cell(r, c).value not in (None, ""):
                count += 1
        counts[day] = count
    py_counts[driver] = counts

print("Python expected sample counts:")
for drv in ["Driver 1", "Driver 2", "Driver 19"]:
    print(drv, py_counts.get(drv))

# Write working formulas into exact target cells B25:H43
for r in range(25, 44):
    driver_name = ws.cell(r, 1).value
    if driver_name in (None, ""):
        continue
    for c in range(2, 9):
        header_day = ws.cell(24, c).value
        if header_day in (None, ""):
            continue
        formula = '=SUMPRODUCT(($A$3:$A$21=$A{r})*($B$1:$U$1={col}$24)*($B$3:$U$21<>""))'.format(
            r=r, col=get_column_letter(c)
        )
        ws.cell(r, c).value = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# recalc
result = await recalculate(out_path)
print("Recalc:", result)

# restore sheet names if changed
orig_names = wb.sheetnames
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_names)
    for i, orig in enumerate(orig_names):
        wb_check.worksheets[i].title = orig
    wb_check.save(out_path)

# verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
wb_data = load_workbook(out_path, data_only=True)
wsd = wb_data[orig_names[0]]

print("Verification formulas B25:H29")
for r in range(25, 30):
    print(r, [wsf.cell(r, c).value for c in range(2, 9)])
print("Verification values B25:H29")
for r in range(25, 30):
    print(wsd.cell(r, 1).value, [wsd.cell(r, c).value for c in range(2, 9)])

print("Check Driver 1 Sunday cell D25:", wsd["D25"].value)
print("Check all target rows nonblank names and values:")
all_ok = True
for r in range(25, 44):
    name = wsd.cell(r, 1).value
    vals = [wsd.cell(r, c).value for c in range(2, 9)]
    print(r, name, vals)
    if name not in (None, "") and any(v is None for v in vals):
        all_ok = False
print("All target formula results non-None:", all_ok)
