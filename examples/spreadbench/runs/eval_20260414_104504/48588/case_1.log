import os, shutil
from openpyxl import load_workbook

# Re-open and inspect remaining relevant rows in detail
src = input_spreadsheet
wb = load_workbook(src)
ws = wb["Sheet1"]

print("Detailed rows 19-43 before writing:")
for r in range(19, ws.max_row + 1):
    print(r, ws.cell(r,1).value, ws.cell(r,2).value)

# Show exact target range and confirm blanks/formulas
target_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r,1).value
    b = ws.cell(r,2).value
    if a not in (None, ""):
        target_rows.append((r, a, b))
print("Total non-empty product rows:", len(target_rows))
print("Rows with blank B that need output:", [r for r,a,b in target_rows if b in (None, "")])

# Write formulas only into blank B cells where column A has a product
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(src))
shutil.copy(src, out_path)

wb2 = load_workbook(out_path)
ws2 = wb2["Sheet1"]

written = []
for r in range(2, ws2.max_row + 1):
    a = ws2.cell(r,1).value
    b = ws2.cell(r,2).value
    if a not in (None, "") and b in (None, ""):
        formula = f"=MATCH(A{r},$A$2:$A{r},0)"
        ws2.cell(r,2).value = formula
        written.append((r, formula))

print("Formulas written:", written[:10], "count:", len(written))

# Save and recalculate
wb2.save(out_path)
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
orig_names = wb.sheetnames[:]
chk = load_workbook(out_path)
print("Sheet names after recalc:", chk.sheetnames)
if chk.sheetnames != orig_names and len(chk.sheetnames) == len(orig_names):
    for i, expected in enumerate(orig_names):
        chk.worksheets[i].title = expected
    chk.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("Verified target cells B19:B43 after recalc:")
for r in range(19, vws.max_row + 1):
    print(r, vws.cell(r,1).value, vws.cell(r,2).value)

# Also verify all non-empty product rows have IDs now
missing = []
for r in range(2, vws.max_row + 1):
    if vws.cell(r,1).value not in (None, "") and vws.cell(r,2).value in (None, ""):
        missing.append(r)
print("Missing IDs after recalc:", missing)

output_spreadsheet = out_path
print("Output saved to:", output_spreadsheet)
