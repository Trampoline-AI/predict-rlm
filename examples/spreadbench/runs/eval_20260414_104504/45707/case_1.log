from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string
import os, shutil

path = input_spreadsheet

# Inspect with cached values to understand actual dates and month boundaries
wb_formula = load_workbook(path)
wb_values = load_workbook(path, data_only=True)
wsf = wb_formula[wb_formula.sheetnames[0]]
wsv = wb_values[wb_values.sheetnames[0]]

print("Sheet names:", wb_formula.sheetnames)
print("Target column D index:", column_index_from_string("D"))

print("Headers A1:E1:", [wsf.cell(1,c).value for c in range(1,6)])

print("\nRows around existing example at D32 and potential month ends:")
for r in list(range(28, 36)) + list(range(57, 64)) + [68, 69]:
    print(
        r,
        {
            "A_formula": wsf[f"A{r}"].value,
            "A_value": wsv[f"A{r}"].value,
            "C": wsf[f"C{r}"].value,
            "D_current": wsf[f"D{r}"].value,
            "E": wsf[f"E{r}"].value,
        }
    )

# Determine rows where next day is first of month based on cached values
month_end_rows = []
for r in range(2, 69):
    curr = wsv[f"A{r}"].value
    nxt = wsv[f"A{r+1}"].value
    if curr is not None and nxt is not None:
        try:
            if nxt.day == 1 and (nxt.month != curr.month or nxt.year != curr.year):
                month_end_rows.append((r, curr, nxt))
        except Exception:
            pass
print("\nDetected month-end rows:", month_end_rows)

# Create output workbook
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
shutil.copy(path, out_path)

wb = load_workbook(out_path)
ws = wb[wb.sheetnames[0]]

# Write formulas to D2:D69
for r in range(2, 70):
    if r < 69:
        ws[f"D{r}"] = (
            f'=IF(DAY(A{r+1})=1,'
            f'COUNTIFS($C$2:$C$69,1,'
            f'$A$2:$A$69,">="&DATE(YEAR(A{r}),MONTH(A{r}),1),'
            f'$A$2:$A$69,"<"&DATE(YEAR(A{r}),MONTH(A{r})+1,1)),'
            f'"")'
        )
    else:
        ws[f"D{r}"] = ""

# Preserve existing headers explicitly
# A1, C1, E1 should remain as-is; do not add D1 header
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload after recalc, restore sheet name if altered
orig_sheetnames = wb_formula.sheetnames
wb_post = load_workbook(out_path)
if wb_post.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_post.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = name
    wb_post.save(out_path)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv2 = wb_verify[orig_sheetnames[0]]

print("\nVerification of target cells D2:D69 (non-blanks only):")
nonblank = []
for r in range(2, 70):
    val = wsv2[f"D{r}"].value
    if val not in (None, ""):
        nonblank.append((r, val))
print(nonblank)

print("\nCheck required key cells and headers:")
print("A1,C1,E1:", wsv2["A1"].value, wsv2["C1"].value, wsv2["E1"].value)
for r in [32, 61, 69]:
    print(r, {"A": wsv2[f"A{r}"].value, "D": wsv2[f"D{r}"].value})

output_spreadsheet = out_path
```
