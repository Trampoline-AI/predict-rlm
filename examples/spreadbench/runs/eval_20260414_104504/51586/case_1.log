from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill
from copy import copy
from openpyxl.utils import get_column_letter
import os

# Inspect styles first
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Style inspection:")
for coord in ["A1","B1","C1","A2","B2","C2","A3","B3","C3"]:
    cell = ws[coord]
    print(coord, "value=", cell.value,
          "font=", {"name": cell.font.name, "size": cell.font.sz, "bold": cell.font.bold, "italic": cell.font.italic, "color": cell.font.color.type if cell.font.color else None},
          "fill=", {"type": cell.fill.fill_type, "fgColor": cell.fill.fgColor.rgb, "patternType": cell.fill.patternType})

# Fill target cells in column C with formulas if blank
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3)
    # write formula for all relevant rows unless already formula; preserve examples? better standardize all rows.
    c.value = f'=RIGHT(TRIM(A{r}),LEN(B{r}))=B{r}'
    
# Apply Calibri font throughout used range, preserving size/bold/italic where possible
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        old_font = cell.font
        cell.font = Font(
            name="Calibri",
            size=old_font.sz,
            bold=old_font.bold,
            italic=old_font.italic,
            vertAlign=old_font.vertAlign,
            underline=old_font.underline,
            strike=old_font.strike,
            color=old_font.color.rgb if old_font.color and old_font.color.type == "rgb" else None
        )

# Change fill color of column C values, excluding title row
green_fill = PatternFill(fill_type="solid", start_color="00B050", end_color="00B050")
for r in range(2, ws.max_row + 1):
    ws.cell(r, 3).fill = green_fill

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb.save(out_path)
print("Saved to", out_path)

res = await recalculate(out_path)
print("Recalc:", res)

# Reload and restore sheet name if changed
wb2 = load_workbook(out_path)
print("Post-recalc sheets:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"] and "Sheet1" not in wb2.sheetnames and len(wb2.sheetnames) == 1:
    wb2[wb2.sheetnames[0]].title = "Sheet1"
    wb2.save(out_path)
    print("Renamed sheet back to Sheet1")

# Verify values
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
print("Verified C2:C6 data_only values:")
for r in range(2, wsv.max_row + 1):
    print(r, wsv.cell(r,3).value)

# Verify formulas and fills/fonts
wbf = load_workbook(out_path)
wsf = wbf["Sheet1"]
print("Formula/style verification:")
for r in range(2, wsf.max_row + 1):
    cell = wsf.cell(r,3)
    print(cell.coordinate, "formula=", cell.value, "fill=", cell.fill.fgColor.rgb, "font=", cell.font.name)
