# style verification on first copied row if exists
if matches:
    src_r = matches[0]
    print("Source first match row", src_r, [ws.cell(src_r,c).value for c in range(1,6)])
    print("Output first match row", 6, [wsv.cell(6,c).value for c in range(9,14)])
    ws_style = load_workbook(out_path)[orig_names[0]]
    for pair in [("A6","I6"), ("B6","J6"), ("E6","M6"), (f"A{src_r}", "I6"), (f"E{src_r}", "M6")]:
