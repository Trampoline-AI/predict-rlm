from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Inspect columns A:N headers row5:", [ws.cell(5,c).value for c in range(1,15)])
for coord in ["M1","N1","M2","N2","M5","N5","N6","O1"]:
    if ws.max_column >= 14 and coord[0] <= get_column_letter(ws.max_column):
        print(coord, ws[coord].value)

# print row dimensions and style clues for source/target
for r in range(5, 11):
    print("Row", r, "height", ws.row_dimensions[r].height,
          "A:E values", [ws.cell(r,c).value for c in range(1,6)],
          "I:M values", [ws.cell(r,c).value for c in range(9,14)])

for coord in ["A5","A6","B6","E6","I5","I6","J6","M6"]:
    cell = ws[coord]
    print(coord, "val=", cell.value, "fmt=", cell.number_format, "font_bold=", cell.font.bold,
          "fill=", cell.fill.fill_type, cell.fill.fgColor.rgb, "border_left=", cell.border.left.style,
          "align=", cell.alignment.horizontal)

# Determine matching rows
start_date = ws["I2"].value
end_date = ws["J2"].value
matches = []
for r in range(6, ws.max_row + 1):
    d = ws.cell(r,1).value
    if d is not None and start_date <= d <= end_date:
        matches.append(r)

print("Start/end:", start_date, end_date)
print("Match count:", len(matches))
print("First 10 matching rows:", matches[:10])
print("Last 5 matching rows:", matches[-5:])
for r in matches[:5] + matches[-5:]:
    print("match row", r, [ws.cell(r,c).value for c in range(1,6)])

# write output
out_start = 6
# clear prior values/styles in target data area I:M rows 6:max_row; preserve criteria/header rows
for r in range(out_start, ws.max_row + 1):
    for c in range(9, 14):
        tgt = ws.cell(r,c)
        tgt.value = None
        tgt._style = copy(ws.cell(r,c)._style)
        if tgt.has_style:
            pass

# copy matching rows values + formatting from A:E to I:M
for idx, src_r in enumerate(matches, start=out_start):
    for offset in range(5):
        src = ws.cell(src_r, 1 + offset)
        tgt = ws.cell(idx, 9 + offset)
        tgt.value = src.value
        tgt.font = copy(src.font)
        tgt.fill = copy(src.fill)
        tgt.border = copy(src.border)
        tgt.alignment = copy(src.alignment)
        tgt.number_format = src.number_format
        tgt.protection = copy(src.protection)
    # copy row height from source to target row for consistent formatting
    ws.row_dimensions[idx].height = ws.row_dimensions[src_r].height

# save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalc
result = await recalculate(out_path)
print("Recalculate:", result)

# restore sheet name if changed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)

# verify
