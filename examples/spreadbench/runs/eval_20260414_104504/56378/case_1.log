        print(f"Column {col_letter} sample non-empty:")
        shown = 0
        for r in range(1, ws.max_row+1):
            v = ws.cell(r,c).value
            if v not in (None, ""):
                print(f"  {col_letter}{r}={v}")
                shown += 1
            if shown >= 15:
                break

    # inspect formulas present in used range
    formula_cells = []
