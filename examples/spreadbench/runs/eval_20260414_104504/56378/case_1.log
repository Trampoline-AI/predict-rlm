from openpyxl import load_workbook
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Detailed rows 4:25, cols C:R")
for r in range(4, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(3, 19)]
    print(r, vals)

# Inspect exact source/target areas and rows with non-empty quantity in frame 1
source_rows = []
for r in range(5, ws.max_row + 1):
    rowvals = [ws.cell(r, c).value for c in range(3, 10)]  # C:I
    qty = ws.cell(r, 9).value
    if qty is not None and str(qty).strip() != "":
        source_rows.append((r, rowvals))
print("\nSource rows with non-empty I (QUANTITY UNITS):")
for item in source_rows:
    print(item)

print("\nCurrent target frame 2 rows 5:25 (L:R):")
for r in range(5, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(12, 19)]
    print(r, vals)

# Implement result into existing frame 2 area (L:R) based on filtered frame 1 rows.
# Using static values for reliability in LibreOffice while fulfilling the requested transformation.
target_start = 5
target_cols = list(range(12, 19))  # L:R
source_cols = list(range(3, 10))   # C:I

# Clear existing target output rows below header, but preserve row 22 summary label cells if present outside target write count
for r in range(target_start, ws.max_row + 1):
    # Clear only rows intended for list output; row 22 currently has summary label in Q:R, keep if beyond filtered output area
    if r >= target_start:
        for c in target_cols:
            # preserve summary cells in row 22 Q:R if row won't be used by filtered output
            if r == 22 and c in (17, 18) and len(source_rows) < (22 - target_start + 1):
                continue
            ws.cell(r, c).value = None

# Write filtered rows into frame 2
for idx, (src_r, rowvals) in enumerate(source_rows, start=0):
    tgt_r = target_start + idx
    for offset, val in enumerate(rowvals):
        ws.cell(tgt_r, 12 + offset).value = val

# Apply alignment: product names left align, output values in O:R right align
for idx in range(len(source_rows)):
    r = target_start + idx
    ws.cell(r, 13).alignment = Alignment(horizontal="left")   # M = PRODUCT in frame 2
    for c in range(15, 19):  # O:R
        ws.cell(r, c).alignment = Alignment(horizontal="right")

# Also align source/target headers untouched; print verification range
print("\nAfter write, target frame 2 rows 4:25 (L:R):")
for r in range(4, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(12, 19)]
    print(r, vals)

out_path = "/sandbox/output/output_spreadsheet/" + input_spreadsheet.split("/")[-1]
wb.save(out_path)
print("Saved to:", out_path)

recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and verify sheet names
wb2 = load_workbook(out_path, data_only=False)
print("Reloaded sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    for i, name in enumerate(wb.sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to original names:", wb.sheetnames)

# Verify output values and alignments
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[wb.sheetnames[0]]
print("\nVerified target cells L:R rows 5 onward:")
for r in range(5, 5 + max(len(source_rows), 5)):
    vals = [wsv.cell(r, c).value for c in range(12, 19)]
    print(r, vals)

# verify styles from non-data_only workbook
wbs = load_workbook(out_path, data_only=False)
wss = wbs[wb.sheetnames[0]]
print("\nAlignment checks:")
for idx in range(len(source_rows)):
    r = 5 + idx
    print(
        r,
        "M align=", wss.cell(r, 13).alignment.horizontal,
        "O:R aligns=", [wss.cell(r, c).alignment.horizontal for c in range(15, 19)]
    )

output_spreadsheet = out_path
