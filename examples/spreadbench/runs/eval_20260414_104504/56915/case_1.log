from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os, shutil

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
cover = wb["COVER"]
data = wb["DATA"]

# Build effective merged-cell value map for DATA
merged_map = {}
for mr in data.merged_cells.ranges:
    tl = data.cell(mr.min_row, mr.min_col).value
    for rr in range(mr.min_row, mr.max_row + 1):
        for cc in range(mr.min_col, mr.max_col + 1):
            merged_map[(rr, cc)] = tl

def eff_data(r, c):
    v = data.cell(r, c).value
    return v if v is not None else merged_map.get((r, c))

entity = cover["B12"].value
cover_col_headers = {c: cover.cell(13, c).value for c in range(2, 6)}

print("Entity:", entity)
print("Cover headers B:E:", cover_col_headers)

# Determine the correct DATA columns for the selected entity.
# Because '% age' appears twice, use left-to-right order for repeated headers.
entity_cols = [c for c in range(2, data.max_column + 1) if eff_data(12, c) == entity]
print("Entity columns on DATA:", [(get_column_letter(c), eff_data(13, c)) for c in entity_cols])

header_occurrence_to_col = {}
occ_counter = {}
for c in entity_cols:
    hdr = eff_data(13, c)
    occ_counter[hdr] = occ_counter.get(hdr, 0) + 1
    header_occurrence_to_col[(hdr, occ_counter[hdr])] = c

print("Header occurrence map:", {k: get_column_letter(v) for k, v in header_occurrence_to_col.items()})

# Build DATA row lookup by exact row label in col A
data_row_by_label = {}
for r in range(18, data.max_row + 1):
    label = data.cell(r, 1).value
    if label is not None:
        data_row_by_label[label] = r

print("Relevant COVER labels and matched DATA rows:")
for r in range(18, 24):
    label = cover.cell(r, 1).value
    print(r, repr(label), "->", data_row_by_label.get(label))

# Write literal rounded values into B18:E23 where a DATA row exists; otherwise leave blanks
percent_fmt = '0.00;(0.00)'
amount_fmt = '#,##0.00;(#,##0.00)'

for r in range(18, 24):
    label = cover.cell(r, 1).value
    data_r = data_row_by_label.get(label)
    if data_r is None:
        # keep section/header rows blank
        for c in range(2, 6):
            cover.cell(r, c).value = None
        continue

    occ_seen = {}
    for c in range(2, 6):
        hdr = cover.cell(13, c).value
        occ_seen[hdr] = occ_seen.get(hdr, 0) + 1
        data_c = header_occurrence_to_col.get((hdr, occ_seen[hdr]))
        val = eff_data(data_r, data_c) if data_c else None
        if isinstance(val, (int, float)):
            val = round(val, 2)
        cover.cell(r, c).value = val
        cover.cell(r, c).number_format = amount_fmt if c in (2, 4) else percent_fmt

wb.save(outfile)
print("Saved to", outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and fix sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    for i, ws in enumerate(wb2.worksheets):
        ws.title = orig_sheetnames[i]
    wb2.save(outfile)

# Verify with data_only
ver = load_workbook(outfile, data_only=True)
print("Verified sheet names:", ver.sheetnames)
cover_v = ver["COVER"]

print("Verified target range B18:E23:")
for r in range(18, 24):
    print(r, [cover_v.cell(r, c).value for c in range(2, 6)])

# Also verify number formats from formula workbook version
fmt_wb = load_workbook(outfile)
fmt_cover = fmt_wb["COVER"]
print("Formats B18:E23:")
for r in range(18, 24):
    print(r, [(fmt_cover.cell(r, c).coordinate, fmt_cover.cell(r, c).number_format) for c in range(2, 6)])
