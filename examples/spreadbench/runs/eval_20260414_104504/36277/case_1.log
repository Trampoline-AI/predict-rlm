import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Inspect exact target cells and any styles before modifying
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet2"]

print("Target area before write:")
for r in range(1, 6):
    print(
        f"H{r}={ws[f'H{r}'].value!r}, I{r}={ws[f'I{r}'].value!r}, "
        f"I{r}_fmt={ws[f'I{r}'].number_format!r}"
    )

# Build output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

wb_out = load_workbook(out_path)
orig_sheetnames = wb_out.sheetnames[:]
ws = wb_out["Sheet2"]

# Write the drag-down-safe header-based lookup formula in I2:I5
# Uses Name column (B) to find the row matching I1, then uses H-row header to choose the return column.
for r in range(2, 6):
    formula = f'=INDEX($A$2:$E$25, MATCH($I$1, $B$2:$B$25, 0), MATCH(H{r}, $A$1:$E$1, 0))'
    print(f"Writing I{r} formula:", formula)
    ws[f"I{r}"] = formula

wb_out.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and fix sheet names if changed
wb_chk = load_workbook(out_path)
print("Sheet names after recalc:", wb_chk.sheetnames)
if wb_chk.sheetnames != orig_sheetnames:
    for idx, old_name in enumerate(orig_sheetnames):
        wb_chk.worksheets[idx].title = old_name
    wb_chk.save(out_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)
wsf = wb_formula["Sheet2"]
wsv = wb_values["Sheet2"]

print("\nVerification target cells H1:I5")
for r in range(1, 6):
    print(
        r,
        "H=", wsf[f"H{r}"].value,
        "I_formula=", wsf[f"I{r}"].value,
        "I_value=", wsv[f"I{r}"].value
    )

output_spreadsheet = out_path
```
