import os, calendar, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Further inspection: merged cells, styles/number formats around target, exact target range
print("Merged ranges:", list(ws.merged_cells.ranges))
for r in range(3, 12):
    vals = []
    for c in range(1, 16):
        cell = ws.cell(r, c)
        vals.append(f"{get_column_letter(c)}{r}={cell.value!r}|fmt={cell.number_format!r}")
    print(" ; ".join(vals))

year = ws["B3"].value
months = [ws.cell(8, c).value for c in range(2, 14)]
night_counts = [ws.cell(9, c).value for c in range(2, 14)]
print("Year in B3:", year)
print("Months B:M:", months)
print("Night counts B9:M9:", night_counts)

# Compute values
results = []
for idx, c in enumerate(range(2, 14), start=1):
    days = calendar.monthrange(int(year), idx)[1]
    count = ws.cell(9, c).value or 0
    val = count / days
    results.append((c, days, count, val))
print("Computed:", [(get_column_letter(c), days, count, val) for c, days, count, val in results])

# Write values and number formats
for c, days, count, val in results:
    cell = ws.cell(11, c)
    cell.value = float(val)
    # Formatting rule
    if abs(val) < 1e-15:
        cell.number_format = '0'
    else:
        rounded1 = round(val, 1)
        if abs(val - rounded1) < 1e-12 and abs(rounded1) > 1e-15:
            cell.number_format = '0.0'
        else:
            cell.number_format = '0.000000000'

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalculate and restore sheet names if needed
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_after = load_workbook(out_path)
if wb_after.sheetnames != orig_names:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)

# Verify
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_names[0]]
print("Verified target row 11 values:")
for c in range(1, 16):
    print(f"{get_column_letter(c)}11={wsv.cell(11,c).value!r}")

# Also verify stored number formats from normal load
wbf = load_workbook(out_path)
wsf = wbf[orig_names[0]]
print("Formats B11:M11:")
for c in range(2, 14):
    print(get_column_letter(c), wsf.cell(11,c).value, wsf.cell(11,c).number_format)
