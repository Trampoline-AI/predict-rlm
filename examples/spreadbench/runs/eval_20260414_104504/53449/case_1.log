    for idx, h in enumerate(hdrs, start=1):
        if h is not None and "procedure" in str(h).lower():
            found.append((ws.title, header_row, idx, h))
        if h is not None and "test" == str(h).strip().lower():
            found.append((ws.title, header_row, idx, h))
print("\nPotential relevant headers:", found)

# Print more focused info around Procedure Category ID if found
for ws in wb.worksheets:
