infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload ORIGINAL input to avoid carrying forward the mistaken H-column write
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Re-inspection before fix:")
print("Sheet names:", wb.sheetnames)
print("max_row/max_col:", ws.max_row, ws.max_column)
print("Headers A:H before writing:", [(get_column_letter(c), ws.cell(1,c).value) for c in range(1,9)])
print("Current values in F1:G16:")
for r in range(1, ws.max_row + 1):
    print(r, ws.cell(r,6).value, ws.cell(r,7).value)

target_col = 7  # exact new column immediately after F
source_col = 6  # Procedure Category ID

def copy_style(src, dst):
    if src.has_style:
        dst._style = copy.copy(src._style)
    if src.number_format is not None:
        dst.number_format = src.number_format
    if src.font is not None:
        dst.font = copy.copy(src.font)
    if src.fill is not None:
        dst.fill = copy.copy(src.fill)
    if src.border is not None:
        dst.border = copy.copy(src.border)
    if src.alignment is not None:
        dst.alignment = copy.copy(src.alignment)
    if src.protection is not None:
        dst.protection = copy.copy(src.protection)

# Write header in G and match prior column formatting
g1 = ws.cell(1, target_col)
copy_style(ws.cell(1, source_col), g1)
g1.value = "Test"

# Match column width from F to G
f_width = ws.column_dimensions["F"].width
if f_width is not None:
    ws.column_dimensions["G"].width = f_width

# Fill rows
for r in range(2, ws.max_row + 1):
    src_cell = ws.cell(r, source_col)
    out_cell = ws.cell(r, target_col)
    copy_style(src_cell, out_cell)
    val = "" if src_cell.value is None else str(src_cell.value).strip()
    out_cell.value = "X" if val == "Covid Test" else ""

# Ensure no accidental extra target column exists in this output
