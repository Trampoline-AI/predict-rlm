print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2,c).value for c in range(1, ws.max_column+1)]
        print("Row2 values:", headers2)
    # detect likely header row
    best_row = 1
    best_score = -1
    for r in range(1, min(ws.max_row, 5)+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        score = sum(v is not None and str(v).strip() != "" for v in vals)
        if score > best_score:
            best_score = score
            best_row = r
    print("Likely header row:", best_row)
    hdrs = [ws.cell(best_row,c).value for c in range(1, ws.max_column+1)]
    print("Likely headers:", [(get_column_letter(c), hdrs[c-1]) for c in range(1, ws.max_column+1)])
    # sample first 10 rows
    top_end = min(ws.max_row, 10)
    print("Top rows sample:")
    for r in range(1, top_end+1):
        row = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, row)
    print("Bottom rows sample:")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        row = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, row)
    return best_row, hdrs

found = []
for ws in wb.worksheets:
