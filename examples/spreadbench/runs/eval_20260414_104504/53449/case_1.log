        matches = [c for c,h in enumerate(headers, start=1) if h is not None and "procedure category id" in str(h).lower()]
        if matches:
            c = matches[0]
            print(f"\nFocused view for {ws.title}: header row {hr}, Procedure Category ID col {get_column_letter(c)}")
            # print neighboring headers
            start = max(1, c-2); end = min(ws.max_column, c+2)
            print("Neighbor headers:", [(get_column_letter(x), ws.cell(hr,x).value) for x in range(start,end+1)])
            for r in range(hr, min(ws.max_row, hr+10)+1):
                print(r, [(get_column_letter(x), ws.cell(r,x).value) for x in range(start,end+1)])
            for r in range(max(hr+1, ws.max_row-4), ws.max_row+1):
