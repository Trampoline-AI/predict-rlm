```repl
from collections import Counter
from openpyxl import load_workbook
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]
desired = wb["Desired Results"]

# gather actual non-empty data rows in col A excluding header
data = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v not in (None, ""):
        data.append((r, v))

desired_data = []
for r in range(2, desired.max_row + 1):
    v = desired.cell(r, 1).value
    if v not in (None, ""):
        desired_data.append((r, v))

counts = Counter(v for _, v in data)
print("Source non-empty rows:", len(data))
print("Unique items/counts:", counts)
print("First 20 source values:", [v for _, v in data[:20]])
print("First 20 desired values:", [v for _, v in desired_data[:20]])
print("Last 10 desired values:", [v for _, v in desired_data[-10:]])

# infer desired order by first appearance in desired sheet
desired_order = []
seen = set()
for _, v in desired_data:
    if v not in seen:
        seen.add(v)
        desired_order.append(v)
print("Desired unique order:", desired_order)
print("Desired counts by item:", {k: Counter(v for _, v in desired_data)[k] for k in desired_order})

# compute sort by descending frequency, tie-break by first appearance in source
first_pos = {}
for idx, (_, v) in enumerate(data):
    if v not in first_pos:
        first_pos[v] = idx
sorted_items = sorted(counts.keys(), key=lambda x: (-counts[x], first_pos[x]))
expanded = []
for item in sorted_items:
    expanded.extend([item] * counts[item])

print("Computed unique order:", sorted_items)
print("Matches desired exactly?:", expanded == [v for _, v in desired_data])

# apply to Sheet1 column A only if not already matching
for i, value in enumerate(expanded, start=2):
    ws.cell(i, 1).value = value

# clear any extra rows in col A below output if present
for r in range(2 + len(expanded), ws.max_row + 1):
    if ws.cell(r, 1).value not in (None, ""):
        ws.cell(r, 1).value = None

# save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalc
res = await recalculate(out_path)
print("Recalculate:", res)

# restore sheet names if altered
orig_names = ["Sheet1", "Desired Results"]
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for ws_obj, orig in zip(wb2.worksheets, orig_names):
        ws_obj.title = orig
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# verify output
ver = load_workbook(out_path, data_only=True)
vws = ver["Sheet1"]
out_vals = [vws.cell(r, 1).value for r in range(2, 2 + len(expanded))]
print("Verified first 20 output:", out_vals[:20])
print("Verified last 10 output:", out_vals[-10:])
print("No blanks in target range?:", all(v not in (None, "") for v in out_vals))
print("Exact match to Desired Results?:", out_vals == [v for _, v in desired_data])

final_output_spreadsheet = out_path
```
