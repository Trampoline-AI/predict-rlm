from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Merged ranges:", list(ws.merged_cells.ranges))
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"Sheet1 R{r}: {vals}")

# inspect target/source columns and formulas/styles
header_row = 5
src_col = None
for c in range(1, ws.max_column + 1):
    if ws.cell(header_row, c).value == "0-15":
        src_col = c
        break
print("Source col for 0-15:", src_col, get_column_letter(src_col) if src_col else None)
print("Current B column values:", [ws.cell(r, 2).value for r in range(1, ws.max_row + 1)])
print("Current source column values:", [ws.cell(r, src_col).value for r in range(1, ws.max_row + 1)])

for r in range(5, ws.max_row + 1):
    print(r, "B=", ws.cell(r,2).value, "src=", ws.cell(r,src_col).value, "L=", ws.cell(r,12).value)

# perform insert and move only on Sheet1
ws.insert_cols(2, 1)

new_src_col = src_col + 1 if src_col >= 2 else src_col
print("After insert, new source col:", new_src_col, get_column_letter(new_src_col))

# copy values, styles, formatting, comments, hyperlinks from source column to B
for r in range(1, ws.max_row + 1):
    src = ws.cell(r, new_src_col)
    dst = ws.cell(r, 2)
    dst.value = src.value
    if src.has_style:
        dst._style = copy(src._style)
    if src.number_format:
        dst.number_format = copy(src.number_format)
    if src.font:
        dst.font = copy(src.font)
    if src.fill:
        dst.fill = copy(src.fill)
    if src.border:
        dst.border = copy(src.border)
    if src.alignment:
        dst.alignment = copy(src.alignment)
    if src.protection:
        dst.protection = copy(src.protection)
    if src.comment:
        dst.comment = copy(src.comment)
    if src.hyperlink:
        dst._hyperlink = copy(src.hyperlink)

# match dimensions
if get_column_letter(new_src_col) in ws.column_dimensions:
    ws.column_dimensions["B"].width = ws.column_dimensions[get_column_letter(new_src_col)].width

# delete original source column
ws.delete_cols(new_src_col, 1)

print("Post-move rows:")
for r in range(5, ws.max_row + 1):
    print(f"R{r}:", [ws.cell(r,c).value for c in range(1, ws.max_column + 1)])

# save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# restore sheet names if needed
wb2 = load_workbook(out_path)
if wb2.sheetnames != wb.sheetnames:
    current = wb2.sheetnames[:]
    for i, orig in enumerate(wb.sheetnames):
        wb2[current[i]].title = orig
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# verify with data_only
verify = load_workbook(out_path, data_only=True)
vws = verify["Sheet1"]
print("Verified sheet names:", verify.sheetnames)
print("Verified Column B values rows 5-11:", [vws.cell(r,2).value for r in range(5, min(11, vws.max_row)+1)])
print("Verified full rows 5-11:")
for r in range(5, min(11, vws.max_row)+1):
    print(r, [vws.cell(r,c).value for c in range(1, vws.max_column + 1)])

output_spreadsheet = out_path
