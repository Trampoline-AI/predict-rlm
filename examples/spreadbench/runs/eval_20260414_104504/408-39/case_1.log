from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, textwrap, shutil

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

inspection = {}
for ws in wb.worksheets:
    max_row, max_col = ws.max_row, ws.max_column
    headers1 = row_values(ws, 1, max_col)
    headers2 = row_values(ws, 2, max_col) if max_row >= 2 else []
    print(f"\n--- Sheet: {ws.title} rows={max_row} cols={max_col} ---")
    print("Row1 headers/values:", headers1)
    print("Row2 values:", headers2)
    
    # find cells with exact '0-15'
    found = []
    for r in range(1, min(max_row, 10)+1):
        for c in range(1, max_col+1):
            v = ws.cell(r,c).value
            if v == "0-15" or v == 0-15:
                found.append(f"{get_column_letter(c)}{r}")
    print("Found exact '0-15' in first 10 rows at:", found)
    
    # sample rows first 10 and last 5
    first_n = min(10, max_row)
    for r in range(1, first_n+1):
        print(f"R{r}:", row_values(ws, r, min(max_col, 15)))
    start_last = max(1, max_row-4)
    if start_last > first_n:
        print("... last 5 rows ...")
        for r in range(start_last, max_row+1):
            print(f"R{r}:", row_values(ws, r, min(max_col, 15)))
    
    inspection[ws.title] = {"rows": max_row, "cols": max_col, "row1": headers1, "row2": headers2}

# Also specifically inspect column B and any source col with header 0-15
for ws in wb.worksheets:
    max_col = ws.max_column
    candidates = []
    for c in range(1, max_col+1):
        if ws.cell(1,c).value == "0-15" or ws.cell(2,c).value == "0-15":
            candidates.append(c)
    print(f"\nSheet {ws.title} candidate 0-15 cols:", [(c, get_column_letter(c)) for c in candidates])
    print("Column B top 10 values:", [ws.cell(r,2).value for r in range(1, min(10, ws.max_row)+1)])
    for c in candidates:
        print(f"Source col {get_column_letter(c)} top 10 values:", [ws.cell(r,c).value for r in range(1, min(10, ws.max_row)+1)])
        cell = ws.cell(1,c)
        print("Header formula?", cell.data_type, cell.value)

print("Done inspection")
