import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Pre-write check: rows with Runner=1 and current H:S")
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 2).value == 1:
        print(r, [ws.cell(r, c).value for c in range(1, 8)], [ws.cell(r, c).value for c in range(8, 20)])

fill = PatternFill(start_color="E2EFDA", end_color="E2EFDA", fill_type="solid")

# Write formulas into H:S for all data rows. Formula preserves blanks and only shows on Runner=1 rows.
for r in range(2, ws.max_row + 1):
    for c in range(8, 20):  # H:S
        cell = ws.cell(r, c)
        # formula uses bounded G range and exact row offsets from the current starter row
        formula = (
            f'=IF($B{r}<>1,"",'
            f'IF({c-7}>$C{r},"",'
            f'IF(INDEX($G$2:$G$28,ROW()-1+COLUMN()-8)="","",INDEX($G$2:$G$28,ROW()-1+COLUMN()-8))))'
        )
        cell.value = formula
        cell.fill = fill
        cell.number_format = "0.############"

# Also shade header row? instruction only H2:S28, so rows 2:28 only
for r in range(2, 29):
    for c in range(8, 20):
        ws.cell(r, c).fill = fill
        ws.cell(r, c).number_format = "0.############"

wb.save(outfile)
print("Saved to", outfile)

result = await recalculate(outfile)
print("Recalc:", result)

# Reload and fix sheet name if recalc renamed it
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # restore names in order
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
else:
    print("Sheet names preserved:", wb2.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals[orig_sheetnames[0]]

print("\nVerification target rows (Runner=1):")
for r in range(2, wsv.max_row + 1):
    if wsv.cell(r, 2).value == 1:
        print("Row", r, "Race", wsv.cell(r,1).value, "Runners", wsv.cell(r,3).value)
        print(" formulas:", [wsf.cell(r, c).value for c in range(8, 20)])
        print(" values  :", [wsv.cell(r, c).value for c in range(8, 20)])

print("\nVerification fills / number format samples:")
for addr in ["H2", "L2", "H7", "O7", "H15", "S28"]:
    cf = wsf[addr]
    print(addr, "fill", cf.fill.start_color.rgb, "numfmt", cf.number_format, "value", wsv[addr].value)

output_spreadsheet = outfile
