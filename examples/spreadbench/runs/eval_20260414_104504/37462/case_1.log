```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
import os
from collections import defaultdict

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Inspect actual source cached values first
wb_data = load_workbook(infile, data_only=True)
wsd = wb_data["DATABASE Countries"]

print("Source A:C rows 4:20 (data_only):")
for r in range(4, 21):
    print(r, wsd[f"A{r}"].value, wsd[f"B{r}"].value, wsd[f"C{r}"].value)

print("\nCheck exchange-rate helper cells around B2 and table B41:C49 (data_only):")
print("B2=", wsd["B2"].value)
for r in range(41, 50):
    print(r, wsd[f"B{r}"].value, wsd[f"C{r}"].value)

# Build USD totals by exact trimmed country match from cached values
usd_by_country = defaultdict(float)
for r in range(4, 37):  # source extent used by formulas
    country = wsd[f"A{r}"].value
    usd_val = wsd[f"C{r}"].value
    if country is None or str(country).strip() == "":
        continue
    key = str(country).strip()
    if usd_val in (None, ""):
        num = 0.0
    else:
        try:
            num = float(usd_val)
        except Exception:
            num = 0.0
    usd_by_country[key] += num

print("\nComputed USD totals from source:")
for k in sorted(usd_by_country)[:10]:
    print(k, usd_by_country[k])
print("India total:", usd_by_country.get("India"))
print("United Kingdom total:", usd_by_country.get("United Kingdom"))

# Write literal values to target cells F4:F244 with required styling
wb = load_workbook(outfile)
ws = wb["DATABASE Countries"]

fill = PatternFill(fill_type="solid", start_color="FFC7CE", end_color="FFC7CE")
base_font = ws["F4"].font
font = Font(
    name=base_font.name,
    size=base_font.sz,
    bold=base_font.bold,
    italic=base_font.italic,
    vertAlign=base_font.vertAlign,
    underline=base_font.underline,
    strike=base_font.strike,
    color="9C0006",
)

for r in range(4, 245):
    country = ws[f"E{r}"].value
    if country is None or str(country).strip() == "":
        continue
    key = str(country).strip()
    val = usd_by_country.get(key, 0.0)
    ws[f"F{r}"] = val
    ws[f"F{r}"].fill = fill
    ws[f"F{r}"].font = font

wb.save(outfile)
print("\nSaved literal-value fallback to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify output
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["DATABASE Countries"]

print("\nVerification target rows:")
for r in [4,5,6,10,50,100,200,244]:
    print(r, "E=", wsv[f"E{r}"].value, "F=", wsv[f"F{r}"].value)

print("\nCheck rows for actual populated countries in source mapping:")
for target_country in ["India", "United Kingdom", "Afghanistan", "Albania", "Other"]:
    found = None
    for r in range(4, 245):
        if str(wsv[f"E{r}"].value).strip() == target_country:
            found = r
            break
    print(target_country, "row", found, "value", wsv[f"F{found}"].value if found else None)

# verify style still present in normal workbook
wbn = load_workbook(outfile)
wsn = wbn["DATABASE Countries"]
for r in [4,5,10]:
    c = wsn[f"F{r}"]
    print("Style", r, c.fill.start_color.rgb, c.font.color.type if c.font.color else None, getattr(c.font.color, "rgb", None))

output_spreadsheet = outfile
