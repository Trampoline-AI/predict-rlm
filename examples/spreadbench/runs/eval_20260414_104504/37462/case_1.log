from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os, json, math

print("INSTRUCTION:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # collect formula cells and colored cells in used range
    formula_cells = []
    colored_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
            fill = cell.fill
            if fill and fill.fill_type == "solid":
                rgb = fill.fgColor.rgb or fill.start_color.rgb
                if rgb not in (None, "00000000", "000000", "000000FF", "FFFFFFFF", "00FFFFFF"):
                    colored_cells.append((cell.coordinate, rgb, cell.value))
    print("Formula cells count:", len(formula_cells))
    print("Sample formula cells:", formula_cells[:20])
    print("Colored cells count:", len(colored_cells))
    print("Sample colored cells:", colored_cells[:30])
