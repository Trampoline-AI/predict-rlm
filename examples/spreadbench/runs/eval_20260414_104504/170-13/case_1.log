import os, shutil
from collections import OrderedDict
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload fresh workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1, ws2, ws3 = wb["Sheet1"], wb["Sheet2"], wb["Sheet3"]

# Build Sheet2 header -> nonblank values map
sheet2_map = OrderedDict()
for c in range(1, ws2.max_column + 1):
    header = ws2.cell(1, c).value
    vals = []
    for r in range(2, ws2.max_row + 1):
        v = ws2.cell(r, c).value
        if v not in (None, ""):
            vals.append(str(v).strip())
    sheet2_map[str(header).strip()] = vals

# Build expected output list: for each Sheet1 entry, if it contains a Sheet2 header,
# append one row per nonblank value from that Sheet2 header.
entries = []
for r in range(2, ws1.max_row + 1):
    v = ws1.cell(r, 1).value
    if v not in (None, ""):
        entries.append(str(v).strip())

expected = []
match_details = []
for entry in entries:
    matched = False
    for hdr, vals in sheet2_map.items():
        if hdr and hdr in entry:
            matched = True
            match_details.append((entry, hdr, len(vals)))
            for v in vals:
                expected.append(entry + v)
            break
    if not matched:
        match_details.append((entry, None, 0))

print("Match details:")
for md in match_details:
    print(md)
print("Expected output row count:", len(expected))

# Inspect current target cells before overwrite
current = [ws3.cell(r, 1).value for r in range(1, ws3.max_row + 1)]
print("Current Sheet3 A1:A{} sample:".format(ws3.max_row))
for i, v in enumerate(current[:10], start=1):
    print(i, v)
if len(current) > 15:
    print("...")
    for idx in range(max(11, len(current)-4), len(current)+1):
        print(idx, current[idx-1])

# Ensure header
ws3["A1"] = "Output"

# Clear existing data rows in column A below header
for r in range(2, ws3.max_row + 1):
    ws3.cell(r, 1).value = None

# Write expected outputs to existing Sheet3 Output column
for i, val in enumerate(expected, start=2):
    ws3.cell(i, 1).value = val

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and repair sheet names if recalc renamed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename by position to original names
    for ws, target_name in zip(wb_check.worksheets, orig_sheetnames):
        ws.title = target_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only after recalculation
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
ws3v = wb_verify["Sheet3"]

target_values = [ws3v.cell(r, 1).value for r in range(1, len(expected) + 2)]
print("Verified target range A1:A{}:".format(len(expected)+1))
for i, v in enumerate(target_values[:12], start=1):
    print(i, v)
if len(target_values) > 20:
    print("...")
    for idx in range(len(target_values)-4, len(target_values)+1):
        print(idx, target_values[idx-1])

# Sanity checks
assert ws3v["A1"].value == "Output"
assert len(expected) == len([v for v in target_values[1:] if v not in (None, "")]), "Output row count mismatch"
assert all((v is not None and str(v).strip() != "") for v in target_values[1:]), "Blank output cells found"

output_spreadsheet = outfile
print("Final output file ready:", output_spreadsheet)
