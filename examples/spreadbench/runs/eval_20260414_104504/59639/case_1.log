import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Confirm target area and current values before modification
print("Before modification:")
for r in range(4, ws.max_row + 1):
    print(f"Row {r} A:{ws[f'A{r}'].value!r} D:K:", [ws.cell(r, c).value for c in range(4, 12)])

# Fill formulas only where source exists and output area is blank (preserve sample row 4)
for r in range(4, ws.max_row + 1):
    source = ws.cell(r, 1).value
    outputs = [ws.cell(r, c).value for c in range(4, 12)]
    if source not in (None, ""):
        # preserve rows that already have sample answers
        if any(v not in (None, "") for v in outputs):
            continue
        for c in range(4, 12):  # D:K exact sample/designated area
            cell = ws.cell(r, c)
            # 1st char in D => COLUMN()-3
            cell.value = f'=IF(LEN($A{r})>=COLUMN()-3,MID($A{r},COLUMN()-3,1),"")'

wb.save(outfile)
print("Saved to", outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("Written formulas rows 5:7 D:K")
for r in range(5, 8):
    print(r, [wsf.cell(r, c).value for c in range(4, 12)])

wb_val = load_workbook(outfile, data_only=True)
wsv = wb_val["Sheet1"]
print("Verified cached values rows 4:7 D:K")
for r in range(4, 8):
    print(r, [wsv.cell(r, c).value for c in range(4, 12)])

output_spreadsheet = outfile
