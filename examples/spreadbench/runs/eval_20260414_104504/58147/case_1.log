```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Here"]

def extract_outcome(val):
    if val is None:
        return None
    s = str(val).strip()
    if s == "":
        return ""
    parts = s.split(" - ")
    if len(parts) >= 3:
        return parts[-2].strip()   # middle part for patterns like "1 - Name - ID"
    if len(parts) == 2:
        return parts[0].strip()    # left part for patterns like "Name - ID"
    return s

# Show current relevant area before fix
print("Before fix, data_only values from source workbook are not recalculated here; writing based on formula patterns and existing examples.")
for r in range(2, 7):
    print("pre", r, "I_formula/value=", ws.cell(r,9).value, "J=", ws.cell(r,10).value)

# To correctly handle rows whose I cells are formulas, use recalculated values from current output file if available,
# otherwise recalc a temp saved workbook first.
tmp_precalc = outfile
wb.save(tmp_precalc)
recalc_result = await recalculate(tmp_precalc)
print("Recalc before extraction:", recalc_result)

wb_vals = load_workbook(tmp_precalc, data_only=True)
ws_vals = wb_vals["Here"]

written = 0
for r in range(2, ws.max_row + 1):
    i_val = ws_vals.cell(r, 9).value
    j_val = extract_outcome(i_val)
    # write only when source has something or existing J has something
    if i_val not in (None, "") or ws.cell(r, 10).value not in (None, ""):
        ws.cell(r, 10).value = j_val
        written += 1
    else:
        ws.cell(r, 10).value = None

wb.save(outfile)

# restore sheet names if changed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)

# final verification
wb_final = load_workbook(outfile, data_only=True)
ws_final = wb_final["Here"]
print("Written rows in J:", written)
print("Verified J2:J6:")
for r in range(2, 7):
    print(r, "I=", ws_final.cell(r,9).value, "J=", ws_final.cell(r,10).value)

output_spreadsheet = outfile
```
