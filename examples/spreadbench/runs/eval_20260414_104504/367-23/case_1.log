import os, math
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Working sheet:", ws.title)
print("Before deletion, rows 1..5:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Identify numeric data rows in column D whose magnitude is within threshold
threshold = 0.011
candidate_rows = []
candidate_vals = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 4).value
    if isinstance(v, (int, float)) and abs(v) < threshold:
        candidate_rows.append(r)
        candidate_vals.append(float(v))

print("Candidate rows:", candidate_rows)
print("Candidate vals:", candidate_vals)
print("Candidate sum:", sum(candidate_vals), "abs(sum):", abs(sum(candidate_vals)))

# Delete those rows only if their net is effectively zero
if candidate_rows and abs(sum(candidate_vals)) < threshold:
    for r in sorted(candidate_rows, reverse=True):
        ws.delete_rows(r, 1)
    print("Deleted rows:", candidate_rows)
else:
    print("No deletion performed")

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheet_names)
    for i, old_name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = old_name
    wb2.save(outfile)

# Verify output
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_sheet_names[0]]
print("After deletion max_row/max_col:", wsv.max_row, wsv.max_column)
for r in range(1, wsv.max_row + 1):
    print("row", r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

output_spreadsheet = outfile
