import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # collect headers from first up to 3 rows to detect header row
    for hr in range(1, min(4, ws.max_row+1)):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column+1)]
        print(f"Row {hr}:", vals)
    # print sample first 10 rows and last 5 rows
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    print("Last rows:")
    start_last = max(1, ws.max_row-4)
    for r in range(start_last, ws.max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # print formulas / non-empty cells with coordinates for small sheets
    print("Non-empty cells with coords:")
    nonempty = []
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                nonempty.append((cell.coordinate, cell.value))
    print(nonempty[:100])

for ws in wb.worksheets:
    sheet_summary(ws)
