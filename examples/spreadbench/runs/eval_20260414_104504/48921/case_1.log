from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Fill blank Result cells in column A based on Code in column B.
# Use LibreOffice-compatible formula: remove first character and coerce to numeric to drop leading zeros.
filled = 0
preserved = 0
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1)
    b = ws.cell(r, 2).value
    if b is None or str(b).strip() == "":
        continue
    if a.value is None or a.value == "":
        a.value = f'=VALUE(RIGHT(B{r},LEN(B{r})-1))'
        filled += 1
    else:
        preserved += 1

print("Filled formulas:", filled, "Preserved existing:", preserved)
print("Sample formulas/values before save:")
for r in [2,3,4,5,6,7,4400,4452]:
    print(r, "A=", ws[f"A{r}"].value, "B=", ws[f"B{r}"].value)

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

