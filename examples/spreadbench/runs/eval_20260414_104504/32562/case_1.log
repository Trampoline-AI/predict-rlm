import os
from collections import Counter
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Re-open fresh workbook for editing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet2"]

# Determine true data extent in column A
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 1).value not in (None, ""):
        last_data_row = r
        break

# Print current target formulas/values before modification
print("Target sheet:", ws.title)
print("Header A1/B1:", ws["A1"].value, ws["B1"].value)
print("Last data row in A:", last_data_row)
print("Current B2:B{} formulas/values:".format(last_data_row))
for r in range(2, last_data_row + 1):
    print(r, ws.cell(r, 1).value, ws.cell(r, 2).value)

# Compute expected counts from source data for verification
items = [ws.cell(r, 1).value for r in range(2, last_data_row + 1) if ws.cell(r, 1).value not in (None, "")]
freq = Counter(items)
print("Computed frequencies:", dict(freq))

# Write correct formulas into existing target column B
for r in range(2, last_data_row + 1):
    a_val = ws.cell(r, 1).value
    b_cell = ws.cell(r, 2)
    if a_val in (None, ""):
        b_cell.value = None
    else:
        b_cell.value = f'=COUNTIF($A$2:$A${last_data_row},A{r})'

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_post = load_workbook(outfile)
if wb_post.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_post.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position to original names
    for i, name in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = name
    wb_post.save(outfile)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[orig_sheetnames[0]]
print("Verified sheet names:", wb_verify.sheetnames)
print("Verified target B2:B{} values:".format(last_data_row))
all_ok = True
for r in range(2, last_data_row + 1):
    item = wsv.cell(r, 1).value
    val = wsv.cell(r, 2).value
    expected = freq.get(item)
    print(r, "A=", item, "B=", val, "expected=", expected)
    if item not in (None, "") and val != expected:
        all_ok = False
print("Verification passed:", all_ok)
```
