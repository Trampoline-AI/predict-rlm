```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
from openpyxl.styles import PatternFill

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Data"]

start_row = 14
start_col = column_index_from_string("AD")
end_col = column_index_from_string("AO")

# clear/fill formulas only for rows that appear to be actual customer rows
written = []
for r in range(start_row, ws.max_row + 1):
    approved = ws[f"K{r}"].value
    eff = ws[f"L{r}"].value
    base = ws[f"W{r}"].value
    freq_ref = f"$J{r}"
    should_fill = (approved == "Approved" and eff is not None and isinstance(base, (int, float)))
    for c in range(start_col, end_col + 1):
        cell = ws.cell(r, c)
        if should_fill:
            col_letter = get_column_letter(c)
            formula = (
                f'=IF(OR($K{r}="",$L{r}="",$W{r}=""),"",'
                f'IF({col_letter}$9<$L{r},"",'
                f'$W{r}'
                f'*(1+IF({col_letter}$9>=$L{r},$M{r},0))'
                f'*(1+IF(AND($N{r}<>"",{col_letter}$9>=DATE(YEAR($L{r}),MONTH($L{r})+{freq_ref},DAY($L{r}))),$N{r},0))'
                f'*(1+IF(AND($O{r}<>"",{col_letter}$9>=DATE(YEAR($L{r}),MONTH($L{r})+2*{freq_ref},DAY($L{r}))),$O{r},0))'
                f'*(1+IF(AND($P{r}<>"",{col_letter}$9>=DATE(YEAR($L{r}),MONTH($L{r})+3*{freq_ref},DAY($L{r}))),$P{r},0))'
                f'))'
            )
            cell.value = formula
            cell.fill = PatternFill(fill_type=None)  # remove yellow fill
            written.append(cell.coordinate)
        else:
            # keep truly inactive rows blank in target range
            if cell.value is not None:
                cell.value = None
            cell.fill = PatternFill(fill_type=None)

wb.save(outfile)
print("Saved:", outfile)
print("Written count:", len(written), "sample:", written[:12])

res = await recalculate(outfile)
print("Recalculate:", res)

# restore sheet name if changed
orig_names = wb.sheetnames
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)

# verification
wbv = load_workbook(outfile, data_only=False)
wsv = wbv["Data"]
wbv2 = load_workbook(outfile, data_only=True)
wsv2 = wbv2["Data"]

for r in [14, 15, 17, 18, 24]:
    print(f"\nRow {r} formulas/values AD:AO")
    for c in range(start_col, end_col + 1):
        coord = f"{get_column_letter(c)}{r}"
        print(coord, "formula=", wsv[coord].value, "value=", wsv2[coord].value)

print("Sheet names final:", wbv.sheetnames)
```
