Code:
```repl
import os, shutil, re
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and transform
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Writing output to Column B for rows 1 to", ws.max_row)
for r in range(1, ws.max_row + 1):
    src = ws.cell(r, 1).value
    current_b = ws.cell(r, 2).value
    print(f"Row {r} source:", src)
    print(f"Row {r} existing B:", current_b)
    if src is None or src == "":
        continue
    text = str(src)
    idx = text.find("FT")
    result = text[:idx].rstrip() if idx != -1 else text.rstrip()
    ws.cell(r, 2).value = result
    print(f"Row {r} result B:", result)

wb.save(outfile)
print("Saved:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", original_sheetnames)
    for i, old_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)
else:
    print("Sheet names unchanged after recalc:", wb_after.sheetnames)

# Verify with data_only view
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify[original_sheetnames[0]]

print("Target cells B1:B{}".format(vws.max_row))
for r in range(1, vws.max_row + 1):
    print(r, "A=", vws.cell(r, 1).value, "| B=", vws.cell(r, 2).value)

output_spreadsheet = outfile
```
