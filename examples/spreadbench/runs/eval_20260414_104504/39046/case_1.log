import os
from openpyxl import load_workbook

infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]
orig_sheetnames = wb.sheetnames[:]

# Determine true last data row based on any non-empty cells in A:F
true_last = 1
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    if any(v is not None and v != "" for v in vals):
        true_last = r

print("True last data row:", true_last)
print("Target headers:", ws["E1"].value, ws["F1"].value)

# Print current target area and formulas/values before modification
for r in range(2, true_last + 1):
    print("BEFORE", r, {
        "B": ws[f"B{r}"].value,
        "C": ws[f"C{r}"].value,
        "D": ws[f"D{r}"].value,
        "E": ws[f"E{r}"].value,
        "F": ws[f"F{r}"].value,
    })

# Apply formulas to all actual data rows only
for r in range(2, true_last + 1):
    if all(ws.cell(r, c).value in (None, "") for c in range(1, 5)):
        continue
    # User asked for formulas; write into designated existing columns E/F
    ws[f"E{r}"] = f'=IF(C{r}="CANCELLED",IF(COUNTIF($D$2:$D${true_last},"*"&B{r}&"*")>0,"Yes","No"),"No")'
    ws[f"F{r}"] = f'=IF(C{r}="CANCELLED",COUNTIF($D$2:$D${true_last},"*"&B{r}&"*"),0)'

# Save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = s
    wb_check.save(outfile)
    print("Restored sheet names:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("FORMULAS written:")
for r in range(2, true_last + 1):
    print(r, wsf[f"E{r}"].value, "|", wsf[f"F{r}"].value)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[orig_sheetnames[0]]
print("CACHED VALUES after recalc:")
for r in range(2, true_last + 1):
    print("AFTER", r, {
        "B": wsv[f"B{r}"].value,
        "C": wsv[f"C{r}"].value,
        "D": wsv[f"D{r}"].value,
        "E": wsv[f"E{r}"].value,
        "F": wsv[f"F{r}"].value,
    })

output_spreadsheet = outfile
