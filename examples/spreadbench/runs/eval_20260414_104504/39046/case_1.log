import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n=== Sheet: {sname} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        print("Header row 2:", row_values(ws, 2, ws.max_column))
    # print first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_values(ws, r, ws.max_column))
    
    # Focus on columns B-F if present
    if ws.max_column >= 6:
        print("Focused B:F preview first 12 rows:")
        for r in range(1, min(ws.max_row, 12) + 1):
            vals = [ws.cell(r, c).value for c in range(2, 7)]
            print(r, vals)
        if ws.max_row > 12:
            print("Focused B:F last 5 rows:")
            for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
                vals = [ws.cell(r, c).value for c in range(2, 7)]
                print(r, vals)
        
        # Existing formulas in E/F
        for col in [5, 6]:
            col_letter = get_column_letter(col)
            found = []
            for r in range(1, ws.max_row + 1):
                v = ws.cell(r, col).value
                if isinstance(v, str) and v.startswith("="):
                    found.append((r, v))
                    if len(found) >= 10:
                        break
            print(f"Sample formulas in column {col_letter}:", found if found else "None")
