import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

# Fill Salary column C for each non-empty data row based on A and B
for r in range(2, ws.max_row + 1):
    job = ws.cell(r, 1).value
    months = ws.cell(r, 2).value
    if job not in (None, "") and months not in (None, ""):
        formula = f'=INDEX(Data!$C$3:$AY$4, MATCH(A{r}, Data!$B$3:$B$4, 0), MATCH(B{r}, Data!$C$2:$AY$2, 0))'
        ws.cell(r, 3).value = formula
        print(f"Wrote C{r}: {formula}")

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if altered
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify formulas and calculated values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)

print("Verified sheet names:", wb_formula.sheetnames)

wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

print("Final formulas/values in target cells:")
for r in range(2, wsf.max_row + 1):
    print(
        f"Row {r}",
        "A=", wsf.cell(r,1).value,
        "B=", wsf.cell(r,2).value,
        "C_formula=", wsf.cell(r,3).value,
        "C_value=", wsv.cell(r,3).value,
    )

output_spreadsheet = outfile
```
