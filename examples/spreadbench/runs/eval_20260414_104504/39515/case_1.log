Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print target area before modification
print("Target column:", "O", "header:", ws["O1"].value)
for r in range(2, ws.max_row + 1):
    print("Before", r, "A/B/O =", ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"O{r}"].value)

# Apply updated formula to all data rows with content
for r in range(2, ws.max_row + 1):
    month_val = ws[f"A{r}"].value
    year_val = ws[f"B{r}"].value
    if month_val is None and year_val is None:
        continue
    # 2022 rows should use JAN; other rows use month lookup
    ws[f"O{r}"] = f'=IF($B{r}=2022,$C{r},INDEX($C{r}:$N{r},MATCH($A{r},$C$1:$N$1,0)))'

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring to", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formulas after write:")
for r in range(2, wsf.max_row + 1):
    print(r, wsf[f"O{r}"].value)

# Verify cached values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
print("Cached values after recalc (A,B,C,O):")
for r in range(2, wsv.max_row + 1):
    print(r, wsv[f"A{r}"].value, wsv[f"B{r}"].value, wsv[f"C{r}"].value, wsv[f"O{r}"].value)

output_spreadsheet = outfile
