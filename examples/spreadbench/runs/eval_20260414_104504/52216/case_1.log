import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:\n", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # detect headers from first 1-3 rows
    for r in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)]
        print(f"Row {r}:", vals)
    # first 10 rows, first up to 10 cols
    print("First rows sample:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 10) + 1)]
        print(f" {r}: {vals}")
    print("Last 5 rows sample:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 10) + 1)]
        print(f" {r}: {vals}")

for ws in wb.worksheets:
    sheet_summary(ws)

# inspect INPUTS tab around referenced area
if "INPUTS" in wb.sheetnames:
    ws = wb["INPUTS"]
    print("\nDetailed INPUTS! rows 10:25 cols A:J")
    for r in range(10, min(26, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, 11)]
        print(r, vals)
    # print formulas and values in C15:G25
    print("\nInspect C15:G25")
    for r in range(15, min(26, ws.max_row + 1)):
        row = []
        for c in range(3, 8):
            cell = ws.cell(r, c)
            row.append((f"{get_column_letter(c)}{r}", cell.value))
        print(row)

# inspect all formula cells and especially around blanks beneath first correct row
for ws in wb.worksheets:
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
    print(f"\nFormula cells in {ws.title}: {len(formula_cells)}")
    for item in formula_cells[:30]:
        print(item)
