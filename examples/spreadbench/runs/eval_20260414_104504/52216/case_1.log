Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and inspect current target cells before modification
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["INPUTS"]

print("Before write, INPUTS!C16:G16 formulas/values:")
for c in range(3, 8):
    print(ws.cell(16, c).coordinate, ws.cell(16, c).value)

# Apply copyable formula only to Electricity first 5 years
base_formula = '=SUMPRODUCT((Sheet2!$A$3:$A$20=$A$14)*(Sheet2!$B$3:$B$20=$A16)*(Sheet2!$C$1:$G$1={hdr})*Sheet2!$C$3:$G$20)'
for c in range(3, 8):  # C:G
    hdr = f"{ws.cell(3, c).coordinate}"
    ws.cell(16, c).value = base_formula.format(hdr=hdr)

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["INPUTS"]
print("\nWritten formulas in INPUTS!C16:G16:")
for c in range(3, 8):
    print(wsf.cell(16, c).coordinate, wsf.cell(16, c).value)

wb_val = load_workbook(outfile, data_only=True)
wsv = wb_val["INPUTS"]
print("\nCached values in INPUTS!C15:G16 after recalc:")
for r in [15, 16]:
    vals = []
    for c in range(3, 8):
        vals.append((wsv.cell(r, c).coordinate, wsv.cell(r, c).value))
    print(vals)

output_spreadsheet = outfile
