import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load original workbook and preserve original sheet names
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Show formulas to be written before writing
formulas = {
    "F25": '=SUMPRODUCT(COUNTIF(F$4:F$23,$A$5:$A$84)*--(LOWER($C$5:$C$84)="x"))',
    "G25": '=SUMPRODUCT(COUNTIF(G$4:G$23,$A$5:$A$84)*--(LOWER($C$5:$C$84)="x"))',
    "H25": '=SUMPRODUCT(COUNTIF(H$4:H$23,$A$5:$A$84)*--(LOWER($C$5:$C$84)="x"))',
    "I25": '=SUMPRODUCT(COUNTIF(I$4:I$23,$A$5:$A$84)*--(LOWER($C$5:$C$84)="x"))',
}
for coord, formula in formulas.items():
    print("Writing", coord, "=", formula)
    ws[coord] = formula

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for ws_obj, orig_name in zip(wb_check.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    wb_check.save(outfile)
    print("Restored original sheet names:", orig_sheetnames)

# Verify formulas exist
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("Stored formulas:")
for coord in ["F25", "G25", "H25", "I25"]:
    print(coord, "formula:", wsf[coord].value)

# Verify calculated values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[orig_sheetnames[0]]
print("Calculated target cells:")
for coord in ["F25", "G25", "H25", "I25"]:
    print(coord, "value:", wsv[coord].value)

# Also compute expected counts in Python as a sanity check
mapping = {c: [ws.cell(r, col).value for r in range(4, 24)] for c, col in zip(["F","G","H","I"], range(6,10))}
yes_nums = []
for r in range(5, ws.max_row + 1):
    num = ws.cell(r, 1).value
    yes = ws.cell(r, 3).value
    if isinstance(yes, str) and yes.strip().lower() == "x":
        yes_nums.append(num)
print("Yes question numbers:", yes_nums)

for c in ["F","G","H","I"]:
    mset = set(v for v in mapping[c] if isinstance(v, (int, float)))
    cnt = sum(1 for n in yes_nums if n in mset)
    print("Python expected", c+"25", "=", cnt)
