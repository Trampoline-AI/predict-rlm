from openpyxl import load_workbook
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]
original_sheetnames = wb.sheetnames[:]

# Preserve existing target mapping inferred from neighboring formulas
target_refs = {
    7: "E31",
    8: "E31",
    9: "E31",
    10: "E31",
    11: "E31",
    12: "E32",
    13: "E33",
    14: "E34",
    15: "E35",
    16: "E35",
}

print("Before writing E7:E16:")
for r in range(7, 17):
    print(r, ws[f"C{r}"].value, ws[f"D{r}"].value, ws[f"E{r}"].value)

for r, ref in target_refs.items():
    ws[f"E{r}"] = f'=IF(OR(C{r}>1,D{r}>1),{ref},"")'

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", original_sheetnames)
    for i, name in enumerate(original_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[original_sheetnames[0]]
print("\nVerified formulas in E7:E16:")
for r in range(7, 17):
    print(r, wsf[f"E{r}"].value)

# Verify cached values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[original_sheetnames[0]]
print("\nVerified cached values in E7:E16:")
for r in range(7, 17):
    print(r, "C=", wsv[f"C{r}"].value, "D=", wsv[f"D{r}"].value, "E=", wsv[f"E{r}"].value)

output_spreadsheet = outfile
print("\nOutput ready:", output_spreadsheet)
