import os
from openpyxl import load_workbook

print("Instruction:")
print(instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def color_to_str(c):
    try:
        if c is None:
            return None
        vals = []
        for attr in ("type", "rgb", "indexed", "theme", "tint"):
            try:
                v = getattr(c, attr, None)
                if v is not None:
                    vals.append(f"{attr}={v}")
            except Exception:
                pass
        return "|".join(vals) if vals else str(c)
    except Exception:
        return str(c)

def fill_desc(cell):
    f = cell.fill
    if not f or f.fill_type is None:
        return None
    return f"fill_type={f.fill_type}; fg={color_to_str(f.fgColor)}; start={color_to_str(f.start_color)}; end={color_to_str(f.end_color)}"

for ws in wb.worksheets:
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    row1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1:", row1)
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row 2:", row2)

    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

    print("Last 5 rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

    formula_cells = []
    colored_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
            fd = fill_desc(cell)
            if fd:
                colored_cells.append((cell.coordinate, cell.value, fd))

    print("Formula cells:", formula_cells[:50])
    print("Colored cells sample:", colored_cells[:80])

    blueish = []
    greenish = []
    for coord, val, fd in colored_cells:
        t = fd.upper()
        if any(k in t for k in ["0000FF", "00B0F0", "4F81BD", "5B9BD5", "9CC2E5", "BDD7EE", "DDEBF7", "92CDDC", "000080", "BLUE"]):
            blueish.append((coord, val, fd))
