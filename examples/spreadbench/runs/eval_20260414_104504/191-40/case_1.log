import os, copy, shutil
from openpyxl import load_workbook

src = input_spreadsheet
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(src)

# Load source workbooks
wb = load_workbook(src)
wb_vals = load_workbook(src, data_only=True)
ws = wb["Sheet1"]
ws_vals = wb_vals["Sheet1"]

orig_sheet_names = wb.sheetnames[:]

def is_nonempty_row(sheet, r):
    return any(sheet.cell(r, c).value not in (None, "") for c in range(1, sheet.max_column + 1))

# detect contiguous non-empty blocks
blocks = []
in_block = False
start = None
for r in range(1, ws.max_row + 1):
    ne = is_nonempty_row(ws, r)
    if ne and not in_block:
        start = r
        in_block = True
    elif not ne and in_block:
        blocks.append((start, r - 1))
        in_block = False
if in_block:
    blocks.append((start, ws.max_row))

print("Blocks:", blocks)

# Capture source rows including values and styles
all_row_data = {}
for r in range(1, ws.max_row + 1):
    row = []
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        row.append({
            "value": cell.value,
            "font": copy.copy(cell.font),
            "fill": copy.copy(cell.fill),
            "border": copy.copy(cell.border),
            "alignment": copy.copy(cell.alignment),
            "number_format": cell.number_format,
            "protection": copy.copy(cell.protection),
        })
    all_row_data[r] = row

# Build sorted block row mappings using evaluated D
sorted_block_rows = {}
for s, e in blocks:
    rows = []
    for r in range(s, e + 1):
        d_val = ws_vals.cell(r, 4).value
        rows.append((r, float("-inf") if d_val is None else d_val))
    rows.sort(key=lambda x: x[1], reverse=True)
    sorted_block_rows[(s, e)] = [r for r, _ in rows]
    print(f"Block {s}-{e} sorted source rows:", sorted_block_rows[(s, e)])

# Start from original workbook again for safe output rewrite
wb_out = load_workbook(src)
ws_out = wb_out["Sheet1"]

# Rewrite each block in place
for s, e in blocks:
    source_rows_sorted = sorted_block_rows[(s, e)]
    for dest_r, src_r in zip(range(s, e + 1), source_rows_sorted):
        src_cells = all_row_data[src_r]
        for c in range(1, ws_out.max_column + 1):
            out_cell = ws_out.cell(dest_r, c)
            src_meta = src_cells[c - 1]

            # restore style
            out_cell.font = copy.copy(src_meta["font"])
            out_cell.fill = copy.copy(src_meta["fill"])
            out_cell.border = copy.copy(src_meta["border"])
            out_cell.alignment = copy.copy(src_meta["alignment"])
            out_cell.number_format = src_meta["number_format"]
            out_cell.protection = copy.copy(src_meta["protection"])

            # values: keep row data moved together, but rebuild formulas for destination row
            if c == 4:
                out_cell.value = f"=B{dest_r}+C{dest_r}"
            elif c == 6:
                out_cell.value = f"=D{dest_r}+E{dest_r}"
            else:
                out_cell.value = src_meta["value"]

        # enforce requested D:E:F formatting
        for c in (4, 5, 6):
            cell = ws_out.cell(dest_r, c)
            cell.font = copy.copy(cell.font)
            cell.font = cell.font.copy(bold=True)
            cell.alignment = copy.copy(cell.alignment)
            cell.alignment = cell.alignment.copy(horizontal="center")
            cell.number_format = "0.#"

# Ensure exactly one blank row between blocks
for i in range(len(blocks) - 1):
    blank_r = blocks[i][1] + 1
    for c in range(1, ws_out.max_column + 1):
        cell = ws_out.cell(blank_r, c)
        cell.value = None

# workbook calc settings
wb_out.calculation.calcMode = "auto"
wb_out.calculation.fullCalcOnLoad = True
wb_out.calculation.forceFullCalc = True

wb_out.save(out_path)
print("Saved rebuilt workbook:", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and fix sheet names if recalc changed them
wb_chk = load_workbook(out_path)
if wb_chk.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb_chk.sheetnames, "-> restoring", orig_sheet_names)
    if len(wb_chk.sheetnames) == len(orig_sheet_names):
        for i, name in enumerate(orig_sheet_names):
            wb_chk[wb_chk.sheetnames[i]].title = name
        wb_chk.save(out_path)

# Verify formulas exist in output
