import os, re, shutil
from datetime import datetime
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Find rows with any content and inspect all non-empty B values
nonempty_rows = []
for r in range(1, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v is not None for v in row_vals):
        nonempty_rows.append(r)

print("Used rows from", min(nonempty_rows), "to", max(nonempty_rows), "count", len(nonempty_rows))
print("Sample first 10 used rows:")
for r in nonempty_rows[:10]:
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
print("Sample last 5 used rows:")
for r in nonempty_rows[-5:]:
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

b_nonempty = [(r, ws.cell(r, 2).value, type(ws.cell(r, 2).value).__name__) for r in range(1, ws.max_row + 1) if ws.cell(r, 2).value is not None]
print("All non-empty B cells:")
for item in b_nonempty:
    print(item)

pattern = re.compile(r'^[A-Z]{2,3}\s?(\d+(?:\.\d+)?)$')
matches = []
nonmatches = []
for r, v, t in b_nonempty:
    if isinstance(v, str):
        m = pattern.fullmatch(v.strip())
        if m:
            matches.append((r, v, m.group(1)))
        else:
            nonmatches.append((r, v))
print("Pattern matches:", matches)
print("String nonmatches:", nonmatches)

# Apply transformation
for r, old, new in matches:
    ws.cell(r, 2).value = new

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalc:", result)

# Reload and verify
wb2 = load_workbook(out_path, data_only=False)
print("Post-recalc sheetnames:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    original_names = wb.sheetnames
    for i, name in enumerate(original_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to", original_names)

verify_wb = load_workbook(out_path, data_only=True)
vws = verify_wb["Sheet1"]
print("Verified target B cells after save/recalc:")
for r, old, new in matches:
