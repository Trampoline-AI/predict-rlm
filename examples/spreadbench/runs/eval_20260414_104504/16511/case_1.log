```repl
import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols+1)]

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows), "first/last non-empty rows:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # print first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r))
    
    # print last 5 rows
    print("Last rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r))
    
    # header candidates
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = row_values(ws, r)
        print(f"Header candidate row {r}:", vals)
    
    # print formulas found in first 30 rows
    formulas = []
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first 30 rows:", formulas[:20], "count:", len(formulas))
