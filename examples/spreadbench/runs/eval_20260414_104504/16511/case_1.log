Code:
```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string, get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Re-open for inspection of exact target cells
wb = load_workbook(infile)
ws = wb["Sheet1"]

print("Sheet names before:", wb.sheetnames)
print("Column D header:", ws["D1"].value, "col idx", column_index_from_string("D"))
print("Column E header:", ws["E1"].value, "col idx", column_index_from_string("E"))
print("Column F header:", ws["F1"].value, "col idx", column_index_from_string("F"))

print("Relevant rows before modification:")
for r in range(2, ws.max_row + 1):
    print(r, {"Album": ws[f"D{r}"].value, "Song": ws[f"E{r}"].value, "TrackNo": ws[f"F{r}"].value})

# Fill missing track numbers with formulas in existing Track No column
written = []
for r in range(2, ws.max_row + 1):
    album = ws[f"D{r}"].value
    song = ws[f"E{r}"].value
    cell = ws[f"F{r}"]
    if album not in (None, "") and song not in (None, "") and cell.value in (None, ""):
        if r == 2:
            formula = "=1"
        else:
            formula = f'=IF(D{r}=D{r-1},F{r-1}+1,1)'
        cell.value = formula
        written.append((cell.coordinate, formula))

print("Written formulas:", written)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalc to verify sheet names and values
wb_check = load_workbook(outfile)
orig_names = ["Sheet1"]
print("Sheet names after recalc/reload:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    # rename back if needed
    for i, expected in enumerate(orig_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Renamed sheets back to:", wb_check.sheetnames)

wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("Verification of target cells F2:F10:")
for r in range(2, ws_values.max_row + 1):
    print(
        r,
        {
            "Album": ws_values[f"D{r}"].value,
            "FormulaInF": ws_formula[f"F{r}"].value,
            "ValueInF": ws_values[f"F{r}"].value,
        },
    )

output_spreadsheet = outfile
```
