import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Determine last non-empty row and last client row in col A
last_nonempty = 0
last_client_row = 0
for r in range(1, ws.max_row + 1):
    row_has_data = any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1))
    if row_has_data:
        last_nonempty = r
    if ws.cell(r, 1).value not in (None, ""):
        last_client_row = r

print("last_nonempty:", last_nonempty, "last_client_row:", last_client_row)

# Print tail rows exactly, especially 17:20
print("\nRows 17:20 key columns:")
for r in range(17, min(last_nonempty, 20) + 1):
    vals = {col: ws[f"{col}{r}"].value for col in ["A","B","F","G","O","P","S","V"]}
    print(r, vals)

# Compute expected first exact match in Python for rows with clients in A
print("\nPython-checked expected matches for rows 2:16:")
expected = {}
for r in range(2, last_client_row + 1):
    a = ws[f"A{r}"].value
    f = ws[f"F{r}"].value
    g = ws[f"G{r}"].value
    match_desc = None
    match_row = None
    for rr in range(2, last_nonempty + 1):
        if ws[f"S{rr}"].value == a and ws[f"O{rr}"].value == f and ws[f"P{rr}"].value == g:
            match_desc = ws[f"V{rr}"].value
            match_row = rr
            break
    expected[r] = (match_desc, match_row)
    print(r, {"A": a, "F": f, "G": g, "expected_B": match_desc, "source_row": match_row})

# Write formulas only into existing client rows with column A populated, column B target
for r in range(2, last_client_row + 1):
    if ws.cell(r, 1).value in (None, ""):
        continue
    formula = (
        f'=IFERROR(INDEX($V$2:$V${last_nonempty},'
        f'MATCH(1,($S$2:$S${last_nonempty}=A{r})*($O$2:$O${last_nonempty}=F{r})*($P$2:$P${last_nonempty}=G{r}),0)),'
        f'""'
        f')'
    )
    print(f"Writing B{r}: {formula}")
    ws[f"B{r}"] = formula

# Save output
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload after recalc; restore sheet name if needed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"]:
    ws_tmp = wb2[wb2.sheetnames[0]]
    ws_tmp.title = "Sheet1"
    wb2.save(out_path)
    print("Renamed sheet back to Sheet1")

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
print("\nVerified B2:B16 values after recalc:")
for r in range(2, last_client_row + 1):
    print(r, {
        "A": wsv[f"A{r}"].value,
        "F": wsv[f"F{r}"].value,
        "G": wsv[f"G{r}"].value,
        "B": wsv[f"B{r}"].value,
        "expected": expected[r][0],
    })

output_spreadsheet = out_path
