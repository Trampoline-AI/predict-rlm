import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect current target range A:B before modification
print("Before fill, rows 14-30 A/B:")
for r in range(14, ws.max_row + 1):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

# Fill column B based on closest non-blank cell above in column A
last_seen = None
for r in range(2, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    b_cell = ws.cell(r, 2)

    if a_val not in (None, ""):
        last_seen = a_val
        # keep existing correct examples; write if blank or different
        if b_cell.value in (None, ""):
            b_cell.value = a_val
    else:
        if last_seen is not None and b_cell.value in (None, ""):
            b_cell.value = last_seen

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # rename in order
    for i, sname in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = sname
    wb_check.save(outfile)

# Verify with data_only and formula view
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]

print("After fill, rows 14-30 A/B:")
for r in range(14, wsv.max_row + 1):
    print(r, wsv[f"A{r}"].value, wsv[f"B{r}"].value)

# Full target verification summary
missing = []
for r in range(2, wsv.max_row + 1):
    if wsv[f"B{r}"].value in (None, ""):
        missing.append(r)
print("Blank B rows after fill:", missing)

output_spreadsheet = outfile
