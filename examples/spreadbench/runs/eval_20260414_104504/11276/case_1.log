Code:
```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)
shutil.copy(infile, outfile)

# Load and modify
wb = load_workbook(outfile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["ATTENDENCE"]

# Print current target area before writing
print("Before writing F3:AJ3 formulas/values:")
for c in range(6, 37):
    print(get_column_letter(c), ws.cell(3, c).value, " / below:", ws.cell(4, c).value)

# Apply weekday formula across F3:AJ3
for c in range(6, 37):
    col = get_column_letter(c)
    ws.cell(3, c).value = f'=TEXT({col}4,"DDD")'

print("\nAfter writing formulas F3:AJ3:")
for c in range(6, 37):
    print(get_column_letter(c), ws.cell(3, c).value)

wb.save(outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("\nRecalc:", recalc_result)

# Restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
else:
    print("Sheet names unchanged after recalc.")

# Verify using data_only workbook
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[orig_sheetnames[0]]

print("\nVerified F3:AJ3 cached values:")
vals = []
for c in range(6, 37):
    addr = f"{get_column_letter(c)}3"
    val = vws[addr].value
    vals.append((addr, val))
print(vals)

# Sanity-check no blanks in target range
blanks = [addr for addr, val in vals if val in (None, "")]
print("Blank targets:", blanks)

output_spreadsheet = outfile
print("Output file:", output_spreadsheet)
```
