import os, shutil
from openpyxl import load_workbook

# Re-open to inspect formatting and target cells more closely
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
orig_sheet_names = wb.sheetnames[:]

print("Detailed target inspection:")
for cell_ref in ["A2","B2","C2","A3","B3","C3"]:
    cell = ws[cell_ref]
    print(cell_ref, "value=", cell.value, "number_format=", cell.number_format)

# Write formulas into target column C for actual data rows (2..max_row)
for r in range(2, ws.max_row + 1):
    a = f"A{r}"
    b = f"B{r}"
    c = f"C{r}"
    print("Before", c, "=", ws[c].value)
    ws[c] = f'=IF(AND({a}<>"",{b}<>""),{a}+{b},"")'
    # Match date/time style from source date column if available
    ws[c].number_format = ws[a].number_format

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc; rename back if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for old, new in zip(orig_sheet_names, wb_after.sheetnames):
        if old != new:
            wb_after[new].title = old
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with formulas view and data_only view
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("Formulas written:")
for r in range(2, wsf.max_row + 1):
    print(f"C{r} formula:", wsf[f"C{r}"].value, "numfmt:", wsf[f'C{r}'].number_format)

wb_data = load_workbook(out_path, data_only=True)
wsd = wb_data[orig_sheet_names[0]]
print("Verified cached values:")
for r in range(2, wsd.max_row + 1):
