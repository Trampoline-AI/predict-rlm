from openpyxl import load_workbook
import os

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

# Rebuild with bounded ranges and verify
wb = load_workbook(input_spreadsheet)
ws = wb["Daily Numbers"]
err = wb["Errors"]

err_last = err.max_row
print("Errors last row:", err_last)

for r in range(3, ws.max_row + 1):
    if ws[f"A{r}"].value in (None, "") or ws[f"L{r}"].value in (None, ""):
        continue
    user_or = (
        f'((Errors!$AB$2:$AB${err_last}=$G{r})+'
        f'(Errors!$AB$2:$AB${err_last}=$H{r})+'
        f'(Errors!$AB$2:$AB${err_last}=$I{r})+'
        f'(Errors!$AB$2:$AB${err_last}=$J{r})>0)'
    )
    common = (
        f'(Errors!$I$2:$I${err_last}=$A{r})*'
        f'(Errors!$Q$2:$Q${err_last}=$L{r})*'
        f'{user_or}'
    )
    ws[f"N{r}"] = f'=SUMPRODUCT({common}*(Errors!$B$2:$B${err_last}=$B{r})*Errors!$M$2:$M${err_last})'
    ws[f"O{r}"] = f'=SUMPRODUCT({common}*(Errors!$B$2:$B${err_last}=$C{r})*(Errors!$M$2:$M${err_last}>0)*Errors!$M$2:$M${err_last})'
    ws[f"P{r}"] = f'=SUMPRODUCT({common}*(Errors!$B$2:$B${err_last}=$D{r})*Errors!$M$2:$M${err_last})'
    ws[f"Q{r}"] = f'=SUMPRODUCT({common}*(Errors!$B$2:$B${err_last}=$E{r})*Errors!$M$2:$M${err_last})'
    ws[f"R{r}"] = f'=SUMPRODUCT({common}*(Errors!$B$2:$B${err_last}=$F{r})*Errors!$M$2:$M${err_last})'

wb.save(out_path)
print("Saved:", out_path)

res = await recalculate(out_path)
print("Recalc:", res)

# restore original sheet names if needed
orig_names = ['Daily Numbers', 'Inbound Receipts', 'Errors']
wb_chk = load_workbook(out_path)
if wb_chk.sheetnames != orig_names and len(wb_chk.sheetnames) == len(orig_names):
    for s, name in zip(wb_chk.worksheets, orig_names):
        s.title = name
    wb_chk.save(out_path)
    print("Restored sheet names:", wb_chk.sheetnames)
else:
    print("Sheet names ok:", wb_chk.sheetnames)

# verify formulas and cached values
fwb = load_workbook(out_path, data_only=False)
vwb = load_workbook(out_path, data_only=True)
fws = fwb["Daily Numbers"]
vws = vwb["Daily Numbers"]

print("Sample target formulas:")
for coord in ["N3","O3","P3","Q3","R3","N24","O24","P24","Q24","R24"]:
    print(coord, "=", fws[coord].value)

print("Sample cached values:")
for coord in ["M3","N3","O3","P3","Q3","R3","M24","N24","O24","P24","Q24","R24"]:
    print(coord, "=", vws[coord].value)

output_spreadsheet = out_path
