from openpyxl import load_workbook
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Verify target cells and current contents/formulas in A:C and F
print("Before modification:")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

for col in range(1, 4):
    for r in range(2, ws.max_row + 1):
        cell = ws.cell(r, col)
        if isinstance(cell.value, str) and cell.value.startswith("="):
            print("Existing formula in", cell.coordinate, cell.value)

filter_vals = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 6).value
    if v not in (None, ""):
        filter_vals.append(str(v).strip())
filter_set = set(filter_vals)
print("Filter list values:", filter_vals)

source_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    if a in (None, "") and b in (None, "") and c in (None, ""):
        status = "blank A:C row"
    else:
        status = "KEEP" if str(a).strip() in filter_set else "REMOVE"
    print(f"Row {r}: A:C={[a,b,c]} => {status}")
    if not (a in (None, "") and b in (None, "") and c in (None, "")) and str(a).strip() in filter_set:
        source_rows.append((a, b, c))

print("Rows to keep/compact:", source_rows)

# Write compacted kept rows into A:C starting row 2
write_row = 2
for a, b, c in source_rows:
    ws.cell(write_row, 1).value = a
    ws.cell(write_row, 2).value = b
    ws.cell(write_row, 3).value = c
    write_row += 1

# Clear remaining A:C only
for r in range(write_row, ws.max_row + 1):
    for c in range(1, 4):
        ws.cell(r, c).value = None

# Preserve/restore autofilter
ws.auto_filter.ref = f"A1:C{ws.max_row}"

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and verify
wb2 = load_workbook(outfile, data_only=False)
print("Post-save sheet names:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"]:
    ws_tmp = wb2[wb2.sheetnames[0]]
    ws_tmp.title = "Sheet1"
    wb2.save(outfile)
    print("Renamed sheet back to Sheet1")

wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]
print("Verification A:F:")
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 7)])
print("Verified AutoFilter ref:", wb2["Sheet1"].auto_filter.ref)

output_spreadsheet = outfile
```
