```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from datetime import datetime
import os, shutil
from collections import defaultdict

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Inspect all source data rows A:D and summary area G:K")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 12)]
    print(r, vals)

# Print target cells and current formulas/values
print("\nTarget headers G1:K1:", [ws.cell(1, c).value for c in range(7, 12)])
for r in range(2, 7):
    print(f"Row {r} summary before:", [ws.cell(r, c).value for c in range(7, 12)])

# Compute expected counts in Python for sanity check
month_specs = [
    ("I", datetime(2022,5,1), datetime(2022,5,31), "May 2022"),
    ("J", datetime(2022,6,1), datetime(2022,6,30), "Jun 2022"),
    ("K", datetime(2022,7,1), datetime(2022,7,31), "Jul 2022"),
]
expected = defaultdict(dict)

for r in range(2, ws.max_row + 1):
    dept = ws[f"B{r}"].value
    created = ws[f"C{r}"].value
    closed = ws[f"D{r}"].value
    if not dept:
        continue
    for col, month_start, month_end, label in month_specs:
        open_eom = (created is not None and created <= month_end) and (closed is None or closed >= month_start)
        expected[dept][label] = expected[dept].get(label, 0) + (1 if open_eom else 0)

print("\nExpected counts by department:")
for r in range(2, 7):
    dept = ws[f"G{r}"].value
    print(dept, expected.get(dept, {}))

# Write formulas to I:K for rows with department names in G
for r in range(2, ws.max_row + 1):
    dept = ws[f"G{r}"].value
    if dept in (None, ""):
        continue
    ws[f"I{r}"] = f'=COUNTIFS($B$2:$B$12,G{r},$C$2:$C$12,"<="&DATE(2022,5,31),$D$2:$D$12,">="&DATE(2022,5,1))+COUNTIFS($B$2:$B$12,G{r},$C$2:$C$12,"<="&DATE(2022,5,31),$D$2:$D$12,"")'
    ws[f"J{r}"] = f'=COUNTIFS($B$2:$B$12,G{r},$C$2:$C$12,"<="&DATE(2022,6,30),$D$2:$D$12,">="&DATE(2022,6,1))+COUNTIFS($B$2:$B$12,G{r},$C$2:$C$12,"<="&DATE(2022,6,30),$D$2:$D$12,"")'
    ws[f"K{r}"] = f'=COUNTIFS($B$2:$B$12,G{r},$C$2:$C$12,"<="&DATE(2022,7,31),$D$2:$D$12,">="&DATE(2022,7,1))+COUNTIFS($B$2:$B$12,G{r},$C$2:$C$12,"<="&DATE(2022,7,31),$D$2:$D$12,"")'

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to", out_path)

recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and fix sheet names if recalc changed them
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)

# Verify with data_only=True
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("\nVerified target range G1:K6 after recalc:")
for r in range(1, 7):
    print(r, [vws.cell(r, c).value for c in range(7, 12)])

output_spreadsheet = out_path
```
