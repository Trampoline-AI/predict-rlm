Code:
```repl
import os, re, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before:")
before_vals = [ws.cell(1, c).value for c in range(1, 9)]
print(before_vals)

for c in range(1, 9):
    cell = ws.cell(1, c)
    val = cell.value
    if isinstance(val, str):
        cleaned = re.sub(r"[^0-9.]", "", val)
        cell.value = cleaned
    else:
        # preserve existing numeric values
        cell.value = val

print("After write (in-memory):")
after_vals = [ws.cell(1, c).value for c in range(1, 9)]
print(after_vals)

wb.save(outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_chk = load_workbook(outfile)
if wb_chk.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_chk.sheetnames, "-> restoring", orig_sheetnames)
    for i, expected in enumerate(orig_sheetnames):
        wb_chk.worksheets[i].title = expected
    wb_chk.save(outfile)
    wb_chk = load_workbook(outfile)

print("Final sheet names:", wb_chk.sheetnames)

# Verify final values
wb_data = load_workbook(outfile, data_only=True)
ws_data = wb_data["Sheet1"]
verified = [ws_data.cell(1, c).value for c in range(1, 9)]
print("Verified Sheet1!A1:H1:", verified)

output_spreadsheet = outfile
```
