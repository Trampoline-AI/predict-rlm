def sheet_info(ws):
    rows = ws.max_row
    cols = ws.max_column
    headers = [ws.cell(1,c).value for c in range(1, cols+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", rows, "max_column:", cols)
    print("Headers row 1:", headers)
    # first 10 rows
