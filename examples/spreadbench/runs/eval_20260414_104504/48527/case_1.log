import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Inspect current target formulas/values in D
print("Pre-write D values/formulas:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"D{r}"].value)

# Row-wise logic:
# if col A == col B, then put unique values from col C into col D, but only fill blanks.
seen = set()
qualifying = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    if a == b and c not in (None, "") and c not in seen:
        qualifying.append((r, c, d))
        seen.add(c)

print("Qualifying rows/values:", qualifying)

for r, cval, dval in qualifying:
    if dval in (None, ""):
        ws.cell(r, 4).value = cval

wb.save(outfile)
print("Saved:", outfile)

# recalc and restore sheet names if needed
