Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Verify exact target area and existing values/formulas
print("Target/date cells:")
for addr in ["E3","E4","F4","H3","I3","H4","I4","H5","I5","H6","I6","H7","I7"]:
    print(addr, repr(ws[addr].value))

# Compute expected example results in Python to confirm pattern
start_date = ws["E4"].value
end_date = ws["F4"].value
data_rows = []
for r in range(3, ws.max_row + 1):
    data_rows.append((r, ws.cell(r,1).value, ws.cell(r,2).value, ws.cell(r,3).value))

print("\nPython check for example terms:")
for term_cell in ["H4","H5","H6","H7"]:
    term = ws[term_cell].value
    total = 0
    matches = []
    for r, dt, fabric, units in data_rows:
        if dt is not None and fabric and units is not None and start_date <= dt <= end_date and term in str(fabric):
            total += units
            matches.append((r, dt.date().isoformat(), fabric, units))
    print(term_cell, term, "->", total, "matches:", matches)

# Write formulas to I for all non-empty terms in column H
last_data_row = ws.max_row
for r in range(4, ws.max_row + 1):
    term = ws.cell(r, 8).value  # H
    if term not in (None, ""):
        formula = (
            f'=SUMPRODUCT(($A$3:$A${last_data_row}>=$E$4)*'
            f'($A$3:$A${last_data_row}<=$F$4)*'
            f'(ISNUMBER(SEARCH(H{r},$B$3:$B${last_data_row})))*'
            f'($C$3:$C${last_data_row}))'
        )
        print(f"Writing I{r} formula:", formula)
        ws.cell(r, 9).value = formula  # I

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore sheet names if recalculation changed them
orig_names = wb.sheetnames[:]
wb_after = load_workbook(out_path)
if wb_after.sheetnames != orig_names:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)

# Verify output with cached values
check_wb = load_workbook(out_path, data_only=False)
check_vals = load_workbook(out_path, data_only=True)
wsf = check_wb[orig_names[0]]
wsv = check_vals[orig_names[0]]

print("\nVerification target cells/formulas:")
for r in range(4, 8):
    print(
        f"H{r}=", repr(wsv[f"H{r}"].value),
        f"I{r}_formula=", repr(wsf[f"I{r}"].value),
        f"I{r}_value=", repr(wsv[f"I{r}"].value)
    )

output_spreadsheet = out_path
```
