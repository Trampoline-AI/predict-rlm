import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print existing target formulas before change
print("Before change:")
for r in [4,5,6,10,71,75]:
    print(r, ws[f"U{r}"].value)

# Fix formulas in-place for all relevant rows with criteria in R,S,T and source ranges A:B, C:M
for r in range(4, ws.max_row + 1):
    if any(ws[f"{col}{r}"].value not in (None, "") for col in ["R","S","T"]):
        ws[f"U{r}"] = f'=SUMPRODUCT(($A$4:$A$75=$R{r})*($B$4:$B$75=$S{r})*($C$3:$M$3=$T{r}),$C$4:$M$75)'

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Restored sheet names:", wb_check.sheetnames)
else:
    print("Sheet names after recalc:", wb_check.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[original_sheetnames[0]]
print("After change formulas:")
for r in [4,5,6,10,71,75]:
    print(r, wsf[f"U{r}"].value)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[original_sheetnames[0]]
print("Verified values U4:U10 and tail:")
for r in list(range(4, 11)) + [71,72,73,74,75]:
    print(r, "R,S,T,U =", wsv[f"R{r}"].value, wsv[f"S{r}"].value, wsv[f"T{r}"].value, wsv[f"U{r}"].value)

output_spreadsheet = outfile
