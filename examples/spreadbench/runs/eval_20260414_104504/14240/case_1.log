from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
print("Sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row2 values:", headers2)
    # print first 10 rows and last 5 rows
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end + 1):
        print(r, row_vals(r))
    print("Last rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        print(r, row_vals(r))

    # print relevant cells and formulas in area P:U and maybe surrounding rows
    print("Relevant area P1:U10")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = []
        for c in range(16, min(21, ws.max_column) + 1):
            cell = ws.cell(r, c)
            vals.append(f"{get_column_letter(c)}{r}={cell.value}")
        print(" | ".join(vals))
