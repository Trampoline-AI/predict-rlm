import os
from openpyxl import load_workbook

# Load fresh workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Opportunities"]
dws = wb["Data"]

# Reconfirm relevant source/target areas
print("Opportunities headers:", [ws.cell(1, c).value for c in range(1, 8)])
print("Data mapping rows:")
for r in range(1, 7):
    print(r, dws[f"A{r}"].value, dws[f"B{r}"].value)

# Identify actual rows needing output in Opportunities
target_rows = []
for r in range(2, ws.max_row + 1):
    d = ws[f"D{r}"].value
    e = ws[f"E{r}"].value
    if d not in (None, "") or e not in (None, ""):
        target_rows.append(r)

print("Target rows:", target_rows)
print("Before write:")
for r in target_rows:
    print(r, {"F": ws[f"F{r}"].value, "G": ws[f"G{r}"].value, "D": ws[f"D{r}"].value, "E": ws[f"E{r}"].value})

# Write formulas
lookup_range = "Data!$A$1:$B$6"
for r in target_rows:
    if ws[f"F{r}"].value in (None, ""):
        ws[f"F{r}"] = f'=IF(D{r}="","",IFERROR(VLOOKUP(D{r},{lookup_range},2,FALSE),""))'
    if ws[f"G{r}"].value in (None, ""):
        ws[f"G{r}"] = f'=IF(OR(D{r}="",E{r}=""),"",IFERROR(E{r}*VLOOKUP(D{r},{lookup_range},2,FALSE),""))'

print("After write formulas:")
for r in target_rows:
    print(r, {"F": ws[f"F{r}"].value, "G": ws[f"G{r}"].value})

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore original sheet names if needed
orig_names = ['Accountants', 'Lawyers', 'IT', 'Inflexion', 'Accountants Info', 'Sheet3', 'Opportunities', 'Data']
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names and len(wb_check.sheetnames) == len(orig_names):
    for i, nm in enumerate(orig_names):
        wb_check.worksheets[i].title = nm
    wb_check.save(out_path)
    print("Restored sheet names:", wb_check.sheetnames)

# Verify formulas and calculated values
wb_formula = load_workbook(out_path, data_only=False)
wf = wb_formula["Opportunities"]
wb_values = load_workbook(out_path, data_only=True)
wv = wb_values["Opportunities"]

print("Verification of target cells:")
for r in target_rows:
    print(
        r,
        {
            "formula_F": wf[f"F{r}"].value,
            "formula_G": wf[f"G{r}"].value,
            "value_F": wv[f"F{r}"].value,
