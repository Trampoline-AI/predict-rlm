import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Determine target column and compute outputs
headers = [str(ws.cell(1, c).value).strip() if ws.cell(1, c).value is not None else "" for c in range(1, 7)]
print("Using headers A1:F1 ->", headers)
print("Target column:", ws["G1"].coordinate, "header=", ws["G1"].value)

# Preserve formatting from an existing G cell
style_src = ws["G2"]

for r in range(2, ws.max_row + 1):
    parts = []
    for c in range(1, 7):
        v = ws.cell(r, c).value
        if isinstance(v, str) and v.strip().upper() == "Y":
            parts.append(headers[c - 1])
    joined = ", ".join(parts)
    ws.cell(r, 7).value = joined
    # keep formatting consistent
    tgt = ws.cell(r, 7)
    if r != 2:
        tgt.font = copy(style_src.font)
        tgt.fill = copy(style_src.fill)
        tgt.border = copy(style_src.border)
        tgt.alignment = copy(style_src.alignment)
        tgt.number_format = style_src.number_format
        tgt.protection = copy(style_src.protection)

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for old, new in zip(orig_sheetnames, wb_check.sheetnames):
        wb_check[new].title = old
    wb_check.save(outfile)
    print("Restored sheet names:", orig_sheetnames)
else:
    print("Sheet names after recalc:", wb_check.sheetnames)

# Verify output values
wb_data = load_workbook(outfile, data_only=True)
wsd = wb_data[orig_sheetnames[0]]
print("Verified G2:G14:")
for r in range(2, wsd.max_row + 1):
    print(r, repr(wsd.cell(r, 7).value))

output_spreadsheet = outfile
```
