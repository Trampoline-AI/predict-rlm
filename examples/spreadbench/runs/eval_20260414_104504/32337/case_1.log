# 1) Fill Expected Result in E using age(year) in O looked up against H:I
for r in range(3, ws.max_row + 1):
    # Only for data rows with a DOB/name
    if ws.cell(r, 1).value is not None or ws.cell(r, 3).value is not None:
        ws.cell(r, 5).value = f'=IFERROR(INDEX($I$3:$I$11,MATCH(O{r},$H$3:$H$11,0)),"")'

# 2) Ensure O contains the rounded age(year) formula for all data rows
for r in range(3, ws.max_row + 1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 3).value is not None:
        ws.cell(r, 15).value = f'=ROUND(($B$1-C{r})/365,0)'

# 3) Add Actual Age in the next column after age (year): P
ws.cell(2, 16).value = "Actual Age"
for r in range(3, ws.max_row + 1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 3).value is not None:
        ws.cell(r, 16).value = f'=ROUND(($B$1-C{r})/365,0)'

# Copy fill colors from preceding column O to P, and format P as requested
# Header
ws["P2"].fill = copy(ws["O2"].fill)
ws["P2"].font = copy(ws["P2"].font)
ws["P2"].font = ws["P2"].font.copy(bold=True) if hasattr(ws["P2"].font, "copy") else copy(ws["P2"].font)
# safer explicit font copy
