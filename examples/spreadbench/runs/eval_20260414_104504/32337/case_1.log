        "numfmt=", cell.number_format
    )

# Compute current age estimates to verify category mapping
report_date = ws["B1"].value
print("Report date B1:", report_date)

computed = []
for r in range(3, ws.max_row + 1):
    dob = ws.cell(r, 3).value
    if dob:
        age_frac = (report_date - dob).days / 365
        age_round = round(age_frac)
        computed.append((r, dob.date() if hasattr(dob, "date") else dob, age_frac, age_round, ws.cell(r,8).value, ws.cell(r,9).value, ws.cell(r,5).value))
print("Computed row / DOB / frac / round / H / I / E")
for row in computed:
    print(row)

# Build/modify workbook
