from openpyxl import load_workbook
from collections import defaultdict
from datetime import datetime
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["SwiftMD"]

# Identify header row/columns exactly
header_row = 2
headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
print("Headers:")
for c, h in enumerate(headers, start=1):
    print(c, get_column_letter(c), repr(h))

header_map = {str(ws.cell(header_row, c).value).strip().lower(): c for c in range(1, ws.max_column + 1) if ws.cell(header_row, c).value is not None}
cols = {
    "last name": header_map["last name"],
    "first name": header_map["first name"],
    "date of birth": header_map["date of birth"],
    "duplicate?": header_map["duplicate?"],
    "relationship": header_map["relationship"],
}
print("Relevant columns:", {k: (v, get_column_letter(v)) for k, v in cols.items()})

def norm_date(v):
    if isinstance(v, datetime):
        return v.date().isoformat()
    return str(v).strip()

rows_yes = []
groups = defaultdict(list)
for r in range(header_row + 1, ws.max_row + 1):
    dup = ws.cell(r, cols["duplicate?"]).value
    if str(dup).strip().lower() == "yes":
        key = (
            str(ws.cell(r, cols["last name"]).value).strip(),
            str(ws.cell(r, cols["first name"]).value).strip(),
            norm_date(ws.cell(r, cols["date of birth"]).value),
        )
        rel = str(ws.cell(r, cols["relationship"]).value).strip()
        rec = {"row": r, "key": key, "relationship": rel}
        rows_yes.append(rec)
        groups[key].append(rec)

print(f"Total rows with Duplicate?='Yes': {len(rows_yes)}")
print("All duplicate-marked groups:")
for key, items in groups.items():
    rels = [x["relationship"] for x in items]
    print(key, "rows", [x["row"] for x in items], "relationships", rels)

# Determine delete candidates: group size >=2 and NO relationship == Employee
delete_rows = []
print("\nGroups eligible for deleting one entry:")
for key, items in groups.items():
    rels = [x["relationship"] for x in items]
    has_employee = any(rel.lower() == "employee" for rel in rels)
    if len(items) >= 2 and not has_employee:
        print("ELIGIBLE", key, "rows", [x["row"] for x in items], "relationships", rels)
        delete_rows.append(items[-1]["row"])  # delete one entry only, choose later row
    else:
        print("KEEP ALL", key, "rows", [x["row"] for x in items], "relationships", rels)

print("Rows to delete:", delete_rows)

# Perform deletion bottom-up
for r in sorted(delete_rows, reverse=True):
    ws.delete_rows(r, 1)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

res = await recalculate(out_path)
print("Recalculate:", res)

# restore original sheet names if needed
