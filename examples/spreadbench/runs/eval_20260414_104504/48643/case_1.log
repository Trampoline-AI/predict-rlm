import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print("\nSHEET", s, "max_row", ws.max_row, "max_col", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        print("Header row 2:", row_values(ws, 2, ws.max_column))
    # print column letters and first 3 rows
    print("Columns:", [(get_column_letter(c), ws.cell(1,c).value) for c in range(1, ws.max_column+1)])
    sample_first = list(range(1, min(ws.max_row, 10)+1))
    sample_last = list(range(max(1, ws.max_row-4), ws.max_row+1))
    print("First rows:")
    for r in sample_first:
        print(r, row_values(ws, r, ws.max_column))
    print("Last rows:")
    for r in sample_last:
        print(r, row_values(ws, r, ws.max_column))
    # print formulas present
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formulas[:50], "count", len(formulas))
