wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1 headers/values:", headers1)
    if any(v is not None for v in headers2):
        print("Row2 sample:", headers2)

    # first 10 rows
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)), "...")

    # last 5 rows
    print("Last 5 rows:")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)), "...")

    # inspect columns around T, CB, CC, CD if present
    for col in ["T", "CB", "CC", "CD"]:
        idx = column_index_from_string(col)
        if idx <= ws.max_column:
            print(f"Column {col} row1-5 values:", [ws[f"{col}{r}"].value for r in range(1, min(6, ws.max_row+1))])
            print(f"Column {col} last5 values:", [ws[f"{col}{r}"].value for r in range(max(1, ws.max_row-4), ws.max_row+1)])

    # print area around target columns for first 15 and last 10 rows
    start = column_index_from_string("T")
    end = min(ws.max_column, column_index_from_string("CD"))
    if start <= ws.max_column:
        cols = list(range(start, end+1))
        print("Columns T:CD letters:", [get_column_letter(c) for c in cols])
        print("Rows 1-15 for T:CD:")
        for r in range(1, min(15, ws.max_row)+1):
            vals = [ws.cell(r, c).value for c in cols]
            print(r, vals)
        print("Last 10 rows for T:CD:")
        for r in range(max(1, ws.max_row-9), ws.max_row+1):
            vals = [ws.cell(r, c).value for c in cols]
            print(r, vals)

    # identify any formulas in target columns
    for col in ["CB", "CC", "CD"]:
        idx = column_index_from_string(col)
        if idx <= ws.max_column:
            formula_rows = []
            for r in range(1, ws.max_row+1):
                v = ws.cell(r, idx).value
                if isinstance(v, str) and v.startswith("="):
                    formula_rows.append((r, v))
                    if len(formula_rows) >= 10:
                        break
            print(f"First formulas in {col}:", formula_rows)
