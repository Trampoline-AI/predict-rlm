import os, math, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Fresh load
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# data_only workbook to read evaluated source values and evaluated AF names
wbv = load_workbook(infile, data_only=True)
wsv = wbv[wbv.sheetnames[0]]

orig_sheet_names = wb.sheetnames[:]

# Identify target Triple Score output rows from CA labels
target_rows = []
for r in range(2, ws.max_row + 1):
    ca = ws[f"CA{r}"].value
    if isinstance(ca, str) and ca.startswith("Triple Score #"):
        target_rows.append(r)
print("Triple Score target rows:", target_rows[:5], "...", target_rows[-5:], "count=", len(target_rows))

# Build position->full name mapping from AG/AF using cached values where possible
pos_to_name = {}
for r in range(2, ws.max_row + 1):
    pos = wsv[f"AG{r}"].value
    name = wsv[f"AF{r}"].value
    if isinstance(pos, (int, float)) and name not in (None, ""):
        pos_to_name[int(pos)] = str(name).strip()

print("Sample pos_to_name:", list(pos_to_name.items())[:10])

# Read actual triple scores from source column T, only positive/numeric entries
triple_rows = []
for r in range(2, min(ws.max_row, 600) + 1):
    val = wsv[f"T{r}"].value
    if isinstance(val, (int, float)) and val != 0:
        triple_rows.append((r, val))

# Sort largest to smallest, ties by source row ascending to mimic SMALL(IF(...),COUNTIF(...))
triple_rows_sorted = sorted(triple_rows, key=lambda x: (-x[1], x[0]))
print("Sorted triple rows:", triple_rows_sorted[:20], "count=", len(triple_rows_sorted))

# Write results into existing Triple Score columns
for idx, r in enumerate(target_rows):
    if idx < len(triple_rows_sorted):
        src_row, score = triple_rows_sorted[idx]
        position = math.ceil(src_row / 21)
        fullname = pos_to_name.get(position, "")
        ws[f"CB{r}"] = score
        ws[f"CC{r}"] = src_row
        ws[f"CD{r}"] = position
        ws[f"CE{r}"] = fullname
    else:
        # clear unused rows in the target result area
        ws[f"CB{r}"] = None
        ws[f"CC{r}"] = None
        ws[f"CD{r}"] = None
        ws[f"CE{r}"] = None

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalc and restore sheet names if LibreOffice changed them
wb_chk = load_workbook(outfile)
if wb_chk.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb_chk.sheetnames, "-> restoring", orig_sheet_names)
    # rename by position
    for i, name in enumerate(orig_sheet_names):
        wb_chk.worksheets[i].title = name
    wb_chk.save(outfile)

# Verify data_only values in targets
wb_final = load_workbook(outfile, data_only=True)
wsf = wb_final[orig_sheet_names[0]]

print("\nVerified target rows 2:15 in CA:CE")
for r in target_rows[:14]:
    print(r, {c: wsf[f"{c}{r}"].value for c in ["CA","CB","CC","CD","CE"]})

print("\nVerified all populated Triple Score rows:")
verified = []
for r in target_rows:
    vals = (wsf[f"CB{r}"].value, wsf[f"CC{r}"].value, wsf[f"CD{r}"].value, wsf[f"CE{r}"].value)
    verified.append((r, vals))
print(verified[:10], "...", verified[-10:])

# Basic sanity checks
nonblank_targets = [r for r in target_rows if wsf[f"CB{r}"].value not in (None, "")]
print("Nonblank Triple Score output rows:", nonblank_targets)
print("Count nonblank:", len(nonblank_targets), "expected:", len(triple_rows_sorted))

output_spreadsheet = outfile
