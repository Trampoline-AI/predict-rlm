import os, shutil
from openpyxl import load_workbook

# Reload for clean edit
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]
original_sheet_names = wb.sheetnames[:]

print("Pre-write target area F3:H6:")
for r in range(3, 7):
    print(r, [ws.cell(r, c).value for c in range(6, 9)])

# Write formulas into existing target cells, preserving headers in row 3.
# Use INDEX/SMALL/IF with bounded ranges, LibreOffice-compatible.
for r in range(4, 7):
    k = r - 3  # 1,2,3 nth lighting row
    row_formula_part = f'SMALL(IF($B$4:$B$13="Lighting",ROW($B$4:$B$13)),{k})-ROW($B$4)+1'
    ws[f"F{r}"] = f'=IFERROR(INDEX($B$4:$B$13,{row_formula_part}),"")'
    ws[f"G{r}"] = f'=IFERROR(INDEX($C$4:$C$13,{row_formula_part}),"")'
    ws[f"H{r}"] = f'=IFERROR(INDEX($D$4:$D$13,{row_formula_part}),"")'

print("\nWritten formulas:")
for r in range(4, 7):
    print(r, ws[f"F{r}"].value, ws[f"G{r}"].value, ws[f"H{r}"].value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_chk = load_workbook(out_path)
print("Sheet names after recalc:", wb_chk.sheetnames)
if wb_chk.sheetnames != original_sheet_names:
    # rename in order
    for i, name in enumerate(original_sheet_names):
        wb_chk.worksheets[i].title = name
    wb_chk.save(out_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("\nFormula check F4:H6:")
for r in range(4, 7):
    print(r, [ws_formula.cell(r, c).value for c in range(6, 9)])

wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("\nCached values F3:H6 after recalc:")
for r in range(3, 7):
    print(r, [ws_values.cell(r, c).value for c in range(6, 9)])

output_spreadsheet = out_path
