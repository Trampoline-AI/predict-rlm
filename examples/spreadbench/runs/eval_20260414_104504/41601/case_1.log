Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Students"]

print("Pre-write target cells E2:E7:")
for r in range(2, ws.max_row + 1):
    print(r, "A=", ws[f"A{r}"].value, "E=", ws[f"E{r}"].value)

# Write dynamic formulas in Age column for all populated student rows
for r in range(2, ws.max_row + 1):
    name = ws[f"A{r}"].value
    if name not in (None, ""):
        ws[f"E{r}"] = f'=INDIRECT("\'"&A{r}&"\'!C2")'

print("\nPost-write formulas E2:E7:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"E{r}"].value)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)
else:
    print("Sheet names after recalc:", wb_check.sheetnames)

# Verify with data_only
wbv = load_workbook(outfile, data_only=True)
print("\nVerified target cells on Students!E2:E7 (data_only):")
for r in range(2, wbv["Students"].max_row + 1):
    print(f"E{r}:", wbv["Students"][f"E{r}"].value)

output_spreadsheet = outfile
