import os, json, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Original sheet names:", wb.sheetnames)

def sheet_info(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Size: rows={max_row}, cols={max_col}")
    print("Headers row 1:", headers)
    # first 10 rows
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, max_row - 4)
    print(f"Last rows {start_last}-{max_row}:")
    for r in range(start_last, max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Focus on Students sheet and candidate target cells/columns
if "Students" in wb.sheetnames:
    ws = wb["Students"]
    print("\nFocused inspection: Students sheet")
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(1, c)
        print(f"Col {get_column_letter(c)} header={cell.value!r}")
    # Print formulas/values in first several rows across first few columns
    for r in range(1, min(ws.max_row, 15) + 1):
        row = []
        for c in range(1, min(ws.max_column, 8) + 1):
            v = ws.cell(r, c).value
            row.append(f"{get_column_letter(c)}{r}={v!r}")
        print(" | ".join(row))

    # specifically inspect column A names and adjacent cells
    print("\nColumn A names and adjacent cells (first 15 rows):")
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 5) + 1)]
        print(r, vals)

    # inspect C2 in each non-Students sheet
    print("\nC2 values in each non-Students sheet:")
    for s in wb.sheetnames:
        if s != "Students":
            print(s, wb[s]["C2"].value)
