# Fill only blank target cells in C:E for data rows 6:9
for r in range(6, 10):
    income_cell = f"B{r}"
    c1, c2, c3 = ws[f"C{r}"], ws[f"D{r}"], ws[f"E{r}"]
    # preserve any existing values
    if c1.value in (None, ""):
        c1.value = f'=IF({income_cell}<=60000,0,MIN({income_cell},90000)-60000)*0.15'
