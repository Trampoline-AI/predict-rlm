print("Post-recalc sheet names:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    if len(wb2.sheetnames) == len(wb.sheetnames):
        for idx, name in enumerate(wb.sheetnames):
            wb2[wb2.sheetnames[idx]].title = name
        wb2.save(out_path)
        print("Restored sheet names to:", wb.sheetnames)

# Verify formulas and values
