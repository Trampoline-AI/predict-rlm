import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n=== Sheet: {s} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        print("Header row 2:", row_values(ws, 2, ws.max_column))
    # print first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, ws.max_column))
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            print(r, row_values(ws, r, ws.max_column))
    # print formulas found in first 20 rows
    formulas = []
    for r in range(1, min(ws.max_row, 20)+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Sample formulas in first 20 rows:", formulas[:20])

# Heuristic search for headers related to income/bonus/tier
keywords = ["income", "bonus", "tier", "salary", "earned"]
for s in wb.sheetnames:
    ws = wb[s]
    print(f"\nKeyword scan in {s}:")
    for r in range(1, min(ws.max_row, 5)+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and any(k in v.lower() for k in keywords):
                print(f"  {get_column_letter(c)}{r} = {v}")
