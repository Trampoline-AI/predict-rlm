from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Inspect target/example area H:K rows 3:10")
for r in range(3, 11):
    vals = [ws.cell(r, c).value for c in range(8, 12)]
    print(r, vals)

print("\nInspect source data A:E rows 1:13")
for r in range(1, 14):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Check if any formulas exist in target cells
for coord in ["K6","K7","K8","K9","K10"]:
    print(coord, "current value:", ws[coord].value)

# Infer answers by Python to confirm intended logic:
# For each query row, within matching item, find row where start_date <= recall_date < next start_date;
# if recall_date is after last available start_date for that item, use the last row.
headers = [ws.cell(2, c).value for c in range(1, 6)]
source_rows = []
for r in range(3, ws.max_row + 1):
    date_val = ws.cell(r, 1).value
    item = ws.cell(r, 2).value
    if date_val is not None and item is not None:
        source_rows.append({
            "row": r,
            "date": date_val,
            "item": item,
            "parameter1": ws.cell(r, 3).value,
            "parameter2": ws.cell(r, 4).value,
            "parameter3": ws.cell(r, 5).value,
        })

from collections import defaultdict
by_item = defaultdict(list)
for rec in source_rows:
    by_item[rec["item"]].append(rec)
for item in by_item:
    by_item[item].sort(key=lambda x: x["date"])

def lookup(item, parameter_label, recall_date):
    key = parameter_label.lower().replace(" ", "")
    rows = by_item.get(item, [])
    if not rows:
        return None
    for i, rec in enumerate(rows):
        next_date = rows[i+1]["date"] if i+1 < len(rows) else None
        if rec["date"] <= recall_date and (next_date is None or recall_date < next_date):
            return rec.get(key)
    return None

print("\nPredicted results for example/query rows:")
for r in range(6, 11):
    item = ws.cell(r, 8).value
    param = ws.cell(r, 9).value
    recall = ws.cell(r, 10).value
    pred = lookup(item, param, recall) if item and param and recall else None
    print(r, item, param, recall, "=>", pred, "| existing K:", ws.cell(r, 11).value)

# Fill only blank target cells in K where query inputs exist
for r in range(5, ws.max_row + 1):
    item = ws.cell(r, 8).value
    param = ws.cell(r, 9).value
    recall = ws.cell(r, 10).value
    target = ws.cell(r, 11)
    if item not in (None, "") and param not in (None, "") and recall not in (None, ""):
        if target.value in (None, ""):
            target.value = lookup(item, param, recall)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to", out_path)

status = await recalculate(out_path)
print("Recalculate:", status)

# restore sheet name if needed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_names)
    # rename by position
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)

# verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("\nVerification H:K rows 4:10")
for r in range(4, 11):
    print(r, [vws.cell(r, c).value for c in range(8, 12)])
