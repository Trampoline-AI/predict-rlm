from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from decimal import Decimal
import os, shutil

wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect target area more explicitly before modifying
for r in range(8, 12):
    print(
        "Before",
        r,
        "E=", ws[f"E{r}"].value,
        "F=", ws[f"F{r}"].value,
        "H=", ws[f"H{r}"].value,
        "H_fill=", ws[f"H{r}"].fill.fill_type,
        ws[f"H{r}"].fill.start_color.rgb
    )

def is_whole_number(val):
    if val is None or isinstance(val, str):
        return False
    try:
        d = Decimal(str(val))
        return d == d.to_integral_value()
    except Exception:
        try:
            return float(val).is_integer()
        except Exception:
            return False

changed_rows = []
for r in range(2, ws.max_row + 1):
    e = ws[f"E{r}"].value
    f = ws[f"F{r}"].value
    if isinstance(e, str) and "Georgia Its Tax" in e:
        new_text = "Georgia WH Tax" if is_whole_number(f) else "Georgia Sales Tax"
        ws[f"E{r}"] = new_text
        changed_rows.append((r, e, f, new_text))
    # Clear column H and remove background color for all actual data rows
    h = ws[f"H{r}"]
    h.value = None
    h.fill = PatternFill(fill_type=None)

print("Changed rows:", changed_rows)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved:", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    for idx, name in enumerate(orig_sheetnames):
        wb2.worksheets[idx].title = name
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# Verify output values
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_sheetnames[0]]
for r in range(8, 12):
    print(
        "After",
        r,
        "E=", repr(wsv[f"E{r}"].value),
        "F=", repr(wsv[f"F{r}"].value),
        "H=", repr(wsv[f"H{r}"].value)
    )

# Also verify fills by opening normal workbook
wbf = load_workbook(out_path)
wsf = wbf[orig_sheetnames[0]]
for r in [10, 11]:
    print("Fill check row", r, "H_fill=", wsf[f"H{r}"].fill.fill_type, "rgb=", wsf[f"H{r}"].fill.start_color.rgb)
