print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"] and "Sheet1" not in wb2.sheetnames:
    wb2[wb2.sheetnames[0]].title = "Sheet1"
    wb2.save(outfile)
    print("Renamed sheet back to Sheet1")

# Verify formulas and cached values
