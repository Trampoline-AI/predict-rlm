import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Sheet1"]

# Inspect exact target column F before writing
print("Target header F1:", ws["F1"].value)
for r in range(2, ws.max_row + 1):
    print(f"Before F{r}:", ws[f"F{r}"].value)

# Write formulas to F2:Fmax_row
for r in range(2, ws.max_row + 1):
    b = f"B{r}"
    c = f"C{r}"
    formula = f'=IF(EXACT(UPPER(LEFT({b},1)),LEFT({b},1)),UPPER(LEFT({c},1))&RIGHT({c},LEN({c})-1),LOWER(LEFT({c},1))&RIGHT({c},LEN({c})-1))'
    ws[f"F{r}"] = formula

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalc; restore sheet name if changed
