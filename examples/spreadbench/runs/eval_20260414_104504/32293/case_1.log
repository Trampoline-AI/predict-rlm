import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload original workbook for editing
wb = load_workbook(infile)
ws = wb["Sheet1"]

print("Before writing:")
for coord in ["B14", "B15", "B16", "B17"]:
    print(coord, "value=", ws[coord].value, "data_type=", ws[coord].data_type)

# Write formulas to exact target cells B14:B17
for r in range(14, 18):
    ws[f"B{r}"] = f'=INDEX($B$1:$B$4,MATCH(A{r},$A$1:$A$4,0))'

print("\nAfter writing formulas:")
for coord in ["B14", "B15", "B16", "B17"]:
    print(coord, ws[coord].value)

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Check sheet names after recalc; restore if changed
orig_names = wb.sheetnames
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    for i, orig in enumerate(orig_names):
        wb_check.worksheets[i].title = orig
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_names)

# Verify formulas and calculated values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification:")
for r in range(14, 18):
    print(
        f"A{r}={ws_values[f'A{r}'].value!r}, "
        f"B{r}_formula={ws_formula[f'B{r}'].value!r}, "
        f"B{r}_value={ws_values[f'B{r}'].value!r}"
    )

output_spreadsheet = outfile
```
