```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]
orig_sheetnames = wb.sheetnames[:]

# Rebuild source mapping from A:B
groups = defaultdict(list)
unique_order = []
seen = set()
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is None or a == "":
        continue
    groups[a].append(b)
    if a not in seen:
        seen.add(a)
        unique_order.append(a)

print("Unique order from column A:", unique_order)
print("Duplicate groups:", {k: v for k, v in groups.items() if len(v) > 1})

# Refresh helper/output area based on intended pattern
start_row = 3
for idx, key in enumerate(unique_order, start=start_row):
    ws.cell(idx, 6).value = key                     # F = unique values as literals
    ws.cell(idx, 5).value = f"=COUNTIF($A$2:$A${ws.max_row},F{idx})"   # E = duplication count formula
    
    vals = groups.get(key, [])
    out = vals if len(vals) > 1 else []
    for c in range(7, 12):  # G:K
        ws.cell(idx, c).value = out[c - 7] if (c - 7) < len(out) else None

# Clear any remaining rows in E:K below the unique list down to row 14/sample area
for r in range(start_row + len(unique_order), max(14, ws.max_row) + 1):
    for c in range(5, 12):
        if r <= 14:
            ws.cell(r, c).value = None

outpath = path
wb.save(outpath)
print("Saved repaired workbook:", outpath)

recalc_result = await recalculate(outpath)
print("Recalculate:", recalc_result)

# restore sheet names if needed
wb_check = load_workbook(outpath)
if wb_check.sheetnames != orig_sheetnames:
    print("Restoring sheet names from", wb_check.sheetnames, "to", orig_sheetnames)
    for i, nm in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = nm
    wb_check.save(outpath)

# verify
ver = load_workbook(outpath, data_only=True)
vws = ver[orig_sheetnames[0]]
print("Verified E3:K14")
for r in range(3, 15):
    print(r, [vws.cell(r, c).value for c in range(5, 12)])

output_spreadsheet = outpath
```
