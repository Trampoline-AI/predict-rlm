import os, shutil
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Inspect exact formulas/values in E3:F13 and infer target rows
print("Inspect E3:F13:")
for r in range(3, 14):
    e = ws[f"E{r}"].value
    f = ws[f"F{r}"].value
    f_repr = f.text if isinstance(f, ArrayFormula) else f
    print(r, "E=", e, "F=", f_repr, "F_type=", type(f).__name__)

# Build mapping from col A -> list of col B
groups = defaultdict(list)
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is not None and a != "":
        groups[a].append(b)

print("\nDerived groups from A:B:")
for k in sorted(groups, key=lambda x: str(x)):
    print(k, groups[k], "count", len(groups[k]))

# Determine target range by existing example area: unique keys in F3:F13, counts in E3:E13, outputs in G:K
targets = []
for r in range(3, 14):
    key = ws[f"F{r}"].value
    if isinstance(key, ArrayFormula):
        key = key.text
    count = ws[f"E{r}"].value
    targets.append((r, key, count))
print("\nTarget rows inferred from F3:F13:")
print(targets)

# Write outputs into G:K for each listed unique value based on corresponding B values if duplicated, else blanks
for r, key, count in targets:
    vals = groups.get(key, [])
    # user wants values from column B associated with duplicate entries in A, so only keep when duplicates exist
    out = vals if len(vals) > 1 else []
    for c in range(7, 12):  # G:K
        current = ws.cell(r, c).value
        newval = out[c - 7] if c - 7 < len(out) else None
        ws.cell(r, c).value = newval
        print(f"Row {r} {get_column_letter(c)} current={current!r} -> new={newval!r}")

# Save
infile = os.path.basename(path)
outpath = os.path.join("/sandbox/output/output_spreadsheet", infile)
