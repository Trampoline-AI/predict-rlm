```repl
from openpyxl import load_workbook
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]
ws2 = wb[wb.sheetnames[1]]

# Deeper inspection of DATA and desired result
print("First sheet:", ws.title, "rows", ws.max_row, "cols", ws.max_column)
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
    print("DATA", r, vals)

print("\nDesired result all rows:")
for r in range(1, ws2.max_row + 1):
    vals = [ws2.cell(r,c).value for c in range(1, ws2.max_column+1)]
    print("DES", r, vals)

# Determine behavior from I2
i2 = ws["I2"].value
print("\nI2 value:", repr(i2))

# Helper predicates
def row_values(sheet, r):
    return [sheet.cell(r,c).value for c in range(1, sheet.max_column+1)]

def is_blank_row(vals):
    return all(v is None or v == "" for v in vals)

def is_header_row(vals):
    # Based on observed structure
    return len(vals) >= 5 and vals[0] == "date" and vals[1] == "id" and vals[2] == "batch"

# Build cleaned rows for first sheet only:
# If I2 empty => compress consecutive blank rows to a single blank row between non-empty groups, and remove trailing blanks.
orig_rows = [row_values(ws, r) for r in range(1, ws.max_row + 1)]
print("Original nonblank/blank pattern:", ["B" if is_blank_row(v) else "N" for v in orig_rows])

new_rows = []
if i2 in (None, ""):
    seen_any = False
    pending_blank = False
    for vals in orig_rows:
        if is_blank_row(vals):
            if seen_any:
                pending_blank = True
            continue
        # nonblank
        if pending_blank and new_rows:
            new_rows.append([None] * ws.max_column)
        new_rows.append(vals)
        seen_any = True
        pending_blank = False
else:
    # For non-empty I2, keep only rows matching ID in col B plus relevant headers/separators.
    target_id = i2
    groups = []
    cur = []
    for vals in orig_rows:
        if is_blank_row(vals):
            if cur:
                groups.append(cur)
                cur = []
        else:
            cur.append(vals)
    if cur:
        groups.append(cur)
    selected = []
    for g in groups:
        has_id = any((len(v) >= 2 and v[1] == target_id) for v in g if not is_header_row(v))
        if has_id:
            if selected:
                selected.append([None] * ws.max_column)
            selected.extend(g)
    new_rows = selected

print("New row count:", len(new_rows))
for i, vals in enumerate(new_rows, start=1):
    print("NEW", i, vals)

# Compare to desired result for confidence
des_rows = [row_values(ws2, r) for r in range(1, ws2.max_row + 1)]
same = (new_rows == des_rows)
print("Matches desired result sheet exactly?", same)

# Rewrite first sheet contents only, preserve structure/sheet names
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r,c).value = None

for r, vals in enumerate(new_rows, start=1):
    for c, v in enumerate(vals, start=1):
        ws.cell(r,c).value = v

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalculate and restore names if needed
orig_names = wb.sheetnames[:]
res = await recalculate(out_path)
print("Recalc:", res)

wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    # rename back by position
    for idx, name in enumerate(orig_names):
        wb_check.worksheets[idx].title = name
    wb_check.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify output after recalculation
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_names[0]]
print("\nVerified first sheet rows:")
verified_rows = []
for r in range(1, max(len(new_rows), wsv.max_row) + 1):
    vals = [wsv.cell(r,c).value for c in range(1, wsv.max_column+1)]
    if r <= len(new_rows) + 2:
        print("OUT", r, vals)
    verified_rows.append(vals)

print("Target sheet name ok?", wsv.title == "DATA")
print("Second sheet exists?", orig_names[1] in wb_verify.sheetnames)
print("Output top rows match expected?", verified_rows[:len(new_rows)] == new_rows)
print("Row after expected range blank?", all(v is None for v in verified_rows[len(new_rows)]) if len(verified_rows) > len(new_rows) else True)

output_spreadsheet = out_path
