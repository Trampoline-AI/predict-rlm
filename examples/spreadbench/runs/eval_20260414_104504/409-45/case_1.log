def visible_rows(ws, max_cols=None):
    mc = ws.max_column if max_cols is None else min(ws.max_column, max_cols)
    rows = []
    for r in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=mc, values_only=True):
        rows.append(r)
    return rows

for sname in wb.sheetnames:
