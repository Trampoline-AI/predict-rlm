import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb["Sheet1"]

# Inspect exact types/values for relevant columns and target area
print("Type checks:")
for coord in ["B2","B3","B8","J7","K7","J8","K8","J9","K9"]:
    v = ws[coord].value
    print(coord, repr(v), type(v).__name__)

print("\nSource sample rows 2:10 (B,D,F):")
for r in range(2, 11):
    print(r, repr(ws[f"B{r}"].value), repr(ws[f"D{r}"].value), repr(ws[f"F{r}"].value))

# Compute matches with normalized string comparison
results = {}
for target_row in range(7, 10):
    crit_d = ws[f"J{target_row}"].value
    crit_b = ws[f"K{target_row}"].value
    match = None
    match_row = None
    for r in range(2, ws.max_row + 1):
        b = ws[f"B{r}"].value
        d = ws[f"D{r}"].value
        if str(b).strip() == str(crit_b).strip() and str(d).strip() == str(crit_d).strip():
            match = ws[f"F{r}"].value
            match_row = r
            break
    results[target_row] = (match, match_row)
    print(f"Target L{target_row}: criteria B={crit_b!r}, D={crit_d!r} -> {match!r} at row {match_row}")

# Write results into exact target cells L7:L9
for target_row, (match, _) in results.items():
    ws[f"L{target_row}"] = match

# Save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to", outfile)

# Recalculate and repair sheet names if needed
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_names:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)

# Verify output values after recalculation
wbv = load_workbook(outfile, data_only=True)
wsv = wbv[orig_names[0]]
print("\nVerification target cells:")
for coord in ["L7","L8","L9"]:
    print(coord, repr(wsv[coord].value))

print("Headers J6:L9:")
for r in range(6, 10):
    print(r, [wsv.cell(r, c).value for c in range(10, 13)])

output_spreadsheet = outfile
```
