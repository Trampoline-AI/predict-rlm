import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_used_bounds(ws):
    min_row=min_col=10**9
    max_row=max_col=0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                min_row=min(min_row, cell.row)
                min_col=min(min_col, cell.column)
                max_row=max(max_row, cell.row)
                max_col=max(max_col, cell.column)
    if max_row == 0:
        return None
    return min_row, min_col, max_row, max_col

for s in wb.sheetnames:
    ws = wb[s]
    bounds = sheet_used_bounds(ws)
    print(f"\n--- Sheet: {s} ---")
    print("max_row/max_col:", ws.max_row, ws.max_column, "used_bounds:", bounds)
    if not bounds:
        continue
    min_row, min_col, max_row, max_col = bounds
    header_candidates = {}
    for r in range(min_row, min(min_row+4, max_row)+1):
        vals = [ws.cell(r,c).value for c in range(min_col, max_col+1)]
        header_candidates[r] = vals
    print("Top rows:")
    for r, vals in header_candidates.items():
        print(r, vals)
    # choose row with most non-empty strings as likely header
    def score(vals):
        return sum(1 for v in vals if isinstance(v, str) and v.strip())
    header_row = max(header_candidates, key=lambda r: score(header_candidates[r]))
    headers = [ws.cell(header_row, c).value for c in range(min_col, max_col+1)]
    print("Likely header row:", header_row)
    print("Headers:", headers)
    
    sample_rows = list(range(min_row, min(max_row, min_row+9)+1))
    last_rows = list(range(max(min_row, max_row-4), max_row+1))
    shown = []
    print("Sample first rows:")
    for r in sample_rows:
        vals = [ws.cell(r,c).value for c in range(min_col, max_col+1)]
        shown.append(r)
        print(r, vals)
    print("Sample last rows:")
    for r in last_rows:
        vals = [ws.cell(r,c).value for c in range(min_col, max_col+1)]
        print(r, vals)
    # print formulas present in used range
    formulas = []
    for r in range(min_row, max_row+1):
        for c in range(min_col, max_col+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells count:", len(formulas))
    print("First formula cells:", formulas[:20])
