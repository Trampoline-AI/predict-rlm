    agent = ws.cell(r, 5).value
    if not agent:
        continue
    agents.append(agent)
    cats = []
    for idx, c in enumerate(range(6, 15)):
        if ws.cell(r, c).value not in (None, "", 0):
            cats.append(category_names[idx])
    agent_categories[agent] = cats

print("agent_categories:", agent_categories)

# Compute counts per interval for categories 1..8 from schedule table
