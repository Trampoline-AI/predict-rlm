computed = defaultdict(list)
target_categories = [ws.cell(r, 5).value for r in range(22, 30)]
print("target_categories:", target_categories)

for c in range(6, 32):
    scheduled_agents = []
    for r in range(13, 19):
        agent = ws.cell(r, 5).value
        if ws.cell(r, c).value not in (None, "", 0):
            scheduled_agents.append(agent)
    counts = {cat: 0 for cat in target_categories}
    for agent in scheduled_agents:
