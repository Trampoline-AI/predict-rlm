```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Load source workbook
src_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src_path))

wb = load_workbook(src_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Support"]

# Criteria
m3 = ws["M3"].value
n3 = ws["N3"].value
n4 = ws["N4"].value

# Compute matches from rows 2:40 (actual data extent inferred from sheet)
matches = []
for r in range(2, ws.max_row + 1):
    b = ws[f"B{r}"].value
    h = ws[f"H{r}"].value
    k = ws[f"K{r}"].value
    if b is None:
        continue
    if h == m3 and k in (n3, n4):
        matches.append((b, k, r))

print("Criteria:", m3, n3, n4)
print("Match count:", len(matches))
print("Matches preview:", matches[:20])

# Define fills requested
yellow_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
green_fill = PatternFill(start_color="00FF00", end_color="00FF00", fill_type="solid")
no_fill = PatternFill(fill_type=None)

# Clear existing output area in Q only (values + fill), preserving structure elsewhere
for r in range(1, ws.max_row + 1):
    cell = ws[f"Q{r}"]
    cell.value = None
    cell.fill = no_fill

# Write results sequentially in Q starting at row 1
for i, (b, k, src_row) in enumerate(matches, start=1):
    cell = ws[f"Q{i}"]
    cell.value = b
    cell.fill = yellow_fill if k == n3 else green_fill

# Save
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)

# Verify values after recalc
wb_val = load_workbook(out_path, data_only=True)
ws_val = wb_val["Support"]
verified_q = [ws_val[f"Q{r}"].value for r in range(1, len(matches) + 5)]
print("Verified Q rows 1..", len(matches)+4, ":", verified_q)

# Verify fills using normal workbook
wb_fmt = load_workbook(out_path)
ws_fmt = wb_fmt["Support"]
fill_info = []
for r in range(1, len(matches) + 1):
    c = ws_fmt[f"Q{r}"]
    fill_info.append((r, c.value, c.fill.start_color.rgb, c.fill.fill_type))
print("Fill verification:", fill_info[:20])

output_spreadsheet = out_path
```
