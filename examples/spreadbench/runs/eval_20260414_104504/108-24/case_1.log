infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy2(infile, outfile)

wb = load_workbook(outfile)
orig_names = wb.sheetnames[:]
src = wb["BZTB"]
tgt = wb["Tema UV COS"]

prefixes = ["COS Pass", "COS Comm", "COS W/S"]
results = []
for r in range(1, src.max_row + 1):
    row_vals = [src.cell(r, c).value for c in range(1, 5)]
    a, b, c, d = row_vals
    btxt = "" if b is None else str(b)
    atxt = "" if a is None else str(a).strip()
    if atxt == "398726":
        continue
    if any(btxt.startswith(p) for p in prefixes) and ("Used" in btxt):
        results.append(row_vals)

print("Filtered result count:", len(results))
print("First few results:", results[:5])
print("Last few results:", results[-5:])

# Clear existing target A:D area only where previously populated
for r in range(1, max(tgt.max_row, len(results)) + 5):
    for c in range(1, 5):
        tgt.cell(r, c).value = None

# Write results to A:D starting row 1
for i, row_vals in enumerate(results, start=1):
    for c, v in enumerate(row_vals, start=1):
        tgt.cell(i, c).value = v

