import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Determine true data extent in A:D
data_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    if any(v is not None for v in vals):
        data_rows.append(r)

first_data_row = min(data_rows)
last_data_row = max(data_rows)
print("Data rows:", first_data_row, "to", last_data_row)

# Print criteria and target area before writing
for coord in ["I3", "K3", "J5", "K5", "L5", "M5", "N5", "H23", "I23"]:
    print(coord, ws[coord].value)

# Python cross-check counts
def time_only(v):
    if v is None:
        return None
    if hasattr(v, "time"):
        return v.time()
    return v

py_counts = {}
for r in range(6, 25):
    start_t = ws.cell(r, 8).value  # H
    end_t = ws.cell(r, 9).value    # I
    for c in range(10, 15):        # J:N
        name = ws.cell(5, c).value
        cnt = 0
        for sr in range(first_data_row, last_data_row + 1):
            typ = ws.cell(sr, 1).value
            dt = ws.cell(sr, 2).value
            nm = ws.cell(sr, 3).value
            dest = ws.cell(sr, 4).value
            if nm == name and dest == ws["I3"].value and typ == ws["K3"].value and dt is not None:
                t = dt.time() if hasattr(dt, "time") else dt
                if start_t <= t < end_t:
                    cnt += 1
        py_counts[(r, c)] = cnt

print("Expected Python counts for J6:N24 where nonzero:")
for (r, c), v in py_counts.items():
    if v:
        print(f"{get_column_letter(c)}{r}={v}")

# Write formulas into J6:N24
for r in range(6, 25):
    for c in range(10, 15):
        coord = f"{get_column_letter(c)}{r}"
        formula = (
            f'=SUMPRODUCT(($C${first_data_row}:$C${last_data_row}={get_column_letter(c)}$5)'
            f'*($D${first_data_row}:$D${last_data_row}=$I$3)'
            f'*($A${first_data_row}:$A${last_data_row}=$K$3)'
            f'*(MOD($B${first_data_row}:$B${last_data_row},1)>=$H{r})'
            f'*(MOD($B${first_data_row}:$B${last_data_row},1)<$I{r}))'
        )
        ws[coord] = formula

wb.save(outfile)
print("Saved to", outfile)

# recalc
result = await recalculate(outfile)
print("Recalc:", result)

# restore sheet names if changed
orig_names = wb.sheetnames[:]
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    for idx, name in enumerate(orig_names):
        wb2.worksheets[idx].title = name
    wb2.save(outfile)

# verify
vwb = load_workbook(outfile, data_only=False)
dwb = load_workbook(outfile, data_only=True)
vws = vwb["Sheet1"]
dws = dwb["Sheet1"]

print("\nVerification formulas and values for nonzero cells:")
for (r, c), expected in py_counts.items():
    if expected:
        coord = f"{get_column_letter(c)}{r}"
        print(coord, "formula:", vws[coord].value, "value:", dws[coord].value, "expected:", expected)

print("\nFull target values J6:N24:")
for r in range(6, 25):
    vals = [dws.cell(r, c).value for c in range(10, 15)]
    print(r, vals)

output_spreadsheet = outfile
