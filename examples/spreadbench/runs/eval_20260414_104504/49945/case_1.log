import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Inspect target area F3:G11:")
for r in range(3, 12):
    print(r, ws[f"F{r}"].value, ws[f"G{r}"].value)

for coord in ["G3","G4","G5","G6"]:
    print(coord, "value=", ws[coord].value, "numfmt=", ws[coord].number_format)

# Apply formulas to rows that have a model in column F
for r in range(4, ws.max_row + 1):
    model = ws[f"F{r}"].value
    if model not in (None, ""):
        ws[f"G{r}"] = f'=SUMIF($C$4:$C$11,F{r},$D$4:$D$11)'

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

res = await recalculate(out_path)
print("Recalculate:", res)

# restore sheet name if recalculation changed it
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    # rename by position
    for i, orig in enumerate(wb.sheetnames):
        wb2.worksheets[i].title = orig
    wb2.save(out_path)
    print("Renamed sheets back to:", wb.sheetnames)

# verify with data_only
ver = load_workbook(out_path, data_only=False)
ver_data = load_workbook(out_path, data_only=True)
wsf = ver["Sheet1"]
wsd = ver_data["Sheet1"]
print("Verification formulas and values:")
for r in range(4, 7):
    print(f"F{r}={wsf[f'F{r}'].value!r}, G{r} formula={wsf[f'G{r}'].value!r}, value={wsd[f'G{r}'].value!r}")

output_spreadsheet = out_path
```
