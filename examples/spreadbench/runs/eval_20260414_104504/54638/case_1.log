def border_summary(cell):
    b = cell.border
    return {
        "left": (b.left.style, b.left.color.type if b.left.color else None, b.left.color.rgb if b.left.color and b.left.color.type=="rgb" else None),
        "right": (b.right.style, b.right.color.type if b.right.color else None, b.right.color.rgb if b.right.color and b.right.color.type=="rgb" else None),
        "top": (b.top.style, b.top.color.type if b.top.color else None, b.top.color.rgb if b.top.color and b.top.color.type=="rgb" else None),
        "bottom": (b.bottom.style, b.bottom.color.type if b.bottom.color else None, b.bottom.color.rgb if b.bottom.color and b.bottom.color.type=="rgb" else None),
    }

print("Sheet1 showGridLines:", ws1.sheet_view.showGridLines)
print("Sheet2 showGridLines:", ws2.sheet_view.showGridLines)

print("\nInspect A1:A16 and B1:B16 styles:")
for r in range(1, 17):
    for col in ["A","B"]:
        c = ws1[f"{col}{r}"]
        print(
            f"{col}{r}",
            "val=", c.value,
            "font=", (c.font.name, c.font.sz, c.font.bold, c.font.italic),
            "fill=", (c.fill.fill_type, c.fill.fgColor.type, c.fill.fgColor.rgb if c.fill.fgColor.type=="rgb" else c.fill.fgColor.indexed),
            "align=", (c.alignment.horizontal, c.alignment.vertical),
            "numfmt=", c.number_format,
            "border=", border_summary(c)
        )
    print("---")

print("\nInspect rows 12-15 specifically for borders in col A and B:")
for r in range(12, 16):
    print("Row", r, "A border", border_summary(ws1[f"A{r}"]), "B border", border_summary(ws1[f"B{r}"]))

print("\nExisting formulas in B2:B10:")
for r in range(2, 11):
    print(r, ws1[f"B{r}"].value, ws1[f"B{r}"].data_type)

print("\nDimensions/hidden settings:")
print("Sheet1 dimensions", ws1.sheet_view.zoomScale, ws1.sheet_format.defaultRowHeight)
print("Sheet2 state", ws2.sheet_state)
