import os, shutil
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill, Border, Side

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Helpers
thin = Side(style="thin")
thin_border = Border(left=thin, right=thin, top=thin, bottom=thin)
no_border = Border()
yellow_fill = PatternFill(fill_type="solid", start_color="FFFF00", end_color="FFFF00")

def to_calibri_font(f):
    return copy(f.copy(name="Calibri")) if hasattr(f, "copy") else Font(
        name="Calibri",
        sz=f.sz, b=f.b, i=f.i, underline=f.underline, strike=f.strike,
        color=f.color.rgb if getattr(f.color, "type", None) == "rgb" else None,
        vertAlign=f.vertAlign, outline=f.outline, shadow=f.shadow,
        condense=f.condense, extend=f.extend, family=f.family, charset=f.charset,
        scheme=f.scheme
    )

# Use copy on font and overwrite only name
for ws in wb.worksheets:
    # remove sheet gridlines when appropriate; Sheet1 clearly presentation sheet
    if ws.title == "Sheet1":
        ws.sheet_view.showGridLines = False
    # ensure Calibri font while preserving bold/size/etc.
    for row in ws.iter_rows():
        for cell in row:
            cell.font = copy(cell.font)
            cell.font = cell.font.copy(name="Calibri") if hasattr(cell.font, "copy") else to_calibri_font(cell.font)

# Hide Sheet2
ws2.sheet_state = "hidden"

# Recreate formulas in column A exactly through row 150
for r in range(2, 151):
    ws1[f"A{r}"] = f'=IF(Sheet2!A{r}="","",Sheet2!A{r})'

# Determine unique nonblank values from A2:A150 preserving first appearance.
# Use Sheet2 source values effectively mirrored into A when recalculated.
source_vals = []
for r in range(2, 151):
    v = ws2[f"A{r}"].value if r <= ws2.max_row else None
    if v is not None and str(v) != "":
        source_vals.append(str(v).strip())

unique_vals = []
seen = set()
for v in source_vals:
    if v not in seen:
        seen.add(v)
        unique_vals.append(v)

# Populate B2:B150 with desired outcome
for r in range(2, 151):
    cell = ws1[f"B{r}"]
    idx = r - 2
    cell.value = unique_vals[idx] if idx < len(unique_vals) else ""

# Formatting:
# Column B rows 2:150 yellow fill + thin borders
for r in range(2, 151):
    c = ws1[f"B{r}"]
    c.fill = copy(yellow_fill)
    c.border = copy(thin_border)

# Column A should only have borders up to row 13
for r in range(1, 151):
    c = ws1[f"A{r}"]
    c.border = copy(thin_border if r <= 13 else no_border)

# Keep header B1 bordered like existing; ensure Calibri already set
# Save
wb.save(outfile)

# Recalculate
recalc_result = await recalculate(outfile)

# Restore sheet names if recalc altered them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    # rename by position back to original names
    for i, desired in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = desired
    wb_check.save(outfile)

# Verify with data_only
wbv = load_workbook(outfile, data_only=True)
print("Saved:", outfile)
print("Recalc:", recalc_result)
print("Sheetnames:", wbv.sheetnames)
print("Sheet2 hidden state:", load_workbook(outfile)["Sheet2"].sheet_state)
print("Sheet1 gridlines:", load_workbook(outfile)["Sheet1"].sheet_view.showGridLines)

wsv = wbv["Sheet1"]
print("A2:A15 values:")
for r in range(2, 16):
    print(r, wsv[f"A{r}"].value)
print("B2:B15 values:")
for r in range(2, 16):
    print(r, repr(wsv[f"B{r}"].value))

# Style verification from non-data_only workbook
wbs = load_workbook(outfile)
wsv2 = wbs["Sheet1"]
print("A12 border styles:", [wsv2[f"A12"].border.left.style, wsv2[f"A12"].border.right.style, wsv2[f"A12"].border.top.style, wsv2[f"A12"].border.bottom.style])
print("A14 border styles:", [wsv2[f"A14"].border.left.style, wsv2[f"A14"].border.right.style, wsv2[f"A14"].border.top.style, wsv2[f"A14"].border.bottom.style])
print("B2 fill/border/font:", wsv2["B2"].fill.fgColor.rgb, wsv2["B2"].border.left.style, wsv2["B2"].font.name)
print("A2 formula:", wsv2["A2"].value)
print("A150 formula:", wsv2["A150"].value)
output_spreadsheet = outfile
