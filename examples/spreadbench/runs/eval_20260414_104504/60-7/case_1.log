import os, shutil
from collections import Counter
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws_ct = wb["Consolidated Tracker"]
ws_exist = wb["Existing Task"]
ws_add = wb["Additions"]
ws_ret = wb["Retired"]

print("Merged ranges in Consolidated Tracker:", list(ws_ct.merged_cells.ranges))
print("Target header row 2 A:L:", [ws_ct.cell(2,c).value for c in range(1,13)])
print("Target output area A3:E11 before write:")
for r in range(3, min(11, ws_ct.max_row)+1):
    print(r, [ws_ct.cell(r,c).value for c in range(1,6)])

def get_rows(ws):
    rows = []
    for r in range(3, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, 6)]
        if any(v is not None and v != "" for v in vals):
            rows.append(tuple(vals))
    return rows

existing_rows = get_rows(ws_exist)
addition_rows = get_rows(ws_add)
retired_rows = get_rows(ws_ret)

print("Counts:", len(existing_rows), len(addition_rows), len(retired_rows))
print("Existing rows:", existing_rows)
print("Addition rows:", addition_rows)
print("Retired rows:", retired_rows)

# multiset arithmetic: Existing + Additions - Retired
counts = Counter(existing_rows) + Counter(addition_rows)
counts.subtract(Counter(retired_rows))
final_rows = []
for row in existing_rows + addition_rows:
    if counts[row] > 0:
        final_rows.append(row)
        counts[row] -= 1

print("Final rows count:", len(final_rows))
for i, row in enumerate(final_rows, start=3):
    print(i, row)

# clear old output area only in A:E from row3 down through current used/needed space
clear_to = max(ws_ct.max_row, 3 + len(final_rows) + 20)
for r in range(3, clear_to + 1):
    for c in range(1, 6):
        ws_ct.cell(r, c).value = None

# write result starting A3
for idx, row in enumerate(final_rows, start=3):
    for c, val in enumerate(row, start=1):
        ws_ct.cell(idx, c).value = val

wb.save(outfile)
print("Saved to", outfile)

res = await recalculate(outfile)
print("Recalculate:", res)

# reload and ensure sheet names preserved
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
orig_names = ['Consolidated Tracker', 'Existing Task', 'Additions', 'Retired']
if wb2.sheetnames != orig_names:
    # rename by position if needed
    for ws, orig in zip(wb2.worksheets, orig_names):
        ws.title = orig
    wb2.save(outfile)
    print("Renamed sheets back to original names")

# verify data_only values
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Consolidated Tracker"]
print("Verified target A2:E12 after save/recalc:")
for r in range(2, 2 + len(final_rows) + 2):
    print(r, [wsv.cell(r,c).value for c in range(1,6)])
