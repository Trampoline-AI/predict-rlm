import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row 2 values:", row2)
    # detect likely header row among first 3 rows
    for hr in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        print(f"Candidate header row {hr}: {vals} (nonempty={nonempty})")
    # first up to 10 rows
    n1 = min(ws.max_row, 10)
    print(f"First {n1} rows:")
    for r in range(1, n1 + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last 5 rows
    start = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # print formulas / non-empty cells in a compact way
    formula_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells count:", len(formula_cells))
    print("First formula cells:", formula_cells[:20])

for ws in wb.worksheets:
    sheet_info(ws)
