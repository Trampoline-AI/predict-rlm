from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Print exact relevant areas before modifying
print("Target table area C3:F7")
for r in range(3, 8):
    print(r, [ws.cell(r, c).value for c in range(3, 7)])

print("\nSource data area I3:K22")
for r in range(3, 23):
    print(r, [ws.cell(r, c).value for c in range(9, 12)])

# Identify target cells (interior of table)
targets = []
for r in range(4, 8):
    row_key = ws.cell(r, 2).value   # col B
    for c in range(3, 7):
        col_key = ws.cell(3, c).value  # header row 3
        targets.append((r, c, row_key, col_key, ws.cell(r, c).value))
print("\nTargets before writing:")
for t in targets:
    print(f"{get_column_letter(t[1])}{t[0]} rowkey={t[2]} colkey={t[3]} current={t[4]}")

# Write formulas into the exact target cells
# Lookup table: I3:K22 where I=first key, J=second key, K=return value
for r in range(4, 8):
    for c in range(3, 7):
        row_key_ref = f"$B{r}"
