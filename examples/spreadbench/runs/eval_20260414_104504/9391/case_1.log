from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook for editing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
wsf = wb["Front"]
wsd = wb["Data"]

# Build expected values in Python for verification
# Parse Data into date->agent->colF value (column F = 6)
expected = {}
r = 1
while r <= wsd.max_row:
    a = wsd.cell(r, 1).value
    if hasattr(a, "year"):  # date row
        current_date = a
        expected[current_date] = {}
        rr = r + 3  # agent rows begin 3 rows after date row
        while rr <= wsd.max_row:
            aval = wsd.cell(rr, 1).value
            if aval is None:
                break
            if hasattr(aval, "year"):
                break
            if aval not in ("Agent Name", "Totals"):
                expected[current_date][aval] = wsd.cell(rr, 6).value
            rr += 1
        r = rr
    else:
        r += 1

print("Expected lookup map sample:")
for d, mp in list(expected.items())[:5]:
    print(d, mp)

# Write formulas to Front!B2:N12
for row in range(2, wsf.max_row + 1):
    for col in range(2, wsf.max_column + 1):
        col_letter = get_column_letter(col)
        formula = (
            f'=IFERROR('
            f'INDEX(Data!$F:$F,'
            f'MATCH($A{row},'
            f'INDEX(Data!$A:$A,MATCH({col_letter}$1,Data!$A:$A,0)+3):'
            f'INDEX(Data!$A:$A,MATCH({col_letter}$1,Data!$A:$A,0)+20),0)'
            f'+MATCH({col_letter}$1,Data!$A:$A,0)+2'
            f'),"")'
        )
        wsf.cell(row, col).value = formula

# Save and recalc
wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, nm in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = nm
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)
else:
    print("Sheet names after recalc:", wb2.sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
vf = wb_formula["Front"]
vv = wb_values["Front"]

print("\nSample formulas in Front:")
for coord in ["B2", "B3", "C2", "N12"]:
    print(coord, vf[coord].value)

print("\nVerification of Front!B2:N12 (value / expected):")
mismatches = []
for row in range(2, vv.max_row + 1):
    date_val = vv.cell(1, row if False else 2).value  # dummy to avoid lint
    for col in range(2, vv.max_column + 1):
        date_key = vv.cell(1, col).value
        agent = vv.cell(row, 1).value
        actual = vv.cell(row, col).value
        exp = expected.get(date_key, {}).get(agent, "")
        # normalize None to blank
        actual_norm = "" if actual is None else actual
        exp_norm = "" if exp is None else exp
        print(f"{get_column_letter(col)}{row}: {actual_norm!r} / {exp_norm!r}")
        if actual_norm != exp_norm:
            mismatches.append((row, col, actual_norm, exp_norm, agent, date_key))

print("Mismatch count:", len(mismatches))
if mismatches[:10]:
    print("First mismatches:", mismatches[:10])

output_spreadsheet = outfile
