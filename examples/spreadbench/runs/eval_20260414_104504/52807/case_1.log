from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Summary"]

print("Original sheetnames:", orig_sheetnames)
print("D3 months completed:", ws["D3"].value)

# Show pre-write target area
print("Pre-write H6:P9:")
for r in range(6, 10):
    print(r, [(f"{get_column_letter(c)}{r}", ws.cell(r, c).value) for c in range(8, 17)])

# Write formulas into H6:P9
for r in range(6, 10):
    for c in range(8, 17):  # H:P
        col_letter = get_column_letter(c)
        formula = (
            f'=IF(SUMIFS(Data!$C$2:$C$13,Data!$A$2:$A$13,Summary!$C{r},'
            f'Data!$D$2:$D$13,Summary!{col_letter}$5)<>0,'
            f'SUMIFS(Data!$C$2:$C$13,Data!$A$2:$A$13,Summary!$C{r},'
            f'Data!$D$2:$D$13,Summary!{col_letter}$5),'
            f'SUM($E{r}:$G{r})/(12-$D$3))'
        )
        ws.cell(r, c).value = formula

# Save before recalculation
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Reload and fix sheet names if changed
wb_post = load_workbook(outfile)
print("Post-recalc sheetnames:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    # rename back by position
    for idx, orig_name in enumerate(orig_sheetnames):
        wb_post.worksheets[idx].title = orig_name
    wb_post.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with formulas view
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula["Summary"]
print("Written formulas H6:P9:")
for r in range(6, 10):
    print(r, [wsf.cell(r, c).value for c in range(8, 17)])

# Verify cached values
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", wb_verify.sheetnames)
wsv = wb_verify["Summary"]
print("Cached values E6:P9:")
for r in range(6, 10):
    vals = [wsv.cell(r, c).value for c in range(5, 17)]
    print(r, vals)

# Print exact target range values
print("Target H6:P9 cached values:")
for r in range(6, 10):
    print(r, [(f"{get_column_letter(c)}{r}", wsv.cell(r, c).value) for c in range(8, 17)])

output_spreadsheet = outfile
