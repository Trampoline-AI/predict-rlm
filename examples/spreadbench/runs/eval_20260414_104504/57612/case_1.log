import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Show existing target formulas before modification
print("Existing D4:D15 formulas/values before change:")
for r in range(4, 16):
    print(r, "C=", ws[f"C{r}"].value, "D=", ws[f"D{r}"].value)

# Apply corrected formula to all relevant populated rows in column C
for r in range(4, ws.max_row + 1):
    c_val = ws.cell(r, 3).value
    d_cell = ws.cell(r, 4)
    if c_val is None or c_val == "":
        continue
    d_cell.value = f'=IF(AND(C{r}>=5,C{r}<=6),5,IF(AND(C{r}>=3,C{r}<=4),3.75,IF(AND(C{r}>=1,C{r}<=2),1,0)))'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc, fix sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # rename by position back to original
    for i, orig_name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("Verified target cells D4:D15 after recalculation:")
for r in range(4, 16):
    print(r, {"C": wsv[f"C{r}"].value, "D": wsv[f"D{r}"].value})

# Also verify formulas still present in non-data_only load
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[original_sheetnames[0]]
print("Formula strings now in D4:D15:")
for r in range(4, 16):
    print(r, wsf[f"D{r}"].value)

output_spreadsheet = outfile
