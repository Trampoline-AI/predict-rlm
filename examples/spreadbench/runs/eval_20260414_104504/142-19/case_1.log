from openpyxl import load_workbook
from pathlib import Path
import shutil, os

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Print full block contents before modification for exact verification
blocks = []
in_block = False
start = None
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    nonblank = (a not in (None, "")) or (b not in (None, ""))
    if nonblank and not in_block:
        start = r
        in_block = True
    elif not nonblank and in_block:
        blocks.append((start, r - 1))
        in_block = False
if in_block:
    blocks.append((start, ws.max_row))

print("Pre-sort blocks and values:")
for start, end in blocks:
    print(f"Block {start}-{end}")
    for r in range(start, end + 1):
        print(r, ws.cell(r,1).value, "|", ws.cell(r,2).value)

# Check target cells currently contain plain values, not formulas
for coord in ["A2","B2","A17","B17","A44","B44","A59","B59"]:
    print("Current", coord, "=", ws[coord].value)

# Sort each contiguous nonblank block independently, excluding the header row
for start, end in blocks:
    header_a = ws.cell(start, 1).value
    header_b = ws.cell(start, 2).value
    data_rows = []
    for r in range(start + 1, end + 1):
        a = ws.cell(r, 1).value
        b = ws.cell(r, 2).value
        if a in (None, "") and b in (None, ""):
            continue
        data_rows.append((a, b))
    data_rows_sorted = sorted(data_rows, key=lambda x: (str(x[0]) if x[0] is not None else ""))
    # rewrite
    ws.cell(start, 1).value = header_a
    ws.cell(start, 2).value = header_b
    write_r = start + 1
    for a, b in data_rows_sorted:
        ws.cell(write_r, 1).value = a
        ws.cell(write_r, 2).value = b
        write_r += 1

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalculate and repair sheet names if needed
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify output values after reload
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
print("Post-sort blocks:")
for start, end in blocks:
    print(f"Block {start}-{end}")
    for r in range(start, end + 1):
        print(r, wsv.cell(r,1).value, "|", wsv.cell(r,2).value)

output_spreadsheet = out_path
print("Prepared output_spreadsheet:", output_spreadsheet)
