import os, shutil
from openpyxl import load_workbook

# Re-open and inspect target area more thoroughly
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

nonempty_cd = []
for r in range(1, ws.max_row + 1):
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    if c not in (None, "") or d not in (None, ""):
        nonempty_cd.append((r, c, d))

print("Non-empty rows in C:D:", nonempty_cd[:20], "count=", len(nonempty_cd))

# Build sorted column A values
words = [ws.cell(r, 1).value.strip() for r in range(1, ws.max_row + 1)
         if isinstance(ws.cell(r, 1).value, str) and ws.cell(r, 1).value.strip()]
sorted_words = sorted(words)

def transform(word):
    return word[4] + word[:4] + word[5:] if isinstance(word, str) and len(word) >= 8 else None

word_set = set(words)
suffix_order = ["ING", "ERS", "ATE", "EST", "ONE", "IER", "ILY"]

pairs_ordered = []
for suf in suffix_order:
    group = []
    for w in words:
        if len(w) >= 8 and w.endswith(suf):
            t = transform(w)
            if t in word_set and t.endswith(suf):
                group.append((w, t))
    group = sorted(set(group), key=lambda x: (x[0], x[1]))
    print(suf, group)
    pairs_ordered.extend(group)

print("Total output pairs:", len(pairs_ordered))

# Write output workbook
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

wb2 = load_workbook(out_path)
ws2 = wb2["Sheet1"]

# Sort column A values; blank out any remaining rows below if needed
for i in range(1, ws2.max_row + 1):
    ws2.cell(i, 1).value = sorted_words[i-1] if i-1 < len(sorted_words) else None

# Clear columns C:D completely, then write pairs with existing layout pattern C=original, D=transformed
for r in range(1, ws2.max_row + 1):
    ws2.cell(r, 3).value = None
    ws2.cell(r, 4).value = None

for idx, (orig, trans) in enumerate(pairs_ordered, start=1):
    ws2.cell(idx, 3).value = orig
    ws2.cell(idx, 4).value = trans

wb2.save(out_path)
wb2.close()

# Recalculate and restore sheet names if needed
orig_sheetnames = wb.sheetnames[:]
wb.close()
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = s
    wb_check.save(out_path)
wb_check.close()

# Verify after reload
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
a_vals = [wsv.cell(r, 1).value for r in range(1, 16)]
cd_vals = [(r, wsv.cell(r, 3).value, wsv.cell(r, 4).value) for r in range(1, len(pairs_ordered)+3)]
print("First 15 sorted A values:", a_vals)
print("Output C:D rows:", cd_vals)
print("Sheetnames final:", wbv.sheetnames)
wbv.close()

final_output_path = out_path
