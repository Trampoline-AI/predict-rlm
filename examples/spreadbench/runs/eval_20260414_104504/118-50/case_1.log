import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row2:", row_values(ws, 2, ws.max_column))
    # print first 10 rows and last 5 rows, limited width
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    last_start = max(1, ws.max_row-4)
    print(f"Last rows {last_start}-{ws.max_row}:")
    for r in range(last_start, ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))

    # inspect column A contents and nearby empty columns
    print("Sample non-empty values in column A:")
    shown = 0
    for r in range(1, ws.max_row+1):
        v = ws.cell(r, 1).value
        if v not in (None, ""):
            print(f"A{r}={v!r}")
            shown += 1
        if shown >= 15:
            break

    # check existing formulas / data in first few columns
    for c in range(1, min(ws.max_column, 12)+1):
        col = get_column_letter(c)
        vals = [ws.cell(r, c).value for r in range(1, min(ws.max_row, 8)+1)]
        print(f"Col {col} first values:", vals)

wb.close()
