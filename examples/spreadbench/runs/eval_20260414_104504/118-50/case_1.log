from openpyxl import load_workbook
from collections import defaultdict

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

print("Total non-empty words in col A:", len(words))
print("First 20 words currently:", words[:20])
print("Is col A already sorted?", words == sorted(words))

word_set = set(words)

def transform(word):
    if len(word) < 8:
        return None
    # move 5th letter to first, keep last 3 letters same
    return word[4] + word[:4] + word[5:]

# Show transformation for the example cell values
example_c = ws["C1"].value
example_d = ws["D1"].value
print("Example cells C1,D1:", example_c, example_d)
if isinstance(example_c, str):
    print("transform(C1):", transform(example_c))

suffix_order = ["ING", "ERS", "ATE", "EST", "ONE", "IER", "ILY"]
pairs_by_suffix = defaultdict(list)
other_pairs = []

for w in words:
    if len(w) >= 8:
        t = transform(w)
        if t in word_set and w[-3:] == t[-3:]:
            if w[-3:] in suffix_order:
                pairs_by_suffix[w[-3:]].append((w, t))
            else:
                other_pairs.append((w, t))

for suf in suffix_order:
    pairs = pairs_by_suffix[suf]
    print(f"Suffix {suf}: {len(pairs)} pairs")
    print(" sample:", pairs[:10])

print("Other suffix pairs count:", len(other_pairs))
print("Other suffix sample:", other_pairs[:20])

# Also check reverse duplicates / unique undirected pairs
unique_pairs = set()
for suf in suffix_order:
    for a,b in pairs_by_suffix[suf]:
        unique_pairs.add(tuple(sorted((a,b))))
print("Unique undirected pairs among requested suffixes:", len(unique_pairs))
print("Sample undirected pairs:", list(unique_pairs)[:20])
