from openpyxl import load_workbook
import os, shutil

# Re-open and inspect all rows including trailing blanks to understand true sheet extent
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Detailed rows 1-28, cols A:E")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Simulate deletion candidates on original sheet
def is_blank_a(ws, r):
    v = ws.cell(r, 1).value
    return v is None or (isinstance(v, str) and v.strip() == "")

def is_line_no_header(ws, r):
    v = ws.cell(r, 1).value
    return isinstance(v, str) and v.strip() == "Line No"

last_row = ws.max_row
to_delete = set()
protected = set()
for r in range(1, last_row + 1):
    if is_blank_a(ws, r):
        to_delete.add(r)  # delete blank row itself
        above = r - 1
        if above >= 1:
            # protect data row directly below a header row containing Line No
            if above >= 2 and is_line_no_header(ws, above - 1) and not is_blank_a(ws, above):
                protected.add(above)
            else:
                to_delete.add(above)

to_delete -= protected
print("Protected rows:", sorted(protected))
print("Rows to delete:", sorted(to_delete))

print("Preview keep/delete decisions rows 1-15")
for r in range(1, 16):
    status = "DEL" if r in to_delete else ("PROTECT" if r in protected else "KEEP")
    print(r, status, [ws.cell(r, c).value for c in range(1, 6)])

# Apply transformation to workbook
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb2 = load_workbook(outfile)
orig_sheetnames = wb2.sheetnames[:]

# Determine sheets to process: from BR1 onwards if present, else all sheets
if "BR1" in wb2.sheetnames:
    start_idx = wb2.sheetnames.index("BR1")
    target_sheets = wb2.sheetnames[start_idx:]
else:
    target_sheets = wb2.sheetnames[:]

print("Target sheets to process:", target_sheets)

for s in target_sheets:
    ws2 = wb2[s]
    # compute deletion set on current sheet based on original row positions
    to_delete = set()
    protected = set()
    for r in range(1, ws2.max_row + 1):
        if is_blank_a(ws2, r):
            to_delete.add(r)
            above = r - 1
            if above >= 1:
                if above >= 2 and is_line_no_header(ws2, above - 1) and not is_blank_a(ws2, above):
                    protected.add(above)
                else:
                    to_delete.add(above)
    to_delete -= protected

    # rebuild rows, keeping formatting/values only via delete_rows from bottom
    for r in sorted(to_delete, reverse=True):
        ws2.delete_rows(r, 1)

wb2.save(outfile)
print("Saved to", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wbv = load_workbook(outfile, data_only=False)
print("Post-save sheet names:", wbv.sheetnames)
for s in wbv.sheetnames:
    wsv = wbv[s]
    print(f"After processing sheet {s}: max_row={wsv.max_row}, max_col={wsv.max_column}")
    for r in range(1, min(wsv.max_row, 15) + 1):
        print(r, [wsv.cell(r, c).value for c in range(1, 6)])
