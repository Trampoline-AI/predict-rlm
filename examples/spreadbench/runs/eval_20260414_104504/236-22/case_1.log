from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, shutil

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def sheet_nonempty_bounds(ws):
    max_row, max_col = ws.max_row, ws.max_column
    # detect actual last non-empty row/col
    last_row = 0
    last_col = 0
    for r in range(1, max_row + 1):
        row_has = False
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                last_col = max(last_col, c)
        if row_has:
            last_row = r
    return last_row, last_col

for s in wb.sheetnames:
    ws = wb[s]
    last_row, last_col = sheet_nonempty_bounds(ws)
    headers = [ws.cell(1, c).value for c in range(1, min(last_col, 12) + 1)]
    print(f"\n--- Sheet {s} ---")
    print("max_row/max_col:", ws.max_row, ws.max_column, "actual_last:", last_row, last_col)
    print("Row1 headers/sample:", headers)
    # print first 10 rows first 8 cols
    cols_to_show = min(max(last_col, 1), 8)
    print("First rows:")
    for r in range(1, min(last_row, 10) + 1):
        print(r, [ws.cell(r, c).value for c in range(1, cols_to_show + 1)])
    print("Last rows:")
    start = max(1, last_row - 4)
    for r in range(start, last_row + 1):
        print(r, [ws.cell(r, c).value for c in range(1, cols_to_show + 1)])
    # inspect column A blanks and nearby rows
    blank_rows = []
    for r in range(1, last_row + 1):
        a = ws.cell(r, 1).value
        if a is None or (isinstance(a, str) and a.strip() == ""):
            blank_rows.append(r)
    print("Blank rows in col A (first 25):", blank_rows[:25], "count:", len(blank_rows))
    focus = sorted(set([r for br in blank_rows[:15] for r in (br-1, br, br+1) if 1 <= r <= last_row] + [1,2,8,9,10]))
    print("Focus rows around blanks:")
    for r in focus[:40]:
        print(r, [ws.cell(r, c).value for c in range(1, cols_to_show + 1)])
