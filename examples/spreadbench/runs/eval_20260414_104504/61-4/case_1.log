```repl
import os, shutil
from collections import defaultdict
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws_in = wb["input"]
ws_out = wb["output"]

# Inspect exact example output area in input!K:Q to confirm pattern
print("Example output in input!K:Q:")
for r in range(1, ws_in.max_row + 1):
    vals = [ws_in.cell(r, c).value for c in range(11, 18)]
    if any(v is not None for v in vals):
        print(r, vals)

# Read source rows from A:H
records = []
for r in range(2, ws_in.max_row + 1):
    date = ws_in.cell(r, 1).value
    stock = ws_in.cell(r, 2).value
    if stock is None and date is None:
        continue
    stock_clean = str(stock).strip() if stock is not None else None
    records.append({
        "date": date,
        "stock_raw": stock,
        "stock": stock_clean,
        "open": ws_in.cell(r, 3).value,
        "high": ws_in.cell(r, 4).value,
        "low": ws_in.cell(r, 5).value,
        "close": ws_in.cell(r, 6).value,
        "volume": ws_in.cell(r, 7).value,
        "change": ws_in.cell(r, 8).value,
    })

# Preserve stock order of appearance
stock_order = []
seen = set()
for rec in records:
    if rec["stock"] not in seen:
        seen.add(rec["stock"])
        stock_order.append(rec["stock"])

by_stock = defaultdict(list)
for rec in records:
    by_stock[rec["stock"]].append(rec)

def is_negative(x):
    return isinstance(x, (int, float)) and x < 0

summarized = []
for stock in stock_order:
    rows = by_stock[stock]
    i = 0
    while i < len(rows):
        rec = rows[i]
        if is_negative(rec["change"]):
            run = [rec]
            j = i + 1
            while j < len(rows) and is_negative(rows[j]["change"]):
                run.append(rows[j])
                j += 1
            summarized.append({
                "date": run[0]["date"],
                "stock_raw": run[0]["stock_raw"],
                "open": run[0]["open"],
                "high": max(x["high"] for x in run),
                "low": min(x["low"] for x in run),
                "close": run[-1]["close"],
                "volume": sum(x["volume"] for x in run),
            })
            i = j
        else:
            summarized.append({
                "date": rec["date"],
                "stock_raw": rec["stock_raw"],
                "open": rec["open"],
                "high": rec["high"],
                "low": rec["low"],
                "close": rec["close"],
                "volume": rec["volume"],
            })
            i += 1

print("\nComputed summarized rows:")
for idx, rec in enumerate(summarized, start=2):
    print(idx, [rec["date"], rec["stock_raw"], rec["open"], rec["high"], rec["low"], rec["close"], rec["volume"]])

# Verify target sheet before writing
print("\nCurrent output sheet rows before writing:")
for r in range(1, ws_out.max_row + 1):
    print(r, [ws_out.cell(r, c).value for c in range(1, 8)])

# Clear existing data rows in output sheet (rows 2 onward, cols A:G only)
for r in range(2, max(ws_out.max_row, len(summarized) + 1) + 1):
    for c in range(1, 8):
        ws_out.cell(r, c).value = None

# Ensure header matches existing structure
headers = [ws_out.cell(1, c).value for c in range(1, 8)]
print("\nOutput headers:", headers)

# Write summarized data
for r, rec in enumerate(summarized, start=2):
    ws_out.cell(r, 1).value = rec["date"]
    ws_out.cell(r, 2).value = rec["stock_raw"]
    ws_out.cell(r, 3).value = rec["open"]
    ws_out.cell(r, 4).value = rec["high"]
    ws_out.cell(r, 5).value = rec["low"]
    ws_out.cell(r, 6).value = rec["close"]
    ws_out.cell(r, 7).value = rec["volume"]

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
res = await recalculate(outfile)
print("Recalculate:", res)

# Reload and restore sheet names if necessary
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
original_names = ["input", "output"]
if wb2.sheetnames != original_names:
    for i, expected in enumerate(original_names):
        wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Restored sheet names to:", wb2.sheetnames)

# Verify with data_only
verify = load_workbook(outfile, data_only=True)
print("\nVerified output sheet rows:")
vws = verify["output"]
for r in range(1, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, 8)]
    if any(v is not None for v in vals):
        print(r, vals)

output_spreadsheet = outfile
