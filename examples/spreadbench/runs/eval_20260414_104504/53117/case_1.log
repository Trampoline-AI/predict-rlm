from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

last_row = ws.max_row
print("Writing formulas to target column D on sheet:", ws.title, "rows 2 to", last_row)
print("Header D1:", ws["D1"].value)

# bounded ranges per instructions / actual data extent
a_rng = f"$A$2:$A${last_row}"
b_rng = f"$B$2:$B${last_row}"
c_rng = f"$C$2:$C${last_row}"

written = []
preserved = []
for r in range(2, last_row + 1):
    dcell = ws.cell(r, 4)
    current = dcell.value
    # preserve existing example answers / nonblank values
    if current not in (None, ""):
        preserved.append((r, current))
        continue
    formula = (
        f'=IF(C{r}<>"US",C{r},'
        f'LOOKUP(2,1/((TEXT({a_rng},"0")=TEXT(A{r},"0"))*({c_rng}<>"US")*({b_rng}=MAX(IF((TEXT({a_rng},"0")=TEXT(A{r},"0"))*({c_rng}<>"US"),{b_rng})))),{c_rng}))'
    )
    dcell.value = formula
    written.append((r, formula))

print("Preserved existing D cells:", preserved[:10], "count=", len(preserved))
print("Wrote formulas to rows:", [r for r, _ in written])
if written:
    print("Sample formula:", written[0][1])

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and fix sheet names if recalculation changed them
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("\nVerification target D15:D27")
for r in range(15, last_row + 1):
    print(
        r,
        "A", ws_values.cell(r,1).value,
        "B", ws_values.cell(r,2).value,
        "C", ws_values.cell(r,3).value,
        "D_formula", ws_formula.cell(r,4).value,
        "D_value", ws_values.cell(r,4).value
    )

# Keep path for submit
output_path = outfile
