# Compute expected outputs in Python to infer exact pattern
def cust_key(v):
    # normalize mixed numeric/string customer IDs
    if v is None:
        return None
    s = str(v).strip()
    if s.endswith(".0"):
        s = s[:-2]
    return s

rows = []
for r in range(2, ws.max_row + 1):
    rows.append({
        "row": r,
        "cust": cust_key(ws.cell(r, 1).value),
        "total": ws.cell(r, 2).value,
        "country": ws.cell(r, 3).value,
        "current_d": ws.cell(r, 4).value,
    })

from collections import defaultdict
best = {}  # cust -> (max_total, country)
for rec in rows:
    if rec["country"] != "US" and isinstance(rec["total"], (int, float)):
        cur = best.get(rec["cust"])
        if cur is None or rec["total"] > cur[0]:
            best[rec["cust"]] = (rec["total"], rec["country"])

print("\nBest non-US country per customer:")
for k in sorted(best.keys())[:20]:
