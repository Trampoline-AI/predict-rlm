Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
ws1 = wb["Sheet1"]

# Confirm all matching rows from Sheet1
matches = []
for r in range(2, ws1.max_row + 1):
    a = ws1.cell(r, 1).value
    b = ws1.cell(r, 2).value
    c = ws1.cell(r, 3).value
    if b == "TELIVISION" or c == "CLASS III" or c == "CLASS IV":
        matches.append((r, [a, b, c]))

print("Total matching rows:", len(matches))
print("Matching source rows:")
for item in matches:
    print(item)

# Create or clear Sheet2 as instructed destination
if "Sheet2" in wb.sheetnames:
    ws2 = wb["Sheet2"]
else:
    ws2 = wb.create_sheet("Sheet2")

print("Before writing, Sheet2 A1:C10:")
for r in range(1, 11):
    print(r, [ws2.cell(r, c).value for c in range(1, 4)])

# Write headers in A2 and data starting A3
headers = [ws1.cell(1, c).value for c in range(1, 4)]
for c, val in enumerate(headers, start=1):
    ws2.cell(2, c).value = val

out_row = 3
for _, rowvals in matches:
    for c, val in enumerate(rowvals, start=1):
        ws2.cell(out_row, c).value = val
    out_row += 1

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
orig_names = wb.sheetnames
if wb_check.sheetnames != orig_names:
    for i, old in enumerate(orig_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = old
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_names)

# Verify output values using data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
ws2v = wb_verify["Sheet2"]
print("Sheet2 target range A2:C12 after write:")
for r in range(2, min(ws2v.max_row, 12) + 1):
    print(r, [ws2v.cell(r, c).value for c in range(1, 4)])

output_spreadsheet = outfile
```
