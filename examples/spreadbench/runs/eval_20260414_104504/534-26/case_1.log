import os
from datetime import datetime
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

src = input_spreadsheet
out = "/sandbox/output/output_spreadsheet/" + os.path.basename(src)

# Rebuild from original input, using the example answer pattern from Result.
wb = load_workbook(src)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]
result_ws = wb["Result"]

# Inspect exact expected kept columns from Result
result_row1 = [result_ws.cell(1, c).value for c in range(1, result_ws.max_column + 1)]
sheet1_row1_before = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Sheet1 row1 before:", sheet1_row1_before)
print("Result row1 expected pattern:", result_row1)

# Determine the cutoff implied by the example answer in Result: first date there is 2020-12-01
example_first_kept_date = result_ws.cell(1, 9).value
print("Example first kept date in Result I1:", example_first_kept_date)

cols_to_delete = []
for c in range(1, ws.max_column + 1):
    v = ws.cell(1, c).value
    if isinstance(v, datetime) and c >= 9 and v < example_first_kept_date:
        cols_to_delete.append((c, get_column_letter(c), v))
print("Columns to delete from Sheet1 based on Result example:", cols_to_delete)
print("Delete count:", len(cols_to_delete))

for c, letter, v in reversed(cols_to_delete):
    ws.delete_cols(c, 1)

sheet1_row1_after = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Sheet1 row1 after:", sheet1_row1_after)
print("Sheet1 now matches Result row1:", sheet1_row1_after == result_row1)

wb.save(out)
print("Saved:", out)

recalc_msg = await recalculate(out)
print("Recalculate:", recalc_msg)

# Reload and preserve original sheet names if recalc changed them
wb_check = load_workbook(out)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for i, desired in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = desired
    wb_check.save(out)
    print("Restored sheet names:", orig_sheetnames)

# Final verification
ver = load_workbook(out, data_only=True)
print("Verified sheet names:", ver.sheetnames)
for sname in ver.sheetnames:
    ws2 = ver[sname]
    row1 = [ws2.cell(1, c).value for c in range(1, ws2.max_column + 1)]
    print(f"{sname}: rows={ws2.max_row}, cols={ws2.max_column}, row1={row1}")

output_spreadsheet = out
