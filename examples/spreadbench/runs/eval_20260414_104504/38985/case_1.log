import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Detailed inspection around the actual used area
print("Merged ranges:", list(ws.merged_cells.ranges))
print("Used area rows 4:13 cols C:N")
for r in range(4, 14):
    vals = [ws.cell(r, c).value for c in range(3, 15)]
    print(r, vals)

# Inspect fills/values in target area D:I for rows 7:13
print("\nTable1 target area current values:")
for r in range(6, 14):
    row = {get_column_letter(c): ws.cell(r,c).value for c in range(3, 10)}
    print(r, row)

# Build mapping from Table 2 (L:N), only real data rows
mapping = {}
table2_rows = []
for r in range(7, ws.max_row + 1):
    key = ws.cell(r, 12).value  # L
    v1 = ws.cell(r, 13).value   # M
    v2 = ws.cell(r, 14).value   # N
    if key in (None, "", "…", "….."):
        continue
    table2_rows.append((r, key, v1, v2))
    mapping.setdefault(key, []).extend([v1, v2])

print("\nParsed table2 rows:", table2_rows)
print("Mapping:", mapping)

# Identify actual table1 data rows: rows with key in C and blank outputs in D onward, skip ellipsis rows
table1_rows = []
for r in range(7, ws.max_row + 1):
    key = ws.cell(r, 3).value
    if key in (None, "", "…", "….."):
        continue
    table1_rows.append((r, key))
print("Table1 rows:", table1_rows)

# Fill outputs across row from D onward, preserving existing nonblank values if already present
for r, key in table1_rows:
    values = mapping.get(key, [])
    for i, val in enumerate(values, start=4):  # D=4
        cell = ws.cell(r, i)
        if cell.value in (None, ""):
            cell.value = val

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# recalc and preserve sheet names
orig_names = wb.sheetnames[:]
res = await recalculate(out_path)
print("Recalc:", res)

wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to", orig_names)

# Verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("\nVerified target rows C:I")
for r in range(6, 14):
    print(r, [vws.cell(r,c).value for c in range(3, 10)])

output_spreadsheet = out_path
```
