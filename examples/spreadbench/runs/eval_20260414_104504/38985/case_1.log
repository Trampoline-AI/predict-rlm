import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n=== SHEET: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find non-empty rows/cols roughly
    headers1 = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    headers2 = [ws.cell(2,c).value for c in range(1, ws.max_column+1)] if ws.max_row >= 2 else []
    print("Row1 headers/values:", [(get_column_letter(i+1), headers1[i]) for i in range(len(headers1))])
    if headers2:
        print("Row2 values:", [(get_column_letter(i+1), headers2[i]) for i in range(len(headers2))])
    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print("\nFirst rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # print last 5 rows
    if ws.max_row > 10:
        print("\nLast rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
            print(r, vals)
    # formulas
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r,c,v))
    print("Formula cells count:", len(formulas))
    if formulas[:20]:
        print("Sample formulas:", formulas[:20])

for ws in wb.worksheets:
    sheet_info(ws)
