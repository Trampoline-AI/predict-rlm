        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
        print(r, vals)
    print("A2 current:", ws["A2"].value, "B2 current:", ws["B2"].value)
    if ws.max_row >= 3:
        print("A3 current:", ws["A3"].value, "B3 current:", ws["B3"].value)

for ws in wb.worksheets:
    sheet_info(ws)
