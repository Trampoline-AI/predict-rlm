This returns text up to the second space. We'll apply it to all relevant data rows where column B has data and column C is blank, save to the output path with same filename, recalculate, reload, verify target cells, and ensure sheet name remains `Sheet1`.
Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before write:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Fill Result Should Be column (C) for rows with Employee data in B
for r in range(2, ws.max_row + 1):
    employee_val = ws.cell(r, 2).value
    target = ws.cell(r, 3)
    print(f"Row {r}: B={employee_val!r}, C before={target.value!r}")
    if employee_val not in (None, "") and target.value in (None, ""):
        target.value = f'=LEFT(B{r},FIND(" ",B{r},FIND(" ",B{r})+1)-1)'
        print(f"  wrote formula to C{r}: {target.value}")
    else:
        print(f"  preserved C{r}")

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Restore original sheet names if recalculation changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_names:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring to", orig_names)
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_names[0]]
print("After save, formulas in target cells:")
for r in range(2, wsf.max_row + 1):
    print(f"C{r} formula/value:", wsf.cell(r, 3).value)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[orig_names[0]]
print("After recalc, target values:")
for r in range(2, wsv.max_row + 1):
    print(f"Row {r}: B={wsv.cell(r,2).value!r}, C={wsv.cell(r,3).value!r}")

output_spreadsheet = outfile
```
