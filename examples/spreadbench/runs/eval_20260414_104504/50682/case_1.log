import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction preview:", instruction[:800], "...\n")

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row2 values:", row_values(ws, 2, ws.max_column))
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    print("Last rows:")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        print(r, row_values(ws, r, ws.max_column))

    # print columns A:M and O onward headers with letters
    print("Column letters/row1 values:")
    for c in range(1, ws.max_column+1):
        print(f"{get_column_letter(c)}{1}={ws.cell(1,c).value!r}", end=" | ")
    print()

    # target/current relevant cells
    for coord in ["A2", "M2"]:
        print(f"{coord} ->", ws[coord].value)
    # show row 2 from A through maybe Z or max_col
    max_show = min(ws.max_column, 30)
    print("Row 2 detailed A:{}".format(get_column_letter(max_show)))
    for c in range(1, max_show+1):
        print(f"{get_column_letter(c)}2={ws.cell(2,c).value!r}", end=" | ")
    print()

    # Show formulas/values in M column first 10 rows
    print("M column first 10 rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        print(r, ws.cell(r, 13).value)

    # Show O onward rows 1-5 for understanding
    start_c = 15
    if ws.max_column >= start_c:
        end_c = min(ws.max_column, start_c + 15)
        print(f"O onward sample columns {get_column_letter(start_c)}:{get_column_letter(end_c)} row1-5")
        for r in range(1, min(ws.max_row, 5)+1):
