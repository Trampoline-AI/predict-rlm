print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for sh, orig_name in zip(wb_check.worksheets, orig_sheetnames):
        sh.title = orig_name
    wb_check.save(outfile)
