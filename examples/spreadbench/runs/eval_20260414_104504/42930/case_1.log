from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from collections import defaultdict

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Inspect target/source columns and existing values/formulas")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

print("\nColumn C existing cell types/values:")
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 3).value
    print(r, repr(v))

print("\nExample mapping in E:F")
example_map = []
for r in range(2, ws.max_row + 1):
    e = ws.cell(r, 5).value
    f = ws.cell(r, 6).value
    if e is not None or f is not None:
        example_map.append((r, e, f))
print(example_map)

# Compute mapping from earliest built year per subdivision
earliest = {}
rows_to_fill = []
for r in range(2, ws.max_row + 1):
    year = ws.cell(r, 1).value
    subdiv = ws.cell(r, 2).value
    if year is None and subdiv is None:
        continue
    rows_to_fill.append(r)
    if subdiv is not None and year is not None:
        if subdiv not in earliest or year < earliest[subdiv]:
            earliest[subdiv] = year

computed_order = sorted(earliest.items(), key=lambda kv: (kv[1], str(kv[0])))
computed_map = {subdiv: i+1 for i, (subdiv, yr) in enumerate(computed_order)}

print("\nEarliest year per subdivision:", earliest)
print("Computed order:", computed_order)
print("Computed map:", computed_map)

# Verify against provided examples in E:F
mismatches = []
for r, e, f in example_map:
    if e in computed_map and computed_map[e] != f:
        mismatches.append((r, e, f, computed_map[e]))
print("Example mismatches:", mismatches)

# Fill column C for all populated data rows
for r in rows_to_fill:
    subdiv = ws.cell(r, 2).value
    if subdiv in computed_map:
        ws.cell(r, 3).value = computed_map[subdiv]

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

res = await recalculate(out_path)
print("Recalculate:", res)

# Reload and verify target cells plus sheet names
wb2 = load_workbook(out_path, data_only=False)
print("Post-recalc sheet names:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    old_sheets = wb2.sheetnames[:]
    # rename by position back to original
    for i, name in enumerate(wb.sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back from", old_sheets, "to", wb.sheetnames)

wbv = load_workbook(out_path, data_only=True)
wsv = wbv[wb.sheetnames[0]]
print("\nVerified C2:C22 values with A/B context:")
for r in range(2, ws.max_row + 1):
    print(r, wsv.cell(r,1).value, wsv.cell(r,2).value, wsv.cell(r,3).value)

output_spreadsheet = out_path
