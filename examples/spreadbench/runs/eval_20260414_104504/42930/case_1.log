import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1)
    print("Headers row 1:")
    for i, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)}{1}: {h}")
    # also inspect row 2 in case headers aren't in row 1
    if ws.max_row >= 2:
        print("Row 2 preview:", row_values(ws, 2))
    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r))
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r))

    # search likely header keywords
    keywords = ["subdivision", "built", "year", "house", "date", "neighborhood", "tract"]
    matches = []
    for c in range(1, ws.max_column+1):
        v = ws.cell(1, c).value
        if isinstance(v, str):
            low = v.lower()
            if any(k in low for k in keywords):
                matches.append((get_column_letter(c), c, v))
    print("Likely relevant headers:", matches)
