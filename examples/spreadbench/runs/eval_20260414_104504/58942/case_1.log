import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Inspect existing target cells/formulas in B2:C11 before modifying
print("Pre-modification B2:C11:")
for r in range(2, 12):
    print(r, repr(ws[f"B{r}"].value), repr(ws[f"C{r}"].value))

# Write formulas to align source dates/values to the timeline in A2:A11
for r in range(2, 12):
    ws[f"B{r}"] = f'=IF(COUNTIF($E$2:$E$6,A{r})>0,A{r},"")'
    ws[f"C{r}"] = f'=IFERROR(INDEX($F$2:$F$6,MATCH(A{r},$E$2:$E$6,0)),"")'

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet name if recalculation changed it
orig_sheetnames = ["Sheet1"]
wb_check = load_workbook(out_path)
print("Post-recalc sheetnames:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for old, new in zip(wb_check.sheetnames, orig_sheetnames):
        wb_check[old].title = new
    wb_check.save(out_path)
    print("Renamed sheets back to original:", wb_check.sheetnames)

# Verify computed values
wb_val = load_workbook(out_path, data_only=True)
ws_val = wb_val[orig_sheetnames[0]]
print("Verified B2:C11 values after recalc:")
for r in range(2, 12):
    print(r, ws_val[f"A{r}"].value, ws_val[f"B{r}"].value, ws_val[f"C{r}"].value)

output_spreadsheet = out_path
