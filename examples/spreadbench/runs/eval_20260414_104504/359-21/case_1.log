import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Delete"]

# Inspect exact target column and rows to be removed
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Headers:", headers)
print("Target column B header/value check:", ws["B1"].value)

rows_before = [
    [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    for r in range(1, ws.max_row + 1)
]
print("Rows before:", rows_before)

# Keep header + rows not matching delete conditions
delete_types = {"STATIONERY", "VEGETABLES"}
kept_rows = [rows_before[0]]
deleted_rows = []
for row in rows_before[1:]:
    if row[1] in delete_types:
        deleted_rows.append(row)
    else:
        kept_rows.append(row)

print("Rows marked for deletion:", deleted_rows)
print("Rows kept:", kept_rows)

# Rewrite sheet contents efficiently
# clear existing cells in used range
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# write kept rows back
for r_idx, row in enumerate(kept_rows, start=1):
    for c_idx, val in enumerate(row, start=1):
        ws.cell(r_idx, c_idx).value = val

# remove any trailing now-empty rows from original extent
extra = ws.max_row - len(kept_rows)
if extra > 0:
    ws.delete_rows(len(kept_rows) + 1, extra)

wb.save(outfile)

# recalculate and restore sheet names if needed
result = await recalculate(outfile)
print("Recalculate:", result)

wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    mapping = {}
    for i, old in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = old
    wb_check.save(outfile)

# Verify output after recalc
