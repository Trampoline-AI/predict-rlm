from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Inspect key cells and nearby rows:")
for coord in ["C2", "A13", "B13", "A14", "B14"]:
    cell = ws[coord]
    v = cell.value
    if hasattr(v, "text"):
        print(coord, "ArrayFormula text:", v.text)
    else:
        print(coord, "=", v)

print("\nRows 11-16, cols A:I")
for r in range(11, 17):
    vals = []
    for c in range(1, 10):
        v = ws.cell(r, c).value
        if hasattr(v, "text"):
            v = f"ArrayFormula:{v.text}"
        vals.append(v)
    print(r, vals)

print("\nSource rows 4:10 cols A,B,I")
for r in range(4, 11):
    print(r, {"A": ws[f"A{r}"].value, "B": ws[f"B{r}"].value, "I": ws[f"I{r}"].value})

# Apply formula to B13: sum B where I contains text in A13 but contains no digits
# Use SUMPRODUCT for LibreOffice compatibility.
digit_checks = "*".join([f'ISERROR(SEARCH("{d}",$I$4:$I$10))' for d in range(10)])
formula_b13 = f'=SUMPRODUCT(--ISNUMBER(SEARCH(A13,$I$4:$I$10)),--ISTEXT($I$4:$I$10),--({digit_checks}),$B$4:$B$10)'
print("\nNew B13 formula:", formula_b13)

ws["B13"] = formula_b13

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# recalc
res = await recalculate(out_path)
print("Recalc:", res)

# restore sheet names if changed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# verify
wbv = load_workbook(out_path, data_only=False)
wsv = wbv[orig_names[0]]
print("Verified formula B13:", wsv["B13"].value)

wbv2 = load_workbook(out_path, data_only=True)
wsv2 = wbv2[orig_names[0]]
print("Cached value B13:", wsv2["B13"].value)
print("A13:", wsv2["A13"].value, "A14:", wsv2["A14"].value, "B14:", wsv["B14"].value if hasattr(wsv["B14"].value, "text") else wsv["B14"].value)
