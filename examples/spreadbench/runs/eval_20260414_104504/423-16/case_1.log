import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Border, Side
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)

test_ws = wb["Test"]
master_ws = wb["master"]

def fill_rgb(cell):
    try:
        if cell.fill and cell.fill.fill_type == "solid":
            return cell.fill.start_color.rgb
    except Exception:
        return None
    return None

# Inspect sample source formatting to infer border style
print("Sample source yellow cells with border styles:")
for r in [7, 14, 17, 23, 43]:
    c = test_ws.cell(r, 1)
    print(r, c.value, fill_rgb(c),
          c.border.left.style, c.border.right.style, c.border.top.style, c.border.bottom.style)

# Collect nonblank yellow cells from Test!A
yellow_values = []
yellow_rows_full = []
for r in range(1, test_ws.max_row + 1):
    c = test_ws.cell(r, 1)
    rgb = fill_rgb(c)
    if rgb in ("FFFFFF00", "00FFFF00", "FFFF00"):
        yellow_rows_full.append((r, c.value))
        if c.value is not None and str(c.value).strip() != "":
            yellow_values.append(c.value)

print("All yellow source rows:", yellow_rows_full)
print("Nonblank yellow values count:", len(yellow_values))
print("Nonblank yellow values:", yellow_values)

# Inspect current master row1 before writing
print("Master row1 before write:")
for c in range(1, max(master_ws.max_column, len(yellow_values)) + 1):
    cell = master_ws.cell(1, c)
    print(get_column_letter(c), cell.value, fill_rgb(cell),
          cell.border.left.style, cell.border.right.style, cell.border.top.style, cell.border.bottom.style)

# Use thin border as requested
thin = Side(style="thin", color="000000")
yellow_fill = PatternFill(fill_type="solid", start_color="FFFF00", end_color="FFFF00")
border = Border(left=thin, right=thin, top=thin, bottom=thin)

# Clear existing row 1 content/styles across used/output range, then write compact transposed values
clear_upto = max(master_ws.max_column, len(yellow_values))
for c in range(1, clear_upto + 1):
    cell = master_ws.cell(1, c)
    cell.value = None
    cell.fill = PatternFill(fill_type=None)
    cell.border = Border()

for idx, val in enumerate(yellow_values, start=1):
    cell = master_ws.cell(1, idx)
    cell.value = val
    cell.fill = yellow_fill
    cell.border = border

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and restore sheet names if needed
orig_names = ["master", "Test"]
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    # rename by position back to original
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify output
wbv = load_workbook(out_path, data_only=False)
m = wbv["master"]
print("Master row1 after write:")
for c in range(1, len(yellow_values) + 2):  # print one extra cell to ensure no blank interspersed
    cell = m.cell(1, c)
    print(get_column_letter(c), repr(cell.value), fill_rgb(cell),
          cell.border.left.style, cell.border.right.style, cell.border.top.style, cell.border.bottom.style)

# Explicit checks
written = [m.cell(1, c).value for c in range(1, len(yellow_values) + 1)]
extra = m.cell(1, len(yellow_values) + 1).value
print("Written values exactly:", written)
print("Expected equals written:", written == yellow_values)
print("Next cell after written range:", repr(extra))
