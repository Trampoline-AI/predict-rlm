def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find likely non-empty rows/cols
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    
    # print first 15 rows, all used columns up to 12 or max_col
    cols_to_show = min(ws.max_column, 12)
    headers = [f"{get_column_letter(c)}" for c in range(1, cols_to_show + 1)]
    print("Columns shown:", headers)
    for r in list(range(1, min(ws.max_row, 12) + 1)):
        vals = [ws.cell(r, c).value for c in range(1, cols_to_show + 1)]
        print(f"Row {r}: {vals}")
    if ws.max_row > 12:
        print("...")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, cols_to_show + 1)]
            print(f"Row {r}: {vals}")

for ws in wb.worksheets:
