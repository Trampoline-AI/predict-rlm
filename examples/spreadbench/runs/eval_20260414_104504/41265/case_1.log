import os, re, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Inspect exact target cells/formulas before modifying
for r in range(1, 7):
    print(f"Row {r}: D={ws[f'D{r}'].value!r}, E={ws[f'E{r}'].value!r}")

# Determine actual data extent for columns A/B and D/E
last_ab = 1
for r in range(ws.max_row, 0, -1):
    if ws[f"A{r}"].value is not None or ws[f"B{r}"].value is not None:
        last_ab = r
        break

last_d = 1
for r in range(ws.max_row, 0, -1):
    if ws[f"D{r}"].value is not None:
        last_d = r
        break

print("last_ab:", last_ab, "last_d:", last_d)

def tokenize(text):
    return re.findall(r"[A-Za-z0-9]+", str(text).lower())

# Compute sums: root must match a complete token in column A
results = {}
for r in range(2, last_d + 1):
    root = ws[f"D{r}"].value
    if root is None or str(root).strip() == "":
        continue
    root_tok = str(root).strip().lower()
    total = 0
    matched_rows = []
    for rr in range(2, last_ab + 1):
        kw = ws[f"A{rr}"].value
        vol = ws[f"B{rr}"].value
        tokens = tokenize(kw) if kw is not None else []
        if root_tok in tokens:
            total += float(vol) if vol is not None else 0
            matched_rows.append((rr, kw, vol))
    results[r] = total
    print(f"Root row {r} {root!r} matches:", matched_rows, "=> total", total)

# Write results into existing target column E
for r, total in results.items():
    ws[f"E{r}"] = int(total) if float(total).is_integer() else total

# Save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and ensure sheet names preserved
orig_names = wb.sheetnames[:]
wb2 = load_workbook(outfile)
print("Post-recalc sheet names:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    # rename back to original order/names
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_names)

# Verify output values after recalculation
wbv = load_workbook(outfile, data_only=True)
wsv = wbv[orig_names[0]]
print("Verification E2:E5:")
for r in range(2, last_d + 1):
    print(r, "D=", wsv[f"D{r}"].value, "E=", wsv[f"E{r}"].value)
