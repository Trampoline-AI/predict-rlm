from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # determine nonempty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_vals(ws, r, ws.max_column)
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("nonempty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    headers = row_vals(ws, 1, ws.max_column)
    print("Row1:", headers)
    if ws.max_row >= 2:
        print("Row2:", row_vals(ws, 2, ws.max_column))
    # first 10 nonempty rows
    print("First up to 10 nonempty rows:")
    for r in nonempty_rows[:10]:
        print(r, row_vals(ws, r, ws.max_column))
    print("Last up to 5 nonempty rows:")
    for r in nonempty_rows[-5:]:
        print(r, row_vals(ws, r, ws.max_column))
    # print formulas and coordinates
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formulas[:20], "total", len(formulas))
