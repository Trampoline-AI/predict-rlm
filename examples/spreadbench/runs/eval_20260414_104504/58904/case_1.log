from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify exact target column/cells before writing
print("Target cells before writing:")
for r in range(11, 18):
    print(f"A{r}={ws[f'A{r}'].value!r}, B{r}={ws[f'B{r}'].value!r}")
print("Column B index check:", column_index_from_string("B"))

data_range = "$C$3:$I$9"
for idx, letter in enumerate("ABCDEFG", start=11):
    formula = f'=SUMPRODUCT((LEFT({data_range},1)="{letter}")*IFERROR(VALUE(RIGHT({data_range},LEN({data_range})-1)),0))'
    ws[f"B{idx}"] = formula

print("\nWritten formulas:")
for r in range(11, 18):
    print(f"B{r} -> {ws[f'B{r}'].value}")

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring to", orig_sheetnames)
    for ws_obj, orig_name in zip(wb_after.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(outfile)
else:
    print("Sheet names after recalc:", wb_after.sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Sheet1"]

print("\nVerification of target cells B11:B17")
for idx, letter in enumerate("ABCDEFG", start=11):
    print(
        idx,
        ws_formula[f"A{idx}"].value,
        "formula:", ws_formula[f"B{idx}"].value,
        "value:", ws_vals[f"B{idx}"].value
    )

output_spreadsheet = outfile
