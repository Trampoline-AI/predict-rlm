```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Re-open fresh workbook for modification
wb = load_workbook(infile)
src = wb["imported Data"]
dst = wb["summary Limits"]
original_sheetnames = wb.sheetnames[:]

# Extra inspection of exact target area before writing
print("Before write - destination sheet title:", dst.title)
print("Destination dimensions:", dst.max_row, dst.max_column)
for r in range(1, 6):
    vals = [dst.cell(r, c).value for c in range(1, 6)]
    print("dest row", r, vals)

# Find rows to copy from source
rows_to_copy = []
for r in range(1, src.max_row + 1):
    a = src.cell(r, 1).value
    if isinstance(a, str) and a.startswith("**"):
        last_nonempty = 0
        for c in range(1, src.max_column + 1):
            if src.cell(r, c).value not in (None, ""):
                last_nonempty = c
        row_vals = [src.cell(r, c).value for c in range(1, last_nonempty + 1)]
        rows_to_copy.append((r, last_nonempty, row_vals))

print("Rows to copy:", rows_to_copy)

# Determine first empty row in destination
first_empty = 1
while True:
    if all(dst.cell(first_empty, c).value in (None, "") for c in range(1, max(dst.max_column, 4) + 1)):
        break
    first_empty += 1
print("First empty destination row:", first_empty)

# Write rows sequentially
for i, (_, last_nonempty, row_vals) in enumerate(rows_to_copy):
    dest_row = first_empty + i
    for c, val in enumerate(row_vals, start=1):
        dst.cell(dest_row, c).value = val

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for ws_obj, orig_name in zip(wb_check.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify output values after recalculation
wb_verify = load_workbook(outfile, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
dstv = wb_verify["summary Limits"]

# Print target range written
for r in range(1, len(rows_to_copy) + 3):
    vals = [dstv.cell(r, c).value for c in range(1, 5)]
    print("verified dest row", r, vals)

output_spreadsheet = outfile
```
