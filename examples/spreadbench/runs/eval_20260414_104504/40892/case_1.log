```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb["Sheet1"]

# Inspect existing formulas/values in target cells
print("Existing B2:B17 values/types before write:")
for r in range(2, ws.max_row + 1):
    v = ws[f"B{r}"].value
    print(r, repr(v), type(v).__name__)

# Build valid color list from column D, excluding header-like/non-color entries, preserving order
raw_d = [ws[f"D{r}"].value for r in range(2, ws.max_row + 1)]
print("Raw D values:", raw_d)
colors = []
seen = set()
for v in raw_d:
    if isinstance(v, str):
        s = v.strip()
        if s and s.lower() not in {"list", "colour", "color"} and s.lower() not in seen:
            colors.append(s)
            seen.add(s.lower())
print("Parsed color list:", colors)

# Create nested IF/SEARCH formula
def make_formula(a_ref, colors):
    formula = '""'
    for color in reversed(colors):
        # SEARCH is case-insensitive; IFERROR handles no match
        formula = f'IF(IFERROR(SEARCH("{color}",{a_ref}),0)>0,"{color}",{formula})'
    return "=" + formula

# Write formulas only into blank target cells with non-empty source A
for r in range(2, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    if a not in (None, "") and (b is None or b == ""):
        ws[f"B{r}"] = make_formula(f"A{r}", colors)

print("Formulas written in B5:B17:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"B{r}"].value)

# Save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and fix sheet name if changed
orig_names = wb.sheetnames
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_names:
    for i, old in enumerate(orig_names):
        if i < len(wb2.sheetnames):
            wb2[wb2.sheetnames[i]].title = old
    wb2.save(outfile)
    print("Renamed sheets back:", wb2.sheetnames)
else:
    print("Sheet names preserved:", wb2.sheetnames)

# Verify with data_only
ver = load_workbook(outfile, data_only=True)
vws = ver[orig_names[0]]
print("Verified A/B/D rows 2:17 after recalc:")
for r in range(2, vws.max_row + 1):
    print(r, vws[f"A{r}"].value, "|", vws[f"B{r}"].value, "|", vws[f"D{r}"].value)

output_spreadsheet = outfile
