from openpyxl import load_workbook
from copy import copy
from collections import Counter
import os

wb = load_workbook(input_spreadsheet)
target_name = "Consolidate_ALL"
tws = wb[target_name]

source_names = [s for s in wb.sheetnames if s != target_name]

# Map source columns -> target A:K
source_cols = [1,3,4,5,6,7,14,15,16,17,18]

def norm(v):
    # keep datetimes/bools/numbers/strings comparable without adding whitespace noise
    if isinstance(v, str):
        return v.strip()
    return v

def row_key_from_source(ws, r, sheet_name):
    vals = [norm(ws.cell(r, c).value) for c in source_cols]
    vals.append(sheet_name)  # target L
    return tuple(vals)

def row_key_from_target(ws, r):
    vals = [norm(ws.cell(r, c).value) for c in range(1, 13)]
    return tuple(vals)

# determine last non-empty row in target A:L
last_nonempty = 0
for r in range(1, tws.max_row + 1):
    if any(tws.cell(r, c).value not in (None, "") for c in range(1, 13)):
        last_nonempty = r
first_blank_row = last_nonempty + 1

# existing target data and counts
existing_keys = set()
target_sheet_counter = Counter()
for r in range(2, last_nonempty + 1):
    k = row_key_from_target(tws, r)
    existing_keys.add(k)
    target_sheet_counter[norm(tws.cell(r, 12).value)] += 1

source_counts = {}
missing_rows = []
for s in source_names:
    ws = wb[s]
    source_counts[s] = max(0, ws.max_row - 1)
    for r in range(2, ws.max_row + 1):
        k = row_key_from_source(ws, r, s)
        if k not in existing_keys:
            missing_rows.append((s, r, k))

print("Source counts:", source_counts, "total", sum(source_counts.values()))
print("Existing target sheet-name counts:", dict(target_sheet_counter), "total", sum(target_sheet_counter.values()))
print("last_nonempty:", last_nonempty, "first_blank_row:", first_blank_row)
print("Missing rows count:", len(missing_rows))
print("First 10 missing rows:", missing_rows[:10])

# Append only missing rows, if any
if missing_rows:
    # use previous data row as formatting template
    template_row = last_nonempty if last_nonempty >= 2 else 2

    for s, src_r, k in missing_rows:
        dest_r = first_blank_row
        vals = list(k)  # A:L
        for c, v in enumerate(vals, start=1):
            cell = tws.cell(dest_r, c)
            cell.value = v

            # copy formatting/layout from template row same column
            tmpl = tws.cell(template_row, c)
            if tmpl.has_style:
                cell._style = copy(tmpl._style)
            if tmpl.number_format:
                cell.number_format = tmpl.number_format
            if tmpl.font:
                cell.font = copy(tmpl.font)
            if tmpl.border:
                cell.border = copy(tmpl.border)
            if tmpl.alignment:
                cell.alignment = copy(tmpl.alignment)
            if tmpl.protection:
                cell.protection = copy(tmpl.protection)

            # do NOT carry over fill colors into appended data cells
            cell.fill = copy(tmpl.fill)
            cell.fill.fill_type = None

        # copy row height if set
        if template_row in tws.row_dimensions and tws.row_dimensions[template_row].height:
            tws.row_dimensions[dest_r].height = tws.row_dimensions[template_row].height

        first_blank_row += 1

# Save output
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# recalculate and restore sheet names if needed
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    # rename back by position
    for i, old in enumerate(orig_names):
        wb2.worksheets[i].title = old
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# verify after reload
vwb = load_workbook(out_path, data_only=True)
vtws = vwb[target_name]
verify_last = 0
for r in range(1, vtws.max_row + 1):
    if any(vtws.cell(r, c).value not in (None, "") for c in range(1, 13)):
        verify_last = r

verify_counter = Counter()
for r in range(2, verify_last + 1):
    verify_counter[norm(vtws.cell(r, 12).value)] += 1

print("Verified target sheet counts:", dict(verify_counter), "total", sum(verify_counter.values()))
print("Verified last nonempty row:", verify_last)
for r in range(max(2, verify_last-4), verify_last+1):
    print("target row", r, [vtws.cell(r,c).value for c in range(1,13)])

final_output_path = out_path
