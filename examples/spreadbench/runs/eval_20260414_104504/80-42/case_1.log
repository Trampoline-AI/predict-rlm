from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from copy import copy
from collections import Counter
import os

# Re-open original workbook fresh
wb = load_workbook(input_spreadsheet)
target_name = "Consolidate_ALL"
tws = wb[target_name]
source_names = [s for s in wb.sheetnames if s != target_name]

# Yellow-highlighted/source columns mapped into target A:K, with source sheet name in L
source_cols = [1, 3, 4, 5, 6, 7, 14, 15, 16, 17, 18]

def norm(v):
    return v.strip() if isinstance(v, str) else v

def source_tuple(ws, r, sheet_name):
    vals = [norm(ws.cell(r, c).value) for c in source_cols]
    vals.append(sheet_name)
    return tuple(vals)

def target_tuple(ws, r):
    return tuple(norm(ws.cell(r, c).value) for c in range(1, 13))

# Find last used row in target A:L
last_nonempty = 0
for r in range(1, tws.max_row + 1):
    if any(tws.cell(r, c).value not in (None, "") for c in range(1, 13)):
        last_nonempty = r
first_blank_row = last_nonempty + 1

# Existing target rows/counts
existing_keys = set()
target_counts = Counter()
for r in range(2, last_nonempty + 1):
    k = target_tuple(tws, r)
    existing_keys.add(k)
    target_counts[norm(tws.cell(r, 12).value)] += 1

# Compute missing rows only (avoid duplicates)
source_counts = {}
missing_rows = []
missing_by_sheet = Counter()

for s in source_names:
    ws = wb[s]
    source_counts[s] = max(0, ws.max_row - 1)
    for r in range(2, ws.max_row + 1):
        k = source_tuple(ws, r, s)
        if k not in existing_keys:
            missing_rows.append((s, r, k))
            missing_by_sheet[s] += 1

print("Source counts:", dict(source_counts), "total", sum(source_counts.values()))
print("Existing target counts:", dict(target_counts), "total", sum(target_counts.values()))
print("Target last_nonempty:", last_nonempty, "first_blank_row:", first_blank_row)
print("Missing by sheet:", dict(missing_by_sheet), "total missing:", len(missing_rows))
print("Sample missing rows:", missing_rows[:5])

# Append missing rows with matching formatting/layout, but no fill colors
if missing_rows:
    template_row = 2 if last_nonempty < 2 else last_nonempty
    no_fill = PatternFill(fill_type=None)

    for s, src_r, vals in missing_rows:
        dest_r = first_blank_row
        for c, v in enumerate(vals, start=1):
            dest = tws.cell(dest_r, c)
            dest.value = v

            tmpl = tws.cell(template_row, c)
            if tmpl.has_style:
                dest._style = copy(tmpl._style)
            dest.font = copy(tmpl.font)
            dest.border = copy(tmpl.border)
            dest.alignment = copy(tmpl.alignment)
            dest.number_format = tmpl.number_format
            dest.protection = copy(tmpl.protection)
            dest.fill = copy(no_fill)  # explicitly no fill color

        if tws.row_dimensions[template_row].height is not None:
            tws.row_dimensions[dest_r].height = tws.row_dimensions[template_row].height

        first_blank_row += 1

out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved:", out_path)

orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalc result:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names:
    for i, nm in enumerate(orig_names):
        wb_check.worksheets[i].title = nm
    wb_check.save(out_path)
    print("Restored sheet names:", wb_check.sheetnames)

# Verification
vwb = load_workbook(out_path, data_only=True)
vtws = vwb[target_name]

verify_last = 0
for r in range(1, vtws.max_row + 1):
    if any(vtws.cell(r, c).value not in (None, "") for c in range(1, 13)):
        verify_last = r

verify_counts = Counter()
for r in range(2, verify_last + 1):
    verify_counts[norm(vtws.cell(r, 12).value)] += 1

print("Verified sheet names:", vwb.sheetnames)
print("Verified target counts:", dict(verify_counts), "total", sum(verify_counts.values()))
print("Verified last used row:", verify_last)
for r in range(max(2, verify_last - 4), verify_last + 1):
    print(r, [vtws.cell(r, c).value for c in range(1, 13)])

