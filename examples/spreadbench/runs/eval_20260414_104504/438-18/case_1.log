import os, shutil
from openpyxl import load_workbook

src_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src_path))
shutil.copy(src_path, out_path)

wb = load_workbook(out_path)
orig_sheetnames = wb.sheetnames[:]
ws_in = wb["INPUT"]
ws_out = wb["OUPUT"]

# confirm existing formulas/values in target area before writing
print("Existing OUPUT rows before write:")
for r in range(1, ws_out.max_row + 1):
    print(r, [ws_out.cell(r, c).value for c in range(1, ws_out.max_column + 1)])

mapping = {
    "UNATIDE STATES AMERICAN": "USA",
    "FRANCE": "FRA",
    "KOREA": "KOR",
    "GERMANY": "GR",
    "ITALY": "IT",
}

# Ensure header remains as existing
headers = [ws_out.cell(1, c).value for c in range(1, 5)]
print("Verified target headers:", headers)

# clear existing output body in current used rows/cols only
for r in range(2, ws_out.max_row + 1):
    for c in range(1, 5):
        ws_out.cell(r, c).value = None

# write transformed data from INPUT rows with actual data
out_row = 2
for r in range(2, ws_in.max_row + 1):
    item = ws_in.cell(r, 1).value
    brand = ws_in.cell(r, 3).value
    typ = ws_in.cell(r, 5).value
    origin = ws_in.cell(r, 6).value
    if all(v in (None, "") for v in [item, brand, typ, origin]):
        continue
    ws_out.cell(out_row, 1).value = item
    ws_out.cell(out_row, 2).value = brand
    ws_out.cell(out_row, 3).value = typ
    ws_out.cell(out_row, 4).value = mapping.get(origin, origin)
    out_row += 1

wb.save(out_path)
print("Saved:", out_path)

recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# reload, restore sheet names if changed
wb2 = load_workbook(out_path)
print("Sheetnames after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position back to original names
    for i, desired in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = desired
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# verify output values after recalc/data_only
verify = load_workbook(out_path, data_only=True)
print("Verified final sheetnames:", verify.sheetnames)
vout = verify["OUPUT"]
print("Verified target range A1:D10:")
for r in range(1, min(10, vout.max_row) + 1):
    print(r, [vout.cell(r, c).value for c in range(1, 5)])

output_spreadsheet = out_path
