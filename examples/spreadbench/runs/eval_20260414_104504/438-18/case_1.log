import os, shutil, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def nonempty_row_count(ws):
    last = 0
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            last = r
    return last

for s in wb.sheetnames:
    ws = wb[s]
    last_row = nonempty_row_count(ws)
    headers1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print(f"\nSheet: {s}")
    print("max_row/max_col:", ws.max_row, ws.max_column, "last_nonempty_row:", last_row)
    print("Row1 headers/values:", headers1)
    if headers2:
        print("Row2 values:", headers2)
    sample_first_end = min(last_row, 10)
    print("First rows:")
    for r in range(1, sample_first_end + 1):
        row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, row)
    if last_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, last_row - 4), last_row + 1):
            row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(r, row)

# inspect likely INPUT/OUTPUT sheets and column F current values
for target_name in ["sheet INPUT", "sheet OUTPUT", "INPUT", "OUTPUT"]:
    if target_name in wb.sheetnames:
        ws = wb[target_name]
        print(f"\nDetailed inspection for {target_name}:")
        for r in range(1, min(nonempty_row_count(ws), 15) + 1):
            print(r, {get_column_letter(c): ws.cell(r,c).value for c in range(1, ws.max_column+1)})
        print("Column F sample values:")
        last_row = nonempty_row_count(ws)
        vals = []
        for r in range(1, last_row + 1):
            v = ws.cell(r, 6).value
            if v not in (None, ""):
                vals.append((r, v))
