    rows.append([
        r,
        ws.cell(r,1).value,
        ws.cell(r,2).value,
        ws.cell(r,3).value,
        ws.cell(r,4).value,
        ws.cell(r,5).value,
        ws.cell(r,6).value if ws.max_column >= 6 else None
    ])

print("First 15 rows:")
for x in rows[:15]:
    print(x)

print("\nRows around transitions (employee/week changes):")
for i in range(2, len(rows)):
    prev = rows[i-1]
    cur = rows[i]
    if prev[2] != cur[2] or prev[5] != cur[5]:
        print("prev", prev)
        print("cur ", cur)
        print("---")

print("\nLast 15 rows:")
for x in rows[-15:]:
    print(x)

# Check whether column F exists via style/format and whether cells there are blank/formatted
