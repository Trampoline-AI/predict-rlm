    emp = ws.cell(r,2).value
    wk = ws.cell(r,5).value
    prev_emp = ws.cell(r-1,2).value if r > 2 else ws.cell(1,2).value
    prev_wk = ws.cell(r-1,5).value if r > 2 else ws.cell(1,5).value
    is_start = (r == 2) or (emp != prev_emp) or (wk != prev_wk)
