import os, shutil, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(input_path), input_path)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

def sheet_summary(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\nSheet: {ws.title} | rows={max_row} cols={max_col}")
    print("First-row headers sample (first 20):")
    print([(get_column_letter(i), headers[i-1]) for i in range(1, min(max_col, 20)+1)])
    if max_col > 20:
        print("First-row headers sample (last 10):")
        start = max(1, max_col-9)
        print([(get_column_letter(i), headers[i-1]) for i in range(start, max_col+1)])
    # rows 1-10 and last 5, first up to 12 cols
    show_cols = min(12, max_col)
    print("Sample first rows:")
    for r in range(1, min(max_row, 10)+1):
        vals = [ws.cell(r, c).value for c in range(1, show_cols+1)]
        print(f"Row {r}: {vals}")
    print("Sample last rows:")
    for r in range(max(1, max_row-4), max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, show_cols+1)]
        print(f"Row {r}: {vals}")
    # target columns
    target_cols = []
    for c in range(1, max_col+1):
        v = ws.cell(1, c).value
        if isinstance(v, str) and "/description" in v:
            target_cols.append((c, get_column_letter(c), v))
    print("Columns with '/description' in row 1:", target_cols[:50], "count=", len(target_cols))
    return target_cols

targets_by_sheet = {}
for ws in wb.worksheets:
    targets_by_sheet[ws.title] = sheet_summary(ws)

# Perform deletion on sheets where row1 has matching columns
for ws in wb.worksheets:
    targets = targets_by_sheet[ws.title]
    if not targets:
        continue
    # delete right-to-left
    for c, letter, header in sorted(targets, reverse=True):
        ws.delete_cols(c, 1)

output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))
wb.save(output_path)
print("\nSaved to:", output_path)

# recalculate
result = await recalculate(output_path)
print("Recalculate:", result)

# reload after recalc, restore sheet names if changed
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheet_names and len(wb2.sheetnames) == len(original_sheet_names):
    for ws, orig_name in zip(wb2.worksheets, original_sheet_names):
        ws.title = orig_name
    wb2.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# verify
wbv = load_workbook(output_path, data_only=True)
print("\nVerification:")
for ws in wbv.worksheets:
    remaining = []
    for c in range(1, ws.max_column+1):
        v = ws.cell(1, c).value
        if isinstance(v, str) and "/description" in v:
            remaining.append((c, get_column_letter(c), v))
    print(f"{ws.title}: remaining '/description' headers =", remaining, "count=", len(remaining))
    print("New first-row sample:", [(get_column_letter(i), ws.cell(1,i).value) for i in range(1, min(ws.max_column, 20)+1)])

final_output_path = output_path
print("Final output path variable set.")
