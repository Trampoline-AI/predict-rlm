import os, re, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
print("Sheet names:", orig_sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n=== Sheet: {s} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    
    # detect non-empty counts per column
    nonempty = []
    for c in range(1, ws.max_column + 1):
        vals = [ws.cell(r, c).value for r in range(1, ws.max_row + 1)]
        count = sum(v not in (None, "") for v in vals)
        sample = next((v for v in vals if v not in (None, "")), None)
        nonempty.append((get_column_letter(c), count, sample))
    print("Column non-empty/sample:", nonempty)
    
    # sample first 10 rows
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # sample last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # find cells matching target pattern anywhere
    pat400 = re.compile(r"^400-.*")
    patA = re.compile(r"^400-.*-A$")
    matches = []
    matchesA = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                vv = v.strip()
                if pat400.match(vv):
                    matches.append((r, c, vv))
                if patA.match(vv):
                    matchesA.append((r, c, vv))
    print("Rows/cells with values starting 400- (up to 20):", matches[:20], "count=", len(matches))
    print("Rows/cells with values matching 400-...-A (up to 20):", matchesA[:20], "count=", len(matchesA))
