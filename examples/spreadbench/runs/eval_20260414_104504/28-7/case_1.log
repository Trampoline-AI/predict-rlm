import os, re, shutil
from openpyxl import load_workbook

# Inspect all rows clearly to verify target range
wb2 = load_workbook(input_spreadsheet)
ws = wb2[wb2.sheetnames[0]]

print("Full row listing (A:E):")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

pat400 = re.compile(r"^400-.*")
patA = re.compile(r"^400-.*-A$")

colA_vals = [(r, ws.cell(r, 1).value) for r in range(1, ws.max_row + 1)]
print("Column A values:", colA_vals)

start_row = None
next_row = None
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and patA.match(v.strip()):
        start_row = r
        break

if start_row is not None:
    for r in range(start_row + 1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if isinstance(v, str) and pat400.match(v.strip()):
            next_row = r
            break

print("Matched start_row (-A):", start_row, "value:", ws.cell(start_row,1).value if start_row else None)
print("Next 400-* row:", next_row, "value:", ws.cell(next_row,1).value if next_row else None)

# Save output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

# Modify workbook
wb_out = load_workbook(out_path)
orig_names = wb_out.sheetnames[:]
ws_out = wb_out[orig_names[0]]

if start_row is not None and next_row is not None:
    delete_count = next_row - start_row
    print("Deleting rows", start_row, "to", next_row - 1, "count", delete_count)
    ws_out.delete_rows(start_row, delete_count)
else:
    print("No deletion performed due to missing required pattern.")

wb_out.save(out_path)
print("Saved:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    for i, nm in enumerate(orig_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = nm
    wb_check.save(out_path)
    print("Restored sheet names:", orig_names)

# Verify with data_only and normal workbook
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_names[0]]
print("Verified max_row:", wsv.max_row, "max_column:", wsv.max_column)
print("Verified full row listing (A:E):")
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 6)])

# Check remaining 400-* rows in column A
remaining = []
for r in range(1, wsv.max_row + 1):
    v = wsv.cell(r, 1).value
    if isinstance(v, str) and pat400.match(v.strip()):
        remaining.append((r, v))
print("Remaining 400-* rows:", remaining)

final_output_path = out_path
