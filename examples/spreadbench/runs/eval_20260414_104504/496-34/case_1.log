from openpyxl import load_workbook
from openpyxl.styles import Font
from copy import copy
import os

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Extra inspection before writing
print("Detailed style/formula inspection")
for r in range(1, 9):
    vals = [ws.cell(r,c).value for c in range(1,9)]
    nfs = [ws.cell(r,c).number_format for c in range(1,9)]
    bolds = [ws.cell(r,c).font.bold for c in range(1,9)]
    colors = [ws.cell(r,c).font.color.type + ":" + str(ws.cell(r,c).font.color.rgb) if ws.cell(r,c).font.color else None for c in range(1,9)]
    print("row", r, "vals", vals)
    print("   numfmts", nfs)
    print("   bolds  ", bolds)
    print("   colors ", colors)

# Gather merged values in col F before unmerge
f_merged_info = []
for mr in list(ws.merged_cells.ranges):
    min_col, min_row, max_col, max_row = mr.bounds
    if min_col <= 6 <= max_col:
        val = ws.cell(min_row, min_col).value
        f_merged_info.append((str(mr), min_row, max_row, val))
print("F merged info:", f_merged_info)

# Build deduplicated A:D rows based on first occurrence order
data_rows = []
seen = {}
for r in range(2, ws.max_row + 1):
    idv = ws.cell(r,1).value
    if idv in (None, ""):
        continue
    name = ws.cell(r,2).value
    dt = ws.cell(r,3).value
    amt = ws.cell(r,4).value
    if idv not in seen:
        seen[idv] = {"ID": idv, "Name": name, "Date": dt, "Amount": 0}
        data_rows.append(seen[idv])
    seen[idv]["Amount"] += int(round(amt or 0))
print("Deduped rows:", data_rows)

# Unmerge all merged cells
for mr in list(ws.merged_cells.ranges):
    ws.unmerge_cells(str(mr))

# Write deduped rows back to A:D starting row 2
start_row = 2
for i, rec in enumerate(data_rows, start=start_row):
    ws.cell(i,1).value = rec["ID"]
    ws.cell(i,2).value = rec["Name"]
    ws.cell(i,3).value = rec["Date"]
    ws.cell(i,4).value = rec["Amount"]

# Clear remaining old content in A:D only
for r in range(start_row + len(data_rows), ws.max_row + 1):
    for c in range(1,5):
        ws.cell(r,c).value = None

# Formatting for A:D data rows only
black = "FF000000"
for r in range(2, start_row + len(data_rows)):
    # A:D not bold, black
    for c in range(1,5):
        cell = ws.cell(r,c)
        cell.font = copy(cell.font)
        cell.font = cell.font.copy(bold=False, color=black) if hasattr(cell.font, "copy") else Font(name=cell.font.name, sz=cell.font.sz, b=False, i=cell.font.i, color=black)
    # Date format in C
    ws.cell(r,3).number_format = "m/dd/yyyy hh:ss"
    # Amount integer format in D
    ws.cell(r,4).number_format = "0"

# Reposition F values to first and last ID rows
for r in range(1, ws.max_row + 1):
    ws.cell(r,6).value = None
if f_merged_info:
    first_val = f_merged_info[0][3]
    last_val = f_merged_info[-1][3]
    ws.cell(2,6).value = first_val
    ws.cell(start_row + len(data_rows) - 1, 6).value = last_val

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalc:", result)

# Reload and restore sheet name if changed
wb2 = load_workbook(out_path)
print("Post-recalc sheetnames:", wb2.sheetnames)
orig_names = ["Sheet1"]
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for idx, nm in enumerate(orig_names):
        wb2.worksheets[idx].title = nm
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# Verification with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver["Sheet1"]
print("Verification rows 1:9 A:H")
for r in range(1,10):
    print(r, [vws.cell(r,c).value for c in range(1,9)])
print("Merged ranges after:", list(vws.merged_cells.ranges))
print("Target F cells:", vws["F2"].value, vws["F6"].value)
print("Date formats/source workbook check done separately in formula-free file.")
output_path = out_path
