import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
original_sheetnames = wb.sheetnames[:]

# Verify target area before writing
print("Pre-write Sheet1 E:F sample:")
for r in range(1, min(ws1.max_row, 6)+1):
    print(r, ws1[f"E{r}"].value, ws1[f"F{r}"].value)

print("Pre-write Sheet2 relevant headers/cols:")
for r in range(1, ws2.max_row+1):
    print(r, ws2[f"A{r}"].value, ws2[f"B{r}"].value, ws2[f"C{r}"].value)

# Create target headers in existing blank columns on Sheet1
ws1["E1"] = "Sheet2 Column B"
ws1["F1"] = "Sheet2 Column C"

last_row1 = ws1.max_row
last_row2 = ws2.max_row

# Write INDEX/MATCH formulas for all populated rows in Sheet1 based on D matching Sheet2 A
for r in range(2, last_row1 + 1):
    lookup_val = ws1[f"D{r}"].value
    if lookup_val not in (None, ""):
        ws1[f"E{r}"] = f'=INDEX(Sheet2!$B$2:$B${last_row2},MATCH($D{r},Sheet2!$A$2:$A${last_row2},0))'
        ws1[f"F{r}"] = f'=INDEX(Sheet2!$C$2:$C${last_row2},MATCH($D{r},Sheet2!$A$2:$A${last_row2},0))'

wb.save(outfile)
print("Saved to", outfile)

# recalculate
result = await recalculate(outfile)
print("Recalculate:", result)

# Restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    # rename by position
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws1f = wb_formula["Sheet1"]
print("Written formulas E1:F6:")
for r in range(1, min(6, ws1f.max_row)+1):
    print(r, ws1f[f"E{r}"].value, ws1f[f"F{r}"].value)

wb_vals = load_workbook(outfile, data_only=True)
ws1v = wb_vals["Sheet1"]
print("Cached values E1:F10 after recalc:")
for r in range(1, min(10, ws1v.max_row)+1):
    print(r, ws1v[f"E{r}"].value, ws1v[f"F{r}"].value)

output_spreadsheet = outfile
