import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Compute expected weighted averages in Python first for sanity-check
wb_in = load_workbook(infile)
ws = wb_in["Sheet1"]

def rows_for_fy(fy):
    vals = []
    for r in range(3, ws.max_row + 1):
        b = ws[f"B{r}"].value
        c = ws[f"C{r}"].value
        d = ws[f"D{r}"].value
        e = ws[f"E{r}"].value
        f = ws[f"F{r}"].value
        # Only detail rows with actual FY and numeric generation
        if b == fy and isinstance(c, (int, float)):
            vals.append((r, c, d, e, f))
    return vals

for rr in range(3, 7):
    fy = ws[f"H{rr}"].value
    rows = rows_for_fy(fy)
    total_gen = sum(x[1] for x in rows)
    wad = sum(x[1] * x[2] for x in rows) / total_gen if total_gen else None
    wae = sum(x[1] * x[3] for x in rows) / total_gen if total_gen else None
    waf = sum(x[1] * x[4] for x in rows) / total_gen if total_gen else None
    print("FY", fy, "matched rows", [x[0] for x in rows], "total_gen", total_gen)
    print("Expected weighted D/E/F:", wad, wae, waf)

# Copy workbook and write formulas only in J3:L6
shutil.copy(infile, outfile)
wb = load_workbook(outfile)
ws = wb["Sheet1"]

for r in range(3, 7):
    # Weighted average = SUMPRODUCT(weight, measure)/SUMIFS(weight, criterion)
    ws[f"J{r}"] = f'=SUMPRODUCT(($B$3:$B$43=H{r})*$C$3:$C$43*$D$3:$D$43)/I{r}'
    ws[f"K{r}"] = f'=SUMPRODUCT(($B$3:$B$43=H{r})*$C$3:$C$43*$E$3:$E$43)/I{r}'
    ws[f"L{r}"] = f'=SUMPRODUCT(($B$3:$B$43=H{r})*$C$3:$C$43*$F$3:$F$43)/I{r}'

print("Written formulas J3:L6:")
for r in range(3, 7):
    print(r, ws[f"J{r}"].value, ws[f"K{r}"].value, ws[f"L{r}"].value)

orig_names = wb.sheetnames[:]
wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_names and len(wb_check.sheetnames) == len(orig_names):
    for s, orig in zip(wb_check.worksheets, orig_names):
        s.title = orig
    wb_check.save(outfile)
    print("Restored sheet names to", orig_names)
else:
    print("Sheet names after recalc:", wb_check.sheetnames)

# Verify with data_only
wb_val = load_workbook(outfile, data_only=True)
wsv = wb_val[orig_names[0]]
print("Verified target cached values J3:L6:")
for r in range(3, 7):
    print(r, [wsv[f"{col}{r}"].value for col in "JKL"])

output_spreadsheet = outfile
```
