import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print("\n--- SHEET:", s, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers1 = row_vals(ws, 1, ws.max_column)
    headers2 = row_vals(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    # detect likely header row
    header_row = 1
    if all(v is None for v in headers1) and any(v is not None for v in headers2):
        header_row = 2
    print("Likely header row:", header_row)
    print("Column letters/headers:", [(get_column_letter(c), ws.cell(header_row, c).value) for c in range(1, ws.max_column+1)])
    
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_vals(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row-4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_vals(ws, r, ws.max_column))
    
    # print formulas/nonempty in used range
    formula_cells = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formula_cells[:20], "count=", len(formula_cells))
