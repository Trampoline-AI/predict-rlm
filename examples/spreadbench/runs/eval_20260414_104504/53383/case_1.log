import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]

ws1 = wb["worksheet 1"]
ws2 = wb["worksheet2"]

# Reconfirm target cells/area
print("Target sheet:", ws2.title)
for r in range(2, ws2.max_row + 1):
    print("Before", r, [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)])

# Determine actual data extent on worksheet 1 for lookup table
data_rows_ws1 = []
for r in range(3, ws1.max_row + 1):
    a = ws1.cell(r, 1).value
    b = ws1.cell(r, 2).value
    if a is not None or b is not None:
        data_rows_ws1.append(r)
lookup_start = min(data_rows_ws1)
lookup_end = max(data_rows_ws1)
lookup_range = f"'worksheet 1'!$A${lookup_start}:$B${lookup_end}"
print("Lookup range:", lookup_range)

# Fill only blanks in target column C for rows with names in worksheet2
for r in range(3, ws2.max_row + 1):
    name = ws2.cell(r, 1).value
    status = ws2.cell(r, 2).value
    target = ws2.cell(r, 3)
    print(f"Row {r}: name={name!r}, status={status!r}, current C={target.value!r}")
    if name is not None and status is not None and (target.value is None or str(target.value).strip() == ""):
        target.value = f'=IF(B{r}=VLOOKUP(A{r},{lookup_range},2,FALSE),"Matched","Not Matched")'
        print("  wrote formula:", target.value)

wb.save(outfile)
print("Saved to", outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and fix sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    sheets = wb_check.worksheets[:]
    for ws, original_name in zip(sheets, orig_sheetnames):
        ws.title = original_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
ws2f = wb_formula["worksheet2"]
print("Formulas/values in target range after save:")
for r in range(3, ws2f.max_row + 1):
    print(r, ws2f[f"A{r}"].value, ws2f[f"B{r}"].value, ws2f[f"C{r}"].value)

# Verify cached evaluated values
wb_values = load_workbook(outfile, data_only=True)
ws2v = wb_values["worksheet2"]
print("Evaluated target values:")
for r in range(3, ws2v.max_row + 1):
    print(r, ws2v[f"C{r}"].value)

output_spreadsheet = outfile
