from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload and inspect exact target cells/formulas
wb = load_workbook(infile)
ws = wb["Sheet1"]
for cell in ["A11","A12","A13","I2","I3","I4","I5","I6","I7"]:
    print(cell, "=", ws[cell].value)

# Determine source rows: data appears in A2:A7 with branch names, checked flags in I
unticked = []
for r in range(2, ws.max_row + 1):
    branch = ws[f"A{r}"].value
    tick = ws[f"I{r}"].value
    # stop considering rows once the source section ends / output section begins
    if r >= 11:
        break
    if branch not in (None, "", "Branches") and (tick is None or str(tick).strip() == ""):
        unticked.append(branch)

print("Unticked branches identified:", unticked)

# Write results in existing designated output area starting A13
start_row = 13
# clear old results below in column A only, but keep headers A11:A12
for r in range(start_row, ws.max_row + 1):
    ws[f"A{r}"] = None

for i, branch in enumerate(unticked, start=start_row):
    ws[f"A{i}"] = branch

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
res = await recalculate(outfile)
print("Recalc:", res)

# Verify and ensure sheet names preserved
orig_names = wb.sheetnames
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_names:
    print("Renaming sheets back:", wb2.sheetnames, "->", orig_names)
    # only handle same number of sheets
    for ws_obj, orig_name in zip(wb2.worksheets, orig_names):
        ws_obj.title = orig_name
    wb2.save(outfile)

# Reload data_only for verification
ver = load_workbook(outfile, data_only=True)
vws = ver["Sheet1"]
print("Verify target area:")
for r in range(11, 11 + max(5, len(unticked) + 2)):
    print(r, vws[f"A{r}"].value)

output_spreadsheet = outfile
