import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Reload original workbook for editing
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Determine actual last non-empty row in column A
last_row = 0
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 1).value not in (None, ""):
        last_row = r
print("Writing formulas to Sheet1!B1:B", last_row, sep="")

# Write formula in column B for every populated row in A
for r in range(1, last_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a not in (None, "") and b in (None, ""):
        ws.cell(r, 2).value = f'=A{r}&""'

wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and fix any sheet-name changes after recalc
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename sheets back by position
    for i, name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify output values after recalculation
wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals[orig_sheet_names[0]]

print("Verification samples for A and B:")
for r in list(range(1, 11)) + list(range(max(1, last_row-4), last_row+1)):
    print(r, "A=", repr(ws_vals.cell(r,1).value), "B=", repr(ws_vals.cell(r,2).value))

# Also verify formula strings in normal load
wb_form = load_workbook(outfile, data_only=False)
ws_form = wb_form[orig_sheet_names[0]]
print("Formula check B1:B5:")
for r in range(1, min(5, last_row) + 1):
    print(r, ws_form.cell(r,2).value)
