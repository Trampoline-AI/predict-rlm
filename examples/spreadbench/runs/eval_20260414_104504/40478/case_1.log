import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Verify target area before writing
print("Before write:")
for r in range(1, ws.max_row + 1):
    print(r, "A=", ws[f"A{r}"].value, "| B=", ws[f"B{r}"].value)

# Fill only blank cells in column B for rows that have source text in A
written = []
for r in range(1, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    if a not in (None, "") and b in (None, ""):
        formula = f'=TRIM(MID(A{r},FIND(" ",A{r},FIND(" ",A{r})+1)+1,FIND("-",A{r})-FIND(" ",A{r},FIND(" ",A{r})+1)-1))'
        ws[f"B{r}"] = formula
        written.append((r, formula))

print("Written formulas:", written)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload after recalc and ensure sheet names preserved
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    # rename sheets back by position
    for idx, name in enumerate(original_sheetnames):
        wb_check.worksheets[idx].title = name
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula[original_sheetnames[0]]
wsv = wb_values[original_sheetnames[0]]

print("Verification target cells:")
for r in range(1, wsf.max_row + 1):
    print(
        r,
        "A=", wsf[f"A{r}"].value,
        "| B_formula=", wsf[f"B{r}"].value,
        "| B_value=", wsv[f"B{r}"].value
    )

output_spreadsheet = outfile
```
