    print("Row1 headers first 60:", headers)
    if ws.max_row >= 2:
        headers2 = []
        for c in range(1, min(ws.max_column, 60) + 1):
            headers2.append(f"{get_column_letter(c)}={ws.cell(2,c).value}")
        print("Row2 values first 60:", headers2)
    
    # AO and nearby
    for c in range(35, min(ws.max_column, 45)+1):
        print(f"Col {get_column_letter(c)} row1={ws.cell(1,c).value!r} row2={ws.cell(2,c).value!r}")
    
    # Sample first rows
    first_n = min(ws.max_row, 8)
    print("\nFirst rows (cols A:AR):")
    for r in range(1, first_n+1):
        vals = row_values(ws, r, 1, min(ws.max_column, 44))
        print(f"Row {r}:", vals)
    
    # Sample last 5 rows
    print("\nLast 5 rows (cols A:AR):")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        vals = row_values(ws, r, 1, min(ws.max_column, 44))
        print(f"Row {r}:", vals)
    
    # Look for formulas in first 20 rows and first 60 cols
    print("\nExisting formulas in first 20 rows / first 60 cols:")
    found = 0
    for r in range(1, min(ws.max_row, 20)+1):
        for c in range(1, min(ws.max_column, 60)+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                print(f"{get_column_letter(c)}{r}: {v}")
                found += 1
                if found >= 40:
                    break
        if found >= 40:
            break
    if found == 0:
        print("No formulas found in inspected area.")
