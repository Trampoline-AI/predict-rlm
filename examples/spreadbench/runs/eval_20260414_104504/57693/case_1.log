import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Detailed target area D5:E32 before changes:")
for r in range(5, 33):
    print(r, ws[f"D{r}"].value, ws[f"E{r}"].value)

# Determine exact target range based on labels a:z in column D
labels = [ws[f"D{r}"].value for r in range(7, 33)]
print("Labels D7:D32:", labels)
print("Input text cell D5:", ws["D5"].value)

# Write formulas into E7:E32
for r in range(7, 33):
    letter_cell = f"D{r}"
    target = f"E{r}"
    formula = f'=LEN(LOWER($D$5))-LEN(SUBSTITUTE(LOWER($D$5),LOWER({letter_cell}),""))'
    ws[target] = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and fix sheet names if changed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)

# Verify formulas and calculated values
