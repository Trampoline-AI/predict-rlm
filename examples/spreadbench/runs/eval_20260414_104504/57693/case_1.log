import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1)
    print("Row 1 values / headers:", headers)
    if ws.max_row >= 2:
        print("Row 2 values:", row_values(ws, 2))
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r))
    # last 5 rows
    print("Last rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        print(r, row_values(ws, r))

    # print cells with formulas in used range
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formulas[:20], "count=", len(formulas))
