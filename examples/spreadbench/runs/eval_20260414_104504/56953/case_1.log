Code:
```repl
import os, shutil
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]
orig_sheetnames = wb.sheetnames[:]

# Determine current selected power
selected_power = ws["F2"].value
print("Selected power F2:", selected_power)

# Inspect source rows A:D and choose rows to display in I:L
# Include header rows where A cell is text and next data rows for that section match selected_power.
rows_to_copy = []
for r in range(2, ws.max_row + 1):
    aval = ws.cell(r, 1).value
    if isinstance(aval, str) and "Power" in aval:
        # find contiguous data rows until next header/end
        rr = r + 1
        section_has_match = False
        while rr <= ws.max_row:
            a2 = ws.cell(rr, 1).value
            if isinstance(a2, str) and "Power" in a2:
                break
            if a2 == selected_power:
                section_has_match = True
            rr += 1
        if section_has_match:
            rows_to_copy.append(r)
            for dr in range(r + 1, rr):
                if ws.cell(dr, 1).value == selected_power:
                    rows_to_copy.append(dr)

print("Rows to copy from A:D:", rows_to_copy)
for r in rows_to_copy:
    print(r, [ws.cell(r,c).value for c in range(1,5)])

# Clear target I2:L13 first
for r in range(2, 14):
    for c in range(9, 13):
        ws.cell(r, c).value = None

# Copy values/formulas/styles from A:D to I:L
target_start_row = 2
for idx, src_r in enumerate(rows_to_copy):
    tgt_r = target_start_row + idx
    if tgt_r > 13:
        break
    for offset in range(4):
        src = ws.cell(src_r, 1 + offset)
        tgt = ws.cell(tgt_r, 9 + offset)
        tgt.value = src.value
        if src.has_style:
            tgt._style = copy(src._style)
        if src.number_format:
            tgt.number_format = src.number_format
        if src.font:
            tgt.font = copy(src.font)
        if src.fill:
            tgt.fill = copy(src.fill)
        if src.border:
            tgt.border = copy(src.border)
        if src.alignment:
            tgt.alignment = copy(src.alignment)
        if src.protection:
            tgt.protection = copy(src.protection)

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)

# Verify output
wbv = load_workbook(outfile, data_only=False)
wsv = wbv[orig_sheetnames[0]]
print("Verified target I2:L13:")
for r in range(2, 14):
    print(r, [wsv.cell(r,c).value for c in range(9,13)])
print("Verified F2:", wsv["F2"].value)

output_spreadsheet = outfile
```
