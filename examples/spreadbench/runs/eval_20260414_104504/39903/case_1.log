import os, shutil, re
from openpyxl import load_workbook
from openpyxl.styles import Border, Side, Font
from openpyxl.utils import column_index_from_string

# Reload workbook and inspect styles/nearby cells more carefully
wb = load_workbook(input_spreadsheet)
ws = wb["SKUs as Bins"]

print("Target column C index:", column_index_from_string("C"))
print("Header C1:", ws["C1"].value)
print("Current C2:C6 values:", [ws[f"C{r}"].value for r in range(2,7)])
print("Current C2:C6 borders:", [ws[f"C{r}"].border for r in range(2,7)])
print("Current C2:C6 fonts:", [ws[f"C{r}"].font for r in range(2,7)])
print("Nearby row samples A:C 2:6:")
for r in range(2,7):
    print(r, [ws.cell(r,c).value for c in range(1,4)])

def count_bins(cell_value):
    if not cell_value or not isinstance(cell_value, str):
        return None
    parts = [p.strip() for p in cell_value.split(",") if p and p.strip()]
    count = 0
    debug = []
    for p in parts:
        loc = p.split(":")[0].strip()
        first = loc[:1].upper()
        # count only likely bin locations, excluding X/Z pallet locations and non-location text like RECEIVING
        is_bin = "-" in loc and first not in {"X", "Z"}
        debug.append((p, loc, is_bin))
        if is_bin:
            count += 1
    return count, debug

for r in range(2,7):
    res = count_bins(ws[f"B{r}"].value)
    print("Row", r, "analysis:", res)

# Modify workbook
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

wb2 = load_workbook(out_path)
ws2 = wb2["SKUs as Bins"]

thin = Side(style="thin", color="000000")
all_border = Border(left=thin, right=thin, top=thin, bottom=thin)
courier9 = Font(name="Courier New", size=9)

for r in range(2,7):
    parsed = count_bins(ws2[f"B{r}"].value)
    ws2[f"C{r}"] = parsed[0] if parsed is not None else None
    ws2[f"C{r}"].border = all_border
    ws2[f"C{r}"].font = courier9

wb2.save(out_path)
print("Saved to", out_path)

# recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Check sheet names after recalc and restore if changed
orig_names = wb.sheetnames
wb_check = load_workbook(out_path)
print("Post-recalc sheet names:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names and len(wb_check.sheetnames) == len(orig_names):
    for i, nm in enumerate(orig_names):
        wb_check.worksheets[i].title = nm
    wb_check.save(out_path)
    print("Restored sheet names to:", orig_names)

# verify data_only values and styles
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_names[0]]
print("Verified C2:C6 data_only:", [wsv[f'C{r}'].value for r in range(2,7)])

wbs = load_workbook(out_path)
wss = wbs[orig_names[0]]
for r in range(2,7):
    cell = wss[f"C{r}"]
    print(
        f"C{r}",
        "value=", cell.value,
        "font=", (cell.font.name, cell.font.sz),
        "border=", (cell.border.left.style, cell.border.right.style, cell.border.top.style, cell.border.bottom.style)
    )

output_spreadsheet = out_path
