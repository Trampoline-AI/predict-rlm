import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# reload clean workbook from input
wb2 = load_workbook(infile)
orig_sheet_names = wb2.sheetnames[:]
ws = wb2["Sheet1"]

max_col = ws.max_column

def full_row(r):
    return [ws.cell(r, c).value for c in range(1, max_col + 1)]

# Identify source rows: contiguous nonblank rows after header until first fully blank row
source_rows = []
for r in range(2, ws.max_row + 1):
    vals = full_row(r)
    if all(v in (None, "") for v in vals):
        break
    source_rows.append(r)

print("source rows:", source_rows)

# Build expanded rows based on AG/COUNT
expanded_rows = []
for r in source_rows:
    vals = full_row(r)
    cnt = vals[32]  # AG
    try:
        cnt = int(cnt)
    except Exception:
        cnt = 1
    if cnt < 1:
        cnt = 1
    for _ in range(cnt):
        expanded_rows.append(list(vals))

print("expanded rows count:", len(expanded_rows))

# Exact target area found from inspection
header_target_row = 16
data_start_row = 17

# Ensure row 16 matches original headers from row 1 exactly across all columns
for c in range(1, max_col + 1):
    ws.cell(header_target_row, c).value = ws.cell(1, c).value

# Clear existing lower output area from row 17 downward for all used rows/cols
for r in range(data_start_row, ws.max_row + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = None

# Write expanded rows starting row 17
for i, vals in enumerate(expanded_rows, start=data_start_row):
    for c, v in enumerate(vals, start=1):
        ws.cell(i, c).value = v

# Save
wb2.save(outfile)
print("saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("recalc:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(outfile)
print("sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    for idx, expected in enumerate(orig_sheet_names):
        wb_check.worksheets[idx].title = expected
    wb_check.save(outfile)
    print("restored sheet names:", wb_check.sheetnames)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

print("Verification rows 14-25:")
for r in range(14, 26):
    vals = [wsv.cell(r, c).value for c in range(1, max_col + 1)]
    print(r, vals)

print("Target checks:")
print("A14:", repr(wsv["A14"].value))
print("A16:AG16:", [wsv.cell(16, c).value for c in range(1, max_col + 1)])
for r in range(17, 17 + len(expanded_rows)):
    print(r, "A=", repr(wsv.cell(r,1).value), "D=", repr(wsv.cell(r,4).value), "H=", repr(wsv.cell(r,8).value), "AG=", repr(wsv.cell(r,33).value))

output_spreadsheet = outfile
