from openpyxl import load_workbook
import os

out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
orig_wb = load_workbook(input_spreadsheet)
orig_names = orig_wb.sheetnames

print("Recalculating:", out_path)
res = await recalculate(out_path)
print("Recalc result:", res)

# restore sheet names if recalc changed them
wb_chk = load_workbook(out_path)
print("Sheet names after recalc:", wb_chk.sheetnames)
if wb_chk.sheetnames != orig_names and len(wb_chk.sheetnames) == len(orig_names):
    for ws, nm in zip(wb_chk.worksheets, orig_names):
        ws.title = nm
    wb_chk.save(out_path)
    print("Renamed sheets back to:", orig_names)

# verify with formulas visible
wbf = load_workbook(out_path, data_only=False)
wsf = wbf["Main"]

print("\nPost-write dimensions:", wsf.max_row, wsf.max_column)
print("Headers:", [wsf.cell(1,c).value for c in range(1,14)])

# Check first 20 rows and a later sample for insertion pattern
for r in list(range(1, 21)) + list(range(55, min(wsf.max_row, 64)+1)):
    vals = [wsf.cell(r,c).value for c in range(1,14)]
    print(r, vals)

# Validation counts
motor = 0
ahmed_can = 0
ntv_india_rows = []
blank_after_ahmed_ok = True
for r in range(2, wsf.max_row + 1):
