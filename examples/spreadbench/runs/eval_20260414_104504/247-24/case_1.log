from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os

wb = load_workbook(input_spreadsheet)
ws = wb["Main"]

# Inspect relevant rows before modification
targets = {
    "Motorcycle": [],
    "Ahmed Sons / Canada": [],
    "Ahmed Sons (all)": [],
    "National TV / India": [],
}
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    rowvals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if a == "Motorcycle":
        targets["Motorcycle"].append((r, rowvals))
    if a == "Ahmed Sons" and b == "Canada":
        targets["Ahmed Sons / Canada"].append((r, rowvals))
    if a == "Ahmed Sons":
        targets["Ahmed Sons (all)"].append((r, rowvals))
    if a == "National TV" and b == "India":
        targets["National TV / India"].append((r, rowvals))

for k, v in targets.items():
    print("\n", k, "count:", len(v))
    for item in v[:10]:
        print(item)

print("\nCurrent M values/formulas for first few data rows:")
for r in range(2, min(12, ws.max_row + 1)):
    print(r, ws.cell(r, 13).value)

# Build lookup dict
lookup_ws = wb["Lookup"]
lookup = {}
for r in range(2, lookup_ws.max_row + 1):
    lookup[lookup_ws.cell(r,1).value] = lookup_ws.cell(r,2).value
print("\nLookup sample:", list(lookup.items())[:10])

# Save original styles from first data row / header
header = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
header_styles = {c: copy(ws.cell(1, c)._style) for c in range(1, ws.max_column + 1)}
data_styles = {c: copy(ws.cell(2, c)._style) for c in range(1, ws.max_column + 1)}

# Read original data rows
orig_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    orig_rows.append(vals)

# Transform rows
new_rows = []
deleted_count = 0
inserted_count = 0

for vals in orig_rows:
    company, location = vals[0], vals[1]
    emp_id = vals[2]
    
    # deletions
    if company == "Motorcycle":
        deleted_count += 1
        continue
    if company == "Ahmed Sons" and location == "Canada":
        deleted_count += 1
        continue
    
    # modify National TV + India rate to 180
    vals2 = list(vals)
    if company == "National TV" and location == "India":
        vals2[6] = 180
    
    new_rows.append(vals2)
    
    # insert two new blank rows after each Ahmed Sons row kept
    if company == "Ahmed Sons":
        inserted_count += 2
        new_rows.append([None]*13)
        new_rows.append([None]*13)

print("\nDeleted rows:", deleted_count, "Inserted blank rows:", inserted_count, "Final data rows:", len(new_rows))

# Clear existing data area
for row in ws.iter_rows(min_row=2, max_row=ws.max_row, max_col=ws.max_column):
    for cell in row:
        cell.value = None
        cell._style = copy(data_styles[cell.column])

# Write header styles back just in case
for c in range(1, ws.max_column + 1):
    ws.cell(1, c).value = header[c-1]
    ws.cell(1, c)._style = copy(header_styles[c])

# Write transformed rows and regenerate formulas
for i, vals in enumerate(new_rows, start=2):
    nonblank = any(v is not None for v in vals[:12])
    for c in range(1, 14):
        cell = ws.cell(i, c)
        cell._style = copy(data_styles[c])
        if c <= 8:
            cell.value = vals[c-1]
        elif c == 9:
            cell.value = f'=G{i}*H{i}' if nonblank else None
        elif c == 10:
            cell.value = f'=G{i}-30' if nonblank else None
        elif c == 11:
            cell.value = f'=J{i}*H{i}' if nonblank else None
        elif c == 12:
            cell.value = f'=I{i}-K{i}' if nonblank else None
        elif c == 13:
            # Use direct lookup value for robustness; blank on inserted blank rows
            emp_id = vals[2]
            cell.value = lookup.get(emp_id) if nonblank and emp_id in lookup else None

# Remove any leftover old rows below final extent
final_last_row = len(new_rows) + 1
for r in range(final_last_row + 1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None
        ws.cell(r, c)._style = copy(data_styles[c])

# Save
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path, "final_last_row", final_last_row)
