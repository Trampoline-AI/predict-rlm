# check trailing rows beyond expected final row remain empty
trailing_nonempty = []
for r in range(65, wsd.max_row + 1):
    if any(wsd.cell(r,c).value is not None for c in range(1,14)):
        trailing_nonempty.append(r)
print("Trailing nonempty rows beyond 64:", trailing_nonempty[:20])

output_spreadsheet = out_path
