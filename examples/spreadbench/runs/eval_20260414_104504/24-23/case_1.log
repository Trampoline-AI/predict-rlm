kept_data = [vals for _, vals in kept_rows]

# clear existing data rows in used range
for r in range(2, true_last_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# write back kept rows starting at row 2
for i, row in enumerate(kept_data, start=2):
    for c, val in enumerate(row, start=1):
        ws.cell(i, c).value = val

output_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
