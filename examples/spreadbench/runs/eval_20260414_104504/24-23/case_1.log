import os, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(input_path), input_path)

wb = load_workbook(input_path)
print("Original sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

sheet_info = {}
for ws in wb.worksheets:
    headers = row_values(ws, 1, ws.max_column)
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    print("Headers row 1:", headers)
    first_n = min(10, ws.max_row)
    print("First rows sample:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, min(ws.max_column, 10)))
    print("Last 5 rows sample:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 10)))
    colA_samples = [ws.cell(r, 1).value for r in range(1, min(ws.max_row, 20) + 1)]
    print("Column A first 20 values:", colA_samples)
    # frequency sample / matches
    matches = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if v in {"@9T", "SAL", "T9A"}:
            matches.append((r, v))
            if len(matches) >= 20:
                break
    print("First matching rows in col A for @9T/SAL/T9A:", matches)
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "headers": headers,
        "first_matches": matches,
    }
