groups = [ws.cell(r, 1).value for r in range(2, true_last_row + 1) if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1))]
cnt = Counter(groups)
targets = {"@9T", "SAL", "T9A"}
print("Top 15 group counts:", cnt.most_common(15))
print("Target counts:", {k: cnt.get(k, 0) for k in targets})
