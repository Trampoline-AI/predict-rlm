print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", max_row, "max_col:", max_col)
    print("Headers row 1:", headers)
    
    # first 10 rows
    first_n = min(10, max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, min(max_col, 6)+1)]
        print(r, vals)
    
    # last 5 rows
    start_last = max(1, max_row-4)
    print("Last 5 rows:")
    for r in range(start_last, max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, min(max_col, 6)+1)]
        print(r, vals)

    # inspect column A/B around blanks and examples
    blank_rows = []
    nonblank_a = []
    for r in range(1, max_row+1):
        a = ws.cell(r, 1).value
        b = ws.cell(r, 2).value
        if a in (None, ""):
            if b not in (None, ""):
                blank_rows.append(r)
        else:
            nonblank_a.append((r, a, b))
    print("Rows with blank A but nonblank B (first 30):", blank_rows[:30], "count:", len(blank_rows))
    
    if blank_rows:
        # print context around first few blank regions
        shown = set()
        print("Context around first blank rows:")
        for br in blank_rows[:10]:
            for r in range(max(1, br-2), min(max_row, br+2)+1):
                if r not in shown:
                    shown.add(r)
                    print("row", r, "A=", ws.cell(r,1).value, "B=", ws.cell(r,2).value)
    
    # sample formulas / values in col A for first 30 nonblank rows
    print("Sample nonblank column A entries:", nonblank_a[:20])

for ws in wb.worksheets:
    sheet_summary(ws)
