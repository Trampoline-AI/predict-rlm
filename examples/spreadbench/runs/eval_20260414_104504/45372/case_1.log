```repl
import os, shutil
from copy import copy
from datetime import time
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

def fill_info(cell):
    f = cell.fill
    return {
        "patternType": f.patternType,
        "fgColor_type": f.fgColor.type,
        "fgColor_rgb": f.fgColor.rgb,
        "fgColor_indexed": f.fgColor.indexed,
        "bgColor_type": f.bgColor.type,
        "bgColor_rgb": f.bgColor.rgb,
    }

print("Detailed target area A:E rows 2:15")
for r in range(2, 16):
    row = [ws.cell(r, c).value for c in range(1, 6)]
    print(r, row)

print("\nExisting E formulas/values and fills:")
for r in range(2, 16):
    c = ws[f"E{r}"]
    print(r, "value=", c.value, "data_type=", c.data_type, "fill=", fill_info(c))

threshold = time(9, 45)
for r in range(2, 15):  # data rows only
    t = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    if t is None:
        new_val = None
    else:
        source_val = b if t < threshold else c
        new_val = None if source_val in (None, 0, "0", "") else source_val
    ws[f"E{r}"] = new_val

# keep existing total formula in E15 if present
print("E15 before save:", ws["E15"].value)

target_fill = PatternFill(fill_type="solid", start_color="FFC000", end_color="FFC000")
for r in range(2, 16):
    ws[f"E{r}"].fill = copy(target_fill)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# reload and restore sheet names if changed
orig_names = wb.sheetnames[:]
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, nm in enumerate(orig_names):
        wb2.worksheets[i].title = nm
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)
else:
    print("Sheet names ok after recalc:", wb2.sheetnames)

# verify values after recalc
val_wb = load_workbook(out_path, data_only=True)
vws = val_wb["Sheet1"]
print("\nVerified E2:E15 data_only values:")
for r in range(2, 16):
    print(r, vws[f"E{r}"].value)

# verify fills in normal workbook
fmt_wb = load_workbook(out_path)
fws = fmt_wb["Sheet1"]
print("\nVerified fills E2:E15:")
for r in range(2, 16):
    print(r, fill_info(fws[f"E{r}"]))
    
output_spreadsheet = out_path
