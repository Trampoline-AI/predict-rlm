# Inspect all rows in target area C, I, M and current fills in M
rows_info = []
for r in range(2, ws.max_row+1):
    rows_info.append((r, ws.cell(r,3).value, ws.cell(r,9).value, ws.cell(r,13).value, ws.cell(r,13).fill.fill_type, ws.cell(r,13).fill.fgColor.rgb))
