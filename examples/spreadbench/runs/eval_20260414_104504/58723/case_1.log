for item in rows_info[:14]:
    print(item)
print("Last 10 rows:")
for item in rows_info[-10:]:
    print(item)

# Verify expected pattern from existing manual entries by Python
group_max = defaultdict(lambda: None)
for r in range(2, ws.max_row+1):
    name = ws.cell(r,3).value
    t = ws.cell(r,9).value
    if name is None or t is None:
        continue
    if group_max[name] is None or t > group_max[name]:
        group_max[name] = t

mismatches = []
for r in range(2, ws.max_row+1):
    name = ws.cell(r,3).value
    t = ws.cell(r,9).value
    existing = ws.cell(r,13).value
    if name and t:
        expected = "Latest" if t == group_max[name] else "Not Latest"
        if existing not in (None, expected):
            mismatches.append((r, name, t, existing, expected))
print("Unique names and max times:", dict(group_max))
print("Manual-answer mismatches count:", len(mismatches), "sample:", mismatches[:10])

# Write formula to exact target cells M2:M41
last_row = ws.max_row
for r in range(2, last_row+1):
    formula = f'=IF(C{r}="","",IF(I{r}="","",IF(COUNTIFS($C$2:$C${last_row},C{r},$I$2:$I${last_row},">"&I{r})=0,"Latest","Not Latest")))'
    ws.cell(r,13).value = formula

