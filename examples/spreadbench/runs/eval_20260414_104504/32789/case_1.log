import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Write formulas for C4:D7 using both primary header (row 2) and secondary header (row 3).
# SUMPRODUCT finds the matching column among BE:BR despite merged cells in row 2.
for r in range(4, 8):
    ws[f"C{r}"] = (
        f'=IFERROR(SUMPRODUCT(($BE$2:$BR$2=$B$2)*($BE$3:$BR$3=C$3)*'
        f'INDEX($BE$4:$BR$81,MATCH($A{r},$BD$4:$BD$81,0),0)),"-")'
    )
    ws[f"D{r}"] = (
        f'=IFERROR(SUMPRODUCT(($BE$2:$BR$2=$B$2)*($BE$3:$BR$3=D$3)*'
        f'INDEX($BE$4:$BR$81,MATCH($A{r},$BD$4:$BD$81,0),0)),"-")'
    )
    ws[f"C{r}"].number_format = "0"
    ws[f"D{r}"].number_format = "0"

# Clear any values below row 7 in columns C:D
for r in range(8, ws.max_row + 1):
    ws[f"C{r}"].value = None
    ws[f"D{r}"].value = None

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore original sheet names if recalculate changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for old, new in zip(orig_sheetnames, wb2.sheetnames):
        wb2[new].title = old
    wb2.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)
else:
    print("Sheet names after recalc:", wb2.sheetnames)

# Verify results with cached values
wbv = load_workbook(outfile, data_only=True)
wsv = wbv[orig_sheetnames[0]]
print("Verified C4:D7 cached values:")
for r in range(4, 8):
    print(r, wsv[f"C{r}"].value, wsv[f"D{r}"].value)

print("Verify cleared rows 8:12 in C:D")
for r in range(8, 13):
    print(r, wsv[f"C{r}"].value, wsv[f"D{r}"].value)

# Also print actual formulas from normal load
wbf = load_workbook(outfile, data_only=False)
wsf = wbf[orig_sheetnames[0]]
print("Formulas now in C4:D7:")
for r in range(4,8):
    print(r, wsf[f"C{r}"].value, " | ", wsf[f"D{r}"].value)
