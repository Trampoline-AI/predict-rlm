```repl
import os, shutil
from functools import lru_cache
from openpyxl import load_workbook

# Reload fresh workbook
infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb["denomination"]

# Identify employee rows exactly
employee_rows = []
for r in range(2, 9):
    sal = ws.cell(r, 5).value
    if isinstance(sal, (int, float)):
        employee_rows.append(r)

salaries = {r: int(ws.cell(r, 5).value) for r in employee_rows}

# Denominations and available counts from table and headers
denoms = [int(ws.cell(1, c).value) for c in range(8, 17)]  # H:P
avail = []
for denom in denoms:
    # find denom in C13:C21
    found = None
    for rr in range(13, 22):
        if ws.cell(rr, 3).value == denom:
            found = ws.cell(rr, 4).value
            break
    avail.append(int(found) if isinstance(found, (int, float)) else 0)

print("Employee rows:", employee_rows)
print("Salaries:", salaries)
print("Denoms:", denoms)
print("Avail counts:", avail, "total notes", sum(avail), "total amount", sum(d*c for d,c in zip(denoms, avail)))

# Order employees largest salary first for easier search
ordered_rows = sorted(employee_rows, key=lambda r: salaries[r], reverse=True)
targets = [salaries[r] for r in ordered_rows]
D = tuple(denoms)

@lru_cache(None)
def suffix_amount_bounds(idx, counts):
    counts = list(counts)
    # exact remaining total amount from counts
    return sum(d*c for d, c in zip(D, counts))

def feasible_amount_range(counts):
    # min achievable is 0; max is total remaining amount
    return (0, sum(d*c for d, c in zip(D, counts)))

def bounded_options(rem, denom, count):
    max_use = min(count, rem // denom)
    # choose larger notes first, narrow branching around proportional / max use
    opts = list(range(max_use, -1, -1))
    return opts

@lru_cache(None)
def solve(emp_idx, counts, rem_targets):
    counts = tuple(counts)
    rem_targets = tuple(rem_targets)
    if emp_idx == len(rem_targets):
        return () if all(c == 0 for c in counts) else None

    target = rem_targets[emp_idx]
    if sum(d*c for d, c in zip(D, counts)) != sum(rem_targets[emp_idx:]):
        return None

    # recursive assignment for one employee
    @lru_cache(None)
    def assign(den_idx, rem_amt, curr_counts):
        curr_counts = tuple(curr_counts)
        if den_idx == len(D):
            if rem_amt == 0:
                next_sol = solve(emp_idx + 1, curr_counts, rem_targets)
                if next_sol is not None:
                    return ((), next_sol)
            return None

        denom = D[den_idx]
        available = curr_counts[den_idx]

        # bounds on remaining denoms after current choice
        for use in bounded_options(rem_amt, denom, available):
            new_counts = list(curr_counts)
            new_counts[den_idx] -= use
            rem2 = rem_amt - use * denom

            # quick prune: can remaining denominations cover rem2?
            max_possible = sum(D[j] * new_counts[j] for j in range(den_idx + 1, len(D)))
            gcd = 1
            # since denomination 1 exists with positive total eventually, gcd prune not necessary
            if rem2 < 0 or rem2 > max_possible:
                continue

            sub = assign(den_idx + 1, rem2, tuple(new_counts))
            if sub is not None:
                alloc_tail, next_sol = sub
                return (((use,), alloc_tail), next_sol)
        return None

    res = assign(0, target, counts)
    if res is None:
        return None

    # flatten current employee allocation
    alloc_nested, next_sol = res
    flat = []
    node = alloc_nested
    while node:
        first, node = node
        flat.extend(first)
    return (tuple(flat),) + next_sol

solution = solve(0, tuple(avail), tuple(targets))
print("Found solution:", solution is not None)
if solution is None:
    raise RuntimeError("No feasible distribution found")

# Map solution back to original row order
alloc_by_row = {}
for row, alloc in zip(ordered_rows, solution):
    alloc_by_row[row] = list(alloc)

print("Allocation by employee row:")
for r in ordered_rows:
    alloc = alloc_by_row[r]
    amount = sum(a*d for a, d in zip(alloc, denoms))
    notes = sum(alloc)
    print(r, ws.cell(r,3).value, salaries[r], alloc, "amount", amount, "notes", notes)

# Verify column totals
col_totals = [sum(alloc_by_row[r][i] for r in employee_rows) for i in range(len(denoms))]
print("Column totals:", col_totals)

# Write outputs H:P and Q
for r in employee_rows:
    # inspect existing values before overwrite
    existing = [ws.cell(r, c).value for c in range(8, 18)]
    print("Existing row", r, existing)
    alloc = alloc_by_row[r]
    for i, c in enumerate(range(8, 17)):
        ws.cell(r, c).value = alloc[i]
    ws.cell(r, 17).value = f"=SUM(H{r}:P{r})"

# Save
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
if wb2.sheetnames != ["denomination"]:
    # rename first sheet back if LibreOffice changed it
    if len(wb2.sheetnames) == 1:
        wb2[wb2.sheetnames[0]].title = "denomination"
        wb2.save(outfile)
    print("Sheetnames after correction:", load_workbook(outfile).sheetnames)
else:
    print("Sheetnames OK:", wb2.sheetnames)

# Verify using data_only
ver = load_workbook(outfile, data_only=True)
vws = ver["denomination"]

print("\nVerification H:Q rows 1:10")
for r in range(1, 11):
    print(r, [vws.cell(r, c).value for c in range(8, 18)])

print("\nRow amount checks")
for r in employee_rows:
    counts = [vws.cell(r, c).value for c in range(8, 17)]
    amount = sum((counts[i] or 0) * denoms[i] for i in range(len(denoms)))
    total_notes = vws.cell(r, 17).value
    print(r, ws.cell(r,3).value, "salary", salaries[r], "amount", amount, "Q", total_notes)

print("\nColumn total checks")
for i, c in enumerate(range(8, 17)):
    vals = [(vws.cell(r, c).value or 0) for r in employee_rows]
    print(denoms[i], sum(vals), "expected", avail[i])

output_spreadsheet = outfile
