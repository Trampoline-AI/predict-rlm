import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # gather non-empty headers from first few rows
    for hr in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {hr}:", vals)
    # detect likely used rows by checking any non-empty cell
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    if nonempty_rows:
        print("First non-empty row:", nonempty_rows[0], "Last non-empty row:", nonempty_rows[-1], "Count:", len(nonempty_rows))
        sample_first = nonempty_rows[:10]
        sample_last = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
        shown = []
        for r in sample_first + [x for x in sample_last if x not in sample_first]:
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            shown.append((r, vals))
        print("Sample rows:")
        for r, vals in shown:
            print(f"  Row {r}: {vals}")
    # print formulas if any in used range
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formula cells found:", len(formulas))
    for item in formulas[:20]:
        r, c, v = item
        print(f"  {get_column_letter(c)}{r}: {v}")

for ws in wb.worksheets:
    sheet_info(ws)
