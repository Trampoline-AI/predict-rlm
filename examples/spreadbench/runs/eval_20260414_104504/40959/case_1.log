from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Load original workbook again for modification
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Pre-write check: target cells/formulas in C2:C7")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value)

# Apply new formula in existing target cells column C
for r in range(2, ws.max_row + 1):
    formula = f'=IF(A{r}="","",IF(B{r}="General","Marketing",IF(ISERROR(SEARCH("-",A{r},1)),"Sales","Marketing")))'
    ws[f"C{r}"] = formula

print("\nPost-write formula check in C2:C7")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"C{r}"].value)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for i, old_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = old_name
    wb_after.save(out_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("\nVerification of formulas C2:C7:")
for r in range(2, ws_formula.max_row + 1):
    print(f"C{r} formula:", ws_formula[f"C{r}"].value)

# Verify cached calculated values
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]
print("\nVerification of calculated values A2:C7:")
for r in range(2, ws_values.max_row + 1):
    print(f"Row {r}: A={ws_values[f'A{r}'].value!r}, B={ws_values[f'B{r}'].value!r}, C={ws_values[f'C{r}'].value!r}")

output_spreadsheet = out_path
