def sheet_used_range(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # collect headers from first non-empty-ish row among first 5 rows
    header_row_idx = None
    for r in range(1, min(6, max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        if any(v is not None and v != "" for v in vals):
            header_row_idx = r
            break
    return max_row, max_col, header_row_idx

for ws in wb.worksheets:
    max_row, max_col, header_row_idx = sheet_used_range(ws)
    headers = [ws.cell(header_row_idx, c).value for c in range(1, max_col + 1)] if header_row_idx else []
