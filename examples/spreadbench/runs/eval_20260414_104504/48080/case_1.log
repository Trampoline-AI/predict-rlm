from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Inspect all non-empty cells in column A and column C
nonempty_A = [(r, ws[f"A{r}"].value) for r in range(1, ws.max_row + 1) if ws[f"A{r}"].value is not None]
nonempty_C = [(r, ws[f"C{r}"].value) for r in range(1, ws.max_row + 1) if ws[f"C{r}"].value is not None]
print("Non-empty A cells:", nonempty_A)
print("Non-empty C cells:", nonempty_C)

# Print rows around all non-empty A cells for context
for r, v in nonempty_A:
    start = max(1, r-2)
    end = min(ws.max_row, r+2)
    print(f"\nContext around A{r}:")
    for rr in range(start, end+1):
        print(rr, [ws.cell(rr, c).value for c in range(1, ws.max_column+1)])

# Infer pattern from examples
example_rows = [r for r, v in nonempty_C if r > 1 and isinstance(v, str) and v.startswith("=A")]
refs = []
for r in example_rows:
    formula = ws[f"C{r}"].value
    ref_row = int(formula.split("A")[1])
    refs.append((r, ref_row))
print("Example C row -> referenced A row:", refs)
if len(refs) >= 2:
    step = refs[1][1] - refs[0][1]
    start_ref = refs[0][1]
    print("Inferred start_ref:", start_ref, "step:", step)

# Write formulas continuing the pattern in column C for all valid references
start_row_out = 2
start_ref = refs[0][1]
step = refs[1][1] - refs[0][1]
out_r = start_row_out
ref_r = start_ref
written = []
while ref_r <= ws.max_row:
    target = ws[f"C{out_r}"]
    print(f"Before write C{out_r}={target.value!r}")
    formula = f"=A{ref_r}"
    ws[f"C{out_r}"] = formula
    written.append((out_r, formula))
    out_r += 1
    ref_r += step

print("Written formulas:", written)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and verify
wb2 = load_workbook(out_path, data_only=False)
print("Sheetnames after recalc:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    orig = wb.sheetnames[0]
    cur = wb2.sheetnames[0]
    wb2[cur].title = orig
    wb2.save(out_path)
    print("Renamed sheet back to", orig)

wbv = load_workbook(out_path, data_only=True)
wsv = wbv[wb.sheetnames[0]]
print("Verified target C cells (formula results):")
for r in range(2, out_r):
    print(f"C{r} ->", wsv[f"C{r}"].value)
    
output_spreadsheet = out_path
