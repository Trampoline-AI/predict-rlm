for r in range(3, wsf.max_row + 1):
    print("Row", r)
    for c in range(4, 11):
        coord = f"{get_column_letter(c)}{r}"
        print(coord, "formula:", wsf[coord].value)

print("\nVerification cached values D:J:")
for r in range(3, wsd.max_row + 1):
    vals = {f"{get_column_letter(c)}{r}": wsd.cell(r, c).value for c in range(4, 11)}
    print(vals)

output_spreadsheet = outfile
