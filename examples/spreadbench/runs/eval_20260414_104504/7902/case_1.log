import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row2 values:", row2)
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Inspect specifically referenced cells and formulas
for s in wb.sheetnames:
    ws = wb[s]
    for coord in ["C3", "A3", "B3", "D3", "E3", "F3", "G3", "H3", "I3"]:
        print(f"{s}!{coord} =", ws[coord].value)

# Search workbook for formulas containing VLOOKUP or references to Grouping/C3
hits = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                text = v.upper()
                if "VLOOKUP" in text or "GROUPING" in text or "C3" in text:
                    hits.append((ws.title, cell.coordinate, v))
print("\nFormula hits:")
for h in hits[:100]:
    print(h)
print("Total hits:", len(hits))
```
