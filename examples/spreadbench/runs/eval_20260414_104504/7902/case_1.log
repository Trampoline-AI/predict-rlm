import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = "/sandbox/output/output_spreadsheet/" + os.path.basename(infile)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Formula Required"]

print("Pre-write check, existing D:J formulas/values:")
for r in range(3, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(4, 11)])

# Write formulas for all relevant data rows (3:max_row) and all aging columns D:J
for r in range(3, ws.max_row + 1):
    group_cell = f"C{r}"
    material_cell = f"B{r}"
    for c in range(4, 11):  # D:J
        col_letter = get_column_letter(c)
        group_index = c - 1      # D->3 ... J->9 for A:I table
        material_index = c - 2   # D->2 ... J->8 for B:I table
        formula = (
            f'=IF({material_cell}<>"",'
            f'IFERROR(VLOOKUP({material_cell},Grouping!$B$2:$I$7,{material_index},FALSE),'
            f'VLOOKUP({group_cell},Grouping!$A$2:$I$7,{group_index},FALSE)),'
            f'VLOOKUP({group_cell},Grouping!$A$2:$I$7,{group_index},FALSE))'
        )
        ws[f"{col_letter}{r}"] = formula

wb.save(outfile)
print("Saved to", outfile)

res = await recalculate(outfile)
print("Recalculate:", res)

# Reload after recalc and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename sheets positionally back to originals
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored original sheet names:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Formula Required"]
wb_data = load_workbook(outfile, data_only=True)
wsd = wb_data["Formula Required"]

