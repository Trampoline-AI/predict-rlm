        print(r, vals)
    # sample last 5 rows
    start_last = max(1, max_row-4)
    print("Last rows sample:")
    for r in range(start_last, max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(r, vals)
    # column I inspection if present
    if max_col >= 9:
        print("Column I header/value samples:")
        for r in range(1, min(max_row, 15)+1):
            print(f"I{r} =", ws.cell(r, 9).value)
        if max_row > 15:
            for r in range(max(16, max_row-5), max_row+1):
                print(f"I{r} =", ws.cell(r, 9).value)

for ws in wb.worksheets:
