import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Read and normalize A1
a1 = ws["A1"].value
a1_text = "" if a1 is None else str(a1).strip()

print("Original A1:", repr(a1_text))
print("Original B2:", repr(ws["B2"].value))

mapping = {
    "4ozark": 1,
    "3tall": 2,
    "1jasper": 3,
    "2gwood": 4,
    "5dawson": 5,
    "8cpark": 6,
}

# Case-insensitive substring match because A1 contains extra date/time text
result = None
lower_a1 = a1_text.lower()
for key, val in mapping.items():
    if key in lower_a1:
        result = val
        break

if result is None:
    raise ValueError(f"Could not map A1 value: {a1_text!r}")

ws["B2"] = result

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheet_names)
    for i, expected in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify[orig_sheet_names[0]]
print("Verified A1:", repr(vws["A1"].value))
print("Verified B2:", repr(vws["B2"].value))

output_spreadsheet = outfile
