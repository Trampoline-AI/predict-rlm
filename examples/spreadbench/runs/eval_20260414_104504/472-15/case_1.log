import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    headers = []
    max_col = ws.max_column
    for c in range(1, max_col + 1):
        headers.append(ws.cell(1, c).value)
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    print("Row 1 headers/values:", headers)
    sample_first = list(range(1, min(ws.max_row, 10) + 1))
    sample_last = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in sample_first + sample_last:
        if r not in seen:
            seen.add(r)
            rows_to_show.append(r)
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")

for ws in wb.worksheets:
    sheet_summary(ws)
    print(f"A1={ws['A1'].value!r}, B2={ws['B2'].value!r}")
    if ws["B2"].data_type == "f":
        print("B2 formula:", ws["B2"].value)

# Also inspect a small area around A1:B5 for every sheet
