    "EXPRR": (13, 14, 15),
}
for name, (c_item, c_ref, c_amt) in blocks.items():
    last_nonempty = 1
    for r in range(2, out.max_row + 1):
        if any(out.cell(r, c).value not in (None, "") for c in (c_item, c_ref, c_amt)):
            last_nonempty = r
    print(f"\nCurrent OUT CAS block {name}: columns {get_column_letter(c_item)}:{get_column_letter(c_amt)}, last_nonempty_row={last_nonempty}")
