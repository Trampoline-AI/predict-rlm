import re, os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
out = wb["OUT CAS"]

source_sheets = [ws.title for ws in wb.worksheets if ws.title != "OUT CAS"]
print("Source sheets used:", source_sheets)

patterns = {
    "PUR PURCHASE": lambda ref: isinstance(ref, str) and ref.startswith("PUR PURCHASE"),
    "PUR PAID": lambda ref: isinstance(ref, str) and ref.startswith("PUR PAID"),
    "CASH SS": lambda ref: isinstance(ref, str) and ref.startswith("CASH SS"),
    "EXPRR": lambda ref: isinstance(ref, str) and ref.startswith("EXPRR"),
}

agg = {k: [] for k in patterns}
unmatched = []
for s in source_sheets:
    ws = wb[s]
    for r in range(2, ws.max_row + 1):
        ref = ws.cell(r, 2).value
        if ref in (None, ""):
            continue
        debit = ws.cell(r, 3).value
        credit = ws.cell(r, 4).value
        amount = debit if debit not in (None, "") else credit
        matched = False
        for k, fn in patterns.items():
            if fn(ref):
                agg[k].append((str(ref), amount, s, r))
                matched = True
                break
        if not matched:
            unmatched.append((s, r, ref, debit, credit))

def sort_key(rec):
    ref = rec[0]
    m = re.search(r'([A-Z]*)(\d+)$', ref)
    if m:
        prefix, num = m.groups()
        return (prefix, int(num), ref)
    return ("", 10**12, ref)

for k in agg:
    agg[k] = sorted(agg[k], key=sort_key)

for k, items in agg.items():
    print(f"\n{k}: count={len(items)}")
    print(" first 8:", items[:8])
    print(" last 8:", items[-8:])

