```repl
import os, re, shutil
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
original_sheetnames = wb.sheetnames[:]
ws = wb["OUT CAS"]

# Aggregate from all non-OUT CAS sheets so inserting sheets before OUT CAS is safe
source_sheets = [name for name in wb.sheetnames if name != "OUT CAS"]

patterns = {
    "PUR PURCHASE": lambda ref: isinstance(ref, str) and ref.startswith("PUR PURCHASE"),
    "PUR PAID": lambda ref: isinstance(ref, str) and ref.startswith("PUR PAID"),
    "CASH SS": lambda ref: isinstance(ref, str) and ref.startswith("CASH SS"),
    "EXPRR": lambda ref: isinstance(ref, str) and ref.startswith("EXPRR"),
}
agg = {k: [] for k in patterns}

for s in source_sheets:
    src = wb[s]
    for r in range(2, src.max_row + 1):
        ref = src.cell(r, 2).value
        if ref in (None, ""):
            continue
        debit = src.cell(r, 3).value
        credit = src.cell(r, 4).value
        amount = debit if debit not in (None, "") else credit
        for k, fn in patterns.items():
            if fn(ref):
                agg[k].append((str(ref), amount))
                break

def sort_key(rec):
    ref = rec[0]
    m = re.search(r'([A-Z]*)(\d+)$', ref)
    if m:
        prefix, num = m.groups()
        return (prefix, int(num), ref)
    return ("", 10**12, ref)

for k in agg:
    agg[k] = sorted(agg[k], key=sort_key)

blocks = {
    "PUR PURCHASE": (1, 2, 3),
    "PUR PAID": (5, 6, 7),
    "CASH SS": (9, 10, 11),
    "EXPRR": (13, 14, 15),
}

# Capture template styles before clearing
templates = {}
for name, (c_item, c_ref, c_amt) in blocks.items():
    data_row = 2
    total_row = None
    for r in range(2, ws.max_row + 1):
        if ws.cell(r, c_item).value == "TOTAL":
            total_row = r
            break
    if total_row is None:
        total_row = len(agg[name]) + 2
    templates[name] = {
        "item": copy(ws.cell(data_row, c_item)._style),
        "ref": copy(ws.cell(data_row, c_ref)._style),
        "amt": copy(ws.cell(data_row, c_amt)._style),
        "item_nf": ws.cell(data_row, c_item).number_format,
        "ref_nf": ws.cell(data_row, c_ref).number_format,
        "amt_nf": ws.cell(data_row, c_amt).number_format,
        "total_item": copy(ws.cell(total_row, c_item)._style),
        "total_ref": copy(ws.cell(total_row, c_ref)._style),
        "total_amt": copy(ws.cell(total_row, c_amt)._style),
        "total_item_nf": ws.cell(total_row, c_item).number_format,
        "total_ref_nf": ws.cell(total_row, c_ref).number_format,
        "total_amt_nf": ws.cell(total_row, c_amt).number_format,
    }

# Clear existing block contents from row 2 down
for name, (c_item, c_ref, c_amt) in blocks.items():
    for r in range(2, ws.max_row + 1):
        for c in (c_item, c_ref, c_amt):
            ws.cell(r, c).value = None

# Rewrite all blocks
for name, items in agg.items():
    c_item, c_ref, c_amt = blocks[name]
    tmpl = templates[name]
    start_row = 2
    for idx, (ref, amount) in enumerate(items, start=1):
        r = start_row + idx - 1
        ws.cell(r, c_item).value = idx
        ws.cell(r, c_ref).value = ref
        ws.cell(r, c_amt).value = amount
        ws.cell(r, c_item)._style = copy(tmpl["item"])
        ws.cell(r, c_ref)._style = copy(tmpl["ref"])
        ws.cell(r, c_amt)._style = copy(tmpl["amt"])
        ws.cell(r, c_item).number_format = tmpl["item_nf"]
        ws.cell(r, c_ref).number_format = tmpl["ref_nf"]
        ws.cell(r, c_amt).number_format = tmpl["amt_nf"]

    total_row = start_row + len(items)
    ws.cell(total_row, c_item).value = "TOTAL"
    ws.cell(total_row, c_ref).value = None
    amt_col_letter = chr(64 + c_amt)
    ws.cell(total_row, c_amt).value = f"=SUM({amt_col_letter}{start_row}:{amt_col_letter}{total_row-1})"
    ws.cell(total_row, c_item)._style = copy(tmpl["total_item"])
    ws.cell(total_row, c_ref)._style = copy(tmpl["total_ref"])
    ws.cell(total_row, c_amt)._style = copy(tmpl["total_amt"])
    ws.cell(total_row, c_item).number_format = tmpl["total_item_nf"]
    ws.cell(total_row, c_ref).number_format = tmpl["total_ref_nf"]
    ws.cell(total_row, c_amt).number_format = tmpl["total_amt_nf"]

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
if wb2.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", original_sheetnames)
    for i, expected in enumerate(original_sheetnames):
        wb2.worksheets[i].title = expected
    wb2.save(outfile)

# Verify with data_only
verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify.sheetnames)
vws = verify["OUT CAS"]

checks = {
    "A1:C5": [(r, [vws.cell(r, c).value for c in range(1, 4)]) for r in range(1, 6)],
    "E1:G5": [(r, [vws.cell(r, c).value for c in range(5, 8)]) for r in range(1, 6)],
    "I1:K12": [(r, [vws.cell(r, c).value for c in range(9, 12)]) for r in range(1, 13)],
    "M1:O7": [(r, [vws.cell(r, c).value for c in range(13, 16)]) for r in range(1, 8)],
    "purchase_tail": [(r, [vws.cell(r, c).value for c in range(1, 4)]) for r in range(1525, 1530)],
    "paid_tail": [(r, [vws.cell(r, c).value for c in range(5, 8)]) for r in range(581, 586)],
}
for k, vals in checks.items():
    print("\n", k)
    for row in vals:
        print(row)

output_spreadsheet = outfile
