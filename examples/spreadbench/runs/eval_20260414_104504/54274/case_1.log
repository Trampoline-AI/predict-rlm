import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction full text:")
print(instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

def display(v):
    if v is None:
        return None
    try:
        if hasattr(v, "text"):
            return f"FORMULA_OBJ:{v.text}"
    except Exception:
        pass
    return v

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row", ws.max_row, "max_col", ws.max_column)
    headers = [display(ws.cell(1,c).value) for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = [display(ws.cell(2,c).value) for c in range(1, ws.max_column+1)]
        print("Row2:", row2)
    # print first 10 and last 5 rows, bounded
    rows_to_show = list(range(1, min(ws.max_row,10)+1))
    if ws.max_row > 10:
        rows_to_show += list(range(max(11, ws.max_row-4), ws.max_row+1))
    seen = set()
    for r in rows_to_show:
        if r in seen: 
            continue
        seen.add(r)
        vals = [display(ws.cell(r,c).value) for c in range(1, ws.max_column+1)]
        print(f"R{r}: {vals}")

# Also inspect formulas / non-empty cells on small sheets
for ws in wb.worksheets:
    print(f"\nFormula scan for {ws.title}:")
    found = []
    for row in ws.iter_rows():
        for cell in row:
            val = cell.value
            if isinstance(val, str) and val.startswith("="):
                found.append((cell.coordinate, val))
            elif hasattr(val, "text"):
                found.append((cell.coordinate, val.text))
    print(found[:50], "count=", len(found))
