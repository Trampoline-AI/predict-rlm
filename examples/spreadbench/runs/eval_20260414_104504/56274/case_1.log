from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Rows 8-12, cols A:F")
for r in range(8, 13):
    print(r, [ws.cell(r,c).value for c in range(1,7)])

for coord in ["D9","D10","D11","D12"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "data_type=", cell.data_type, "numfmt=", cell.number_format)

print("Month header mapping G:R")
for c in range(7, 19):
    print(get_column_letter(c), ws.cell(3,c).value, "open", ws.cell(4,c).value, "debit", ws.cell(5,c).value, "credit", ws.cell(6,c).value, "close", ws.cell(7,c).value)

# Write formulas into target cells
ws["D9"]  = '=INDEX($G$4:$R$4,1,MATCH($D$7,$G$3:$R$3,0))'
ws["D10"] = '=INDEX($G$5:$R$5,1,MATCH($D$7,$G$3:$R$3,0))'
ws["D11"] = '=INDEX($G$6:$R$6,1,MATCH($D$7,$G$3:$R$3,0))'
ws["D12"] = '=INDEX($G$7:$R$7,1,MATCH($D$7,$G$3:$R$3,0))'

out = "/sandbox/output/output_spreadsheet/initial.xlsx"
wb.save(out)
print("saved", out)
print("formulas now:", ws["D9"].value, ws["D10"].value, ws["D11"].value, ws["D12"].value)

res = await recalculate(out)
print("recalc:", res)

# Reload and verify
wb2 = load_workbook(out, data_only=False)
print("sheetnames after recalc:", wb2.sheetnames)
ws2 = wb2[wb2.sheetnames[0]]
for coord in ["D7","D9","D10","D11","D12"]:
    print("formula book", coord, ws2[coord].value)

wb3 = load_workbook(out, data_only=True)
ws3 = wb3[wb3.sheetnames[0]]
for coord in ["D7","D9","D10","D11","D12"]:
    print("data_only", coord, ws3[coord].value)
