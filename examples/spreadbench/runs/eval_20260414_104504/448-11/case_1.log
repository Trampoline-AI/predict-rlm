from openpyxl import load_workbook
from collections import Counter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)

# Inspect full used area enough to identify duplicates and current region
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(r, vals)

# Determine current region by scanning for non-empty rows
nonempty_rows = []
for r in range(1, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v is not None and v != "" for v in row_vals):
        nonempty_rows.append(r)

print("Non-empty rows:", nonempty_rows)
start_row, end_row = min(nonempty_rows), max(nonempty_rows)
print("Current non-empty region rows:", start_row, "to", end_row)

colA_vals = []
for r in range(start_row, end_row + 1):
    v = ws.cell(r, 1).value
    colA_vals.append((r, v))
print("Column A values in region:", colA_vals)

counts = Counter(v for r, v in colA_vals if v is not None and v != "")
dups = {k: v for k, v in counts.items() if v > 1}
print("Duplicate Column A values before:", dups)

# Delete duplicate rows based only on Column A, preserving first occurrence.
# Treat first row of region as header if it contains text in A and following rows are data.
seen = set()
rows_to_delete = []
for r in range(start_row + 1, end_row + 1):
    key = ws.cell(r, 1).value
    if key is None or key == "":
        continue
    if key in seen:
        rows_to_delete.append(r)
    else:
        seen.add(key)

print("Rows to delete:", rows_to_delete)

for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore sheet names if LO changed them
orig_names = load_workbook(input_spreadsheet).sheetnames
wb_chk = load_workbook(out_path)
print("Sheet names after recalc:", wb_chk.sheetnames)
if wb_chk.sheetnames != orig_names and len(wb_chk.sheetnames) == len(orig_names):
    for i, nm in enumerate(orig_names):
        wb_chk.worksheets[i].title = nm
    wb_chk.save(out_path)
    print("Renamed sheets back to original:", orig_names)

# Verify output
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_names[0]]
print("Verified sheet:", wsv.title, "rows:", wsv.max_row, "cols:", wsv.max_column)
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

# Verify uniqueness in column A for data rows
nonempty_rows_v = []
for r in range(1, wsv.max_row + 1):
    row_vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    if any(v is not None and v != "" for v in row_vals):
        nonempty_rows_v.append(r)
sv, ev = min(nonempty_rows_v), max(nonempty_rows_v)
vals_v = [wsv.cell(r, 1).value for r in range(sv + 1, ev + 1) if wsv.cell(r, 1).value not in (None, "")]
counts_v = Counter(vals_v)
dups_v = {k: v for k, v in counts_v.items() if v > 1}
print("Duplicate Column A values after:", dups_v)

final_output_path = out_path
