from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, re

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def first_nonempty_rows(ws, n=10):
    rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            rows.append((r, vals))
        if len(rows) >= n:
            break
    return rows

def last_nonempty_rows(ws, n=5):
    rows = []
    for r in range(ws.max_row, 0, -1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            rows.append((r, vals))
        if len(rows) >= n:
            break
    return list(reversed(rows))

for s in wb.sheetnames:
    ws = wb[s]
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    print("Row 1 headers/values:", headers)
    print("First non-empty rows:")
    for r, vals in first_nonempty_rows(ws, 10):
        print(r, vals)
    print("Last non-empty rows:")
    for r, vals in last_nonempty_rows(ws, 5):
        print(r, vals)
    print("Column A/B sample values:")
    for r in range(1, min(ws.max_row, 15) + 1):
        print(r, "A=", ws[f"A{r}"].value, "B=", ws[f"B{r}"].value)
