from openpyxl import load_workbook
import os, re, shutil

# Re-open and inspect formulas / exact target area
wb = load_workbook(input_spreadsheet)
for s in ["Before", "After"]:
    ws = wb[s]
    print(f"\nInspecting sheet {s}")
    for r in range(1, ws.max_row + 1):
        a = ws[f"A{r}"].value
        b = ws[f"B{r}"].value
        if r <= 10 or r >= ws.max_row - 2:
            print(r, repr(a), repr(b), "A_formula" if isinstance(a, str) and a.startswith("=") else "", "B_formula" if isinstance(b, str) and b.startswith("=") else "")

# Prepare output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

wb2 = load_workbook(out_path)
ws = wb2["Before"]  # target sheet to modify based on example in "After"

def split_at_first_letter(val):
    if val is None:
        return None, None
    s = str(val)
    m = re.search(r"[A-Za-z]", s)
    if not m:
        return s, None
    idx = m.start()
    return s[:idx], s[idx:]

# Preserve header row as-is; transform data rows with content in A
for r in range(2, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    if a is None or a == "":
        continue
    # only fill if B is empty, to avoid overwriting good data
    if b not in (None, ""):
        print(f"Skipping row {r} because B already has value:", b)
        continue
    left, right = split_at_first_letter(a)
    print(f"Row {r}: A before={repr(a)} -> A after={repr(left)}, B after={repr(right)}")
    ws[f"A{r}"] = left
    ws[f"B{r}"] = right

wb2.save(out_path)
print("Saved to", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Verify and restore sheet names if recalculation changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position back to original
    for i, desired in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = desired
    wb_check.save(out_path)
    print("Restored sheet names:", wb_check.sheetnames)

# Reload data_only for verification
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Before"]
print("\nVerification of target cells in Before!A:B")
for r in range(1, min(10, wsv.max_row) + 1):
    print(r, repr(wsv[f"A{r}"].value), repr(wsv[f"B{r}"].value))
print("Last populated rows check:")
for r in range(max(1, wsv.max_row - 5), wsv.max_row + 1):
    print(r, repr(wsv[f"A{r}"].value), repr(wsv[f"B{r}"].value))

final_output_path = out_path
```
