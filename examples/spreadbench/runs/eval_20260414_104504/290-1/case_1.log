import os, shutil
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Reconfirm exact mapping and target extent
source_rows = [r for r in range(2, ws.max_row + 1) if ws[f"I{r}"].value is not None or ws[f"H{r}"].value is not None]
pairs = [(ws[f"I{r}"].value, ws[f"H{r}"].value) for r in source_rows]
print("Source row count:", len(source_rows))
print("First 10 source pairs:", pairs[:10])
print("Existing example row2:", [(ws["K2"].value, ws["L2"].value),(ws["N2"].value, ws["O2"].value),(ws["Q2"].value, ws["R2"].value),(ws["T2"].value, ws["U2"].value)])
print("Existing example row3:", [(ws["K3"].value, ws["L3"].value),(ws["N3"].value, ws["O3"].value),(ws["Q3"].value, ws["R3"].value),(ws["T3"].value, ws["U3"].value)])

target_rows_needed = 2 + (len(pairs) - 1) // 4
print("Target rows needed:", target_rows_needed, "(rows 2 to", target_rows_needed, ")")

# Copy formatting pattern from example rows 2 and 3 alternating as needed, only for K:V
# (preserve existing formatting; populate blank rows with matching style/borders)
for tr in range(2, target_rows_needed + 1):
    template_row = 2 if (tr % 2 == 0) else 3
    if tr in (2, 3):
        continue
    for c in range(11, 23):  # K:V
        src = ws.cell(template_row, c)
        dst = ws.cell(tr, c)
        if dst.value is None:
            dst._style = copy(src._style)
            if src.number_format:
                dst.number_format = src.number_format
            dst.font = copy(src.font)
            dst.fill = copy(src.fill)
            dst.border = copy(src.border)
            dst.alignment = copy(src.alignment)
            dst.protection = copy(src.protection)
    ws.row_dimensions[tr].height = ws.row_dimensions[template_row].height

# Populate transposed values: 4 (number, code) pairs per row with spacer columns blank
pair_starts = [11, 14, 17, 20]  # K, N, Q, T
for idx, (num, code) in enumerate(pairs):
    tr = 2 + idx // 4
    start_col = pair_starts[idx % 4]
    ws.cell(tr, start_col).value = num
    ws.cell(tr, start_col + 1).value = code
    # preserve spacer column as blank
    ws.cell(tr, start_col + 2).value = None

# Clear any unused target cells within needed rows after last pair
remainder = len(pairs) % 4
if remainder != 0:
    last_row = target_rows_needed
    used_positions = set(pair_starts[:remainder])
    for start_col in pair_starts:
        if start_col not in used_positions:
            ws.cell(last_row, start_col).value = None
            ws.cell(last_row, start_col + 1).value = None
            ws.cell(last_row, start_col + 2).value = None

wb.save(outfile)
print("Saved:", outfile)

# recalculate and preserve sheet name if changed
original_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    # only one sheet here, restore titles by position
    for ws_cur, orig in zip(wb_check.worksheets, original_sheetnames):
        ws_cur.title = orig
    wb_check.save(outfile)

# Verify output with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]
print("Verified sheetnames:", wb_verify.sheetnames)
for r in range(2, target_rows_needed + 1):
    vals = [wsv.cell(r, c).value for c in range(11, 23)]
    print(r, vals)

output_spreadsheet = outfile
