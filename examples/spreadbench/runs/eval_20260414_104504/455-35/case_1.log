from openpyxl import load_workbook
from collections import Counter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Thorough inspection focused on target column B and nearby evidence
print("Target sheet:", ws.title)
print("Header row:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Count first-character distribution in column B
counter_b = Counter()
nonempty_b = 0
matches_rows = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 2).value
    s = "" if v is None else str(v)
    if s != "":
        nonempty_b += 1
        counter_b[s[0]] += 1
        if s[0] in ("H", "A"):
            matches_rows.append((r, s))
print("Column B non-empty rows:", nonempty_b)
print("Column B first-character counts (top 10):", counter_b.most_common(10))
print("Rows in column B starting with H or A (first 20):", matches_rows[:20])
print("Total rows in column B starting with H or A:", len(matches_rows))

# Also inspect first-character counts for all columns to verify no confusion
for c in range(1, ws.max_column + 1):
    counter = Counter()
    for r in range(2, min(ws.max_row, 2000) + 1):  # sample enough to identify pattern
        v = ws.cell(r, c).value
        s = "" if v is None else str(v)
        if s:
            counter[s[0]] += 1
    print(f"Col {c} ({ws.cell(1,c).value}) sample first-char counts:", counter.most_common(5))

# No pre-existing formulas/output columns; task is row deletion in place.
# Apply requested operation exactly on column B: keep header and rows whose B starts with H or A.
rows_to_keep = [1]
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 2).value
    s = "" if v is None else str(v)
    if s.startswith("H") or s.startswith("A"):
        rows_to_keep.append(r)

print("Original max_row:", ws.max_row)
print("Rows to keep including header:", len(rows_to_keep))

# Rewrite kept rows in place, then blank remaining rows
kept_data = []
for r in rows_to_keep:
    kept_data.append([ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

for out_r, row_vals in enumerate(kept_data, start=1):
    for c, val in enumerate(row_vals, start=1):
        ws.cell(out_r, c).value = val

for r in range(len(kept_data) + 1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
orig_names = [ws.title for ws in wb.worksheets]
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for wsx, orig in zip(wb2.worksheets, orig_names):
        wsx.title = orig
    wb2.save(out_path)
    print("Restored original sheet names:", orig_names)

# Verify output with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_names[0]]
print("Verified sheet names:", wbv.sheetnames)
print("Verified target sheet:", wsv.title)
print("Verified max_row/max_col:", wsv.max_row, wsv.max_column)

for r in range(1, min(10, wsv.max_row) + 1):
    print(f"Row {r}:", [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

# Check whether any remaining data rows violate the rule
violations = []
remaining_nonempty_rows = 0
for r in range(2, wsv.max_row + 1):
