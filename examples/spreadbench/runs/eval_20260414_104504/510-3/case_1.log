Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

def strip_marks(val):
    if val is None:
        return None
    return str(val).replace("\u202d", "").replace("\u202c", "").strip()

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Data"]

# Preserve exact existing number formats for D:G by capturing them first
numfmts = {}
for col in range(4, 8):
    # all appear General, but capture per-row to preserve exactly
    numfmts[col] = {r: ws.cell(r, col).number_format for r in range(1, ws.max_row + 1)}

# Rewrite rows 2:max_row
samples_before_after = []
for r in range(2, ws.max_row + 1):
    raw_d = ws.cell(r, 4).value
    cleaned_d = strip_marks(raw_d)
    if cleaned_d in (None, ""):
        continue
    parts = cleaned_d.split("/")
    if len(parts) != 3:
        raise ValueError(f"Unexpected date format at D{r}: {raw_d!r} -> {cleaned_d!r}")
    y, m, d = [int(strip_marks(p)) for p in parts]

    # Recreate D:G values
    ws.cell(r, 4).value = f"{y:02d}/{m:02d}/{d:02d}"   # cleaned string date
    ws.cell(r, 5).value = y
    ws.cell(r, 6).value = m
    ws.cell(r, 7).value = d

    # Restore original number formats exactly for D:G
    for col in range(4, 8):
        ws.cell(r, col).number_format = numfmts[col][r]

    # Hardcode sum in H
    ws.cell(r, 8).value = y * 365 + m * 12 + d

    if r <= 10 or r >= ws.max_row - 4:
        samples_before_after.append(
            (r, raw_d, ws.cell(r,4).value, ws.cell(r,5).value, ws.cell(r,6).value, ws.cell(r,7).value, ws.cell(r,8).value)
        )

# Ensure headers are not bold (instruction explicitly says do not bold titles)
for col in range(4, 9):
    ws.cell(1, col).font = ws.cell(1, col).font.copy(bold=False)

wb.save(outfile)
print("Saved to:", outfile)
print("Sample rewritten rows:")
for row in samples_before_after:
    print(row)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalc and fix sheet name if changed
wb2 = load_workbook(outfile)
print("Sheetnames after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename in order to original names
    for i, old_name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = old_name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verification with data_only=True
wbv = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", wbv.sheetnames)
wsv = wbv["Data"]

# Print target cells/ranges mentioned by instruction
for r in [2,3,4,5,6,7,8,9,10,74,75,76,77,78]:
    vals = [wsv.cell(r, c).value for c in range(4, 9)]
    print(r, vals)

# Sanity checks
assert wbv.sheetnames == orig_sheetnames
for r in range(2, wsv.max_row + 1):
    dval = wsv.cell(r, 4).value
    if dval in (None, ""):
        continue
    eval_ = wsv.cell(r, 5).value
    fval = wsv.cell(r, 6).value
    gval = wsv.cell(r, 7).value
    hval = wsv.cell(r, 8).value
    assert eval_ is not None and fval is not None and gval is not None and hval is not None, f"Blank target at row {r}"
    expected = int(eval_) * 365 + int(fval) * 12 + int(gval)
    assert int(hval) == expected, f"Mismatch at row {r}: {hval} vs {expected}"

output_spreadsheet = outfile
