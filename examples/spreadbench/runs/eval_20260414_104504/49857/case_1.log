import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Find actual last data row based on any non-empty cell in the row
def row_nonempty(r):
    return any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1))

data_rows = [r for r in range(1, ws.max_row + 1) if row_nonempty(r)]
print("Non-empty rows:", data_rows[:20], "...", data_rows[-10:])
last_data_row = max(data_rows)
print("Actual last data row:", last_data_row)

# Inspect rows around the real data area and formulas/values in G
for r in range(3, last_data_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(r, vals)

print("Current G formulas/values:")
for r in range(4, last_data_row + 1):
    print(r, "F=", ws[f"F{r}"].value, "G=", ws[f"G{r}"].value, "numfmt=", ws[f"G{r}"].number_format)

# Write formulas only for actual data rows where col A or F has content
for r in range(4, last_data_row + 1):
    row_has_data = any(ws.cell(r, c).value not in (None, "") for c in range(1, 10))
    if not row_has_data:
        continue
    # Match existing Yes/No text in col F, case-insensitively
    ws[f"G{r}"] = f'=IF(UPPER(TRIM(F{r}))="YES",COUNTIF($F$4:F{r},"Yes")+COUNTIF($F$4:F{r},"YES")+COUNTIF($F$4:F{r},"yes"),0)'

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore sheet name if changed
