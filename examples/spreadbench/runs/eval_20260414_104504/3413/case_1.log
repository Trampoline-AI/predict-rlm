import os, shutil
from openpyxl import load_workbook

# Reload and inspect target formulas/values precisely
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Current target cells and data types/formulas:")
for r in range(3, 7):
    cell = ws[f"G{r}"]
    print(f"G{r}: value={cell.value!r}, data_type={cell.data_type}")

# Build formula pattern for G3:G6
# Logic:
# if Frow="ALL": sum all totals for dept in Erow
# else if count exact dept+RU > 0: sum exact dept+RU
# else: fallback sum all totals for dept in Erow
for r in range(3, 7):
    formula = (
        f'=IF(F{r}="ALL",'
        f'SUMIF($A$3:$A$7,E{r},$C$3:$C$7),'
        f'IF(COUNTIFS($A$3:$A$7,E{r},$B$3:$B$7,F{r})>0,'
        f'SUMIFS($C$3:$C$7,$A$3:$A$7,E{r},$B$3:$B$7,F{r}),'
        f'SUMIF($A$3:$A$7,E{r},$C$3:$C$7)))'
    )
    ws[f"G{r}"] = formula
    print(f"Set G{r} -> {formula}")

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Check and restore sheet name if changed
orig_names = load_workbook(input_spreadsheet).sheetnames
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_names:
    for idx, orig in enumerate(orig_names):
        wb_after.worksheets[idx].title = orig
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify formulas and computed values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
print("Formulas in G3:G6:")
for r in range(3, 7):
    print(r, wsf[f"G{r}"].value)

wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values[orig_names[0]]
print("Computed values in E3:G6:")
for r in range(3, 7):
    print(r, [wsv[f"E{r}"].value, wsv[f"F{r}"].value, wsv[f"G{r}"].value])

output_spreadsheet = out_path
