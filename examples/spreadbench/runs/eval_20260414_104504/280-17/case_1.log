from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

workbook_info = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    headers = row_values(ws, 1, ws.max_column)
    workbook_info[sname] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
    }
    print(f"\n--- Sheet: {sname} ---")
    print(f"Rows: {ws.max_row}, Cols: {ws.max_column}")
    print("Headers:")
    for i, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)} ({i}): {h!r}")
    
    first_n = min(10, ws.max_row)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        print(f"Row {r}: {row_values(ws, r, ws.max_column)}")
    
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast {ws.max_row - start_last + 1} rows:")
    for r in range(start_last, ws.max_row + 1):
        print(f"Row {r}: {row_values(ws, r, ws.max_column)}")
    
    # duplicate scan per column excluding header row
    print("\nColumns with duplicates (candidate key columns):")
    candidates = []
    for c in range(1, ws.max_column + 1):
        vals = []
        rownums = []
        for r in range(2, ws.max_row + 1):
            v = ws.cell(r, c).value
            if v is not None and v != "":
                vals.append(v)
                rownums.append(r)
        if not vals:
            continue
        # preserve counts
        counts = {}
        positions = {}
        for r, v in zip(rownums, vals):
            counts[v] = counts.get(v, 0) + 1
            positions.setdefault(v, []).append(r)
        dup_values = {k: v for k, v in counts.items() if v > 1}
        if dup_values:
            sample = list(dup_values.items())[:5]
            sample_positions = {k: positions[k] for k, _ in sample}
            candidates.append((c, headers[c-1], len(dup_values), sample_positions))
    for c, h, dupcnt, sample_positions in candidates[:10]:
        print(f"  {get_column_letter(c)} {h!r}: {dupcnt} duplicated values; sample positions={sample_positions}")
    if not candidates:
        print("  None")

# keep wb and workbook_info in memory for next step
