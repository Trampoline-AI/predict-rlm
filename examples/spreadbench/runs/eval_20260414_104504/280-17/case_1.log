from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb2 = load_workbook(infile)
orig_names = wb2.sheetnames[:]
ws = wb2[orig_names[0]]

# Print exact target column values before modification
print("Before modification, column B values by row:")
for r in range(1, ws.max_row + 1):
    print(r, ws.cell(r, 2).value)

# Determine last occurrence rows for each value in column B
last_row_for_value = {}
for r in range(1, ws.max_row + 1):
    val = ws.cell(r, 2).value
    last_row_for_value[val] = r

rows_to_keep = sorted(last_row_for_value.values())
rows_to_delete = [r for r in range(1, ws.max_row + 1) if r not in rows_to_keep]

print("Rows to keep (last occurrence of each unique value in column B):", rows_to_keep)
print("Rows to delete:", rows_to_delete)

# Delete bottom-up
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

wb2.save(outfile)
print("Saved to", outfile)

# Recalculate and restore sheet names if needed
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring to", orig_names)
    for i, old_name in enumerate(orig_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(outfile)

# Verify output after recalculation
