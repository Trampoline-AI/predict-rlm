print("Remaining rows:")
remaining = []
for r in range(1, vws.max_row + 1):
    row = [vws.cell(r, c).value for c in range(1, vws.max_column + 1)]
    remaining.append(row)
    print(r, row)

output_spreadsheet = outfile
