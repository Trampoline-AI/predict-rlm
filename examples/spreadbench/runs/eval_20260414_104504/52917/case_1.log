    cell = ws[f"J{r}"]
    print(r, "J value:", cell.value, "data_type:", cell.data_type, "number_format:", cell.number_format)

# Determine rows needing output
rows_to_fill = []
for r in range(2, ws.max_row + 1):
    a, b, c, j = ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value, ws[f"J{r}"].value
    if a is not None and b is not None and c is not None and j is None:
        rows_to_fill.append(r)
