import os, shutil
from collections import Counter
from openpyxl import load_workbook
from openpyxl.styles import Alignment

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Reconfirm target cells blank/current values
print("Before write I3:J10:")
for r in range(3, 11):
    print(r, ws[f"I{r}"].value, ws[f"J{r}"].value)

# Count items from column B, data rows with actual values
items = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 2).value
    if v not in (None, ""):
        items.append(str(v).strip())
counts = Counter(items)
print("Counts:", counts)

order = ["A006", "A004", "A005"]
# In case there are additional items in larger files, append them sorted after requested custom order
remaining = sorted([k for k in counts if k not in order])
final_items = [x for x in order if x in counts] + remaining
print("Final item order:", final_items)

# Write headers and results starting at I3
ws["I3"] = "ITEM"
ws["J3"] = "Qty"

for idx, item in enumerate(final_items, start=4):
    ws.cell(idx, 9).value = item
    ws.cell(idx, 10).value = counts[item]

# Left align entire answer range written
last_row = 3 + len(final_items)
for r in range(3, last_row + 1):
    for c in range(9, 11):
        ws.cell(r, c).alignment = Alignment(horizontal="left")

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
else:
    print("Sheet names preserved:", wb2.sheetnames)

# Verify with data_only and regular load
verify_vals = load_workbook(outfile, data_only=True)
vws = verify_vals[orig_sheetnames[0]]
print("Verified target values:")
for r in range(3, last_row + 1):
    print(r, vws[f"I{r}"].value, vws[f"J{r}"].value)

verify_fmt = load_workbook(outfile)
fws = verify_fmt[orig_sheetnames[0]]
print("Verified alignment:")
for r in range(3, last_row + 1):
    print(r, fws.cell(r, 9).alignment.horizontal, fws.cell(r, 10).alignment.horizontal)

output_spreadsheet = outfile
