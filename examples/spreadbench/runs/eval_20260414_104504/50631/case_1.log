from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]
original_sheetnames = wb.sheetnames[:]

yellow = PatternFill(fill_type="solid", start_color="FFFF00", end_color="FFFF00")
calibri11 = Font(name="Calibri", size=11)

# Hide gridlines as instructed
ws.sheet_view.showGridLines = False

# Extend sheet to row 69 by copying row styles from row 38 where needed
for r in range(ws.max_row + 1, 70):
    for c in range(1, ws.max_column + 1):
        src = ws.cell(38, c)
        dst = ws.cell(r, c)
        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.border:
            dst.border = copy(src.border)
        if src.protection:
            dst.protection = copy(src.protection)

# Apply Calibri throughout used region
for r in range(1, 70):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        cell.font = copy(calibri11)

# Preserve labels/source dates
ws["B2"] = "Beg Date"
ws["F2"] = "End Date"
ws["J3"] = "Dates to exclude"

# Number formats for date columns
for col in ["B", "D", "F", "H", "J"]:
    for r in range(1, 70):
        ws[f"{col}{r}"].number_format = "mm-dd-yy"

# Clear target ranges first
for col in ["B", "D", "F", "H"]:
    for r in range(7, 70):
        ws[f"{col}{r}"].value = None

# Fill colors exactly where appropriate
# B: rows 7:37 yellow, row 37 blank formatted cell after last date
for r in range(7, 38):
    ws[f"B{r}"].fill = copy(yellow)
for r in range(38, 70):
    ws[f"B{r}"].fill = PatternFill(fill_type=None)

# D/F/H: rows 7:69 yellow
for col in ["D", "F", "H"]:
    for r in range(7, 70):
        ws[f"{col}{r}"].fill = copy(yellow)

# Recreate formulas in column B
for r in range(7, 37):
    ws[f"B{r}"] = f'=IF($B$3+ROWS($B$7:$B{r})-1<=DATE(2021,9,30),$B$3+ROWS($B$7:$B{r})-1,"")'
    ws[f"B{r}"].fill = copy(yellow)
    ws[f"B{r}"].font = copy(calibri11)
    ws[f"B{r}"].number_format = "mm-dd-yy"

# B37 blank but formatted
ws["B37"].value = None
ws["B37"].fill = copy(yellow)
ws["B37"].font = copy(calibri11)
ws["B37"].number_format = "mm-dd-yy"

# Recreate formulas in D and F down to 11/2/2021
for r in range(7, 70):
    ws[f"D{r}"] = f'=IF($B$3+ROWS($D$7:D{r})-1<=DATE(2021,11,2),$B$3+ROWS($D$7:D{r})-1,"")'
    ws[f"F{r}"] = f'=IF($B$3+ROWS($F$7:F{r})-1<=DATE(2021,11,2),$B$3+ROWS($F$7:F{r})-1,"")'
    for col in ["D", "F"]:
        ws[f"{col}{r}"].fill = copy(yellow)
        ws[f"{col}{r}"].font = copy(calibri11)
        ws[f"{col}{r}"].number_format = "mm-dd-yy"

# New formula for H: workdays after B3 excluding weekends and holidays in J5:J7
for r in range(7, 70):
    ws[f"H{r}"] = f'=WORKDAY($B$3-1,ROWS($H$7:H{r}),$J$5:$J$7)'
    ws[f"H{r}"].fill = copy(yellow)
    ws[f"H{r}"].font = copy(calibri11)
    ws[f"H{r}"].number_format = "mm-dd-yy"

wb.save(outfile)
print("Saved:", outfile)

res = await recalculate(outfile)
print("Recalculate:", res)

# Reload and restore sheet names if LO changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != original_sheetnames:
    for i, name in enumerate(original_sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)

# Verification
wbv = load_workbook(outfile, data_only=False)
wsv = wbv["Sheet1"]
print("Verify sheet names:", wbv.sheetnames)
print("Gridlines hidden:", wsv.sheet_view.showGridLines)
print("Fonts B7,H7:", wsv["B7"].font.name, wsv["H7"].font.name)
print("B formulas/values rows 35:38:", [(r, wsv[f'B{r}'].value, wsv[f'B{r}'].fill.fgColor.rgb if wsv[f'B{r}'].fill.fill_type else None) for r in range(35,39)])
print("D formulas rows 67:69:", [(r, wsv[f'D{r}'].value) for r in range(67,70)])
print("F formulas rows 67:69:", [(r, wsv[f'F{r}'].value) for r in range(67,70)])
print("H formulas rows 7:10:", [(r, wsv[f'H{r}'].value) for r in range(7,11)])

wbv2 = load_workbook(outfile, data_only=True)
wsd = wbv2["Sheet1"]
