from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
import os, shutil

# Reload and inspect target/source areas carefully
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet title:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)

# Print full relevant ranges A:I and K:S
print("\nSource table A:I rows 4:19")
for r in range(4, 20):
    vals = [ws.cell(r, c).value for c in range(1, 10)]
    print(r, vals)

print("\nTarget table K:S rows 4:19")
for r in range(4, 20):
    vals = []
    for c in range(11, 20):
        v = ws.cell(r, c).value
        vals.append(v)
    print(r, vals)

# Print existing formulas/values in target output cells M6:S19
print("\nExisting target cells M6:S19:")
for r in range(6, 20):
    row = []
    for c in range(13, 20):
        cell = ws.cell(r, c)
        row.append((f"{get_column_letter(c)}{r}", cell.value))
    print(row)

# Identify actual rows with target brands in L
target_rows = [r for r in range(6, ws.max_row + 1) if ws.cell(r, 12).value not in (None, "")]
print("\nTarget rows with brands in L:", target_rows)
print("Target categories in M:S row 5:", [ws.cell(5, c).value for c in range(13, 20)])
print("Source categories in C:I row 5:", [ws.cell(5, c).value for c in range(3, 10)])

# Build output path
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

# Write formulas into M:S for rows having brand in L
wb2 = load_workbook(outfile)
ws2 = wb2[wb2.sheetnames[0]]

for r in target_rows:
    brand_ref = f"$L{r}"
    for c in range(13, 20):  # M:S
        cat_ref = f"{get_column_letter(c)}$5"
        formula = f'=INDEX($C$6:$I$19, MATCH({brand_ref}, $B$6:$B$19, 0), MATCH({cat_ref}, $C$5:$I$5, 0))'
        ws2.cell(r, c).value = formula

# Save before recalc
wb2.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
result = await recalculate(outfile)
print("Recalculate:", result)

# Reload after recalc, fix sheet name if changed
orig_names = wb.sheetnames
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_names:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_names)
    # rename sheets back in order
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)

# Verify formulas and evaluated values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_names[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_names[0]]

print("\nVerification: formulas in M6:S19")
for r in target_rows:
    print(r, [ws_formula.cell(r, c).value for c in range(13, 20)])

print("\nVerification: evaluated values in L:S for target rows")
for r in target_rows:
    print(r, [ws_values.cell(r, c).value for c in range(12, 20)])

output_spreadsheet = outfile
