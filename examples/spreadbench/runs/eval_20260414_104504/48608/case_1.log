from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = output_spreadsheet  # from prior step

# Use data_only workbook to read actual session IDs in G, including G2 from array formula cache
wb_formula = load_workbook(outfile)
ws_formula = wb_formula[wb_formula.sheetnames[0]]

wb_data = load_workbook(outfile, data_only=True)
ws_data = wb_data[wb_data.sheetnames[0]]

# Build lookup from source table A:B in formula workbook
session_to_name = {}
for r in range(2, ws_formula.max_row + 1):
    a = ws_formula[f"A{r}"].value
    b = ws_formula[f"B{r}"].value
    c = ws_formula[f"C{r}"].value
    if any(v is not None for v in (a, b, c)) and a is not None and b is not None:
        session_to_name[b] = a

print("Session lookup:", session_to_name)

# Overwrite F for every row where data_only G has a session ID
fixed = []
for r in range(2, ws_formula.max_row + 1):
    g_cached = ws_data[f"G{r}"].value
    if g_cached in (None, ""):
        continue
    name = session_to_name.get(g_cached)
    print(f"row {r}: G cached={g_cached}, old F={ws_formula[f'F{r}'].value}, new={name}")
    if name is not None:
        ws_formula[f"F{r}"] = name
        fixed.append((r, g_cached, name))

wb_formula.save(outfile)
print("Fixed rows:", fixed)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify
wbv = load_workbook(outfile, data_only=True)
wsv = wbv[wbv.sheetnames[0]]
print("Verified targets:")
for r in range(2, 10):
    print(r, "G=", wsv[f"G{r}"].value, "F=", wsv[f"F{r}"].value)
