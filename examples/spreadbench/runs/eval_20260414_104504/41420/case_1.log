from openpyxl import load_workbook
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Build a LibreOffice-compatible formula that returns the k-th unique digit
# present in A{row}, considering digits in ascending order 0..9.
def kth_digit_formula(row, k):
    a = f"$A{row}"
    count_prev = 0
    parts = []
    for d in range(10):
        cond_present = f'ISNUMBER(FIND("{d}",{a}&""))'
        cond_rank = f'({count_prev}+1={k})'
        parts.append((cond_present, cond_rank, str(d)))
        count_prev += f'--ISNUMBER(FIND("{d}",{a}&""))'
    # nest IFs
    formula = ""
    for cond_present, cond_rank, val in parts:
        formula += f'IF(AND({cond_present},{cond_rank}),{val},'
    formula += '""' + (")" * len(parts))
    return "=" + formula

# Load and inspect formulas/targets again briefly
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Writing formulas to target range C2:G8 on sheet:", ws.title)
for r in range(2, 9):
    print("A{} = {}".format(r, ws[f"A{r}"].value))
    for idx, col in enumerate("CDEFG", start=1):
        f = kth_digit_formula(r, idx)
        ws[f"{col}{r}"] = f
        if r <= 3:
            print(f"{col}{r} formula:", f)

wb.save(outfile)
print("Saved to", outfile)

