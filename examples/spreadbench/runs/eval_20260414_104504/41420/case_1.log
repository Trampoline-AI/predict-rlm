from openpyxl import load_workbook
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

def kth_digit_formula(row, k):
    a = f"$A{row}"
    prior_terms = []
    pieces = []
    for d in range(10):
        present = f'ISNUMBER(FIND("{d}",{a}&""))'
        if prior_terms:
            rank_expr = "(" + "+".join(prior_terms) + "+1)"
        else:
            rank_expr = "1"
        pieces.append(f'IF(AND({present},{rank_expr}={k}),{d},')
        prior_terms.append(f'--ISNUMBER(FIND("{d}",{a}&""))')
    return "=" + "".join(pieces) + '""' + (")" * 10)

# Load workbook and confirm target area before writing
