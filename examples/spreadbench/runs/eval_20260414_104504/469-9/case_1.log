import os, shutil
from openpyxl import load_workbook

# Re-open and inspect target columns H:I before writing
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Pre-write target inspection H:I")
for r in range(1, ws.max_row + 1):
    print(r, ws.cell(r, 8).value, ws.cell(r, 9).value)

# Write headers and split amounts from column C
ws["H1"] = "Debits"
ws["I1"] = "Credits"

written = []
for r in range(2, ws.max_row + 1):
    amt = ws.cell(r, 3).value
    h = ws.cell(r, 8)
    i = ws.cell(r, 9)
    # clear existing values only in target columns for processed rows
    h.value = None
    i.value = None
    if amt is None or amt == "":
        pass
    else:
        try:
            num = float(amt)
        except Exception:
            num = None
        if num is not None:
            if num < 0:
                h.value = abs(num)
            elif num > 0:
                i.value = abs(num)
    written.append((r, amt, h.value, i.value))

print("Planned written rows:")
for row in written:
    print(row)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames and len(wb_after.sheetnames) == len(wb.sheetnames):
    for idx, orig_name in enumerate(wb.sheetnames):
        wb_after[wb_after.sheetnames[idx]].title = orig_name
    wb_after.save(out_path)
    print("Restored sheet names:", wb.sheetnames)

# Verify with data_only
verify_wb = load_workbook(out_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[wb.sheetnames[0]]
print("Verification H:I values")
for r in range(1, vws.max_row + 1):
    print(r, vws.cell(r, 3).value, vws.cell(r, 8).value, vws.cell(r, 9).value)

output_spreadsheet = out_path
```
