import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    # sample first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r, ws.max_column))
    # print cols A:I values for target area
    if ws.max_column >= 9:
        print("Cols A:I preview:")
        for r in range(1, min(ws.max_row, 15)+1):
            print(r, row_values(ws, r, 9))
        print("Last rows A:I:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            print(r, row_values(ws, r, 9))

