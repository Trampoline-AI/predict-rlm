```repl
from openpyxl import load_workbook
from copy import copy
from collections import defaultdict
import os

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Determine true data bounds
max_col = ws.max_column
last_nonempty_row = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, max_col + 1)):
        last_nonempty_row = r

print("Original sheet names:", orig_sheet_names)
print("Using sheet:", ws.title, "last_nonempty_row:", last_nonempty_row, "max_col:", max_col)

# Read all rows and preserve formatting/style of rows if possible
all_row_data = []
for r in range(1, last_nonempty_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
    all_row_data.append(vals)

# Keep top blank rows exactly as-is until first data row.
first_data_row = None
for r in range(1, last_nonempty_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    e = ws.cell(r, 5).value
    if a is not None or b is not None or e is not None:
        first_data_row = r
        break

print("First data row:", first_data_row)

# Build groups from data rows
groups = defaultdict(list)  # (A,B) -> list of dicts
for r in range(first_data_row, last_nonempty_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
    a = row_vals[0]
    b = row_vals[1]
    e = row_vals[4] if max_col >= 5 else None
    # only actual data rows
    if a is None and b is None and e is None and all(v in (None, "") for v in row_vals):
        continue
    groups[(a, b)].append({"rownum": r, "vals": row_vals, "e": e})

# Decide rows to keep
kept = []
decision_summary = []
for key, items in groups.items():
    dated_items = [it for it in items if it["e"] not in (None, "")]
    if not dated_items:
        decision_summary.append((key, "delete_all_blank_E", [it["rownum"] for it in items]))
        continue
    max_e = max(it["e"] for it in dated_items)
    keep_items = [it for it in dated_items if it["e"] == max_e]
    kept.extend(keep_items)
    decision_summary.append((key, max_e, [it["rownum"] for it in keep_items]))

# Preserve original row order
kept.sort(key=lambda x: x["rownum"])

print("Group decisions:")
for item in decision_summary:
    print(item)
print("Total kept rows:", len(kept), "out of data rows:", sum(len(v) for v in groups.values()))

# Clear existing data rows from first_data_row through last_nonempty_row
for r in range(first_data_row, last_nonempty_row + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = None

# Write back kept rows starting at first_data_row
for i, item in enumerate(kept, start=first_data_row):
    for c, val in enumerate(item["vals"], start=1):
        ws.cell(i, c).value = val

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc renamed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position if same number of sheets
    if len(wb_check.sheetnames) == len(orig_sheet_names):
        for i, orig_name in enumerate(orig_sheet_names):
            wb_check.worksheets[i].title = orig_name
        wb_check.save(outfile)
        print("Restored original sheet names:", orig_sheet_names)

# Verification with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify[orig_sheet_names[0]]

# Find remaining nonempty rows and inspect all kept rows
remaining_rows = []
for r in range(1, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, max_col + 1)]
    if any(v not in (None, "") for v in vals):
        remaining_rows.append((r, vals))

print("Remaining nonempty rows count:", len(remaining_rows))
print("Remaining rows:")
for r, vals in remaining_rows:
    print(r, vals)

# Rule verification
verify_groups = defaultdict(list)
for r, vals in remaining_rows:
    a = vals[0] if len(vals) >= 1 else None
    b = vals[1] if len(vals) >= 2 else None
    e = vals[4] if len(vals) >= 5 else None
    if r < first_data_row and all(v in (None, "") for v in vals):
        continue
    if a is not None or b is not None or e is not None:
        verify_groups[(a, b)].append((r, e, vals))

issues = []
for key, items in verify_groups.items():
    es = [e for _, e, _ in items]
    if any(e in (None, "") for e in es):
        issues.append((key, "blank E remained", items))
    if len(set(es)) > 1:
        issues.append((key, "multiple E values remained", items))

print("Verification issues:", issues)
final_output_path = outfile
