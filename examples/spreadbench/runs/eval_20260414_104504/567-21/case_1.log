    for r in range(1, min(last_row, 12) + 1):
        print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"E{r}"].value)
    
    print("\nFocused sample for columns A,B,E (last 5 non-empty rows):")
    for r in range(start_last, last_row + 1):
        print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"E{r}"].value)

    # Check for formulas in first few rows/cells
