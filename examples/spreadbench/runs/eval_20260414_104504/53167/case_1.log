import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Verify columns and inspect existing values/formulas in target area
print("Sheet:", ws.title)
print("Existing B:E rows 3:16")
for r in range(3, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(2, 6)]
    print(r, vals)

print("\nExisting E formulas/values:")
for r in range(4, ws.max_row + 1):
    print(r, ws[f"E{r}"].value, ws[f"E{r}"].data_type)

# Infer formula: difference from previous weight for same serial number, else 0
# Use LOOKUP over prior rows in same serial-number column.
for r in range(4, ws.max_row + 1):
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    d = ws[f"D{r}"].value
    if b is None and c is None and d is None:
        continue
    formula = f'=IF(COUNTIF($B$4:B{r-1},B{r})=0,0,LOOKUP(2,1/($B$4:B{r-1}=B{r}),$D$4:D{r-1})-D{r})'
    ws[f"E{r}"] = formula

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and ensure sheet names preserved
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    # rename corresponding sheets by position
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)

# Verify formulas and calculated values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
print("\nWritten formulas in E4:E16:")
for r in range(4, wsf.max_row + 1):
    print(f"E{r} formula:", wsf[f"E{r}"].value)

wb_vals = load_workbook(out_path, data_only=True)
wsv = wb_vals[orig_names[0]]
print("\nCalculated values B:E rows 4:16:")
for r in range(4, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(2, 6)])

output_spreadsheet = out_path
