# Re-open workbook for detailed inspection of example region styles/formulas
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Inspect example mapping rows 27:46 -> target 6:25")
for r in [27, 28, 39, 46]:
    vals = []
    for c in range(5, 11):  # E:J sample
        v = ws.cell(r, c).value
        if hasattr(v, "text"):
            v = v.text
        vals.append((f"{get_column_letter(c)}{r}", v))
    print(r, vals)

# Inspect row styles/number formats for target row 5 and example rows
for r in [5, 6, 26, 27]:
    print(f"\nRow {r} styles/values E:K")
    for c in range(5, 12):
        cell = ws.cell(r, c)
        v = cell.value.text if hasattr(cell.value, "text") else cell.value
        print(
            f"{get_column_letter(c)}{r}",
            "val=", v,
            "fmt=", cell.number_format,
            "fill=", cell.fill.fill_type,
            "font_bold=", cell.font.bold,
            "border_left=", cell.border.left.style,
            "align=", cell.alignment.horizontal,
        )

# Build formulas exactly following the demonstrated pattern in rows 27:46
def build_formula(row, col):
    col_letter = get_column_letter(col)
    return f'=IFERROR((MOD(DATEDIF({col_letter}$4+1,EOMONTH($D{row},0)+1,"m"),12/$C{row})=0)*$B{row},0)+(EOMONTH($D{row},0)={col_letter}$4)*$A{row}'

# Apply changes
for c in range(5, 29):  # E:AB
    if ws.cell(5, c).value in (None, ""):
        ws.cell(5, c).value = "-"
    for r in range(6, 26):  # 6:25
        ws.cell(r, c).value = build_formula(r, c)

# Optionally copy number format/style from example area (same relative columns)
for c in range(5, 29):
    # row 5 style from row 26 if present else row 27
    src_style = ws.cell(26, c) if 26 <= ws.max_row else ws.cell(27, c)
    tgt = ws.cell(5, c)
    tgt._style = copy.copy(src_style._style)
    tgt.number_format = src_style.number_format
    # copy styles for formula block from rows 27:46 -> 6:25
    for r in range(6, 26):
        src = ws.cell(r + 21, c)
        if r + 21 <= ws.max_row:
