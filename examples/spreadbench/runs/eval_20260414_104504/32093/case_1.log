from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row 2:", headers2)
    # print first 10 rows and last 5 rows
    sample_rows = list(range(1, min(ws.max_row, 10) + 1))
    tail_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in sample_rows + tail_rows:
        if r not in seen:
            seen.add(r)
            rows_to_show.append(r)
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)

    # Inspect columns B:F specifically
    print("Columns B:F preview/formulas:")
    for r in rows_to_show:
        vals = []
        for c in range(2, min(6, ws.max_column) + 1):
            cell = ws.cell(r, c)
            vals.append((f"{get_column_letter(c)}{r}", cell.value))
        print(vals)
