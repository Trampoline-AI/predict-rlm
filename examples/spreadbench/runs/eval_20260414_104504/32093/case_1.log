```repl
from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect current formulas/values in target F before modifying
print("Pre-write target F values/formulas:")
for r in range(2, ws.max_row + 1):
    print(r, {"B": ws[f"B{r}"].value, "C": ws[f"C{r}"].value, "D": ws[f"D{r}"].value, "E": ws[f"E{r}"].value, "F": ws[f"F{r}"].value})

written_rows = []
skipped_rows = []
for r in range(2, ws.max_row + 1):
    fcell = ws[f"F{r}"]
    # preserve existing plausible answers
    if fcell.value not in (None, ""):
        skipped_rows.append(r)
        continue
    formula = f'=IF(COUNTA(C{r}:E{r})=0,B{r},IF(COUNTA(C{r}:E{r})=1,IF(C{r}<>"",C{r},IF(D{r}<>"",D{r},E{r})),"ERROR"))'
    fcell.value = formula
    written_rows.append((r, formula))

print("Rows written:", written_rows)
print("Rows skipped (pre-existing F):", skipped_rows)

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Re-open and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]

print("\nVerification F2:F15:")
for r in range(2, wsv.max_row + 1):
    print(
        r,
        {
            "inputs": [wsv[f"B{r}"].value, wsv[f"C{r}"].value, wsv[f"D{r}"].value, wsv[f"E{r}"].value],
            "formula_or_value": wsf[f"F{r}"].value,
            "cached_value": wsv[f"F{r}"].value,
        }
    )

output_spreadsheet = outfile
