Code:
```repl
from collections import OrderedDict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

# Reload workbook for manipulation
wb = load_workbook(input_spreadsheet)
ws = wb["merge"]

# Inspect source columns A:D more carefully
last_nonempty = 0
for r in range(ws.max_row, 0, -1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    if any(v is not None and v != "" for v in vals):
        last_nonempty = r
        break

print("Source data rows:", 2, "to", last_nonempty)
print("Headers A:D:", [ws.cell(1, c).value for c in range(1, 5)])
print("Existing target headers G:J:", [ws.cell(1, c).value for c in range(7, 11)])
print("Existing target row 2 before write:", [ws.cell(2, c).value for c in range(7, 11)])

# Aggregate by A,B,C and sum D, preserving first-seen order
agg = OrderedDict()
for r in range(2, last_nonempty + 1):
    key = tuple(ws.cell(r, c).value for c in range(1, 4))
    total = ws.cell(r, 4).value
    if all(v is None or v == "" for v in key):
        continue
    if key not in agg:
        agg[key] = 0
    agg[key] += 0 if total in (None, "") else total

print("Unique groups:", len(agg))
for i, (k, v) in enumerate(agg.items(), start=1):
    print("Group", i, k, "sum", v)

# Clear old target output values below headers in G:J
for r in range(2, ws.max_row + 1):
    for c in range(7, 11):
        ws.cell(r, c).value = None

# Write aggregated output starting G2
out_row = 2
for (idv, brand, typ), total in agg.items():
    ws.cell(out_row, 7).value = idv
    ws.cell(out_row, 8).value = brand
    ws.cell(out_row, 9).value = typ
    ws.cell(out_row, 10).value = total
    out_row += 1

print("Written rows G:J:")
for r in range(1, out_row):
    print(r, [ws.cell(r, c).value for c in range(7, 11)])

# Save output
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and then verify
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if changed
wb_check = load_workbook(out_path)
if wb_check.sheetnames != ["merge"]:
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    # rename first sheet back if needed
    if len(wb_check.sheetnames) == 1:
        wb_check[wb_check.sheetnames[0]].title = "merge"
        wb_check.save(out_path)
        print("Renamed sheet back to merge")
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify values after recalc with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["merge"]
print("Verified target G1:J6:")
for r in range(1, 7):
    print(r, [wsv.cell(r, c).value for c in range(7, 11)])

output_spreadsheet = out_path
```
