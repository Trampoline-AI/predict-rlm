from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("INSTRUCTION:\n", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)]
        print("Row2 values:", row2)
    # print first up to 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
            print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# specifically inspect columns A:D and any formulas in D
for ws in wb.worksheets:
    print(f"\nSpecific scan for {ws.title} cols A:D:")
    for r in range(1, min(ws.max_row, 25)+1):
