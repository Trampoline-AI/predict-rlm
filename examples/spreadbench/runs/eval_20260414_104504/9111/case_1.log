Code:
```repl
from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Build case-insensitive mappings from the visible lists, excluding helper labels.
list1 = {}
for r in range(2, ws.max_row + 1):
    name = ws.cell(r, 7).value
    idv = ws.cell(r, 8).value
    if name not in (None, ""):
        key = str(name).strip()
        if key.lower() != "list1":
            list1[key.lower()] = idv

list2 = {}
for r in range(2, ws.max_row + 1):
    name = ws.cell(r, 10).value
    idv = ws.cell(r, 11).value
    if name not in (None, ""):
        key = str(name).strip()
        if key.lower() != "list2":
            list2[key.lower()] = idv

print("Case-insensitive list1:", list1)
print("Case-insensitive list2:", list2)

# Determine target rows: rows with sequence number in col A
target_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, 1).value not in (None, "")]
print("Target rows:", target_rows)

changes = []
for r in target_rows:
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    cur = ws.cell(r, 4).value

    b_key = str(b).strip().lower() if b not in (None, "") else ""
    c_key = str(c).strip().lower() if c not in (None, "") else ""

    if not b_key and not c_key:
        new = ""
    elif b_key and b_key in list1:
        new = list1[b_key]
    elif c_key and c_key in list2:
        new = list2[c_key]
    else:
        new = 2500

    if cur != new:
        changes.append((r, cur, new, b, c))
        ws.cell(r, 4).value = new

# Leave D1 alone except maybe note it; target outputs are row-wise below header/sample region
print("Planned/Applied changes:")
for item in changes:
    print(item)
print("Total changes:", len(changes))

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open after recalc; repair sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    for i, old_name in enumerate(orig_sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = old_name
    wb2.save(outfile)
    wb2 = load_workbook(outfile)

print("Final sheet names:", wb2.sheetnames)

# Verify with data_only
ver = load_workbook(outfile, data_only=True)
vws = ver["Sheet1"]
print("\nVerification rows 2:20 A:D")
for r in range(2, 21):
    print(r, [vws.cell(r, c).value for c in range(1, 5)])

output_spreadsheet = outfile
