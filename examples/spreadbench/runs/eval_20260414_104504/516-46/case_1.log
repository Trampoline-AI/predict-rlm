from openpyxl import load_workbook
from collections import defaultdict
from datetime import datetime
import os

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Inspect H:L existing rows 1-10:")
for r in range(1, min(10, ws.max_row)+1):
    vals = [ws.cell(r,c).value for c in range(8,13)]
    print(r, vals)

print("\nCell formulas/types in H2:L5:")
for r in range(2, min(5, ws.max_row)+1):
    print(r, [(ws.cell(r,c).coordinate, ws.cell(r,c).value, type(ws.cell(r,c).value).__name__) for c in range(8,13)])

# Summarize source rows by brand/date
brand_date_rows = defaultdict(list)
for r in range(2, ws.max_row+1):
    date = ws.cell(r,1).value
    brand = ws.cell(r,2).value
    batch = ws.cell(r,3).value
    origin = ws.cell(r,4).value
    qty = ws.cell(r,5).value
    if any(v is not None for v in [date, brand, batch, origin, qty]):
        brand_date_rows[(brand, date)].append((r, batch, origin, qty))

print("\nSource rows grouped by brand/date:")
for key in sorted(brand_date_rows.keys(), key=lambda x: (str(x[0]), x[1] or datetime.min)):
    print(key, brand_date_rows[key])

# Compute intended output candidates: one row per brand using last date and summed qty on that date
brand_rows = defaultdict(list)
for r in range(2, ws.max_row+1):
    vals = [ws.cell(r,c).value for c in range(1,6)]
    if any(v is not None for v in vals):
        brand_rows[ws.cell(r,2).value].append((r, *vals))

computed = []
for brand, rows in sorted(brand_rows.items()):
    max_date = max(row[1] for row in rows)
    last_rows = [row for row in rows if row[1] == max_date]
    total_qty = sum((row[5] or 0) for row in last_rows)
    computed.append({
        "brand": brand,
        "max_date": max_date,
        "last_rows": last_rows,
        "total_qty": total_qty,
    })

print("\nComputed intended rows per brand:")
