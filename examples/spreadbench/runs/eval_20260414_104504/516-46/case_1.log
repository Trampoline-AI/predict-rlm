import os
from collections import defaultdict
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Collect source rows A:E
source_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    if any(v is not None and v != "" for v in vals):
        source_rows.append({
            "row": r,
            "date": vals[0],
            "brand": vals[1],
            "batch": vals[2],
            "origin": vals[3],
            "quantity": vals[4] or 0,
        })

# Find last date per brand
last_date_by_brand = {}
for row in source_rows:
    b = row["brand"]
    d = row["date"]
    if b is None or d is None:
        continue
    if b not in last_date_by_brand or d > last_date_by_brand[b]:
        last_date_by_brand[b] = d

# Aggregate rows occurring on each brand's last date.
# Group by date+brand+batch+origin and sum quantity for duplicates.
agg = defaultdict(lambda: 0)
for row in source_rows:
    b = row["brand"]
    d = row["date"]
    if b in last_date_by_brand and d == last_date_by_brand[b]:
        key = (d, b, row["batch"], row["origin"])
        agg[key] += row["quantity"] or 0

results = []
for key, qty in agg.items():
    d, b, batch, origin = key
    results.append((d, b, batch, origin, qty))

# Sort by brand then date
results.sort(key=lambda x: (str(x[1]), x[0], str(x[2]), str(x[3])))

print("Computed results to write H:L:")
for item in results:
    print(item)

# Preserve header row H1:L1; clear existing output area H2:L(max existing relevant row)
clear_to = max(ws.max_row, 2 + len(results) + 5)
for r in range(2, clear_to + 1):
    for c in range(8, 13):
        ws.cell(r, c).value = None

# Write results starting H2
start_row = 2
for i, (d, b, batch, origin, qty) in enumerate(results, start=start_row):
    ws.cell(i, 8).value = d
    ws.cell(i, 9).value = b
    ws.cell(i, 10).value = batch
    ws.cell(i, 11).value = origin
    ws.cell(i, 12).value = qty

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename positionally
    for idx, orig_name in enumerate(orig_sheetnames):
        wb2.worksheets[idx].title = orig_name
    wb2.save(outfile)

# Verify with data_only
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[orig_sheetnames[0]]

print("Verified target H1:L10:")
for r in range(1, 11):
    vals = [vws.cell(r, c).value for c in range(8, 13)]
    print(r, vals)

output_spreadsheet = outfile
