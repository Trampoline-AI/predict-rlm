import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INSTRUCTION:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = [ws.cell(1, c).value for c in range(1, ws.max_column+1)]
    headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)] if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    # detect likely used rows
    nonempty_rows = []
    for r in range(1, ws.max_row+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:5], nonempty_rows[-5:] if nonempty_rows else []))
    sample_rows = list(range(1, min(ws.max_row, 10)+1))
    if ws.max_row > 10:
        sample_rows += list(range(max(1, ws.max_row-4), ws.max_row+1))
    seen=set()
    for r in sample_rows:
        if r in seen: 
            continue
        seen.add(r)
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", vals)
    # print formulas or special cells in used area
    formulas = []
    for r in range(1, min(ws.max_row, 30)+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first 30 rows:", formulas[:20], "count:", len(formulas))
