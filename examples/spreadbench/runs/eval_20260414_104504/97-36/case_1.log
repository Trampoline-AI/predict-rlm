        if isinstance(v, str) and target_sub in v.lower():
            found = (r, c, v)
            break
    if found:
        break

print("Found target:", found)

if found is None:
    raise ValueError("Substring 'domestic' not found")

target_row = found[0]
if target_row > 1:
    print(f"Deleting rows 1 to {target_row-1}")
    ws.delete_rows(1, target_row - 1)
else:
