def sheet_nonempty_bounds(ws):
    max_r, max_c = ws.max_row, ws.max_column
    last_r = 0
    last_c = 0
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value not in (None, ""):
                row_has = True
                if cell.column > last_c:
                    last_c = cell.column
        if row_has:
            last_r = cell.row
    return last_r or max_r, last_c or max_c

