import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find non-empty rows/cols roughly
    headers = []
    if ws.max_row >= 1:
        for c in range(1, ws.max_column + 1):
            headers.append(ws.cell(1, c).value)
    print("Row1 headers/values:", headers)
    # sample first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Focus on SH1 and DATA
for name in ["SH1", "DATA"]:
    if name in wb.sheetnames:
        ws = wb[name]
        print(f"\n### Detailed scan for {name} ###")
        # print coordinates and values for non-empty cells in used range if not too big
        nonempty = []
        for r in range(1, ws.max_row + 1):
            row = []
            for c in range(1, ws.max_column + 1):
                v = ws.cell(r, c).value
                if v is not None:
                    row.append(f"{get_column_letter(c)}{r}={v}")
            if row:
                nonempty.append((r, row))
        for r, row in nonempty[:30]:
            print(r, row[:20])
        if len(nonempty) > 30:
            print("... total nonempty rows:", len(nonempty))
        
        # inspect formulas in DATA D/E if exists
        if name == "DATA":
            for c in [4,5]:
                col = get_column_letter(c)
                print(f"Column {col} sample values:")
                for r in range(1, min(ws.max_row, 20)+1):
                    v = ws.cell(r, c).value
                    print(f"{col}{r}={v}")
