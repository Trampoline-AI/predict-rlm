import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
sh1 = wb["SH1"]
data = wb["DATA"]
fake = wb["FAKE"]

# Extract invoice numbers from SH1 by scanning for "INVOICE NO" labels and the value below
invoice_positions = []
for r in range(1, sh1.max_row + 1):
    for c in range(1, sh1.max_column + 1):
        v = sh1.cell(r, c).value
        if v == "INVOICE NO":
            below = sh1.cell(r + 1, c).value if r + 1 <= sh1.max_row else None
            invoice_positions.append((r, c, below))
print("SH1 invoice markers and invoice numbers:")
for item in invoice_positions:
    print(item, "cell", f"{get_column_letter(item[1])}{item[0]} -> {get_column_letter(item[1])}{item[0]+1}")

# Print all rows in DATA and FAKE focusing on cols A:E and totals to compare pattern
def print_group_summary(ws, name):
    print(f"\n{name} grouped rows:")
    for r in range(2, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, 6)] + [ws.cell(r, 11).value]
        print(r, vals)

print_group_summary(data, "DATA")
print_group_summary(fake, "FAKE")

# Determine expected invoice assignment from FAKE for CUSTOMER=SH1 groups
expected = []
for r in range(2, fake.max_row + 1):
    if fake.cell(r, 5).value == "SH1":
        expected.append((r, fake.cell(r, 4).value, fake.cell(r, 1).value))
print("\nExpected from FAKE for SH1 rows (row, invoice, itemcol):")
print(expected)

# Also inspect current DATA col D formulas/values exactly
print("\nCurrent DATA D2:D17 values/types:")
for r in range(2, data.max_row + 1):
    v = data.cell(r, 4).value
    print(r, repr(v), type(v).__name__)

# Apply update: for rows where column E == 'SH1', replace D with FAKE's D (verified pattern)
for r in range(2, data.max_row + 1):
    if data.cell(r, 5).value == "SH1":
        data.cell(r, 4).value = fake.cell(r, 4).value

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
orig_names = ['SH1', 'DATA', 'FAKE']
if wb2.sheetnames != orig_names:
    for i, nm in enumerate(orig_names):
        wb2.worksheets[i].title = nm
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

check = load_workbook(out_path, data_only=True)
print("\nVerified DATA D/E rows after save:")
for r in range(2, check["DATA"].max_row + 1):
    print(r, check["DATA"].cell(r,4).value, check["DATA"].cell(r,5).value, check["DATA"].cell(r,1).value)

final_output_path = out_path
