    for c in range(7, ws_d.max_column + 1):
        dt = ws_d.cell(6, c).value
        if dt is None:
            continue
        qty = ws_d.cell(r, c).value
        ws_t.cell(out_row, 1).value = item
        ws_t.cell(out_row, 2).value = dt
        ws_t.cell(out_row, 3).value = qty if qty is not None else 0
