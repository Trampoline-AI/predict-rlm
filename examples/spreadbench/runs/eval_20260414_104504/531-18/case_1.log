for rr, item in items[:2]:
    sample = [(item, ws_d.cell(6, c).value, ws_d.cell(rr, c).value) for c, _ in dates[:8]]
    print("Sample source for item:", item, sample)

# Prepare output file
outfile = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
shutil.copy(input_spreadsheet, outfile)

wb = load_workbook(outfile)
ws_d = wb["Data"]
ws_t = wb["Transpose"]

# Verify target cells / headers before writing
print("Before write, Transpose A1:C6:")
for r in range(1, 7):
