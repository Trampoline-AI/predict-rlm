```repl
import os, shutil
from collections import OrderedDict
from copy import copy
from datetime import datetime
from openpyxl import load_workbook

src_path = input_spreadsheet
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(src_path))

wb = load_workbook(src_path)
ws_r = wb["RANGES"]
ws_l = wb["LISTS"]

# Inspect destination section boundaries and some style refs
print("LISTS rows 23-35 before:")
for r in range(23, min(35, ws_l.max_row)+1):
    print(r, [ws_l.cell(r,c).value for c in range(1,5)])

# Parse source sections from RANGES using title rows in col C
sections = OrderedDict()
title_rows = []
for r in range(1, ws_r.max_row + 1):
    v = ws_r.cell(r, 3).value
    if isinstance(v, str) and v.strip() in {"STAGE", "DATA", "OPERATION"}:
        title_rows.append((v.strip(), r))
print("Source title rows:", title_rows)

for i, (title, title_row) in enumerate(title_rows):
    header_row = title_row + 1
    next_title_row = title_rows[i+1][1] if i+1 < len(title_rows) else ws_r.max_row + 1
    data_rows = []
    r = header_row + 1
    while r < next_title_row:
        vals = [ws_r.cell(r,c).value for c in range(1,6)]
        # stop/skip blanks
        if all(v is None for v in vals[:5]):
            r += 1
            continue
        sn, datev, batch, ref, amt = vals
        if datev is None and ref is None and amt is None:
            r += 1
            continue
        data_rows.append((r, datev, ref, amt))
        r += 1
    sections[title] = {"title_row": title_row, "header_row": header_row, "rows": data_rows}

for title, info in sections.items():
    print("\nSECTION", title, "source rows:", len(info["rows"]))
    print("sample:", info["rows"][:5], "last:", info["rows"][-3:])

def norm_date(v):
    if isinstance(v, datetime):
        return v
    if isinstance(v, str):
        s = v.strip()
        for fmt in ("%m/%d/%Y", "%m/%d/%y", "%Y-%m-%d", "%d/%m/%Y"):
            try:
                return datetime.strptime(s, fmt)
            except:
                pass
    return v

def aggregate_rows(rows):
    agg = OrderedDict()
    for _, datev, ref, amt in rows:
        key = (norm_date(datev), ref)
        if key not in agg:
            agg[key] = 0
        agg[key] += amt if amt is not None else 0
    result = []
    for (datev, ref), amt in agg.items():
        result.append((datev, ref, amt))
    return result

aggregated = {title: aggregate_rows(info["rows"]) for title, info in sections.items()}
for title, rows in aggregated.items():
    print(title, "aggregated count", len(rows), "rows:", rows)

# Destination title rows in LISTS
dest_titles = {}
for r in range(1, ws_l.max_row + 1):
    v = ws_l.cell(r, 3).value
    if isinstance(v, str) and v.strip() in {"STAGE", "DATA", "OPERATION"}:
        dest_titles[v.strip()] = r
print("Destination title rows:", dest_titles)

def copy_row_style(src_row, dst_row, cols=4):
    for c in range(1, cols+1):
        s = ws_l.cell(src_row, c)
        d = ws_l.cell(dst_row, c)
        if s.has_style:
            d._style = copy(s._style)
        if s.number_format:
            d.number_format = s.number_format
        if s.font:
            d.font = copy(s.font)
        if s.fill:
            d.fill = copy(s.fill)
        if s.border:
            d.border = copy(s.border)
        if s.alignment:
            d.alignment = copy(s.alignment)
        if s.protection:
            d.protection = copy(s.protection)

def populate_section(title):
    title_row = dest_titles[title]
    header_row = title_row + 1
    next_title_row = min([r for t, r in dest_titles.items() if r > title_row], default=ws_l.max_row + 1)
    existing_total_row = None
    for r in range(header_row + 1, next_title_row):
        if ws_l.cell(r,1).value == "TOTAL":
            existing_total_row = r
            break
    if existing_total_row is None:
        existing_total_row = next_title_row - 1

    template_data_row = header_row + 1
    template_total_row = existing_total_row

    rows = aggregated[title]
    needed_total_row = header_row + len(rows) + 1

    # insert rows if needed before next section
    if needed_total_row >= next_title_row:
        insert_n = needed_total_row - next_title_row + 1
        ws_l.insert_rows(next_title_row, amount=insert_n)
        # refresh destination title rows after insertion
        for t, rr in list(dest_titles.items()):
            if rr >= next_title_row:
                dest_titles[t] = rr + insert_n
        existing_total_row += 0  # old total row stays before inserted block if inserted at next_title_row

    # clear body area from first data row until just before next title/current allocated section
    next_title_row = min([r for t, r in dest_titles.items() if r > title_row], default=ws_l.max_row + 1)
    for r in range(header_row + 1, next_title_row):
        for c in range(1,5):
            ws_l.cell(r,c).value = None

    # write aggregated rows
    for idx, (datev, ref, amt) in enumerate(rows, start=1):
        r = header_row + idx
        copy_row_style(template_data_row, r, cols=4)
        ws_l.cell(r,1).value = idx
        ws_l.cell(r,2).value = datev
        ws_l.cell(r,3).value = ref
        ws_l.cell(r,4).value = amt

    # write total row
    total_row = header_row + len(rows) + 1
    copy_row_style(template_total_row, total_row, cols=4)
    ws_l.cell(total_row,1).value = "TOTAL"
    ws_l.cell(total_row,2).value = None
    ws_l.cell(total_row,3).value = None
    ws_l.cell(total_row,4).value = f"=SUM(D{header_row+1}:D{total_row-1})"
    return {"title": title, "header_row": header_row, "total_row": total_row, "data_end": total_row-1}

# Leave STAGE as-is; fill DATA and OPERATION according to instruction/reference
results = {}
for title in ["DATA", "OPERATION"]:
    results[title] = populate_section(title)

print("\nAfter writing, preview LISTS rows 13-35:")
for r in range(13, min(35, ws_l.max_row)+1):
    print(r, [ws_l.cell(r,c).value for c in range(1,5)])

wb.save(out_path)
print("Saved to", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
orig_names = ['RANGES', 'LISTS']
if wb_after.sheetnames != orig_names:
    print("Sheet names changed:", wb_after.sheetnames)
    for i, nm in enumerate(orig_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = nm
    wb_after.save(out_path)
    wb_after = load_workbook(out_path)

print("Final sheet names:", wb_after.sheetnames)

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["LISTS"]
print("\nVerification targets:")
for title in ["DATA", "OPERATION"]:
    title_row = dest_titles[title]
    next_title = min([r for t, r in dest_titles.items() if r > title_row], default=wsv.max_row+1)
    print(f"\n{title} block rows {title_row}:{next_title-1}")
    for r in range(title_row, next_title):
        print(r, [wsv.cell(r,c).value for c in range(1,5)])
```
