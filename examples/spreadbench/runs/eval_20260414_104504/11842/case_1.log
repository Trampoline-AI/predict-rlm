import os, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r,c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    first_n = min(8, ws.max_row)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))
    print("Last rows:")
    start = max(1, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))

# Inspect Total sheet and relevant cells
if "Total" in wb.sheetnames:
    ws = wb["Total"]
    print("\n=== Detailed Total sheet inspection ===")
    for cell in ["O3","O1","O2","N3","P3","Q3","R3","S3","T3","U3","V3","W3","X3","Y3","Z3"]:
        print(cell, ws[cell].value)
    # print columns A:Z for first 15 rows with coordinate:value pairs
    for r in range(1, min(15, ws.max_row)+1):
        vals = []
        for c in range(1, min(26, ws.max_column)+1):
            v = ws.cell(r,c).value
            if v is not None:
                vals.append(f"{get_column_letter(c)}{r}={v}")
        print("Row", r, vals)
    # print formulas in used range A:Z rows 1:20
    print("Formulas in Total A1:Z20")
    for r in range(1, min(20, ws.max_row)+1):
        for c in range(1, min(26, ws.max_column)+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                print(f"{get_column_letter(c)}{r}: {v}")
