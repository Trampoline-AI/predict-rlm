Code:
```repl
import os, math, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

matches = []
for r in range(1, ws.max_row + 1):
    fval = ws.cell(r, 6).value  # F
    jval = ws.cell(r, 10).value # J
    is_whole = False
    if isinstance(jval, int):
        is_whole = True
    elif isinstance(jval, float):
        is_whole = jval.is_integer()
    if fval == "Marble Slab Creamery" and is_whole:
        matches.append((r, fval, jval))

print("Matching rows before update:", matches)

for r, _, _ in matches:
    ws.cell(r, 6).value = "Georgia State WH"

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalculation and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # rename by position if counts match
    if len(wb_check.sheetnames) == len(original_sheetnames):
        for i, s in enumerate(wb_check.worksheets):
            s.title = original_sheetnames[i]
        wb_check.save(outfile)
        print("Restored sheet names to:", original_sheetnames)

# Verify with data_only read
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("Verification of Column F/J rows 1-15:")
for r in range(1, wsv.max_row + 1):
    print(r, wsv.cell(r, 6).value, wsv.cell(r, 10).value)

print("Specific checks:")
for coord in ["F10","J10","F13","J13"]:
    print(coord, "=", wsv[coord].value)

updated_rows = [r for r, _, _ in matches if wsv.cell(r, 6).value == "Georgia State WH"]
print("Updated rows confirmed:", updated_rows)

final_output_spreadsheet = outfile
```
