import os, json, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers/values:", headers)
    # print first 10 rows, cols A:J or all if fewer
    max_c = min(ws.max_column, 10)
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_c + 1)]
        print(r, vals)
    print("Last 5 rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_c + 1)]
        print(r, vals)
    # specific cells mentioned
    for coord in ["F10", "J10", "F13", "J13"]:
        print(coord, "=", ws[coord].value)

for ws in wb.worksheets:
    sheet_summary(ws)
