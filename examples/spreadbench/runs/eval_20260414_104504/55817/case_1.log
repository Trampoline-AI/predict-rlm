import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Inspect exact target/example area and source blocks
print("Target area B2:H10 before changes:")
for r in range(2, 11):
    print(r, [ws.cell(r, c).value for c in range(2, 9)])

print("\nSource column A blocks:")
for start in range(2, ws.max_row + 1, 7):
    block = [ws.cell(start + i, 1).value for i in range(7) if start + i <= ws.max_row]
    print(start, block)

# Determine number of complete non-empty 7-item blocks in column A
blocks = []
r = 2
while r <= ws.max_row:
    block = [ws.cell(r+i, 1).value for i in range(7) if r+i <= ws.max_row]
    if len(block) == 7 and any(v is not None for v in block):
        blocks.append((r, block))
    r += 7
print("\nDetected blocks:", len(blocks))

# Fill rows starting at B2 with each block across B:H, preserving existing non-empty cells
for idx, (start_row_a, block) in enumerate(blocks, start=2):
    for offset, val in enumerate(block, start=2):  # columns B:H
        cell = ws.cell(idx, offset)
        if cell.value is None:
            cell.value = val

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalc:", result)

# Reload and restore sheet names if needed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# Verify output values
wbv = load_workbook(out_path, data_only=False)
wsv = wbv[orig_names[0]]
print("\nVerified B2:H6 formulas/values:")
for r in range(2, 7):
    print(r, [wsv.cell(r, c).value for c in range(2, 9)])

wbv2 = load_workbook(out_path, data_only=True)
wsv2 = wbv2[orig_names[0]]
print("\nVerified data_only B2:H6:")
for r in range(2, 7):
    print(r, [wsv2.cell(r, c).value for c in range(2, 9)])

output_spreadsheet = out_path
