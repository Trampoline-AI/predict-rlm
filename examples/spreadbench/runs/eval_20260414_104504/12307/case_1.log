from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # find actual non-empty bounds roughly
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                nonempty_cols.add(c)
        if row_has:
            nonempty_rows.append(r)
    print("Non-empty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("Non-empty cols:", [get_column_letter(c) for c in sorted(nonempty_cols)])
    
    # print first 20 rows x first 12 cols (or max)
    maxp = min(ws.max_column, 12)
    print("\nTop rows:")
    for r in range(1, min(ws.max_row, 20) + 1):
        vals = [ws.cell(r, c).value for c in range(1, maxp + 1)]
        print(r, vals)
    
    # print last 5 non-empty-ish rows
    print("\nBottom rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, maxp + 1)]
        print(r, vals)

# specifically inspect around target cells / tables
