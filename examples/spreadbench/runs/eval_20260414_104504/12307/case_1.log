from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify current target cells and nearby ranges before writing
print("Before writing:")
print("A2:A3 countries:", [ws[f"A{r}"].value for r in range(2, 4)])
print("Headers B11:H11:", [ws.cell(11, c).value for c in range(2, 9)])
print("I12 existing:", ws["I12"].value)
print("I13 existing:", ws["I13"].value)

# Apply formulas to exact target cells
ws["I12"] = '=SUMPRODUCT((B12:H12>0)*COUNTIF($A$2:$A$3,B$11:H$11))'
ws["I13"] = '=SUMPRODUCT((B13:H13>0)*COUNTIF($A$2:$A$3,B$11:H$11))'

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename in order
    for i, target_name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = target_name
    wb2.save(outfile)

# Verify after recalc with cached values
wbv = load_workbook(outfile, data_only=False)
wsv = wbv[orig_sheetnames[0]]
print("Formulas written:")
print("I12 formula:", wsv["I12"].value)
print("I13 formula:", wsv["I13"].value)

wbv2 = load_workbook(outfile, data_only=True)
wsv2 = wbv2[orig_sheetnames[0]]
print("Verified cached values:")
print("I12 value:", wsv2["I12"].value)
print("I13 value:", wsv2["I13"].value)

output_spreadsheet = outfile
```
