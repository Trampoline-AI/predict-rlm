Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Print current target cells and any existing formulas/values before modification
print("Before modification:")
for r in range(3, ws.max_row + 1):
    print(r, "B=", ws[f"B{r}"].value, "C=", ws[f"C{r}"].value)

# Write formula to column C for all rows with description in B from row 3 onward.
# Priority: extract 10-char token beginning with 955; if absent, extract 10-char token beginning with CHK; else blank.
for r in range(3, ws.max_row + 1):
    bval = ws[f"B{r}"].value
    if bval is None or str(bval).strip() == "":
        continue
    formula = f'=IFERROR(MID(B{r},SEARCH("955",B{r}),10),IFERROR(MID(B{r},SEARCH("CHK",B{r}),10),""))'
    ws[f"C{r}"] = formula

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_data = load_workbook(outfile, data_only=True)
ws_data = wb_data[orig_sheetnames[0]]

print("\nVerification:")
for r in range(3, ws_formula.max_row + 1):
    print(
        f"Row {r}: B={ws_formula[f'B{r}'].value!r} | "
        f"C_formula={ws_formula[f'C{r}'].value!r} | "
        f"C_value={ws_data[f'C{r}'].value!r}"
    )

output_spreadsheet = outfile
```
