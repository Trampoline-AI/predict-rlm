import os, json, textwrap, re
from openpyxl import load_workbook

print("Instruction:\n", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Row1 headers/values:", headers)
    # first 10 rows
    first_rows = []
    for r in range(1, min(max_row, 10)+1):
        first_rows.append([ws.cell(r,c).value for c in range(1, max_col+1)])
    print("First rows sample:")
    for row in first_rows:
        print(row)
    # last 5 rows
    print("Last 5 rows sample:")
    for r in range(max(1, max_row-4), max_row+1):
        print([ws.cell(r,c).value for c in range(1, max_col+1)])

for ws in wb.worksheets:
    sheet_summary(ws)

# Search all cells for macro-like text and "Del_Blanks"
hits = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and ("Del_Blanks" in v or "Sub " in v or "SpecialCells" in v or "blank" in v.lower()):
                hits.append((ws.title, cell.coordinate, v))
print("\nPotential macro/instruction cells found:", len(hits))
for hit in hits[:20]:
    print(hit[0], hit[1], repr(hit[2][:300]))
```
