import os
from openpyxl import load_workbook

# Reload fresh workbook and inspect exact Column A values with row numbers
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title, "max_row:", ws.max_row, "max_col:", ws.max_column)
print("Column A values by row:")
colA = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    colA.append(v)
    print(r, repr(v))

nonblank_rows = [r for r, v in enumerate(colA, start=1) if v not in (None, "")]
print("Nonblank rows in A:", nonblank_rows)
first_nonblank = nonblank_rows[0]
last_nonblank = nonblank_rows[-1]
blank_rows_between = [r for r in range(first_nonblank, last_nonblank + 1) if ws.cell(r, 1).value in (None, "")]
print("First nonblank row:", first_nonblank)
print("Last nonblank row:", last_nonblank)
print("Blank rows to delete:", blank_rows_between)

# Perform deletion from bottom to top
for r in reversed(blank_rows_between):
    ws.delete_rows(r, 1)

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Ensure sheet names preserved after recalc
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_names = wb.sheetnames
if wb_after.sheetnames != orig_names:
    # rename in order back to originals if count matches
    if len(wb_after.sheetnames) == len(orig_names):
        for s, orig in zip(wb_after.worksheets, orig_names):
            s.title = orig
        wb_after.save(out_path)
        print("Renamed sheets back to original names:", orig_names)

# Verify output
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_names[0]]
print("Verified sheet:", wsv.title, "max_row:", wsv.max_row, "max_col:", wsv.max_column)
print("Column A after deletion:")
for r in range(1, wsv.max_row + 1):
    print(r, repr(wsv.cell(r, 1).value))

verify_nonblank_rows = [r for r in range(1, wsv.max_row + 1) if wsv.cell(r, 1).value not in (None, "")]
vf = verify_nonblank_rows[0]
vl = verify_nonblank_rows[-1]
remaining_blanks_between = [r for r in range(vf, vl + 1) if wsv.cell(r, 1).value in (None, "")]
print("Post-delete first nonblank:", vf)
print("Post-delete last nonblank:", vl)
print("Remaining blanks between first and last nonblank in A:", remaining_blanks_between)

output_spreadsheet = out_path
