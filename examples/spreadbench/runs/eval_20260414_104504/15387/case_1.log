import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Sheet1"]

# Inspect exact target / nearby cells again, including any existing formulas
for coord in ["A12","B12","A13","A14","B1","C1","D1","E1","F1","B3","C3","D3","E3","F3"]:
    print(coord, "=>", ws[coord].value)

# Implement a formula-based solution using helper formulas in blank area H13:H17,
# and output formulas in A13:A17. This avoids dynamic arrays and gives nth match results.
# Criterion remains in B12 (already 0).
customers = ["B","C","D","E","F"]
for idx, col in enumerate(customers, start=13):
    # H13:H17 store qualifying customer names or blanks
    ws[f"H{idx}"] = f'=IF({col}$1=$B$12,{col}$3,"")'
    print(f"H{idx} formula:", ws[f"H{idx}"].value)

# A13:A17 return successive nonblank values from H13:H17
for r in range(13, 18):
    if r == 13:
        formula = '=IFERROR(INDEX($H$13:$H$17,MATCH(FALSE,INDEX($H$13:$H$17="",0),0)),"")'
    else:
        prev = r - 1
        formula = f'=IFERROR(INDEX($H$13:$H$17,MATCH(FALSE,INDEX(($H$13:$H$17="")+($H$13:$H$17=A${prev}),0),0)),"")'
    ws[f"A{r}"] = formula
    print(f"A{r} formula:", formula)

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and check if sheet names changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"]:
    # restore original sheet name
    wb2[wb2.sheetnames[0]].title = "Sheet1"
    wb2.save(outfile)
    print("Restored sheet names:", load_workbook(outfile).sheetnames)

# Verify with formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
wb_data = load_workbook(outfile, data_only=True)
wsd = wb_data["Sheet1"]

print("Final formulas A13:A17:")
for r in range(13, 18):
    print(r, wsf[f"A{r}"].value)

print("Cached values A13:A17:")
for r in range(13, 18):
    print(r, wsd[f"A{r}"].value)

print("Cached helper values H13:H17:")
for r in range(13, 18):
    print(r, wsd[f"H{r}"].value)
