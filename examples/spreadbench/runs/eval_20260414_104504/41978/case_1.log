import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and inspect exact target cells before modifying
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Cumulative"]

print("Pre-write I2:I11:")
for r in range(2, 12):
    print(r, "G", ws[f"G{r}"].value, "I", ws[f"I{r}"].value, "style", ws[f"I{r}"].style_id)

# Write formulas into existing formatted cells in column I
for r in range(2, 12):
    year_cell = f"G{r}"
    target = f"I{r}"
    ws[target] = f'=COUNTIFS($G$14:$G$185,{year_cell},$J$14:$J$185,"Open")'

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename by position back to originals
    for idx, orig_name in enumerate(orig_sheetnames):
        wb_check.worksheets[idx].title = orig_name
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and calculated values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Cumulative"]
wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Cumulative"]

print("\nVerification I2:I11 formulas and values:")
for r in range(2, 12):
    print(
        f"I{r}",
        "year=", ws_vals[f"G{r}"].value,
        "formula=", ws_formula[f"I{r}"].value,
        "value=", ws_vals[f"I{r}"].value,
    )

# Also compare against Python-computed counts for sanity
py_counts = {}
for r in range(2, 12):
    year = ws_vals[f"G{r}"].value
    count = 0
    for rr in range(14, 186):
        if ws_vals[f"G{rr}"].value == year and str(ws_vals[f"J{rr}"].value).strip().lower() == "open":
            count += 1
    py_counts[year] = count
print("Python counts:", py_counts)

final_output_path = outfile
