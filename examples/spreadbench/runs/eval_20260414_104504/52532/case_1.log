Code:
```repl
import os, shutil
from openpyxl import load_workbook

# Re-open original workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Verify intended counts from current data before writing
players = []
for r in range(2, ws.max_row + 1):
    name = ws.cell(r, 1).value
    if name is not None and str(name).strip() != "":
        players.append((r, name))

game_cols = list(range(2, 8))  # B:G based on inspection
print("Players:", players)
print("Game columns:", game_cols, [ws.cell(1, c).value for c in game_cols])

# Print per-game maxima and winners to confirm logic
for c in game_cols:
    vals = [(r, ws.cell(r, 1).value, ws.cell(r, c).value) for r, _ in players]
    nums = [v for _, _, v in vals if isinstance(v, (int, float))]
    mx = max(nums)
    winners = [(name, val) for _, name, val in vals if val == mx]
    print(f"{ws.cell(1,c).value}: max={mx}, winners={winners}")

# Write formulas into H for all player rows
for r, name in players:
    formula = (
        f'=IF(B{r}=MAX(B$2:B${ws.max_row}),1,0)'
        f'+IF(C{r}=MAX(C$2:C${ws.max_row}),1,0)'
        f'+IF(D{r}=MAX(D$2:D${ws.max_row}),1,0)'
        f'+IF(E{r}=MAX(E$2:E${ws.max_row}),1,0)'
        f'+IF(F{r}=MAX(F$2:F${ws.max_row}),1,0)'
        f'+IF(G{r}=MAX(G$2:G${ws.max_row}),1,0)'
    )
    print(f"Writing H{r} for {name}: {formula}")
    ws.cell(r, 8).value = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore original sheet names if needed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(out_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["Sheet1"]
print("Verified H values:")
for r, name in players:
    print(f"A{r}={wsv.cell(r,1).value!r}, H{r}={wsv.cell(r,8).value!r}")

output_spreadsheet = out_path
