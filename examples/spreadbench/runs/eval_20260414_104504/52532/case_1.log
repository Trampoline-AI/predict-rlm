orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_preview(ws, first_n=10, last_n=5):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print("Row1 headers/values:", headers)
    if max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, max_col+1)]
        print("Row2 values:", headers2)
    # print first rows
    first_end = min(max_row, first_n)
    print(f"First {first_end} rows:")
    for r in range(1, first_end+1):
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(r, vals)
    # print last rows
    start_last = max(1, max_row-last_n+1)
    if start_last <= max_row:
        print(f"Last rows {start_last}-{max_row}:")
        for r in range(start_last, max_row+1):
            vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
            print(r, vals)

for ws in wb.worksheets:
    sheet_preview(ws)

# specifically inspect column H and nearby columns
for ws in wb.worksheets:
    print(f"\nSpecific inspection for {ws.title}: columns A:H")
