import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
print("Original sheet names:", wb.sheetnames)

# Reconfirm target cells/values/formulas in result sheet
ws_prob = wb["problem"]
ws_res = wb["result"]

print("Result sheet current rows before modification:")
for r in range(1, ws_res.max_row + 1):
    print(r, ws_res.cell(r,1).value, ws_res.cell(r,2).value)

# Build transformed rows from problem A:B
out_rows = []
for r in range(1, ws_prob.max_row + 1):
    key = ws_prob.cell(r, 1).value
    raw = ws_prob.cell(r, 2).value
    print(f"Problem row {r}: key={key!r}, raw={raw!r}")
    if key is None or key == "":
        continue
    if raw is None or raw == "":
        out_rows.append((key, None))
    else:
        parts = [p.strip() for p in str(raw).replace("\r\n", "\n").replace("\r", "\n").split("\n")]
        parts = [p for p in parts if p != ""]
        if parts:
            for p in parts:
                out_rows.append((key, p))
        else:
            out_rows.append((key, None))

print("Transformed rows count:", len(out_rows))
print("Preview transformed first 10:", out_rows[:10])
print("Preview transformed last 10:", out_rows[-10:])

# Clear existing result sheet contents in used area and rewrite A:B in place
# Keep sheet structure; only blank cells in current used range + any extra old rows in A:B
for r in range(1, max(ws_res.max_row, len(out_rows)) + 1):
    for c in range(1, 3):
        ws_res.cell(r, c).value = None

for i, (a, b) in enumerate(out_rows, start=1):
    ws_res.cell(i, 1).value = a
    ws_res.cell(i, 2).value = b

wb.save(outfile)
print("Saved to", outfile)

# Recalculate and repair sheet names if needed
orig_names = wb.sheetnames[:]
recalc_status = await recalculate(outfile)
print("Recalc:", recalc_status)

wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    for idx, name in enumerate(orig_names):
        wb2.worksheets[idx].title = name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_names)

# Verify output values
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
vr = wbv["result"]
print("Verified result max_row/max_col:", vr.max_row, vr.max_column)
for r in range(1, vr.max_row + 1):
    print(r, vr.cell(r,1).value, vr.cell(r,2).value)
    
output_spreadsheet = outfile
