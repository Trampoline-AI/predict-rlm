import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    max_r, max_c = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_c+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", max_r, "max_col:", max_c)
    print("Row1 headers/values:", headers)
    
    # detect actual non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, max_r+1):
        vals = [ws.cell(r, c).value for c in range(1, max_c+1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None, "count:", len(nonempty_rows))
    
    # sample first 10 rows
    print("First rows:")
    for r in range(1, min(max_r, 10)+1):
        vals = [ws.cell(r, c).value for c in range(1, max_c+1)]
        print(r, vals)
    print("Last 5 rows:")
    for r in range(max(1, max_r-4), max_r+1):
        vals = [ws.cell(r, c).value for c in range(1, max_c+1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Extra focused inspection for likely relevant sheets
for s in wb.sheetnames:
    if s.lower() in ("problem", "result"):
        ws = wb[s]
        print(f"\nFocused inspection of {s}:")
        for r in range(1, min(ws.max_row, 20)+1):
            vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 10)+1)]
            print(r, vals)
