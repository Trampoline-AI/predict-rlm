def parse_num(v):
    if v is None:
        return None
    if isinstance(v, (int, float)):
        return float(v)
    if isinstance(v, str):
        t = v.strip()
        if t == "":
            return None
        try:
            return float(t.replace(",", ""))
        except:
            return None
    return None

