from collections import defaultdict
from openpyxl.utils import get_column_letter

ws = wb["Sheet1"]

# Inspect target area G:I in more detail
print("Detailed target area G:I rows 1:15")
for r in range(1, 16):
    vals = [ws.cell(r, c).value for c in range(7, 10)]
    print(r, vals)

# Find all distinct materials and compute total area from source data A:C
totals = defaultdict(float)
materials_in_order = []
seen = set()
for r in range(2, ws.max_row + 1):
    m = ws.cell(r, 1).value
    w = ws.cell(r, 2).value
    h = ws.cell(r, 3).value
    if m is None:
        continue
    if m not in seen:
        seen.add(m)
        materials_in_order.append(m)
    try:
        area = float(w) * float(h)
    except Exception:
        area = 0
    totals[m] += area

print("\nDistinct materials in source order:", materials_in_order)
print("Computed totals:")
for m in materials_in_order:
    print(m, totals[m])

# Print current values/formulas in expected target cells around examples
for cell in ["G2","H2","I2","G3","H3","I3","G4","H4","I4","G5","H5","I5"]:
    print(cell, ws[cell].value)
