import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb2 = load_workbook(infile)
ws = wb2["Sheet1"]

last_row = ws.max_row
print("Using data rows 2 to", last_row)

# Write dynamic formulas in H2:H5 based on material names in G2:G5
for r in range(2, 6):
    material_cell = f"G{r}"
    target_cell = f"H{r}"
    old_val = ws[target_cell].value
    formula = f'=SUMPRODUCT(($A$2:$A${last_row}={material_cell})*($B$2:$B${last_row})*($C$2:$C${last_row}))'
    print(target_cell, "old:", old_val, "new formula:", formula)
    ws[target_cell] = formula

wb2.save(outfile)
print("Saved to", outfile)

# recalculate
result = await recalculate(outfile)
print("Recalculate:", result)

# reload and ensure sheet names unchanged
orig_names = wb.sheetnames
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    # rename back by position
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_names)

# verify with data_only
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]
for cell in ["G2","H2","I2","G3","H3","I3","G4","H4","I4","G5","H5","I5"]:
    print(cell, repr(wsv[cell].value))

output_spreadsheet = outfile
