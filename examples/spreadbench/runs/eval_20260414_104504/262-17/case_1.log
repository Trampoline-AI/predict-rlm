wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # collect first 10 rows x all used cols for inspection
    rows = list(ws.iter_rows(min_row=1, max_row=min(ws.max_row, 10), values_only=True))
    for i, row in enumerate(rows, start=1):
        print(f"Row {i}:", row)
    if ws.max_row > 10:
        start_last = max(1, ws.max_row - 4)
        for r in range(start_last, ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}:", vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Try to identify header row and columns containing Task / Responsibility in each sheet
for ws in wb.worksheets:
    print(f"\nHeader search in {ws.title}:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        normalized = [str(v).strip().lower() if v is not None else "" for v in vals]
        if "task" in normalized or "tasks" in normalized or "responsibility" in normalized or "responsibilities" in normalized:
            print("Possible header row", r, vals)

# Print formulas if any in first 15 rows
for ws in wb.worksheets:
    formulas = []
    for r in range(1, min(ws.max_row, 15) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((ws.cell(r, c).coordinate, v))
    print(f"\nFormulas in first 15 rows of {ws.title}:", formulas[:20], "count:", len(formulas))
