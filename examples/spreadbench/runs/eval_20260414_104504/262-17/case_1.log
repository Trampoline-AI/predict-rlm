wb = load_workbook(input_spreadsheet)
ws1 = wb[wb.sheetnames[0]]
ws2 = wb[wb.sheetnames[1]]

def nonempty_rows(ws):
    out = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            out.append((r, vals))
    return out

print("All non-empty rows in Sheet2:")
for r, vals in nonempty_rows(ws2):
    print(r, vals)

headers = [ws1.cell(1, c).value for c in range(1, ws1.max_column + 1)]
print("Headers:", headers)
task_col = headers.index("Task") + 1
resp_col = headers.index("Responsibility") + 1
print("Task col:", task_col, "Responsibility col:", resp_col)

data_rows = []
for r in range(2, ws1.max_row + 1):
    vals = [ws1.cell(r, c).value for c in range(1, ws1.max_column + 1)]
    if any(v is not None for v in vals):
        data_rows.append(vals)

sorted_rows = sorted(data_rows, key=lambda row: (str(row[task_col-1]), str(row[resp_col-1])))
print("\nPython-sorted rows:")
for row in sorted_rows:
    print(row)

sheet2_expected = []
for r in range(2, ws2.max_row + 1):
    vals = [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)]
    if any(v is not None for v in vals[:6]):
        if r < 20:  # exclude the notes row
            sheet2_expected.append(vals)

print("\nExpected rows count:", len(sheet2_expected), "Sorted rows count:", len(sorted_rows))
print("Exact match to Sheet2 expected?", sorted_rows == sheet2_expected)

# Perform write to Sheet1 if match is confirmed
for idx, row_vals in enumerate(sorted_rows, start=2):
    for c, v in enumerate(row_vals, start=1):
        ws1.cell(idx, c).value = v

# Clear any extra old rows below sorted data in Sheet1 used range if necessary
for r in range(2 + len(sorted_rows), ws1.max_row + 1):
    for c in range(1, ws1.max_column + 1):
        ws1.cell(r, c).value = None

out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb.save(out_path)
print("Saved to", out_path)

recalc_result = await recalculate(str(out_path))
print("Recalc:", recalc_result)

# restore sheet names if altered
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != wb.sheetnames:
    for i, name in enumerate(wb.sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Restored original sheet names:", wb.sheetnames)

# Verify output values
wb_verify = load_workbook(out_path, data_only=True)
vws1 = wb_verify[wb.sheetnames[0]]
print("\nVerified target rows in Sheet1:")
verified_rows = []
for r in range(1, vws1.max_row + 1):
