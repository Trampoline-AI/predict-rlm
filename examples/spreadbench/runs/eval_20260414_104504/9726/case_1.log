from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Inspect target/table areas:")
for r in range(1, 8):
    print(r, [ws.cell(r,c).value for c in range(1, 11)])

j2 = ws["J2"].value
print("J2 raw type:", type(j2))
if isinstance(j2, ArrayFormula):
    print("J2 array formula text:", j2.text)
else:
    print("J2 raw value:", j2)

# find actual data extents for Table 1 and Table 2
table1_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None or ws.cell(r, 3).value is not None:
        if ws.cell(r, 1).value is not None and ws.cell(r, 3).value is not None:
            table1_rows.append(r)
table2_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 8).value is not None or ws.cell(r, 9).value is not None or ws.cell(r, 10).value is not None:
        table2_rows.append(r)

print("Table1 rows:", table1_rows)
print("Table2 rows:", table2_rows)
print("Current target values:", [(r, ws.cell(r,8).value, ws.cell(r,9).value, ws.cell(r,10).value) for r in table2_rows])

# write formula to all relevant table2 rows
start1, end1 = min(table1_rows), max(table1_rows)
for r in table2_rows:
    sid = ws.cell(r, 8).value
    sub_date = ws.cell(r, 9).value
    if sid is not None and sub_date is not None:
        formula = f'=LOOKUP(2,1/(($A${start1}:$A${end1}=H{r})*($C${start1}:$C${end1}<I{r})),$C${start1}:$C${end1})'
        print(f"Writing J{r} formula:", formula)
        ws.cell(r, 10).value = formula

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved:", out_path)

orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# restore sheet names if recalc changed them
wb_after = load_workbook(out_path)
if wb_after.sheetnames != orig_names:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)

# verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("Verified target cells:")
for r in table2_rows:
    print(f"H{r}: {vws.cell(r,8).value!r}, I{r}: {vws.cell(r,9).value!r}, J{r}: {vws.cell(r,10).value!r}")

# also inspect formula version
verf = load_workbook(out_path, data_only=False)
print("Formula in J2 after save:", verf["Sheet1"]["J2"].value)

output_spreadsheet = out_path
