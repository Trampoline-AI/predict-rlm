import os, json, math, statistics, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # gather row counts with any non-empty cells
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("nonempty row range:", (nonempty_rows[0], nonempty_rows[-1]) if nonempty_rows else None, "count:", len(nonempty_rows))
    
    # print first 15 rows x all used cols
    headers = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers)
    for r in range(1, min(ws.max_row, 12)+1):
        row = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"r{r}:", row)
    if ws.max_row > 12:
        print("... last 5 rows ...")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            row = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
            print(f"r{r}:", row)

# Also inspect formulas specifically
for ws in wb.worksheets:
    print(f"\nFormula cells in {ws.title}:")
    found = 0
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                print(f"{get_column_letter(c)}{r}: {v}")
                found += 1
                if found >= 20:
                    break
        if found >= 20:
            break
    print("formula count shown:", found)
