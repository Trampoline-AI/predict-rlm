infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load and inspect exact target cells again
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Target area before write:")
for coord in ["H1","I1","H2","I2","H3","I3"]:
    print(coord, "=", ws[coord].value)

# Determine actual populated data block for lookup/count area (A:D, rows 1:15 in this workbook)
# We'll derive last non-empty data row among columns A:D
