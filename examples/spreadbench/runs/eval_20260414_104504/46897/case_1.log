import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target/input cells
print("Before rewrite:")
for coord in ["A1","B1","C1","D1","H1","I1","H2","I2","H3","I3"]:
    print(coord, ws[coord].value)

last_data_row = 15  # verified from inspection
formula = (
    '=IFERROR('
    'IF($I$1=$A$1,COUNTIF($A$2:$A$15,$I$2),0)+'
    'IF($I$1=$B$1,COUNTIF($B$2:$B$15,$I$2),0)+'
    'IF($I$1=$C$1,COUNTIF($C$2:$C$15,$I$2),0)+'
    'IF($I$1=$D$1,COUNTIF($D$2:$D$15,$I$2),0)'
    ',"")'
)
ws["I3"] = formula
print("New formula for I3:", ws["I3"].value)

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# restore sheet names if needed
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    for i, nm in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = nm
    wb_post.save(outfile)
    print("Restored sheet names")

# Verify formula view and cached value
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["Sheet1"]
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]

print("After recalc formula view I3:", wsf["I3"].value)
print("After recalc data_only I3:", wsv["I3"].value)

# sanity-check expected count
vals = [ws.cell(r, 2).value for r in range(2, 16)]
print("Fruit column values:", vals)
print("Apple count expected:", sum(1 for v in vals if v == "Apple"))

output_spreadsheet = outfile
```
