from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print("\n" + "="*80)
    print("Sheet:", ws.title)
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # headers from first 3 rows for context
    for r in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # detect non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("First non-empty row:", nonempty_rows[0], "Last non-empty row:", nonempty_rows[-1])

    # print first 10 non-empty rows
    print("\nFirst up to 10 non-empty rows:")
    for r in nonempty_rows[:10]:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # print last 5 non-empty rows
    print("\nLast up to 5 non-empty rows:")
    for r in nonempty_rows[-5:]:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # print column letters + row1 values
    headers = []
    for c in range(1, ws.max_column + 1):
        headers.append(f"{get_column_letter(c)}={ws.cell(1,c).value!r}")
    print("\nColumn headers row1:", headers)
    
    # also inspect a bounded grid for visible layout
    max_r = min(ws.max_row, 20)
    max_c = min(ws.max_column, 12)
    print(f"\nTop-left grid 1:{max_r}, 1:{max_c}")
    for r in range(1, max_r+1):
        row = [ws.cell(r,c).value for c in range(1, max_c+1)]
        print(f"{r:>3}:", row)

for ws in wb.worksheets:
    sheet_info(ws)
