import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# find true last non-empty row based on columns A:B
last_row = 1
for r in range(ws.max_row, 0, -1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_row = r
        break

# inspect matching rows before writing
matches = []
for r in range(2, last_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a == 4 and isinstance(b, str) and "Gary Stoddard" in b:
        matches.append((r, a, b))
print("True last data row:", last_row)
print("Rows with A=4 and B containing 'Gary Stoddard':", len(matches))
print("Sample matching rows:", matches[:10])
print("Current F3 formula:", ws["F3"].value)

# write corrected formula to F3 using bounded ranges
new_formula = f'=COUNTIFS($B$2:$B${last_row},"*Gary Stoddard*",$A$2:$A${last_row},4)'
ws["F3"] = new_formula
print("New F3 formula:", ws["F3"].value)

wb.save(outfile)
print("Saved to:", outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# reload and restore sheet name if changed
wb_after = load_workbook(outfile)
orig_names = ["Sheet1"]
if wb_after.sheetnames != orig_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_names)
    # only handling single-sheet workbook here
    wb_after[wb_after.sheetnames[0]].title = orig_names[0]
    wb_after.save(outfile)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# verify formula and cached result
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]
print("Verified formula in F3:", wsf["F3"].value)
print("Cached value in F3 after recalc:", wsv["F3"].value)
print("Expected Python count:", len(matches))

output_spreadsheet = outfile
