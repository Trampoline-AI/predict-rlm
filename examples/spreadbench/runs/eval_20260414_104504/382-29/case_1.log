from openpyxl import load_workbook

# Reopen original input to avoid carrying forward wrong formulas
orig_path = input_spreadsheet
wb = load_workbook(orig_path)
print("Original sheets:", wb.sheetnames)

data_sheets = [s for s in wb.sheetnames if s != "Totals"]
tot = wb["Totals"]

# Inspect exact source/target mapping inferred from existing example
print("Existing example Totals!B2:", tot["B2"].value)
for s in data_sheets:
    ws = wb[s]
    print(f"\n{s} AB5:AB29 sample:")
    for r in list(range(5, 11)) + list(range(25, 30)):
        print(f"  AB{r} =", ws[f"AB{r}"].value)

print("\nTotals current A1:B26:")
for r in range(1, 27):
    print(r, tot[f"A{r}"].value, tot[f"B{r}"].value)

# Write correct formulas: Totals row 2..26 maps to source AB5..AB29
for total_row in range(2, 27):
    src_row = total_row + 3  # 2->5, 26->29
    refs = [f"'{s}'!AB{src_row}" for s in data_sheets]
    formula = "=" + "+".join(refs)
    tot[f"B{total_row}"] = formula

# Save output
outpath = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(orig_path))
wb.save(outpath)
print("\nSaved corrected workbook to:", outpath)

# Recalculate
recalc_result = await recalculate(outpath)
print("Recalc result:", recalc_result)

# Check sheet names post-recalc and restore if needed
wb_check = load_workbook(outpath)
print("Sheet names after recalc:", wb_check.sheetnames)
orig_names = wb.sheetnames
if wb_check.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(outpath)
    print("Restored sheet names:", orig_names)

# Verify formulas and cached values
wbf = load_workbook(outpath, data_only=False)
wbv = load_workbook(outpath, data_only=True)
totf = wbf["Totals"]
totv = wbv["Totals"]

print("\nVerified Totals B2:B26:")
verification = []
for total_row in range(2, 27):
    src_row = total_row + 3
    formula = totf[f"B{total_row}"].value
    value = totv[f"B{total_row}"].value
    code = totv[f"A{total_row}"].value
    verification.append((total_row, code, formula, value))
    print(total_row, code, formula, value)

# extra sanity-check: compare a few computed totals against Python sums from source cached values
