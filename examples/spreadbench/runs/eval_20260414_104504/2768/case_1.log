from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INSTRUCTION:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Find likely true used range by scanning non-empty rows/cols
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                nonempty_cols.add(c)
        if row_has:
            nonempty_rows.append(r)
    print("nonempty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("nonempty cols:", [f"{get_column_letter(c)}" for c in sorted(nonempty_cols)])
    
    # Print first 10 rows with coordinates and values
    print("\nFirst 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    print("\nLast 5 rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # Candidate header rows: first 5 rows with many strings
    print("\nHeader-like rows among first 5:")
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        str_count = sum(isinstance(v, str) and v.strip() != "" for v in vals)
        print(f"row {r} string_count={str_count} values={vals}")
    
    # Find formulas in first 30 rows
    formulas = []
    for r in range(1, min(ws.max_row, 50) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("\nFormulas in first 50 rows:", formulas[:20], "total", len(formulas))
