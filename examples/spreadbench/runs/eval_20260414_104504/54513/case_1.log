import os, json, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row", ws.max_row, "max_col", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)]
        print("Row2 values:", headers2)
    # print first up to 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # print last 5 rows
    start = max(1, ws.max_row-4)
    print("Last rows:")
    for r in range(start, ws.max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)

    # print formulas / nonempty cells coordinates
    nonempty = []
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                nonempty.append((cell.coordinate, cell.value))
                if isinstance(cell.value, str) and cell.value.startswith("="):
                    formulas.append((cell.coordinate, cell.value))
    print("Non-empty cells:", nonempty[:30], "count", len(nonempty))
    print("Formulas:", formulas[:20], "count", len(formulas))
