from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect exact target area and formatting
for r in range(7, 9):
    vals = [ws.cell(r, c).value for c in range(2, 7)]
    print("Row", r, vals)
for coord in ["C8","D8","E8","F8","B4","C4","B5","C5"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

# check if F8 has existing formatting
print("F8 fill/format:", ws["F8"].number_format, ws["F8"].style_id)

# write formula into F8
ws["F8"] = '=IF(OR(C8="",E8=""),"",C8*(1-E8))'
ws["F8"].number_format = ws["C8"].number_format or '$0.00'

# save
