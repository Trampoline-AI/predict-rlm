import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Re-open and inspect only the relevant target area
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]
orig_sheet_names = wb.sheetnames[:]

print("Sheet:", ws.title)
print("I12 value:", ws["I12"].value)
print("I12 number_format:", ws["I12"].number_format)
print("J23 current value:", ws["J23"].value)
print("J23 current number_format:", ws["J23"].number_format)

print("\nRelevant range H10:J24:")
for r in range(10, 25):
    vals = [ws.cell(r, c).value for c in range(8, 11)]
    print(r, vals)

# Write the correct formula into the exact target cell
ws["J23"] = '=IF(I12="","",I12)'

# Preserve existing number format if present; otherwise mirror I12 to avoid odd display
if ws["J23"].number_format in (None, "", "General"):
    ws["J23"].number_format = ws["I12"].number_format

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheet_names)
    for i, name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)
ws_formula = wb_check[orig_sheet_names[0]]
print("Verified formula in J23:", ws_formula["J23"].value)
print("I12 formula/workbook value:", ws_formula["I12"].value)

# Verify cached value after recalc
wb_data = load_workbook(outfile, data_only=True)
ws_data = wb_data[orig_sheet_names[0]]
print("Cached data_only I12:", ws_data["I12"].value)
print("Cached data_only J23:", ws_data["J23"].value)
print("Cached J23 number_format:", ws_formula["J23"].number_format)

output_spreadsheet = outfile
