import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Verify target range current values
print("Current A14:E17 before write:")
for r in range(14, 18):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Source data and transform
source_rows = []
for r in range(1, 5):  # header + 3 data rows as present in source block
    source_rows.append([ws.cell(r, c).value for c in range(1, 6)])
print("Source rows:", source_rows)

transformed = [source_rows[0]]
for row in source_rows[1:]:
    seen = set()
    new_row = [row[0]]  # site name preserved
    for val in row[1:]:
        if val is None or val == "":
            new_row.append(val)
        elif val in seen:
            new_row.append(None)
        else:
            new_row.append(val)
            seen.add(val)
    transformed.append(new_row)

print("Transformed rows to write A14:E17:")
for row in transformed:
    print(row)

# Write to A14:E17
for i, row in enumerate(transformed, start=14):
    for c, val in enumerate(row, start=1):
        ws.cell(i, c).value = val

orig_names = wb.sheetnames[:]
wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_names)
    for idx, name in enumerate(orig_names):
        wb2.worksheets[idx].title = name
    wb2.save(outfile)

# Verify output values
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_names[0]]
print("A14:E17 after save/recalc:")
for r in range(14, 18):
    print(r, [wsv.cell(r, c).value for c in range(1, 6)])

output_spreadsheet = outfile
