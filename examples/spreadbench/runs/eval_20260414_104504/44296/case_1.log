import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload fresh workbook for writing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Final pre-write checks
source_states = [ws1.cell(r, 2).value for r in range(3, ws1.max_row + 1) if ws1.cell(r, 2).value is not None]
source_years = [ws1.cell(1, c).value for c in range(12, ws1.max_column + 1) if ws1.cell(1, c).value is not None]
print("Source states count:", len(source_states), "first/last:", source_states[:5], source_states[-5:])
print("Source years:", source_years)
print("Target rows to fill:", ws2.max_row - 2)

# Write formulas into D for rows with both state and year present
written = 0
for r in range(3, ws2.max_row + 1):
    state = ws2.cell(r, 1).value
    year = ws2.cell(r, 2).value
    if state not in (None, "") and year not in (None, ""):
        formula = f'=INDEX(Sheet1!$L$3:$R$53, MATCH(A{r}, Sheet1!$B$3:$B$53, 0), MATCH(B{r}, Sheet1!$L$1:$R$1, 0))'
        ws2.cell(r, 4).value = formula
        written += 1

print("Formulas written:", written)
print("Sample formulas:", [ws2.cell(r,4).value for r in [3,4,53,54,104]])

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Reload and fix sheet names if changed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # restore by position
    for i, expected in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
ws2f = wb_formula["Sheet2"]
ws2v = wb_values["Sheet2"]

sample_rows = [3, 4, 53, 54, 104]
print("\nVerification samples (row, state, year, formula, value):")
for r in sample_rows:
    print(r, ws2v.cell(r,1).value, ws2v.cell(r,2).value, ws2f.cell(r,4).value, ws2v.cell(r,4).value)

# Full verification: check blanks/errors in target rows
blank_rows = []
error_like_rows = []
for r in range(3, ws2v.max_row + 1):
    if ws2v.cell(r,1).value not in (None, "") and ws2v.cell(r,2).value not in (None, ""):
        val = ws2v.cell(r,4).value
        if val in (None, ""):
            blank_rows.append(r)
        elif isinstance(val, str) and val.startswith("#"):
            error_like_rows.append((r, val))

print("Blank target rows after recalc:", blank_rows[:20], "count=", len(blank_rows))
print("Error-like target rows after recalc:", error_like_rows[:20], "count=", len(error_like_rows))
