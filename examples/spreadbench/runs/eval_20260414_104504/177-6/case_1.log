from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
from collections import defaultdict
import os

wb = load_workbook(input_spreadsheet)
data_ws = wb["DATA"]
comb_ws = wb["combined"]

print("Merged ranges DATA:", list(data_ws.merged_cells.ranges))
print("Merged ranges combined:", list(comb_ws.merged_cells.ranges))

print("DATA column widths A:R:")
for c in range(1, 19):
    letter = get_column_letter(c)
    print(letter, data_ws.column_dimensions[letter].width)

print("combined column widths A:R:")
for c in range(1, 19):
    letter = get_column_letter(c)
    print(letter, comb_ws.column_dimensions[letter].width)

print("DATA row heights 1:15")
for r in range(1, min(15, data_ws.max_row)+1):
    print(r, data_ws.row_dimensions[r].height)

print("combined row heights 1:10")
for r in range(1, min(10, comb_ws.max_row)+1):
    print(r, comb_ws.row_dimensions[r].height)

# Build grouped output
def is_blankish(v):
    return v is None or v == "" or v == "\xa0"

groups = []
seen = set()
for r in range(2, data_ws.max_row + 1):
    row_vals = [data_ws.cell(r, c).value for c in range(1, 19)]
    if all(v is None for v in row_vals):
        continue
    key = data_ws.cell(r, 8).value
    if key not in seen:
        seen.add(key)
        groups.append(key)

group_rows = defaultdict(list)
for r in range(2, data_ws.max_row + 1):
    row_vals = [data_ws.cell(r, c).value for c in range(1, 19)]
    if all(v is None for v in row_vals):
        continue
    key = data_ws.cell(r, 8).value
    group_rows[key].append(r)

print("\nPlanned grouped results:")
for key in groups:
    rows = group_rows[key]
    totals = []
    for c in range(9, 19):
        s = 0.0
        has_num = False
        for r in rows:
            v = data_ws.cell(r, c).value
            if not is_blankish(v):
                try:
                    s += float(v)
                    has_num = True
                except:
                    pass
        totals.append("" if (not has_num or abs(s) < 1e-12) else round(s, 2))
    print(key, rows, totals)

# Rebuild combined sheet
# Clear existing rows below header in A:R
for r in range(2, comb_ws.max_row + 1):
    for c in range(1, 19):
        cell = comb_ws.cell(r, c)
        cell.value = None
        cell._style = copy(data_ws.cell(2, c)._style) if data_ws.max_row >= 2 else copy(comb_ws.cell(1, c)._style)
        cell.number_format = data_ws.cell(2, c).number_format if data_ws.max_row >= 2 else comb_ws.cell(1, c).number_format

out_row = 2
for key in groups:
    src_rows = group_rows[key]
    src_r = src_rows[0]

    # copy A:R values and formatting from first row in group
    for c in range(1, 19):
        src = data_ws.cell(src_r, c)
        dst = comb_ws.cell(out_row, c)
        dst.value = src.value
        dst._style = copy(src._style)
        dst.font = copy(src.font)
        dst.fill = copy(src.fill)
        dst.border = copy(src.border)
        dst.alignment = copy(src.alignment)
        dst.protection = copy(src.protection)
        dst.number_format = src.number_format

    # overwrite aggregated I:R
    for c in range(9, 19):
        s = 0.0
        has_num = False
        for r in src_rows:
            v = data_ws.cell(r, c).value
            if not is_blankish(v):
                try:
                    s += float(v)
                    has_num = True
                except:
                    pass
        dst = comb_ws.cell(out_row, c)
        if (not has_num) or abs(s) < 1e-12:
            dst.value = ""
        else:
            dst.value = round(s, 2)
            dst.number_format = "0.00"
    # preserve row height from source row
    comb_ws.row_dimensions[out_row].height = data_ws.row_dimensions[src_r].height
    out_row += 1

# Clear any leftover old rows below output
for r in range(out_row, max(comb_ws.max_row, out_row) + 5):
    for c in range(1, 19):
        comb_ws.cell(r, c).value = None

# Copy column widths from DATA to combined for A:R
for c in range(1, 19):
    letter = get_column_letter(c)
    comb_ws.column_dimensions[letter].width = data_ws.column_dimensions[letter].width

# Save
fname = os.path.basename(input_spreadsheet)
out_path = os.path.join("/sandbox/output/output_spreadsheet", fname)
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
original_names = ["DATA", "combined"]
if wb2.sheetnames != original_names:
    for i, nm in enumerate(original_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = nm
    wb2.save(out_path)
    print("Renamed sheets back to:", wb2.sheetnames)

# Verify with data_only
ver_wb = load_workbook(out_path, data_only=True)
print("Verified sheet names:", ver_wb.sheetnames)
ver_ws = ver_wb["combined"]
print("combined dimensions:", ver_ws.max_row, ver_ws.max_column)
for r in range(1, ver_ws.max_row + 1):
    vals = [ver_ws.cell(r, c).value for c in range(1, 19)]
    print("combined row", r, vals)

# Print exact target cells I:R for output rows
for r in range(2, ver_ws.max_row + 1):
    print(f"Row {r} H={ver_ws.cell(r,8).value!r} I:R={[ver_ws.cell(r,c).value for c in range(9,19)]}")

output_spreadsheet = out_path
