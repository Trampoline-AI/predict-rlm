import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and preserve original sheet names
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print current target and nearby cells/formulas
print("Before fix, B7 raw:", ws["B7"].value)
for r in range(1, 8):
    print(r, ws.cell(r,1).value, ws.cell(r,2).value)

# Fix the broken formula in place
ws["B7"] = "=VLOOKUP(A7,A1:B5,2,FALSE)"
print("After fix, B7 raw:", ws["B7"].value)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(outfile)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring", original_sheetnames)
    # rename by position to original names
    for i, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
v = wb_verify["Sheet1"]["B7"].value
print("Verified Sheet1!B7 value:", v)
print("Verified A7:", wb_verify["Sheet1"]["A7"].value)
assert v is not None and str(v).strip() != "", "B7 is blank after recalc"
