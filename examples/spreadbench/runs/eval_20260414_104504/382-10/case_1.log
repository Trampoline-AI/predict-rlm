from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and inspect exact target cells/formulas before modification
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Target sheet:", ws.title)
print("Target column:", "A")
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.startswith("="):
        print("Existing formula before change:", f"A{r} =", v)

# Clear any A cell whose trimmed, case-insensitive text is not exactly "comments"
changed = []
kept = []
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 1)
    v = cell.value
    norm = str(v).strip().lower() if v is not None else ""
    if norm == "comments":
        kept.append((r, v))
    else:
        if v not in (None, ""):
            changed.append((r, v))
        cell.value = None

print("Rows kept as comments:", kept)
print("Rows cleared:", changed)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, sname in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = sname
    wb2.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verification with formulas cached values
