Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
print("Original sheetnames:", wb.sheetnames)

src = wb["Source"]
src2 = wb["Source2"]
res = wb["Result"]

# Verify target area
print("Existing Result cells:")
for r in range(1, max(5, res.max_row)+1):
    print(r, res.cell(r,1).value)

source_vals = [src.cell(r, 2).value for r in range(2, src.max_row + 1) if src.cell(r, 2).value is not None]
source2_vals = [src2.cell(r, 1).value for r in range(2, src2.max_row + 1) if src2.cell(r, 1).value is not None]
source2_set = set(source2_vals)

print("Source values:", source_vals)
print("Source2 values:", source2_vals)

# Build result: values in Source but not in Source2; special-case 2 if present in both, include once.
result_vals = []
seen = set()
for v in source_vals:
    include = (v not in source2_set) or (v == 2 and 2 in source2_set)
    if include and v not in seen:
        result_vals.append(v)
        seen.add(v)

print("Computed result values:", result_vals)

# Clear old result entries below header only in column A existing used rows
for r in range(2, res.max_row + 1):
    res.cell(r, 1).value = None

# Write results under existing header
for i, v in enumerate(result_vals, start=2):
    res.cell(i, 1).value = v

wb.save(outfile)
print("Saved to", outfile)

recalc_status = await recalculate(outfile)
print("Recalc:", recalc_status)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Post-recalc sheetnames:", wb2.sheetnames)
orig_names = ["Source", "Source2", "Result"]
if wb2.sheetnames != orig_names:
    for ws, name in zip(wb2.worksheets, orig_names):
        ws.title = name
    wb2.save(outfile)
    print("Restored sheetnames to:", wb2.sheetnames)

# Verification with data_only
ver = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", ver.sheetnames)
vres = ver["Result"]
print("Verified Result values:")
for r in range(1, max(vres.max_row, len(result_vals)+1)+1):
    print(r, vres.cell(r,1).value)

output_spreadsheet = outfile
```
