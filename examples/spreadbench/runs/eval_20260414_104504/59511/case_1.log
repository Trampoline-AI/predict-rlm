Code:
```repl
import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Detailed inspection:")
for r in range(1, 13):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

print("\nCell-by-cell meanings around target area:")
for coord in ["A2","B2","C2","E2","F2","A3","B3","C3","E3","F3","E4","F4","E5","F5","E6","F6"]:
    print(coord, "=", ws[coord].value)

print("\nExisting formulas in columns A/B/F:")
for r in range(2, 13):
    print(r, "A", ws[f"A{r}"].value, "B", ws[f"B{r}"].value, "F", ws[f"F{r}"].value)

# Determine rows in E needing output
target_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, 5).value not in (None, "")]
print("\nRows with input values in column E:", target_rows)

# Fill blank F cells for rows with E values using non-XLOOKUP range lookup formula
# Logic: find largest lower bound in col A less than or equal to E row; return corresponding C.
# Since A contains 0,1001,2001... and B upper bounds 1000,2000..., MATCH on A works.
for r in target_rows:
    fcell = ws.cell(r, 6)
    if fcell.value in (None, ""):
        fcell.value = f'=INDEX($C$2:$C$12, MATCH(E{r}, $A$2:$A$12, 1))'
        print(f"Set F{r} =", fcell.value)
    else:
        print(f"Preserved existing F{r} =", fcell.value)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet name if needed
orig_names = wb.sheetnames
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_names)
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    wb_check = load_workbook(out_path)

# Verify formulas and calculated values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values[orig_names[0]]

print("\nVerification target cells E/F:")
for r in target_rows:
    print(
        f"Row {r}: E{r} input={wsv.cell(r,5).value!r}, "
        f"F{r} formula={wsf.cell(r,6).value!r}, "
        f"F{r} value={wsv.cell(r,6).value!r}"
    )

output_spreadsheet = out_path
