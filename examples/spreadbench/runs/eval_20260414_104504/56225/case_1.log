```repl
import os, shutil
from collections import defaultdict
from datetime import datetime, date, time
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
orig_sheetnames = wb.sheetnames[:]
wsm = wb["mechanic"]
wsd = wb["data"]

def norm_date(v):
    if v is None:
        return None
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    if isinstance(v, str):
        for fmt in ("%m-%d-%y", "%m/%d/%y", "%Y-%m-%d", "%m-%d-%Y", "%m/%d/%Y"):
            try:
                return datetime.strptime(v, fmt).date()
            except:
                pass
    return None

def time_to_hours(t):
    if t is None:
        return None
    if isinstance(t, time):
        return t.hour + t.minute/60 + t.second/3600
    return None

# Build row-level hours from time in/out and write K where appropriate
written_k = []
for r in range(2, wsd.max_row + 1):
    d = norm_date(wsd.cell(r, 1).value)
    name = wsd.cell(r, 3).value
    tin = wsd.cell(r, 5).value
    tout = wsd.cell(r, 6).value
    if d and name and tin and tout:
        hrs = time_to_hours(tout) - time_to_hours(tin)
        if hrs is not None:
            # write numeric total hours into K for all valid work rows
            wsd.cell(r, 11).value = hrs
            written_k.append((r, hrs))

# Aggregate by exact name/date
agg = defaultdict(float)
for r in range(2, wsd.max_row + 1):
    d = norm_date(wsd.cell(r, 1).value)
    name = wsd.cell(r, 3).value
    kval = wsd.cell(r, 11).value
    if d and name is not None and isinstance(kval, (int, float)):
        agg[(d, str(name).strip().lower())] += float(kval)

# Criteria area on data sheet
crit_name = (wsd["M3"].value or "").strip().lower()
crit_date = norm_date(wsd["N5"].value)

name_only_sum = sum(v for (d, nm), v in agg.items() if crit_name and crit_name in nm)
name_date_sum = sum(v for (d, nm), v in agg.items() if crit_name and crit_date and d == crit_date and crit_name in nm)

# Preserve labels, place computed answers in existing target cells
wsd["N3"] = name_only_sum
wsd["O3"] = name_date_sum

# Fill mechanic summary table B2:E32
mechanics = []
for c in range(2, wsm.max_column + 1):
    header = wsm.cell(1, c).value
    mechanics.append((c, str(header).strip().lower() if header is not None else ""))

filled_summary = []
for r in range(2, wsm.max_row + 1):
    d = norm_date(wsm.cell(r, 1).value)
    if not d:
        continue
    for c, mech in mechanics:
        if not mech:
            continue
        total = sum(v for (ad, nm), v in agg.items() if ad == d and mech in nm)
        wsm.cell(r, c).value = total if total != 0 else None
        filled_summary.append((r, c, total))

wb.save(outfile)

# recalc
result = await recalculate(outfile)
print("recalculate:", result)

# restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_sheetnames)
    for i, nm in enumerate(orig_sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = nm
    wb2.save(outfile)

# verify with data_only
vwb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", vwb.sheetnames)

vwsm = vwb["mechanic"]
vwsd = vwb["data"]

print("data!M3:", vwsd["M3"].value)
print("data!N5:", vwsd["N5"].value)
print("data!N3:", vwsd["N3"].value)
print("data!O3:", vwsd["O3"].value)

print("Sample K values rows 2:15:")
for r in range(2, 16):
    print(r, vwsd.cell(r, 11).value)

print("Mechanic summary rows 1:6 A:E")
for r in range(1, 7):
    print(r, [vwsm.cell(r, c).value for c in range(1, 6)])

print("Mechanic summary last 5 rows A:E")
for r in range(vwsm.max_row - 4, vwsm.max_row + 1):
    print(r, [vwsm.cell(r, c).value for c in range(1, 6)])

output_spreadsheet = outfile
