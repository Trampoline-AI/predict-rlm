from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n=== SHEET ===", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # find non-empty headers in first 3 rows
    for hr in range(1, min(4, ws.max_row+1)):
        vals = row_values(ws, hr, ws.max_column)
        print(f"Row {hr} headers/sample:", vals)
    
    # detect likely header row among first 5 rows
    likely_header = None
    best_score = -1
    for hr in range(1, min(6, ws.max_row+1)):
        vals = row_values(ws, hr, ws.max_column)
        score = sum(v is not None and str(v).strip() != "" for v in vals)
        if score > best_score:
            best_score = score
            likely_header = hr
    print("Likely header row:", likely_header)
    
    headers = row_values(ws, likely_header, ws.max_column)
    print("Column headers with letters:")
    for i, h in enumerate(headers, start=1):
        if h is not None:
            print(f"  {get_column_letter(i)}: {h}")
    
    # print first 10 and last 5 rows
    print("\nFirst rows:")
    first_end = min(ws.max_row, likely_header + 9)
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, min(ws.max_column, 18)))  # first 18 cols for readability
    
    print("\nLast 5 rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 18)))
    
    # specific columns H, L, Q if present
    for col in [8, 12, 17]:
        if col <= ws.max_column:
            print(f"\nColumn {get_column_letter(col)} sample values:")
            vals = []
            for r in range(1, min(ws.max_row, 12) + 1):
                vals.append((r, ws.cell(r, col).value))
            print("Top:", vals)
            vals2 = []
            for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
                vals2.append((r, ws.cell(r, col).value))
            print("Bottom:", vals2)

    # print compact H/L/Q triples for first and last rows
    if ws.max_column >= 17:
        print("\nH/L/Q triples around top:")
        for r in range(1, min(ws.max_row, 15) + 1):
            print(r, {"H": ws.cell(r,8).value, "L": ws.cell(r,12).value, "Q": ws.cell(r,17).value})
        print("\nH/L/Q triples around bottom:")
        for r in range(max(1, ws.max_row-9), ws.max_row+1):
            print(r, {"H": ws.cell(r,8).value, "L": ws.cell(r,12).value, "Q": ws.cell(r,17).value})
