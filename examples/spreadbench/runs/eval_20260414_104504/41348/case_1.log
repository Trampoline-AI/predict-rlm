from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from collections import defaultdict

# Re-open to inspect formulas in target column Q and exact target range
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)

# Print Q cells with formulas/raw values and related columns H/I/J/L/P
for r in range(1, ws.max_row + 1):
    vals = {
        "row": r,
        "H_ProjectID": ws.cell(r, 8).value,
        "I_Linked": ws.cell(r, 9).value,
        "J_BudgetID": ws.cell(r, 10).value,
        "L_BudgetType": ws.cell(r, 12).value,
        "P_TechRevenue": ws.cell(r, 16).value,
        "Q_value": ws.cell(r, 17).value,
        "Q_data_type": ws.cell(r, 17).data_type,
    }
    print(vals)

# Determine projects with any Technology line
project_has_tech = {}
project_rows = defaultdict(list)
for r in range(2, ws.max_row + 1):
    project_id = ws.cell(r, 8).value
    linked = ws.cell(r, 9).value
    budget_type = ws.cell(r, 12).value
    project_rows[project_id].append(r)
    if project_id not in project_has_tech:
        project_has_tech[project_id] = False
    if project_id is not None and str(linked).strip() == "Y" and isinstance(budget_type, str) and budget_type.strip().lower() == "technology":
        project_has_tech[project_id] = True

print("project_has_tech:", project_has_tech)

# Apply requested logic into existing column Q
changes = []
for r in range(2, ws.max_row + 1):
    project_id = ws.cell(r, 8).value
    linked = ws.cell(r, 9).value
    old = ws.cell(r, 17).value

    if str(linked).strip() == "N" or project_id is None:
        new = "N"
    else:
        new = "Y" if project_has_tech.get(project_id, False) else "N"

    if old != new:
        changes.append((r, old, new))
    ws.cell(r, 17).value = new

print("Changes made:", changes)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
orig_names = wb.sheetnames[:]
wb2 = load_workbook(out_path)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    for i, old_name in enumerate(orig_names):
        wb2.worksheets[i].title = old_name
    wb2.save(out_path)
    print("Restored sheet names:", orig_names)

# Verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("Verification target column Q:")
for r in range(1, vws.max_row + 1):
    print(r, {
        "H": vws.cell(r, 8).value,
        "I": vws.cell(r, 9).value,
        "J": vws.cell(r, 10).value,
        "L": vws.cell(r, 12).value,
        "Q": vws.cell(r, 17).value
    })

output_spreadsheet = out_path
