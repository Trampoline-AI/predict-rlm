import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Inspect target area B:H rows 2-22")
for r in range(2, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(2, 9)]
    print(r, row_vals)

print("\nCell metadata for B/H:")
for r in range(2, ws.max_row + 1):
    b = ws.cell(r, 2)
    h = ws.cell(r, 8)
    print(f"Row {r}: B={b.value!r} type={b.data_type} | H={h.value!r} type={h.data_type}")

# Perform overwrite for actual data rows (exclude row 2 header text)
for r in range(3, ws.max_row + 1):
    h_val = ws.cell(r, 8).value
    if h_val not in (None, ""):
        ws.cell(r, 2).value = h_val

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate and handle possible sheet rename
orig_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename back by position
    for i, old_name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = old_name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_sheetnames[0]]
print("\nVerification B and H rows 2-22:")
all_ok = True
for r in range(2, vws.max_row + 1):
    b = vws.cell(r, 2).value
    h = vws.cell(r, 8).value
    print(f"Row {r}: B={b!r} | H={h!r}")
    if r >= 3 and (b != h):
        all_ok = False

print("All data rows B==H?", all_ok)
output_spreadsheet = out_path
