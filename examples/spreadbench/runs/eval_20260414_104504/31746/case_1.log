import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find likely used rows/cols more carefully
    nonempty_rows = []
    for r in range(1, ws.max_row+1):
        if any(ws.cell(r,c).value is not None for c in range(1, ws.max_column+1)):
            nonempty_rows.append(r)
    print("nonempty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    headers1 = row_values(ws, 1)
    headers2 = row_values(ws, 2) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    
    # print first 10 rows and last 5 nonempty rows
    sample_rows = list(range(1, min(ws.max_row, 10)+1))
    tail_rows = list(range(max(1, ws.max_row-4), ws.max_row+1))
    shown = []
    for r in sample_rows + tail_rows:
        if r not in shown:
            shown.append(r)
    for r in shown:
        print(f"R{r}:", row_values(ws, r))
    
    # print formulas found in first 20 rows/all cols
    formulas = []
    for r in range(1, min(ws.max_row, 25)+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formulas in first 25 rows:", formulas[:20], "count=", len(formulas))
