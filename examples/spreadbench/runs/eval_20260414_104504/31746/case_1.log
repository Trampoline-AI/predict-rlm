import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import Font
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Target column Q header:", ws["Q2"].value)
for r in range(30, 39):
    vals = [ws.cell(r, c).value for c in range(1, 18)]
    print(f"R{r} A:Q ->", vals)
    print(f"   Q{r} current:", ws[f'Q{r}'].value, "bold:", ws[f'Q{r}'].font.bold)

# identify rows with month data in D:P and Q blank
rows_need_q = []
for r in range(3, 38):
    month_vals = [ws.cell(r, c).value for c in range(4, 17)]
    has_any_data = any((v not in (None, "")) for v in month_vals)
    if has_any_data and ws.cell(r, 17).value in (None, ""):
        rows_need_q.append(r)
print("Rows needing Q formula:", rows_need_q)

# Build formula pattern from headers / month logic
# Months D:P are 12,13,18,21,24,25,30,36,37,48,60,72,78 -> multipliers 70,69,64,61,58,57,52,46,45,34,22,10,4
terms = []
multipliers = [70,69,64,61,58,57,52,46,45,34,22,10,4]
for idx, c in enumerate(range(4,17)):
    col = get_column_letter(c)
    mult = multipliers[idx]
    terms.append((col, mult))
print("Formula terms:", terms)

for r in rows_need_q:
    formula = "=" + "+".join([f"({col}{r}*{mult})" for col, mult in terms])
    ws.cell(r, 17).value = formula

# Set grand total in Q38
ws["Q38"] = "=SUM(Q3:Q37)"

# Ensure Q values are not bold, especially Q38 per instruction
for r in rows_need_q + [38]:
    cell = ws.cell(r, 17)
    cell.font = cell.font.copy(bold=False)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore original sheet name if changed
orig_names = ["Sheet1"]
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring")
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)

# Verify with data_only
wbv = load_workbook(out_path, data_only=False)
wbv_data = load_workbook(out_path, data_only=True)
wsf = wbv["Sheet1"]
wsd = wbv_data["Sheet1"]

for r in rows_need_q + [38]:
