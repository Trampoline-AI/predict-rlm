from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames
ws = wb[orig_sheet_names[0]]

# Re-inspect target area before writing
print("Pre-write target area:")
for r in range(1, ws.max_row + 1):
    print(r, {"A": ws[f"A{r}"].value, "B": ws[f"B{r}"].value, "C": ws[f"C{r}"].value})
print("Existing C1:", ws["C1"].value)

# Update second column formulas to round to nearest 5 with exact midpoints rounded down
for r in range(1, ws.max_row + 1):
    original_b = ws.cell(r, 2).value
    if isinstance(original_b, str) and original_b.startswith("="):
        expr = original_b[1:]  # strip leading =
        new_formula = f'=IF(MOD(({expr}),5)=2.5,({expr})-2.5,ROUND(({expr})/5,0)*5)'
        ws.cell(r, 2).value = new_formula
        ws.cell(r, 2).number_format = '0.00'
        print(f"Row {r} B formula:", new_formula)

# Put the corresponding rounded formula in C1, matching requested tie-down behavior
# Base it on the current B1 source expression if available.
a1_based_expr = "+A1+(A1*0.05)"
c1_formula = f'=IF(MOD(({a1_based_expr}),5)=2.5,({a1_based_expr})-2.5,ROUND(({a1_based_expr})/5,0)*5)'
ws["C1"] = c1_formula
ws["C1"].number_format = '0.00'
print("Written C1 formula:", ws["C1"].value)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verify cached values after recalc
wb_data = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_data.sheetnames)
wsd = wb_data[orig_sheet_names[0]]
for coord in ["B1", "B2", "C1"]:
    print(coord, "=>", wsd[coord].value)

# Also print formulas from normal load for exact verification
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
for coord in ["B1", "B2", "C1"]:
    print("FORMULA", coord, "=>", wsf[coord].value)
