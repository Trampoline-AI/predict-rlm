import os, shutil
from openpyxl import load_workbook

# Re-open for closer inspection
wb = load_workbook(input_spreadsheet)
ws_in = wb["Input"]
ws_out = wb["Output"]

print("Detailed Input rows 7:34 cols A:F")
for r in range(7, ws_in.max_row + 1):
    print(r, [ws_in.cell(r, c).value for c in range(1, 7)])

print("\nDetailed Output rows 1:34 cols A:B")
for r in range(1, ws_out.max_row + 1):
    print(r, [ws_out.cell(r, c).value for c in range(1, 3)])

# Determine matching input rows
matches = []
for r in range(1, ws_in.max_row + 1):
    a = ws_in[f"A{r}"].value
    b = ws_in[f"B{r}"].value
    todo = ws_in[f"E{r}"].value
    if isinstance(todo, str) and todo.strip().lower() == "yes" and a not in (None, "") and b not in (None, ""):
        matches.append((r, a, b))
print("\nMatched input rows (To Do=yes and A/B non-empty):")
for m in matches:
    print(m)
print("Total matches:", len(matches))

# Write output file
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

wb2 = load_workbook(out_path)
ws_in2 = wb2["Input"]
ws_out2 = wb2["Output"]

# Preserve top area, rewrite target block A:B from row 10 downward
for r in range(10, ws_out2.max_row + 1):
    ws_out2.cell(r, 1).value = None
    ws_out2.cell(r, 2).value = None

out_row = 10
for r, a, b in matches:
    ws_out2.cell(out_row, 1).value = f"=Input!A{r}"
    ws_out2.cell(out_row, 2).value = f"=Input!B{r}"
    out_row += 1

wb2.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
orig_names = wb.sheetnames
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    # rename by position back to original
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Restored sheet names to:", orig_names)

# Verify target cells with cached values
wb_verify = load_workbook(out_path, data_only=True)
print("\nVerified Output rows 10 onward A:B (data_only):")
for r in range(10, 10 + len(matches) + 3):
