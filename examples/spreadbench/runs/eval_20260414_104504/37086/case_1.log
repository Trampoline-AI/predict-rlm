import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook for editing
wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify target columns again
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Headers:", headers)

# Write updated formulas into existing Total column cells
for r in range(2, ws.max_row + 1):
    col1 = ws.cell(r, 1).value
    current_total = ws.cell(r, 4).value
    print(f"Before row {r}: A{r}={col1}, D{r}={current_total}")
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 4)):  # only data rows
        ws.cell(r, 4).value = f'=SUM(B{r}:C{r})+IF(A{r}="A",10,IF(A{r}="B",-10,0))'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    for idx, name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = name
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheet_names)

# Verification: formulas and computed values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("Verification of target cells:")
for r in range(2, ws_formula.max_row + 1):
    print(
        f"Row {r}: A{r}={ws_formula[f'A{r}'].value}, "
        f"Formula D{r}={ws_formula[f'D{r}'].value}, "
        f"Value D{r}={ws_values[f'D{r}'].value}"
    )

output_spreadsheet = outfile
