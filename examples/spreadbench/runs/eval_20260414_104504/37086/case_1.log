import os, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)
print("Input file exists:", os.path.exists(input_spreadsheet), input_spreadsheet)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # headers from first 3 rows to detect actual header row
    for hr in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {hr}:", vals)
    
    # choose likely header row as first row with at least 2 non-empty values
    header_row = None
    for r in range(1, min(6, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty >= 2:
            header_row = r
            break
    print("Likely header row:", header_row)
    if header_row:
        headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
        print("Headers:", headers)
    
    # first 10 rows
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
    
    # last 5 rows
    print("Last rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
    
    # find possible target columns
    for r in range(1, min(6, ws.max_row + 1)):
        headers = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        lowered = [str(h).strip().lower() if h is not None else "" for h in headers]
        if "total" in lowered or "column1" in lowered:
            print("Found relevant header row", r)
            for c, h in enumerate(headers, start=1):
                if str(h).strip().lower() in ("total", "column1"):
                    print("Relevant header:", h, "at", f"{get_column_letter(c)}{r}")
                    # print some current values below header
                    for rr in range(r+1, min(ws.max_row, r+8) + 1):
                        print(f"  {get_column_letter(c)}{rr} =", ws.cell(rr, c).value)
