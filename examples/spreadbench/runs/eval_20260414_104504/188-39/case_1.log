from openpyxl import load_workbook
from openpyxl.styles import Alignment
import os, shutil

# Reload for modification
wb = load_workbook(input_spreadsheet)
main_ws = wb["main sheet"]
res_ws = wb["result"]

# Inspect current alignments/styles around target area
for coord in ["A1","B1","C1","D1","A2","B2","C2","D2"]:
    cell = res_ws[coord]
    print(coord, "value=", cell.value, "align=", (cell.alignment.horizontal, cell.alignment.vertical))

allowed = {"Branch Manager", "Branch Credit Manager"}

# Build mapping by location from main sheet
main_records = {}
print("\nMain sheet records and whether designation allowed:")
for r in range(2, main_ws.max_row + 1):
    loc = main_ws.cell(r, 1).value
    name = main_ws.cell(r, 2).value
    contact = main_ws.cell(r, 3).value
    mail = main_ws.cell(r, 4).value
    desig = main_ws.cell(r, 5).value
    main_records[loc] = {"name": name, "contact": contact, "mail": mail, "designation": desig}
    print(r, loc, desig, desig in allowed)

# Print target cells before writing
print("\nTarget cells before writing:")
for r in range(2, res_ws.max_row + 1):
    print(r, res_ws.cell(r,1).value, [res_ws.cell(r,c).value for c in range(2,5)])

# Fill result sheet based on location lookup
for r in range(2, res_ws.max_row + 1):
    loc = res_ws.cell(r, 1).value
    rec = main_records.get(loc)
    if rec and rec["designation"] in allowed:
        res_ws.cell(r, 2).value = rec["designation"]
        res_ws.cell(r, 3).value = str(rec["contact"]).strip() if rec["contact"] is not None else ""
        res_ws.cell(r, 4).value = rec["mail"]
    else:
        res_ws.cell(r, 2).value = "N/A"
        res_ws.cell(r, 3).value = "N/A"
        res_ws.cell(r, 4).value = "N/A"
    for c in range(2, 5):
        res_ws.cell(r, c).alignment = Alignment(horizontal="left")

# Also left-align headers/output columns to satisfy instruction for outputed entries
for c in range(1, 5):
    res_ws.cell(1, c).alignment = Alignment(horizontal="left")
for r in range(2, res_ws.max_row + 1):
    res_ws.cell(r, 1).alignment = Alignment(horizontal="left")

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to", out_path)

# Recalculate and handle possible renamed sheets
calc_result = await recalculate(out_path)
print("Recalculate:", calc_result)

wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != ["main sheet", "result"]:
    # rename by position to original names if needed
    for i, expected in enumerate(["main sheet", "result"]):
        wb2.worksheets[i].title = expected
    wb2.save(out_path)
    print("Renamed sheets back:", wb2.sheetnames)

# Verify values after recalculation/data_only
ver = load_workbook(out_path, data_only=True)
print("\nVerified result rows:")
for r in range(1, ver["result"].max_row + 1):
    print(r, [ver["result"].cell(r,c).value for c in range(1,5)])

output_spreadsheet = out_path
