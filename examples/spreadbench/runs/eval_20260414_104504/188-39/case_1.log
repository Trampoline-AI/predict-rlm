import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # headers from first few rows to detect actual header row
    for hr in range(1, min(4, ws.max_row)+1):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column+1)]
        print(f"Row {hr}:", vals)
    # choose likely header as first non-empty row among first 5
    likely_header = None
    for r in range(1, min(6, ws.max_row+1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        nonempty = sum(v is not None and v != "" for v in vals)
        if nonempty >= 2:
            likely_header = r
            break
    print("Likely header row:", likely_header)
    if likely_header:
        headers = [ws.cell(likely_header, c).value for c in range(1, ws.max_column+1)]
        print("Headers:", headers)
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # last 5 rows
    print("Last rows:")
    start = max(1, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Also inspect formulas / non-empty cells in a compact way
for ws in wb.worksheets:
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
    print(f"\nFormula cells in {ws.title}: {formula_cells[:20]} total={len(formula_cells)}")
