from openpyxl import load_workbook
import os, math

outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb = load_workbook(outfile)
orig_sheet_names = ['Sheet1']
ws = wb[orig_sheet_names[0]]

def is_numeric(v):
    return isinstance(v, (int, float)) and not isinstance(v, bool)

def is_whole(v, tol=1e-9):
    return abs(v - round(v)) < tol

# Apply requested number formatting in N, O, P
for row in range(1, ws.max_row + 1):
    for col in [14, 15, 16]:  # N, O, P
        cell = ws.cell(row=row, column=col)
        v = cell.value
        if is_numeric(v):
            cell.number_format = "General" if is_whole(float(v)) else '#,##0.##'

wb.save(outfile)
print("Re-saved with number formats:", outfile)

res = await recalculate(outfile)
print("Recalc:", res)

# Restore names if needed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheet_names:
    print("Restoring sheet names:", wb2.sheetnames, "->", orig_sheet_names)
    for i, name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify target cells/ranges
wbf = load_workbook(outfile, data_only=False)
wbd = load_workbook(outfile, data_only=True)
wsf = wbf[orig_sheet_names[0]]
wsd = wbd[orig_sheet_names[0]]

print("Sheet names final:", wbf.sheetnames)
print("Target headers row 6 N/O/P:", wsf["N6"].value, wsf["O6"].value, wsf["P6"].value)

for r in range(7, 24):
    print(
        r,
        {
            "M": wsd[f"M{r}"].value,
            "N": wsd[f"N{r}"].value,
            "O": wsd[f"O{r}"].value,
            "P": wsd[f"P{r}"].value,
            "N_fmt": wsf[f"N{r}"].number_format,
            "O_fmt": wsf[f"O{r}"].number_format,
            "P_fmt": wsf[f"P{r}"].number_format,
            "N_font": wsf[f"N{r}"].font.name,
            "O_font": wsf[f"O{r}"].font.name,
            "P_font": wsf[f"P{r}"].font.name,
        }
    )

all_fonts_ok = all(cell.font.name == "等线" for row in wsf.iter_rows() for cell in row)
