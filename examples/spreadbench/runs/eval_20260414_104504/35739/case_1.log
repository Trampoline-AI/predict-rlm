Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import numbers
from openpyxl.utils import column_index_from_string
import os, shutil

# Load workbook
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine true last data row based on cols A and B having any data
last_data_row = 1
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 1).value not in (None, "") or ws.cell(r, 2).value not in (None, ""):
        last_data_row = r

print("Detected last data row using columns A/B:", last_data_row)
print("Column C index check:", column_index_from_string("C"))

# Print relevant rows around midnight and tail before modification
for r in [2,3,4,5,8,9,10,last_data_row,last_data_row+1 if last_data_row+1<=ws.max_row else None]:
    if r:
        print("Before", r, [ws.cell(r,c).value for c in range(1,4)])

# Apply corrected formula only to rows with actual data
for r in range(2, last_data_row + 1):
    formula = f'=IF(OR(A{r}="",B{r}=""),"",MOD(B{r}-TIME(0,30,0),1))'
    ws.cell(r, 3).value = formula
    ws.cell(r, 3).number_format = 'hh:mm'

# Clear formulas in trailing blank rows so blank rows stay blank
for r in range(last_data_row + 1, ws.max_row + 1):
    if ws.cell(r,1).value in (None, "") and ws.cell(r,2).value in (None, ""):
        ws.cell(r,3).value = None

# Save to output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position
    for i, old_name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = old_name
    wb2.save(out_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["Sheet1"]
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values["Sheet1"]

print("Verification target header:", [wsf.cell(1,c).value for c in range(1,4)])
for r in [2,3,4,5,8,9,10,last_data_row,last_data_row+1 if last_data_row+1<=ws.max_row else None]:
    if r:
        print(
            "Row", r,
            "A/B:", wsf.cell(r,1).value, wsf.cell(r,2).value,
            "Formula C:", wsf.cell(r,3).value,
            "Value C:", wsv.cell(r,3).value
        )

final_output_path = out_path
```
