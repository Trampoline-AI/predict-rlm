import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Statement"]

first_match = None
for r in range(1, ws.max_row + 1):
    val = ws.cell(r, 1).value
    if val is not None and str(val).strip() == "Invoice No.":
        first_match = r
        break

print("First 'Invoice No.' row in Statement col A:", first_match)
print("Current Statement!A1:", repr(ws["A1"].value))
print("Current target row values:", [ws.cell(first_match, c).value for c in range(1, ws.max_column + 1)])

if first_match is None:
    raise ValueError("Could not find 'Invoice No.' in column A of Statement sheet.")

if first_match > 1:
    ws.delete_rows(1, first_match - 1)

print("After deletion, Statement!A1:A5 row1 values:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # rename by position back to original
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify data_only values
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Statement"]
print("Statement max_row/max_col:", wsv.max_row, wsv.max_column)
print("Statement!A1:E5 after processing:")
for r in range(1, min(5, wsv.max_row) + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, min(5, wsv.max_column) + 1)])

assert wsv["A1"].value == "Invoice No.", f"A1 is not 'Invoice No.': {wsv['A1'].value!r}"
output_spreadsheet = outfile
print("Prepared output:", output_spreadsheet)
