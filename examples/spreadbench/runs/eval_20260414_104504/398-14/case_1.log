```repl
import os, copy
from collections import OrderedDict
from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
print("Sheets:", wb.sheetnames)

# locate collection sheet case-insensitively
collection_name = next(s for s in wb.sheetnames if s.lower() == "collection")
ws = wb[collection_name]
print("Collection sheet actual name:", collection_name)

# Inspect collection details/styles/formulas before editing
print("Collection dimensions:", ws.max_row, ws.max_column)
for r in range(1, ws.max_row + 1):
    print("COLLECTION row", r, [ws.cell(r,c).value for c in range(1, ws.max_column+1)])

print("Collection cell styles snapshot:")
for coord in ["A1","B1","C1","D1","E1","F1","G1","A2","E2","F2","G2","A8","G8"]:
    cell = ws[coord]
    print(coord, {
        "value": cell.value,
        "font": (cell.font.name, cell.font.sz, cell.font.bold, cell.font.color.type if cell.font.color else None, cell.font.color.rgb if cell.font.color and cell.font.color.type=="rgb" else None),
        "align": (cell.alignment.horizontal, cell.alignment.vertical)
    })

# aggregate across all non-collection sheets by (TY, OR)
def numify(v):
    if v is None or v == "" or v == "-":
        return 0.0
    return float(v)

agg = OrderedDict()
for s in wb.sheetnames:
    if s == collection_name:
        continue
    sh = wb[s]
    headers = [sh.cell(1,c).value for c in range(1, sh.max_column+1)]
    hmap = {str(h).strip().upper(): i+1 for i,h in enumerate(headers) if h is not None}
    print("Processing", s, hmap)
    needed = {"TY", "OR"}
    if not needed.issubset(hmap):
        continue
    for r in range(2, sh.max_row+1):
        ty = sh.cell(r, hmap["TY"]).value
        orv = sh.cell(r, hmap["OR"]).value
        if ty in (None, "") and orv in (None, ""):
            continue
        br = sh.cell(r, hmap["BR"]).value if "BR" in hmap else None
        sale = numify(sh.cell(r, hmap["SALE"]).value) if "SALE" in hmap else 0.0
        ret = numify(sh.cell(r, hmap["RET"]).value) if "RET" in hmap else 0.0
        key = (ty, orv)
        if key not in agg:
            agg[key] = {"BR": br, "SALE": 0.0, "RET": 0.0}
        if agg[key]["BR"] in (None, "") and br not in (None, ""):
            agg[key]["BR"] = br
        agg[key]["SALE"] += sale
        agg[key]["RET"] += ret

print("Aggregated keys/results:")
for k,v in agg.items():
    print(k, v, "BAL", v["SALE"] - v["RET"])

# existing collection order
existing_keys = []
for r in range(2, ws.max_row+1):
    ty = ws.cell(r, 3).value
    orv = ws.cell(r, 4).value
    if ty is None and orv is None:
        continue
    existing_keys.append((ty, orv))
print("Existing order:", existing_keys)

# Determine rows to write, preserving original order and appending missing keys
final_keys = existing_keys[:]
for k in agg:
    if k not in final_keys:
        final_keys.append(k)
print("Final order:", final_keys)

# copy style from template rows/cells
header_style = {c: copy.copy(ws.cell(1,c)._style) for c in range(1,8)}
row2_style = {c: copy.copy(ws.cell(2,c)._style) for c in range(1,8)}
num_format_row2 = {c: ws.cell(2,c).number_format for c in range(1,8)}
fill_row2 = {c: copy.copy(ws.cell(2,c).fill) for c in range(1,8)}
border_row2 = {c: copy.copy(ws.cell(2,c).border) for c in range(1,8)}

# rewrite headers exactly
headers = ["ITEM","BR","TY","OR","SALE","RET","BALANCE"]
for c,h in enumerate(headers, start=1):
    cell = ws.cell(1,c)
    cell.value = h
    cell._style = copy.copy(header_style[c])

# write rows
for idx, key in enumerate(final_keys, start=2):
    ty, orv = key
    vals = agg.get(key, {"BR": ws.cell(idx,2).value, "SALE": 0.0, "RET": 0.0})
    br = vals["BR"]
    sale = vals["SALE"]
    ret = vals["RET"]
    bal = sale - ret

    item_cell = ws.cell(idx,1)
    item_cell.value = idx - 1
    for c in range(1,8):
        ws.cell(idx,c)._style = copy.copy(row2_style[c])
        ws.cell(idx,c).fill = copy.copy(fill_row2[c])
        ws.cell(idx,c).border = copy.copy(border_row2[c])
        ws.cell(idx,c).number_format = num_format_row2[c]

    ws.cell(idx,2).value = br
    ws.cell(idx,3).value = ty
    ws.cell(idx,4).value = orv
    ws.cell(idx,5).value = "-" if sale == 0 else sale
    ws.cell(idx,6).value = "-" if ret == 0 else ret
    ws.cell(idx,7).value = "-" if bal == 0 else bal

# clear any extra old rows below final data if present
for r in range(len(final_keys)+2, ws.max_row+1):
    for c in range(1,8):
        ws.cell(r,c).value = None

# apply requested formatting on collection sheet
red_rgb = "FFFF0000"
for r in range(1, len(final_keys)+2):
    for c in range(1,8):
        cell = ws.cell(r,c)
        # all text unbold, Calibri 11
        color = None
        if r > 1 and c == 7 and isinstance(cell.value, (int, float)) and cell.value < 0:
            color = red_rgb
        elif cell.font.color and cell.font.color.type == "rgb":
            color = cell.font.color.rgb
        cell.font = Font(
            name="Calibri",
            size=11,
            bold=False,
            italic=cell.font.italic,
            vertAlign=cell.font.vertAlign,
            underline=cell.font.underline,
            strike=cell.font.strike,
            color=color
        )
        # alignments
        if c in [1,5,6,7]:
            cell.alignment = Alignment(horizontal="right", vertical=cell.alignment.vertical or "bottom")
        else:
            cell.alignment = Alignment(horizontal="left", vertical=cell.alignment.vertical or "bottom")

# header specifically unbold and left aligned
for c in range(1,8):
    ws.cell(1,c).alignment = Alignment(horizontal="left", vertical=ws.cell(1,c).alignment.vertical or "bottom")
    ws.cell(1,c).font = Font(
        name="Calibri",
        size=11,
        bold=False,
        italic=ws.cell(1,c).font.italic,
        vertAlign=ws.cell(1,c).font.vertAlign,
        underline=ws.cell(1,c).font.underline,
        strike=ws.cell(1,c).font.strike,
        color=(ws.cell(1,c).font.color.rgb if ws.cell(1,c).font.color and ws.cell(1,c).font.color.type=="rgb" else None)
    )

# save
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# recalc, then ensure sheet names preserved
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames:
    # rename by index back to originals
    for i, expected in enumerate(wb.sheetnames):
        wb_after.worksheets[i].title = expected
    wb_after.save(out_path)
    print("Renamed sheets back to original names")

# verify with data_only
verify = load_workbook(out_path, data_only=True)
vws = verify[collection_name if collection_name in verify.sheetnames else next(s for s in verify.sheetnames if s.lower()=="collection")]
print("Verified final collection rows:")
for r in range(1, vws.max_row+1):
    print(r, [vws.cell(r,c).value for c in range(1,8)])

# also verify style-critical cells from non-data workbook
style_wb = load_workbook(out_path)
sws = style_wb[collection_name if collection_name in style_wb.sheetnames else next(s for s in style_wb.sheetnames if s.lower()=="collection")]
for coord in ["A1","E1","G1","A2","B2","E2","F2","G2","A9","G9"]:
    cell = sws[coord]
    print(coord, {
        "value": cell.value,
        "font": (cell.font.name, cell.font.sz, cell.font.bold, cell.font.color.type if cell.font.color else None, cell.font.color.rgb if cell.font.color and cell.font.color.type=="rgb" else None),
        "align": cell.alignment.horizontal
    })

output_spreadsheet = out_path
