orig_sheetnames = wb.sheetnames[:]
print("Sheet names:", orig_sheetnames)

def sheet_info(ws):
    rows = ws.max_row
    cols = ws.max_column
    header1 = [ws.cell(1,c).value for c in range(1, cols+1)]
    header2 = [ws.cell(2,c).value for c in range(1, cols+1)] if rows >= 2 else []
    print(f"\n=== Sheet: {ws.title} ===")
    print(f"max_row={rows}, max_col={cols}")
    print("Row1 headers/values:", header1)
    if rows >= 2:
        print("Row2 values:", header2)
    sample_first = list(range(1, min(rows, 10)+1))
    sample_last = list(range(max(1, rows-4), rows+1))
    sample_rows = []
    for r in sample_first + [x for x in sample_last if x not in sample_first]:
        vals = [ws.cell(r,c).value for c in range(1, cols+1)]
        sample_rows.append((r, vals))
    print("Sample rows:")
    for r, vals in sample_rows:
        print(r, vals)

for ws in wb.worksheets:
