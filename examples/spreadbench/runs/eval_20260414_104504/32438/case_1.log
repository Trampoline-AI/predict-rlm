Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before modification:")
for r in range(2, ws.max_row + 1):
    print(r, "I", ws[f"I{r}"].value, ws[f"I{r}"].number_format, "| J", ws[f"J{r}"].value, ws[f"J{r}"].number_format)

# Replace existing broken formulas in J with time-extraction formula
for r in range(2, ws.max_row + 1):
    if ws[f"I{r}"].value is not None:
        ws[f"J{r}"] = f"=MOD(I{r},1)"
        ws[f"J{r}"].number_format = "hh:mm:ss AM/PM"

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Check/restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames:
    for idx, old_name in enumerate(original_sheetnames):
        wb2.worksheets[idx].title = old_name
    wb2.save(outfile)
    print("Restored sheet names:", original_sheetnames)

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formulas in target cells after save:")
for r in range(2, wsf.max_row + 1):
    print(f"J{r} formula:", wsf[f'J{r}'].value, "format:", wsf[f'J{r}'].number_format)

# Verify evaluated values
wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals["Sheet1"]
print("Evaluated target cells:")
for r in range(2, wsv.max_row + 1):
    print(f"I{r}={wsv[f'I{r}'].value!r}, J{r}={wsv[f'J{r}'].value!r}")

output_spreadsheet = outfile
```
