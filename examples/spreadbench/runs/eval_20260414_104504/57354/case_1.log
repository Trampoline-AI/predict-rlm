import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

outfile = output_spreadsheet
# reload original output file fresh from original input to avoid damaged formulas
shutil.copy2(input_spreadsheet, outfile)

wb = load_workbook(outfile)
ws = wb[wb.sheetnames[0]]

last_col = ws.max_column
end_col = get_column_letter(last_col)
print("Using bounded detail range F:%s" % end_col)
print("Current headers F:U:", [ws.cell(2,c).value for c in range(6, last_col+1)])

# write SUMPRODUCT formulas over actual detail range only
d_formula = f'=SUMPRODUCT(($F$2:${end_col}$2="REVENUE")*($F3:${end_col}3))'
e_formula = f'=SUMPRODUCT(($F$2:${end_col}$2="GP")*($F3:${end_col}3))'
ws["D3"] = d_formula
ws["E3"] = e_formula
wb.save(outfile)

print("Written D3:", d_formula)
print("Written E3:", e_formula)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# verify formulas and values
wbf = load_workbook(outfile, data_only=False)
wsf = wbf[wbf.sheetnames[0]]
print("Stored formulas:", wsf["D3"].value, wsf["E3"].value)

wbd = load_workbook(outfile, data_only=True)
wsd = wbd[wbd.sheetnames[0]]
print("Cached values D3/E3:", wsd["D3"].value, wsd["E3"].value)
print("D11/E11:", wsd["D11"].value, wsd["E11"].value)

# fallback to literal if still not evaluated
if wsd["D3"].value in (None, 0) or wsd["E3"].value in (None, 0):
    revenue = sum((ws.cell(3,c).value or 0) for c in range(6, last_col+1) if ws.cell(2,c).value == "REVENUE")
    gp = 0
    for c in range(6, last_col+1):
        if ws.cell(2,c).value == "GP":
            v = ws.cell(3,c).value
            if isinstance(v, (int,float)):
                gp += v
            elif isinstance(v, str) and v.startswith("="):
                col = get_column_letter(c)
                if col == "I":
                    gp += (ws["H3"].value or 0) - (ws["F3"].value or 0)
                elif col == "Q":
                    gp += (ws["P3"].value or 0) - (ws["N3"].value or 0)
                elif col == "U":
                    gp += (ws["T3"].value or 0) - (ws["R3"].value or 0)
    print("Fallback literal values:", revenue, gp)
    wb = load_workbook(outfile)
    ws = wb[wb.sheetnames[0]]
    ws["D3"] = revenue
    ws["E3"] = gp
    wb.save(outfile)
    wbd2 = load_workbook(outfile, data_only=True)
    wsd2 = wbd2[wbd2.sheetnames[0]]
    print("After fallback D3/E3:", wsd2["D3"].value, wsd2["E3"].value)
