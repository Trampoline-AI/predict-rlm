import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify current target values before writing
print("Before write formulas:", [ws[cell].value for cell in ["A6", "B6", "C6"]])

target_formulas = {
    "A6": "=COUNTBLANK(A3:C3)",
    "B6": "=COUNTBLANK(D3:F3)",
    "C6": "=COUNTBLANK(G3:I3)",
}

for cell, formula in target_formulas.items():
    current = ws[cell].value
    if current != formula:
        ws[cell] = formula

print("After write formulas:", [ws[cell].value for cell in ["A6", "B6", "C6"]])

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    for idx, old_name in enumerate(orig_sheetnames):
        wb_check.worksheets[idx].title = old_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify cached results
wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals[orig_sheetnames[0]]
print("Verified formulas cached values A6:C6:", [ws_vals[cell].value for cell in ["A6", "B6", "C6"]])
print("Source row 3 groups:",
      [ws_vals["A3"].value, ws_vals["B3"].value, ws_vals["C3"].value],
      [ws_vals["D3"].value, ws_vals["E3"].value, ws_vals["F3"].value],
      [ws_vals["G3"].value, ws_vals["H3"].value, ws_vals["I3"].value])
```
