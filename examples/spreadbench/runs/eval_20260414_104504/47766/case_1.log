import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find probable used range and headers
    for r in range(1, min(ws.max_row, 8) + 1):
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"Row {r}:", vals)
    # sample first 10 and last 5 rows for first 12 cols
    rows_to_show = list(range(1, min(ws.max_row, 10)+1))
    tail_start = max(1, ws.max_row-4)
    for r in range(tail_start, ws.max_row+1):
        if r not in rows_to_show:
            rows_to_show.append(r)
    print("Sample rows:")
    for r in rows_to_show:
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"{r}: {vals}")
    # search formulas
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
    print("Formula cells count:", len(formula_cells))
    print("First 20 formula cells:", formula_cells[:20])

for ws in wb.worksheets:
    sheet_info(ws)
