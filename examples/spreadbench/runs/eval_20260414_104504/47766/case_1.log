import os, shutil
from datetime import datetime, timedelta
from collections import defaultdict
from openpyxl import load_workbook

src = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src))

def excel_date_to_dt(v):
    if isinstance(v, datetime):
        return v
    if isinstance(v, (int, float)):
        return datetime(1899, 12, 30) + timedelta(days=float(v))
    return None

# Load formula workbook for structure and value workbook for cached numbers
wb = load_workbook(src)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

wbv = load_workbook(src, data_only=True)
wsv = wbv[orig_sheetnames[0]]

ranges = {
    "Rentals": (8, 37),
    "Sales": (41, 58),
    "Commercial": (62, 74),
}
agents = {
    "PE": "PE",
    "GF": "GS",   # existing formulas indicate GF section corresponds to GS token
    "CC": "CC",
}
years = [2021, 2022, 2023, 2024, 2025]

totals = defaultdict(lambda: defaultdict(dict))
details = defaultdict(lambda: defaultdict(dict))

for agent_label, token in agents.items():
    for section, (start, end) in ranges.items():
        for year in years:
            total = 0
            rows = []
            for r in range(start, end + 1):
                amt = wsv.cell(r, 3).value
                dt = excel_date_to_dt(ws.cell(r, 6).value)
                agent_val = ws.cell(r, 8).value
                if dt is None or agent_val is None:
                    continue
                if token in str(agent_val) and datetime(year, 1, 1) <= dt < datetime(year + 1, 1, 1):
                    total += amt or 0
                    rows.append((r, amt, dt.date().isoformat(), agent_val))
            totals[agent_label][section][year] = total
            details[agent_label][section][year] = rows

print("Computed totals:")
for a in ["PE", "GF", "CC"]:
    for s in ["Rentals", "Sales", "Commercial"]:
        print(a, s, [totals[a][s][y] for y in years])

# Map target rows
target_rows = {
    ("PE", "Rentals"): 40,
    ("PE", "Sales"): 41,
    ("PE", "Commercial"): 42,
    ("GF", "Rentals"): 45,
    ("GF", "Sales"): 46,
    ("GF", "Commercial"): 47,
    ("CC", "Rentals"): 50,
    ("CC", "Sales"): 51,
    ("CC", "Commercial"): 52,
}

# Print current target values before overwrite
print("\nCurrent target cells K:O before writing:")
for key, row in target_rows.items():
    print(row, key, [ws.cell(row, col).value for col in range(11, 16)])

# Write literal values into K:O
for (agent_label, section), row in target_rows.items():
    for idx, year in enumerate(years, start=11):  # K=11 ... O=15
        ws.cell(row, idx).value = totals[agent_label][section][year]

# Save
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename by position back to originals
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify output with data_only
wb_out = load_workbook(out_path, data_only=True)
ws_out = wb_out[orig_sheetnames[0]]

print("\nVerified target cells K:O after recalc (data_only=True):")
for (agent_label, section), row in target_rows.items():
    vals = [ws_out.cell(row, col).value for col in range(11, 16)]
    print(row, agent_label, section, vals)

# Also print year header rows to confirm alignment
for r in [43, 48, 53]:
    print("Header row", r, [ws_out.cell(r, c).value for c in range(10, 16)])

final_output_path = out_path
```
