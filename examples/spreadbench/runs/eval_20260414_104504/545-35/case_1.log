for r in range(3, 21):
    for c in range(21, 36):
        cell = ws.cell(r, c)
        v = cell.value
        if v is None or v == "":
            continue
        keep = False
        if isinstance(v, (int, float)):
            keep = True
        elif isinstance(v, str) and re.fullmatch(r"\d+(\.\d+)?", v.strip()):
            keep = True
        if not keep:
            changed.append((cell.coordinate, v, 0))
            cell.value = 0

