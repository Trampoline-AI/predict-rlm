from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Inspecting target column C formulas/values and sample pattern")
for r in range(4, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    print(r, "A", a, "B", b, "C", c, "type(C)", type(c).__name__)

# compute expected rolling 7-day totals in Python for all data rows
print("\nPython-computed rolling totals (inclusive current date, previous 6 days):")
computed = {}
for r in range(4, ws.max_row + 1):
    date_r = ws[f"A{r}"].value
    pts_r = ws[f"B{r}"].value
    if date_r is None:
        continue
    total = 0
    for rr in range(4, ws.max_row + 1):
        d = ws[f"A{rr}"].value
        p = ws[f"B{rr}"].value
        if d is not None and p is not None:
            delta = (date_r.date() - d.date()).days
            if 0 <= delta <= 6:
                total += p
    computed[r] = total
    print(r, date_r.date(), total)

print("\nCompare existing examples in C:")
for r in range(4, 12):
    print(r, "existing", ws[f'C{r}'].value, "computed", computed.get(r))

# write formulas only into missing target cells in column C for data rows with dates
for r in range(4, ws.max_row + 1):
    if ws[f"A{r}"].value is None:
        continue
    current_c = ws[f"C{r}"].value
    if current_c is None:
        ws[f"C{r}"] = f'=SUMIFS($B$4:$B${ws.max_row},$A$4:$A${ws.max_row},">="&A{r}-6,$A$4:$A${ws.max_row},"<="&A{r})'

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to", out_path)

res = await recalculate(out_path)
print("Recalculate:", res)

# restore sheet names if needed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# verify data_only results
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("\nVerified target cells C12:C19:")
for r in range(12, 20):
    print(r, vws[f"A{r}"].value, vws[f"B{r}"].value, vws[f"C{r}"].value)

output_spreadsheet = out_path
