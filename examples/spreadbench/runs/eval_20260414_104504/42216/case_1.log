# Verify key target cells in Group B
key_rows = [19, 22, 23, 49, 50, 54, 95, 109, 200, 261]
for r in key_rows:
    print("B verify", r, wsv.cell(r,1).value, wsv.cell(r,2).value)

# Sanity checks on known special cases
# Feb 29-31 should be blank because source has -99999/M/-99999
for r in [78,79,80]:  # 1951-02-29/30/31 rows in continuous date list
