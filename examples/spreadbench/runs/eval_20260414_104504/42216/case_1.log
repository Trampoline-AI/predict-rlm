import os, shutil
from datetime import datetime
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target area before writing
print("Before write - row 3:8 col A:AF first few:")
for r in range(3, 9):
    print(r, [ws.cell(r,c).value for c in range(1, 8)])

print("Group B header area:")
for r in range(17, 22):
    print(r, [ws.cell(r,c).value for c in range(1, 3)])

# Insert April row before current May row if not already present
months = [ws.cell(r, 1).value for r in range(3, 20)]
if "1951-04" not in months:
    # Find insertion point before 1951-05
    insert_at = None
    for r in range(3, ws.max_row + 1):
        if ws.cell(r, 1).value == "1951-05":
            insert_at = r
            break
    if insert_at is None:
        raise ValueError("Could not find 1951-05 row to insert April before.")
    ws.insert_rows(insert_at, 1)
    ws.cell(insert_at, 1).value = "1951-04"
    # For April row, keep zeros as blanks => initialize all day columns blank
    for c in range(2, 33):
        ws.cell(insert_at, c).value = None
    april_row = insert_at
else:
    april_row = next(r for r in range(3, ws.max_row + 1) if ws.cell(r,1).value == "1951-04")
    # Ensure April row blank for day columns if zeros were present
    for c in range(2, 33):
        if ws.cell(april_row, c).value == 0:
            ws.cell(april_row, c).value = None

print("April row index:", april_row)
print("April row values A:G:", [ws.cell(april_row,c).value for c in range(1,8)])

# Build month lookup after insertion
month_to_row = {}
for r in range(3, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and len(v) == 7 and v[4] == "-":
        month_to_row[v] = r

# Populate Group B Data column B
written_preview = []
for r in range(19, ws.max_row + 1):
    dt = ws.cell(r, 1).value
    if not isinstance(dt, datetime):
        continue
    ym = dt.strftime("%Y-%m")
    day = dt.day
    out_cell = ws.cell(r, 2)

    if ym == "1951-04":
        out_val = 0
    else:
        src_row = month_to_row.get(ym)
        if src_row is None:
            out_val = None
        else:
            src = ws.cell(src_row, day + 1).value
            if src in (-9999, -99999, "M"):
                out_val = None
            elif src == "NA":
                out_val = None
            elif src is None or src == "":
                out_val = 0
            else:
                out_val = src

    out_cell.value = out_val
    if len(written_preview) < 20:
        written_preview.append((r, dt.date().isoformat(), out_val))

print("Preview written rows:", written_preview[:10], "... total preview", len(written_preview))

wb.save(outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    while len(wb2.worksheets) == len(orig_sheetnames) and wb2.sheetnames != orig_sheetnames:
        for i, name in enumerate(orig_sheetnames):
            wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verification with data_only
check = load_workbook(outfile, data_only=True)
wsv = check["Sheet1"]

print("Verified sheet names:", check.sheetnames)

# Verify April row in Group A
for r in range(3, 9):
