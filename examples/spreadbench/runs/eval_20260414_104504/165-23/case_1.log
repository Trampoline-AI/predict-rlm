import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Modify workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Delete from bottom to top; keep row 1 blank and keep only rows with C == #N/A error
rows_deleted = []
for r in range(ws.max_row, 1, -1):
    row_has_any = any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1))
    if not row_has_any:
        continue
    c = ws.cell(r, 3)
    keep = (c.data_type == 'e' and c.value == '#N/A')
    if not keep:
        ws.delete_rows(r, 1)
        rows_deleted.append(r)

wb.save(outfile)
print("Saved modified file:", outfile)
print("Deleted rows count:", len(rows_deleted))

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename by position back to original names
    for ws_obj, orig_name in zip(wb_check.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify output with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify["Sheet1"]
print("Verified Sheet1 max_row/max_col:", vws.max_row, vws.max_column)

# Print all remaining nonblank rows in Sheet1
remaining = []
for r in range(1, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, min(vws.max_column, 8) + 1)]
    if any(v is not None for v in vals):
        remaining.append((r, vals, vws.cell(r, 3).value))

print("Remaining nonblank rows in Sheet1:", len(remaining))
for item in remaining:
    print(item)

# Extra exact checks
print("A1:N1 blank?", all(vws.cell(1, c).value is None for c in range(1, vws.max_column + 1)))
print("Remaining IDs:", [vws.cell(r, 1).value for r in range(2, vws.max_row + 1) if vws.cell(r, 1).value is not None])

output_spreadsheet = outfile
