desired2 = wb["Desired Sheet1 after delrow2"]

def row_values(ws, r, max_cols=8):
    return [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols)+1)]

# Inspect desired delrow2 thoroughly
