from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from itertools import combinations
import os, math

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
before = wb["Before"]
after = wb["After"]

# Inspect the relevant highlighted cells and sum
highlight_coords = []
for row in after.iter_rows():
    for cell in row:
        fill = cell.fill
        rgb = None
        if fill and fill.fill_type == "solid":
            rgb = fill.fgColor.rgb or fill.start_color.rgb
        if rgb and rgb not in ("00000000", "000000", "FFFFFFFF", "00FFFFFF", None):
            highlight_coords.append(cell.coordinate)

highlight_values = [(coord, after[coord].value) for coord in highlight_coords]
highlight_sum = sum(v for _, v in highlight_values if isinstance(v, (int, float)))
print("After highlighted coords/values:", highlight_values)
print("Sum of highlighted values:", highlight_sum)

# Brute force all subsets to find sums in target range
vals = [before[f"A{r}"].value for r in range(1, before.max_row + 1)]
coords = [f"A{r}" for r in range(1, before.max_row + 1)]

solutions = []
n = len(vals)
for mask in range(1, 1 << n):
    s = 0
    chosen = []
    for i in range(n):
        if mask & (1 << i):
            s += vals[i]
            chosen.append(coords[i])
    if 994108 <= s <= 994112:
        solutions.append((s, chosen))

print("Number of solutions in [994108,994112]:", len(solutions))
print("Solutions:", solutions[:10])

# Apply requested modifications
if "Sheet3" in wb.sheetnames:
    del wb["Sheet3"]

green_fill = PatternFill(start_color="FF00FF00", end_color="FF00FF00", fill_type="solid")

# Clear existing fills in Before A1:A16, then fill chosen combo
for r in range(1, before.max_row + 1):
    before[f"A{r}"].fill = PatternFill(fill_type=None)

# Determine combination to use: from exact solution search if unique, otherwise match After pattern
if len(solutions) == 1:
    target_sum, chosen_coords = solutions[0]
else:
    chosen_coords = highlight_coords
    target_sum = highlight_sum

for coord in chosen_coords:
    before[coord].fill = green_fill

before["C2"] = target_sum

# Save
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if needed
orig_names = ["Before", "After"]
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    # rename first two sheets back if recalc changed locale names
    for ws, expected in zip(wb2.worksheets, orig_names):
        ws.title = expected
    # remove any extra Sheet3 if somehow present
    if "Sheet3" in wb2.sheetnames:
        del wb2["Sheet3"]
    wb2.save(out_path)
    print("Renamed sheets back:", wb2.sheetnames)

# Verification using data_only for value in C2, and normal mode for fills
wb_val = load_workbook(out_path, data_only=True)
wb_fmt = load_workbook(out_path)
print("Verified sheets:", wb_val.sheetnames)

b_val = wb_val["Before"]
b_fmt = wb_fmt["Before"]
print("Before!C2 value:", b_val["C2"].value)

verified_fills = []
for coord in chosen_coords:
    cell = b_fmt[coord]
    rgb = None
    if cell.fill and cell.fill.fill_type == "solid":
        rgb = cell.fill.fgColor.rgb or cell.fill.start_color.rgb
    verified_fills.append((coord, b_val[coord].value, rgb))
print("Verified chosen fills on Before:", verified_fills)
print("Sheet3 exists?", "Sheet3" in wb_val.sheetnames)

output_spreadsheet = out_path
