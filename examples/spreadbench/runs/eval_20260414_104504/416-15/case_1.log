Code:
```repl
import os, shutil
from datetime import datetime
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original workbook for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Identify exact target rows in column A
targets = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(r, 1).value
    if isinstance(val, str) and "T" in val and val.endswith("Z"):
        targets.append((r, val))
print("Target rows in column A:", targets)

# Modify only target cells
for r, val in targets:
    date_part = val.split("T", 1)[0].strip()
    dt = datetime.strptime(date_part, "%Y-%m-%d")
    cell = ws.cell(r, 1)
    cell.value = dt
    cell.number_format = "m/dd/yyyy"

# Also ensure existing date cells in column A use requested display format, but do not alter header
for r in range(2, ws.max_row + 1):
    cell = ws.cell(r, 1)
    if isinstance(cell.value, datetime):
        cell.number_format = "m/dd/yyyy"

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for old, new in zip(orig_sheet_names, wb_check.sheetnames):
        wb_check[new].title = old
    wb_check.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[orig_sheet_names[0]]

print("Verified target cells after save/recalc (data_only):")
for r in range(2, wsv.max_row + 1):
    print(f"A{r} =", wsv.cell(r,1).value)

# Verify display formats from formula workbook
wb_fmt = load_workbook(output_path)
wsf = wb_fmt[orig_sheet_names[0]]
print("Verified formats A2:A19:")
for r in range(2, wsf.max_row + 1):
    c = wsf.cell(r,1)
    print(f"A{r}: value={c.value!r}, number_format={c.number_format!r}")

final_output_path = output_path
```
