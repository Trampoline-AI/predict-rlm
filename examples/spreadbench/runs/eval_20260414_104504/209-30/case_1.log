import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))
os.makedirs(outdir, exist_ok=True)
shutil.copy(infile, outfile)

# Load and modify
wb = load_workbook(outfile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Data to Import"]

# determine true last non-empty row in column C
last_nonempty = None
for r in range(ws.max_row, 1, -1):
    v = ws.cell(r, 3).value
    if v not in (None, ""):
        last_nonempty = r
        break

print("Target sheet:", ws.title)
print("Target column:", "C")
print("Last non-empty row in C:", last_nonempty)

# print a few before values
before_samples = [2,3,4,5,6, max(2, last_nonempty-2), max(2, last_nonempty-1), last_nonempty]
before_seen = []
for r in before_samples:
    if 2 <= r <= last_nonempty and r not in before_seen:
        before_seen.append(r)
print("Before samples:")
for r in before_seen:
    print(r, repr(ws.cell(r, 3).value))

# Apply transformation only to non-empty rows
changed = 0
for r in range(2, last_nonempty + 1):
    cell = ws.cell(r, 3)
    val = cell.value
    if val in (None, ""):
        continue
    sval = str(val)
    newval = sval[:-3] if len(sval) >= 3 else ""
    if newval != sval:
        cell.value = newval
        changed += 1

wb.save(outfile)
print("Changed rows:", changed)
print("Saved:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    # rename sheets back by position
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Restored sheet names:", wb_check.sheetnames)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verification with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", wb_verify.sheetnames)
wsv = wb_verify["Data to Import"]

print("After samples:")
for r in before_seen:
    print(r, repr(wsv.cell(r, 3).value))

# verify last rows beyond extent remain blank
print("Rows around boundary:")
for r in range(max(2, last_nonempty-2), min(wsv.max_row, last_nonempty+3)+1):
    print(r, repr(wsv.cell(r,3).value))

output_spreadsheet = outfile
