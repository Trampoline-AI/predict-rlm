import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Build lookup from Basic Table: (stock, year) -> log value from H/G/I
lookup = {}
for r in range(3, ws.max_row + 1):
    year = ws.cell(r, 7).value   # G
    stock = ws.cell(r, 8).value  # H
    logv = ws.cell(r, 9).value   # I
    if stock is not None and year is not None:
        lookup[(stock, year)] = logv

# Fill requested table C based on A/B, preserving already-correct values
changes = []
for r in range(3, ws.max_row + 1):
    stock = ws.cell(r, 1).value  # A
    year = ws.cell(r, 2).value   # B
    cur = ws.cell(r, 3).value    # C
    if stock is None and year is None:
        continue
    src = lookup.get((stock, year), None)
    new_val = 0 if (src is None or src == "") else src
    # only fill blanks; preserve existing nonblank values
    if cur is None or cur == "":
        ws.cell(r, 3).value = new_val
        changes.append((r, stock, year, new_val))

wb.save(outfile)
print("Saved to:", outfile)
print("Changes made:", changes)

# recalculate
result = await recalculate(outfile)
print("Recalculate:", result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    for i, sname in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = sname
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[orig_sheetnames[0]]
verified = []
for r in range(3, wsv.max_row + 1):
    verified.append((r, wsv.cell(r,1).value, wsv.cell(r,2).value, wsv.cell(r,3).value))
print("Verified requested table A:C rows 3:19")
for row in verified:
    print(row)

output_spreadsheet = outfile
```
