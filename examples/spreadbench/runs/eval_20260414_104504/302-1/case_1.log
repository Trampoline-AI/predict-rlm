import os, shutil
from openpyxl import load_workbook

# Re-open to inspect exact target cells/formulas and then modify
wb = load_workbook(input_spreadsheet)
print("Original sheet names:", wb.sheetnames)

for s in ["SHEET1", "SHEET2"]:
    ws = wb[s]
    print(f"\nInspecting target column B in {s}:")
    for r in range(1, ws.max_row + 1):
        cell = ws.cell(r, 2)
        print(r, repr(cell.value), "data_type=", cell.data_type)

# Compare with expected result sheets
for src, res in [("SHEET1", "result sheet1"), ("SHEET2", "result sheet2")]:
    print(f"\nComparing {src} to {res}:")
    ws_src = wb[src]
    ws_res = wb[res]
    for r in range(1, min(ws_src.max_row, ws_res.max_row) + 1):
        print(r, "src:", repr(ws_src.cell(r,2).value), "| expected:", repr(ws_res.cell(r,2).value))

items_ws = wb["ITEMS"]
items_b = {r: items_ws.cell(r, 2).value for r in range(1, items_ws.max_row + 1)}

changes = {}
for s in ["SHEET1", "SHEET2"]:
    ws = wb[s]
    changes[s] = []
    last_row = min(ws.max_row, items_ws.max_row)
    for r in range(2, last_row + 1):  # skip header
        current = ws.cell(r, 2).value
        target = items_b.get(r)
        if current != target:
            changes[s].append((r, current, target))
            ws.cell(r, 2).value = target

for s, ch in changes.items():
    print(f"\nApplied changes in {s}: {len(ch)}")
    for rownum, old, new in ch:
        print(f"B{rownum}: {old!r} -> {new!r}")

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    for idx, expected in enumerate(orig_sheet_names):
        wb_check.worksheets[idx].title = expected
    wb_check.save(out_path)
    print("Restored sheet names:", load_workbook(out_path).sheetnames)
else:
    print("Sheet names preserved.")

# Verification with data_only
wb_verify = load_workbook(out_path, data_only=True)
print("\nVerified sheet names:", wb_verify.sheetnames)

for s in ["SHEET1", "SHEET2"]:
    ws = wb_verify[s]
    print(f"\nFinal values in {s} column B:")
    for r in range(1, ws.max_row + 1):
        print(f"B{r} =", repr(ws.cell(r,2).value))

# Compare final outputs against ITEMS and expected result sheets
for s, res in [("SHEET1", "result sheet1"), ("SHEET2", "result sheet2")]:
    ws = wb_verify[s]
    res_ws = wb_verify[res]
    print(f"\nVerification against ITEMS and {res}:")
    ok = True
    for r in range(2, ws.max_row + 1):
        val = ws.cell(r,2).value
        item_val = wb_verify["ITEMS"].cell(r,2).value if r <= wb_verify["ITEMS"].max_row else None
        res_val = res_ws.cell(r,2).value if r <= res_ws.max_row else None
        print(r, repr(val), "| ITEMS:", repr(item_val), "| expected:", repr(res_val))
        if val != item_val or val != res_val:
            ok = False
    print("PASS" if ok else "FAIL")

output_spreadsheet = out_path
