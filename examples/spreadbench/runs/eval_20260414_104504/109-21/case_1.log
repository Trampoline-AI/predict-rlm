import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

def row_nonempty(ws, r, cols=24):
    return any(ws.cell(r, c).value not in (None, "") for c in range(1, cols+1))

# actual non-empty rows from row 5 onward
nonempty_rows = [r for r in range(5, ws.max_row+1) if row_nonempty(ws, r, 24)]
print("Non-empty row count from row 5:", len(nonempty_rows))
print("First 15 non-empty rows:", nonempty_rows[:15])
print("Last 15 non-empty rows:", nonempty_rows[-15:])

# contiguous blocks/groups
groups = []
r = 5
while r <= ws.max_row:
    if row_nonempty(ws, r, 24):
        start = r
        rows = []
        while r <= ws.max_row and row_nonempty(ws, r, 24):
            rows.append(r)
            r += 1
        end = rows[-1]
        groups.append((start, end, rows))
    r += 1

print("Total groups:", len(groups))
print("First 12 group summaries:")
for start, end, rows in groups[:12]:
    names = [ws.cell(rr, 1).value for rr in rows]
    kvals = [ws.cell(rr, 11).value for rr in rows]
    print({"start": start, "end": end, "size": len(rows), "names": names, "K": kvals})

print("Last 8 group summaries:")
for start, end, rows in groups[-8:]:
    names = [ws.cell(rr, 1).value for rr in rows]
    kvals = [ws.cell(rr, 11).value for rr in rows]
    print({"start": start, "end": end, "size": len(rows), "names": names, "K": kvals})

# check current Z values for target rows
for col in [25, 26]:
    print(f"Column {get_column_letter(col)} existing values on first 20 data rows:",
          [(r, ws.cell(r, col).value) for r in nonempty_rows[:20]])

# perform write to Z
for start, end, rows in groups:
    kvals = [ws.cell(rr, 11).value for rr in rows]
    numeric = [float(v) for v in kvals if v not in (None, "")]
    if not numeric:
        # if no K values at all, leave blank
        for rr in rows:
            ws.cell(rr, 26).value = None
        continue
    maxk = max(numeric)
    for rr in rows:
        v = ws.cell(rr, 11).value
        if v in (None, ""):
            ws.cell(rr, 26).value = "N"
        else:
            ws.cell(rr, 26).value = "Y" if float(v) == maxk else "N"

# ensure blank rows remain blank in Z
for r in range(1, ws.max_row+1):
    if not row_nonempty(ws, r, 24):
        ws.cell(r, 26).value = None

# save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# recalculate and restore sheet names if needed
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    # rename back by position
    for i, orig_name in enumerate(wb.sheetnames):
        wb2.worksheets[i].title = orig_name
    wb2.save(out_path)
    print("Renamed sheets back to original:", wb.sheetnames)

# verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver[wb.sheetnames[0]]
print("Verification first 12 groups:")
for start, end, rows in groups[:12]:
    print([(rr, vws.cell(rr,1).value, vws.cell(rr,11).value, vws.cell(rr,26).value) for rr in rows])

print("Verification last 8 groups:")
for start, end, rows in groups[-8:]:
    print([(rr, vws.cell(rr,1).value, vws.cell(rr,11).value, vws.cell(rr,26).value) for rr in rows])

output_spreadsheet = out_path
