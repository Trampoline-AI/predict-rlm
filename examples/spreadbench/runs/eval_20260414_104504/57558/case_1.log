import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INSTRUCTION:")
print(instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

def visible_rows(ws, n_first=8, n_last=5, max_cols=20):
    rows = list(ws.iter_rows(values_only=True))
    total = len(rows)
    first = rows[:n_first]
    last = rows[-n_last:] if total > n_last else []
    return first, last

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)]
        print("Row2 values:", headers2)
    first, last = visible_rows(ws)
    print("First rows:")
    for i, row in enumerate(first, start=1):
        print(i, row)
    if last:
        print("Last rows:")
        start_idx = ws.max_row - len(last) + 1
        for i, row in enumerate(last, start=start_idx):
            print(i, row)
    # print formulas in used range
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print(f"Found {len(formulas)} formulas")
    for item in formulas[:30]:
        print(" formula", item)

