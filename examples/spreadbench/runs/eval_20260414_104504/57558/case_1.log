import os, shutil
from openpyxl import load_workbook

# Re-open and verify exact target/matches before writing
wb = load_workbook(input_spreadsheet)
ws_dep = wb["Deposits"]
ws_rate = wb["RateHurdles"]

# Determine actual non-empty last row in RateHurdles across A:E
last_rate_row = 1
for r in range(1, ws_rate.max_row + 1):
    vals = [ws_rate.cell(r, c).value for c in range(1, 6)]
    if any(v is not None for v in vals):
        last_rate_row = r
print("RateHurdles effective last row:", last_rate_row)

# Print current target cells and corresponding criteria
for r in range(2, ws_dep.max_row + 1):
    print(f"Before Deposits!A{r} =", ws_dep[f"A{r}"].value,
          "| criteria:", ws_dep[f"B{r}"].value, ws_dep[f"C{r}"].value, ws_dep[f"D{r}"].value)

# Verify intended lookup result in Python
for r in range(2, ws_dep.max_row + 1):
    sale_type = ws_dep[f"B{r}"].value
    sp = ws_dep[f"C{r}"].value
    dep_date = ws_dep[f"D{r}"].value
    matches = []
    for rr in range(2, last_rate_row + 1):
        start = ws_rate[f"A{rr}"].value
        end = ws_rate[f"B{rr}"].value
        t = ws_rate[f"C{rr}"].value
        s = ws_rate[f"D{rr}"].value
        rate = ws_rate[f"E{rr}"].value
        if start is not None and end is not None and t == sale_type and s == sp and start <= dep_date <= end:
            matches.append((rr, rate))
    print(f"Python matches for Deposits row {r}:", matches)

# Write formulas to exact target column A
for r in range(2, ws_dep.max_row + 1):
    formula = (
        f'=SUMIFS(RateHurdles!$E$2:$E${last_rate_row},'
        f'RateHurdles!$C$2:$C${last_rate_row},B{r},'
        f'RateHurdles!$D$2:$D${last_rate_row},C{r},'
        f'RateHurdles!$A$2:$A${last_rate_row},"<="&D{r},'
        f'RateHurdles!$B$2:$B${last_rate_row},">="&D{r})'
    )
    ws_dep[f"A{r}"] = formula
    print(f"Wrote Deposits!A{r} formula:", formula)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
orig_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore sheet names if needed
wb_post = load_workbook(out_path)
if wb_post.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb_post.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = name
    wb_post.save(out_path)

# Verify after recalc with data_only=True
wb_val = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)
ws_val = wb_val["Deposits"]
for r in range(2, ws_val.max_row + 1):
    print(f"After recalc Deposits!A{r} =", ws_val[f'A{r}'].value)

output_file = out_path
