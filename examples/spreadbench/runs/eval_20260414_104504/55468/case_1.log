import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    headers2 = [ws.cell(2,c).value for c in range(1, ws.max_column+1)] if ws.max_row >= 2 else []
    print("Row1:", headers1)
    if headers2:
        print("Row2:", headers2)
    sample_rows = list(range(1, min(ws.max_row,10)+1))
    if ws.max_row > 10:
        sample_rows += list(range(max(1, ws.max_row-4), ws.max_row+1))
    seen=set()
    for r in sample_rows:
        if r in seen: 
            continue
        seen.add(r)
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"R{r}:", vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# print formulas / non-empty cells in used range
for ws in wb.worksheets:
    print(f"\nFormulas/non-empty scan for {ws.title}:")
    found = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if v is not None:
                if isinstance(v, str) and v.startswith("="):
                    found.append((r,c,v))
    print("Formula cells:", found[:50], "count=", len(found))
