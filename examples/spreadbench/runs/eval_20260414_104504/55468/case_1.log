import os, shutil
from openpyxl import load_workbook

# Re-open fresh workbook for modification
wb2 = load_workbook(input_spreadsheet)
ws = wb2["Sheet1"]

# Verify expected lookup manually from sample criteria
grade = ws["AE4"].value
flute = ws["AD4"].value
qty = ws["AB4"].value
prefix = ws["AC4"].value
print("Lookup inputs:", {"grade": grade, "flute": flute, "qty": qty, "prefix": prefix})

# Find matching row and column in Python for sanity
row_match = None
for r in range(5, 11):
    if ws.cell(r, 1).value == grade and ws.cell(r, 2).value == flute:
        row_match = r
        break
print("Matched row:", row_match)

col_match = None
for c in range(3, 27):
    if ws.cell(3, c).value == qty and ws.cell(4, c).value == prefix:
        col_match = c
        break
print("Matched col:", col_match, "letter", get_column_letter(col_match) if col_match else None)
print("Expected value from table:", ws.cell(row_match, col_match).value if row_match and col_match else None)

# Show existing target formula exactly
old = ws["AE5"].value
if hasattr(old, "text"):
    print("Old AE5 formula:", old.text)
else:
    print("Old AE5 raw:", old)

new_formula = '=INDEX(C$5:Z$10,MATCH(1,INDEX((AE4=A$5:A$10)*(AD4=B$5:B$10),0),0),MATCH(1,INDEX((AC4=C$4:Z$4)*(AB4=C$3:Z$3),0),0))'
ws["AE5"] = new_formula
print("New AE5 formula:", ws["AE5"].value)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb2.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore sheet names if changed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != ["Sheet1"]:
    # rename first sheet back if needed
    if len(wb_check.sheetnames) == 1:
        wb_check[wb_check.sheetnames[0]].title = "Sheet1"
        wb_check.save(out_path)
    else:
        for i, name in enumerate(wb_check.sheetnames):
            wb_check[name].title = ["Sheet1"][i] if i < 1 else name
        wb_check.save(out_path)

# Verify with data_only
