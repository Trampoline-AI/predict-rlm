from openpyxl import load_workbook
from datetime import datetime, date
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Inspect holiday table and date matches more precisely
print("Headers A:J:", [ws.cell(1,c).value for c in range(1,11)])

holiday_rows = []
for r in range(2, ws.max_row + 1):
    hname = ws.cell(r, 8).value
    hdate = ws.cell(r, 9).value
    htype = ws.cell(r, 10).value
    if any(v not in (None, "") for v in (hname, hdate, htype)):
        holiday_rows.append((r, hname, hdate, htype))
print("Holiday rows count:", len(holiday_rows))
print("First 15 holiday rows:")
for x in holiday_rows[:15]:
    print(x)
print("Last 10 holiday rows:")
for x in holiday_rows[-10:]:
    print(x)

main_rows = []
for r in range(2, ws.max_row + 1):
    dt = ws.cell(r, 1).value
    if dt not in (None, ""):
        main_rows.append((r, dt, ws.cell(r,5).value))
print("Main data row count:", len(main_rows))
print("First 10 main rows:", main_rows[:10])
print("Last 5 main rows:", main_rows[-5:])

def norm_date(v):
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    return None

holiday_map = {}
for r, hname, hdate, htype in holiday_rows:
    nd = norm_date(hdate)
    if nd:
        holiday_map[nd] = htype

matches = []
nonmatches = []
for r, dt, cur in main_rows:
    nd = norm_date(dt)
    if nd in holiday_map:
        matches.append((r, nd.isoformat(), holiday_map[nd]))
    else:
        nonmatches.append((r, nd.isoformat()))
print("Matching main dates to holidays:", len(matches))
print("Matches:", matches[:20])
print("Some nonmatches:", nonmatches[:10])

# Write WORKDAY column E
day_map = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
for r, dt, cur in main_rows:
    nd = norm_date(dt)
    if nd in holiday_map:
        ws.cell(r, 5).value = holiday_map[nd]
    else:
        ws.cell(r, 5).value = day_map[nd.weekday()]

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and restore sheet name if needed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Restored sheet names to", orig_names)

# Verify output values
ver = load_workbook(out_path, data_only=True)
vws = ver[orig_names[0]]
print("Verify E header:", vws["E1"].value)
for r in list(range(2, 12)) + [holiday_rows[0][0], holiday_rows[3][0], 50, 71, 75]:
    print(r, vws.cell(r,1).value, "->", vws.cell(r,5).value)

# Check all target cells nonblank where date exists
blanks = []
for r, dt, _ in main_rows:
    if vws.cell(r,5).value in (None, ""):
        blanks.append(r)
print("Blank WORKDAY cells:", blanks[:20], "count", len(blanks))

output_spreadsheet = out_path
