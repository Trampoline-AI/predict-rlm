import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def nonempty_row_count(ws):
    last = 0
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            last = r
    return last

for s in wb.sheetnames:
    ws = wb[s]
    last_row = nonempty_row_count(ws)
    headers1 = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    headers2 = [ws.cell(2,c).value for c in range(1, ws.max_column+1)] if ws.max_row >= 2 else []
    print("\n--- SHEET:", s, "---")
    print("max_row/max_col:", ws.max_row, ws.max_column, "last_nonempty_row:", last_row)
    print("Row1:", headers1)
    print("Row2:", headers2)
    sample_rows = list(range(1, min(last_row, 10)+1))
    if last_row > 10:
        sample_rows += list(range(max(1, last_row-4), last_row+1))
    seen = set()
    for r in sample_rows:
        if r in seen: 
            continue
        seen.add(r)
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", vals)

    # print cells with formulas in first 20 rows
    formulas = []
    for r in range(1, min(last_row, 20)+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append(f"{get_column_letter(c)}{r}={v}")
    print("Formulas in first 20 rows:", formulas[:20])

    # likely date/holiday/workday columns
    for c in range(1, ws.max_column+1):
        col_vals = [ws.cell(r,c).value for r in range(1, min(last_row, 8)+1)]
        header = ws.cell(1,c).value
        print(f"Col {get_column_letter(c)} header={header!r} sample={col_vals}")
