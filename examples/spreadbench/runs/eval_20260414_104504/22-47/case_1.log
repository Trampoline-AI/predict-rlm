import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["sheet1"]

# Read helper names from J, excluding header/blank, preserving first occurrence only
helper_names = []
helper_seen = set()
for r in range(1, ws.max_row + 1):
    v = ws[f"J{r}"].value
    if v is None:
        continue
    s = str(v).strip()
    if not s or s.upper() == "LIST":
        continue
    if s not in helper_seen:
        helper_seen.add(s)
        helper_names.append(s)

# Read valid source rows from A:C, skip repeated headers/blanks, dedupe by (B,C)
valid_rows = []
seen_keys = set()
for r in range(1, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    bs = "" if b is None else str(b).strip()
    cs = "" if c is None else str(c).strip()
    if bs == "" or cs == "":
        continue
    if bs.upper() == "NAME" or cs.upper() == "REF":
        continue
    key = (bs, cs)
    if key in seen_keys:
        continue
    seen_keys.add(key)
    valid_rows.append((a, bs, c, key))

# Build output order
if helper_names:
    ordered = []
    used = set()
    for name in helper_names:
        for row in valid_rows:
            if row[1] == name and row[3] not in used:
                ordered.append(row)
                used.add(row[3])
    for row in valid_rows:
        if row[3] not in used:
            ordered.append(row)
            used.add(row[3])
else:
    ordered = sorted(valid_rows, key=lambda x: (x[1].upper(), str(x[2])))

print("Helper names:", helper_names)
print("Valid rows:", [(r[0], r[1], r[2]) for r in valid_rows])
print("Ordered rows:", [(r[0], r[1], r[2]) for r in ordered])

# Clear existing output area F:H below header across used range
for r in range(2, ws.max_row + 1):
    for c in range(6, 9):  # F:H
        ws.cell(r, c).value = None

# Ensure headers remain as expected in F:H row 1
ws["F1"] = "ITEM"
ws["G1"] = "NAME"
ws["H1"] = "REF"

# Write ordered output to F:H from row 2
out_row = 2
for a, b, c, key in ordered:
    ws.cell(out_row, 6).value = a
    ws.cell(out_row, 7).value = b
    ws.cell(out_row, 8).value = c
    out_row += 1

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb_check.sheetnames, "-> restoring", orig_sheet_names)
    for i, s in enumerate(wb_check.worksheets):
        s.title = orig_sheet_names[i]
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify target output values using data_only
wb_data = load_workbook(outfile, data_only=True)
wsd = wb_data["sheet1"]

print("Verified F:H rows 1 to", out_row + 2)
for r in range(1, min(out_row + 2, 20)):
    print(r, [wsd.cell(r, c).value for c in range(6, 9)])

# Check that stray lower rows were cleared
for r in [11, 12, 13, 194, 195]:
    if r <= wsd.max_row:
        print("Row", r, "F:H =", [wsd.cell(r, c).value for c in range(6, 9)])

final_output_spreadsheet = outfile
