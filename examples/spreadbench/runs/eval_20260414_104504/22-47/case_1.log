import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        print("Header row 2:", row_values(ws, 2, ws.max_column))
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))

    # Print relevant columns B, F:H, J for first/last ranges
