Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Identify all rows where column B contains 1
b1_rows = [r for r in range(1, ws.max_row + 1) if ws.cell(r, 2).value == 1]
print("Rows with B=1:", b1_rows)

# Compute counts between consecutive B=1 rows
computed = {}
prev = None
for r in b1_rows:
    if prev is None:
        computed[r] = None
    else:
        cnt = 0
        for rr in range(prev + 1, r):
            aval = ws.cell(rr, 1).value
            try:
                if aval is not None and float(aval) > 0:
                    cnt += 1
            except Exception:
                pass
        computed[r] = cnt
    prev = r

print("Computed target values for Column C at B=1 rows:")
for r in b1_rows:
    print(f"row {r}: existing C={ws.cell(r,3).value!r}, computed={computed[r]!r}")

# Clear/fill Column C according to instruction:
# - only rows where B=1 may have a value
# - first occurrence remains blank
# - other rows with B=1 get computed count
# - all other rows blank
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 2).value == 1:
        ws.cell(r, 3).value = computed[r]
    else:
        ws.cell(r, 3).value = None

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if recalculation altered them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position back to originals
    for wsx, original_name in zip(wb2.worksheets, orig_sheetnames):
        wsx.title = original_name
    wb2.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verification with data_only
ver = load_workbook(outfile, data_only=True)
print("Verified sheet names:", ver.sheetnames)
vws = ver["Sheet1"]

print("Final Column C values at rows where B=1:")
for r in b1_rows:
    print(r, "A=", vws.cell(r,1).value, "B=", vws.cell(r,2).value, "C=", vws.cell(r,3).value)

print("Check non-B=1 rows around samples:")
for r in [2,3,4,5,7,8,9,11,12,13,14,61,62,64,65]:
    if 1 <= r <= vws.max_row:
        print(r, [vws.cell(r,c).value for c in range(1,4)])
```
