Code:
```repl
import os, re, shutil
from itertools import product
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws_in = wb["Input"]
ws_out = wb["Output"]

# Reconfirm exact target headers/columns
out_headers = [ws_out.cell(1, c).value for c in range(1, ws_out.max_column + 1)]
print("Output headers:", out_headers)

def parse_filter(filter_text):
    result = {}
    if not filter_text:
        return result

    # Equality pattern: ("orgId" = "LIM")
    for key, val in re.findall(r'\("([^"]+)"\s*=\s*"([^"]*)"\)', filter_text):
        result[key] = val

    # IN LIST pattern: ("specialtyId" IN LIST 03,056)
    for key, vals in re.findall(r'\("([^"]+)"\s+IN\s+LIST\s+([^)]+)\)', filter_text):
        items = []
        for x in vals.split(","):
            x = x.strip().strip('"')
            if x == "":
                continue
            # leading zeros can be omitted
            if re.fullmatch(r'\d+', x):
                items.append(int(x))
            else:
                items.append(x)
        result[key] = items
    return result

# Print parse of each input row before writing
parsed_rows = []
for r in range(2, ws_in.max_row + 1):
    base = {
        "wtype_id": ws_in.cell(r, 1).value,
        "name": ws_in.cell(r, 2).value,
        "status": ws_in.cell(r, 3).value,
    }
    filt = ws_in.cell(r, 4).value
    parsed = parse_filter(filt)
    print(f"Input row {r} filter:", filt)
    print(f"Parsed row {r}:", parsed)
    parsed_rows.append((base, parsed))

# Build expanded output rows matching observed pattern
expanded = []
for base, parsed in parsed_rows:
    org = parsed.get("orgId")
    care = parsed.get("careType")
    specialties = parsed.get("specialtyId")
    contexts = parsed.get("contextId")

    if specialties is None:
        specialties_list = [None]
    elif isinstance(specialties, list):
        specialties_list = specialties
    else:
        specialties_list = [specialties]

    if contexts is None:
        contexts_list = [None]
    elif isinstance(contexts, list):
        contexts_list = contexts
    else:
        contexts_list = [contexts]

    for sp, ctx in product(specialties_list, contexts_list):
        expanded.append([
            base["wtype_id"],
            base["name"],
            base["status"],
            org,
            care,
            sp,
            ctx,
        ])

print("Expanded rows count:", len(expanded))
for i, row in enumerate(expanded, start=1):
    print("Expanded", i, row)

# Clear existing Output data rows only (preserve header and sheet)
for r in range(2, ws_out.max_row + 1):
    for c in range(1, ws_out.max_column + 1):
        ws_out.cell(r, c).value = None

# Write expanded rows
for r_idx, row in enumerate(expanded, start=2):
    for c_idx, val in enumerate(row, start=1):
        ws_out.cell(r_idx, c_idx).value = val

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and repair sheet names if necessary
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    # rename by position back to original
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_names)

# Verify with data_only
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv["Output"]
print("Verified Output rows:")
for r in range(1, max(wsv.max_row, len(expanded)+1) + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 8)]
    print(r, vals)
