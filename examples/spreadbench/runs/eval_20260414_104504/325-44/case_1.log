import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws, sample_n=8):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers/values:", headers)
    # also inspect row2 in case headers are there
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row2 sample:", row2)
    # print first 10 rows
    first_end = min(ws.max_row, 10)
    print(f"First {first_end} rows:")
    for r in range(1, first_end + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Print cells with formulas/non-empty in Output to infer pattern
if "Output" in wb.sheetnames:
    ws = wb["Output"]
    print("\nNon-empty cells in Output (up to first 80):")
    count = 0
