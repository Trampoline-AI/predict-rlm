wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify output
verify_wb = load_workbook(out_path, data_only=True)
verify_ws = verify_wb["Result what i am getting"]
print("\nVerified output rows in target sheet:")
for r in range(1, min(verify_ws.max_row, 21) + 1):
    vals = [verify_ws.cell(r, c).value for c in range(1, verify_ws.max_column + 1)]
    print("row", r, vals)

verified_ids = [verify_ws.cell(r, 1).value for r in range(2, verify_ws.max_row + 1) if verify_ws.cell(r, 1).value not in (None, "")]
print("Verified IDs:", verified_ids)
