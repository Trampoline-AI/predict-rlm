import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

path = input_spreadsheet
wb = load_workbook(path)
print("Actual sheet names:", wb.sheetnames)

main_ws = wb["Main unique ID"]
get_ws = wb["Result what i am getting"]
exp_ws = wb["Result what i am expecting "]

# Explicitly inspect IDs and highlighted rows/cells on expecting sheet
main_ids = [main_ws.cell(r, 1).value for r in range(1, main_ws.max_row + 1) if main_ws.cell(r, 1).value not in (None, "")]
get_ids = [get_ws.cell(r, 1).value for r in range(2, get_ws.max_row + 1) if get_ws.cell(r, 1).value not in (None, "")]
exp_ids = [exp_ws.cell(r, 1).value for r in range(2, exp_ws.max_row + 1) if exp_ws.cell(r, 1).value not in (None, "")]
missing_ids = [x for x in main_ids if x not in get_ids]

print("Main IDs:", main_ids)
print("Getting IDs:", get_ids)
print("Expecting IDs:", exp_ids)
print("Missing IDs from getting:", missing_ids)

print("\nExpecting sheet rows with missing IDs:")
for r in range(2, exp_ws.max_row + 1):
    if exp_ws.cell(r, 1).value in missing_ids:
        vals = [exp_ws.cell(r, c).value for c in range(1, exp_ws.max_column + 1)]
        fills = []
        for c in range(1, exp_ws.max_column + 1):
            cell = exp_ws.cell(r, c)
            if cell.fill and cell.fill.fill_type == "solid":
                color = cell.fill.fgColor.rgb or cell.fill.start_color.rgb
                fills.append((cell.coordinate, color))
        print("row", r, vals, "fills:", fills[:5], "fill_count:", len(fills))

# Build current data rows from getting sheet
header = [get_ws.cell(1, c).value for c in range(1, get_ws.max_column + 1)]
current_rows = {}
for r in range(2, get_ws.max_row + 1):
    row_vals = [get_ws.cell(r, c).value for c in range(1, get_ws.max_column + 1)]
    uid = row_vals[0]
    if uid not in (None, ""):
        current_rows[uid] = row_vals

print("\nHeader:", header)
print("Current row count excluding header:", len(current_rows))

# Rewrite the existing 'getting' sheet to match main ID list order, with blank rows for missing IDs
for r in range(2, get_ws.max_row + 1):
    for c in range(1, get_ws.max_column + 1):
        get_ws.cell(r, c).value = None
        get_ws.cell(r, c).fill = PatternFill(fill_type=None)

out_row = 2
yellow = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")

for uid in main_ids:
    row_vals = current_rows.get(uid)
    if row_vals is None:
        row_vals = [uid] + [None] * (get_ws.max_column - 1)
        is_missing = True
    else:
        is_missing = False
    for c, val in enumerate(row_vals, start=1):
        get_ws.cell(out_row, c).value = val
        if is_missing:
            get_ws.cell(out_row, c).fill = yellow
    out_row += 1

# Clear any leftover rows below output
for r in range(out_row, get_ws.max_row + 1):
    for c in range(1, get_ws.max_column + 1):
        get_ws.cell(r, c).value = None
        get_ws.cell(r, c).fill = PatternFill(fill_type=None)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

recalc_result = await recalculate(out_path)
