import os, shutil
from openpyxl import load_workbook

# Reload and inspect any other similar "answer" labels to ensure S10 is the only target
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

hits = []
for row in ws.iter_rows():
    for cell in row:
        if isinstance(cell.value, str) and cell.value and str(cell.value).strip().lower() in {"answer", "starting level", "ending level"}:
            hits.append((cell.coordinate, cell.value))
print("Label hits:", hits)

# Print exact target area again
for r in range(4, 11):
    print(r, [ws.cell(r,c).value for c in range(18,20)])  # R:S

# Write dynamic formula into S10
# Sum values in the column whose row-2 header matches S4
# between rows where column A equals S6 and S8 inclusive.
formula = '=SUM(INDEX($B$3:$P$82,MATCH($S$6,$A$3:$A$82,0),MATCH($S$4,$B$2:$P$2,0)):INDEX($B$3:$P$82,MATCH($S$8,$A$3:$A$82,0),MATCH($S$4,$B$2:$P$2,0)))'
ws["S10"] = formula
print("Written formula to S10:", ws["S10"].value)

# Save output
