import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_nonempty_bounds(ws):
    max_r, max_c = ws.max_row, ws.max_column
    # find actual last non-empty row/col
    last_r = 0
    last_c = 0
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value is not None:
                row_has = True
                last_c = max(last_c, cell.column)
        if row_has:
            last_r = row[0].row
    return last_r or max_r, last_c or max_c

for s in wb.sheetnames:
    ws = wb[s]
    last_r, last_c = sheet_nonempty_bounds(ws)
    print(f"\n=== Sheet: {s} ===")
    print("max_row/max_col:", ws.max_row, ws.max_column, "actual_last:", last_r, last_c)
    headers = [ws.cell(1,c).value for c in range(1, last_c+1)]
    print("Row1 headers/values:", headers)
    if last_r >= 2:
        headers2 = [ws.cell(2,c).value for c in range(1, last_c+1)]
        print("Row2 values:", headers2)
    sample_rows = list(range(1, min(last_r, 10)+1))
    tail_start = max(1, last_r-4)
    tail_rows = list(range(tail_start, last_r+1))
    shown = []
    for r in sample_rows + [x for x in tail_rows if x not in sample_rows]:
        vals = [ws.cell(r,c).value for c in range(1, min(last_c, 12)+1)]
        shown.append((r, vals))
    print("Sample rows (first up to 10 and last 5, first 12 cols):")
    for r, vals in shown:
        print(r, vals)

    # print formulas and nonempty cells in a useful top-left region
    print("Top-left nonempty/formula cells A1:L20:")
    for r in range(1, min(last_r, 20)+1):
        row_items = []
        for c in range(1, min(last_c, 12)+1):
            v = ws.cell(r,c).value
            if v is not None:
                row_items.append(f"{get_column_letter(c)}{r}={v}")
        if row_items:
            print(" | ".join(row_items))
