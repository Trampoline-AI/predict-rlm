```repl
import os, re, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print exact target area before modification
print("Pre-modification column B values:")
for r in range(1, ws.max_row + 1):
    print(r, repr(ws.cell(r, 2).value))

paren_pat = re.compile(r"\(([^()]*)\)")

changes = []
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 2)
    val = cell.value
    if val is None:
        continue
    if isinstance(val, str):
        if val == "":
            continue
        m = paren_pat.search(val)
        new_val = m.group(1) if m else val
        if new_val != val:
            changes.append((r, val, new_val))
            cell.value = new_val

print("\nPlanned/applied changes:")
for item in changes:
    print(item)
print("Total changed:", len(changes))

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate as required
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and ensure sheet names unchanged; if not, rename back and save once
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[orig_sheetnames[0]]
print("\nVerified column B values after save/recalc:")
for r in range(1, wsv.max_row + 1):
    print(r, repr(wsv.cell(r, 2).value))

# Basic assertions/sanity checks
assert wsv["B3"].value == "tig"
assert wsv["B5"].value == "tib"
assert wsv["B13"].value is None
assert wsv["B21"].value == "tig"

output_spreadsheet = outfile
print("\nOutput ready:", output_spreadsheet)
```
