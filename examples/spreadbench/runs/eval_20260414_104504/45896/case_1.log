import os, shutil
from collections import defaultdict
from datetime import datetime
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load source workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Volym P5_P6_2023"]
z = wb["ZORD"]

# Build grouped unique formatted dates from ZORD column C by material in column A
dates_by_material = defaultdict(list)
seen_by_material = defaultdict(set)

for r in range(2, z.max_row + 1):
    material = z.cell(r, 1).value
    dt = z.cell(r, 3).value
    if material is None or dt in (None, ""):
        continue
    if isinstance(dt, datetime):
        s = dt.strftime("%d/%m/%Y")
    else:
        s = str(dt).strip()
    if s and s not in seen_by_material[material]:
        seen_by_material[material].add(s)
        dates_by_material[material].append(s)

# Print current and planned values for exact target cells
print("Before writing I2:I10:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"A{r}"].value, ws[f"I{r}"].value)

# Write joined date strings into existing column I only
for r in range(2, ws.max_row + 1):
    material = ws.cell(r, 1).value
    joined = ", ".join(dates_by_material.get(material, []))
    ws.cell(r, 9).value = joined

print("\nAfter writing I2:I10 (in-memory):")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"A{r}"].value, ws[f"I{r}"].value)

# Save
wb.save(outfile)
wb.close()

# Recalculate
recalc_result = await recalculate(outfile)
print("\nRecalculate result:", recalc_result)

# Reload and restore original sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    for i, expected in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = expected
    wb2.save(outfile)
    wb2.close()
else:
    wb2.close()

# Verify output with data_only
verify = load_workbook(outfile, data_only=True)
print("\nVerified sheet names:", verify.sheetnames)
vws = verify["Volym P5_P6_2023"]
print("Verified target cells I2:I10:")
for r in range(2, vws.max_row + 1):
    print(f"I{r} =", repr(vws[f"I{r}"].value))
verify.close()

output_spreadsheet = outfile
```
