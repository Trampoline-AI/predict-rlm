        print("Row 2:")
        print(row_values(ws, 2, ws.max_column))
    
    # Print columns with letters
    col_map = [(get_column_letter(c), ws.cell(1, c).value) for c in range(1, ws.max_column+1)]
    print("Columns:", col_map)
    
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, ws.max_column))
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r, ws.max_column))
    
    # detect formulas / filled cells in later columns
    formula_cells = []
    nonempty_counts = []
    for c in range(1, ws.max_column+1):
        count = 0
        for r in range(1, ws.max_row+1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                count += 1
