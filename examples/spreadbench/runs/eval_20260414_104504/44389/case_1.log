ws = wb[wb.sheetnames[0]]

print("Target columns check:")
for c in range(1, ws.max_column + 1):
    print(c, get_column_letter(c), ws.cell(1, c).value)

print("\nInspect O/P cells and O formulas:")
for r in range(2, ws.max_row + 1):
    o = ws[f"O{r}"].value
    p = ws[f"P{r}"].value
    o_repr = o.text if hasattr(o, "text") else o
    print(r, "O=", o_repr, "P=", p)

# Determine exact output column: use existing header "Seller" in P
print("\nHeader O1:", ws["O1"].value, "Header P1:", ws["P1"].value)
print("Writing seller/header result to column P based on row minimum > 0 across B:N.")

# LibreOffice-compatible formula using TEXTJOIN with _xlfn prefix.
# It returns headers where row value equals the minimum positive value in B:N.
for r in range(2, ws.max_row + 1):
    # only write for actual data rows with product name present
    if ws.cell(r, 1).value not in (None, ""):
        formula = (
            f'=_xlfn.TEXTJOIN(",",TRUE,'
            f'IF((B{r}:N{r}>0)*(B{r}:N{r}=MIN(IF(B{r}:N{r}>0,B{r}:N{r}))),B$1:N$1,""))'
        )
        ws[f"P{r}"] = formula
        print(f"P{r} <- {formula}")

