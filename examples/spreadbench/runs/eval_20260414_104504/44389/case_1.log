                    formula_cells.append((f"{get_column_letter(c)}{r}", v))
        nonempty_counts.append((get_column_letter(c), headers[c-1], count))
    print("Non-empty counts by column:")
    print(nonempty_counts)
    print("Sample formula cells:")
    print(formula_cells[:20])
