from openpyxl import load_workbook
import os, math

# Reload original workbook and compute literal outputs to avoid formula incompatibility
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

price_cols = list(range(2, 15))  # B:N

def to_num(v):
    if v in (None, ""):
        return None
    if isinstance(v, (int, float)):
        return float(v)
    try:
        s = str(v).strip()
        if s == "":
            return None
        return float(s)
    except:
        return None

print("Recomputing O (min price > 0) and P (seller header(s)) as literal values.")
for r in range(2, ws.max_row + 1):
    product = ws.cell(r, 1).value
    row_pairs = []
    for c in price_cols:
        header = ws.cell(1, c).value
        val = to_num(ws.cell(r, c).value)
        row_pairs.append((c, header, val))
    positives = [(c, h, v) for c, h, v in row_pairs if v is not None and v > 0]
    if product not in (None, "") and positives:
        min_val = min(v for _, _, v in positives)
        sellers = [h for _, h, v in positives if abs(v - min_val) < 1e-9]
        ws.cell(r, 15).value = min_val  # O
        ws.cell(r, 16).value = ",".join(sellers)  # P
        print(r, product, "min=", min_val, "seller=", ",".join(sellers))
    elif product not in (None, ""):
        ws.cell(r, 15).value = None
        ws.cell(r, 16).value = None
        print(r, product, "no positive values")

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved:", out_path)

# recalc and restore sheet names if needed
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

wb_check = load_workbook(out_path)
if wb_check.sheetnames != orig_names:
    print("Restoring sheet names:", wb_check.sheetnames, "->", orig_names)
    for i, nm in enumerate(orig_names):
        wb_check.worksheets[i].title = nm
    wb_check.save(out_path)

# verify
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_names[0]]
print("\nVerified target cells O2:P{}:".format(wsv.max_row))
for r in range(2, wsv.max_row + 1):
    print(r, wsv[f"A{r}"].value, "O=", wsv[f"O{r}"].value, "P=", wsv[f"P{r}"].value)

output_spreadsheet = out_path
```
