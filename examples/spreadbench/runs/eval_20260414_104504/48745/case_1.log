Code:
```repl
from openpyxl import load_workbook
import os, shutil

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Build lookup from G:H
lookup = {}
for r in range(5, ws.max_row + 1):
    code = ws[f"G{r}"].value
    grp = ws[f"H{r}"].value
    if code is not None and grp is not None:
        lookup[str(code).strip()] = str(grp).strip()

print("Lookup map:", lookup)

def compute_group(cell_value):
    if cell_value is None:
        return None
    s = str(cell_value).strip()
    if not s:
        return None
    parts = [p.strip() for p in s.split(";") if p is not None and str(p).strip() != ""]
    groups = []
    for p in parts:
        g = lookup.get(p)
        if g and g not in groups:
            groups.append(g)
    # sort by numeric suffix if present, else text
    def sort_key(g):
        import re
        m = re.search(r'(\d+)', g)
        return (0, int(m.group(1))) if m else (1, g)
    groups = sorted(groups, key=sort_key)
    return ", ".join(groups) if groups else None

print("Current and expected D values:")
for r in range(5, ws.max_row + 1):
    cval = ws[f"C{r}"].value
    dval = ws[f"D{r}"].value
    exp = compute_group(cval)
    print(r, "C=", cval, "D current=", dval, "expected=", exp)

# Fill/adjust column D for all rows with input in C
changes = []
for r in range(5, ws.max_row + 1):
    cval = ws[f"C{r}"].value
    if cval is None or str(cval).strip() == "":
        continue
    exp = compute_group(cval)
    cur = ws[f"D{r}"].value
    if cur != exp:
        ws[f"D{r}"] = exp
        changes.append((r, cur, exp))

print("Changes to write:", changes)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and restore sheet names if changed
orig_names = ["Sheet1"]
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for ws_obj, name in zip(wb2.worksheets, orig_names):
        ws_obj.title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify output values with data_only
verify_wb = load_workbook(out_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb["Sheet1"]
print("Verification D5:D10:")
for r in range(5, 11):
    print(r, "C=", vws[f"C{r}"].value, "D=", vws[f"D{r}"].value)

output_spreadsheet = out_path
```
