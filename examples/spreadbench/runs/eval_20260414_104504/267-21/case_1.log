import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
print("Original sheet names:", wb.sheetnames)

# Build lookup maps from SH1 and RP1: ID -> QTY
lookup = {}
for sname in ["SH1", "RP1"]:
    ws = wb[sname]
    id_to_qty = {}
    for r in range(2, ws.max_row + 1):
        _id = ws.cell(r, 2).value
        qty = ws.cell(r, 3).value
        id_to_qty[_id] = qty
    lookup[sname] = id_to_qty
    print(sname, "lookup:", id_to_qty)

wsm = wb["merging"]

# Verify target cells before writing
print("Before writing, merging C:D rows 2-11:")
for r in range(2, wsm.max_row + 1):
    print(r, wsm.cell(r,2).value, "| C:", wsm.cell(r,3).value, "| D:", wsm.cell(r,4).value)

# Fill columns C and D based on ID in column B
for r in range(2, wsm.max_row + 1):
    key = wsm.cell(r, 2).value
    val_c = lookup["SH1"].get(key, "-")
    val_d = lookup["RP1"].get(key, "-")
    if val_c in (None, ""):
        val_c = "-"
    if val_d in (None, ""):
        val_d = "-"
    wsm.cell(r, 3).value = val_c
    wsm.cell(r, 4).value = val_d

wb.save(outfile)
print("Saved to", outfile)

rec = await recalculate(outfile)
print("Recalculate:", rec)

# Reload and ensure sheet names preserved
wb2 = load_workbook(outfile, data_only=False)
if wb2.sheetnames != ["SH1", "RP1", "merging"]:
    print("Sheet names changed after recalc:", wb2.sheetnames)
    current = wb2.sheetnames[:]
    # rename by position back to originals
    for i, desired in enumerate(["SH1", "RP1", "merging"]):
        wb2[current[i]].title = desired
    wb2.save(outfile)
    print("Renamed sheets back:", wb2.sheetnames)

# Verify output values
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["merging"]
print("Verified merging rows 1-11 cols A:D:")
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 5)])

output_spreadsheet = outfile
