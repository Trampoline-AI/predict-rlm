wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames
print("Sheet names:", orig_sheetnames)

def sheet_info(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\n--- Sheet: {ws.title} rows={max_row} cols={max_col}")
    print("Headers row1:", headers)
    # print first 10 rows and last 5 rows
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, max_col+1)]
    first_end = min(max_row, 10)
    print("First rows:")
    for r in range(1, first_end+1):
        print(r, row_vals(r))
    if max_row > 10:
        print("Last rows:")
        for r in range(max(1, max_row-4), max_row+1):
            print(r, row_vals(r))

for ws in wb.worksheets:
