import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import numbers

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws_t = wb["Transactions"]
ws_y = wb["2022"]

# Determine bounded source range based on actual transaction extent
start_row = 3
end_row = ws_t.max_row
print("Transactions source rows:", start_row, "to", end_row)

# Verify current target area before modification
print("Current income section B5:M8 before write:")
for r in range(5, 9):
    print(r, [ws_y.cell(r, c).value for c in range(1, 15)])

# Write formulas to exact target cells: income section monthly cells B5:M8
for r in range(5, 9):
    category_ref = f"$A{r}"
    for c in range(2, 14):  # B:M
        month_ref = f"{ws_y.cell(3, c).coordinate}"
        cell = ws_y.cell(r, c)
        formula = (
            f'=IFERROR(SUMIFS(Transactions!$C${start_row}:$C${end_row},'
            f'Transactions!$A${start_row}:$A${end_row},{month_ref},'
            f'Transactions!$D${start_row}:$D${end_row},{category_ref}),0)'
        )
        cell.value = formula
        cell.number_format = numbers.FORMAT_CURRENCY_USD_SIMPLE

# Also format income totals row/column as currency, preserving formulas
for r in range(5, 10):
    ws_y.cell(r, 14).number_format = numbers.FORMAT_CURRENCY_USD_SIMPLE
for c in range(2, 15):
    ws_y.cell(9, c).number_format = numbers.FORMAT_CURRENCY_USD_SIMPLE

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verification using formulas workbook
wbf = load_workbook(outfile, data_only=False)
wsyf = wbf["2022"]
print("\nWritten formulas in income section B5:M8:")
for r in range(5, 9):
    print(r, [wsyf.cell(r, c).value for c in range(2, 14)])

# Verification using data_only workbook after recalculation
wbd = load_workbook(outfile, data_only=True)
wsyd = wbd["2022"]
print("\nVerified cached values A5:N9:")
for r in range(5, 10):
    print(r, [wsyd.cell(r, c).value for c in range(1, 15)])

# Verify key expected values from sample data
print("\nKey checks:")
for coord in ["D7", "E7", "N7", "D8", "E8", "N8"]:
    print(coord, "=", wsyd[coord].value)
print("Number format B5:", wsyf["B5"].number_format, "D7:", wsyf["D7"].number_format, "N7:", wsyf["N7"].number_format)

output_spreadsheet = outfile
