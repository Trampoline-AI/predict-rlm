import os, shutil, re
from openpyxl import load_workbook

# Re-open and inspect target cells/formulas explicitly
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Target column header B1:", ws["B1"].value)
for r in range(2, ws.max_row + 1):
    print(f"Row {r}: A{r}={ws[f'A{r}'].value!r} | B{r}={ws[f'B{r}'].value!r} | B{r}_type={type(ws[f'B{r}'].value).__name__}")

# Fill only blanks in existing target column B using LibreOffice-compatible formula
for r in range(2, ws.max_row + 1):
    source = ws.cell(r, 1).value
    target = ws.cell(r, 2)
    if isinstance(source, str) and "Collection-" in source and (target.value is None or target.value == ""):
        # Extract text after Collection- up to comma, or to end if no comma exists
        target.value = f'=TRIM(LEFT(MID(A{r},FIND("Collection-",A{r})+11,999),IFERROR(FIND(",",MID(A{r},FIND("Collection-",A{r})+11,999))-1,LEN(MID(A{r},FIND("Collection-",A{r})+11,999)))) )'

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_names = ["Sheet1"]
if wb_after.sheetnames != orig_names and len(wb_after.sheetnames) == len(orig_names):
    for old, new in zip(wb_after.sheetnames, orig_names):
        wb_after[old].title = new
    wb_after.save(out_path)
    print("Renamed sheets back to:", wb_after.sheetnames)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["Sheet1"]
print("Verification target cells:")
for r in range(2, wsv.max_row + 1):
    print(f"B{r} -> {wsv[f'B{r}'].value!r}")

output_file = out_path
