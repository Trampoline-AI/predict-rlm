import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Munka1"]

# Build source mapping from A:B
sources = []
for r in range(2, ws.max_row + 1):
    sid = ws.cell(r, 1).value
    comment = ws.cell(r, 2).value
    if sid not in (None, "") and comment not in (None, ""):
        sources.append((r, str(sid), str(comment)))

print("Sources:", sources)

written = []
for r in range(2, ws.max_row + 1):
    p1 = ws.cell(r, 5).value
    p2 = ws.cell(r, 6).value
    target = ws.cell(r, 7)
    current = target.value
    if p1 not in (None, "") and p2 not in (None, ""):
        p1s, p2s = str(p1), str(p2)
        matches = [(sr, sid, cmt) for sr, sid, cmt in sources if p1s in cmt and p2s in cmt]
        found = matches[0][1] if matches else None
        if current in (None, ""):
            target.value = found
        written.append((r, p1s, p2s, current, found, matches))
    else:
        written.append((r, p1, p2, current, None, []))

wb.save(outfile)
print("Written summary:")
for item in written:
    print(item)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheet_names)
    # rename by position
    for i, orig_name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = orig_name
    wb2.save(outfile)

# Verification after recalc/data_only
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv["Munka1"]
print("Verify target cells G1:G7 and row context A:G:")
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 8)]
    print(r, vals)

output_spreadsheet = outfile
print("Output file ready:", output_spreadsheet)
```
