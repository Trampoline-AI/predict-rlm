import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet4"]
cb = wb["CBtrans"]

# determine true used rows
def last_used_row(ws):
    last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            last = r
    return last

cb_last = last_used_row(cb)

# build 3-way key set from CBtrans: company + account + xchar
keys = set()
for r in range(2, cb_last + 1):
    company = cb.cell(r, 1).value
    account = cb.cell(r, 8).value
    xchar = cb.cell(r, 11).value
    if isinstance(account, str):
        account = account.strip()
    keys.add((company, account, xchar))

pink_fill = PatternFill(start_color="FF66CC", end_color="FF66CC", fill_type="solid")

results_written = {}
for r in range(2, 8):
    company = ws.cell(r, 2).value
    account = ws.cell(r, 9).value
    xchar = ws.cell(r, 5).value
    if isinstance(account, str):
        account = account.strip()
    result = "Match" if (company, account, xchar) in keys else "-"
    ws.cell(r, 11).value = result
    ws.cell(r, 11).fill = pink_fill
    results_written[f"K{r}"] = result

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, desired in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = desired
    wb2.save(outfile)

# verify values and fills
verify_wb = load_workbook(outfile, data_only=False)
verify_ws = verify_wb["Sheet4"]
print("Verified sheet names:", verify_wb.sheetnames)
for r in range(2, 8):
    cell = verify_ws[f"K{r}"]
    print(f"K{r}:", cell.value, "fill=", cell.fill.fgColor.rgb, "fill_type=", cell.fill.fill_type)

output_spreadsheet = outfile
```
