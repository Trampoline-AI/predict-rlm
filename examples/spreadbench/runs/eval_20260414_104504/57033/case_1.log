import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row1 headers/values:", headers)
    # also inspect row2 in case headers start there
    if ws.max_row >= 2:
        print("Row2 values:", row_values(ws, 2, ws.max_column))
    # first 8 rows
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end+1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row-4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r, ws.max_column))

# inspect the referenced sheet closely
target_sheet = wb["Sheet 4"] if "Sheet 4" in wb.sheetnames else wb[wb.sheetnames[3]]
ws = target_sheet
print("\n=== Detailed inspect target sheet:", ws.title, "===")
for r in range(1, min(ws.max_row, 12)+1):
    vals = []
    for c in range(1, min(ws.max_column, 14)+1):
        cell = ws.cell(r,c)
        vals.append(f"{get_column_letter(c)}{r}={cell.value}")
    print(" | ".join(vals))

print("\nK2:K7 current values/formulas:")
for r in range(2,8):
    cell = ws[f"K{r}"]
    print(f"K{r}:", cell.value)

print("\nNearby cells A1:N10 formulas/values:")
for r in range(1, min(ws.max_row, 10)+1):
    row = []
    for c in range(1, min(ws.max_column, 14)+1):
        v = ws.cell(r,c).value
        row.append(v)
    print(r, row)
