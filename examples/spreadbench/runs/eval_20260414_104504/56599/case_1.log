import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and inspect target before writing
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheetnames:", original_sheetnames)
print("Target cells before writing:")
for coord in ["B2", "M5", "G5", "H5", "J5"]:
    print(coord, "=", ws[coord].value)

# Write the requested formula into B2.
# Blank input -> not found message
# No matching slip range -> not found message
# Otherwise return BookNo from J based on slip range G:H
formula_b2 = '=IF(M5="","not found - please re-enter",IF(COUNTIFS($G$6:$G$30,"<="&M5,$H$6:$H$30,">="&M5)=0,"not found - please re-enter",SUMPRODUCT(($G$6:$G$30<=M5)*($H$6:$H$30>=M5)*$J$6:$J$30)))'
ws["B2"] = formula_b2

print("B2 formula written:", ws["B2"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open and restore sheet names if LibreOffice changed them
wb_after = load_workbook(outfile)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for i, old_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)
    print("Restored sheetnames to:", original_sheetnames)

# Verification: formula workbook + data_only workbook
wbf = load_workbook(outfile, data_only=False)
wbd = load_workbook(outfile, data_only=True)
wsf = wbf[original_sheetnames[0]]
wsd = wbd[original_sheetnames[0]]

print("VERIFY formula B2:", wsf["B2"].value)
print("VERIFY cached value B2 with blank M5:", wsd["B2"].value)
print("VERIFY M5:", wsd["M5"].value)

# Additional sanity checks with temporary test values, then revert to blank
# to ensure formula behaves correctly; do this in memory only, not save.
