```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Before writing, A/B sample rows 1-10:")
for r in range(1, 11):
    print(r, ws.cell(r,1).value, ws.cell(r,2).value)

written = 0
for r in range(2, ws.max_row + 1):
    val = ws.cell(r, 1).value
    target = ws.cell(r, 2)
    if val is None or str(val).strip() == "":
        continue
    s = str(val).strip()
    # preserve already-populated plausible values
    if target.value not in (None, ""):
        continue
    digits = "".join(ch for ch in s if ch.isdigit())
    if len(digits) == 9 and digits.startswith("0"):
        ymd = digits[1:]
        formatted = f"{ymd[:4]} {ymd[4:6]} {ymd[6:8]}"
    elif len(digits) == 8:
        formatted = f"{digits[:4]} {digits[4:6]} {digits[6:8]}"
    else:
        formatted = s
    target.value = formatted
    written += 1

print("Rows written:", written)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for i, old in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = old
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verification with data_only
wb_ver = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_ver.sheetnames)
wsv = wb_ver[orig_sheetnames[0]]

print("Verify target cells B2:B10:")
for r in range(2, 11):
    print(f"A{r}={wsv.cell(r,1).value!r}, B{r}={wsv.cell(r,2).value!r}")

print("Verify last 5 written rows:")
for r in range(wsv.max_row - 4, wsv.max_row + 1):
    print(f"A{r}={wsv.cell(r,1).value!r}, B{r}={wsv.cell(r,2).value!r}")

output_spreadsheet = outfile
```
