Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]

changes = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and '"' in v:
                new_v = v.replace('"', '')
                changes.append((ws.title, cell.coordinate, v, new_v))
                cell.value = new_v

print("Planned/applied changes:", changes)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# restore sheet names if recalculation/localization changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != original_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", original_sheetnames)
    for ws, original_name in zip(wb2.worksheets, original_sheetnames):
        ws.title = original_name
    wb2.save(outfile)

# verify with formulas resolved / cached values
ver = load_workbook(outfile, data_only=True)
print("Verified sheet names:", ver.sheetnames)
for ws in ver.worksheets:
    print("Sheet:", ws.title, "size:", ws.max_row, ws.max_column)
    for coord in ["A1", "A2", "A3", "A4"]:
        print(coord, ws[coord].value)

output_spreadsheet = outfile
```
