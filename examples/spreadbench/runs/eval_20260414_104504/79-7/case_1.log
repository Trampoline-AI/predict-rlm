    quoted = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and '"' in v:
                quoted.append((r, c, v))
                if len(quoted) >= 20:
                    break
        if len(quoted) >= 20:
            break
    print("Sample cells containing double quotes (up to 20):")
    for r, c, v in quoted:
        print(f"{get_column_letter(c)}{r} = {v!r}")
    total_quoted = 0
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and '"' in v:
