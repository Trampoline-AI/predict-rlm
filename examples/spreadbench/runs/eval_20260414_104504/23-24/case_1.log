import os, shutil
from openpyxl import load_workbook

# Re-open fresh source workbook for modification
src_path = input_spreadsheet
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(src_path))

wb2 = load_workbook(src_path)
ws = wb2[wb2.sheetnames[0]]
original_sheetnames = wb2.sheetnames[:]

# Build lists and inspect exact target area
A_rows = [r for r in range(1, ws.max_row + 1) if ws.cell(r, 1).value not in (None, "")]
I_words = {ws.cell(r, 9).value for r in range(1, ws.max_row + 1) if ws.cell(r, 9).value not in (None, "")}

matching = []
nonmatching = []
for r in A_rows:
    row_ae = [ws.cell(r, c).value for c in range(1, 6)]
    if ws.cell(r, 1).value in I_words:
        matching.append((r, row_ae))
    else:
        nonmatching.append((r, row_ae))

print("Rows with A populated:", len(A_rows))
print("Rows to delete/shift-up in A:E:", len(matching))
print("Rows to keep in A:E:", len(nonmatching))
print("Sample matching rows:", matching[:10])
print("Sample non-matching rows:", nonmatching[:10])

# Compact A:E upward with only nonmatching rows
kept_rows = [rowvals for _, rowvals in nonmatching]
for idx, rowvals in enumerate(kept_rows, start=1):
    for c, val in enumerate(rowvals, start=1):
        ws.cell(idx, c).value = val

# Clear the remainder of A:E below the compacted region
for r in range(len(kept_rows) + 1, max(A_rows) + 1):
    for c in range(1, 6):
        ws.cell(r, c).value = None

# Save
wb2.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(out_path)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    # Rename in order
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    wb_check = load_workbook(out_path)

print("Final sheet names:", wb_check.sheetnames)

# Verification using values
wb_val = load_workbook(out_path, data_only=True)
wsv = wb_val[original_sheetnames[0]]

new_A_rows = [r for r in range(1, wsv.max_row + 1) if wsv.cell(r, 1).value not in (None, "")]
new_A_words = [wsv.cell(r, 1).value for r in new_A_rows]
intersection_after = sorted(set(new_A_words) & I_words)

print("After write, non-empty A rows:", len(new_A_rows))
print("Intersection remaining:", len(intersection_after))
print("First 15 rows A:E and I after compaction:")
for r in range(1, 16):
    print(r, [wsv.cell(r, c).value for c in range(1, 6)] + [wsv.cell(r, 9).value])

print("Rows around new bottom of kept A:E region:")
for r in range(max(1, len(kept_rows) - 5), len(kept_rows) + 6):
