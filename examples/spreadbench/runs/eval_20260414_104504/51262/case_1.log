```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Inspect the exact target area and relevant source data
print("Relevant range B5:H14:")
for r in range(5, 15):
    vals = [ws.cell(r, c).value for c in range(2, 9)]
    print(r, vals)

print("\nCurrent target formulas:")
for cell in ["F6", "G6", "H6"]:
    print(cell, ws[cell].value)

# Compute expected totals from source data for validation
criteria = [ws[f"F{r}"].value for r in range(10, 15) if ws[f"F{r}"].value not in (None, "")]
print("\nCriteria list from F10:F14:", criteria)

from collections import defaultdict
monthly = defaultdict(int)
for r in range(6, 14):
    dt = ws[f"B{r}"].value
    crit = ws[f"C{r}"].value
    amt = ws[f"D{r}"].value
    if dt is not None and crit in criteria and amt is not None:
        monthly[(dt.year, dt.month)] += amt
print("Expected monthly totals for criteria list:", dict(monthly))

# Fix formulas in existing target cells only
# Use SUM(SUMIFS(..., criteria_range)) which works in Excel/Google Sheets for list criteria
for col in ["F", "G", "H"]:
    formula = (
        f'=SUM(SUMIFS($D$6:$D$13,'
        f'$B$6:$B$13,">="&DATE(YEAR({col}$5),MONTH({col}$5),1),'
        f'$B$6:$B$13,"<="&EOMONTH({col}$5,0),'
        f'$C$6:$C$13,$F$10:$F$14))'
    )
    print("Writing", col+"6", "->", formula)
    ws[f"{col}6"] = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore sheet names if recalculation renamed them
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_names)
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
print("\nPost-save formulas:")
for cell in ["F6", "G6", "H6"]:
    print(cell, wsf[cell].value)

wb_val = load_workbook(out_path, data_only=True)
wsv = wb_val[orig_names[0]]
print("\nVerified cached values:")
for cell in ["F6", "G6", "H6"]:
    print(cell, wsv[cell].value)

output_spreadsheet = out_path
```
