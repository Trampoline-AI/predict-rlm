```repl
from openpyxl import load_workbook
import os
from openpyxl.styles import PatternFill

# Inspect whether formulas survived or were converted
wbf = load_workbook(final_output_path, data_only=False)
wsf = wbf["Analyse"]
print("Current stored values/formulas in Analyse D5:F7:")
for r in range(5, 8):
    print(r, [wsf.cell(r, c).value for c in range(4, 7)])

# Rebuild output using Python-computed literals for reliability
wb = load_workbook(input_spreadsheet)
ws_data = wb["Datensatz"]
ws_an = wb["Analyse"]

# Determine actual customer rows and product columns
customer_rows = [r for r in range(4, ws_data.max_row + 1) if ws_data.cell(r, 3).value not in (None, "")]
product_cols = list(range(4, 12))  # D:K
product_names = [ws_data.cell(3, c).value for c in product_cols]
print("Products:", product_names)
print("Customer count:", len(customer_rows))

# Build boolean purchase map (>0 means sold)
purchase = {}
for c in product_cols:
    pname = ws_data.cell(3, c).value
    purchase[pname] = []
    for r in customer_rows:
        val = ws_data.cell(r, c).value
        purchase[pname].append((val or 0) > 0)

# Compute matrix
matrix = {}
n = len(customer_rows)
for p_row in product_names:
    matrix[p_row] = {}
    for p_col in product_names:
        if p_row == p_col:
            val = 1
        else:
            both = sum(1 for a, b in zip(purchase[p_row], purchase[p_col]) if a and b)
            val = both / n
        matrix[p_row][p_col] = val

# Print a few sanity checks including Product1/Product2 expected symmetry
print("Sample computed values:")
for a,b in [("Product 1","Product 2"),("Product 2","Product 1"),("Product 1","Product 1"),("Product 7","Product 8")]:
    print(a, b, matrix[a][b])

# Write literal values into Analyse D5:K12 using existing headers
fill = PatternFill(start_color="F2F2F2", end_color="F2F2F2", fill_type="solid")
for r in range(5, 13):
    row_name = ws_an.cell(r, 3).value
    for c in range(4, 12):
        col_name = ws_an.cell(4, c).value
        cell = ws_an.cell(r, c)
        cell.value = matrix[row_name][col_name]
        cell.number_format = "0.#########"
        cell.fill = fill

# Save over output path
wb.save(final_output_path)
print("Re-saved Python-computed output to", final_output_path)

# Recalculate anyway per requirement
recalc_result = await recalculate(final_output_path)
print("Recalc result:", recalc_result)

# Verify after reload
wb_chk = load_workbook(final_output_path, data_only=True)
wsv = wb_chk["Analyse"]
print("Verified target cells values:")
for coord in ["D5", "E5", "D6", "E6", "K12"]:
    print(coord, wsv[coord].value)

print("Full Analyse matrix values D5:K12:")
for r in range(5, 13):
    vals = [wsv.cell(r, c).value for c in range(4, 12)]
    print(r, vals)

# Verify symmetry and nonzero off-diagonals exist
pairs = [("E5","D6"),("F5","D7"),("K11","J12")]
for c1, c2 in pairs:
    print(c1, wsv[c1].value, c2, wsv[c2].value)

# Confirm styles/fill in formula workbook
wb_style = load_workbook(final_output_path, data_only=False)
wsa = wb_style["Analyse"]
for coord in ["D5","E5","K12"]:
    c = wsa[coord]
    print(coord, "numfmt=", c.number_format, "fill=", c.fill.fill_type, c.fill.fgColor.rgb)

final_output_path = final_output_path
```
