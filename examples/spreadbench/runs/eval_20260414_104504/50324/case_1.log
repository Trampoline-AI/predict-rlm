import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

# Reload for modification
wb = load_workbook(input_spreadsheet)
print("Original sheetnames:", wb.sheetnames)

ws_data = wb["Datensatz"]
ws_an = wb["Analyse"]

# Inspect target area and any existing formats/styles
print("Analyse target area before writing:")
for r in range(4, 13):
    vals = [ws_an.cell(r, c).value for c in range(3, 12)]
    print(r, vals)

for coord in ["D5", "E5", "D6", "K12"]:
    cell = ws_an[coord]
    print(coord, "value=", cell.value, "number_format=", cell.number_format, "fill=", cell.fill.fill_type, cell.fill.fgColor.rgb)

# Determine true customer row count from Datensatz rows where customer label in col C exists
customer_rows = [r for r in range(4, ws_data.max_row + 1) if ws_data.cell(r, 3).value not in (None, "")]
print("Customer rows:", customer_rows[:3], "...", customer_rows[-3:], "count=", len(customer_rows))

# Confirm product headers
data_headers = [ws_data.cell(3, c).value for c in range(4, 12)]
analyse_col_headers = [ws_an.cell(4, c).value for c in range(4, 12)]
analyse_row_headers = [ws_an.cell(r, 3).value for r in range(5, 13)]
print("Datensatz headers D:K:", data_headers)
print("Analyse col headers D:K:", analyse_col_headers)
print("Analyse row headers C5:C12:", analyse_row_headers)

# Write formulas + formatting
fill = PatternFill(start_color="F2F2F2", end_color="F2F2F2", fill_type="solid")
for r in range(5, 13):
    for c in range(4, 12):
        cell = ws_an.cell(r, c)
        if r == c + 1:  # diagonal in this shifted matrix: D5, E6, ..., K12
            formula = "=1"
        else:
            row_hdr = f"$C{r}"
            col_hdr = f"{get_column_letter(c)}$4"
            formula = (
                f'=SUMPRODUCT(--(INDEX(Datensatz!$D$4:$K$33,0,MATCH({row_hdr},Datensatz!$D$3:$K$3,0))>0),'
                f'--(INDEX(Datensatz!$D$4:$K$33,0,MATCH({col_hdr},Datensatz!$D$3:$K$3,0))>0))'
                f'/COUNTA(Datensatz!$C$4:$C$33)'
            )
        cell.value = formula
        cell.number_format = "0.#########"
        cell.fill = fill

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_chk = load_workbook(out_path)
print("Sheetnames after recalc:", wb_chk.sheetnames)
original_names = ["Datensatz", "Analyse"]
if wb_chk.sheetnames != original_names and len(wb_chk.sheetnames) == len(original_names):
    for ws, orig in zip(wb_chk.worksheets, original_names):
        ws.title = orig
    wb_chk.save(out_path)
    print("Renamed sheets back to original names:", wb_chk.sheetnames)

# Verify formulas and values
wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)
wsf = wb_formula["Analyse"]
wsv = wb_values["Analyse"]

print("Verification target cells:")
for coord in ["D5", "E5", "D6", "E6", "K12"]:
    print(coord, "formula=", wsf[coord].value, "value=", wsv[coord].value, "numfmt=", wsf[coord].number_format)

# Print full result matrix values
print("Analyse values D5:K12")
for r in range(5, 13):
    row_vals = [wsv.cell(r, c).value for c in range(4, 12)]
    print(r, row_vals)

# Verify fill on corners/sample
for coord in ["D5", "E5", "K12"]:
    c = wsf[coord]
    print("Fill", coord, c.fill.fill_type, c.fill.fgColor.rgb)
    
final_output_path = out_path
