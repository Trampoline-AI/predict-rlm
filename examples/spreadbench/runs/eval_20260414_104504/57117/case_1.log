import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Target column F header:", ws["F1"].value)
for r in range(2, ws.max_row + 1):
    print(f"Before row {r}: D{r}={ws[f'D{r}'].value!r}, F{r}={ws[f'F{r}'].value!r}")

for r in range(2, ws.max_row + 1):
    dval = ws[f"D{r}"].value
    if dval is None or str(dval).strip() == "":
        continue
    ws[f"F{r}"] = f'=IF(ISNUMBER(SEARCH("BA",D{r})),"BA",IF(ISNUMBER(SEARCH("MA",D{r})),"MA",""))'

for r in range(2, ws.max_row + 1):
    print(f"Formula row {r} F{r}={ws[f'F{r}'].value!r}")

wb.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    for i, old_name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = old_name
    wb2.save(outfile)

# verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]

print("Verification:")
for r in range(2, wsf.max_row + 1):
    print(
        f"row {r}: D={wsv[f'D{r}'].value!r}, "
        f"F_formula={wsf[f'F{r}'].value!r}, "
        f"F_value={wsv[f'F{r}'].value!r}"
    )

output_spreadsheet = outfile
```
