import os, json, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheets = wb.sheetnames
print("Sheet names:", orig_sheets)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    # first 10 rows
    first_n = min(ws.max_row, 10)
    for r in range(1, first_n+1):
        print(f"r{r}:", row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row-4)
    if start_last <= ws.max_row:
        print("Last rows:")
        for r in range(start_last, ws.max_row+1):
            print(f"r{r}:", row_values(ws, r, ws.max_column))
    # specifically inspect D and F current values/formulas
