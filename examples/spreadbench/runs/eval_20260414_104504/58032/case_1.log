import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill, Border, Side
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Extra inspection to verify exact target ranges and lookup data
print("Sheet1 dimensions:", ws.max_row, ws.max_column)
print("Rows with source data in B:C and lookup data in H:J:")
for r in range(2, ws.max_row + 1):
    left = [ws.cell(r,c).value for c in range(1,4)]
    right = [ws.cell(r,c).value for c in range(8,11)]
    if any(v is not None for v in left) or any(v is not None for v in right):
        print(r, "A:C", left, "H:J", right)

# Identify rows needing formulas
target_rows = []
for r in range(2, ws.max_row + 1):
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    if b not in (None, "") and c not in (None, ""):
        target_rows.append(r)
print("Target rows for formulas:", target_rows[:10], "... total", len(target_rows))

# Apply formatting and formulas
header_font = Font(name="Arial", bold=True, italic=True)
body_font = Font(name="Arial", bold=False, italic=False)
thin = Side(style="thin", color="FF000000")
thin_border = Border(left=thin, right=thin, top=thin, bottom=thin)
gray_fill = PatternFill(fill_type="solid", start_color="FFCCCCCC", end_color="FFCCCCCC")
formula_fill = PatternFill(fill_type="solid", start_color="FFFCD5B4", end_color="FFFCD5B4")

# Ensure all existing cells use Arial and keep row 1 style requirements
for row in ws.iter_rows(1, ws.max_row, 1, ws.max_column):
    for cell in row:
        if cell.row == 1:
            cell.font = Font(name="Arial", bold=True, italic=True)
            cell.border = thin_border
        else:
            cell.font = Font(name="Arial", bold=False, italic=False)
            # preserve existing borders pattern by ensuring bordered cells stay bordered
            if any([cell.border.left.style, cell.border.right.style, cell.border.top.style, cell.border.bottom.style]):
                cell.border = thin_border

# Fill D2 downward only on used rows
for r in range(2, ws.max_row + 1):
    ws.cell(r, 4).fill = gray_fill
    ws.cell(r, 4).font = body_font

# Write formulas in column A for all relevant rows
last_lookup_row = ws.max_row
for r in target_rows:
    formula = f'=IFERROR(INDEX($H$2:$H${last_lookup_row},MATCH(1,INDEX(($I$2:$I${last_lookup_row}=B{r})*($J$2:$J${last_lookup_row}=C{r}),0),0)),"")'
    ws.cell(r, 1).value = formula
    ws.cell(r, 1).fill = formula_fill
    ws.cell(r, 1).font = body_font
    ws.cell(r, 1).border = thin_border

# Hide gridlines
ws.sheet_view.showGridLines = False

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Restore original sheet names if changed
orig_names = ["Sheet1"]
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Restored sheet names:", wb2.sheetnames)

# Verify
wbv = load_workbook(out_path, data_only=False)
wsv = wbv["Sheet1"]
wbvd = load_workbook(out_path, data_only=True)
wsvd = wbvd["Sheet1"]

print("Verification: showGridLines =", wsv.sheet_view.showGridLines)
for coord in ["A1","D2","A2","A12","A15","A31"]:
    cf = wsv[coord]
    cd = wsvd[coord]
    print(coord, "formula/raw=", cf.value, "data_only=", cd.value, "fill=", cf.fill.fgColor.rgb)

print("Sample resolved names for target rows:")
for r in target_rows[:10]:
    print(r, "B,C=", wsvd.cell(r,2).value, wsvd.cell(r,3).value, "A=", wsvd.cell(r,1).value)

final_output_path = out_path
