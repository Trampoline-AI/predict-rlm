from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws1 = wb["book1"]
ws2 = wb["book2"]

# Inspect exact target cells and current array formulas
print("book1 target area:")
for r in range(2, min(ws1.max_row, 10) + 1):
    a = ws1[f"A{r}"].value
    b = ws1[f"B{r}"].value
    if hasattr(b, "text"):
        b_repr = b.text
    else:
        b_repr = b
    print(r, a, b_repr)

# Find true last non-empty row in book2 based on any non-empty cell
last_nonempty = 0
for r in range(1, ws2.max_row + 1):
    if any(ws2.cell(r, c).value is not None for c in range(1, ws2.max_column + 1)):
        last_nonempty = r
print("book2 true last non-empty row:", last_nonempty)

# Print headers with letters
print("book2 headers:")
for c in range(1, ws2.max_column + 1):
    print(get_column_letter(c), ws2.cell(1, c).value)

# Print first 15 used rows and last 5 used rows
print("book2 sample rows:")
for r in list(range(1, min(last_nonempty, 15) + 1)) + list(range(max(1, last_nonempty - 4), last_nonempty + 1)):
    if r <= last_nonempty:
        vals = [ws2.cell(r, c).value for c in range(1, 11)]
        print(r, vals)

# Show sample matches for a few Places from book1 and expected sums from Python
print("Python-computed sums for first few places:")
for r in range(3, min(ws1.max_row, 8) + 1):
    place = ws1[f"A{r}"].value
    total = 0
    matches = 0
    for rr in range(2, last_nonempty + 1):
        if ws2[f"A{rr}"].value == place:
            matches += 1
            total += sum((ws2.cell(rr, c).value or 0) for c in range(8, 11))
    print(place, "matches", matches, "sum H:J =", total)

# Replace formulas in B3:Bmax_row
for r in range(3, ws1.max_row + 1):
    if ws1[f"A{r}"].value is not None:
        ws1[f"B{r}"] = f'=SUMPRODUCT((book2!$A$2:$A${last_nonempty}=A{r})*(book2!$H$2:$H${last_nonempty}+book2!$I$2:$I${last_nonempty}+book2!$J$2:$J${last_nonempty}))'

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and restore sheet names if changed
orig_names = ["book1", "book2"]
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names and len(wb_check.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Renamed sheets back to", orig_names)

# Verify formulas and calculated values
wb_formula = load_workbook(out_path, data_only=False)
wb_data = load_workbook(out_path, data_only=True)
vws1f = wb_formula["book1"]
vws1d = wb_data["book1"]

print("Verification B3:B10 formulas and values:")
for r in range(3, min(vws1f.max_row, 10) + 1):
    print(r, vws1f[f"A{r}"].value, vws1f[f"B{r}"].value, "=>", vws1d[f"B{r}"].value)

output_spreadsheet = out_path
