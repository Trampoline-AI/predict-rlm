import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["raw 1"]

# Inspect current target area before modifying
print("Before:")
for r in range(3, 9):
    print(r, [ws.cell(r, c).value for c in range(6, 8)])  # F:G

# Write formulas to G4:G8 corresponding to F4:F8
# Logic: count rows where player_class equals F-row class AND (depo <> 0 OR with <> 0)
# Implemented as: count(A=F, B<>0) + count(A=F, B=0, C<>0)
for r in range(4, 9):
    formula = (
        f'=COUNTIFS($A$2:$A$100000,F{r},$B$2:$B$100000,"<>0")'
        f'+COUNTIFS($A$2:$A$100000,F{r},$B$2:$B$100000,"=0",$C$2:$C$100000,"<>0")'
    )
    ws[f"G{r}"] = formula
    print(f"Set G{r} ->", formula)

# Add filter to A1:C1
ws.auto_filter.ref = "A1:C1"
print("AutoFilter ref:", ws.auto_filter.ref)

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = s
    wb2.save(outfile)
    print("Restored sheet names:", orig_sheetnames)

# Verify formulas and calculated values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["raw 1"]
print("Formulas after save:")
for r in range(4, 9):
    print(f"F{r}={wsf[f'F{r}'].value}, G{r} formula={wsf[f'G{r}'].value}")
print("Filter now:", wsf.auto_filter.ref)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["raw 1"]
print("Calculated values:")
for r in range(4, 9):
    print(f"G{r} =", wsv[f"G{r}"].value)

output_spreadsheet = outfile
