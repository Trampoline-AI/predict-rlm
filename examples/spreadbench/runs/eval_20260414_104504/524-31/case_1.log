import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Exp-DB"]

# Build mapping from A:B rows that are populated
mapping = []
for r in range(1, ws.max_row + 1):
    patt = ws.cell(r, 1).value
    cat = ws.cell(r, 2).value
    if patt is not None and cat is not None and str(patt).strip() != "":
        mapping.append((str(patt), str(cat)))

# Longest prefix first to avoid shorter patterns stealing matches
mapping_sorted = sorted(mapping, key=lambda x: len(x[0]), reverse=True)

# Print current target area before modification
print("Pre-write target samples:")
for r in [1,2,4,10,16,25,37,40,49,53]:
    print(r, ws[f"D{r}"].value, ws[f"E{r}"].value, ws[f"G{r}"].value)

# Write computed categories into existing result columns E and G
written = []
unmatched = []
for r in range(1, ws.max_row + 1):
    d = ws.cell(r, 4).value
    if d is None or str(d).strip() == "":
        continue
    dstr = str(d)
    category = None
    for patt, cat in mapping_sorted:
        if dstr.upper().startswith(patt.upper()):
            category = cat
            break
    ws.cell(r, 5).value = category  # column E existing output area
    ws.cell(r, 7).value = category  # column G existing output area
    if category is None:
        unmatched.append((r, dstr))
    else:
        written.append((r, dstr, category))

wb.save(outfile)
print("Saved:", outfile)
print("Matched:", len(written), "Unmatched:", len(unmatched))
print("First unmatched:", unmatched[:12])

# Recalculate
res = await recalculate(outfile)
print("Recalculate:", res)

# Reload and restore sheet names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring to", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify after recalculation
verify = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", verify.sheetnames)
vws = verify["Exp-DB"]

print("Post-write verification samples:")
for r in [1,2,3,4,5,9,10,16,17,18,19,20,25,26,27,37,38,40,44,47,49,53]:
    print({
        "row": r,
        "D": vws[f"D{r}"].value,
        "E": vws[f"E{r}"].value,
        "G": vws[f"G{r}"].value
    })

# Sanity checks
nonblank_targets = 0
for r in range(1, vws.max_row + 1):
    if vws.cell(r, 4).value not in (None, ""):
        if vws.cell(r, 5).value not in (None, "") or vws.cell(r, 7).value not in (None, ""):
            nonblank_targets += 1
print("Rows with D and some output in E/G:", nonblank_targets, "out of", sum(1 for r in range(1, vws.max_row + 1) if vws.cell(r,4).value not in (None, "")))

output_spreadsheet = outfile
```
