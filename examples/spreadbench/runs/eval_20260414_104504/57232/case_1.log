import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload fresh workbook for writing
wb = load_workbook(infile)
ws = wb["Sea Freight Rates"]
vol = wb["Volume"]
original_sheetnames = wb.sheetnames[:]

# Inspect match coverage with Python first
last_sf = ws.max_row
last_vol = 0
for r in range(1, vol.max_row + 1):
    if any(vol.cell(r, c).value not in (None, "") for c in range(1, 7)):
        last_vol = r

lookup = {}
for r in range(3, last_vol + 1):
    origin = vol.cell(r, 1).value
    equip = vol.cell(r, 2).value
    if origin and equip:
        for c in range(4, 7):
            dest = vol.cell(2, c).value
            lookup[(origin, equip, dest)] = vol.cell(r, c).value

unmatched = []
matched = 0
for r in range(2, last_sf + 1):
    key = (ws.cell(r, 2).value, ws.cell(r, 5).value, ws.cell(r, 4).value)
    if key in lookup:
        matched += 1
    else:
        unmatched.append((r, key))

print("Sea Freight data rows:", last_sf - 1)
print("Matched rows via Python lookup:", matched)
print("Unmatched rows:", len(unmatched))
print("First few unmatched:", unmatched[:10])

# Write formulas into exact target cells H2:Hlast
for r in range(2, last_sf + 1):
    formula = (
        f'=IFERROR('
        f'INDEX(Volume!$D$3:$F${last_vol},'
        f'MATCH(1,(Volume!$A$3:$A${last_vol}=B{r})*(Volume!$B$3:$B${last_vol}=E{r}),0),'
        f'MATCH(D{r},Volume!$D$2:$F$2,0)'
        f'),"")'
    )
    ws.cell(r, 8).value = formula

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Restore original sheet names if LibreOffice changed them
wb_chk = load_workbook(outfile)
if wb_chk.sheetnames != original_sheetnames:
    print("Sheet names changed:", wb_chk.sheetnames, "-> restoring", original_sheetnames)
    # rename by position
    for i, name in enumerate(original_sheetnames):
        wb_chk.worksheets[i].title = name
    wb_chk.save(outfile)
else:
    print("Sheet names preserved.")

# Verify after recalculation
wb_data = load_workbook(outfile, data_only=True)
wsd = wb_data["Sea Freight Rates"]

print("Verify H1 and sample target values:")
print("H1:", wsd["H1"].value)
for r in range(2, 12):
