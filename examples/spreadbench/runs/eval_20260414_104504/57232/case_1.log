print("Last 5 target values:")
for r in range(last_sf - 4, last_sf + 1):
    print(f"Row {r} keys:", wsd.cell(r,2).value, wsd.cell(r,5).value, wsd.cell(r,4).value, "=> H", wsd.cell(r,8).value)

none_targets = [r for r in range(2, last_sf + 1) if wsd.cell(r,8).value in (None, "")]
print("Blank/None target count after recalc:", len(none_targets))
print("First few blank target rows:", none_targets[:10])

