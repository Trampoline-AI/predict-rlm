        print(f"Row {r}:", vals)

    # print formulas / non-empty cells in used range
    print("Non-empty cells with formulas or notable values:")
    count = 0
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                print(f"  {get_column_letter(c)}{r}: FORMULA {v}")
                count += 1
            elif v is not None and v != "" and (r <= 5 or r > ws.max_row-5):
                pass
    if count == 0:
        print("  No formulas found")

    # print compact grid with coordinates for first 15 rows / all used cols
    print("Compact preview with coordinates:")
    for r in range(1, min(ws.max_row, 15)+1):
        row_items = []
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if v is not None:
                row_items.append(f"{get_column_letter(c)}{r}={v}")
        print(" ", "; ".join(row_items))
