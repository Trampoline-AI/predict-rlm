import os, json, re, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET ---", ws.title)
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Headers row1:", headers)
    if ws.max_row >= 2:
        print("Row2:", row_values(ws, 2, ws.max_column))
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))

    # print formulas/non-empty cells in first few columns/rows to infer pattern
    print("Non-empty/formula scan first 15 rows:")
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = []
        for c in range(1, min(ws.max_column, 12) + 1):
