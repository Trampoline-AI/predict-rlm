import os, json, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
print("Original sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column+1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column+1)]
        print("Row2 values:", headers2)
    sample_rows = list(range(1, min(ws.max_row, 10)+1))
    if ws.max_row > 10:
        sample_rows += list(range(max(1, ws.max_row-4), ws.max_row+1))
    seen = set()
    sample_rows = [r for r in sample_rows if not (r in seen or seen.add(r))]
    for r in sample_rows:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", vals)
    # specific H/I inspection
    if ws.max_column >= 9:
        print("Column H header:", ws["H1"].value, "Column I header:", ws["I1"].value)
        hi_rows = []
        for r in range(1, ws.max_row+1):
            h = ws.cell(r, 8).value
            i = ws.cell(r, 9).value
            if h is not None or i is not None:
                hi_rows.append((r, h, i))
        print("First 15 non-empty H/I rows:", hi_rows[:15])
        print("Last 10 non-empty H/I rows:", hi_rows[-10:])
        candidates = []
        for r in range(2, ws.max_row+1):
            h = ws.cell(r, 8).value
            i = ws.cell(r, 9).value
            h_blank = h is None or (isinstance(h, str) and h.strip() == "")
            i_has = i is not None and not (isinstance(i, str) and i.strip() == "")
            if h_blank and i_has:
                row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12)+1)]
                candidates.append((r, h, i, row_vals))
        print("Candidate rows to delete (H blank, I has value):", len(candidates))
        for item in candidates[:20]:
            print(item)

for ws in wb.worksheets:
    sheet_summary(ws)
