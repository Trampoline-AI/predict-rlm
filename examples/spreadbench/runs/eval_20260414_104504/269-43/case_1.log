import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Reload fresh workbook for modification
wb2 = load_workbook(infile)
orig_sheet_names = wb2.sheetnames[:]

deleted_info = {}
for ws in wb2.worksheets:
    rows_to_delete = []
    for r in range(1, ws.max_row + 1):
        h = ws.cell(r, 8).value
        i = ws.cell(r, 9).value
        h_blank = h is None or (isinstance(h, str) and h.strip() == "")
        i_has = i is not None and not (isinstance(i, str) and i.strip() == "")
        if h_blank and i_has:
            rows_to_delete.append(r)
    deleted_info[ws.title] = rows_to_delete[:]
    print(f"{ws.title} rows flagged for deletion:", rows_to_delete)
    for r in reversed(rows_to_delete):
        row_snapshot = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Deleting row {r}: {row_snapshot}")
        ws.delete_rows(r, 1)

wb2.save(outfile)
print("Saved to", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload after recalc, restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    for idx, expected in enumerate(orig_sheet_names):
        wb_check.worksheets[idx].title = expected
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verify output
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
for ws in wb_verify.worksheets:
    print(f"\nPost-delete sheet {ws.title}: max_row={ws.max_row}, max_col={ws.max_column}")
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    remaining_candidates = []
    for r in range(1, ws.max_row + 1):
        h = ws.cell(r, 8).value
        i = ws.cell(r, 9).value
        h_blank = h is None or (isinstance(h, str) and h.strip() == "")
        i_has = i is not None and not (isinstance(i, str) and i.strip() == "")
        if h_blank and i_has:
            remaining_candidates.append((r, h, i))
    print("Remaining rows matching delete condition:", remaining_candidates)

output_spreadsheet = outfile
print("Output ready:", output_spreadsheet)
