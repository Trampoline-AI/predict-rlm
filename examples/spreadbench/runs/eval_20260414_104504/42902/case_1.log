import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload fresh workbook for editing
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Read source list from column A, preserving only nonblank rows
source_vals = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None and str(v).strip() != "":
        source_vals.append(v)

print("Source count:", len(source_vals))
print("Source values:", source_vals)
print("Existing target D:F row 1-10 before write:")
for r in range(1, 11):
    print(r, [ws.cell(r, c).value for c in range(4, 7)])

# Group every 3 rows into one record in D:E:F
assert len(source_vals) % 3 == 0, f"Source row count {len(source_vals)} is not divisible by 3"
records = [source_vals[i:i+3] for i in range(0, len(source_vals), 3)]
print("Record count:", len(records))
print("Records preview:", records[:10])

for out_row, rec in enumerate(records, start=1):
    for offset, val in enumerate(rec, start=4):  # D=4, E=5, F=6
        ws.cell(out_row, offset).value = val

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and preserve sheet names if needed
orig_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)

# Verify with data_only
ver = load_workbook(outfile, data_only=True)
vws = ver[orig_sheetnames[0]]
print("Verified target D:F rows 1-10 after save:")
for r in range(1, 11):
    print(r, [vws.cell(r, c).value for c in range(4, 7)])

output_spreadsheet = outfile
