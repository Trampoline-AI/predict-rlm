```repl
import os
from decimal import Decimal, InvalidOperation
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
pl = wb["PL Recon Items"]
st = wb["Statement Recon Items"]

def norm(v):
    if v is None:
        return None
    if isinstance(v, str):
        s = v.strip()
        if s == "":
            return None
        try:
            return Decimal(s)
        except InvalidOperation:
            return s
    if isinstance(v, (int, float)):
        return Decimal(str(v))
    try:
        return Decimal(str(v))
    except Exception:
        return str(v).strip()

# Build matching keys across all relevant rows
pl_keys = []
for r in range(2, pl.max_row + 1):
    c = pl[f"C{r}"].value
    d = pl[f"D{r}"].value
    if c is None and d is None:
        continue
    pl_keys.append((r, (norm(c), norm(d))))

st_keys = []
for r in range(2, st.max_row + 1):
    f = st[f"F{r}"].value
    i = st[f"I{r}"].value
    if f is None and i is None:
        continue
    st_keys.append((r, (norm(f), norm(i))))

pl_key_set = {k for _, k in pl_keys}
st_key_set = {k for _, k in st_keys}
common_keys = pl_key_set & st_key_set

print("PL keys:", pl_keys)
print("Statement keys:", st_keys)
print("Common keys:", common_keys)

pl_delete_rows = [r for r, k in pl_keys if k in common_keys]
st_delete_rows = [r for r, k in st_keys if k in common_keys]
print("PL rows to delete:", pl_delete_rows)
print("Statement rows to delete:", st_delete_rows)

# Delete from bottom up
for r in sorted(pl_delete_rows, reverse=True):
    pl.delete_rows(r, 1)
for r in sorted(st_delete_rows, reverse=True):
    st.delete_rows(r, 1)

wb.save(outfile)
print("Saved to", outfile)

# Recalculate and handle potential sheet rename
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheet_names)
    # rename by position if counts match
    if len(wb_after.sheetnames) == len(orig_sheet_names):
        for idx, old_name in enumerate(orig_sheet_names):
            wb_after.worksheets[idx].title = old_name
        wb_after.save(outfile)

# Verification after recalc
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)

for sname in orig_sheet_names:
    ws = wbv[sname]
    print(f"\nSheet {sname}: max_row={ws.max_row}, max_column={ws.max_column}")
    for r in range(1, ws.max_row + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

output_spreadsheet = outfile
