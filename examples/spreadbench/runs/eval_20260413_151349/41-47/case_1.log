import openpyxl

# Path to the input workbook
wb_path = "/sandbox/input/input_spreadsheet/1_41-47_init.xlsx"

# Load workbook (keep formulas for now)
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
sheet_names = wb.sheetnames
print("Sheet names:", sheet_names)

# Helper to preview first few rows of a sheet
def preview_sheet(ws, max_rows=5):
    rows = []
    for r in ws.iter_rows(min_row=1, max_row=max_rows, values_only=True):
        rows.append(list(r))
    return rows

# Preview each sheet (first 5 rows)
