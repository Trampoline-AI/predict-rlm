Code:
```repl
import openpyxl
from pathlib import Path
from openpyxl.styles import PatternFill

# Paths
input_path = Path('/sandbox/input/input_spreadsheet/1_57033_init.xlsx')
output_dir = Path('/sandbox/output/output_spreadsheet/')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify target sheet (contains 'Sheet4') and lookup sheet (contains 'CBtrans')
ws_target = None
ws_lookup = None
for name in wb.sheetnames:
    if '4' in name.lower():
        ws_target = wb[name]
    if 'cb' in name.lower():
        ws_lookup = wb[name]

if ws_target is None or ws_lookup is None:
    raise RuntimeError('Could not locate required sheets')

# Build lookup dictionary from CBtrans: (company, doc-id, year) -> baseval
lookup = {}
for r in range(2, ws_lookup.max_row + 1):
    company = ws_lookup.cell(row=r, column=1).value
    doc_id = ws_lookup.cell(row=r, column=3).value
    year = ws_lookup.cell(row=r, column=5).value
    baseval = ws_lookup.cell(row=r, column=9).value  # column I is baseval
    if company is None or doc_id is None or year is None:
        continue
    key = (company, str(doc_id).strip(), year)
    lookup[key] = baseval

# Define fill for shading
fill = PatternFill(start_color='FF66CC', end_color='FF66CC', fill_type='solid')

# Populate K2:K7 in target sheet
for r in range(2, 8):  # rows 2 through 7 inclusive
    company = ws_target.cell(row=r, column=2).value  # column B
    doc = ws_target.cell(row=r, column=3).value   # column C
    year = ws_target.cell(row=r, column=10).value  # column J
    if doc is not None:
        doc = str(doc).strip()
    key = (company, doc, year)
    value = lookup.get(key, None)
    # Write the value (could be None if not found)
    target_cell = ws_target.cell(row=r, column=11)  # column K
    target_cell.value = value
    # Apply shading
    target_cell.fill = fill

# Save workbook to output location
wb.save(output_path)
print('Saved processed workbook to', output_path)
```
