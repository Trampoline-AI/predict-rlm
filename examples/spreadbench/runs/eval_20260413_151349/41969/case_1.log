import os, openpyxl, pathlib

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_41969_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_41969_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active

# Write COUNTBLANK formulas into A6, B6, C6
ws["A6"] = "=COUNTBLANK(A3:C3)"
ws["B6"] = "=COUNTBLANK(D3:F3)"
ws["C6"] = "=COUNTBLANK(G3:I3)"

# Save workbook to output location
wb.save(output_path)

# Reload with data_only=True to read evaluated values (LibreOffice will compute them when opened,
# but we can also force a recalculation using the provided tool if needed).
