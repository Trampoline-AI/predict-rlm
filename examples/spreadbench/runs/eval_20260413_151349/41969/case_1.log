import openpyxl, os, pathlib, json, sys

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_41969_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas
ws = wb.active

# Basic inspection
print("Sheet title:", ws.title)
print("Dimensions: rows =", ws.max_row, "cols =", ws.max_column)

# Helper to get values in a range as list
def range_values(start_col, start_row, end_col, end_row):
    vals = []
    for row in ws.iter_rows(min_row=start_row, max_row=end_row,
                            min_col=start_col, max_col=end_col):
        vals.append([cell.value for cell in row])
    return vals

# Print values for the first three 3‑column ranges in row 3
ranges = [("A3:C3", 1, 3, 3, 3), ("D3:F3", 4, 3, 6, 3), ("G3:I3", 7, 3, 9, 3)]
for name, sc, sr, ec, er in ranges:
    vals = range_values(sc, sr, ec, er)
    print(f"{name} values:", vals)
