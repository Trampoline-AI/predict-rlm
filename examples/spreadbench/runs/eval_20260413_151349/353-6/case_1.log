```repl
import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

# Load workbook (data_only to read any cached formula results, though not needed here)
wb = load_workbook(input_path, data_only=True)
ws = wb.active  # assume the relevant data is in the active sheet

# Column I is column 9 (1-indexed)
col_idx = 9
target = "hub notes"

# Gather rows to delete (exclude header row 1)
rows_to_delete = []
for row in range(2, ws.max_row + 1):
    val = ws.cell(row=row, column=col_idx).value
    if isinstance(val, str) and val.strip().lower() == target:
        rows_to_delete.append(row)

print(f"Rows before deletion: {ws.max_row}")
print(f"Rows matching '{target}' (excluding header): {len(rows_to_delete)}")

# Delete rows from bottom to top to keep indices stable
for row_idx in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(row_idx)

print(f"Rows after deletion: {ws.max_row}")

# Save the modified workbook
wb.save(output_path)
print(f"Saved output to: {output_path}")
