Code:
```repl
import os
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_109-21_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (preserve formulas)
wb = load_workbook(input_path)  # data_only=False
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row

# First pass: gather rows per group, and handle rows without a group immediately
group_rows = {}   # group_id -> list of (row_index, points)
for r in range(2, max_row + 1):
    group_val = ws.cell(row=r, column=2).value   # column B = group identifier
    points = ws.cell(row=r, column=11).value    # column K = Total points

    if group_val is None:
        # No group → automatically Y (even if points missing)
        ws.cell(row=r, column=26).value = "Y"
    else:
        # Store for later max comparison; keep rows even if points is None
        group_rows.setdefault(group_val, []).append((r, points))

# Second pass: compute max per group and write Y/N
for grp, rows in group_rows.items():
    # Filter out rows where points is None for max calculation
    points_vals = [pts for _, pts in rows if pts is not None]
    if not points_vals:
        # No points in this group → all get N
        for row_idx, _ in rows:
            ws.cell(row=row_idx, column=26).value = "N"
        continue

    max_points = max(points_vals)
    for row_idx, pts in rows:
        if pts is None:
            ws.cell(row=row_idx, column=26).value = "N"
        else:
            ws.cell(row=row_idx, column=26).value = "Y" if pts == max_points else "N"

# Save the workbook
wb.save(output_path)

print(f"Processed workbook saved to {output_path}")

# Verification: print a few sample rows (group, points, flag)
samples = []
for r in range(2, min(12, max_row + 1)):
    grp = ws.cell(row=r, column=2).value
    pts = ws.cell(row=r, column=11).value
    flg = ws.cell(row=r, column=26).value
    samples.append({"row": r, "group": grp, "points": pts, "flag": flg})
print("Sample rows (first 10):", samples)
