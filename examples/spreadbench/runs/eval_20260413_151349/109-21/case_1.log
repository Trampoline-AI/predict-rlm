Code:
```repl
import os
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_109-21_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook for reading and writing (keep formulas if any)
wb = load_workbook(input_path)  # default data_only=False to preserve formulas
ws = wb[wb.sheetnames[0]]

# Build a mapping from group id (column A) to list of (row_index, total_points)
group_rows = {}
for r in range(2, ws.max_row + 1):  # assume header at row 1, data starts at row 2
    group_val = ws.cell(row=r, column=1).value  # column A
    points = ws.cell(row=r, column=11).value   # column K (Total points)
    # Skip rows without a group identifier or without points
    if group_val is None or points is None:
        continue
    group_rows.setdefault(group_val, []).append((r, points))

# Determine Y/N for each row and write to column Z (26)
for group, rows in group_rows.items():
    # Find the maximum points in this group
    max_points = max(p for _, p in rows)
    for row_idx, pts in rows:
        flag = "Y" if pts == max_points else "N"
        ws.cell(row=row_idx, column=26).value = flag  # column Z

# Save the modified workbook
wb.save(output_path)

print(f"Saved processed workbook to {output_path}")
print(f"Processed {len(group_rows)} groups, total rows written: {sum(len(v) for v in group_rows.values())}")
```
