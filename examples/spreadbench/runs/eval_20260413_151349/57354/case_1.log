import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # /sandbox/input/input_spreadsheet/1_57354_init.xlsx
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = load_workbook(input_path)

for ws in wb.worksheets:
    max_col = ws.max_column
    # Build absolute range strings for the whole row 2 and row 3
    start_letter = get_column_letter(1)
    end_letter = get_column_letter(max_col)
    cat_range = f"${start_letter}$2:${end_letter}$2"
    val_range = f"${start_letter}$3:${end_letter}$3"

    for col in range(1, max_col + 1):
        header_cell = ws.cell(row=2, column=col)
        total_cell = ws.cell(row=3, column=col)
        header = header_cell.value
        # Identify the placeholder total cells: header is REVENUE or GP and total cell is empty
        if isinstance(header, str):
            hdr = header.strip().upper()
            if hdr in ("REVENUE", "GP") and (total_cell.value is None or str(total_cell.value).strip() == ""):
                # Write SUMIF formula for the matching category
                formula = f"=SUMIF({cat_range}, \"{hdr}\", {val_range})"
                total_cell.value = formula
                print(f"Written {hdr} total formula to {ws.title}!{total_cell.coordinate}: {formula}")

# Save the modified workbook
wb.save(output_path)

# Verify by re‑loading with data_only=True (cached values will be None until recalculated)
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb.active
print("Verification – total cells after writing formulas:")
for col in range(1, verify_ws.max_column + 1):
    header = verify_ws.cell(row=2, column=col).value
    if isinstance(header, str) and header.strip().upper() in ("REVENUE", "GP"):
        total = verify_ws.cell(row=3, column=col).value
        print(f"{verify_ws.title}!{get_column_letter(col)}3: {total}")
