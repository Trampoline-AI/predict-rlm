```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths from the provided variables
input_path = input_spreadsheet  # e.g., /sandbox/input/input_spreadsheet/1_57354_init.xlsx
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load the workbook (keep formulas)
wb = load_workbook(input_path)

# Process each sheet
for ws in wb.worksheets:
    max_col = ws.max_column
    # Build the absolute range strings for row 2 (categories) and row 3 (values)
    start_col_letter = get_column_letter(1)
    end_col_letter = get_column_letter(max_col)
    cat_range = f"${start_col_letter}$2:${end_col_letter}$2"
    val_range = f"${start_col_letter}$3:${end_col_letter}$3"

    # Scan row 3 for total cells
    for col in range(1, max_col + 1):
        cell = ws.cell(row=3, column=col)
        if isinstance(cell.value, str):
            val_lower = cell.value.lower()
            if "total revenue" in val_lower:
                category = "Revenue"
            elif "total gp" in val_lower:
                category = "GP"
            else:
                continue
            # Write the SUMIF formula
            formula = f"=SUMIF({cat_range}, \"{category}\", {val_range})"
            cell.value = formula
            print(f"Written formula to {ws.title}!{cell.coordinate}: {formula}")

# Save the modified workbook
wb.save(output_path)

# Verify by re‑loading with data_only=True (cached values will be None until recalculated)
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb.active
print("Verification snapshot (first 10 columns of row 3):")
for col in range(1, min(10, verify_ws.max_column) + 1):
    cell = verify_ws.cell(row=3, column=col)
    print(f"{cell.coordinate}: {cell.value}")
```

