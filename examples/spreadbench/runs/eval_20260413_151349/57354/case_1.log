                val_range = f"${start_letter}$3:${end_letter}$3"
                formula = f"=SUMIF({cat_range}, \"{header.strip().upper()}\", {val_range})"
                total_cell.value = formula

# Save the workbook with formulas
wb.save(output_path)

# Recalculate all formulas using the provided helper (LibreOffice fallback)
# This will cache the computed values in the file.
recalc_result = await recalculate(output_path)
print(f"Recalculate result: {recalc_result}")

