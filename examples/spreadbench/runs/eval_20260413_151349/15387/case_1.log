```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_15387_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_15387_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# Write the array formulas into A13 and A14
# Note: openpyxl stores the formula text; LibreOffice will treat it as an array formula
# when the user confirms with Ctrl+Shift+Enter. The braces are not needed in the stored text.
ws["A13"] = '=IFERROR(INDEX($B$3:$F$3, SMALL(IF($B$1:$F$1=0, COLUMN($B$1:$F$1)-COLUMN($B$1)+1), ROWS($A$13:A13))), "")'
ws["A14"] = '=IFERROR(INDEX($B$3:$F$3, SMALL(IF($B$1:$F$1=0, COLUMN($B$1:$F$1)-COLUMN($B$1)+1), ROWS($A$13:A14))), "")'

# Save the modified workbook
wb.save(output_path)

# Quick verification: print the formulas we just wrote
print("A13 formula:", ws["A13"].value)
print("A14 formula:", ws["A14"].value)
print("Saved modified workbook to", output_path)
```
