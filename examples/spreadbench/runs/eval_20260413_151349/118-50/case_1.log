Code:
```repl
import re
from pathlib import Path
from openpyxl import load_workbook

output_path = Path("/sandbox/output/output_spreadsheet/1_118-50_init.xlsx")
wb = load_workbook(output_path, data_only=True)
ws = wb.active

pattern = re.compile(r"PEA$")
matches = []
for r in range(2, ws.max_row + 1):
    word = ws.cell(row=r, column=1).value
    transformed = ws.cell(row=r, column=2).value
    if isinstance(word, str) and pattern.search(word):
        matches.append((r, word, transformed))

print(f"Found {len(matches)} words ending with 'PEA'.")
for idx, (row, orig, trans) in enumerate(matches[:10], start=1):
    print(f"Match {idx}: Row {row}, Original='{orig}', Transformed='{trans}'")

# Show a few rows around the first match to verify sorting
if matches:
    first_match_row = matches[0][0]
    start = max(1, first_match_row - 2)
    end = min(ws.max_row, first_match_row + 2)
    print("\nRows around first match (A | B):")
    for r in range(start, end + 1):
        print(f"Row {r}: A={ws.cell(r,1).value!r} B={ws.cell(r,2).value!r}")
```
