import openpyxl, os, asyncio

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_45937_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_45937_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Write formula only where E is empty and D has a category
for row in range(2, ws.max_row + 1):  # start after header
    cat = ws.cell(row=row, column=4).value  # D column
    e_val = ws.cell(row=row, column=5).value  # E column
    if cat is not None and e_val is None:
        formula = f"=VLOOKUP(C{row}, $H$20:$N$22, MATCH(D{row}, $H$18:$N$18, 0), TRUE)"
        ws.cell(row=row, column=5).value = formula

# Save workbook
wb.save(output_path)
print('Workbook saved to', output_path)

# Recalculate formulas so cached values are stored
# The recalculate tool is async; we need to await it.
# Use the provided await recalculate function.

# Define a small async helper to run the recalc and then verify
async def recalc_and_verify():
    # Recalculate formulas
    result = await recalculate(output_path)
    print('Recalculate result:', result)
    # Reload with data_only to see evaluated values
    wb_check = openpyxl.load_workbook(output_path, data_only=True)
    ws_check = wb_check[wb_check.sheetnames[0]]
    print('Verification (E column values after recalculation):')
    for r in range(7, min(12, ws_check.max_row + 1)):
        print(f"E{r} =", ws_check.cell(row=r, column=5).value)

# Run the async helper
await recalc_and_verify()
