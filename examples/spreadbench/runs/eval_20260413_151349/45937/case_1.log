# Helper to display C, D, E for a range of rows
def show_rows(start, end):
    print(f'Rows {start}-{end} (C, D, E):')
    for r in range(start, end+1):
        c = ws.cell(row=r, column=3).value   # column C (kms)
        d = ws.cell(row=r, column=4).value   # column D (category)
        e = ws.cell(row=r, column=5).value   # column E (percentage / formula)
        print(f'Row {r}: C={c}, D={d}, E={e}')

# Show current state for rows 10-22
show_rows(10, 22)

# Write formula where D has a category but E is empty
for row in range(2, ws.max_row + 1):
    cat = ws.cell(row=row, column=4).value
    e_val = ws.cell(row=row, column=5).value
    if cat is not None and e_val is None:
        formula = f"=VLOOKUP(C{row}, $H$20:$N$22, MATCH(D{row}, $H$18:$N$18, 0), TRUE)"
        ws.cell(row=row, column=5).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas (async)
async def recalc_and_verify():
    result = await recalculate(output_path)
    print('Recalculate result:', result)
    # Reload with data_only to see evaluated values
    wb_check = openpyxl.load_workbook(output_path, data_only=True)
    ws_check = wb_check[wb_check.sheetnames[0]]
    print('Verification after recalculation (C, D, E) rows 10-22:')
    for r in range(10, 23):
        c = ws_check.cell(row=r, column=3).value
        d = ws_check.cell(row=r, column=4).value
        e = ws_check.cell(row=r, column=5).value
        print(f'Row {r}: C={c}, D={d}, E={e}')

await recalc_and_verify()
