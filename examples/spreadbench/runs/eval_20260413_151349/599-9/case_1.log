import os
from pathlib import Path
from openpyxl import load_workbook, Workbook

# Paths from the provided variables
input_path = Path(input_spreadsheet)  # e.g., /sandbox/input/input_spreadsheet/1_599-9_init.xlsx
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name  # keep same filename

# Load the workbook (preserve formulas, data only when reading later)
wb = load_workbook(filename=input_path, data_only=False)  # keep formulas
# Assume the first sheet is the one we need to modify
ws = wb.active

# Determine the max row with data (openpyxl provides max_row)
max_row = ws.max_row

# Process rows: start from row 2 assuming a header row; adjust if no header
start_row = 2
for row in range(start_row, max_row + 1):
    cell_g = ws.cell(row=row, column=7)   # column G
    cell_k = ws.cell(row=row, column=11)  # column K

    # If column G has a value (non‑None and not empty string), copy it to K
    if cell_g.value not in (None, ""):
        cell_k.value = cell_g.value
    # else: leave K unchanged (do nothing)

# Save the modified workbook
wb.save(output_path)

# Quick verification: print first few rows of columns G and K
print("Sample verification (first 5 data rows):")
for row in range(start_row, min(start_row + 5, max_row + 1)):
    g_val = ws.cell(row=row, column=7).value
    k_val = ws.cell(row=row, column=11).value
    print(f"Row {row}: G={g_val!r} -> K={k_val!r}")
```
