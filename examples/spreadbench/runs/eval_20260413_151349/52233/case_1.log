import openpyxl, os, re

# Load the input workbook (data_only=False to preserve formulas)
input_path = '/sandbox/input/input_spreadsheet/1_52233_init.xlsx'
wb = openpyxl.load_workbook(input_path, data_only=False)

# Find the cell(s) containing the original formula pattern
original_pattern = re.compile(r"=SUM\(INDEX\(B3:B5,0,MATCH\(A7,\$B\$2:\$Z\$2,0\)\)\)")
found = []
for ws in wb.worksheets:
    for row in ws.iter_rows(values_only=False):
        for cell in row:
            if isinstance(cell.value, str) and original_pattern.search(cell.value.replace(' ', '')):
                found.append((ws.title, cell.coordinate, cell.value))

print(f"Found {len(found)} cells with the original formula.")
for ws_name, coord, val in found:
    print(f"Sheet: {ws_name}, Cell: {coord}, Formula: {val}")

# Define the modified formula (using absolute range for the table and dynamic column offset)
modified_formula = '=SUM(INDEX($B$3:$Z$5,0,MATCH(A7,$B$2:$Z$2,0)+ROW()-ROW($A$7)))'

# Replace the original formula and copy it down the same column for the same number of rows
for ws_name, coord, _ in found:
    ws = wb[ws_name]
    # Determine the column letter and starting row
    col_letter = re.match(r"([A-Z]+)", coord).group(1)
    start_row = int(re.search(r"(\d+)$", coord).group(1))
    # Determine how many rows to fill: we will fill until the next empty cell in the same column
    # (or just replicate the original range length if known). For safety, fill down 10 rows.
    fill_rows = 10
    for offset in range(fill_rows):
        target_cell = f"{col_letter}{start_row + offset}"
        ws[target_cell] = modified_formula
    print(f"Wrote modified formula to {fill_rows} cells starting at {col_letter}{start_row} in sheet {ws_name}.")

# Save the modified workbook to the output directory
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_52233_init_modified.xlsx')
wb.save(output_path)
print(f"Saved modified workbook to {output_path}")

# Verify by reloading with data_only=True to see cached values (optional)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[found[0][0]] if found else wb_check.active
print("Sample of written formulas (first 5 rows):")
for i in range(start_row, start_row + 5):
    print(ws_check[f"{col_letter}{i}"].value)

2026-04-13 15:43:50,954 INFO RLM iteration 2/50
Reasoning: We need to locate the cell(s) containing the original formula `=SUM(INDEX(B3:B5,0,MATCH(A7,$B$2:$Z$2,0)))`.  
Then replace each with a formula that, when dragged vertically, shifts the column reference (B→C→D…) while keeping the row numbers (3‑5) unchanged.  

A suitable formula is:

```
=SUM(INDEX($B$3:$Z$5,0,MATCH(A7,$B$2:$Z$2,0)+ROW()-ROW($A$7)))
```

- `$B$3:$Z$5` is an absolute range covering all possible columns.
- `MATCH(... )` finds the column index based on the header.
- `ROW()-ROW($A$7)` adds an offset that increases by 1 for each row the formula is dragged down, thus moving the column reference while the row range (3‑5) stays fixed.

After writing the new formula into the original cell, we will copy it down the same column for every row that already contains data (up to the sheet’s `max_row`).  
Finally we save the workbook to the output directory using the **same filename** as the input workbook.
Code:
```repl
import os, re
import openpyxl

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_52233_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_52233_init.xlsx")  # same filename

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Pattern to locate the exact original formula (ignore spaces)
orig_pat = re.compile(r"=SUM\(INDEX\(B3:B5,0,MATCH\(A7,\$B\$2:\$Z\$2,0\)\)\)", re.IGNORECASE)

# New formula that shifts column with each row dragged down
new_formula = "=SUM(INDEX($B$3:$Z$5,0,MATCH(A7,$B$2:$Z$2,0)+ROW()-ROW($A$7)))"

# Find all cells containing the original formula
targets = []  # (worksheet, cell coordinate)
for ws in wb.worksheets:
    for row in ws.iter_rows(values_only=False):
        for cell in row:
            if isinstance(cell.value, str) and orig_pat.search(cell.value.replace(" ", "")):
                targets.append((ws, cell.coordinate))

print(f"Found {len(targets)} cell(s) with the original formula.")

# Replace and drag down
for ws, coord in targets:
    col_letter = re.match(r"([A-Z]+)", coord).group(1)
    start_row = int(re.search(r"(\d+)$", coord).group(1))
    max_row = ws.max_row  # fill down to the last used row in the sheet
    for r in range(start_row, max_row + 1):
        ws[f"{col_letter}{r}"].value = new_formula
    print(f"Wrote modified formula from {col_letter}{start_row} to {col_letter}{max_row} in sheet '{ws.title}'.")

# Save workbook
wb.save(output_path)
print(f"Saved modified workbook to {output_path}")

# Quick verification: reload with data_only=False and show a few formulas
check_wb = openpyxl.load_workbook(output_path, data_only=False)
check_ws = check_wb[targets[0][0].title] if targets else check_wb.active
print("Sample of written formulas (first 5 rows of the target column):")
sample_col = re.match(r"([A-Z]+)", targets[0][1]).group(1) if targets else "A"
for i in range(start_row, min(start_row + 5, check_ws.max_row + 1)):
    print(f"{sample_col}{i}: {check_ws[f'{sample_col}{i}'].value}")
```
