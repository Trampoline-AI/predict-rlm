import os
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_55468_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_55468_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook preserving formulas
wb = load_workbook(input_path, data_only=False)

# Define the corrected formula with four criteria
new_formula = "=INDEX(C5:Z10," \
              "MATCH(1, INDEX((A5:A10=AE4)*(B5:B10=AB4),0),0), " \
              "MATCH(1, INDEX((C4:Z4=AD4)*(C3:Z3=AC4),0),0))"

# Add a new sheet (or reuse if already exists)
sheet_name = "ModifiedFormula"
if sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
else:
    ws = wb.create_sheet(title=sheet_name)

# Write the formula to a prominent cell (A1)
ws["A1"] = new_formula

# Save the workbook
wb.save(output_path)

# Print a brief verification summary
print(f"Workbook saved to: {output_path}")
print(f"Sheets in workbook: {wb.sheetnames}")
print(f"Formula written to {sheet_name}!A1: {new_formula}")
