import openpyxl

# Load the workbook (read_only for quick inspection)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)  # keep formulas if any
print("Sheets:", wb.sheetnames)

# Assume the first sheet contains the data
ws = wb[wb.sheetnames[0]]

# Basic dimensions
print("Rows:", ws.max_row, "Columns:", ws.max_column)

# Show header row (first 10 columns) to locate columns F‑AT
header = [ws.cell(row=1, column=c).value for c in range(1, min(20, ws.max_column)+1)]
print("Header (first 20 cols):", header)

# Sample data for first few rows, columns F‑AT (columns 6‑46)
for r in range(2, 6):  # rows 2‑5
    row_vals = [ws.cell(row=r, column=c).value for c in range(6, 47)]  # F=6, AT=46
    print(f"Row {r} F‑AT:", row_vals[:15], "...")  # truncate for readability

# Check data type of a typical date/time column if present (e.g., column A)
sample_date = ws.cell(row=2, column=1).value
print("Sample column A value:", sample_date, "type:", type(sample_date))

# Close workbook
wb.close()
