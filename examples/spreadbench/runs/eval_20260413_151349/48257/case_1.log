import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_48257_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_48257_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming a single sheet

# Determine column indices for new helpers
max_col = ws.max_column          # currently 3
sep_col = max_col + 1            # column D -> DecimalSeparator
num_col = max_col + 2            # column E -> ExtractedNumber

# Write headers for the new columns
ws.cell(row=1, column=sep_col).value = "DecimalSeparator"
ws.cell(row=1, column=num_col).value = "ExtractedNumber"

# Formula to detect decimal separator ('.' or ',')
sep_formula = (
    '=IFERROR('
    'IF(FIND(".",B{row})>0, '
    'IF(FIND(",",B{row})>0, '
    'IF(FIND(".",B{row})>FIND(",",B{row}),".",","), '
    '"."), '
    'IF(FIND(",",B{row})>0, ",", ".")), '
    '")'
)

# Formula to extract numeric value using NUMBERVALUE (LibreOffice prefix)
num_formula = (
    '=_xlfn.NUMBERVALUE('
    'SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(TRIM(B{row}),"USD",""),"EUR","")," ",""),"$",""), '
    'D{row}, '
    '" "'
)

# Populate formulas for each data row
for row in range(2, ws.max_row + 1):
    ws.cell(row=row, column=sep_col).value = sep_formula.format(row=row)
    ws.cell(row=row, column=num_col).value = num_formula.format(row=row)

# Save the workbook with the new formulas
wb.save(output_path)

# Recalculate formulas to cache their results
await recalculate(str(output_path))

