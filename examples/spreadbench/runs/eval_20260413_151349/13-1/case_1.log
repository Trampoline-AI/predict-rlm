    ws_lists.cell(row=out_row, column=2, value=date)       # DATE -> B
    ws_lists.cell(row=out_row, column=3, value=ref)        # REF -> C
    ws_lists.cell(row=out_row, column=4, value=total_amount)  # AMOUNTS -> D
    out_row += 1
    sn += 1

# -------------------------------------------------
