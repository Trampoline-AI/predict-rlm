```repl
import openpyxl
from pathlib import Path

# Load the workbook (read-only is fine for inspection)
wb_path = Path("/sandbox/input/input_spreadsheet/1_13-1_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=True)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Function to print first few rows of a sheet
def preview_sheet(ws, max_rows=5):
    rows = []
    for r in ws.iter_rows(min_row=1, max_row=max_rows, values_only=True):
        rows.append(r)
    return rows

# Show headers and a few rows for each sheet
for name in wb.sheetnames:
    ws = wb[name]
    preview = preview_sheet(ws, max_rows=5)
    print(f"\n--- Sheet: {name} ---")
    for row in preview:
        print(row)

# Close workbook
wb.close()
```
