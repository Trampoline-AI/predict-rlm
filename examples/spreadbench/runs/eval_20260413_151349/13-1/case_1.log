# -------------------------------------------------
amount_samples = []
for i, row in enumerate(ws_ranges.iter_rows(min_row=3, values_only=True), start=3):
    amount = row[4]  # column E
    amount_samples.append((i, type(amount), amount))
    if len(amount_samples) >= 10:
        break
print("Sample amount values (row, type, value):", amount_samples)

# -------------------------------------------------
# 1. Clear old data rows in LISTS (keep first 2 rows)
