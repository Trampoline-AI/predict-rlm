# -------------------------------------------------
agg = {}  # key: (date, ref) -> total amount (float)
for row in ws_ranges.iter_rows(min_row=3, values_only=True):
    date = row[1]   # column B
    ref = row[3]    # column D
    raw_amount = row[4]  # column E
    # Skip rows missing essential data
    if date is None or ref is None or raw_amount is None:
        continue
    # Convert amount to float safely
