import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_13-1_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_13-1_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws_ranges = wb["RANGES"]
ws_lists = wb["LISTS"]

# -------------------------------------------------
