Code:
```repl
import openpyxl, os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_160-6_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_160-6_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb["SH"]

# Identify blank rows (all cells None or empty string after stripping)
def is_blank_row(row):
    for cell in row:
        val = cell.value
        if val is None:
            continue
        if isinstance(val, str) and val.strip() == "":
            continue
        return False
    return True

blank_rows = [r for r in range(1, ws.max_row + 1) if is_blank_row(ws[r])]
print("Blank rows to delete:", blank_rows)

# Delete blank rows from bottom to top
for r in reversed(blank_rows):
    ws.delete_rows(r, 1)

# Save modified workbook
wb.save(output_path)
print("Saved cleaned workbook to:", output_path)

# Verify no blank rows remain
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2["SH"]
remaining_blank = [r for r in range(1, ws2.max_row + 1) if is_blank_row(ws2[r])]
print("Remaining blank rows after deletion:", remaining_blank)
print(f"Final dimensions: rows={ws2.max_row}, cols={ws2.max_column}")
```
