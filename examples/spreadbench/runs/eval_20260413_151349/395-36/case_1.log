import openpyxl
from pathlib import Path

# Load the workbook
wb_path = Path("/sandbox/input/input_spreadsheet/1_395-36_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=True)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Function to preview first few rows of a sheet
def preview_sheet(ws, max_rows=5):
    rows = list(ws.iter_rows(values_only=True))
    # Print column headers (first row)
    if rows:
        print("Headers:", rows[0])
    else:
        print("Empty sheet")
        return
    # Print up to max_rows data rows (skip header)
    for i, row in enumerate(rows[1:max_rows+1], start=1):
        print(f"Row {i}:", row)

# Preview each sheet
for name in wb.sheetnames:
    print(f"\n--- Preview of sheet: {name} ---")
    ws = wb[name]
    preview_sheet(ws, max_rows=5)
```
2026-04-13 15:21:24,648 INFO RLM iteration 2/50
Reasoning: We inspected the workbook and identified three sheets. The 'Main unique ID' sheet contains a single column of IDs (no header). The 'Result what i am getting' sheet has a header row with 'Unique ID' in column A and data rows starting at row 2. The task is to find IDs present in the Main sheet but missing in the Result sheet, and append a new row for each missing ID to the Result sheet, keeping the Unique ID column filled and leaving other columns empty. We'll load the workbook, collect IDs from both sheets, compute the missing set, append rows with the missing IDs (padding the rest of the columns with None), and save the modified workbook to the output directory with the same filename. Finally, we'll reload the saved file to verify the new IDs were added.
Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_395-36_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_395-36_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Worksheets
ws_main = wb["Main unique ID"]
ws_res = wb["Result what i am getting"]

# Collect IDs from Main unique ID sheet (all rows in column A)
main_ids = set()
for row in ws_main.iter_rows(min_row=1, max_col=1, values_only=True):
    val = row[0]
    if val is not None:
        main_ids.add(val)

# Collect IDs from Result what i am getting sheet (skip header row)
res_ids = set()
for row in ws_res.iter_rows(min_row=2, max_col=1, values_only=True):
    val = row[0]
    if val is not None:
        res_ids.add(val)

# Determine missing IDs
missing_ids = sorted(main_ids - res_ids)
print(f"Missing IDs to add: {missing_ids}")

# Append a new row for each missing ID, preserving column count
num_cols = ws_res.max_column  # total columns in Result sheet
for mid in missing_ids:
    # Build a row: ID in first column, rest empty (None)
    new_row = [mid] + [None] * (num_cols - 1)
    ws_res.append(new_row)

# Save to output location
wb.save(output_path)

# Verify by reloading (data_only) and printing the final list of IDs in Result sheet
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Result what i am getting"]
final_ids = [row[0] for row in ws_check.iter_rows(min_row=2, max_col=1, values_only=True) if row[0] is not None]
print(f"Total IDs in Result sheet after update: {len(final_ids)}")
print(f"First few IDs: {final_ids[:10]}")
```
