import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

# Paths from the provided variables
input_path = input_spreadsheet  # e.g., /sandbox/input/input_spreadsheet/1_37086_init.xlsx
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load the workbook (keep formulas)
wb = load_workbook(filename=input_path, data_only=False)
ws = wb.active  # assume the first sheet is the target

# Identify header row (assume row 1)
header_row = 1
headers = {}
for col in range(1, ws.max_column + 1):
    cell_val = ws.cell(row=header_row, column=col).value
    if isinstance(cell_val, str):
        headers[cell_val.strip()] = col

# Determine column1 (the first column with a header; if not found, default to column A)
col1_name = None
col1_idx = None
# The instruction mentions "column1" – we interpret it as the first column in the sheet
if ws.max_column >= 1:
    col1_idx = 1
    # If there is a header for this column, capture its name for reference
    col1_name = ws.cell(row=header_row, column=col1_idx).value

# Ensure a "Total" column exists; if not, create it after the last column
if "Total" in headers:
    total_idx = headers["Total"]
else:
    total_idx = ws.max_column + 1
    ws.cell(row=header_row, column=total_idx).value = "Total"

# Build the formula string using the appropriate column letter for column1
col1_letter = get_column_letter(col1_idx)
formula_template = f"=IF({col1_letter}{{row}}=\"A\", 10, IF({col1_letter}{{row}}=\"B\", -10, 0))"

# Apply the formula to each data row (starting after header)
for row in range(header_row + 1, ws.max_row + 1):
    ws.cell(row=row, column=total_idx).value = formula_template.format(row=row)

# Save the modified workbook to the output location
wb.save(output_path)

print(f"Workbook saved to {output_path}")
```
