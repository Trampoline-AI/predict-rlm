import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_209-30_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_209-30_init.xlsx"

# Load workbook (keep formulas if any, but we will overwrite values)
wb = openpyxl.load_workbook(input_path, data_only=False)
sheet_name = "Data to Import"
if sheet_name not in wb.sheetnames:
    raise ValueError(f"Sheet '{sheet_name}' not found in workbook.")
ws = wb[sheet_name]

max_row = ws.max_row

# Transform column C (index 3) values: remove last three characters
for r in range(2, max_row + 1):
    cell = ws.cell(row=r, column=3)  # column C
    val = cell.value
    if isinstance(val, str) and len(val) >= 3:
        # Remove last three characters
        cell.value = val[:-3]
    else:
        # Leave None or short strings unchanged
        pass

# Save to output location
wb.save(output_path)

# Verify by printing first few transformed values (rows 1‑5)
print("Transformed first 5 rows in column C (including header):")
for r in range(1, min(6, max_row + 1)):
    print(f"R{r}C3: {ws.cell(row=r, column=3).value!r}")
```
