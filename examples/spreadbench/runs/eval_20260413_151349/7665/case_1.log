Code:
```repl
import os
import openpyxl

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_7665_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_7665_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Extract values from column H, skipping header if it's a string
col_h_vals = []
for row in range(1, ws.max_row + 1):
    val = ws.cell(row=row, column=8).value
    if val is None:
        continue
    # Skip non‑numeric header (e.g., "Number List")
    if isinstance(val, (int, float)):
        col_h_vals.append(val)

# Compute unique sorted values
unique_sorted = sorted(set(col_h_vals))

# Write first six values (or fewer) into Q2:V2 (columns 17‑22)
start_col = 17  # Q
row = 2
for i, val in enumerate(unique_sorted[:6]):
    ws.cell(row=row, column=start_col + i, value=val)

# Save to output path
wb.save(output_path)

# Verify by reloading with data_only and printing Q2:V2
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
verified = [ws_check.cell(row=2, column=start_col + i).value for i in range(6)]
print("Verified Q2:V2 values:", verified)
```
