We will load both sheets, print a small matrix of values for rows 1‑6 and columns I‑U, and also list any merged cell ranges. This will let us determine where the month names are so we can construct the required formula for column U.
Code:
```repl
import openpyxl, os, json, pathlib

wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)

def print_sheet_info(ws, name):
    print(f"\n--- Sheet: {name} ---")
    print("Dimensions:", ws.max_row, ws.max_column)
    # Print merged cell ranges
    if ws.merged_cells.ranges:
        print("Merged ranges:", [str(r) for r in ws.merged_cells.ranges])
    else:
        print("No merged ranges")
    # Print rows 1‑6, columns I (9) to U (21)
    for r in range(1, min(7, ws.max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(9, 22)]
        print(f"Row {r:2d} I‑U:", row_vals)

# Inspect all sheets
for title in wb.sheetnames:
    ws = wb[title]
    print_sheet_info(ws, title)

# Save a copy for later (optional)
out_path = "/sandbox/output/output_spreadsheet/inspect_full.xlsx"
os.makedirs(os.path.dirname(out_path), exist_ok=True)
wb.save(out_path)
print("\nSaved full inspection copy to", out_path)
```
