print("Sheets:", wb.sheetnames)

# Assume the first sheet is the target
ws = wb[wb.sheetnames[0]]
print("Active sheet:", ws.title)

# Determine dimensions
max_row = ws.max_row
max_col = ws.max_column
print(f"Rows: {max_row}, Columns: {max_col}")

# Show header row (first row) for columns I (9) to T (20)
