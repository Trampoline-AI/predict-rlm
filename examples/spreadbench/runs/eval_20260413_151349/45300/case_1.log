import openpyxl, os, json, textwrap

# Load the workbook (read-only for inspection)
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, read_only=True, data_only=True)
print(f"Workbook loaded: {wb_path}")
print(f"Sheets: {wb.sheetnames}")

# Use the first sheet
ws = wb[wb.sheetnames[0]]
print(f"Active sheet: {ws.title}")
print(f"Rows: {ws.max_row}, Columns: {ws.max_column}")

# Show header row (first row) values
header = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
print("Header row values:", header)

# Show first 5 data rows (row 2-6)
for r in range(2, min(ws.max_row, 6)+1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
    print(f"Row {r}:", row_vals)

wb.close()
