import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_56921_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_56921_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Debug: show current formula and some surrounding values
print("Current C15 formula:", ws["C15"].value)
print("B15 (criterion):", ws["B15"].value)
print("A3:A10:", [ws[f"A{r}"].value for r in range(3, 11)])
print("C3:N10 (first row):", [ws[f"{get_column_letter(c)}3"].value for c in range(3, 15)])

# Corrected formula
corrected_formula = "=SUMPRODUCT(($A$3:$A$10=B15)*(MOD(COLUMN(C3:N10)-COLUMN(C3),4)=0)*(C3:N10))"
ws["C15"].value = corrected_formula
print("New C15 formula set to:", ws["C15"].value)

# Save to output path
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas (await async tool)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to read the computed value
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("Computed C15 value after recalculation:", ws2["C15"].value)
