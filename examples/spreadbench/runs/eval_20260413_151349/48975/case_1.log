Code:
```repl
import os
import openpyxl

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
# Ensure Output sheet exists
if "Output" not in wb.sheetnames:
    wb.create_sheet(title="Output")
output_ws = wb["Output"]
# Clear existing data in Output (keep only header row if needed)
output_ws.delete_rows(1, output_ws.max_row)

# Access Input sheet
input_ws = wb["Input"] if "Input" in wb.sheetnames else wb[wb.sheetnames[0]]

out_row = 1  # start at first row in Output
for r in range(1, input_ws.max_row + 1):
    e_val = input_ws.cell(row=r, column=5).value  # column E
    if isinstance(e_val, str) and e_val.strip().lower() == "yes":
        a_val = input_ws.cell(row=r, column=1).value  # column A
        b_val = input_ws.cell(row=r, column=2).value  # column B
        # Skip rows with empty A or B
        if a_val is None or b_val is None:
            continue
        # Write to Output
        output_ws.cell(row=out_row, column=1, value=a_val)
        output_ws.cell(row=out_row, column=2, value=b_val)
        out_row += 1

# Save to output path
wb.save(output_path)
print("Saved transformed workbook to:", output_path)

# Verify by loading saved file with data_only and printing first few rows of Output
wb_check = openpyxl.load_workbook(output_path, data_only=True)
out_check = wb_check["Output"]
print("First 5 rows in Output (A, B):")
for r in range(1, min(6, out_check.max_row + 1)):
    a = out_check.cell(row=r, column=1).value
    b = out_check.cell(row=r, column=2).value
    print(f"Row {r}: A={a!r}, B={b!r}")
```
