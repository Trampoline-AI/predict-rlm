from pathlib import Path
from openpyxl import load_workbook

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_55260_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_55260_init.xlsx"

# Load workbook (keep formulas initially)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # Sheet2

def round_to_nearest_5(val: float) -> float:
    """Round to nearest multiple of 5, ties (2.5) round down."""
    remainder = val % 5
    if remainder <= 2.5:
        return val - remainder
    else:
        return val + (5 - remainder)

# Process each data row (no header, start at row 1)
rounded_info = []  # for verification printing
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, max_col=2, values_only=False):
    cell_a = row[0]  # column A
    cell_b = row[1]  # column B (to be overwritten)
    # Get numeric base value from column A
    try:
        base_val = float(cell_a.value)
    except (TypeError, ValueError):
        # Skip rows where column A is not numeric
        continue
    # Compute amount (A * 1.05) – same as the original formula
    amount = base_val * 1.05
    # Round to nearest $5 with tie‑down
    rounded_amount = round_to_nearest_5(amount)
    # Write back to column B
    cell_b.value = rounded_amount
    rounded_info.append((base_val, amount, rounded_amount))

# Insert the required formula into C1
ws["C1"] = "=IF(MOD(B1,5)=2.5, FLOOR(B1,5), IF(MOD(B1,5)<2.5, FLOOR(B1,5), CEILING(B1,5)))"

# Save the modified workbook
wb.save(output_path)

# Verify by reloading with data_only (cached values)
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Gather first few rounded values from column B for reporting
sample_vals = []
for r in ws_check.iter_rows(min_row=1, max_row=ws_check.max_row, max_col=2, values_only=True):
    sample_vals.append(r[1])  # column B value

print(f"Processed {len(rounded_info)} rows.")
print("Sample rounded amounts in column B (first rows):", sample_vals[:5])
print("C1 formula text:", ws_check["C1"].value)
```
