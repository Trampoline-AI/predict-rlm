Code:
```repl
import os
from pathlib import Path
from openpyxl import load_workbook, Workbook

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_55260_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_55260_init.xlsx"

# Load workbook (keep formulas)
wb = load_workbook(input_path)
ws = wb.active  # assume first sheet

# Helper to round to nearest 5 with tie down
def round_to_nearest_5(val):
    try:
        # Ensure numeric
        x = float(val)
    except (TypeError, ValueError):
        return val  # leave unchanged if not a number
    remainder = x % 5
    # Tie (exactly 2.5) should round down, so <= 2.5 goes down
    if remainder <= 2.5:
        return x - remainder
    else:
        return x + (5 - remainder)

# Process rows (skip header row 1)
rounded_vals = []
for row in ws.iter_rows(min_row=2, max_col=2, values_only=False):
    cell = row[1]  # column B (index 1)
    orig = cell.value
    rounded = round_to_nearest_5(orig)
    cell.value = rounded
    rounded_vals.append((orig, rounded))

# Write formula into C1
ws["C1"] = "=IF(MOD(B1,5)=2.5, FLOOR(B1,5), IF(MOD(B1,5)<2.5, FLOOR(B1,5), CEILING(B1,5)))"

# Save workbook
wb.save(output_path)

# Verify by reloading with data_only to see cached values (if any)
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active
# Gather first 5 rounded values for reporting
sample = []
for i, row in enumerate(ws_check.iter_rows(min_row=2, max_col=2, values_only=True), start=2):
    if i > 6:
        break
    sample.append(row[1])  # column B value

print(f"Processed rows: {len(rounded_vals)}")
print("First 5 rounded amounts in column B:", sample)
print("C1 formula text:", ws["C1"].value)
```
