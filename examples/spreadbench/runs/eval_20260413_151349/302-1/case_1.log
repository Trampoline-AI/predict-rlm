import openpyxl, os

# Path to the saved workbook
output_path = "/sandbox/output/output_spreadsheet/1_302-1_init.xlsx"

# Load the workbook (read‑only is fine for verification)
wb = openpyxl.load_workbook(output_path, data_only=True)

ws_items = wb["ITEMS"]
ws_sheet1 = wb["SHEET1"]
ws_sheet2 = wb["SHEET2"]

max_row = ws_items.max_row

mismatches_sheet1 = 0
mismatches_sheet2 = 0

for row in range(2, max_row + 1):
    items_val = ws_items.cell(row=row, column=2).value
    sheet1_val = ws_sheet1.cell(row=row, column=2).value
    sheet2_val = ws_sheet2.cell(row=row, column=2).value
    if sheet1_val != items_val:
        mismatches_sheet1 += 1
    if sheet2_val != items_val:
        mismatches_sheet2 += 1

print(f"Row count (excluding header): {max_row - 1}")
print(f"Mismatches in SHEET1 column B: {mismatches_sheet1}")
print(f"Mismatches in SHEET2 column B: {mismatches_sheet2}")

# Set the output variable for submission
output_spreadsheet = output_path
```
