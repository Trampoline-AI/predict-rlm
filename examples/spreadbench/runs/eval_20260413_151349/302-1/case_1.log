print("Sheets:", wb.sheetnames)

# Function to preview first few values of column B (excluding header)
def preview_col_b(ws, n=5):
    vals = []
    # Assume header is in row 1, start from row 2
    for row in range(2, min(ws.max_row, n + 1) + 1):
        vals.append(ws.cell(row=row, column=2).value)
    return vals

