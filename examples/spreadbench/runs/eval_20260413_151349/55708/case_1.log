Code:
```repl
import openpyxl, os, math

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_55708_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_55708_init.xlsx")

# Load the output workbook (data_only to see written numbers)
wb = openpyxl.load_workbook(output_path, data_only=True)
ws = wb.active

# Identify column indices again (in case order changed)
header = [cell.value for cell in ws[1]]
dept_col = header.index("Department") + 1
status_col = header.index("Status") + 1
turn_col = header.index("turnaroud time") + 1
avg_col = header.index("Avg Turnaround") + 1

# Compute expected averages from the original data (ignoring any formulas)
orig_wb = openpyxl.load_workbook(input_path, data_only=True)
orig_ws = orig_wb.active

dept_vals = {}
for row in orig_ws.iter_rows(min_row=2, max_row=orig_ws.max_row):
    dept = row[dept_col-1].value
    status = row[status_col-1].value
    turn = row[turn_col-1].value
    if isinstance(turn, (int, float)):
        if status in ("In Progress", "In Review") and turn >= 6:
            dept_vals.setdefault(dept, []).append(turn)

dept_avg = {d: (sum(v)/len(v) if v else None) for d, v in dept_vals.items()}

# Verify each row's Avg Turnaround matches the computed average (or is blank)
mismatches = []
for row in ws.iter_rows(min_row=2, max_row=ws.max_row):
    dept = row[dept_col-1].value
    written = row[avg_col-1].value
    expected = dept_avg.get(dept)
    # Treat None/blank as missing
    if expected is None:
        if written is not None:
            mismatches.append((row[0].row, dept, written, "blank expected"))
    else:
        # Allow small floating‑point differences
        if written is None or not math.isclose(written, expected, rel_tol=1e-9, abs_tol=1e-9):
            mismatches.append((row[0].row, dept, written, expected))

if mismatches:
    print("Found mismatches:")
    for r in mismatches[:10]:
        print(f"Row {r[0]} dept {r[1]}: written={r[2]}, expected={r[3]}")
else:
    print("All rows match expected averages.")

orig_wb.close()
wb.close()
```
