import openpyxl, json, os

# Load the workbook (read-only for speed)
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=True)

# Gather basic info
sheet_info = []
for ws in wb.worksheets:
    # Get max row/col (may be None for empty sheets)
    max_row = ws.max_row
    max_col = ws.max_column
    # Capture first row values as potential headers
    header = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    sheet_info.append({
        "title": ws.title,
        "max_row": max_row,
        "max_col": max_col,
        "header": header,
    })

# Print a concise summary
print(json.dumps(sheet_info, indent=2, default=str))

# Keep workbook and sheet info for later steps
workbook = wb
sheets_summary = sheet_info
```
