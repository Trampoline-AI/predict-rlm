Code:
```repl
import openpyxl, os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_438-18_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (preserve formulas if any)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Helper to find sheet case‑insensitively
def find_sheet(name_target):
    for name in wb.sheetnames:
        if name.strip().lower() == name_target.lower():
            return wb[name]
    return None

# Locate INPUT sheet
input_ws = find_sheet('INPUT')
if input_ws is None:
    # fallback to first sheet
    input_ws = wb[wb.sheetnames[0]]

# Locate OUTPUT sheet (prefer exact 'OUTPUT', else existing 'OUPUT', else create new)
output_ws = find_sheet('OUTPUT')
if output_ws is None:
    output_ws = find_sheet('OUPUT')
if output_ws is None:
    output_ws = wb.create_sheet(title='OUTPUT')

# Mapping of full names to short codes
replace_map = {
    'UNATIDE STATES AMERICAN': 'USA',
    'FRANCE': 'FRA',
    'KOREA': 'KOR',
    'GERMANY': 'GR',
    'ITALY': 'IT',
}

# Copy rows
max_row = input_ws.max_row
max_col = input_ws.max_column

for r in range(1, max_row + 1):
    for c in range(1, max_col + 1):
        cell = input_ws.cell(row=r, column=c)
        new_val = cell.value
        # Apply replacement only for column F (6) and not header row (optional)
        if c == 6 and new_val in replace_map:
            new_val = replace_map[new_val]
        output_ws.cell(row=r, column=c, value=new_val)

# Save to output path
wb.save(output_path)

# Verify: load saved file with data_only and print column F values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
out_ws = wb_check[output_ws.title]  # same title as we wrote
sample_vals = [out_ws.cell(row=r, column=6).value for r in range(2, min(out_ws.max_row, 10) + 1)]
print('Verification - column F values in OUTPUT (rows 2‑10):', sample_vals)
```
