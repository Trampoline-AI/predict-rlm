```repl
import os
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_32293_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_32293_init.xlsx")

# Load workbook
wb = load_workbook(input_path)
ws = wb.active  # assume the relevant sheet is the active one

# Define the formula template with a placeholder for the row number
formula_template = (
    '=IF(A{row}="MNQ", B1*0.56, '
    'IF(A{row}="MES", B2*0.56, '
    'IF(A{row}="NQ", B3*2.09, '
    'IF(A{row}="ES", B4*2.04, ""))))'
)

# Apply the formula to B14 through B17
for row in range(14, 18):
    ws.cell(row=row, column=2).value = formula_template.format(row=row)

# Save the modified workbook
wb.save(output_path)

# Verify that the file exists
print("Saved to:", output_path)
print("Formulas written:")
for row in range(14, 18):
    print(f"B{row} =", ws.cell(row=row, column=2).value)
```
