import openpyxl
from pathlib import Path

# Load the workbook (read_only for speed, data_only to get values, not formulas)
wb_path = Path(input_spreadsheet)
wb = openpyxl.load_workbook(wb_path, data_only=True)

print(f"Workbook loaded from: {wb_path}")
print("Sheets:", wb.sheetnames)

# Explore each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Dimensions: rows={ws.max_row}, columns={ws.max_column}")

    # Get header row (assume first row contains column names)
    header = [cell.value for cell in ws[1]]
    print("Headers:", header)

    # Show first 5 data rows (skip header)
