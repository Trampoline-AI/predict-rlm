import openpyxl

# Load the workbook (read‑only for fast inspection)
wb_path = input_spreadsheet  # path provided by the environment
wb = openpyxl.load_workbook(wb_path, read_only=True, data_only=True)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Helper to summarize a sheet
def summarize_sheet(ws, max_rows=5):
    # Determine dimensions
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Sheet '{ws.title}': {max_row} rows, {max_col} columns")
    # Print header row (first row) values
    header = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Header (first row):", header)
    # Print first few data rows
    for r in range(2, min(max_rows, max_row)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

# Summarize each sheet
for ws in wb.worksheets:
    summarize_sheet(ws)
