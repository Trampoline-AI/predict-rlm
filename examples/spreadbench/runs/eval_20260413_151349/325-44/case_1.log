Code:
```repl
import pathlib, re, itertools, os
import openpyxl

# Paths
input_path = pathlib.Path(input_spreadsheet)
output_dir = pathlib.Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_325-44_init.xlsx"

# Load workbook (keep formulas if any)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Keep Input sheet unchanged
input_ws = wb["Input"]
output_ws = wb["Output"]

# ----------------------------------------------------------------------
# Helper to parse a filter string into a dict of key -> list of values
# ----------------------------------------------------------------------
def parse_filter(filter_str: str):
    """
    Returns a dict: key -> list of values (strings or ints).
    Only extracts keys we need: orgId, careType, specialtyId, contextId.
    """
    # Remove surrounding parentheses/semicolon and extra spaces
    filter_str = filter_str.strip()
    # Remove trailing semicolon if present
    if filter_str.endswith(";"):
        filter_str = filter_str[:-1]

    # Pattern for = "value"
    eq_pat = re.compile(r'\(\s*"([^"]+)"\s*=\s*"([^"]+)"\s*\)')
    # Pattern for IN LIST numbers (comma separated, may have spaces)
    inlist_pat = re.compile(r'\(\s*"([^"]+)"\s*IN\s+LIST\s+([^)]*)\)')

    result = {}

    # Find all = clauses
    for match in eq_pat.finditer(filter_str):
        key, val = match.group(1), match.group(2)
        result.setdefault(key, []).append(val)

    # Find all IN LIST clauses
    for match in inlist_pat.finditer(filter_str):
        key, vals = match.group(1), match.group(2)
        # Split by commas, strip spaces
        val_list = [v.strip() for v in vals.split(",") if v.strip()]
        result.setdefault(key, []).extend(val_list)

    return result

# ----------------------------------------------------------------------
# Build output rows
# ----------------------------------------------------------------------
output_rows = []  # list of tuples matching Output columns

# Header row (will be written later)
header = ["wtype_id", "name", "status", "orgId", "careType", "specialtyId", "contextId"]

# Iterate over Input rows (skip header)
for row in input_ws.iter_rows(min_row=2, max_row=input_ws.max_row, values_only=True):
    wtype_id, name, status, filter_val = row
    # Skip completely empty rows
    if wtype_id is None and name is None and status is None and filter_val is None:
        continue

    # Parse filter string; if None, treat as empty dict
    filter_dict = parse_filter(filter_val) if isinstance(filter_val, str) else {}

    # Extract needed keys, default to [None] if missing
    org_ids = filter_dict.get("orgId", [None])
    care_types = filter_dict.get("careType", [None])
    specialty_ids_raw = filter_dict.get("specialtyId", [None])
    context_ids_raw = filter_dict.get("contextId", [None])

    # Convert numeric-looking values to int (dropping leading zeros)
    def coerce_numeric(val):
        if val is None:
            return None
        # Try int conversion; if fails, keep original string
        try:
            return int(val)
        except ValueError:
            return val

    specialty_ids = [coerce_numeric(v) for v in specialty_ids_raw]
    context_ids = [coerce_numeric(v) for v in context_ids_raw]

    # Generate Cartesian product of specialtyId and contextId
    for org, care, spec, ctx in itertools.product(org_ids, care_types, specialty_ids, context_ids):
        output_rows.append((
            wtype_id,
            name,
            status,
            org,
            care,
            spec,
            ctx
        ))

# ----------------------------------------------------------------------
# Write to Output sheet
# ----------------------------------------------------------------------
# Clear existing rows (keep header row)
output_ws.delete_rows(2, output_ws.max_row)  # delete everything after header

# Write header (in case it was removed)
for col_idx, col_name in enumerate(header, start=1):
    output_ws.cell(row=1, column=col_idx, value=col_name)

# Write data rows
for r_idx, out_row in enumerate(output_rows, start=2):
    for c_idx, value in enumerate(out_row, start=1):
        output_ws.cell(row=r_idx, column=c_idx, value=value)

# Save workbook to output path
wb.save(output_path)

# ----------------------------------------------------------------------
# Verification: reload with data_only=True and print first few rows of Output
# ----------------------------------------------------------------------
verif_wb = openpyxl.load_workbook(output_path, data_only=True)
verif_ws = verif_wb["Output"]
print("Verification - first 10 rows of Output (including header):")
for i, row in enumerate(verif_ws.iter_rows(min_row=1, max_row=10, values_only=True), start=1):
    print(f"Row {i}: {row}")
```
