Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = load_workbook(input_path)
ws = wb.active  # assume single sheet

# Determine original data range (exclude any previously added result column)
orig_max_col = ws.max_column
orig_max_row = ws.max_row

# Check if the last column already contains our header; if so, reuse it
header_cell = ws.cell(row=1, column=orig_max_col)
if header_cell.value == "MinPosHeader":
    result_col_idx = orig_max_col
    # Do not insert a new column; just overwrite formulas
else:
    # Insert a new column after the last existing column
    result_col_idx = orig_max_col + 1
    ws.insert_cols(result_col_idx)
    ws.cell(row=1, column=result_col_idx, value="MinPosHeader")

# Column letters for original data columns (1 .. orig_max_col if result column not yet added)
data_start_col = 1
data_end_col = orig_max_col if result_col_idx != orig_max_col + 1 else orig_max_col

start_letter = get_column_letter(data_start_col)
end_letter = get_column_letter(data_end_col)

# Header range (absolute)
header_range = f"${start_letter}$1:${end_letter}$1"

# Write formula for each data row
for row in range(2, orig_max_row + 1):
    data_range = f"{start_letter}{row}:{end_letter}{row}"
    formula = (
        f"=_xlfn.TEXTJOIN(\",\", TRUE, IF({data_range}= _xlfn.AGGREGATE(15,6,{data_range}/({data_range}>0),1), "
        f"{header_range}, \"\"))"
    )
    ws.cell(row=row, column=result_col_idx, value=formula)

# Save workbook
wb.save(output_path)

# Recalculate formulas to cache values
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Verify a few rows (data_only)
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Sample output values:")
for r in range(2, min(6, orig_max_row + 1)):
    print(f"Row {r}:", ws_check.cell(row=r, column=result_col_idx).value)
