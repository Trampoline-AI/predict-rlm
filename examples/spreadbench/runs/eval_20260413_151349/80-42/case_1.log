2. Skip the header row and copy each data row's values from those columns into the next empty row of Consolidated_ALL, preserving the order of the highlighted columns left‑to‑right.
3. Copy the cell style (font, border, alignment, number format) so the layout matches existing rows, but we will not copy the yellow fill itself.
4. Write the originating sheet name into column L (the 12th column) of the consolidated row.
We will determine the first blank row in Consolidated_ALL, then append rows from each source sheet sequentially. Finally we will save the workbook to the required output directory. The code uses openpyxl and the standard library; no external calls are needed.
Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas as they are)
wb = load_workbook(input_path)

# Identify target sheet
target_sheet_name = "Consolidated_ALL"
if target_sheet_name not in wb.sheetnames:
    raise ValueError(f"Target sheet '{target_sheet_name}' not found in workbook")

target_ws = wb[target_sheet_name]

# Determine first empty row in target (skip any fully empty rows at the bottom)
# We'll consider a row empty if column A is empty
start_row = target_ws.max_row + 1
if start_row < 2:
    start_row = 2  # ensure at least row 2 (row 1 may be headers)

# Helper to detect yellow fill (typical ARGB for yellow is 'FFFFFF00' or 'FFFF00')

def is_yellow(fill: PatternFill) -> bool:
    # openpyxl stores the fill colour in fill.fgColor.rgb (ARGB) or fgColor.theme
    rgb = getattr(fill.fgColor, "rgb", None)
    if rgb:
        # Compare the last 6 hex digits (RGB) to 'FFFF00'
        return rgb[-6:].upper() == "FFFF00"
    # Some files use indexed colours; treat index 5 (yellow) as yellow if present
    if getattr(fill.fgColor, "type", None) == "indexed":
        return fill.fgColor.index == 5
    return False

# Process each source sheet except the target
for sheet_name in wb.sheetnames:
    if sheet_name == target_sheet_name:
        continue
    src_ws = wb[sheet_name]
    # Identify highlighted columns based on header row (row 1)
    highlighted_cols = []
    for col_idx in range(1, src_ws.max_column + 1):
        header_cell = src_ws.cell(row=1, column=col_idx)
        if is_yellow(header_cell.fill):
            highlighted_cols.append(col_idx)
    if not highlighted_cols:
        # No highlighted columns – skip this sheet
        continue
    # Copy data rows (starting from row 2)
    for src_row in range(2, src_ws.max_row + 1):
        # Check if the entire row is empty (all highlighted cells empty) – skip
        if all(src_ws.cell(row=src_row, column=c).value is None for c in highlighted_cols):
            continue
        # Write each highlighted column into target columns A, B, ... sequentially
        for tgt_col_idx, src_col_idx in enumerate(highlighted_cols, start=1):
            src_cell = src_ws.cell(row=src_row, column=src_col_idx)
            tgt_cell = target_ws.cell(row=start_row, column=tgt_col_idx)
            # Copy value
            tgt_cell.value = src_cell.value
            # Copy style (font, border, alignment, number format) – but not fill (to avoid yellow)
            tgt_cell.font = src_cell.font
            tgt_cell.border = src_cell.border
            tgt_cell.alignment = src_cell.alignment
            tgt_cell.number_format = src_cell.number_format
            tgt_cell.protection = src_cell.protection
        # Write originating sheet name into column L (12)
        sheet_name_cell = target_ws.cell(row=start_row, column=12)
        sheet_name_cell.value = sheet_name
        # Optional: copy style from first highlighted column for the sheet name cell (or leave default)
        # Increment target row for next entry
        start_row += 1

# Save the modified workbook to the output location
wb.save(output_path)

print(f"Consolidation complete. Output saved to: {output_path}")
