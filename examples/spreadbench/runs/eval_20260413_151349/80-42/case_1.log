```repl
import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

input_path = input_spreadsheet
wb = load_workbook(input_path, data_only=False)

# Helper to get a readable color string from a cell fill

def get_fill_rgb(fill):
    # openpyxl stores fill color in fill.fgColor
    fg = fill.fgColor
    # If rgb is set, return it
    if hasattr(fg, "rgb") and fg.rgb:
        return fg.rgb
    # If theme is set, return theme index
    if hasattr(fg, "theme") and fg.theme is not None:
        return f"theme:{fg.theme}"
    # If indexed color is used
    if hasattr(fg, "type") and fg.type == "indexed":
        return f"indexed:{fg.index}"
    return None

source_sheets = [name for name in wb.sheetnames if name not in ("Consolidate_ALL",)]
for sheet_name in source_sheets:
    ws = wb[sheet_name]
    print(f"\nSheet: {sheet_name}")
    for col_idx in range(1, ws.max_column + 1):
        cell = ws.cell(row=1, column=col_idx)
        rgb = get_fill_rgb(cell.fill)
        # Print only if there is a fill color (non‑None)
        if rgb:
            print(f"  Column {col_idx} fill: {rgb}")
