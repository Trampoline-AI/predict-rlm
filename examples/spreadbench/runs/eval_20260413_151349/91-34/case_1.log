import openpyxl, json, os

# Load the workbook for inspection (read_only=False to allow full access)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=True)
ws = wb.active

# Extract header row values (first row)
header = list(ws.iter_rows(min_row=1, max_row=1, values_only=True))[0]
print("Header:", header)

# Show first 5 data rows as dictionaries
sample_rows = []
for i, row_vals in enumerate(ws.iter_rows(min_row=2, max_row=6, values_only=True), start=2):
    row_dict = dict(zip(header, row_vals))
    sample_rows.append(row_dict)
print("Sample rows:", json.dumps(sample_rows, indent=2, default=str))

# Determine column indices (1-indexed) for columns of interest
cols_of_interest = ["Last Name", "First Name", "DOB", "Duplicate?", "Relationship"]
col_indices = {name: idx+1 for idx, name in enumerate(header) if name in cols_of_interest}
print("Column indices:", col_indices)
```
