import openpyxl

# Load the workbook (read only for faster inspection)
wb = openpyxl.load_workbook(input_spreadsheet, read_only=True, data_only=False)

print("Sheet names:", wb.sheetnames)

# Function to preview first few rows of a sheet

def preview_sheet(ws, max_rows=5):
    rows = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        rows.append(row)
        if i >= max_rows:
            break
    return rows

for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Sheet: {name} ---")
    # Get header (first row)
    header = next(ws.iter_rows(values_only=True))
    print("Header:", header)
    # Preview next few rows
    preview = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        if i == 0:
            continue  # skip header already captured
        preview.append(row)
        if i >= 5:
            break
    print("First rows:", preview)
