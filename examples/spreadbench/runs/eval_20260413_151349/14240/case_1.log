import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_14240_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_14240_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(filename=input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Identify column U (21)
col_idx = 21
col_letter = get_column_letter(col_idx)

# Helper to build corrected formula for a given row
def corrected_formula(row):
    # Row‑specific criteria cells
    # Column S (col 19) holds the first criterion (A column)
    # Column T (col 20) holds the second criterion (B column) ? Actually original uses S4 for B, T4 for header.
    # The original U4 uses R4, S4, T4. For other rows, they use $S5, $U$3, $T5, etc.
    # We'll follow the pattern observed:
    #   A column criterion: $S{row}
    #   B column criterion: $U$3 (fixed header for B? keep as is)
    #   Header criterion: $T{row}
    #   Data range: $C$4:$P$75 (columns 3‑16)
    #   Row criteria for A: $A$4:$A$75
    #   Row criteria for B: $B$4:$B$75
    #   Header range: $C$3:$P$3
    #   Data range: $C$4:$P$75
    # Build formula string:
    return (
        f"=SUMPRODUCT(($A$4:$A$75=$S{row})"
        f"*($B$4:$B$75=$U$3)"
        f"*($C$3:$P$3=$T{row})"
        f"*($C$4:$P$75)"
    )

# Update formulas in column U from row 4 to max_row
for r in range(4, ws.max_row + 1):
    cell = ws.cell(row=r, column=col_idx)
    # Only replace if the cell contains a SUMPRODUCT formula (case‑insensitive)
    if isinstance(cell.value, str) and "SUMPRODUCT" in cell.value.upper():
        new_form = corrected_formula(r)
        cell.value = new_form
        # Optional: print change for debugging (will be truncated in output)
        # print(f"Updated {col_letter}{r}: {new_form}")

# Save the modified workbook
wb.save(output_path)

