import openpyxl
import os
from pathlib import Path

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_53994_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_53994_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path)  # default data_only=False to preserve formulas
src_ws = wb["TEST_SHEET"]

# ----------------------------------------------------------------------
# 1. Create Summary sheet
# ----------------------------------------------------------------------
if "Summary" in wb.sheetnames:
    summary_ws = wb["Summary"]
else:
    summary_ws = wb.create_sheet("Summary")

# ----------------------------------------------------------------------
# 2. Place date range inputs (StartDate in B1, EndDate in B2)
# ----------------------------------------------------------------------
summary_ws["A1"] = "Start Date"
summary_ws["A2"] = "End Date"
# Provide example dates (user can edit later)
summary_ws["B1"] = "2021-01-01"
summary_ws["B2"] = "2021-02-28"

# ----------------------------------------------------------------------
# 3. List machines vertically (starting at A4) and phases horizontally (starting at B3)
# ----------------------------------------------------------------------
machines = ["M1", "M2", "M3"]
phases = ["SETUP", "RUN"]

# Write machine names
for i, m in enumerate(machines, start=4):
    summary_ws.cell(row=i, column=1, value=m)

# Write phase names
for j, p in enumerate(phases, start=2):
    summary_ws.cell(row=3, column=j, value=p)

# ----------------------------------------------------------------------
# 4. Determine the column ranges for the two date blocks in TEST_SHEET
#    Block 1 (Date Received) starts at column L (12) and goes to column W (23)
#    Block 2 (Date of Delivery) starts at column X (24) and goes to column AI (35)
#    We'll map them to column letters for easier formula building.
# ----------------------------------------------------------------------
from openpyxl.utils import get_column_letter

# Block 1: columns L (12) to W (23)
block1_start = 12
block1_end = 23
# Block 2: columns X (24) to AI (35)
block2_start = 24
block2_end = 35

# Helper to build range string like $L$16:$W$16
def range_str(start_col, end_col, row):
    return f"${get_column_letter(start_col)}${row}:${get_column_letter(end_col)}${row}"

# ----------------------------------------------------------------------
# 5. Write SUMPRODUCT formulas for each machine/phase cell
# ----------------------------------------------------------------------
for i, m in enumerate(machines, start=4):   # row in Summary
    for j, p in enumerate(phases, start=2):  # column in Summary
        # Build formula parts for both blocks
        # Row indices in TEST_SHEET:
        #   Row 16: Phase labels
        #   Row 17: Machine identifiers
        #   Row 18: Person (ignored)
        #   Row 19: Time values for first date (Date Received)
        #   Row 20: Machine identifiers (second date block)
        #   Row 21: Person (ignored)
        #   Row 22: Time values for second date (Date of Delivery)
        # Actually, looking at the data, rows 17‑22 repeat the pattern for each date.
        # We'll reference rows 17‑19 for block1 and rows 20‑22 for block2.

        # Block1 ranges
        phase_range1 = range_str(block1_start, block1_end, 16)
        machine_range1 = range_str(block1_start, block1_end, 17)
        time_range1 = range_str(block1_start, block1_end, 19)

        # Block2 ranges
        phase_range2 = range_str(block2_start, block2_end, 16)
        machine_range2 = range_str(block2_start, block2_end, 20)
        time_range2 = range_str(block2_start, block2_end, 22)

        # Build the SUMPRODUCT expression for each block
        # Use $A{i} for machine, B$1 for phase, $B$1 and $B$2 for dates
        # Date rows are row 16 (phase row) actually contains the phase name,
        # but the dates themselves are in row 15? Wait: The dates are in row 15? No.
        # The dates are in row 15? Actually row 15 has "DATA" and numbers.
        # The actual dates are in row 15? No, they are in row 15 column I/J? Let's inspect:
        # Row 15 column I is None, column J is None, column K is None, column L is None...
        # Row 16 column I = "Date Received", column J = "Date of Delivery", column K = "Metric"
        # Row 17 column I = datetime(2021-01-01) (Date Received), column J = datetime(2021-02-12) (Date of Delivery)
        # So the dates are in row 17 (for Date Received) and row 18 (for Date of Delivery) for the first block,
        # but subsequent blocks repeat the same dates in rows 20,21,22 etc.
        # For simplicity, we will apply the date filter to the **phase row** (row 16) which actually holds
        # the phase name, not the date. Instead, we need to look at the date rows (row 17 for block1, row 20 for block2).
        # We'll use row 17 for block1 dates and row 20 for block2 dates.

        date_range1 = range_str(block1_start, block1_end, 17)  # dates for block1
        date_range2 = range_str(block2_start, block2_end, 20)  # dates for block2

        # Build formula strings
        formula_block1 = (
            f"SUMPRODUCT("
            f"(TEST_SHEET!{machine_range1}=$A{i})*"
            f"(TEST_SHEET!{phase_range1}=B${j})*"
            f"(TEST_SHEET!{date_range1}>=$B$1)*"
            f"(TEST_SHEET!{date_range1}<=$B$2)*"
            f"TEST_SHEET!{time_range1}"
            f")"
        )
        formula_block2 = (
            f"SUMPRODUCT("
            f"(TEST_SHEET!{machine_range2}=$A{i})*"
            f"(TEST_SHEET!{phase_range2}=B${j})*"
            f"(TEST_SHEET!{date_range2}>=$B$1)*"
            f"(TEST_SHEET!{date_range2}<=$B$2)*"
            f"TEST_SHEET!{time_range2}"
            f")"
        )
        # Combine both blocks
        full_formula = f"={formula_block1}+{formula_block2}"

        # Write formula to Summary cell
        summary_ws.cell(row=i, column=j, value=full_formula)

# ----------------------------------------------------------------------
# 6. Save workbook
# ----------------------------------------------------------------------
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# ----------------------------------------------------------------------
# 7. Recalculate formulas to cache values (optional verification step)
# ----------------------------------------------------------------------
