import os
import openpyxl

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)

# Build lookup dictionaries for SH1 and RP1 (ID -> QTY)
def build_lookup(sheet_name):
    ws = wb[sheet_name]
    lookup = {}
    for r in range(2, ws.max_row + 1):
        id_val = ws.cell(row=r, column=2).value  # column B (ID)
        qty_val = ws.cell(row=r, column=3).value  # column C (QTY)
        if id_val is not None:
            lookup[id_val] = qty_val
    return lookup

sh1_lookup = build_lookup("SH1")
rp1_lookup = build_lookup("RP1")

# Fill merging sheet
merge_ws = wb["merging"]
for r in range(2, merge_ws.max_row + 1):
    id_val = merge_ws.cell(row=r, column=2).value  # column B (ID)
    # MONTH1 (C) from SH1
    qty1 = sh1_lookup.get(id_val, "-")
    if qty1 is None or qty1 == "":
        qty1 = "-"
    merge_ws.cell(row=r, column=3).value = qty1
    # MONTH2 (D) from RP1
    qty2 = rp1_lookup.get(id_val, "-")
    if qty2 is None or qty2 == "":
        qty2 = "-"
    merge_ws.cell(row=r, column=4).value = qty2

# Save to output location
wb.save(output_path)

# Quick verification: print first few rows of merging sheet after update
print("Verification of merging sheet (first 5 rows):")
for r in range(2, min(7, merge_ws.max_row + 1)):
    row_vals = [merge_ws.cell(row=r, column=c).value for c in range(1, merge_ws.max_column + 1)]
    print(f"Row {r}:", row_vals)
```
