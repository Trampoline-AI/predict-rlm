Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook for reading/writing
wb = openpyxl.load_workbook(input_path, data_only=False)

# ---------- 1. Accumulate totals from Transactions ----------
tx_ws = wb["Transactions"]

# Determine start row for data (skip the two header rows seen in preview)
data_start_row = 3  # 1‑based index

totals = {}  # {category: {month: sum_amount}}

for row in tx_ws.iter_rows(min_row=data_start_row, values_only=True):
    month = row[0]      # Column A
    amount = row[2]     # Column C
    category = row[3]   # Column D

    # Validate types
    if not (isinstance(month, str) and isinstance(category, str) and isinstance(amount, (int, float))):
        continue

    month = month.strip()
    category = category.strip()

    totals.setdefault(category, {})
    totals[category][month] = totals[category].get(month, 0) + amount

# ---------- 2. Locate month header row on 2022 ----------
sheet202_ws = wb["2022"]
month_names = ["January","February","March","April","May","June",
               "July","August","September","October","November","December"]

header_row_idx = None
month_to_col = {}  # name -> column index (1‑based)

for row in sheet202_ws.iter_rows(min_row=1, max_row=10):  # scan first few rows
    for cell in row:
        if isinstance(cell.value, str) and cell.value.strip() in month_names:
            header_row_idx = cell.row
            break
    if header_row_idx:
        break

if header_row_idx is None:
    raise RuntimeError("Could not find month header row on '2022' sheet.")

# Build mapping from month name to column index
for cell in sheet202_ws[header_row_idx]:
    if isinstance(cell.value, str):
        name = cell.value.strip()
        if name in month_names:
            month_to_col[name] = cell.column  # 1‑based index

# ---------- 3. Write totals into 2022 ----------
# Find rows where column A contains a category name (skip generic labels like "Income")
for row in sheet202_ws.iter_rows(min_row=1):
    cat_cell = row[0]  # column A
    if cat_cell.value and isinstance(cat_cell.value, str):
        cat_name = cat_cell.value.strip()
        if cat_name.upper() == "INCOME":
            continue
        cat_totals = totals.get(cat_name, {})
        for month, col_idx in month_to_col.items():
            amount = cat_totals.get(month, 0)
            sheet202_ws.cell(row=cat_cell.row, column=col_idx, value=amount)

# ---------- 4. Save workbook ----------
wb.save(output_path)

# ---------- 5. Verification ----------
verify_wb = openpyxl.load_workbook(output_path, data_only=True)
verify_ws = verify_wb["2022"]

print("Verification (first 5 category rows on 2022):")
shown = 0
for row in verify_ws.iter_rows(min_row=1):
    cat = row[0].value
    if cat and isinstance(cat, str) and cat.upper() != "INCOME":
        month_vals = [row[col_idx-1].value for col_idx in month_to_col.values()]
        print(f"Category: {cat}, totals: {month_vals}")
        shown += 1
        if shown >= 5:
            break
```
