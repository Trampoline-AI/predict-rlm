import openpyxl

# Load the workbook (read-only is fine for inspection)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)

# List sheet names
print("Sheets:", wb.sheetnames)

# Function to preview first N rows of a sheet
def preview_sheet(ws, n=5):
    rows = []
    for i, row in enumerate(ws.iter_rows(values_only=True), start=1):
        rows.append(row)
        if i >= n:
            break
    return rows

# Preview each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Preview of sheet '{name}' (first 5 rows) ---")
    preview = preview_sheet(ws, n=5)
    for r in preview:
        print(r)
```
2026-04-13 15:42:04,255 INFO RLM iteration 2/50
Reasoning: We inspected the input workbook. It contains two sheets: **Transactions** and **2022**.

- In **Transactions**, the first table (columns A‑D) holds month, description, amount, and category.  
- The **2022** sheet already has month headers (January‑December) in row 2 starting at column B, and category names (e.g., “Chickens”) in column A starting around row 7.  

The task is to total the amounts spent per month for each category and place those totals under the appropriate month column on the **2022** sheet.

Plan:
1. Load the workbook with openpyxl (read/write mode).
2. Scan the **Transactions** sheet, starting after the header rows, and accumulate sums in a nested dict `totals[category][month]`.
3. Map month names to column indices on the **2022** sheet using the header row.
4. Locate each category row on **2022** (non‑empty value in column A) and write the computed totals into the correct month cells.
5. Save the modified workbook to the output directory, preserving the original filename.
6. Reload the saved file with `data_only=True` and print a few sample totals to verify the write.

The following code implements these steps.
Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)  # provided variable
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)

# ---------- Step 1: accumulate totals from Transactions ----------
tx_ws = wb["Transactions"]

# Determine where data starts: first two rows are headers (based on preview)
start_row = 3  # row index (1‑based) where actual transaction rows begin

totals = {}  # {category: {month: sum_amount}}

for row in tx_ws.iter_rows(min_row=start_row, values_only=True):
    month = row[0]   # Column A
    # description = row[1]  # not needed
    amount = row[2]   # Column C
    category = row[3] # Column D

    # Skip rows that don't contain a proper transaction
    if not (isinstance(month, str) and isinstance(category, str) and isinstance(amount, (int, float))):
        continue

    month = month.strip()
    category = category.strip()

    totals.setdefault(category, {})
    totals[category][month] = totals[category].get(month, 0) + amount

# ---------- Step 2: map month names to column indices on 2022 ----------
sheet202_ws = wb["2022"]

# Header row with month names is row 2 (based on preview)
header_row_idx = 2
month_to_col = {}  # e.g., "January": 2 (column B)

for cell in sheet202_ws[header_row_idx]:
    if cell.value and isinstance(cell.value, str):
        name = cell.value.strip()
        # Only consider month names (ignore "Total" etc.)
        if name in ["January","February","March","April","May","June",
                    "July","August","September","October","November","December"]:
            month_to_col[name] = cell.column  # openpyxl column index (1‑based)

# ---------- Step 3: write totals into 2022 ----------
# Find rows where column A contains a category name (skip header rows)
for row in sheet202_ws.iter_rows(min_row=1):
    cat_cell = row[0]  # column A
    if cat_cell.value and isinstance(cat_cell.value, str):
        cat_name = cat_cell.value.strip()
        # Skip generic labels like "Income"
        if cat_name.upper() == "INCOME":
            continue
        # Get the dict of month totals for this category (may be empty)
        cat_totals = totals.get(cat_name, {})
        # Write each month total into the appropriate column
        for month, col_idx in month_to_col.items():
            amount = cat_totals.get(month, 0)
            sheet202_ws.cell(row=cat_cell.row, column=col_idx, value=amount)

# ---------- Step 4: save workbook ----------
wb.save(output_path)

# ---------- Step 5: verification ----------
# Reload with data_only to see the written numbers
verify_wb = openpyxl.load_workbook(output_path, data_only=True)
verify_ws = verify_wb["2022"]

# Print a few verification rows (first 5 category rows)
print("Verification (first 5 category rows on 2022):")
count = 0
for row in verify_ws.iter_rows(min_row=1):
    cat = row[0].value
    if cat and isinstance(cat, str) and cat.upper() != "INCOME":
        month_vals = [row[col_idx-1].value for col_idx in month_to_col.values()]
        print(f"Category: {cat}, totals: {month_vals}")
        count += 1
        if count >= 5:
            break
```
