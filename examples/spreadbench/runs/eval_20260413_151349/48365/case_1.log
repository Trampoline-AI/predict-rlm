Code:
```repl
import openpyxl, os, json

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_48365_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_48365_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb['Dashboard']

# Write the formula into D11 (row 11, column 4)
formula = (
    '=IF('
    'OR('
    'TRIM(C11)="", TRIM(C11)="All", '
    'TRIM(C12)="", TRIM(C12)="All", '
    'TRIM(C13)="", TRIM(C13)="All"'
    '), '
    'SUMIFS(Data!$C:$C, Data!$A:$A, $C$2), '
    'SUMPRODUCT('
    '(Data!$A:$A=$C$2)*('
    '(Data!$B:$B=C11)+(Data!$B:$B=C12)+(Data!$B:$B=C13)'
    '), '
    'Data!$C:$C'
    ')'
    ')'
)
ws.cell(row=11, column=4).value = formula  # D11

# Save the modified workbook
wb.save(output_path)

print('Formula written to D11:', formula)
print('Workbook saved to', output_path)
```
