import openpyxl, json, os

# Load the workbook
wb = openpyxl.load_workbook('/sandbox/input/input_spreadsheet/1_48365_init.xlsx')

# Gather sheet info
sheet_info = {}
for ws in wb.worksheets:
    # Get headers (first row)
