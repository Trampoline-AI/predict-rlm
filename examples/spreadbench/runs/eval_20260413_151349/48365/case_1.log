    # Sample first 5 rows of data (excluding header)
    rows = []
    for r in range(2, min(ws.max_row, 6)+1):
        row = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        rows.append(row)
    sheet_info[ws.title] = {
        'max_row': ws.max_row,
        'max_column': ws.max_column,
        'headers': headers,
        'sample_rows': rows,
    }

print(json.dumps(sheet_info, indent=2, default=str))
