Code:
```repl
import openpyxl
from pathlib import Path

output_path = Path("/sandbox/output/output_spreadsheet/1_192-22_init.xlsx")
wb = openpyxl.load_workbook(output_path, data_only=False)
ws = wb["Sheet1"] if "Sheet1" in wb.sheetnames else wb.active

billing_rows = []
blank_rows = []
for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=4, max_col=6):
    d_cell = row[0]  # column D
    f_cell = row[2]  # column F (since min_col=4 -> indices 0,1,2)
    d_val = d_cell.value
    f_val = f_cell.value
    if f_val == "Billing PO":
        billing_rows.append((d_cell.row, d_val, f_val))
    else:
        blank_rows.append((d_cell.row, d_val, f_val))

print(f"Total rows processed: {ws.max_row - 1}")
print(f"Rows with 'Billing PO' in column F: {len(billing_rows)}")
print(f"Rows without 'Billing PO' (blank) in column F: {len(blank_rows)}")
print("\nSample rows with 'Billing PO':")
for sample in billing_rows[:5]:
    print(sample)
