Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_15380_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_15380_init.xlsx"

# Load workbook for editing (data_only to get any cached values)
wb = openpyxl.load_workbook(input_path, data_only=True)
ws = wb["Sheet3"]  # the only sheet we need

# Helper to read a named range into a flat list of values
def read_named_range(name: str):
    if name not in wb.defined_names:
        raise KeyError(f"Named range '{name}' not found")
    values = []
    for sheet_name, range_str in wb.defined_names[name].destinations:
        sheet = wb[sheet_name]
        for row in sheet[range_str]:
            for cell in row:
                values.append(cell.value)
    return values

# Retrieve codes and months
codes = read_named_range("codes2")
months = read_named_range("month")

# Get the text from A3
a3_text = ws["A3"].value
if not isinstance(a3_text, str):
    raise ValueError("Cell A3 does not contain a string")

# Split A3 on underscores and find the first token that matches a code
matched_index = None
for token in a3_text.split("_"):
    if token in codes:
        matched_index = codes.index(token)  # index in the codes list
        break

# Write the corresponding month to B3 (or leave blank if no match)
if matched_index is not None and matched_index < len(months):
    ws["B3"].value = months[matched_index]
else:
    ws["B3"].value = ""  # no match found

# Save the modified workbook
wb.save(output_path)

# Verification prints (will appear in the REPL output)
print("A3:", a3_text)
print("Matched token:", token if matched_index is not None else None)
print("Written to B3:", ws["B3"].value)
```
