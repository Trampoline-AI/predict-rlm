Code:
```repl
import os
import re
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_28-7_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_28-7_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Identify the column to process.
# We'll look for the first column that has at least one cell matching ^400-.*.
target_col = None
for col in range(1, ws.max_column + 1):
    for row in range(2, ws.max_row + 1):
        val = ws.cell(row=row, column=col).value
        if isinstance(val, str) and re.match(r"^400-.*", val):
            target_col = col
            break
    if target_col:
        break

if target_col is None:
    # No column with 400- pattern found; nothing to do.
    print("No column with part numbers starting with '400-' found.")
else:
    col_letter = get_column_letter(target_col)
    print(f"Target column: {col_letter}")

    # Gather delete ranges (start_row, end_row_inclusive)
    delete_ranges = []
    row = 2
    max_row = ws.max_row
    while row <= max_row:
        cell_val = ws.cell(row=row, column=target_col).value
        if isinstance(cell_val, str) and re.fullmatch(r"^400-.*-A$", cell_val):
            start = row
            # Find next row after start where cell matches ^400-.* (any part number)
            nxt = row + 1
            while nxt <= max_row:
                nxt_val = ws.cell(row=nxt, column=target_col).value
                if isinstance(nxt_val, str) and re.match(r"^400-.*", nxt_val):
                    break
                nxt += 1
            end = nxt - 1  # inclusive; if nxt > max_row, end = max_row
            delete_ranges.append((start, end))
            # Move row pointer past this range to avoid overlapping detection
            row = nxt
        else:
            row += 1

    # Delete ranges from bottom to top
    for start, end in sorted(delete_ranges, key=lambda x: x[0], reverse=True):
        amount = end - start + 1
        print(f"Deleting rows {start} to {end} (amount={amount})")
        ws.delete_rows(start, amount)

# Save the modified workbook
wb.save(output_path)

# Verify by reloading with data_only and printing first few rows of the target column
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Post‑deletion sample (first 15 rows of target column):")
sample = [ws_check.cell(row=r, column=target_col).value for r in range(1, min(ws_check.max_row, 15) + 1)]
print(sample)
```
