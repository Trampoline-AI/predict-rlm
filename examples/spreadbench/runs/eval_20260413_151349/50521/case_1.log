ws[f"{new_col_letter}1"] = "BlanksBetweenFirstTwoNumbers"

# Build and write the formula for each row
for row in range(2, ws.max_row + 1):
    row_range = f"{first_col_letter}{row}:{last_col_letter}{row}"
    first_cell = f"{first_col_letter}{row}"
    # Formula:
    # 1) MATCH(1, INDEX(ISNUMBER(row_range),0),0)  -> position of first numeric
    # 2) OFFSET(first_cell,0, that_position)       -> reference to first numeric cell
    # 3) MATCH(1, INDEX(ISNUMBER(OFFSET(first_cell,0, first_position)),0),0) -> offset to second numeric
    # 4) OFFSET(first_cell,0, first_position,1, second_position-first_position) -> range between them
    # 5) COUNTBLANK on that range, wrapped in IFERROR
    formula = (
        f"=IFERROR(COUNTBLANK("
        f"OFFSET({first_cell},0,"
        f"MATCH(1,INDEX(ISNUMBER({row_range}),0),0),"
        f"1,"
        f"MATCH(1,INDEX(ISNUMBER(OFFSET({first_cell},0,"
        f"MATCH(1,INDEX(ISNUMBER({row_range}),0),0))),0),0)"
        f"-MATCH(1,INDEX(ISNUMBER({row_range}),0),0))),\"\"))"
    )
    ws[f"{new_col_letter}{row}"] = formula

# Save the workbook
