import openpyxl
from pathlib import Path

# Load the workbook
input_path = Path("/sandbox/input/input_spreadsheet/1_120-24_init.xlsx")
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume the first sheet is the target

# Helper to convert column letters to numbers (openpyxl already 1‑indexed)
def col_letter_to_index(letter: str) -> int:
    return openpyxl.utils.column_index_from_string(letter)

# Determine column indices for BL, BG, AY
cols = {"BL": col_letter_to_index("BL"),
        "BG": col_letter_to_index("BG"),
        "AY": col_letter_to_index("AY")}
print("Column indices:", cols)

# Print header row (first row) for reference
header = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
print("Header (first 20 columns):", header[:20])

# Show a few sample rows (rows 2‑5) for the three columns of interest
samples = []
for r in range(2, min(6, ws.max_row + 1)):
    bl = ws.cell(row=r, column=cols["BL"]).value
    bg = ws.cell(row=r, column=cols["BG"]).value
    ay = ws.cell(row=r, column=cols["AY"]).value
    samples.append((r, bl, bg, ay))
print("Sample rows (row, BL, BG, AY):", samples)
