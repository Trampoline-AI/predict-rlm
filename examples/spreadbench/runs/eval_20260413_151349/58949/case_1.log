Code:
```repl
import openpyxl
from pathlib import Path
from collections import defaultdict

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_58949_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_58949_init.xlsx"

# Load workbook (read_only values)
wb = openpyxl.load_workbook(input_path, data_only=True)

# Source sheet
src_ws = wb["Extract"]

# Target sheet name
tgt_ws_name = "Desired Result"

# Get or create target sheet, clearing any existing content
if tgt_ws_name in wb.sheetnames:
    tgt_ws = wb[tgt_ws_name]
    # Clear existing cells
    for row in tgt_ws.iter_rows(min_row=1, max_row=tgt_ws.max_row):
        for cell in row:
            cell.value = None
else:
    tgt_ws = wb.create_sheet(tgt_ws_name)

# Identify column indices from header row
header = [src_ws.cell(row=1, column=c).value for c in range(1, src_ws.max_column + 1)]
person_col = header.index("Person") + 1
car_col = header.index("Car") + 1
value_col = header.index("Value") + 1

# Collect rows per Person
person_data = defaultdict(list)  # Person -> list of (Car, Value)
for r in range(2, src_ws.max_row + 1):
    person = src_ws.cell(row=r, column=person_col).value
    car = src_ws.cell(row=r, column=car_col).value
    value = src_ws.cell(row=r, column=value_col).value
    if person is not None:
        person_data[person].append((car, value))

# Determine maximum number of detail pairs for any Person
max_pairs = max((len(v) for v in person_data.values()), default=0)

# Build dynamic header: Person, Car1, Value1, Car2, Value2, ...
header_row = ["Person"]
for i in range(1, max_pairs + 1):
    header_row.append(f"Car{i}")
    header_row.append(f"Value{i}")

# Write header to target sheet
for c, val in enumerate(header_row, start=1):
    tgt_ws.cell(row=1, column=c, value=val)

# Write each Person's data row
out_row = 2
for person, details in person_data.items():
    tgt_ws.cell(row=out_row, column=1, value=person)
    col_idx = 2
    for car, val in details:
        tgt_ws.cell(row=out_row, column=col_idx, value=car)
        tgt_ws.cell(row=out_row, column=col_idx + 1, value=val)
        col_idx += 2
    out_row += 1

# Save transformed workbook
wb.save(output_path)
print("Saved transformed workbook to", output_path)
```
