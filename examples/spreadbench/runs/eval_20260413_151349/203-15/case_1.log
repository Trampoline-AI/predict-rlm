while True:
    val = main_ws.cell(row=row, column=8).value
    if val is None:
        break
    allowances.append(val)
    row += 1

# 3. Write allowances transposed starting at column H (8) in row 1 (after existing headers)
start_col = 8
for idx, allowance in enumerate(allowances):
    out_ws.cell(row=1, column=start_col + idx).value = allowance

# Save workbook to output path
