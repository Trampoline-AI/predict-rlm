```repl
import openpyxl
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Assume the main sheet is the first one (or named 'Main')
main_ws = wb[wb.sheetnames[0]]

# 1. Gather distinct allowance types from column H (starting row 2)
allowance_types = []
row = 2
while True:
    val = main_ws.cell(row=row, column=8).value  # column H
    if val is None:
        break
    if val not in allowance_types:
        allowance_types.append(val)
    row += 1

# 2. Build staff mapping
# Key: staff no. (column A). Value: dict with base data (A‑G) and allowances dict
staff_data = {}
row = 2
while True:
    staff_no = main_ws.cell(row=row, column=1).value  # column A
    if staff_no is None:
        break
    # Base columns A‑G
    base_vals = [main_ws.cell(row=row, column=c).value for c in range(1, 8)]
    allowance = main_ws.cell(row=row, column=8).value
    amount = main_ws.cell(row=row, column=9).value  # column I
    # Initialize entry if first occurrence
    if staff_no not in staff_data:
        staff_data[staff_no] = {
            "base": base_vals,
            "allowances": {}
        }
    # Store amount for this allowance type (overwrite if duplicate, assume one per type)
    staff_data[staff_no]["allowances"][allowance] = amount
    row += 1

# 3. Ensure output sheet exists
output_sheet_name = "Output Required"
if output_sheet_name in wb.sheetnames:
    out_ws = wb[output_sheet_name]
else:
    out_ws = wb.create_sheet(title=output_sheet_name)

# 4. Write headers: copy A1:G1
for col in range(1, 8):
    out_ws.cell(row=1, column=col).value = main_ws.cell(row=1, column=col).value

# Write allowance type headers starting at column H (8)
for idx, atype in enumerate(allowance_types):
    out_ws.cell(row=1, column=8 + idx).value = atype

# 5. Write staff rows
out_row = 2
for staff_no, info in staff_data.items():
    # Write base columns A‑G
    for col_idx, val in enumerate(info["base"], start=1):
        out_ws.cell(row=out_row, column=col_idx).value = val
    # Write allowance amounts under the correct columns
    for idx, atype in enumerate(allowance_types):
        amount = info["allowances"].get(atype)
        out_ws.cell(row=out_row, column=8 + idx).value = amount
    out_row += 1

# Save workbook
wb.save(output_path)

# Verification: reload and print first few rows of the output sheet
wb_check = openpyxl.load_workbook(output_path, data_only=True)
out_ws_check = wb_check[output_sheet_name]

# Print headers
headers = [out_ws_check.cell(row=1, column=c).value for c in range(1, out_ws_check.max_column + 1)]
print("Output headers:", headers)

# Print first 3 staff rows
for r in range(2, min(5, out_ws_check.max_row + 1)):
    row_vals = [out_ws_check.cell(row=r, column=c).value for c in range(1, out_ws_check.max_column + 1)]
    print(f"Row {r}:", row_vals)
```
