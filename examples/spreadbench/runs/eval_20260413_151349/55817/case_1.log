import openpyxl
from pathlib import Path

# Load the workbook
wb_path = Path(input_spreadsheet)
wb = openpyxl.load_workbook(wb_path)
ws = wb[wb.sheetnames[0]]

# Collect all non‑empty values from column A (starting at row 1)
col_a_vals = [ws.cell(row=r, column=1).value for r in range(1, ws.max_row + 1)]
# Optionally filter out None values if they should be skipped; keep order including blanks as they appear
# For this task we will transpose all cells, preserving None as empty cells.

# Write the transposed values into row 2, starting at column B (column index 2)
start_row = 2
start_col = 2  # column B
for idx, val in enumerate(col_a_vals):
    ws.cell(row=start_row, column=start_col + idx, value=val)

# Save to the output directory with the same filename
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_spreadsheet).name
wb.save(output_path)

print(f"Transposed {len(col_a_vals)} values into row {start_row} starting at column B. Output saved to {output_path}")
```
