Code:
```repl
import openpyxl, json, os

# Load the workbook (read only for inspection)
wb_path = '/sandbox/input/input_spreadsheet/1_31746_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=True)

# Gather basic info
sheets_info = []
for ws in wb.worksheets:
    # Get header row (first non-empty row)
    header = []
    for row in ws.iter_rows(min_row=1, max_row=1, values_only=True):
        header = [str(cell) if cell is not None else '' for cell in row]
        break
    # Sample first 5 data rows after header
    samples = []
    for i, row in enumerate(ws.iter_rows(min_row=2, max_row=6, values_only=True), start=2):
        samples.append([cell for cell in row])
    sheets_info.append({
        'title': ws.title,
        'max_row': ws.max_row,
        'max_column': ws.max_column,
        'header': header,
        'samples': samples,
    })

print(json.dumps(sheets_info, indent=2))
```
2026-04-13 15:39:46,367 INFO RLM iteration 2/50
Reasoning: We inspected the workbook and found a single sheet with a header row (row 2) that includes month columns named like "Month 12", "Month 13", ..., "Month 78". The instruction requires computing, for each row, the total cost savings as sum over each month column of (81 - (month-1)) * saving = (82 - month) * saving. We'll add a new column after the existing "Priced in productivity" column, label it "Total Cost Savings", compute the value for each data row, write it, and save the workbook to the output directory. After saving, we'll reload the file (data_only=True) and print a few sample results to verify.
Code:
```repl
import os, openpyxl, re

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_31746_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_31746_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook for editing (keep formulas if any)
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assuming the first sheet is the target

# Identify header row (row 2) and month columns
header_row = 2
month_cols = []  # list of (col_idx, month_number)
for cell in ws[header_row]:
    if isinstance(cell.value, str) and cell.value.startswith('Month'):
        # Extract month number
        m = re.search(r"Month\s*(\d+)", cell.value)
        if m:
            month = int(m.group(1))
            month_cols.append((cell.column, month))

# Determine column index for new result (after last existing column)
last_col = ws.max_column
result_col = last_col + 1
# Write header for result column
ws.cell(row=header_row, column=result_col, value='Total Cost Savings')

# Compute total savings for each data row (starting at row 3)
for row in ws.iter_rows(min_row=header_row+1, max_row=ws.max_row, min_col=1, max_col=last_col, values_only=False):
    total = 0.0
    for col_idx, month in month_cols:
        cell = ws.cell(row=row[0].row, column=col_idx)
        val = cell.value
        if isinstance(val, (int, float)):
            total += (82 - month) * val
    # Write total to result column
    ws.cell(row=row[0].row, column=result_col, value=total)

# Save to output path
wb.save(output_path)

# Verify by reloading with data_only and printing first few totals
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print('Verification (first 5 rows total savings):')
for r in range(3, min(8, ws_check.max_row+1)):
    print(f'Row {r}:', ws_check.cell(row=r, column=result_col).value)
```
