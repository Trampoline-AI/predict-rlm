import openpyxl, os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_50768_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet'
output_path = os.path.join(output_dir, '1_50768_init.xlsx')

# Load workbook (the one we just saved)
wb = openpyxl.load_workbook(output_path, data_only=False)

# Identify the data sheet (original)
data_ws = wb[wb.sheetnames[0]]  # assuming first sheet is the original data

# Header row is row 3, data starts at row 4
header_row = 3
id_col, impact_col, likelihood_col = 1, 2, 3

# Gather all IDs from source
source_ids = []
for r in range(header_row + 1, data_ws.max_row + 1):
    risk_id = data_ws.cell(row=r, column=id_col).value
    impact = data_ws.cell(row=r, column=impact_col).value
    likelihood = data_ws.cell(row=r, column=likelihood_col).value
    if risk_id is None or impact is None or likelihood is None:
        continue
    source_ids.append(str(risk_id))

# Gather all IDs placed in matrix
matrix_ws = wb['Matrix']
matrix_ids = []
for r in range(2, matrix_ws.max_row + 1):  # skip header row
    for c in range(2, matrix_ws.max_column + 1):  # skip impact label column
        cell_val = matrix_ws.cell(row=r, column=c).value
        if cell_val:
            # split by commas and strip whitespace
            matrix_ids.extend([pid.strip() for pid in cell_val.split(',')])

# Summary
print(f"Total IDs in source: {len(source_ids)}")
print(f"Total IDs placed in matrix: {len(matrix_ids)}")
missing = set(source_ids) - set(matrix_ids)
print(f"Missing IDs (should be empty): {missing}")

# Quick sanity check: ensure matrix dimensions are 3x3 (excluding labels)
expected_rows = 4  # header + 3 impact rows
expected_cols = 4  # label column + 3 likelihood columns
print(f"Matrix size (rows x cols): {matrix_ws.max_row} x {matrix_ws.max_column}")
print(f"Expected size: {expected_rows} x {expected_cols}")
