import openpyxl, os, json, itertools, textwrap, sys
from pathlib import Path

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_42181_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# Gather basic info
sheets_info = {}
for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    # sample first 5 rows values (including formulas)
    sample = []
    for r in range(1, min(6, max_row+1)):
        row_vals = []
        for c in range(1, min(6, max_col+1)):
            cell = ws.cell(row=r, column=c)
            if cell.value is None:
                val = None
            elif isinstance(cell.value, str) and cell.value.startswith("="):
                val = {"formula": cell.value}
            else:
                val = cell.value
            row_vals.append(val)
        sample.append(row_vals)
    sheets_info[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "sample_rows": sample,
    }

# Print summary
print("Workbook loaded:", wb_path)
print("Sheets:", list(wb.sheetnames))
print("Sheet details (first 5 rows, first 5 cols):")
print(json.dumps(sheets_info, indent=2, ensure_ascii=False)[:2000])
