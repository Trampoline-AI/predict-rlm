import openpyxl
from openpyxl import load_workbook
from datetime import datetime, timedelta
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook
wb = load_workbook(input_path)
ws = wb.active  # assume single sheet

# ----------------------------------------------------------------------
# 1. Inspect original header (row 1) in columns A‑C
# ----------------------------------------------------------------------
orig_header = [ws.cell(row=1, column=c).value for c in range(1, 4)]
print("Original header row A‑C:", orig_header)

