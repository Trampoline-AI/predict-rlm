# 2. Build date → value mapping from E1:F6
# ----------------------------------------------------------------------
dates_vals = {}
for row in ws.iter_rows(min_row=1, max_row=6, min_col=5, max_col=6, values_only=True):
    d, v = row
    # Normalize date to datetime.date
    if isinstance(d, datetime):
        d = d.date()
    elif isinstance(d, str):
        for fmt in ("%m/%d/%Y", "%Y-%m-%d", "%d-%b-%Y"):
            try:
                d = datetime.strptime(d, fmt).date()
                break
            except ValueError:
                continue
    if isinstance(d, datetime):
        d = d.date()
    if isinstance(d, datetime.date):
        dates_vals[d] = v

print(f"Loaded {len(dates_vals)} date/value pairs from E1:F6.")
print("Sample mapping (first 3):", list(dates_vals.items())[:3])

# ----------------------------------------------------------------------
