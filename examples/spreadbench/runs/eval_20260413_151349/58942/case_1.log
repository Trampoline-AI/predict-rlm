# ----------------------------------------------------------------------
ws.cell(row=1, column=1, value="Date")
ws.cell(row=1, column=2, value="SourceDate")
ws.cell(row=1, column=3, value="SourceValue")

# ----------------------------------------------------------------------
# 5. Populate timeline (daily) starting at row 2
# ----------------------------------------------------------------------
start_date = datetime(2018, 1, 1).date()
end_date   = datetime(2020, 12, 31).date()
delta = timedelta(days=1)

row_idx = 2  # start after header
current = start_date
while current <= end_date:
    ws.cell(row=row_idx, column=1, value=current)  # Column A = timeline date
    if current in dates_vals:
        # Write the original source date (same as current) and its value
        ws.cell(row=row_idx, column=2, value=current)          # SourceDate
        ws.cell(row=row_idx, column=3, value=dates_vals[current])  # SourceValue
    row_idx += 1
    current += delta

total_rows = row_idx - 1
print(f"Timeline written: {total_rows} data (including header).")

# ----------------------------------------------------------------------
# 6. Save workbook
# ----------------------------------------------------------------------
wb.save(output_path)
print(f"Workbook saved to: {output_path}")

# ----------------------------------------------------------------------
