import openpyxl
from datetime import date, timedelta
from pathlib import Path

output_path = Path("/sandbox/output/output_spreadsheet/1_58942_init.xlsx")
wb = openpyxl.load_workbook(output_path, data_only=True)
ws = wb.active

# Compute row index for a specific date (e.g., 2019-01-03)
target_date = date(2019, 1, 3)
start_date = date(2018, 1, 1)
row_index = 2 + (target_date - start_date).days  # row 2 is start_date

a = ws.cell(row=row_index, column=1).value
b = ws.cell(row=row_index, column=2).value
c = ws.cell(row=row_index, column=3).value
print(f"Row for {target_date} (index {row_index}): A={a}, B={b}, C={c}")

# Also print a few rows around it for context
print("\nRows around the target date:")
for r in range(row_index - 2, row_index + 3):
    a = ws.cell(row=r, column=1).value
    b = ws.cell(row=r, column=2).value
    c = ws.cell(row=r, column=3).value
    print(f"Row {r}: A={a}, B={b}, C={c}")
```
