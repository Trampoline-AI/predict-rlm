import openpyxl

# Load the workbook (read/write mode)
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path)

# Assume the first sheet is the target
ws = wb.active

print(f"Sheet name: {ws.title}")
print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")

# Examine the first 10 rows of column G (index 7)
for r in range(1, min(ws.max_row, 10) + 1):
    cell = ws.cell(row=r, column=7)
    # Get fill color (RGB) – may be None if no fill
    fill = cell.fill
    rgb = fill.start_color.rgb if fill.start_color.type == "rgb" else None
    print(f"Row {r}: value={cell.value!r}, fill_rgb={rgb}")
```
2026-04-13 15:15:54,978 INFO RLM iteration 2/50
Reasoning: We inspected the workbook and found that column G (index 7) contains formulas beginning with `=CONCATENATE(`. The fill color for highlighted rows is yellow, represented by the RGB code `FFFFFF00` (or any code ending with `FF00`).  

The task is to prepend the literal string `"//"` to the concatenated result, but only for rows whose column‑G cell has the yellow fill. The easiest way is to modify the formula string: replace the leading `=CONCATENATE(` with `=CONCATENATE("//", `, keeping the rest of the original arguments unchanged.

Implementation steps:
1. Load the input workbook (read/write mode).
2. Iterate over all rows in column G.
3. Detect a yellow fill via `cell.fill.start_color.rgb`.
4. If the cell contains a `CONCATENATE` formula, rewrite it to include `"//"` as the first argument.
5. Save the modified workbook to the output directory, preserving the original filename.
6. Reload the saved file with `data_only=True` and print a few sample rows to confirm the change.

The code below follows these steps and prints a short verification after saving.
Code:
```repl
import os
import openpyxl

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume the first sheet is the target

def is_yellow(fill):
    """Return True if the fill color is yellow (RGB ending with FF00)."""
    if fill is None:
        return False
    # openpyxl stores colors as ARGB strings, e.g., 'FFFFFF00'
    rgb = fill.start_color.rgb
    return rgb is not None and rgb.upper().endswith("FF00")

# Process column G (index 7)
for row in range(1, ws.max_row + 1):
    cell = ws.cell(row=row, column=7)
    # Check fill color
    if is_yellow(cell.fill):
        # Ensure we have a formula that starts with =CONCATENATE(
        if isinstance(cell.value, str) and cell.value.startswith("=CONCATENATE("):
            # Extract the inner part after the opening parenthesis
            inner = cell.value[len("=CONCATENATE("):]  # everything after '('
            # Build new formula with "//" as first argument
            new_formula = f'=CONCATENATE("//", {inner}'
            cell.value = new_formula
            # Optional: you could also set the fill to keep the highlight
            # (no change needed)
        else:
            # Not a CONCATENATE formula; skip or handle as needed
            pass

# Save to output location
wb.save(output_path)

# Verify by reloading with data_only (cached values) and printing a few rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification (first 5 rows of column G after change):")
for r in range(1, min(ws_check.max_row, 5) + 1):
    cell = ws_check.cell(row=r, column=7)
    print(f"Row {r}: value={cell.value!r}")
```
