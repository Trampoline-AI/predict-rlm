Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_42216_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_42216_init.xlsx"

# Load the workbook we saved earlier
wb = openpyxl.load_workbook(output_path)
ws = wb.active  # original sheet (Group A)
groupb_ws = wb["GroupB"]

# -------------------------------------------------
# Verify April row in Group A (should have blanks for zeros)
# -------------------------------------------------
# Find the April row index (last row)
april_row_idx = ws.max_row
april_label_cell = ws.cell(row=april_row_idx, column=1).value
print(f"April row label: {april_label_cell}")

# Collect first 10 day cells in April row
april_day_vals = [ws.cell(row=april_row_idx, column=c).value for c in range(2, 12)]
print("April row first 10 day values (Group A):", april_day_vals)

# -------------------------------------------------
# Verify April column in GroupB (should keep zeros)
# -------------------------------------------------
# Find April column index in GroupB (header row)
april_col_idx = None
for c in range(2, groupb_ws.max_column + 1):
    if groupb_ws.cell(row=1, column=c).value == "April":
        april_col_idx = c
        break
print(f"April column index in GroupB: {april_col_idx}")

# Collect first 10 day values for April column in GroupB
april_col_vals = [groupb_ws.cell(row=r, column=april_col_idx).value for r in range(2, 12)]
print("April column first 10 day values (GroupB):", april_col_vals)

# -------------------------------------------------
# Verify that -9999 / -99999 / 'M' are blank in GroupB
# -------------------------------------------------
# Scan a few rows/columns for these values
issues = []
for r in range(2, min(groupb_ws.max_row, 20)):
    for c in range(2, min(groupb_ws.max_column, 10)):
        val = groupb_ws.cell(row=r, column=c).value
        if val in (-9999, -99999, "M"):
            issues.append((r, c, val))
print("Irrelevant values still present in GroupB (should be none):", issues)

# -------------------------------------------------
# Save (overwrites same file) and confirm save
# -------------------------------------------------
wb.save(output_path)
print("Verification complete, workbook saved.")
```
