import openpyxl
from pathlib import Path

# Paths
output_dir = Path("/sandbox/output/output_spreadsheet")
output_path = output_dir / Path(input_spreadsheet).name

# Load the workbook for editing (read/write)
wb = openpyxl.load_workbook(output_path)
ws = wb[wb.sheetnames[0]]

# Header row identified earlier as row 3
header_row = 3

# Determine column indices by header names
headers = [ws.cell(row=header_row, column=c).value for c in range(1, ws.max_column + 1)]
col_map = {h: idx + 1 for idx, h in enumerate(headers) if isinstance(h, str)}
date_col = col_map.get("Date")
beans_col = col_map.get("Beans Counted")
avg_col = col_map.get("12 month rolling average")

if not (date_col and beans_col and avg_col):
    raise ValueError("Required columns not found in header row")

# Correct formula string (use single quotes for Python string)
formula = '=AVERAGEIFS([Beans Counted], [Date], ">=" & ([@Date] - 365), [Date], "<=" & [@Date])'

# Insert the formula for each data row (rows after the header)
last_row = ws.max_row
for row in range(header_row + 1, last_row + 1):
    ws.cell(row=row, column=avg_col).value = formula

# Save the corrected workbook
wb.save(output_path)
print(f"Corrected workbook saved to {output_path}")

# Recalculate formulas
