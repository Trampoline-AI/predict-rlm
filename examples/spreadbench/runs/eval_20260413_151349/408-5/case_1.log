```repl
import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (default to the active sheet)
wb = load_workbook(input_path)
ws = wb.active

# Variables to collect
sum_D = 0
br1_row = None
rows_to_delete = set()

# Iterate over rows (skip header row if present; start at row 2)
for row in ws.iter_rows(min_row=2, max_row=ws.max_row, max_col=ws.max_col):
    # Column indices: A=1, B=2, C=3, D=4, E=5 -> zero‑based list indices 0‑4
    c_val = row[2].value   # Column C
    d_cell = row[3]        # Column D cell (for value and row number)
    e_cell = row[4]        # Column E cell

    # Detect the 'BR1 Sales' reference row
    if c_val == "BR1 Sales":
        br1_row = d_cell.row

    # If Column E is zero, add Column D value to the sum
    if e_cell.value == 0:
        if isinstance(d_cell.value, (int, float)):
            sum_D += d_cell.value
        # Mark for deletion unless this is the BR1 Sales row
        if c_val != "BR1 Sales":
            rows_to_delete.add(d_cell.row)

    # Detect completely blank rows (all cells empty or None)
    if all(cell.value in (None, "") for cell in row):
        rows_to_delete.add(d_cell.row)

# Insert the computed sum into Column D of the BR1 Sales row (if found)
if br1_row is not None:
    ws.cell(row=br1_row, column=4, value=sum_D)

# Delete rows from bottom to top to preserve indices
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r)

# Save the modified workbook
wb.save(output_path)

print(f"Saved transformed workbook to {output_path}")
print(f"Sum of D where E==0: {sum_D}")
print(f"BR1 Sales row: {br1_row}")
print(f"Rows deleted: {sorted(rows_to_delete)}")
```
