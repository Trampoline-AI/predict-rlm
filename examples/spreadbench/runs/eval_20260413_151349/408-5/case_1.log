Code:
```repl
import os
from openpyxl import load_workbook

# -------------------------------------------------
# Paths
# -------------------------------------------------
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# -------------------------------------------------
# Load workbook
# -------------------------------------------------
wb = load_workbook(input_path)
ws = wb.active

# -------------------------------------------------
# 1️⃣ Locate the row with "BR1 Sales" in Column C
# -------------------------------------------------
br1_row = None
target_text = "br1 sales"
for r in range(1, ws.max_row + 1):
    cell_val = ws.cell(row=r, column=3).value  # Column C
    if isinstance(cell_val, str):
        # Strip whitespace, lower‑case, and allow the target to be a substring
        if target_text in cell_val.strip().lower():
            br1_row = r
            break

print(f"BR1 Sales row found at: {br1_row}")

# -------------------------------------------------
# 2️⃣ Compute sum of Column D where Column E == 0
#    and collect rows to delete
# -------------------------------------------------
sum_D = 0.0
rows_to_delete = set()

for r in range(1, ws.max_row + 1):
    # Values for this row
    c_val = ws.cell(row=r, column=3).value
    d_cell = ws.cell(row=r, column=4)   # Column D
    e_val = ws.cell(row=r, column=5).value  # Column E

    # ----- Sum condition -----
    if e_val == 0 or e_val == "0":
        if isinstance(d_cell.value, (int, float)):
            sum_D += d_cell.value
        # Mark for deletion unless this is the BR1 Sales row
        if r != br1_row:
            rows_to_delete.add(r)

    # ----- Blank‑row detection (all cells empty or None) -----
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    if all(v in (None, "") for v in row_vals):
        rows_to_delete.add(r)

# -------------------------------------------------
# 3️⃣ Write the computed sum into Column D of the BR1 Sales row
# -------------------------------------------------
if br1_row is not None:
    ws.cell(row=br1_row, column=4, value=sum_D)
    print(f"Inserted sum {sum_D} into D{br1_row}")
else:
    print("Warning: BR1 Sales row not found – sum not inserted.")

# -------------------------------------------------
# 4️⃣ Delete rows (bottom‑to‑top to keep indices stable)
# -------------------------------------------------
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r)

print(f"Deleted {len(rows_to_delete)} rows (including blanks).")

# -------------------------------------------------
# 5️⃣ Save the transformed workbook
# -------------------------------------------------
wb.save(output_path)
print(f"Saved transformed workbook to {output_path}")
```
