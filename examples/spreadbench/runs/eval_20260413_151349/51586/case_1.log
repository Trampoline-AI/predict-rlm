import openpyxl
from openpyxl import load_workbook

# Load the workbook (read only is fine for inspection)
wb_path = input_spreadsheet  # variable provided by the system
wb = load_workbook(wb_path, data_only=False)  # keep formulas

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Inspect the first sheet (likely Sheet1)
ws = wb[wb.sheetnames[0]]
print("Active sheet title:", ws.title)

# Print column headers (first row)
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
print("Headers (row 1):", headers)

# Print first few rows with values and fill colors for columns A, B, C
print("First 5 rows (A, B, C values and fill colors):")
for r in range(2, min(ws.max_row, 6)):
    a_cell = ws.cell(row=r, column=1)
    b_cell = ws.cell(row=r, column=2)
    c_cell = ws.cell(row=r, column=3)
    def fmt(cell):
        # Get fill color if present (rgb)
        fill = cell.fill
        color = fill.start_color.rgb if fill and fill.start_color else None
        return f"value={cell.value!r}, fill={color}"
    print(f"Row {r}: A={fmt(a_cell)}, B={fmt(b_cell)}, C={fmt(c_cell)}")
