import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_130-9_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_130-9_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheet names (as discovered)
src_name = "cdnr"
dest_name = "b2b, sez, de"
src_ws = wb[src_name]
dest_ws = wb[dest_name]

# Helper: find header row (first row where column A == "A")

def find_header_row(ws):
    for r in range(1, ws.max_row + 1):
        if ws.cell(row=r, column=1).value == "A":
            return r
    raise ValueError(f"Header row not found in sheet {ws.title}")

src_header_row = find_header_row(src_ws)
dest_header_row = find_header_row(dest_ws)

# Build header -> column index maps (1‑based column numbers)

def header_map(ws, header_row):
    mapping = {}
    for col in range(1, ws.max_column + 1):
        val = ws.cell(row=header_row, column=col).value
        if isinstance(val, str) and val:
            mapping[val] = col
    return mapping

src_header_map = header_map(src_ws, src_header_row)
est_header_map = header_map(dest_ws, dest_header_row)

# Determine first empty row in destination (first row after header where column A is empty)
first_empty_dest = dest_header_row + 1
while dest_ws.cell(row=first_empty_dest, column=1).value is not None:
    first_empty_dest += 1

# Copy rows
src_start = src_header_row + 1
src_end = src_ws.max_row

def is_row_empty(ws, row):
    return all(ws.cell(row=row, column=c).value is None for c in range(1, ws.max_column + 1))

dest_row = first_empty_dest
for r in range(src_start, src_end + 1):
    if is_row_empty(src_ws, r):
        continue  # skip blank rows
    # For each header in destination, fetch matching source value
    for header, dest_col in dest_header_map.items():
        src_col = src_header_map.get(header)
        if src_col is None:
            # No matching column in source; leave destination cell as is (or blank)
            continue
        src_val = src_ws.cell(row=r, column=src_col).value
        # Negate values for columns L and M (header names "L" and "M")
        if header in ("L", "M") and isinstance(src_val, (int, float)):
            src_val = -src_val
        dest_ws.cell(row=dest_row, column=dest_col).value = src_val
    dest_row += 1

# Save workbook
wb.save(output_path)

# Optional: recalculate formulas (if any) to cache values
try:
    from sandbox import recalculate  # assuming the tool is available in the environment
    result = await recalculate(str(output_path))
    print("Recalculate result:", result)
except Exception as e:
    print("Recalculate not performed:", e)

print(f"Copy complete. Destination rows now up to {dest_ws.max_row}. Output saved to {output_path}")
