wb_path = Path("/sandbox/input/input_spreadsheet/1_130-9_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=False)

def print_rows(ws, start=1, end=10):
    print(f"--- Rows {start}-{end} of sheet '{ws.title}' ---")
    for r in range(start, end + 1):
        values = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        # Trim trailing Nones for readability
        while values and values[-1] is None:
            values.pop()
        print(f"Row {r}: {values}")

# Inspect first few rows of each sheet
