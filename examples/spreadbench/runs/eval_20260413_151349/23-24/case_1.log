import os
from openpyxl import load_workbook

# Paths from previous iteration
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))

# Load the saved workbook (read values only)
wb = load_workbook(output_path, data_only=True)
ws = wb.active

# Re‑gather words from column I (9th column)
i_words = set()
for row in range(1, ws.max_row + 1):
    val = ws.cell(row=row, column=9).value
    if isinstance(val, str):
        i_words.add(val.strip())

# Scan column A for any matches left
remaining_matches = []
for row in range(1, ws.max_row + 1):
    val = ws.cell(row=row, column=1).value
    if isinstance(val, str) and val.strip() in i_words:
        remaining_matches.append((row, val.strip()))

print(f"Rows remaining after deletion: {ws.max_row}")
print(f"Remaining matches (should be 0): {len(remaining_matches)}")
if remaining_matches:
    print("Examples of remaining matches:", remaining_matches[:5])
