import openpyxl
from pathlib import Path

# Load the workbook (read-only is fine for inspection)
wb_path = Path(input_spreadsheet)
wb = openpyxl.load_workbook(wb_path, data_only=False)
print(f"Workbook loaded: {wb_path}")
print("Sheets:", wb.sheetnames)

# Use the first sheet (assuming the data is there)
ws = wb[wb.sheetnames[0]]
print(f"Active sheet: {ws.title}")

# Determine dimensions
max_row = ws.max_row
max_col = ws.max_column
print(f"Rows: {max_row}, Columns: {max_col}")

# Show first few rows (A and B columns)
print("First 5 rows (A, B):")
for r in range(1, min(6, max_row+1)):
    a_val = ws.cell(row=r, column=1).value
    b_val = ws.cell(row=r, column=2).value
    print(f"Row {r}: A={a_val!r}, B={b_val!r}")
