import openpyxl
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Recalculate formulas in the saved workbook
result = await recalculate(str(output_path))
print("Recalculation result:", result)

# Load the workbook with data_only=True to read computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Print sample rows to verify IDs
print("Sample rows after recalculation (A, B):")
for r in range(1, min(6, ws_check.max_row + 1)):
    a = ws_check.cell(row=r, column=1).value
    b = ws_check.cell(row=r, column=2).value
    print(f"Row {r}: A={a!r}, B={b!r}")
