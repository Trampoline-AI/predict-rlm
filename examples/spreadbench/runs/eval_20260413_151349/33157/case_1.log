import openpyxl
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_33157_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_33157_init.xlsx")

# Load workbook (write mode)
wb = openpyxl.load_workbook(input_path)  # keep formulas if any
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Header mapping: description columns -> their headers
desc_cols = [2, 4, 6, 8]   # B, D, F, H
date_cols = [3, 5, 7, 9]   # C, E, G, I
header_row = 1

# Build a list of headers for quick lookup
activity_headers = [ws.cell(row=header_row, column=c).value for c in desc_cols]

# Process each data row
for row in range(2, ws.max_row + 1):
    earliest_date = ws.cell(row=row, column=10).value  # column J
    if earliest_date is None:
        # No earliest date; leave K blank
        ws.cell(row=row, column=11).value = None
        continue

    # Gather the four activity dates
    dates = [ws.cell(row=row, column=c).value for c in date_cols]

    # Find the index of the date that matches earliest_date.
    # If multiple match, pick the first.
    match_idx = None
    for i, d in enumerate(dates):
        if d == earliest_date:
            match_idx = i
            break

    # Fallback: if no exact match (possible due to time components), use min date
    if match_idx is None:
        # Filter out None values
        valid_dates = [(i, d) for i, d in enumerate(dates) if d is not None]
        if valid_dates:
            match_idx = min(valid_dates, key=lambda x: x[1])[0]
        else:
            match_idx = None

    # Write the corresponding activity header into column K
    if match_idx is not None:
        header = activity_headers[match_idx]
        ws.cell(row=row, column=11).value = header
    else:
        ws.cell(row=row, column=11).value = None

# Save to output path
wb.save(output_path)

# Verify a few rows (print row number and new K value)
print("Verification (first 5 data rows):")
for row in range(2, min(7, ws.max_row + 1)):
    name = ws.cell(row=row, column=1).value
    earliest = ws.cell(row=row, column=10).value
    activity = ws.cell(row=row, column=11).value
    print(f"Row {row}: Name={name}, EarliestDate={earliest}, ActivityHeader={activity}")
```
