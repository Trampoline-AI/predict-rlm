from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet, data_only=False)
ws = wb.active

total_rows = ws.max_row - 1  # exclude header
matches = 0
first_matches = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=2).value
    if isinstance(val, str) and val[:1].upper() in ("H", "A"):
        matches += 1
        if len(first_matches) < 5:
            first_matches.append((r, val))

print(f"Total data rows: {total_rows}")
print(f"Rows where column B starts with H or A: {matches}")
print("First few matching rows (row, value):", first_matches)
```
