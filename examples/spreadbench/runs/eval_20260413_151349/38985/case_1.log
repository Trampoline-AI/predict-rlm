# Load the workbook (read-only is fine for inspection)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=True)

# Print sheet names
print("Sheets:", wb.sheetnames)

# Helper to show first few rows of a sheet
def preview_sheet(ws, max_rows=5):
    rows = []
    for r in ws.iter_rows(min_row=1, max_row=max_rows, values_only=True):
        rows.append(r)
    return rows

# Iterate over sheets and preview
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Sheet: {name} ---")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    preview = preview_sheet(ws, max_rows=8)
    for i, row in enumerate(preview, start=1):
        print(f"Row {i}:", row)

# Also show the instruction for reference
