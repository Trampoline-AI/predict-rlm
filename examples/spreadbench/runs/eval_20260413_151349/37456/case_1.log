    date = ws.cell(row=r, column=1).value
    product = ws.cell(row=r, column=3).value
    sales = ws.cell(row=r, column=4).value
    daily = ws.cell(row=r, column=9).value
    print(f"Row {r}: Date={date}, Product={product}, Sales={sales}, DailySales={daily}")

# Close workbook
wb.close()

# Store output path for submission
output_spreadsheet = str(output_path)
