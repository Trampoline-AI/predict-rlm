import openpyxl, json, os, pathlib

# Load the workbook (read only not inspection)
wb_path = '/sandbox/input/input_spreadsheet/1_97-36_init.xlsx'
wb = openpyxl.load_workbook(wb_path, read_only=True, data_only=True)

# Gather basic info
sheet_names = wb.sheetnames
print('Sheet names:', sheet_names)

# Inspect the first sheet's dimensions and a few rows
first_ws = wb[sheet_names[0]]
max_row, max_col = first_ws.max_row, first_ws.max_column
print(f'First sheet {sheet_names[0]} dimensions: rows={max_row}, cols={max_col}')

# Print first 5 rows (as a list of lists)
rows = []
for r in range(1, min(6, max_row+1)):
    row = [first_ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    rows.append(row)
print('First 5 rows:', rows)
```
