import openpyxl
from pathlib import Path

# Load the workbook (read‑only for quick inspection)
wb_path = Path("/sandbox/input/input_spreadsheet/1_9569_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas intact

# Print sheet names
print("Sheets:", wb.sheetnames)

# Work with the first sheet (assume primary data is there)
ws = wb[wb.sheetnames[0]]
print(f"Sheet '{ws.title}' dimensions: rows={ws.max_row}, cols={ws.max_column}")

# Show header row (first row) values for the first 30 columns
header = [ws.cell(row=1, column=c).value for c in range(1, min(ws.max_column, 30) + 1)]
print("Header (first 30 cols):", header)

# Show first 5 data rows (excluding header)
for r in range(2, min(ws.max_row, 6)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, min(ws.max_column, 30) + 1)]
    print(f"Row {r} values (first 30 cols):", row_vals)
