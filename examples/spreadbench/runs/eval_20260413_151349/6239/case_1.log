import openpyxl
from openpyxl import load_workbook

# Load the workbook (read-only is fine for inspection)
wb = load_workbook(input_spreadsheet, data_only=True)
print(f"Workbook loaded with {len(wb.sheetnames)} sheet(s): {wb.sheetnames}")

# Iterate over sheets and summarize
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    # Get header values from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print(f"Sheet '{sheet_name}': {max_row} rows, {max_col} columns")
    print(f"  Headers: {headers}")
    # Show a few sample rows (2-5)
    for r in range(2, min(6, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"  Row {r}: {row_vals}")
    print("---")
