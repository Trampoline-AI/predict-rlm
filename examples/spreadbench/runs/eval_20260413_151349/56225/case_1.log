import openpyxl
from openpyxl import load_workbook
from collections import defaultdict
import pathlib

# Load the input workbook (read‑only for inspection, then writable)
wb = load_workbook(input_spreadsheet)

# Identify the sheet that holds the raw data – based on inspection it is named 'data'
source_ws = wb['data']

# Column indices (1‑based) based on inspection
COL_DATE = 1   # A
COL_MECH = 13  # M (mechanic name)
COL_START = 14 # N (start date)
COL_VALUE = 11 # K (numeric value to sum)

# Aggregate total time per (date, mechanic)
aggregated = defaultdict(float)
for row in range(2, source_ws.max_row + 1):
    date_val = source_ws.cell(row=row, column=COL_DATE).value
    mech_val = source_ws.cell(row=row, column=COL_MECH).value
    start_val = source_ws.cell(row=row, column=COL_START).value
    num_val = source_ws.cell(row=row, column=COL_VALUE).value
    # Skip rows missing any of the required fields
    if date_val is None or mech_val is None or num_val is None:
        continue
    # Use the date (or string) as part of the key; keep the raw value for later display
    key = (date_val, mech_val)
    try:
        aggregated[key] += float(num_val)
    except Exception:
        # If conversion fails, ignore this row
        continue

# Create (or replace) a sheet named 'summary'
if 'summary' in wb.sheetnames:
    summary_ws = wb['summary']
else:
    summary_ws = wb.create_sheet('summary')

# Write header
summary_ws.append(['date', 'mechanic', 'total time'])

# Write aggregated rows sorted by date then mechanic
for (date_val, mech_val), total in sorted(aggregated.items(), key=lambda x: (x[0][0], x[0][1])):
    summary_ws.append([date_val, mech_val, total])

# Demonstrate the SUMIFS logic for the specific criteria (M3 and N5) in the summary sheet
# We'll place the criteria values in cells B1 and C1 for clarity, then compute the sum in D1.
# B1 = name from M3, C1 = start date from N5 (taken from the source sheet)
name_criteria = source_ws['M3'].value
start_criteria = source_ws['N5'].value
summary_ws['B1'] = name_criteria
summary_ws['C1'] = start_criteria
# Use SUMIFS (LibreOffice compatible) to sum column K where column C = name_criteria and column N = start_criteria
# Column K is column K, name column is C, start date column is N.
# The formula will be written as a literal string; LibreOffice will evaluate it when the file is opened.
summary_ws['D1'] = f"=SUMIFS(K:K, C:C, \"{name_criteria}\", N:N, \"{start_criteria}\")"

# Save the workbook to the output directory, preserving the original filename
output_path = pathlib.Path('/sandbox/output/output_spreadsheet') / pathlib.Path(input_spreadsheet).name
wb.save(output_path)

# Verify by re‑loading the saved file (data_only) and printing a few summary rows
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb['summary']
print('Verification – first 5 rows of summary:')
for r in range(2, min(7, verify_ws.max_row + 1)):
    print([verify_ws.cell(row=r, column=c).value for c in range(1, 4)])
```
