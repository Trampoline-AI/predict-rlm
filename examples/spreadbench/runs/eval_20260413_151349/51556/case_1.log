Code:
```repl
import openpyxl
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load the workbook we previously saved (with AvgRent sheet)
wb = openpyxl.load_workbook(output_path, data_only=False)

# Ensure the AvgRent sheet exists
ws = wb["AvgRent"]

# Update formula to reference the original data sheet "Sheet1"
# Using absolute sheet name references for clarity
formula = (
    "=SUMPRODUCT((Sheet1!B2:L2=$A2)*(Sheet1!M3:M8=$B2), Sheet1!B3:L8)/"
    "SUMPRODUCT((Sheet1!B2:L2=$A2)*(Sheet1!M3:M8=$B2))"
)
ws["C2"] = formula

# Save the updated workbook
wb.save(output_path)

# Set the output variable for submission
output_spreadsheet = output_path

# Print confirmation
print("Updated formula and saved to:", output_path)
print("File size (bytes):", os.path.getsize(output_path))
```
