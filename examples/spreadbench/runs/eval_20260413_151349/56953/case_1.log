import openpyxl, os, pathlib

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_56953_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_56953_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Define formulas for columns I-L (columns 9-12)
# I: column A values, J: column B, K: column C, L: column D
# Use AGGREGATE to get nth match where $A$2:$A$15 == $F$2
# ROW()-1 gives the correct k for rows starting at 2
formulas = {
    9: "=IFERROR(INDEX($A$2:$A$15,AGGREGATE(15,6,($A$2:$A$15=$F$2)*(ROW($A$2:$A$15)-ROW($A$2)+1),ROW()-1)),\"")",
    10: "=IFERROR(INDEX($B$2:$B$15,AGGREGATE(15,6,($A$2:$A$15=$F$2)*(ROW($A$2:$A$15)-ROW($A$2)+1),ROW()-1)),\"")",
    11: "=IFERROR(INDEX($C$2:$C$15,AGGREGATE(15,6,($A$2:$A$15=$F$2)*(ROW($A$2:$A$15)-ROW($A$2)+1),ROW()-1)),\"")",
    12: "=IFERROR(INDEX($D$2:$D$15,AGGREGATE(15,6,($A$2:$A$15=$F$2)*(ROW($A$2:$A$15)-ROW($A$2)+1),ROW()-1)),\"")",
}

# Write formulas into rows 2 through 13 (inclusive)
for row in range(2, 14):
    for col, formula in formulas.items():
        ws.cell(row=row, column=col).value = formula

# Save to output path
wb.save(output_path)
print('Saved workbook to', output_path)

# Quick verification: read back a few cells (data_only=True) after recalculation
# (We will not recalc now; just show that formulas are written)
for r in range(2, 5):
    vals = [ws.cell(row=r, column=c).value for c in range(9, 13)]
    print(f'Row {r} I-L formulas:', vals)
