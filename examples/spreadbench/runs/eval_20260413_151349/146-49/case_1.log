Code:
```repl
import openpyxl, os, itertools

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Gather words from column A (skip header row)
words = []
for row in ws.iter_rows(min_row=2, max_col=1, values_only=True):
    val = row[0]
    if isinstance(val, str):
        words.append(val.strip().upper())

# Function to test if two words form a valid S‑vowel replacement pair

def is_pair(w1, w2):
    if len(w1) != len(w2):
        return False
    vowel = None
    for c1, c2 in zip(w1, w2):
        if c1 == 'S':
            # c2 must be a vowel
            if c2 not in 'AEIOU':
                return False
            if vowel is None:
                vowel = c2
            elif c2 != vowel:
                return False
        else:
            # non‑S letters must match exactly
            if c1 != c2:
                return False
    # Must have at least one S replaced
    return vowel is not None

# Find all unique unordered pairs (w1 with w2) where w1 has S and w2 is the vowel‑replaced version
pairs = []
for w1 in words:
    if 'S' not in w1:
        continue
    for w2 in words:
        if w1 == w2:
            continue
        if is_pair(w1, w2):
            pairs.append((w1, w2))

# Write pairs to columns G and H starting at row 2
out_row = 2
for w1, w2 in pairs:
    ws.cell(row=out_row, column=7, value=w1)  # column G = 7
    ws.cell(row=out_row, column=8, value=w2)  # column H = 8
    out_row += 1

# Sort the result range G2:H (both columns together) in ascending order
# Extract the written rows
result_rows = []
for r in range(2, out_row):
    g = ws.cell(row=r, column=7).value
    h = ws.cell(row=r, column=8).value
    if g is not None and h is not None:
        result_rows.append((g, h))
# Sort by first column then second column (lexicographically)
result_rows.sort()
# Write back sorted rows
for idx, (g, h) in enumerate(result_rows, start=2):
    ws.cell(row=idx, column=7, value=g)
    ws.cell(row=idx, column=8, value=h)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)
# Save workbook
wb.save(output_path)

print(f"Processed {len(words)} words, found {len(pairs)} pairs.")
print(f"Output saved to {output_path}")
# Show first few output rows for verification
for i in range(2, min(2+5, out_row)):
    print(i, ws.cell(row=i, column=7).value, ws.cell(row=i, column=8).value)
```
