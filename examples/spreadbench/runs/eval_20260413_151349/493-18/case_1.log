import os
from openpyxl import load_workbook

output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))

# Load workbook with data_only to see values (formulas stay as cached results)
wb = load_workbook(output_path, data_only=True)
ws = wb.active

# Print header row for reference
header = [ws.cell(row=1, column=c).value for c in range(1, 7)]
print("Header:", header)

# Print first 10 rows after transformation
for r in range(2, min(ws.max_row, 11)):
    a = ws.cell(row=r, column=1).value
    b = ws.cell(row=r, column=2).value
    c = ws.cell(row=r, column=3).value
    f = ws.cell(row=r, column=6).value
    print(f"Row {r}: A={a!r}, B={b!r}, C={c!r}, F={f!r}")

# Verify autofilter range (if any)
if ws.auto_filter.ref:
    print("Autofilter range:", ws.auto_filter.ref)
else:
    print("No autofilter detected")
