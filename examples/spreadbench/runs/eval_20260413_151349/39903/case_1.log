import openpyxl
from openpyxl.styles import Border, Side, Font

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_39903_init.xlsx"
output_path = "/sandbox/output/output_spreadsheet/1_39903_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # Assuming first sheet is target

# Define thin border and font
thin = Side(border_style="thin", color="000000")
border = Border(left=thin, right=thin, top=thin, bottom=thin)
courier_font = Font(name="Courier New", size=9)

# Helper to count non‑pallet locations in a text string
def count_non_pallet_locations(text: str) -> int:
    if not text:
        return 0
    # Split on common delimiters (comma, newline, semicolon)
    entries = [e.strip() for e in text.replace("\n", ",").replace(";", ",").split(",") if e.strip()]
    count = 0
    for entry in entries:
        # Expect format "location: quantity"
        if ":" not in entry:
            continue
        location_part = entry.split(":", 1)[0].strip()
        if not location_part:
            continue
        # Check first character (ignoring any leading whitespace)
        first_char = location_part[0].upper()
        if first_char not in ("X", "Z"):
            count += 1
    return count

# Process rows 2‑6
for row in range(2, 7):
    # Apply border/font to C cell as requested
    cell_c = ws.cell(row=row, column=3)  # Column C
    cell_c.border = border
    cell_c.font = courier_font

    # Read location string from column B
    cell_b = ws.cell(row=row, column=2)  # Column B
    count = count_non_pallet_locations(cell_b.value)

    # Write count to column D and style it
    cell_d = ws.cell(row=row, column=4)  # Column D
    cell_d.value = count
    cell_d.border = border
    cell_d.font = courier_font

# Save to output directory
wb.save(output_path)

# Verify by re‑loading with data_only and printing counts
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Counts in column D (rows 2‑6):", [ws_check.cell(row=r, column=4).value for r in range(2, 7)])
```
