# Also verify that borders and fonts are set on C2:C6 and D2:D6
from openpyxl.styles import Font, Border
for row in range(2, 7):
    c_cell = ws.cell(row=row, column=3)
    d_cell = ws.cell(row=row, column=4)
    print(f"C{row} font: {c_cell.font.name}, size: {c_cell.font.size}, border: {c_cell.border.left.border_style}")
    print(f"D{row} font: {d_cell.font.name}, size: {d_cell.font.size}, border: {d_cell.border.left.border_style}")
