import os
from openpyxl import load_workbook

# Path to the workbook we just saved
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

# Load the saved workbook data‑only for verification
wb = load_workbook(output_path, data_only=True)
ws = wb.active

max_row = ws.max_row
max_col = ws.max_column

# Detect blocks (same logic as before)
blocks = []
current = []
for r in range(1, max_row + 1):
    val = ws.cell(row=r, column=4).value  # column D
    if val is None or (isinstance(val, str) and val.strip() == ""):
        if current:
            blocks.append(current)
            current = []
    else:
        current.append(r)
if current:
    blocks.append(current)

# Verify each block is sorted descending by column D
sorted_ok = True
violations = []
for i, block in enumerate(blocks, start=1):
    # Extract D values
    d_vals = [ws.cell(row=r, column=4).value for r in block]
    # Check descending order (allow equal values)
    for a, b in zip(d_vals, d_vals[1:]):
        if (isinstance(a, (int, float)) and isinstance(b, (int, float)) and a < b):
            sorted_ok = False
            violations.append((i, block[0], a, b))
            break

# Count blank rows between blocks
blank_rows_between = 0
for r in range(1, max_row):
    v = ws.cell(row=r, column=4).value
    v_next = ws.cell(row=r+1, column=4).value
    if (v is None or (isinstance(v, str) and v.strip() == "")) and (v_next is not None and not (isinstance(v_next, str) and v_next.strip() == "")):
        blank_rows_between += 1

# Expected blank rows = blocks - 1
expected_blank = max(0, len(blocks) - 1)

print(f"Verification Summary:")
print(f"  Total rows (including blanks): {max_row}")
print(f"  Number of blocks detected: {len(blocks)}")
print(f"  Blank rows between blocks: {blank_rows_between} (expected {expected_blank})")
print(f"  Sorting order correct: {sorted_ok}")
if not sorted_ok:
    print(f"  Violations (block index, first row index, a, b) where a < b):")
    for v in violations[:5]:
        print("   ", v)

# Expose the output path for submission
output_spreadsheet = output_path
