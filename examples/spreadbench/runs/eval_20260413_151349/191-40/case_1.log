Reasoning: We need to:
1. Load the input workbook (with formulas) and a data‑only version to read the evaluated numeric values in column D.
2. Detect blocks on Sheet1: consecutive rows where column D is non‑blank, separated by exactly one blank row (any row where column D is empty).
3. For each block, sort its rows by the numeric value of column D in descending order, using the data‑only workbook for the sort key while preserving the original formulas from the formula workbook.
4. Re‑write the sorted rows back to a clean sheet, inserting a single blank row between blocks (no extra blank row after the final block).
5. Replace the original sheet with the new sorted sheet, save the workbook to the output directory, and run `recalculate` so that LibreOffice sees cached formula results.
6. Verify by loading the saved file (data‑only) and printing a few rows.

The code below follows these steps, using `openpyxl` and the provided `recalculate` async tool. It prints a concise summary (number of blocks, rows written) for verification before the final submission.
Code:
```repl
import os
import pathlib
from openpyxl import load_workbook, Workbook

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbooks: one with formulas, one data‑only for values
wb_formulas = load_workbook(input_path, data_only=False)
wb_data = load_workbook(input_path, data_only=True)

# Assume the target sheet is the first sheet (or named "Sheet1")
ws_formulas = wb_formulas.active
ws_data = wb_data.active

max_row = ws_formulas.max_row
max_col = ws_formulas.max_column

# ----------------------------------------------------------------------
# 1. Detect blocks separated by a blank row in column D (4th column)
# ----------------------------------------------------------------------
blocks = []          # list of list of row indices
current_block = []

for r in range(1, max_row + 1):
    cell = ws_formulas.cell(row=r, column=4)  # column D
    # Treat None or empty string as a blank separator
    if cell.value is None or (isinstance(cell.value, str) and cell.value.strip() == ""):
        if current_block:
            blocks.append(current_block)
            current_block = []
    else:
        current_block.append(r)

# Append the final block if file ends without a trailing blank row
if current_block:
    blocks.append(current_block)

# ----------------------------------------------------------------------
# 2. Sort each block by the numeric value in column D (descending)
# ----------------------------------------------------------------------
sorted_rows = []   # each entry is a list of cell values (including formulas)

for block in blocks:
    # Gather (row_index, numeric_value) using the data‑only workbook
    rows_with_vals = []
    for r in block:
        val = ws_data.cell(row=r, column=4).value
        # Ensure we have a comparable numeric value; non‑numeric treated as -inf
        if isinstance(val, (int, float)):
            sort_key = val
        else:
            sort_key = float("-inf")
        rows_with_vals.append((r, sort_key))

    # Sort descending by the numeric value
    rows_with_vals.sort(key=lambda x: x[1], reverse=True)

    # Append the rows in sorted order, preserving formulas from the formula workbook
    for r, _ in rows_with_vals:
        row_vals = [ws_formulas.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        sorted_rows.append(row_vals)

    # Insert a single blank row after each block (will be removed after the last block)
    sorted_rows.append([None] * max_col)

# Remove the trailing blank row after the final block, if present
if sorted_rows and all(v is None for v in sorted_rows[-1]):
    sorted_rows.pop()

# ----------------------------------------------------------------------
# 3. Write the sorted data to a fresh sheet and replace the original sheet
# ----------------------------------------------------------------------
# Create a temporary sheet
temp_ws = wb_formulas.create_sheet(title="___temp_sorted___")
out_row = 1
for row_vals in sorted_rows:
    for col_idx, val in enumerate(row_vals, start=1):
        temp_ws.cell(row=out_row, column=col_idx, value=val)
    out_row += 1

# Remove the original sheet and rename the temporary one
original_name = ws_formulas.title
wb_formulas.remove(ws_formulas)
temp_ws.title = original_name

# ----------------------------------------------------------------------
# 4. Save the workbook to the output directory
# ----------------------------------------------------------------------
wb_formulas.save(output_path)

# ----------------------------------------------------------------------
# 5. Recalculate formulas so LibreOffice sees cached values
# ----------------------------------------------------------------------
# The `recalculate` tool is async; we await it.
recalc_result = await recalculate(output_path)
print(f"Recalculate result: {recalc_result}")

# ----------------------------------------------------------------------
# 6. Quick verification: load the saved file data‑only and print a few rows
# ----------------------------------------------------------------------
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb.active
print(f"Verification – total rows written (including blanks): {verify_ws.max_row}")
print("First 5 rows (showing column D values):")
for r in range(1, min(6, verify_ws.max_row + 1)):
    print(f"Row {r}: D = {verify_ws.cell(row=r, column=4).value}")

# Done – the output workbook is ready at `output_path`
