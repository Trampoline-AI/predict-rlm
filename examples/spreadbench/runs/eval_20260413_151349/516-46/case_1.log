Code:
```repl
import openpyxl, os, shutil

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_516-46_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_516-46_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Collect data per brand
brand_data = {}
for row in ws.iter_rows(min_row=2, max_col=5, values_only=True):
    date, brand, batch, origin, qty = row
    if brand is None:
        continue
    # Initialize entry if not present
    if brand not in brand_data:
        brand_data[brand] = {'max_date': date, 'qty_sum': qty or 0}
    else:
        entry = brand_data[brand]
        # Compare dates
        if date > entry['max_date']:
            entry['max_date'] = date
            entry['qty_sum'] = qty or 0
        elif date == entry['max_date']:
            entry['qty_sum'] += qty or 0

# Write headers starting at H1
ws['H1'] = 'brand'
ws['I1'] = 'date'
ws['J1'] = 'quantity'

# Write results starting at H2
out_row = 2
for brand, info in brand_data.items():
    ws.cell(row=out_row, column=8, value=brand)          # H column
    ws.cell(row=out_row, column=9, value=info['max_date'])  # I column
    ws.cell(row=out_row, column=10, value=info['qty_sum']) # J column
    out_row += 1

# Save to output path
wb.save(output_path)
print('Saved output to', output_path)
```
