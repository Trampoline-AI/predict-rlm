import openpyxl, re, json, sys, os

wb_path = '/sandbox/input/input_spreadsheet/1_54925_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

sheet_formulas = {}
for ws_name in wb.sheetnames:
    ws = wb[ws_name]
    formulas = []
    for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith('='):
                formulas.append((cell.coordinate, cell.value))
    sheet_formulas[ws_name] = formulas

# Print summary
for ws_name, formulas in sheet_formulas.items():
    print(f"Sheet '{ws_name}': {len(formulas)} formula cells")
    # Show up to 5 formulas
    for coord, formula in formulas[:5]:
        # Truncate long formulas for readability
        short = (formula[:80] + '...') if len(formula) > 80 else formula
        print(f"  {coord}: {short}")
    print()

# Find formulas that reference column H or K or cells M3/N3/N4 (including absolute refs)
target_refs = ['H', 'K', '$H$', '$K$', 'M3', '$M$3', 'N3', '$N$3', 'N4', '$N$4']
matches = []
for ws_name, formulas in sheet_formulas.items():
    for coord, formula in formulas:
        if any(ref in formula for ref in target_refs):
            matches.append((ws_name, coord, formula))

print(f"Total formulas containing any target reference: {len(matches)}")
for ws_name, coord, formula in matches[:10]:
    short = (formula[:80] + '...') if len(formula) > 80 else formula
    print(f"  Sheet {ws_name} {coord}: {short}")
```
