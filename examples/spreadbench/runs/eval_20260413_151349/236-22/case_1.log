import os
from pathlib import Path
from openpyxl import load_workbook

# Paths
input_path = Path(input_spreadsheet)  # e.g., /sandbox/input/input_spreadsheet/1_236-22_init.xlsx
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (preserve formulas)
wb = load_workbook(filename=input_path, data_only=False)

# Determine processing order: start from sheet named "BR1" and include all subsequent sheets
sheet_names = wb.sheetnames
if "BR1" not in sheet_names:
    raise ValueError("Sheet 'BR1' not found in workbook.")
start_idx = sheet_names.index("BR1")
target_sheets = sheet_names[start_idx:]  # inclusive of BR1 and all after it

protected_rows = {2, 9}  # rows that must never be deleted

for sheet_name in target_sheets:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column

    # First pass: collect rows to delete based on blank column A
    rows_to_delete = set()
    for r in range(2, max_row + 1):  # start at row 2 (row 1 likely header)
        cell_val = ws.cell(row=r, column=1).value
        if cell_val is None or (isinstance(cell_val, str) and cell_val.strip() == ""):
            # Blank in column A
            rows_to_delete.add(r)          # delete the blank row
            if r - 1 >= 1:
                rows_to_delete.add(r - 1)  # delete the row directly above

    # Second pass: remove protected rows and rows that must stay because they are data rows
    # right below a header containing "Line No"
    rows_to_keep = set()
    for r in list(rows_to_delete):
        # Protect explicit rows
        if r in protected_rows:
            rows_to_delete.discard(r)
            continue

        # If the row has data in column A, check the row above for "Line No"
        cell_val = ws.cell(row=r, column=1).value
        if cell_val is not None and isinstance(cell_val, str) and cell_val.strip() != "":
            # This row has data; see if the previous row contains "Line No"
            prev_r = r - 1
            if prev_r >= 1:
                for c in range(1, max_col + 1):
                    prev_val = ws.cell(row=prev_r, column=c).value
                    if isinstance(prev_val, str) and "Line No" in prev_val:
                        # This data row must stay; also keep the header row above it
                        rows_to_delete.discard(r)
                        rows_to_delete.discard(prev_r)  # just in case it was marked
                        break

    # Delete rows in descending order to avoid index shifting
    for r in sorted(rows_to_delete, reverse=True):
        ws.delete_rows(r)

# Save the modified workbook
wb.save(output_path)

# Simple verification print
print(f"Saved modified workbook to: {output_path}")
print(f"Processed sheets: {target_sheets}")
print(f"Rows deleted per sheet (example from first sheet):")
first_sheet = wb[target_sheets[0]]
print(f"  {first_sheet.title}: now {first_sheet.max_row} rows")
