```repl
import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb.active

# Inspect first few rows to locate the header '0-15'
print('--- First 5 rows values ---')
for r in range(1, min(6, ws.max_row + 1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    print(f'Row {r}:', row_vals)

# Search for header '0-15' in all rows (trim whitespace)
header_target = '0-15'
found = False
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        val = ws.cell(row=r, column=c).value
        if isinstance(val, str) and val.strip() == header_target:
            src_row, src_col = r, c
            found = True
            break
    if found:
        break

if not found:
    raise ValueError(f"Header '{header_target}' not found in any cell")

print(f"Found header '{header_target}' at row {src_row}, column {src_col}")

# Ensure we are moving the entire column (regardless of header row). We'll copy the whole column.
# Insert new column at B (index 2)
ws.insert_cols(2)

# Adjust source column index after insertion
# If source column was to the right of B, its index increased by 1
src_col_adj = src_col if src_col < 2 else src_col + 1

# Copy values from source column to new B column for all rows
for row in ws.iter_rows(min_row=1, max_row=ws.max_row):
    dest_cell = row[1]  # column B (0‑based index 1)
    src_cell = row[src_col_adj - 1]  # 0‑based index
    dest_cell.value = src_cell.value

# Delete the original column (now at src_col_adj)
ws.delete_cols(src_col_adj)

# Save to output directory
output_dir = '/sandbox/output/output_spreadsheet'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print(f'Saved modified workbook to {output_path}')
