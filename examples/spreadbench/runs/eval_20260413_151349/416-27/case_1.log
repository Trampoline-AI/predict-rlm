Code:
```repl
import os, json, openpyxl

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_416-27_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet'
output_path = os.path.join(output_dir, '1_416-27_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb.active

# Determine the first non‑blank row in column A
first_data_row = None
for r in range(1, ws.max_row + 1):
    if ws.cell(row=r, column=1).value not in (None, ""):
        first_data_row = r
        break
if first_data_row is None:
    # No data in column A – nothing to delete
    first_data_row = 1

# Collect rows to delete (blank cells in column A) from first_data_row to the original max row
original_max_row = ws.max_row
rows_to_delete = []
for r in range(first_data_row, original_max_row + 1):
    val = ws.cell(row=r, column=1).value
    if val in (None, ""):
        rows_to_delete.append(r)

# Delete rows in reverse order to keep indices stable
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

# Save the modified workbook
wb.save(output_path)

# Verify: reload with data_only to check column A values after first_data_row
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
check_vals = [ws_check.cell(row=r, column=1).value for r in range(first_data_row, ws_check.max_row + 1)]
print(json.dumps({
    "first_data_row": first_data_row,
    "rows_deleted": len(rows_to_delete),
    "remaining_col_a": check_vals,
    "new_max_row": ws_check.max_row
}, indent=2))
```
