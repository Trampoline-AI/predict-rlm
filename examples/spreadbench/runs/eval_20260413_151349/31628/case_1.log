import openpyxl
from pathlib import Path

# Load the input spreadsheet
input_path = Path(input_spreadsheet)  # variable provided by the environment
wb = openpyxl.load_workbook(input_path, data_only=False)  # keep formulas if any
ws = wb.active  # assume the first sheet is the target

# Inspect sheet name and dimensions
print("Sheet name:", ws.title)
print("Max row in sheet:", ws.max_row, "Max column:", ws.max_column)

# Examine cells A1:A11
values = []
for i in range(1, 12):  # rows 1 through 11 inclusive
    cell = ws.cell(row=i, column=1)  # column A
    values.append((i, cell.value, type(cell.value)))
    print(f"A{i}: value={cell.value!r}, type={type(cell.value)}")

# Summarize non‑empty rows
non_empty = [(row, val) for row, val, typ in values if val is not None]
print("Non‑empty cells in A1:A11:", non_empty)
