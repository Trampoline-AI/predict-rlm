import openpyxl, json, os

# Load the workbook (read/write mode)
wb_path = '/sandbox/input/input_spreadsheet/1_44296_init.xlsx'
wb = openpyxl.load_workbook(wb_path)

# Gather sheet info
sheet_info = {}
for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    # Sample first 5 rows of first 5 columns
    sample = []
    for r in range(1, min(6, max_row+1)):
        row_vals = []
        for c in range(1, min(6, max_col+1)):
            row_vals.append(ws.cell(row=r, column=c).value)
        sample.append(row_vals)
    sheet_info[ws.title] = {
        'max_row': max_row,
        'max_col': max_col,
        'sample': sample,
    }

print('Sheets and dimensions:')
print(json.dumps(sheet_info, indent=2, default=str))
```
