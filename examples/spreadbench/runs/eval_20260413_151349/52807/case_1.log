import openpyxl

# Load the workbook
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)  # keep formulas
print("Sheets:", wb.sheetnames)

# Access the Summary sheet
ws = wb["Summary"]
print("Summary sheet dimensions:", ws.max_row, ws.max_column)

# Print formulas/values for E6:G9
print("E6:G9 formulas/values:")
for row in range(6, 10):
    vals = []
    for col in range(5, 8):  # E=5, F=6, G=7
        cell = ws.cell(row=row, column=col)
        if cell.value is None:
            vals.append("EMPTY")
        else:
            # Show formula if present, else value
            if cell.data_type == "f":
                vals.append(f"FORMULA:{cell.value}")
            else:
                vals.append(f"VALUE:{cell.value}")
    print(f"Row {row}:", vals)

# Also show D3 value (months completed)
d3 = ws["D3"].value
print("D3 (months completed):", d3)

# Save a copy for later modifications (optional)
wb.save("/sandbox/output/output_spreadsheet/inspect_copy.xlsx")
