```repl
import os
from pathlib import Path
from openpyxl import load_workbook

# Paths
input_path = Path(input_spreadsheet)  # /sandbox/input/input_spreadsheet/1_6698_init.xlsx
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # assume the sheet with G4 is the active sheet

# Apply auto‑filter to A1:C1
ws.auto_filter.ref = "A1:C1"

# Update G4:G8 formulas
for row in range(4, 9):  # 4 through 8 inclusive
    # Cell in column F for this row (e.g., F4)
    f_cell = f"F{row}"
    # Build formula string using the F‑cell reference
    # Count rows in 'raw 1' where A matches F‑cell and B<>0, plus where A matches F‑cell and C<>0
    formula = (
        f"=SUM(COUNTIFS('raw 1'!A:A, {f_cell}, 'raw 1'!B:B, "<>0"), "n"
        f"COUNTIFS('raw 1'!A:A, {f_cell}, 'raw 1'!C:C, "<>0"))"
    )
    ws[f"G{row}"] = formula

# Save to output location
wb.save(output_path)

# Verify by reloading with data_only to ensure formulas are present (optional)
# (We could also call recalculate here if needed.)

# Submit the result
SUBMIT(output_spreadsheet=str(output_path))
