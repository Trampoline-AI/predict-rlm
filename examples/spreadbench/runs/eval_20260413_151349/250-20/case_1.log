The code below follows these steps and uses `openpyxl` only (no VBA needed, as the task is performed programmatically).
Code:
```repl
import os
import openpyxl
from collections import defaultdict

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_250-20_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_250-20_init.xlsx')
os.makedirs(output_dir, exist_ok=True)

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb['RNM']

def get_header(ws):
    """Return a list of header values from the first row."""
    return [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]

header = get_header(ws)

# Column indices (1‑based)
COL_NUMBER = 2   # B
COL_LINE   = 3   # C
COL_SUM    = 10  # J (MATCHED_QTY)

# Aggregation dictionary: key -> {'row_vals': [...], 'total': sum}
agg = {}

for r in range(2, ws.max_row + 1):
    number = ws.cell(row=r, column=COL_NUMBER).value
    line   = ws.cell(row=r, column=COL_LINE).value
    sumval = ws.cell(row=r, column=COL_SUM).value or 0
    key = (number, line)

    # Capture full row values (list) for the first occurrence of this key
    if key not in agg:
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        agg[key] = {'row_vals': row_vals, 'total': sumval}
    else:
        agg[key]['total'] += sumval

# Update column J in each stored row with the aggregated total
aggregated_rows = []
for entry in agg.values():
    row_vals = entry['row_vals']
    row_vals[COL_SUM - 1] = entry['total']   # list is 0‑based
    aggregated_rows.append(row_vals)

# Delete existing data rows (keep header)
if ws.max_row > 1:
    ws.delete_rows(2, ws.max_row - 1)

# Write aggregated rows back starting at row 2
out_row = 2
for vals in aggregated_rows:
    for col_idx, val in enumerate(vals, start=1):
        ws.cell(row=out_row, column=col_idx, value=val)
    out_row += 1

# Save the modified workbook
wb.save(output_path)
wb.close()

# Verification: reload with data_only and print a few rows
vb = openpyxl.load_workbook(output_path, data_only=True)
vs = vb['RNM']
print('Header after save:', get_header(vs))
print('First 5 aggregated rows:')
for r in range(2, min(7, vs.max_row + 1)):
    print([vs.cell(row=r, column=c).value for c in range(1, vs.max_column + 1)])
vb.close()
```
