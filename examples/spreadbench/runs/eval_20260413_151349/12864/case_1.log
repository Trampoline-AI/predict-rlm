import openpyxl

# Load the workbook
wb = openpyxl.load_workbook("/sandbox/input/input_spreadsheet/1_12864_init.xlsx")
print("Sheets:", wb.sheetnames)

# Function to print a few rows of a sheet
def preview_sheet(ws, max_rows=5):
    print(f"\nPreview of sheet '{ws.title}':")
    for r in ws.iter_rows(min_row=1, max_row=max_rows, values_only=True):
        print(r)

# Preview each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    preview_sheet(ws, max_rows=6)
```
