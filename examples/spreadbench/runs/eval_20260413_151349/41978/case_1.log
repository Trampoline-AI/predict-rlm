output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Verify file exists
print("File exists:", output_path.is_file())

# Load workbook (keep formulas)
wb = load_workbook(filename=output_path, data_only=False)
ws = wb.active

# Check for any merged cells that still intersect column I (9) rows 14-185
merged_intersections = []
for mr in ws.merged_cells.ranges:
    min_col, min_row, max_col, max_row = mr.bounds
    if min_col <= 9 <= max_col and not (max_row < 14 or min_row > 185):
        merged_intersections.append(str(mr))
print("Merged cells still intersecting column I rows 14-185:", merged_intersections)

# Show sample formulas in column I
for r in range(14, 19):
    cell = ws.cell(row=r, column=9)
    print(f"I{r} -> {cell.value}")

# Set output variable for submission
output_spreadsheet = str(output_path)
