import openpyxl, os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50250_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (preserve formulas if any)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume first sheet

# Reference value from G2
ref = ws["G2"].value

# Column indices (1‑based)
col_A, col_B = 1, 2
col_C, col_D, col_E = 3, 4, 5

# Compute sum
total = 0
for row in range(2, ws.max_row + 1):
    if ws.cell(row=row, column=col_A).value == ref or ws.cell(row=row, column=col_B).value == ref:
        for col in (col_C, col_D, col_E):
            val = ws.cell(row=row, column=col).value
            if isinstance(val, (int, float)):
                total += val

# Write total to H2 (column 8)
ws["H2"].value = total

# Save to output location
wb.save(output_path)

# Verify by re‑loading with data_only to read the cached value
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
assert ws_check["H2"].value == total, "Verification failed: H2 does not contain the expected sum."

print("Sum written to H2:", total)
print("Output saved at:", output_path)
