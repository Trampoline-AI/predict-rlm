Code:
```repl
import openpyxl
from openpyxl.styles import PatternFill
from pathlib import Path

# Paths (same as previous iteration)
input_path = "/sandbox/input/input_spreadsheet/1_50631_init.xlsx"
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_50631_init.xlsx"

# Load the newly created workbook to verify fills and formulas
wb = openpyxl.load_workbook(output_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is Sheet1

# Find a sample of cells with yellow fill (#FFFF00) to verify they exist
yellow_cells = []
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        fill = cell.fill
        if isinstance(fill, PatternFill) and fill.fgColor and fill.fgColor.rgb:
            # openpyxl stores colors as ARGB; yellow is 'FFFFFF00' (alpha FF + RGB FFFF00)
            if fill.fgColor.rgb.upper().endswith("FFFF00"):
                yellow_cells.append(cell.coordinate)
                if len(yellow_cells) >= 5:
                    break
    if len(yellow_cells) >= 5:
        break

print("Sample cells with yellow fill:", yellow_cells[:5])

# Verify that formulas in columns B, D, F are retained (print first few)
def cell_formula(coord):
    return ws[coord].value if isinstance(ws[coord].value, str) and ws[coord].value.startswith("=") else None

sample_formulas = {
    "B2": cell_formula("B2"),
    "D2": cell_formula("D2"),
    "F2": cell_formula("F2"),
}
print("Sample formulas in B, D, F columns:", sample_formulas)

# Expose the output path as the required output variable
output_spreadsheet = str(output_path)
print("Output spreadsheet path set to:", output_spreadsheet)
```
