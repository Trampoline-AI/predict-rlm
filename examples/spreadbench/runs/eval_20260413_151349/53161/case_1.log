Code:
```python
```repl
import openpyxl
from pathlib import Path
import datetime

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_53161_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook for editing
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # only one sheet

# -------------------------------------------------
# 1. Build agent -> category count mapping (Category table rows 4‑9)
# -------------------------------------------------
agent_to_catcount = {}
row = 4
while True:
    agent = ws.cell(row=row, column=5).value
    if agent is None or agent == "Agent Schedule":
        break
    cat_sum = sum(1 for col in range(6, 15) if ws.cell(row=row, column=col).value == 1)
    agent_to_catcount[agent] = cat_sum
    row += 1

print("Agent to category count:", agent_to_catcount)

# -------------------------------------------------
# 2. Identify interval columns from header row (row 12)
# -------------------------------------------------
header_row = 12
max_col = ws.max_column
interval_cols = []
for col in range(6, max_col + 1):
    val = ws.cell(row=header_row, column=col).value
    if isinstance(val, (datetime.time, str, int, float)):
        interval_cols.append(col)

# -------------------------------------------------
# 3. Compute totals per interval using schedule rows (13‑18)
# -------------------------------------------------
totals = {col: 0 for col in interval_cols}
for row in range(13, 20):  # rows 13‑19 (row 20 is the label row)
    agent = ws.cell(row=row, column=5).value
    if not agent:
        continue
    cat_cnt = agent_to_catcount.get(agent, 0)
    for col in interval_cols:
        if ws.cell(row=row, column=col).value == 1:
            totals[col] += cat_cnt

print("Totals per interval column (raw):", totals)

# -------------------------------------------------
# 4. Handle merged cells in row 20
# -------------------------------------------------
# Build a mapping from any column that falls inside a merged range
# to the leftmost column of that range (the real writable cell).
merged_map = {}
for mr in ws.merged_cells.ranges:
    # mr is a CellRange object, e.g., "F20:K20"
    min_col, max_col = mr.min_col, mr.max_col
    min_row, max_row = mr.min_row, mr.max_row
    if min_row <= 20 <= max_row:  # merged range includes row 20
        for col in range(min_col, max_col + 1):
            merged_map[col] = min_col  # target the leftmost column

# -------------------------------------------------
# 5. Write totals into row 20, respecting merged cells
# -------------------------------------------------
output_row = 20
for col, total in totals.items():
    target_col = merged_map.get(col, col)  # use leftmost if merged, else col
    ws.cell(row=output_row, column=target_col).value = total

# -------------------------------------------------
# 6. Save the workbook
# -------------------------------------------------
wb.save(output_path)
print(f"Saved modified workbook to {output_path}")

# -------------------------------------------------
# 7. Verify by re‑loading with data_only=True and printing the totals row
# -------------------------------------------------
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
verified = [ws_check.cell(row=output_row, column=col).value for col in interval_cols]
print("Verified totals row (by interval columns):", verified)

# Store the output path for submission
output_spreadsheet = str(output_path)
