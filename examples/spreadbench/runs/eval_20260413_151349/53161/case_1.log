The code below implements this plan.
Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_53161_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook for editing
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # only one sheet

# -----------------------------------------------------------------------------
# 1. Build agent -> category count mapping (Category table rows 4‑9)
# -----------------------------------------------------------------------------
agent_to_catcount = {}
row = 4
while True:
    agent = ws.cell(row=row, column=5).value
    # Stop when we reach a blank row or the "Agent Schedule" marker
    if agent is None or agent == "Agent Schedule":
        break
    # Sum category flags columns 6‑14 (Category 1‑9)
    cat_sum = 0
    for col in range(6, 15):  # 15 is exclusive, so 6‑14
        val = ws.cell(row=row, column=col).value
        if val == 1:
            cat_sum += 1
    agent_to_catcount[agent] = cat_sum
    row += 1

print("Agent to category count:", agent_to_catcount)

# -----------------------------------------------------------------------------
# 2. Compute totals per interval (Schedule table rows 13‑18, header row 12)
# -----------------------------------------------------------------------------
# Determine the range of interval columns from the header row (row 12)
header_row = 12
max_col = ws.max_column
interval_cols = []
for col in range(6, max_col + 1):
    val = ws.cell(row=header_row, column=col).value
    if isinstance(val, (str, int, float, datetime.time)):
        interval_cols.append(col)

# Prepare a dict to hold totals per column
totals = {col: 0 for col in interval_cols}

# Iterate schedule rows (13‑18) until we hit the total label row (20) or blank
schedule_start = 13
schedule_end = 20  # exclusive
for row in range(schedule_start, schedule_end):
    agent = ws.cell(row=row, column=5).value
    if agent is None:
        continue
    cat_count = agent_to_catcount.get(agent, 0)
    for col in interval_cols:
        scheduled = ws.cell(row=row, column=col).value
        if scheduled == 1:
            totals[col] += cat_count

print("Totals per interval column:", totals)

# -----------------------------------------------------------------------------
# 3. Write totals into row 20 (the label row already has text in column 5)
# -----------------------------------------------------------------------------
output_row = 20
for col, total in totals.items():
    ws.cell(row=output_row, column=col).value = total

# Save to output path
wb.save(output_path)
print(f"Saved modified workbook to {output_path}")

# -----------------------------------------------------------------------------
# 4. Verify by re‑loading with data_only=True and printing the totals row
# -----------------------------------------------------------------------------
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
verified = [ws_check.cell(row=output_row, column=col).value for col in interval_cols]
print("Verified totals row:", verified)
```
