import openpyxl
from pathlib import Path
import datetime

# Paths
output_path = Path("/sandbox/output/output_spreadsheet/1_53161_init.xlsx")

# Load workbook with data_only to read cached values
wb = openpyxl.load_workbook(output_path, data_only=True)
ws = wb.active

# Identify interval columns from header row (row 12) again
header_row = 12
max_col = ws.max_column
interval_cols = []
for col in range(6, max_col + 1):
    val = ws.cell(row=header_row, column=col).value
    if isinstance(val, (datetime.time, str, int, float)):
        interval_cols.append(col)

# Gather merged ranges that intersect row 20
merged_ranges = [mr for mr in ws.merged_cells.ranges if mr.min_row <= 20 <= mr.max_row]

print("Merged ranges covering row 20:")
for mr in merged_ranges:
    print(mr)

# Build a mapping from each interval column to the leftmost column of its merged range (or itself)
merged_map = {}
for mr in merged_ranges:
    for col in range(mr.min_col, mr.max_col + 1):
        merged_map[col] = mr.min_col

# Read totals from the actual writable cells (leftmost column of each merged range)
output_row = 20
interval_totals = {}
for col in interval_cols:
    target_col = merged_map.get(col, col)
    total = ws.cell(row=output_row, column=target_col).value
    # Get the interval label from the header row for readability
    interval_label = ws.cell(row=header_row, column=col).value
    interval_totals[interval_label] = total

print("\nInterval totals (as read from the written cells):")
for label, total in interval_totals.items():
