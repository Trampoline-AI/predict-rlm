import openpyxl, pathlib

# Paths (same as previous step)
input_path = pathlib.Path("/sandbox/input/input_spreadsheet/1_32562_init.xlsx")
output_dir = pathlib.Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_32562_init.xlsx"

# Load the transformed workbook (cached values only)
wb = openpyxl.load_workbook(output_path, data_only=True)
ws = wb[wb.sheetnames[0]]

# Gather statistics
max_row = ws.max_row
occ_counts = []
for r in range(2, max_row + 1):
    occ_counts.append(ws.cell(row=r, column=2).value)

max_occ = max([c for c in occ_counts if isinstance(c, (int, float))], default=0)
print("Total rows (excluding header):", max_row - 1)
print("Maximum occurrence index in Column B:", max_occ)

# Show a few rows from the middle and end to verify non‑1 values
mid = max_row // 2
sample_rows = list(range(mid, min(mid + 5, max_row + 1))) + list(range(max_row - 4, max_row + 1))
sample_vals = [(r, ws.cell(r,1).value, ws.cell(r,2).value) for r in sample_rows]
print("Sample rows (row, Column A, Column B):", sample_vals)

# Store the output path for submission
output_spreadsheet = str(output_path)
print("Output spreadsheet path stored in variable `output_spreadsheet`.")
