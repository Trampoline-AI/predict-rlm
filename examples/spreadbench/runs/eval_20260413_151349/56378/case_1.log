import openpyxl
from pathlib import Path
from openpyxl.styles import Alignment

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_56378_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_56378_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Folha1"]

# Determine the last data row in frame 1 (column C = CODE PRODUCT)
last_row = 4
for row in range(5, ws.max_row + 1):
    if ws.cell(row=row, column=3).value is not None:
        last_row = row
if last_row < 5:
    last_row = 5

# Helper to build the corrected array formula
def make_formula(src_col: str, tgt_col: str, start_row: int, cur_row: int) -> str:
    """
    Build an array formula that returns the cur non‑empty QUANTITY UNITS row
    from src_col into tgt_col.
    start_row = first data row (5)
    cur_row   = row where the formula will be placed
    """
    src_range = f"${src_col}${start_row}:${src_col}${last_row}"
    qty_range = f"$I${start_row}:$I${last_row}"
    nth = f"ROWS(${tgt_col}${start_row}:{tgt_col}{cur_row})"
    row_base = f"$I${start_row}"
    # Use <>"" to keep rows where QUANTITY UNITS is NOT empty
    formula = (
        f"=IFERROR("
        f"INDEX({src_range}, "
        f"SMALL(IF({qty_range}<\"\", ROW({qty_range})-ROW({row_base})+1), {nth})), "
        f"\"\""
        f")"
    )
    return formula

# Write corrected formulas for columns L‑R (frame2)
for r in range(5, last_row + 1):
    ws.cell(row=r, column=12).value = make_formula("C", "L", 5, r)  # CODE PRODUCT
    ws.cell(row=r, column=13).value = make_formula("D", "M", 5, r)  # PRODUCT
    ws.cell(row=r, column=14).value = make_formula("E", "N", 5, r)  # TAX
    ws.cell(row=r, column=15).value = make_formula("F", "O", 5, r)  # UNIT PRICE
    ws.cell(row=r, column=16).value = make_formula("G", "P", 5, r)  # PRICE TABLE
    ws.cell(row=r, column=17).value = make_formula("H", "Q", 5, r)  # COMMERCIAL DISCOUNT
    ws.cell(row=r, column=18).value = make_formula("I", "R", 5, r)  # QUANTITY UNITS

# Apply alignments
left_align = Alignment(horizontal="left")
right_align = Alignment(horizontal="right")
for r in range(5, last_row + 1):
    ws.cell(row=r, column=13).alignment = left_align   # PRODUCT name (M)
    for col in (15, 16, 17, 18):  # O, P, Q, R
        ws.cell(row=r, column=col).alignment = right_align

# Save the workbook
wb.save(output_path)

# Verify a few sample formulas
print("Sample corrected formulas (rows 5‑7):")
for r in range(5, 8):
    print(
        r,
        ws.cell(row=r, column=12).value,  # L
        ws.cell(row=r, column=13).value,  # M
        ws.cell(row=r, column=14).value,  # N
        ws.cell(row=r, column=15).value,  # O
        ws.cell(row=r, column=16).value,  # P
        ws.cell(row=r, column=17).value,  # Q
        ws.cell(row=r, column=18).value,  # R
    )
