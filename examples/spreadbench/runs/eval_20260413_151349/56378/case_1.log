    # Array formula (LibreOffice will treat it as an array formula when entered)
    formula = (
        f"=IFERROR(INDEX({src_range}, "
        f"SMALL(IF({qty_range}<\"\", ROW({qty_range})-ROW(${qty_range}]+1), {nth})), \"\")"
    )
    return formula

