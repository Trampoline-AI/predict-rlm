import openpyxl, os, json

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_49237_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet'
output_path = os.path.join(output_dir, '1_49237_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Helper to find cell containing a specific substring in its formula
search_substr = 'LEFT(F10)'
found_cell = None
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        if isinstance(cell.value, str) and search_substr in cell.value.upper():
            found_cell = cell
            break
    if found_cell:
        break

# Define the new conditional formula
new_formula = '=IF(LEN(TRIM(F10))=0, "", LEFT(TRIM(F10),1) & ".")'

if found_cell:
    target_address = found_cell.coordinate
    ws[target_address] = new_formula
    print(f'Updated existing cell {target_address} with formula: {new_formula}')
else:
    # Choose a default location (G10) if not found
    target_address = 'G10'
    ws[target_address] = new_formula
    print(f'Created new cell {target_address} with formula: {new_formula}')

# Save the modified workbook
wb.save(output_path)
print('Saved modified workbook to:', output_path)

# Verify by re‑loading with data_only=False and reading the target cell formula
wb_check = openpyxl.load_workbook(output_path, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]
print('Verification -', target_address, 'formula =', ws_check[target_address].value)
