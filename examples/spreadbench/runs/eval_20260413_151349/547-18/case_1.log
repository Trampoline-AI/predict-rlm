import openpyxl
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)               # provided variable
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas, we only copy values)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Get source and destination sheets (case‑sensitive names as they appear)
src_ws = wb["imported Data"]          # source sheet
if "summary Limits" in wb.sheetnames:
    dst_ws = wb["summary Limits"]
else:
    dst_ws = wb.create_sheet("summary Limits")

# Determine first empty row in destination (append after existing data)
dest_row = dst_ws.max_row + 1 if dst_ws.max_row > 0 else 1

rows_copied = 0

# Iterate over rows in source sheet
for row_idx in range(1, src_ws.max_row + 1):
    cell_a = src_ws.cell(row=row_idx, column=1)   # Column A
    val_a = cell_a.value
    if isinstance(val_a, str) and val_a.startswith("**"):
        # Find last column with data in this row
        last_col = 1
        for col_idx in range(src_ws.max_column, 0, -1):
            if src_ws.cell(row=row_idx, column=col_idx).value is not None:
                last_col = col_idx
                break

        # Copy values from A to last_col into destination row
        for col_idx in range(1, last_col + 1):
            src_cell = src_ws.cell(row=row_idx, column=col_idx)
            dst_ws.cell(row=dest_row, column=col_idx).value = src_cell.value

        dest_row += 1
        rows_copied += 1

# Save the modified workbook
wb.save(output_path)

# Verification output
print(f"Saved modified workbook to {output_path}")
print(f"Rows copied: {rows_copied}")
