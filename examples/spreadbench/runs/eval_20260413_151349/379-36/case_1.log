os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (preserve formulas if any)
wb = load_workbook(input_path)
ws = wb.active  # assume the target sheet is the active one

# Counters for reporting
changed_wh = 0
changed_sales = 0
cleared_h = 0

for row in ws.iter_rows(min_row=2, max_col=8, values_only=False):
    # Columns are 0‑indexed in the tuple; column E = index 4, F = 5, H = 7
    cell_e = row[4]
    cell_f = row[5]
    cell_h = row[7]

    # ----- Update column E based on the presence of the phrase -----
    if isinstance(cell_e.value, str) and "Georgia Its Tax" in cell_e.value:
        # Determine if column F is a whole number (no pennies)
        val_f = cell_f.value
        is_whole = False
        if isinstance(val_f, (int, float)):
            if isinstance(val_f, float):
                is_whole = val_f.is_integer()
            else:
                is_whole = True
        # Apply the appropriate text
        if is_whole:
            cell_e.value = "Georgia WH Tax"
            changed_wh += 1
        else:
            cell_e.value = "Georgia Sales Tax"
            changed_sales += 1

    # ----- Clear column H value and background fill -----
    if cell_h.value is not None or (cell_h.fill and cell_h.fill.fill_type is not None):
        cell_h.value = None
        # Remove any fill by setting a blank PatternFill
        cell_h.fill = PatternFill(fill_type=None)
        cleared_h += 1

# Save the modified workbook
wb.save(output_path)

print(f"Rows updated to WH Tax: {changed_wh}")
print(f"Rows updated to Sales Tax: {changed_sales}")
print(f"Column H cells cleared: {cleared_h}")
print(f"Output saved to: {output_path}")
