Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Paths from the variables
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas if any)
wb = load_workbook(input_path)
ws = wb.active  # assume first sheet is the target

# Counters for reporting
changed_wh = 0
changed_sales = 0
cleared_h = 0

for row in ws.iter_rows(min_row=2, max_col=8, values_only=False):
    # row is a tuple of Cell objects for columns A-H (1-8)
    cell_e = row[4]  # column E (index 4)
    cell_f = row[5]  # column F (index 5)
    cell_h = row[7]  # column H (index 7)

    # Ensure we have a string in column E
    if isinstance(cell_e.value, str) and cell_e.value == "Georgia Its Tax":
        # Determine if column F is a whole number
        val_f = cell_f.value
        is_whole = False
        if isinstance(val_f, (int, float)):
            # For floats, check if fractional part is zero
            if isinstance(val_f, float):
                is_whole = val_f.is_integer()
            else:
                is_whole = True
        # Update column E accordingly
        if is_whole:
            cell_e.value = "Georgia WH Tax"
            changed_wh += 1
        else:
            cell_e.value = "Georgia Sales Tax"
            changed_sales += 1

    # Clear column H value and background fill
    if cell_h.value is not None or cell_h.fill.fill_type is not None:
        cell_h.value = None
        # Remove any fill by setting fill_type to None
        cell_h.fill = PatternFill(fill_type=None)
        cleared_h += 1

# Save the modified workbook
wb.save(output_path)

print(f"Rows updated to WH Tax: {changed_wh}")
print(f"Rows updated to Sales Tax: {changed_sales}")
print(f"Column H cells cleared: {cleared_h}")
print(f"Output saved to: {output_path}")
```
