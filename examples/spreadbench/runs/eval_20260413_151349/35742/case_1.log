import openpyxl, pathlib, json, itertools

# Load the workbook (keep formulas)
wb_path = pathlib.Path(input_spreadsheet)
wb = openpyxl.load_workbook(wb_path, data_only=False)

# Store for later use
workbook = wb

# Print sheet overview
sheet_info = []
for ws in wb.worksheets:
    sheet_info.append({
        "title": ws.title,
        "max_row": ws.max_row,
        "max_column": ws.max_column,
    })
print("Sheets:", sheet_info)

# Sample first few rows of each sheet (show raw value and formula if present)
def cell_repr(cell):
    if cell.data_type == "f":
        return {"value": cell.value, "formula": cell.value}
    else:
        return {"value": cell.value}

samples = {}
for ws in wb.worksheets:
    rows = []
    for r in ws.iter_rows(min_row=1, max_row=min(5, ws.max_row), max_col=ws.max_column):
        rows.append([cell_repr(cell) for cell in r])
    samples[ws.title] = rows

print("Sample rows (first up to 5 rows per sheet):")
print(json.dumps(samples, indent=2, default=str))
