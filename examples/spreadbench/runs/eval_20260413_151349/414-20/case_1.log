Code:
```repl
import os
from pathlib import Path
from openpyxl import load_workbook

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (read‑write)
wb = load_workbook(filename=input_path)
ws = wb.active  # assume first sheet is the target

# Find first row with "Invoice No." in column A (case‑insensitive)
first_invoice_row = None
for r in range(1, ws.max_row + 1):
    cell_val = ws.cell(row=r, column=1).value
    if isinstance(cell_val, str) and "invoice no." in cell_val.lower():
        first_invoice_row = r
        break

if first_invoice_row is None:
    raise ValueError('Phrase "Invoice No." not found in column A.')

# Delete all rows above the found row
rows_to_delete = first_invoice_row - 1
if rows_to_delete > 0:
    ws.delete_rows(idx=1, amount=rows_to_delete)

# Save the modified workbook
wb.save(output_path)

# Verify: reload with data_only and print first few values of column A
wb_check = load_workbook(filename=output_path, data_only=True)
ws_check = wb_check.active
print("After deletion, first 10 values in column A:")
print([ws_check.cell(row=r, column=1).value for r in range(1, min(ws_check.max_row, 10)+1)])
```
