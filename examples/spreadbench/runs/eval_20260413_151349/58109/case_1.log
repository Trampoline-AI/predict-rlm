import pathlib, os, openpyxl, asyncio

# Paths
input_path = pathlib.Path(input_spreadsheet)  # /sandbox/input/input_spreadsheet/initial.xlsx
output_dir = pathlib.Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name  # same filename

# Load workbook with formulas intact
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# New formula to sum last four weekdays up to I4 (inclusive)
new_formula = '=SUMIFS(B:B, A:A, ">" & WORKDAY(I4, -4), A:A, "<=" & I4)'

# Update I6
