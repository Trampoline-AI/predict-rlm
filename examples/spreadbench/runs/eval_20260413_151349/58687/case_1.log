import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_58687_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_58687_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook for editing (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is relevant

# Determine the last column that contains month data (row 4)
# We'll scan from column C (index 3) until we hit a None value in row 4.
last_col = 3
while True:
    cell_val = ws.cell(row=4, column=last_col).value
    if cell_val is None:
        last_col -= 1
        break
    last_col += 1
# Ensure we have at least column C
if last_col < 3:
    last_col = 3

last_col_letter = get_column_letter(last_col)

# Build absolute range strings for lookup
cum_range = f"$C$6:${last_col_letter}$6"
month_range = f"$C$4:${last_col_letter}$4"

# Write the LOOKUP formula into column B (index 2) from row 9 to the last row with data
last_row = ws.max_row
for r in range(9, last_row + 1):
    formula = f"=LOOKUP(A{r}, {cum_range}, {month_range})"
    ws.cell(row=r, column=2).value = formula

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas using the provided tool
recalc_result = await recalc(output_path)
print("Recalc result:", recalc_result)

# Reload workbook with data_only to see computed values
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data[ws.title]

# Verification: print first 10 rows of column A (index) and column B (month)
print("Verification of first 10 rows (A=Index, B=Month):")
for r in range(9, 19):
    idx = ws_data.cell(row=r, column=1).value
    month = ws_data.cell(row=r, column=2).value
    print(f"Row {r}: Index={idx}, Month={month}")
```
