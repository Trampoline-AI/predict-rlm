import os
from openpyxl import load_workbook

# Path from previous iteration
output_path = "/sandbox/output/output_spreadsheet/1_178-22_init.xlsx"

# Reload workbook for verification (read only, data only)
wb_check = load_workbook(filename=output_path, data_only=True)

# Ensure Sheet2 exists
assert "Sheet2" in wb_check.sheetnames, "Sheet2 missing"

ws2 = wb_check["Sheet2"]

# Determine number of data rows (excluding header row at 2)
data_rows = ws2.max_row - 1  # because header is row 2, data starts at 3
print(f"Total rows in Sheet2 (including header): {ws2.max_row}")
print(f"Data rows (starting at row 3): {data_rows}")

# Print header (row 2) and first few data rows
header = [ws2.cell(row=2, column=c).value for c in range(1, ws2.max_column + 1)]
print("Header:", header)

# Show up to first 5 data rows
for r in range(3, min(3 + 5, ws2.max_row + 1)):
    row_vals = [ws2.cell(row=r, column=c).value for c in range(1, ws2.max_column + 1)]
    print(f"Row {r}:", row_vals)

# Assign output variable for submission
output_spreadsheet = output_path
