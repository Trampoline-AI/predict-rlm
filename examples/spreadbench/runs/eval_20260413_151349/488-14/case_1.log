# Compute frequencies in the output to verify ordering
freq_out = Counter(data_vals)
sorted_out = sorted(freq_out.items(), key=lambda x: (-x[1], x[0]))
print("Frequencies (desc):", sorted_out)

# Show first 10 rows of output
