Code:
```repl
import openpyxl, os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_47842_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_47842_init.xlsx")

# Load the saved workbook (data_only=False to see our written values)
wb = openpyxl.load_workbook(output_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Verify every row
mismatches = []
for row in range(2, ws.max_row + 1):
    orig = ws.cell(row=row, column=2).value
    conv = ws.cell(row=row, column=3).value
    if isinstance(orig, str) and isinstance(conv, str):
        # Check case of first character
        if (orig[0].isupper() and not conv[0].isupper()) or (orig[0].islower() and not conv[0].islower()):
            mismatches.append((row, orig, conv))
    else:
        # Record rows with missing data
        mismatches.append((row, orig, conv))

print(f"Total rows checked: {ws.max_row - 1}")
print(f"Mismatches found: {len(mismatches)}")
if mismatches:
    print("Examples of mismatches (up to 5):")
    for i, (row, orig, conv) in enumerate(mismatches[:5], start=1):
        print(f"Row {row}: Original='{orig}' | Converted='{conv}'")
else:
    print("All rows have correct capitalization.")
```
