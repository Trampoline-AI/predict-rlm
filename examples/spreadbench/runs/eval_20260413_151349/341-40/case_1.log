# Count rows where column Q (17) == "Volkswagen"
volkswagen_count = 0
for row in range(2, ws.max_row + 1):
    if ws.cell(row=row, column=17).value == "Volkswagen":
        volkswagen_count += 1

print(f"Total rows with 'Volkswagen' in column Q: {volkswagen_count}")

# Set the output variable as required by the task
