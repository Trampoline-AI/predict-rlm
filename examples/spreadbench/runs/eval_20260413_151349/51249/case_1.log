Code:
```repl
import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = load_workbook(input_path)
ws = wb.active

# Determine the last row with data in column B (or any column)
max_row = ws.max_row

# Build the formula string (LibreOffice compatible). We use IF and AND.
# The logic:
#   If B = "Description A" and C is empty -> "Single A"
#   Else if B = "Description B" and C is empty -> "Single B"
#   Else if B = "Description A" and C = "Description B" -> "Multiple"
#   Else -> ""
formula = (
    "=IF(AND(B1=\"Description A\", C1=\"\"), \"Single A\", "
    "IF(AND(B1=\"Description B\", C1=\"\"), \"Single B\", "
    "IF(AND(B1=\"Description A\", C1=\"Description B\"), \"Multiple\", \"\"))))"
)
# Write formula to D1
ws["D1"] = formula

# Fill down the formula for all rows (starting from row 2 to max_row)
for row in range(2, max_row + 1):
    ws.cell(row=row, column=4).value = formula.replace("B1", f"B{row}").replace("C1", f"C{row}")

# Save the workbook
wb.save(output_path)

print(f"Saved modified workbook to {output_path}")
```
