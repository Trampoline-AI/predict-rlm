```repl
import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep existing sheets)
wb = load_workbook(input_path)
ws = wb.active

# Determine the last row that has data in column B (description column)
max_row = ws.max_row
# Ensure we have at least one row of data beyond the header
if max_row < 2:
    max_row = 2

# Build the formula template for a given row r (checking B_r and B_{r+1})
# LibreOffice compatible IF/AND syntax

def formula_for(row: int) -> str:
    # References to current B and next B
    cur = f"B{row}"
    nxt = f"B{row + 1}"
    return (
        f"=IF(AND({cur}=\"Description A\", {nxt}=\"\"), \"Single A\", "
        f"IF(AND({cur}=\"Description B\", {nxt}=\"\"), \"Single B\", "
        f"IF(AND({cur}=\"Description A\", {nxt}=\"Description B\"), \"Multiple\", \"\"))))"
    )

# Write formulas to column D for all rows that have a header (starting at row 1)
for r in range(1, max_row + 1):
    ws.cell(row=r, column=4).value = formula_for(r)

# Save the workbook
wb.save(output_path)
print(f"Formulas written and saved to {output_path}")
```
