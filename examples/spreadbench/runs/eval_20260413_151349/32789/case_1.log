import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet  # "/sandbox/input/input_spreadsheet/initial.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (preserve formulas)
wb = load_workbook(input_path)
ws = wb.active  # assume the relevant sheet is the active one

# Formula template (row number will be adjusted automatically by copying)
formula_template = (
    '=IFERROR('
    'INDEX($BE$3:$BV$81, '
    'MATCH($A4,$BD$3:$BD$81,0), '
    'MATCH(CONCAT(B$2),$BE$2:$BV$2,0))'
    ',"-")'
)

# Apply formula to D4:D7 and set whole‑number format
for row in range(4, 8):  # 4,5,6,7
    cell = ws.cell(row=row, column=4)  # column D
    cell.value = formula_template
    cell.number_format = "0"  # whole number

# Clear any values below row 7 in columns C (3) and D (4)
max_row = ws.max_row
for row in range(8, max_row + 1):
    ws.cell(row=row, column=3).value = None  # column C
    ws.cell(row=row, column=4).value = None  # column D

# Save the modified workbook
wb.save(output_path)
```
