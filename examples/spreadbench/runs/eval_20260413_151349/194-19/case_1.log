Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)  # keep formulas if any

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Helper to preview first N rows of a sheet
def preview_sheet(ws, n=5):
    rows = []
    for i, row in enumerate(ws.iter_rows(values_only=True), start=1):
        rows.append(row)
        if i >= n:
            break
    return rows

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- {name} ---")
    print(f"Dimensions: max_row={ws.max_row}, max_column={ws.max_column}")
    # Show column letters and headers (first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print("Headers:", headers)
    # Show first few data rows
    data_rows = preview_sheet(ws, n=5)
    print("First rows:", data_rows)
```
