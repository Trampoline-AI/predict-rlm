import openpyxl, os, asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_39515_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_39515_init.xlsx")

# Load workbook preserving formulas
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Update column O (15) formulas for each data row
for r in range(2, ws.max_row + 1):
    # Build the new formula string with the correct row number
    new_formula = f"=IF($B{r}=2022, $C{r}, INDEX($C{r}:$N{r}, MATCH($A{r}, $C$1:$N$1, 0)))"
    ws.cell(row=r, column=15).value = new_formula

# Save the modified workbook
wb.save(output_path)

