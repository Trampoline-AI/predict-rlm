import openpyxl, os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_57743_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_57743_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Write lookup formula into column B for each row with data (skip header)
for r in range(2, ws.max_row + 1):
    ws.cell(row=r, column=2).value = f"=INDEX(D:D,MATCH(A{r},C:C,0))"

# Save the modified workbook
wb.save(output_path)

