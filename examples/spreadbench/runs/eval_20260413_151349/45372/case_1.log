- If the time in column A is **before** 09:45, copy the value from column B.
- If the time is **09:45 or after**, copy the value from column C.
- If the resulting value is `0`, leave the cell blank (set to None).
- Apply a solid fill color `#FFC000` to every cell in E2:E15.
All other formatting must stay unchanged. We'll load the workbook, iterate rows 2‑15, compute the appropriate value, set the cell value (or clear it if zero), apply the fill, then save the workbook to the output directory with the same filename.
Code:
```repl
import openpyxl
from openpyxl.styles import PatternFill
from datetime import time
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name  # same filename

# Load workbook (keep existing formatting)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume first sheet is target

# Define the fill color
fill = PatternFill(fill_type="solid", fgColor="FFC000")

# Threshold time
threshold = time(9, 45)

# Process rows 2 through 15 (or up to max_row if smaller)
for r in range(2, min(16, ws.max_row + 1)):
    time_cell = ws.cell(row=r, column=1)   # Column A
    val_b_cell = ws.cell(row=r, column=2) # Column B
    val_c_cell = ws.cell(row=r, column=3) # Column C
    target_cell = ws.cell(row=r, column=5) # Column E

    # Ensure we have a time object; if not, try parsing string
    cell_time = time_cell.value
    if isinstance(cell_time, str):
        # Attempt simple HH:MM parsing
        try:
            h, m = map(int, cell_time.split(":"))
            cell_time = time(h, m)
        except Exception:
            cell_time = None

    # Determine source value
    if isinstance(cell_time, time):
        source_val = val_b_cell.value if cell_time < threshold else val_c_cell.value
    else:
        # If time missing or unparsable, default to blank
        source_val = None

    # If source_val is numeric zero, clear the cell
    if source_val == 0:
        target_cell.value = None
    else:
        target_cell.value = source_val

    # Apply fill color
    target_cell.fill = fill

# Save the modified workbook
wb.save(output_path)

# Verify by reloading with data_only (cached values)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
# Print a quick summary of column E values for rows 2-15
summary = [ws_check.cell(row=r, column=5).value for r in range(2, min(16, ws_check.max_row + 1))]
print("Column E values (rows 2-15):", summary)
```
