import openpyxl
from pathlib import Path

# Load the workbook (read_only=False to allow full access)
wb_path = Path(input_spreadsheet)
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# Print sheet overview
print("Sheets:", wb.sheetnames)

for ws_name in wb.sheetnames:
    ws = wb[ws_name]
    print(f"\n--- Sheet: {ws_name} ---")
    print("Max row, max column:", ws.max_row, ws.max_column)

    # Print first row (likely headers)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print("Headers (first row):", headers)

    # List any tables defined in the sheet
    if hasattr(ws, "tables") and ws.tables:
        print("Tables in sheet:")
        for tbl_name, tbl in ws.tables.items():
            print(f"  Table name: {tbl_name}, ref: {tbl.ref}")
    else:
        print("No tables found in this sheet.")

    # Sample first few data rows (up to 5)
    sample_rows = []
    for r in range(2, min(ws.max_row, 6) + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        sample_rows.append(row_vals)
    print("Sample data rows (2-6):", sample_rows)
