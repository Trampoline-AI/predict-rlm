Code:
```repl
import openpyxl
from pathlib import Path
import asyncio

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path('/sandbox/output/output_spreadsheet')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Define the new formula (using structured references for the current row)
new_formula = "=IFERROR([@START_DATE] >= VLOOKUP([@PARTICIPANT_NAME], $D$2:$E$100, 2, FALSE), FALSE)"

# Iterate over all sheets and replace formulas in column G (7) for rows that belong to any table
for ws in wb.worksheets:
    # Determine rows that are part of any table using ws.tables definitions
    table_rows = set()
    if hasattr(ws, 'tables'):
        for tbl in ws.tables.values():
            # tbl.ref is a range like 'A3:B6'
            ref = tbl.ref
            # Parse the range to get start/end rows
            start_cell, end_cell = ref.split(':')
            start_row = ws[start_cell].row
            end_row = ws[end_cell].row
            # Add all rows of the table (including header row) – we will skip header later
            for r in range(start_row, end_row + 1):
                table_rows.add(r)
    # Now replace formulas in column G for each data row (skip header rows which usually have column titles)
    for r in sorted(table_rows):
        # Skip header row (first row of each table)
        # Header row can be identified by checking if column A of that row contains a string header like 'PARTICIPANT_NAME'
        header_val = ws.cell(row=r, column=1).value
        if isinstance(header_val, str) and header_val.upper().startswith('PARTICIPANT'):
            continue
        # Write new formula in column G (7)
        ws.cell(row=r, column=7).value = new_formula

# Save the modified workbook
wb.save(output_path)
print('Workbook saved to', output_path)

# Recalculate formulas to cache results (LibreOffice fallback)
# The recalculate tool is async; we call it and wait for result
recalc_result = await recalculate(str(output_path))
print('Recalc result:', recalc_result)

# Reload workbook with data_only=True to read cached boolean values
wb_cached = openpyxl.load_workbook(output_path, data_only=True)
ws = wb_cached.active
# Print a few sample rows from column G to verify
samples = []
for r in range(3, min(ws.max_row, 10) + 1):
    samples.append((r, ws.cell(row=r, column=7).value))
print('Sample column G values (row, value):', samples)
```
