Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path('/sandbox/input/input_spreadsheet/1_54513_init.xlsx')
output_dir = Path('/sandbox/output/output_spreadsheet/')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / '1_54513_init.xlsx'

# Load workbook for editing
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Write discounted price formula in column F (6) of row 8 (original price in C8)
# Discount is 55% => keep 45% => multiply by 0.45
ws.cell(row=8, column=6).value = "=C8*0.45"

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas to cache values
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Verify the formula and its cached value by loading with data_only
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
formula_cell = ws_check.cell(row=8, column=6)
print("Cell F8 cached value after recalculation:", formula_cell.value)
```
