import openpyxl, os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_40959_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_40959_init.xlsx')

# Load workbook (writeable)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine max row with data (ignore completely empty trailing rows)
max_row = ws.max_row

# Apply new formula to column C (index 3) for rows 2..max_row
for row in range(2, max_row + 1):
    a_cell = ws.cell(row=row, column=1).value  # Column A
    b_cell = ws.cell(row=row, column=2).value  # Column B
    # Build formula string (reference same row)
    formula = (
        f'=IF(AND(A{row}="Sales",B{row}=""),"Sales",'
        f'IF(AND(A{row}="Sales-Marketing",B{row}=""),"Marketing",'
        f'IF(B{row}="General","Marketing","")))'
    )
    ws.cell(row=row, column=3, value=formula)

# Save workbook
wb.save(output_path)

# Verify a few rows
for r in range(2, min(6, max_row+1)):
    print(f'Row {r} C formula:', ws.cell(row=r, column=3).value)
