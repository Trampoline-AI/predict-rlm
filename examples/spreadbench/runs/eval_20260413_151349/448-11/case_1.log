import os
from openpyxl import load_workbook

# Path to the output workbook created in the previous step
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))

# Load the workbook with data_only to read any cached values
wb = load_workbook(output_path, data_only=True)
ws = wb.active

# Gather Column A values (skip header and empty cells)
col_a_vals = []
for r in range(1, ws.max_row + 1):
    val = ws.cell(row=r, column=1).value
    if r == 1 and (val is None or str(val).strip() == ""):
        # If the first row is empty, treat it as possible header row
        continue
    if r == 1 and val is not None:
        # Assume first row is header; skip it for duplicate checking
        continue
    if val is not None:
        col_a_vals.append(val)

# Check for duplicates
duplicates = [v for v in set(col_a_vals) if col_a_vals.count(v) > 1]

print("Column A values after processing:", col_a_vals)
print("Found duplicates:", duplicates)
print("Total rows in output workbook:", ws.max_row)
print("Output file path:", output_path)
```
