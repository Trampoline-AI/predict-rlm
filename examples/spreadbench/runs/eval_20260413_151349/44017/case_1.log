import openpyxl, pathlib, json

# Paths
input_path = pathlib.Path("/sandbox/input/input_spreadsheet/1_44017_init.xlsx")
output_dir = pathlib.Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_44017_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Helper to get baseline column letter for a given month index (0‑based)
# Baseline columns Q‑AB correspond to months 1‑12
baseline_cols = [openpyxl.utils.get_column_letter(col) for col in range(openpyxl.utils.column_index_from_string('Q'),
                                                                 openpyxl.utils.column_index_from_string('AB')+1)]

# Write formulas for each row from 14 to max_row
for row in range(14, ws.max_row + 1):
    # Effective date cell
    eff_date_cell = ws.cell(row=row, column=openpyxl.utils.column_index_from_string('L'))
    # Frequency cell (months between waves)
    freq_cell = ws.cell(row=row, column=openpyxl.utils.column_index_from_string('J'))
    # Increase percentage cells (M‑P)
    inc1_cell = ws.cell(row=row, column=openpyxl.utils.column_index_from_string('M'))
    inc2_cell = ws.cell(row=row, column=openpyxl.utils.column_index_from_string('N'))
    inc3_cell = ws.cell(row=row, column=openpyxl.utils.column_index_from_string('O'))
    inc4_cell = ws.cell(row=row, column=openpyxl.utils.column_index_from_string('P'))

    # Write formulas across AD (column 30) to AO (column 39)
    for col_offset in range(0, 10):  # AD..AO inclusive (10 columns)
        target_col_idx = openpyxl.utils.column_index_from_string('AD') + col_offset
        target_col_letter = openpyxl.utils.get_column_letter(target_col_idx)
        # Baseline column for this month
        baseline_col_letter = baseline_cols[col_offset]
        baseline_cell_ref = f"{baseline_col_letter}{row}"
        # Target date = effective date shifted by col_offset months
        # Use EDATE(Lrow, col_offset)
        target_date_expr = f"EDATE({eff_date_cell.coordinate}, {col_offset})"
        # Build the sequential multiplication formula
        # baseline * (IF(target_date >= L, 1, 1)) * (IF(target_date >= EDATE(L, J), 1+M, 1)) * ...
        # We need to guard against missing frequency (J) or missing increase percentages.
        # Use IFERROR to avoid errors when J is empty.
        formula = (
            f"={baseline_cell_ref} * "
            f"IF({target_date_expr} >= {eff_date_cell.coordinate}, 1, 1) * "
            f"IF({target_date_expr} >= EDATE({eff_date_cell.coordinate}, {freq_cell.coordinate}), 1+{inc1_cell.coordinate}, 1) * "
            f"IF({target_date_expr} >= EDATE({eff_date_cell.coordinate}, {freq_cell.coordinate}*2), 1+{inc2_cell.coordinate}, 1) * "
            f"IF({target_date_expr} >= EDATE({eff_date_cell.coordinate}, {freq_cell.coordinate}*3), 1+{inc3_cell.coordinate}, 1) * "
            f"IF({target_date_expr} >= EDATE({eff_date_cell.coordinate}, {freq_cell.coordinate}*4), 1+{inc4_cell.coordinate}, 1)"
        )
        ws.cell(row=row, column=target_col_idx).value = formula

# Save the modified workbook
wb.save(output_path)

print(f"Formulas written to {output_path}")
print(f"Rows processed: {ws.max_row - 13}")
print(f"Columns AD‑AO written: {list(openpyxl.utils.get_column_letter(c) for c in range(openpyxl.utils.column_index_from_string('AD'), openpyxl.utils.column_index_from_string('AO')+1))}")
```
