Code:
```repl
import os
import openpyxl

# Paths
input_path = input_spreadsheet  # /sandbox/input/input_spreadsheet/1_36764_init.xlsx
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
# Identify sheets (first sheet is Sheet1, second is Sheet2)
sheet1 = wb[wb.sheetnames[0]]
sheet2 = wb[wb.sheetnames[1]]

# Prepare sheet name reference for formulas (quote if contains spaces or special chars)
def quote_sheet(name):
    if any(ch in name for ch in " -+*/!@#$%^&*()[]{};:'\",<>?"):
        return f"'{name}'"
    return name

sheet2_ref = quote_sheet(sheet2.title)

# Write SUMIFS formula in C2 of Sheet1
# =SUMIFS(Sheet2!R2:R363, Sheet2!A2:A363, A2)
formula = f"=SUMIFS({sheet2_ref}!R2:R363, {sheet2_ref}!A2:A363, A2)"
sheet1["C2"] = formula

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas so the cached value is stored
await recalculate(output_path)

# Verify the cached result by loading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
sheet1_check = wb_check[wb_check.sheetnames[0]]
c2_cached = sheet1_check["C2"].value
print("Cached value in Sheet1!C2 after recalculation:", c2_cached)

# Store the output path for final submission
output_spreadsheet = output_path
```
