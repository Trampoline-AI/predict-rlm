Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_59358_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_59358_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume first sheet

# Helper to get cell value safely
def get_val(row, col):
    return ws.cell(row=row, column=col).value

# Read target values from L7, L8, L9 (column 12)
targets = [get_val(r, 12) for r in (7, 8, 9)]
print("Targets:", targets)

# Build set of values in D2:D23 (column 4)
d_values = {get_val(r, 4) for r in range(2, 24)}
print("D column values (set):", d_values)

# For each target, find first matching row in B where target also in D set
results = []
for target in targets:
    match_f = ""
    if target is not None and target in d_values:
        for r in range(2, 24):
            b_val = get_val(r, 2)  # column B
            if b_val == target:
                match_f = get_val(r, 6) or ""  # column F
                break
    results.append(match_f)

print("Matched F values:", results)

# Write results into column M (13) rows 7,8,9
for idx, r in enumerate((7, 8, 9)):
    ws.cell(row=r, column=13, value=results[idx])

# Save workbook
wb.save(output_path)
print("Saved to", output_path)
```
