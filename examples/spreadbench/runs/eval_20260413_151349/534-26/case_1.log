# Load the workbook to verify the macro sheet
wb = openpyxl.load_workbook(output_path, data_only=False)
macro_ws = wb['Macro']
macro_text = macro_ws['A1'].value

print("Macro sheet present? ", macro_ws.title == 'Macro')
print("First 200 characters of macro text:")
print(macro_text[:200])

# Set the output variable for submission
output_spreadsheet = output_path
