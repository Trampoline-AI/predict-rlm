import openpyxl

# Load the workbook (read_only for faster inspection)
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False, read_only=True)

print(f"Workbook loaded: {wb_path}")
print("Sheet names:", wb.sheetnames)

# Function to preview first few rows of a sheet

def preview_sheet(ws, max_rows=5):
    data = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        if i >= max_rows:
            break
        data.append(row)
    return data

for name in wb.sheetnames:
    ws = wb[name]
    print(f"\nSheet: {name}")
    print(f"  Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    preview = preview_sheet(ws)
    print("  First rows:")
    for r in preview:
        print("    ", r)
```
