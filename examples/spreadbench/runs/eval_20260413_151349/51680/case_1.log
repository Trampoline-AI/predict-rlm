Code:
```repl
import os
from pathlib import Path
from openpyxl import load_workbook

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_51680_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (preserve formatting)
wb = load_workbook(input_path)
ws = wb.active  # assume the first sheet is the target

# Read and strip header texts from A1:F1 (columns 1‑6)
raw_headers = [ws.cell(row=1, column=col).value for col in range(1, 7)]
headers = [str(h).strip() if h is not None else "" for h in raw_headers]

# Process each data row
row_count = 0
for row in range(2, ws.max_row + 1):
    selected = []
    for col, header in enumerate(headers, start=1):
        cell_val = ws.cell(row=row, column=col).value
        if isinstance(cell_val, str) and cell_val.strip().upper() == "Y":
            selected.append(header)
    result_text = ", ".join(selected)
    ws.cell(row=row, column=7).value = result_text  # column G
    row_count += 1

# Save the modified workbook
wb.save(output_path)

# Verification: print summary and a few sample rows
print(f"Processed {row_count} rows.")
print("Headers (stripped):", headers)
# Show first 10 rows of column G
samples = [ws.cell(row=r, column=7).value for r in range(2, min(12, ws.max_row + 1))]
print("Sample G column values (first 10 rows):", samples)
```
