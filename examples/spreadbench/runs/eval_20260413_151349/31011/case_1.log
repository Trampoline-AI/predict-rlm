# Assume the first sheet is the target (adjust if needed)
ws = wb[wb.sheetnames[0]]

# Basic dimensions
print("Max row:", ws.max_row, "Max column:", ws.max_column)

# Show column letters for max column
from openpyxl.utils import get_column_letter
print("Last column letter:", get_column_letter(ws.max_column))

# Sample a few cells around the expected header (row 1) and date column (A)
print("Row 1 (times) sample:", [ws.cell(row=1, column=c).value for c in range(2, min(10, ws.max_column+1))])
print("Column A (dates) sample:", [ws.cell(row=r, column=1).value for r in range(2, min(10, ws.max_row+1))])

# Show where R6 currently is
print("Current R6 value:", ws["R6"].value)

# Determine the data block: assume it starts at B2 and ends at the column before R (i.e., column Q) and last row with data
# Find the column index of R
col_R = openpyxl.utils.column_index_from_string("R")
# Data block columns: B (2) to column before R (col_R-1)
data_start_col = 2
data_end_col = col_R - 1
data_start_row = 2
data_end_row = ws.max_row

print(f"Data block range: {openpyxl.utils.get_column_letter(data_start_col)}{data_start_row}:{openpyxl.utils.get_column_letter(data_end_col)}{data_end_row}")

# Save this info for later use
exploration = {
    "sheet_name": ws.title,
    "max_row": ws.max_row,
    "max_column": ws.max_column,
    "data_start_col": data_start_col,
    "data_end_col": data_end_col,
    "data_start_row": data_start_row,
    "data_end_row": data_end_row,
}
```
