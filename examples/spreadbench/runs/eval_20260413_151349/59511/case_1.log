import openpyxl
from pathlib import Path

# Load the input workbook
input_path = Path("/sandbox/input/input_spreadsheet/1_59511_init.xlsx")
wb = openpyxl.load_workbook(input_path)
print("Sheets:", wb.sheetnames)

# Inspect the first sheet (assume that's the one we need)
ws = wb[wb.sheetnames[0]]

# Print column headers from the first row
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
print("Headers:", headers)

# Show a few rows of data (first 5 rows)
sample_rows = []
for r in range(2, min(7, ws.max_row + 1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    sample_rows.append(row_vals)
print("Sample rows (first 5):", sample_rows)

# Identify which column likely holds the base numbers for the increment.
# We'll look for a numeric column that changes gradually.
numeric_cols = {}
for c in range(1, ws.max_column + 1):
    col_vals = [ws.cell(row=r, column=c).value for r in range(2, ws.max_row + 1)]
    # Count how many are numbers
    num_numbers = sum(1 for v in col_vals if isinstance(v, (int, float)))
    if num_numbers > 0:
        numeric_cols[c] = num_numbers
print("Numeric columns with counts:", numeric_cols)

# For demonstration, assume the base numbers are in column E (5th column)
# Write the formula into column F (6th column): =INT(E2/1000)
target_col = 6  # F
source_col = 5  # E

for r in range(2, ws.max_row + 1):
    ws.cell(row=r, column=target_col).value = f"=INT({openpyxl.utils.get_column_letter(source_col)}{r}/1000)"
    # Optionally, add a header if not present
if ws.cell(row=1, column=target_col).value is None:
    ws.cell(row=1, column=target_col).value = "Incremented"

# Save to output directory
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_59511_init.xlsx"
wb.save(output_path)
print("Saved modified workbook to:", output_path)
```
