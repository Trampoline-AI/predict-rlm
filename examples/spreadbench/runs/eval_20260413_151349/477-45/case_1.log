```repl
import os
from openpyxl import load_workbook

# Load the workbook
input_path = input_spreadsheet  # provided variable
wb = load_workbook(input_path)
ws = wb.active  # assume first sheet

# Inspect sheet name and first few rows
print("Sheet name:", ws.title)
print("Max row:", ws.max_row, "Max column:", ws.max_column)

# Show first row (headers) values
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
print("Headers (first row):", headers)

# Show a few sample rows
