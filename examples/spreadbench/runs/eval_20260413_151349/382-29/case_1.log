import os
import shutil
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Copy the input workbook to the output location
shutil.copyfile(input_path, output_path)

# Recalculate all formulas in the copied workbook
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Load the workbook with cached (calculated) values
wb = load_workbook(output_path, data_only=True)

# Identify the Totals sheet (case‑insensitive match for "total")
totals_sheet = None
for ws in wb.worksheets:
    if "total" in ws.title.lower():
        totals_sheet = ws
        break
if totals_sheet is None:
    totals_sheet = wb.worksheets[-1]  # fallback
print("Totals sheet:", totals_sheet.title)

# All other sheets are considered data sheets
data_sheets = [ws for ws in wb.worksheets if ws.title != totals_sheet.title]
print("Number of data sheets:", len(data_sheets))

# Sum B2‑B26 across data sheets and write to Totals sheet
for row in range(2, 27):  # rows 2 through 26 inclusive
    total = 0
    for ws in data_sheets:
        val = ws.cell(row=row, column=2).value
        # Convert numeric strings to float if possible
        if isinstance(val, (int, float)):
            total += val
        elif isinstance(val, str):
            try:
                num = float(val)
                total += num
            except ValueError:
                pass  # non‑numeric string, ignore
    totals_sheet.cell(row=row, column=2).value = total

# Save the updated workbook
wb.save(output_path)

# Verification: print summed totals for B2‑B5
print("Verification of summed totals (B2‑B5) on Totals sheet:")
for row in range(2, 6):
    print(f"B{row}: {totals_sheet.cell(row=row, column=2).value}")

print("Output workbook saved to:", output_path)
```
