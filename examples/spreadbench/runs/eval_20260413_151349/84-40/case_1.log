Code:
```repl
import openpyxl, json, os

# Load the workbook (read only for inspection)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=True)

# Gather sheet information
sheet_info = {}
for ws in wb.worksheets:
    # Get first row values (header) if present
    header = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    # Sample first few data rows (up to 5)
    rows = []
    for r in range(2, min(ws.max_row, 6)+1):
        rows.append([ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)])
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "header": header,
        "sample_rows": rows,
    }

print(json.dumps(sheet_info, indent=2, default=str))
```
2026-04-13 15:17:59,686 INFO RLM iteration 2/50
Reasoning: We have inspected the workbook. It contains sheets CA, MN, SDFRT, and LIST. The task is to sum column C (IMPORT) and column D (EXPORT) for each sheet (excluding column B) and write those sums into the LIST sheet: column B gets the sheet name, column C gets the IMPORT sum, column D gets the EXPORT sum, and column E gets the balance (IMPORT - EXPORT). The LIST sheet already has rows for each sheet and a TOTAL row; we will update the existing rows (or add them if missing) and compute the overall totals for the TOTAL row. We'll load the workbook, compute the sums, write the values back, save the workbook to the output directory, and finally verify the written values.
Code:
```repl
import os
import openpyxl
from pathlib import Path

# Paths
input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Compute sums for each sheet except LIST
sheet_sums = {}
for ws in wb.worksheets:
    if ws.title.upper() == "LIST":
        continue
    import_sum = 0
    export_sum = 0
    for row in ws.iter_rows(min_row=2, max_col=4, values_only=True):
        # row indices: 0=DATE,1=BATCH,2=IMPORT,3=EXPORT
        imp = row[2]
        exp = row[3]
        if isinstance(imp, (int, float)):
            import_sum += imp
        if isinstance(exp, (int, float)):
            export_sum += exp
    sheet_sums[ws.title] = (import_sum, export_sum)

# Access LIST sheet (create if missing)
if "LIST" in wb.sheetnames:
    list_ws = wb["LIST"]
else:
    list_ws = wb.create_sheet("LIST")

# Ensure header exists (row 1)
headers = [list_ws.cell(row=1, column=c).value for c in range(1, list_ws.max_column+1)]
# If header missing or incomplete, set it
expected_headers = ["ITEMS", "SHEETS NAMES", "IMPORT", "EXPORT", "BALANCE"]
if headers[:5] != expected_headers:
    for idx, title in enumerate(expected_headers, start=1):
        list_ws.cell(row=1, column=idx).value = title

# Map existing sheet name rows in LIST (by column B)
name_to_row = {}
for r in range(2, list_ws.max_row + 1):
    name = list_ws.cell(row=r, column=2).value
    if isinstance(name, str):
        name_to_row[name] = r

# Write per‑sheet totals
next_row = list_ws.max_row + 1
for sheet_name, (imp_sum, exp_sum) in sheet_sums.items():
    if sheet_name in name_to_row:
        row = name_to_row[sheet_name]
    else:
        # Append a new row after current data (before TOTAL if present)
        # Find if a TOTAL row exists (column B == "TOTAL")
        total_row = None
        for r in range(2, list_ws.max_row + 1):
            if list_ws.cell(row=r, column=2).value == "TOTAL":
                total_row = r
                break
        if total_row:
            row = total_row  # will overwrite the TOTAL row later after totals are computed
        else:
            row = next_row
            next_row += 1
    # Write sheet name, import, export, balance
    list_ws.cell(row=row, column=2).value = sheet_name
    list_ws.cell(row=row, column=3).value = imp_sum
    list_ws.cell(row=row, column=4).value = exp_sum
    list_ws.cell(row=row, column=5).value = imp_sum - exp_sum

# Compute overall totals for the TOTAL row
total_import = sum(imp for imp, _ in sheet_sums.values())
total_export = sum(exp for _, exp in sheet_sums.values())
total_balance = total_import - total_export

# Locate or create TOTAL row (column B == "TOTAL")
total_row = None
for r in range(2, list_ws.max_row + 1):
    if list_ws.cell(row=r, column=2).value == "TOTAL":
        total_row = r
        break
if total_row is None:
    total_row = list_ws.max_row + 1
    list_ws.cell(row=total_row, column=2).value = "TOTAL"

list_ws.cell(row=total_row, column=3).value = total_import
list_ws.cell(row=total_row, column=4).value = total_export
list_ws.cell(row=total_row, column=5).value = total_balance

# Save workbook to output path
wb.save(output_path)

# Verify by re‑loading with data_only=True and printing the LIST sheet summary
verify_wb = openpyxl.load_workbook(output_path, data_only=True)
verify_ws = verify_wb["LIST"]
print("LIST sheet after update:")
for r in range(1, verify_ws.max_row + 1):
    vals = [verify_ws.cell(row=r, column=c).value for c in range(1, 6)]
    print(vals)
```
