import openpyxl
from openpyxl.styles import Font, Border, Side, PatternFill
from openpyxl.worksheet.views import SheetView

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = f"{output_dir}/processed.xlsx"

# Ensure output directory exists
import os
os.makedirs(output_dir, exist_ok=True)

# Load original workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is Sheet1

max_row = ws.max_row
max_col = ws.max_column

# 1. Apply Arial font everywhere (preserve size if present)
for r in range(1, max_row + 1):
    for c in range(1, max_col + 1):
        cell = ws.cell(row=r, column=c)
        size = cell.font.size if cell.font.size else 11
        cell.font = Font(name="Arial", size=size)

# 2. Header row formatting (row 1)
thin_side = Side(style="thin", color="000000")
thin_border = Border(left=thin_side, right=thin_side, top=thin_side, bottom=thin_side)
for c in range(1, max_col + 1):
    hdr = ws.cell(row=1, column=c)
    hdr.font = Font(name="Arial", bold=True, italic=True, size=hdr.font.size)
    hdr.border = thin_border

# 3. Fill column D (column 4) from D2 onward with #CCCCCC (ARGB FFCCCCCC)
fill_d = PatternFill(start_color="FFCCCCCC", end_color="FFCCCCCC", fill_type="solid")
for r in range(2, max_row + 1):
    ws.cell(row=r, column=4).fill = fill_d

# 4. Write lookup formula in column A (column 1) from A2 onward and fill #FCD5B4 (ARGB FFFCD5B4)
fill_a = PatternFill(start_color="FFFCD5B4", end_color="FFFCD5B4", fill_type="solid")
for r in range(2, max_row + 1):
    formula = (
        f"=INDEX($H$2:$H${max_row}, "
        f"MATCH(1, ($I$2:$I${max_row}=B{r}) * ($J$2:$J${max_row}=C{r}), 0))"
    )
    cell = ws.cell(row=r, column=1)
    cell.value = formula
    cell.fill = fill_a
    # Ensure font stays Arial (size already set above)
    cell.font = Font(name="Arial", size=cell.font.size)

# 5. Hide gridlines
if hasattr(ws, "sheet_view") and ws.sheet_view is not None:
    ws.sheet_view.showGridLines = False
else:
    ws.sheet_view = SheetView(showGridLines=False)

# Save the workbook
wb.save(output_path)

# ---------- Verification ----------

def get_fill_hex(cell):
    fill = cell.fill
    if isinstance(fill, PatternFill) and fill.fill_type == "solid":
        rgb = getattr(fill.start_color, "rgb", None)
        if rgb and len(rgb) == 8:
            return f"#{rgb[2:]}"  # strip alpha
    return None

# Load saved workbook for verification (data_only=False to see formulas)
wb_check = openpyxl.load_workbook(output_path, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]

print("A2 formula:", ws_check["A2"].value)
print("A2 fill:", get_fill_hex(ws_check["A2"]))
print("D2 fill:", get_fill_hex(ws_check["D2"]))
print("Header A1 bold:", ws_check["A1"].font.bold, "italic:", ws_check["A1"].font.italic)
print("Header A1 border:", ws_check["A1"].border.left.style,
      ws_check["A1"].border.right.style, ws_check["A1"].border.top.style,
      ws_check["A1"].border.bottom.style)
print("Gridlines hidden:", ws_check.sheet_view.showGridLines)
# Check later rows for fill consistency
for r in range(10, 13):
    print(f"Row {r} A{r} fill:", get_fill_hex(ws_check.cell(row=r, column=1)))
