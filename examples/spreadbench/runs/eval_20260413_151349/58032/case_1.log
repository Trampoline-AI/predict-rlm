```repl
import os
import openpyxl
from openpyxl.styles import Font, Border, Side, PatternFill

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_58032_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is Sheet1

max_row = ws.max_row
max_col = ws.max_column

# 1. Apply Arial font everywhere (preserve size)
for r in range(1, max_row + 1):
    for c in range(1, max_col + 1):
        cell = ws.cell(row=r, column=c)
        # Preserve existing size if any, else default 11
        size = cell.font.size if cell.font.size else 11
        cell.font = Font(name="Arial", size=size)

# 2. Header row formatting (row 1)
thin_side = Side(style="thin", color="000000")
thin_border = Border(left=thin_side, right=thin_side, top=thin_side, bottom=thin_side)

for c in range(1, max_col + 1):
    hdr = ws.cell(row=1, column=c)
    hdr.font = Font(name="Arial", bold=True, italic=True, size=hdr.font.size)
    hdr.border = thin_border

# 3. Fill column D (column 4) from D2 onward with #CCCCCC
fill_d = PatternFill(fill_type="solid", fgColor="CCCCCC")
for r in range(2, max_row + 1):
    ws.cell(row=r, column=4).fill = fill_d

# 4. Write lookup formula in column A (column 1) from A2 onward
# Formula: =INDEX($H$2:$H${max_row}, MATCH(1, ($I$2:$I${max_row}=B2) * ($J$2:$J${max_row}=C2), 0))
# Fill color for formula cells: #FCD5B4
fill_a = PatternFill(fill_type="solid", fgColor="FCD5B4")
for r in range(2, max_row + 1):
    formula = (
        f"=INDEX($H$2:$H${max_row}, "
        f"MATCH(1, ($I$2:$I${max_row}=B{r}) * ($J$2:$J${max_row}=C{r}), 0))"
    )
    cell = ws.cell(row=r, column=1)
    cell.value = formula
    cell.fill = fill_a
    # Ensure font is Arial (size already set above)
    cell.font = Font(name="Arial", size=cell.font.size)

# 5. Hide gridlines
if not hasattr(ws, "sheet_view"):
    ws.sheet_view = openpyxl.worksheet.views.SheetView()
ws.sheet_view.showGridLines = False

# Save to output path
wb.save(output_path)

print(f"Workbook saved to {output_path}")
print(f"Rows: {max_row}, Columns: {max_col}")
```
