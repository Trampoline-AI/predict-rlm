import openpyxl

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row

# Collect rows where column C has a formula (starts with '=')
formula_rows = []
for r in range(2, max_row + 1):
    cell_c = ws.cell(row=r, column=3)
    if isinstance(cell_c.value, str) and cell_c.value.startswith('='):
        formula_rows.append((r, cell_c.value))

print(f"Found {len(formula_rows)} rows with formulas in column C.")
# Show first 15 such rows
for r, f in formula_rows[:15]:
    print(f"Row {r}: {f}")

# Also capture the target row number from the formula (e.g., =A25 -> 25)
import re
targets = []
for r, f in formula_rows:
    m = re.search(r'A(\d+)', f)
    if m:
        targets.append((r, int(m.group(1))))
print("Mappings (row C -> source A row):")
for r, src in targets[:15]:
    print(f"{r} -> {src}")

# Compute differences to see if a consistent offset exists
diffs = [src - r for r, src in targets]
print("Differences (source - target row) for first 15 mappings:")
print(diffs[:15])
```
