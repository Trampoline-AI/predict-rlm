The task is to recreate Sheet1 exactly (preserving all cell values and existing formatting), then:

1. Make the heading row (row 4) bold, give every heading cell a thin border on all sides, and ensure wrap‑text is on for the whole row.
2. Clear any values and borders from column G.
3. Count how many rows have the operator number **5551234** in column D (the “transfer number”) and a non‑empty staff entry in column E. Write that total count into the cell immediately to the right of the **last** such row – i.e., column H of that row (since column G must stay empty).

We will copy the source sheet cell‑by‑cell (value + style) into a new workbook, then apply the modifications, save the result to the output directory, and finally verify the count cell.
Code:
```repl
import openpyxl
from openpyxl import Workbook, load_workbook
from openpyxl.styles import Font, Border, Side, Alignment

# Paths
src_path = input_spreadsheet
dst_dir = "/sandbox/output/output_spreadsheet/"
dst_path = dst_dir + "1_58484_init.xlsx"

# Load source workbook (keep formulas, styles)
src_wb = load_workbook(src_path, data_only=False)
src_ws = src_wb["Sheet1"]

# Create destination workbook and a sheet named Sheet1
dst_wb = Workbook()
# Remove default sheet
default_ws = dst_wb.active
dst_wb.remove(default_ws)
dst_ws = dst_wb.create_sheet(title="Sheet1")

# Helper to copy style objects
def copy_style(cell):
    # Font
    font = cell.font.copy()
    # Fill
    fill = cell.fill.copy()
    # Border
    border = cell.border.copy()
    # Alignment
    alignment = cell.alignment.copy()
    # Number format
    number_format = cell.number_format
    # Protection
    protection = cell.protection.copy()
    return font, fill, border, alignment, number_format, protection

# Copy all cells (value + style)
for row in src_ws.iter_rows(min_row=1, max_row=src_ws.max_row,
                            min_col=1, max_col=src_ws.max_column):
    for src_cell in row:
        dst_cell = dst_ws.cell(row=src_cell.row, column=src_cell.column)
        dst_cell.value = src_cell.value
        # Copy style
        font, fill, border, alignment, number_format, protection = copy_style(src_cell)
        dst_cell.font = font
        dst_cell.fill = fill
        dst_cell.border = border
        dst_cell.alignment = alignment
        dst_cell.number_format = number_format
        dst_cell.protection = protection

# ----------------------------------------------------------------------
# 1. Format heading row (row 4): bold, thin border on all sides, wrap text
thin_side = Side(style="thin", color="000000")
thin_border = Border(left=thin_side, right=thin_side,
                     top=thin_side, bottom=thin_side)

max_col = dst_ws.max_column
for col in range(1, max_col + 1):
    cell = dst_ws.cell(row=4, column=col)
    # Bold
    cell.font = cell.font.copy(bold=True)
    # Thin border
    cell.border = thin_border
    # Wrap text
    cell.alignment = cell.alignment.copy(wrap_text=True)

# ----------------------------------------------------------------------
# 2. Ensure column G (col 7) has no values and no borders
for row in range(1, dst_ws.max_row + 1):
    cell = dst_ws.cell(row=row, column=7)
    cell.value = None
    cell.border = Border()   # no borders

# ----------------------------------------------------------------------
# 3. Count transfers for operator 5551234 and write total next to last transfer
transfer_number = 5551234
count = 0
last_row = None

for row in range(5, dst_ws.max_row + 1):   # data starts after header row (row 4)
    d_val = dst_ws.cell(row=row, column=4).value
    e_val = dst_ws.cell(row=row, column=5).value
    if d_val == transfer_number and e_val not in (None, "", 0):
        count += 1
        last_row = row

if last_row is not None:
    # Write count into column H (col 8) of the last matching row
    dst_ws.cell(row=last_row, column=8).value = count
    # Optional: make it bold for visibility
    dst_ws.cell(row=last_row, column=8).font = dst_ws.cell(row=last_row, column=8).font.copy(bold=True)

# ----------------------------------------------------------------------
# Save the destination workbook
dst_wb.save(dst_path)

# Verify: print the count cell location and value
print("Total transfers counted:", count)
if last_row:
    print("Count written to cell:", f"H{last_row}")
    print("Cell value:", dst_ws.cell(row=last_row, column=8).value)
```
