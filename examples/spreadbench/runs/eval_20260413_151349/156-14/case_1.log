Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path('/sandbox/input/input_spreadsheet/1_156-14_init.xlsx')
output_dir = Path('/sandbox/output/output_spreadsheet')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook
wb = openpyxl.load_workbook(input_path)

target_sheets = ["99250", "99251", "99252"]

for sheet_name in target_sheets:
    if sheet_name not in wb.sheetnames:
        print(f"Sheet {sheet_name} not found, skipping.")
        continue
    ws = wb[sheet_name]
    rows_to_delete = []
    # Scan rows from 6 to max_row inclusive
    for r in range(6, ws.max_row + 1):
        cell_val = ws.cell(row=r, column=6).value
        if isinstance(cell_val, str) and cell_val.strip() == "to be processed":
            rows_to_delete.append(r)
    # Delete rows from bottom to top to keep indices stable
    for r in sorted(rows_to_delete, reverse=True):
        ws.delete_rows(r, amount=1)
    print(f"Sheet {sheet_name}: deleted {len(rows_to_delete)} rows; new max_row = {ws.max_row}")

# Save the modified workbook
wb.save(output_path)
print(f"Saved modified workbook to {output_path}")
```
