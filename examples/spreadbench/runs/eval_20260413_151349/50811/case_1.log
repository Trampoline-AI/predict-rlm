import openpyxl
import pathlib

# Paths
input_path = pathlib.Path("/sandbox/input/input_spreadsheet/1_50811_init.xlsx")
output_dir = pathlib.Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_50811_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Define the formula (using absolute ranges for the lookup table rows 5‑12)
# The row number will be inserted via f‑string for each target cell.
def make_formula(row):
    return f"=SUMPRODUCT(($B$5:$B$12=B{row})*($C$5:$C$12=C{row})*$D$5:$D$12)"

# Write formulas into D21, D22, D23
for r in (21, 22, 23):
    ws[f"D{r}"].value = make_formula(r)

# Save to output location
wb.save(output_path)

# Recalculate formulas to cache values (LibreOffice fallback)
await recalculate(str(output_path))
