# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Helper to create the corrected SUMPRODUCT formula for a given row
def make_formula(row: int) -> str:
    # Lookup Rep (col F), Client (col C), % (col H) from rows 5‑12
    return f"=SUMPRODUCT(($F$5:$F$12=B{row})*($C$5:$C$12=C{row})*$H$5:$H$12)"

