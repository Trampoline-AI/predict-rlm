The code below performs all of these steps.
Code:
```repl
import os
from openpyxl import load_workbook, Workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_57693_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_57693_init.xlsx")

# Load workbook (read/write)
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# -------------------------------------------------
# 1. Find the column that contains the text to analyse
# -------------------------------------------------
text_col = None
for col in range(1, ws.max_column + 1):
    for row in range(2, ws.max_row + 1):
        val = ws.cell(row=row, column=col).value
        if isinstance(val, str) and val.strip():
            text_col = col
            break
    if text_col is not None:
        break

if text_col is None:
    raise ValueError("Could not locate a column with text data.")

text_col_letter = get_column_letter(text_col)
print(f"Detected text column: {text_col_letter}")

# -------------------------------------------------
# 2. Add 26 new columns for letters a‑z
# -------------------------------------------------
start_col = ws.max_column + 1
letters = [chr(ord('a') + i) for i in range(26)]

for i, letter in enumerate(letters):
    ws.cell(row=1, column=start_col + i).value = letter

# -------------------------------------------------
# 3. Write counting formulas for each row and each letter
# -------------------------------------------------
for row in range(2, ws.max_row + 1):
    text_cell_ref = f"{text_col_letter}{row}"
    for i, letter in enumerate(letters):
        target_col = start_col + i
        formula = (
            f'=LEN({text_cell_ref})-LEN(SUBSTITUTE(LOWER({text_cell_ref}),"{letter}",""))'
        )
        ws.cell(row=row, column=target_col).value = formula

# -------------------------------------------------
# 4. Save to output path
# -------------------------------------------------
wb.save(output_path)
print(f"Workbook saved to {output_path}")

# -------------------------------------------------
# 5. Verify: reload and print a few formulas
# -------------------------------------------------
wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]

# Print headers for the new columns
header_vals = [ws_check.cell(row=1, column=c).value for c in range(start_col, start_col + 26)]
print("New headers:", header_vals)

# Print formulas for the first data row (row 2)
row2_formulas = [ws_check.cell(row=2, column=c).value for c in range(start_col, start_col + 26)]
print("Row 2 formulas (a‑z):", row2_formulas[:5], "...")  # show first 5 for brevity
```
