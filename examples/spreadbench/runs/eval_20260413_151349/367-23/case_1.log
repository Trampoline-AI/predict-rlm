import openpyxl
from pathlib import Path

# Load workbook (read cached values)
wb_path = Path("/sandbox/input/input_spreadsheet/1_367-23_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=True)

# Find the target sheet case‑insensitively
target_name = "Final Recon Items"
sheet_name = None
for name in wb.sheetnames:
    if name.lower() == target_name.lower():
        sheet_name = name
        break

if sheet_name is None:
    print(f"ERROR: No sheet matching '{target_name}' found.")
else:
    ws = wb[sheet_name]
    print(f"Using sheet: '{sheet_name}'")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")

    # Show first 10 rows (A‑E)
    print("First 10 rows (A‑E):")
    for r in range(1, min(11, ws.max_row + 1)):
