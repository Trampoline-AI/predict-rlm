import openpyxl, os

# Path to the saved output workbook
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

# Load workbook for verification (data_only to see any formulas, though we wrote literals)
wb_out = openpyxl.load_workbook(output_path, data_only=True)

# Helper to print sheet contents (header + first few rows)
def print_sheet(ws, max_rows=10):
    print(f"\nSheet: {ws.title}")
    for r in ws.iter_rows(min_row=1, max_row=max_rows, values_only=True):
        print(r)

# Verify Sheet3 and Sheet4
print_sheet(wb_out["Sheet3"])
print_sheet(wb_out["Sheet4"])
