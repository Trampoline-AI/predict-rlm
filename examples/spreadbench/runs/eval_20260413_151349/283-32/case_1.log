Code:
```repl
import openpyxl

# Load the workbook (read only is fine for inspection)
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=True)

# Print sheet names
print("Sheets:", wb.sheetnames)

# Function to preview a sheet
def preview_sheet(ws, max_rows=5):
    rows = []
    for r in ws.iter_rows(min_row=1, max_row=max_rows, values_only=True):
        rows.append(r)
    return rows

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n=== {name} ===")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    header = [cell.value for cell in ws[1]]
    print("Header:", header)
    preview = preview_sheet(ws, max_rows=5)
    print("First rows:", preview)
```
2026-04-13 15:15:49,831 INFO RLM iteration 2/50
Reasoning: We inspected the workbook and saw that each sheet has a single column of meaningful data (the first column contains entries like 'XYZ', 'Tanzania', etc.) while the other columns are empty. The task is to compare Sheet1 and Sheet2 and write the differences to Sheet3 and Sheet4: Sheet3 = rows present in Sheet1 but not in Sheet2, Sheet4 = rows present in Sheet2 but not in Sheet1. We'll treat each row as a tuple of its cell values (up to the maximum column count) and compare sets of tuples. We'll copy the header row (row 1) from Sheet1 to both output sheets, then write the differing rows below the header. Finally, we save the workbook to the output directory with the same filename.
Code:
```repl
import os
import openpyxl

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Access sheets
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
ws3 = wb["Sheet3"]
ws4 = wb["Sheet4"]

# Determine number of columns to consider (use the max of Sheet1 and Sheet2)
max_col = max(ws1.max_column, ws2.max_column)

# Helper to extract rows as tuples, skipping completely empty rows

def rows_as_tuples(ws):
    rows = []
    for r in ws.iter_rows(min_row=1, max_col=max_col, values_only=True):
        if any(cell is not None for cell in r):
            rows.append(tuple(r))
    return rows

# Extract rows (including header) from both sheets
rows1 = rows_as_tuples(ws1)
rows2 = rows_as_tuples(ws2)

# Assume first row is header (if it looks like a header). We'll copy it to output sheets.
header = rows1[0] if rows1 else tuple([None] * max_col)

# Build sets of data rows (excluding header)
set1 = set(rows1[1:])
set2 = set(rows2[1:])

# Differences
only_in_1 = sorted(set1 - set2)  # rows present in Sheet1 but not in Sheet2
only_in_2 = sorted(set2 - set1)  # rows present in Sheet2 but not in Sheet1

# Function to write to a sheet: clear existing content, write header then data rows

def write_sheet(ws, data_rows):
    # Clear existing rows by deleting all rows
    ws.delete_rows(1, ws.max_row)
    # Write header
    for col_idx, value in enumerate(header, start=1):
        ws.cell(row=1, column=col_idx, value=value)
    # Write data rows
    for row_idx, row_vals in enumerate(data_rows, start=2):
        for col_idx, value in enumerate(row_vals, start=1):
            ws.cell(row=row_idx, column=col_idx, value=value)

# Populate Sheet3 and Sheet4
write_sheet(ws3, only_in_1)
write_sheet(ws4, only_in_2)

# Save to output path
wb.save(output_path)

print(f"Saved output workbook to {output_path}")
print(f"Sheet3 rows (excluding header): {len(only_in_1)}")
print(f"Sheet4 rows (excluding header): {len(only_in_2)}")
```
