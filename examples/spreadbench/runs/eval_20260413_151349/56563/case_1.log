```repl
import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = load_workbook(filename=input_path, data_only=False)  # keep formulas
print("Sheets:", wb.sheetnames)

# Search for the original formula
found = []
for ws in wb.worksheets:
    for row in ws.iter_rows(values_only=False):
        for cell in row:
            if isinstance(cell.value, str) and "SUM(C2:C13)" in cell.value:
                found.append((ws.title, cell.coordinate, cell.value))

print("Found original SUM formulas:", found)
