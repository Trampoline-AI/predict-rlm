import os, openpyxl, asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_48921_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_48921_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Ensure header in column C
header_cell = ws.cell(row=1, column=3)
if not header_cell.value:
    header_cell.value = "Extracted"

# Write formula for each data row (starting at row 2)
for r in range(2, ws.max_row + 1):
    src_cell = ws.cell(row=r, column=2)  # column B contains the original numbers
    if src_cell.value is None:
        continue
    # Formula: =VALUE(REGEX(Bx, "0*([0-9]+)$", "$1"))
    formula = f'=VALUE(REGEX({src_cell.coordinate}, "0*([0-9]+)$", "$1"))'
    ws.cell(row=r, column=3).value = formula

# Save workbook
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas (LibreOffice fallback)
recalc_result = await recalculate(output_path)
print("Recalculation result:", recalc_result)

# Reload with cached values to verify a few rows
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data[wb_data.sheetnames[0]]
print("Verification of first 5 extracted values:")
for r in range(2, min(ws_data.max_row, 6)):
    extracted = ws_data.cell(row=r, column=3).value
    print(f"Row {r}: {extracted}")
