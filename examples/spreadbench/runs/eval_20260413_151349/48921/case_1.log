print('Sheets:', wb.sheetnames)

# Inspect the first sheet
ws = wb[wb.sheetnames[0]]
# Print first few rows (up to 5) and column count
max_rows = min(ws.max_row, 5)
max_cols = ws.max_column
print(f'Rows: {ws.max_row}, Columns: {ws.max_column}')
for r in range(1, max_rows+1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_cols+1)]
    print(f'Row {r}:', row_vals)

# Determine where to place the formula – assume original numbers are in column A
# We'll write the formula into column B (next column) for each data row (starting from row 2 if row 1 is header)
# First, ensure column B header exists
header_cell = ws.cell(row=1, column=2)
