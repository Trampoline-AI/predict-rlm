for r in range(2, ws_orig.max_row + 1):
    orig_e = ws_orig.cell(row=r, column=5).value
    proc_e = ws_proc.cell(row=r, column=5).value
    proc_d = ws_proc.cell(row=r, column=4).value

    if isinstance(orig_e, str) and "check" in orig_e.lower():
        # E must be updated to exactly "Check Paid"
