import re
from pathlib import Path
from openpyxl import load_workbook

# ---------- Step 1: Process the workbook ----------
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load original workbook (keep formulas if any)
wb_orig = load_workbook(filename=input_path, data_only=False)
ws_orig = wb_orig.active

# Load a copy for processing (we will modify this)
wb = load_workbook(filename=input_path, data_only=False)
ws = wb.active

# Regex to find any sequence of digits
digit_regex = re.compile(r"\d+")

for row in ws.iter_rows(min_row=2, max_col=5, values_only=False):
    cell_e = row[4]  # Column E
    if cell_e.value is None:
        continue
    e_text = str(cell_e.value)
    if "check" in e_text.lower():
        # Extract first number if present
        match = digit_regex.search(e_text)
        if match:
            number = int(match.group())
            # Write to column D (index 3)
            cell_d = row[3]
            cell_d.value = number
        # Update column E text
        cell_e.value = "Check Paid"

# Save processed workbook
wb.save(output_path)
print(f"Processed workbook saved to {output_path}")

# ---------- Step 2: Verify against original ----------
# Reload both workbooks with data_only=True to read cached values
wb_orig = load_workbook(filename=input_path, data_only=True)
ws_orig = wb_orig.active
wb_proc = load_workbook(filename=output_path, data_only=True)
