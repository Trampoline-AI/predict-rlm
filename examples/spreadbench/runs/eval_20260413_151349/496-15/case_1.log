            if proc_d != expected_num:
                issues.append((r, "D number mismatch", proc_d))
        else:
            # No number originally; D can be None or unchanged – no issue
            pass
    else:
        # Cells without "Check" should not be changed to "Check Paid"
        if proc_e == "Check Paid":
            issues.append((r, "E incorrectly changed", proc_e))

print(f"Total data rows inspected: {total_rows}")
