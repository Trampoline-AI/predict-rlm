`COLLECTION` already has a `BALANCE` column (currently a formula).  

Task:
1. Aggregate `SALE` and `RET` per unique `(TY, OR)` across all sheets except `COLLECTION`.  
   - Sum values where the column exists; treat missing values as 0.  
   - Keep the first encountered `ITEM` and `BR` for each `(TY, OR)` to fill those columns later.  
2. In `COLLECTION`:
   - Preserve the existing row order. For each existing row, replace `SALE`, `RET`, and `BALANCE` with the aggregated totals (BALANCE = SALE‑RET).  
   - Append rows for any `(TY, OR)` that were not already present, using the stored `ITEM`/`BR`.  
   - Display calculated numbers (no formulas).  
   - Show a hyphen (`"-"`) instead of a zero for empty cells.  
   - Color negative numbers red (`#FF0000`).  
   - Set all text to Calibri 11 pt, un‑bold.  
   - Header row: left‑aligned, un‑bold.  
   - Column alignments: A, E, F, G right‑aligned; B, C, D left‑aligned.  
3. Save the modified workbook to `/sandbox/output/output_spreadsheet/1_398-14_init.xlsx`.  

The code below implements these steps using `openpyxl` and its styling utilities. It creates the output directory if needed, writes the updated workbook, and finishes without printing large data (only a short confirmation).
Code:
```repl
import os
import openpyxl
from openpyxl.styles import Font, Alignment, PatternFill, Color
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Identify sheets to process (exclude COLLECTION)
collection_name = "COLLECTION"
source_sheets = [name for name in wb.sheetnames if name != collection_name]

# Helper to find column index by header name (case‑insensitive)
def col_index(ws, header):
    for c in range(1, ws.max_column + 1):
        val = ws.cell(row=1, column=c).value
        if isinstance(val, str) and val.strip().upper() == header.upper():
            return c
    return None

# Aggregate data
agg = {}  # key (TY, OR) -> dict with sums and first ITEM/BR
for sheet_name in source_sheets:
    ws = wb[sheet_name]
    # locate columns
    idx_item = col_index(ws, "ITEM")
    idx_br   = col_index(ws, "BR")
    idx_ty   = col_index(ws, "TY")
    idx_or   = col_index(ws, "OR")
    idx_sale = col_index(ws, "SALE")
    idx_ret  = col_index(ws, "RET")
    # iterate rows
    for r in range(2, ws.max_row + 1):
        ty = ws.cell(row=r, column=idx_ty).value if idx_ty else None
        or_ = ws.cell(row=r, column=idx_or).value if idx_or else None
        if ty is None or or_ is None:
            continue
        key = (ty, or_)
        sale = ws.cell(row=r, column=idx_sale).value if idx_sale else 0
        ret  = ws.cell(row=r, column=idx_ret).value  if idx_ret else 0
        # coerce non‑numeric to 0
        try:
            sale = float(sale)
        except (TypeError, ValueError):
            sale = 0.0
        try:
            ret = float(ret)
        except (TypeError, ValueError):
            ret = 0.0
        if key not in agg:
            # capture first ITEM and BR for this key
            item = ws.cell(row=r, column=idx_item).value if idx_item else None
            br   = ws.cell(row=r, column=idx_br).value   if idx_br else None
            agg[key] = {"sale": 0.0, "ret": 0.0, "item": item, "br": br}
        agg[key]["sale"] += sale
        agg[key]["ret"]  += ret

# Prepare formatting objects (once)
font_normal = Font(name="Calibri", size=11, bold=False, color="000000")
align_left  = Alignment(horizontal="left", vertical="center")
align_right = Alignment(horizontal="right", vertical="center")
red_color   = "FF0000"

# Open COLLECTION sheet
coll = wb[collection_name]

# Determine column indices in COLLECTION (should already exist)
idx_item_c = col_index(coll, "ITEM")
idx_br_c   = col_index(coll, "BR")
idx_ty_c   = col_index(coll, "TY")
idx_or_c   = col_index(coll, "OR")
idx_sale_c = col_index(coll, "SALE")
idx_ret_c  = col_index(coll, "RET")
idx_bal_c  = col_index(coll, "BALANCE")

# Update header formatting (row 1)
for c in range(1, coll.max_column + 1):
    cell = coll.cell(row=1, column=c)
    cell.font = font_normal
    cell.alignment = align_left  # headers left‑aligned
    # keep existing fill / border

# Process existing rows
existing_keys = set()
for r in range(2, coll.max_row + 1):
    ty = coll.cell(row=r, column=idx_ty_c).value
    or_ = coll.cell(row=r, column=idx_or_c).value
    key = (ty, or_)
    existing_keys.add(key)
    if key in agg:
        total_sale = agg[key]["sale"]
        total_ret  = agg[key]["ret"]
        balance    = total_sale - total_ret

        # Helper to write a value or hyphen
        def write_cell(cell, value):
            if value == 0:
                cell.value = "-"
                cell.font = font_normal
                cell.alignment = align_right
            else:
                cell.value = value
                cell.font = font_normal
                cell.alignment = align_right
                if isinstance(value, (int, float)) and value < 0:
                    cell.font = Font(name="Calibri", size=11, bold=False, color=red_color)

        # ITEM, BR, TY, OR stay as‑is (just ensure font/alignment)
        for col_idx in (idx_item_c, idx_br_c, idx_ty_c, idx_or_c):
            cell = coll.cell(row=r, column=col_idx)
            cell.font = font_normal
            # alignment: B,C,D left; A right (ITEM is column A)
            if col_idx == idx_item_c:
                cell.alignment = align_right
            else:
                cell.alignment = align_left

        # SALE
        write_cell(coll.cell(row=r, column=idx_sale_c), total_sale)
        # RET
        write_cell(coll.cell(row=r, column=idx_ret_c), total_ret)
        # BALANCE
        write_cell(coll.cell(row=r, column=idx_bal_c), balance)

# Append missing keys
next_row = coll.max_row + 1
for key, data in agg.items():
    if key in existing_keys:
        continue
    ty, or_ = key
    item = data["item"]
    br   = data["br"]
    total_sale = data["sale"]
    total_ret  = data["ret"]
    balance    = total_sale - total_ret

    # Write cells
    coll.cell(row=next_row, column=idx_item_c).value = item
    coll.cell(row=next_row, column=idx_br_c).value   = br
    coll.cell(row=next_row, column=idx_ty_c).value   = ty
    coll.cell(row=next_row, column=idx_or_c).value   = or_

    # Apply font/alignment for the new row
    for col_idx in (idx_item_c, idx_br_c, idx_ty_c, idx_or_c):
        cell = coll.cell(row=next_row, column=col_idx)
        cell.font = font_normal
        cell.alignment = align_right if col_idx == idx_item_c else align_left

    # Helper to write numeric or hyphen
    def write_cell(cell, value):
        if value == 0:
            cell.value = "-"
            cell.font = font_normal
            cell.alignment = align_right
        else:
            cell.value = value
            cell.font = font_normal
            cell.alignment = align_right
            if isinstance(value, (int, float)) and value < 0:
                cell.font = Font(name="Calibri", size=11, bold=False, color=red_color)

    write_cell(coll.cell(row=next_row, column=idx_sale_c), total_sale)
    write_cell(coll.cell(row=next_row, column=idx_ret_c), total_ret)
    write_cell(coll.cell(row=next_row, column=idx_bal_c), balance)

    next_row += 1

# Ensure column widths are unchanged (openpyxl retains them)

# Save workbook
wb.save(output_path)

print("Transformation complete. Output saved to:", output_path)
```
