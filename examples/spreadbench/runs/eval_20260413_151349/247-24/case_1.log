from openpyxl import load_workbook

# Reload the saved workbook (data_only to see computed values)
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check["Main"] if "Main" in wb_check.sheetnames else wb_check[wb_check.sheetnames[0]]

# 1. Count rows where Company = "Motorcycle"
motorcycle_rows = sum(1 for r in ws_check.iter_rows(min_row=2, max_col=1, values_only=True) if r[0] == "Motorcycle")

# 2. Count rows where Company = "Ahmed Sons" and Location = "Canada"
ahmed_canada_rows = sum(
    1
    for r in ws_check.iter_rows(min_row=2, max_col=2, values_only=True)
    if r[0] == "Ahmed Sons" and r[1] == "Canada"
)

# 3. Verify Bill Rate = 180 for National TV / India rows
bill_rate_mismatches = []
for r in ws_check.iter_rows(min_row=2, max_col=7, values_only=False):
    company = r[0].value
    location = r[1].value
    bill_rate = r[6].value  # Column G index 7 -> 0‑based 6
    if company == "National TV" and location == "India" and bill_rate != 180:
        bill_rate_mismatches.append(r[0].row)

# 4. Verify two blank rows after each Ahmed Sons row
# We'll scan rows and count consecutive blank rows after each Ahmed Sons
blank_rows_after_ahmed = []
max_row = ws_check.max_row
row = 2
while row <= max_row:
    if ws_check.cell(row=row, column=1).value == "Ahmed Sons":
        # count following blank rows
        blanks = 0
        nxt = row + 1
        while nxt <= max_row and all(
            ws_check.cell(row=nxt, column=col).value in (None, "")
            for col in range(1, ws_check.max_column + 1)
        ):
            blanks += 1
            nxt += 1
        blank_rows_after_ahmed.append(blanks)
        row = nxt
    else:
        row += 1

# 5. Verify Column M populated (non‑None) where Employee Id exists in Lookup
lookup_missing = []
for r in ws_check.iter_rows(min_row=2, max_col=13, values_only=False):
    emp_id = ws_check.cell(row=r[0].row, column=3).value
    weeks = ws_check.cell(row=r[0].row, column=13).value
    if emp_id is not None and weeks is None:
        lookup_missing.append(r[0].row)

print("Verification results:")
print(f"Rows with Company 'Motorcycle': {motorcycle_rows}")
print(f"Rows with Company 'Ahmed Sons' and Location 'Canada': {ahmed_canada_rows}")
print(f"Bill Rate mismatches (should be 180): {bill_rate_mismatches}")
print(f"Blank rows after each 'Ahmed Sons' row: {blank_rows_after_ahmed}")
print(f"Rows where Employee Id has no Working Weeks (Column M empty): {lookup_missing}")
```
