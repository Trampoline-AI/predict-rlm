```repl
import openpyxl, os, json

input_path = '/sandbox/input/input_spreadsheet/1_54717_init.xlsx'
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Define keywords to look for
keywords = ['start', 'end', 'row', 'column', 'col', 'p1', 'p2', 'border', 'auto prime']

found = []
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        if isinstance(cell.value, str):
            low = cell.value.lower()
            if any(k in low for k in keywords):
                # capture adjacent cell to the right (possible value) and below
                right = ws.cell(row=cell.row, column=cell.column+1).value
                below = ws.cell(row=cell.row+1, column=cell.column).value
                found.append({
                    'label': cell.value,
                    'coord': cell.coordinate,
                    'right': right,
                    'below': below
                })

print('Found label cells:', json.dumps(found, indent=2, default=str))
```
