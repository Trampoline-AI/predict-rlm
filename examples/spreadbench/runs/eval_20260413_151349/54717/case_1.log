```repl
import openpyxl, json, os

input_path = '/sandbox/input/input_spreadsheet/1_54717_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_54717_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Find start/end row values (already known)
start_row = ws.cell(row=6, column=19).value   # S6 (column 19)
end_row   = ws.cell(row=8, column=19).value   # S8

# Search for a label that defines the column to sum
col_label = None
col_ref = None
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        if isinstance(cell.value, str) and 'column' in cell.value.lower():
            # Assume the adjacent cell to the right holds the column identifier (letter or number)
            col_label = cell.value
            col_ref = ws.cell(row=cell.row, column=cell.column+1).value
            break
    if col_label:
        break

print("Start row:", start_row, "End row:", end_row)
print("Column label:", col_label, "Column reference:", col_ref)

# Determine the column index to sum
if isinstance(col_ref, str):
    # Convert column letter to index (A=1)
    col_idx = openpyxl.utils.column_index_from_string(col_ref.upper())
elif isinstance(col_ref, int):
    col_idx = col_ref
else:
    raise ValueError("Unable to determine column to sum from sheet")

# Build the SUM formula using the dynamic row numbers
# Example: =SUM(C40:C60) if column C is the target
col_letter = openpyxl.utils.get_column_letter(col_idx)
formula = f"=SUM({col_letter}{start_row}:{col_letter}{end_row})"

# Write the formula into a new cell (e.g., A{ws.max_row+2})
target_row = ws.max_row + 2
ws.cell(row=target_row, column=1).value = "Sum Result"
ws.cell(row=target_row, column=2).value = formula

# Save the workbook to the output location
wb.save(output_path)

# Verify by loading with data_only to see cached result (after recalculation)
# (Recalculation will be done later before final verification)
print("Formula written to", f"A{target_row}")
```
