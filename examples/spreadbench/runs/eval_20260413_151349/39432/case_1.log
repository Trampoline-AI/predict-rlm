```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook for editing (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Insert FIFO per‑unit‑cost formula into column M (13) for each data row
for row in range(2, ws.max_row + 1):
    formula = (
        f"=IF(L{row}=0,0,"
        f"(MIN(B{row},L{row})*C{row}+"
        f"MIN(MAX(L{row}-B{row},0),D{row})*E{row}+"
        f"MIN(MAX(L{row}-B{row}-D{row},0),F{row})*G{row}+"
        f"MIN(MAX(L{row}-B{row}-D{row}-F{row},0),H{row})*I{row}+"
        f"MIN(MAX(L{row}-B{row}-D{row}-F{row}-H{row},0),J{row})*K{row})/L{row})"
    )
    ws.cell(row=row, column=13).value = formula

# Save the edited workbook
wb.save(output_path)

# ---- Verification in Python (no recalc) ----
def fifo_cost(row_vals):
    """
    Compute FIFO per‑unit cost given a list of cell values for a row.
    Expected order (1‑based columns):
    B (2): Beg Inv, C (3): Beg Cost,
    D (4): PO1 units, E (5): PO1 cost,
    F (6): PO2 units, G (7): PO2 cost,
    H (8): PO3 units, I (9): PO3 cost,
    J (10): PO4 units, K (11): PO4 cost,
    L (12): Current Inv
    """
    beg_inv = row_vals[1] or 0
    beg_cost = row_vals[2] or 0
    po1_units = row_vals[3] or 0
    po1_cost = row_vals[4] or 0
    po2_units = row_vals[5] or 0
    po2_cost = row_vals[6] or 0
    po3_units = row_vals[7] or 0
    po3_cost = row_vals[8] or 0
    po4_units = row_vals[9] or 0
    po4_cost = row_vals[10] or 0
    cur_inv = row_vals[11] or 0

    if cur_inv == 0:
        return 0.0

    remaining = cur_inv
    total_cost = 0.0

    # Helper to take from a layer
    def take(qty, unit_cost):
        nonlocal remaining, total_cost
        if remaining <= 0:
            return
        take_qty = min(qty, remaining)
        total_cost += take_qty * unit_cost
        remaining -= take_qty

    take(beg_inv, beg_cost)
    take(po1_units, po1_cost)
    take(po2_units, po2_cost)
    take(po3_units, po3_cost)
    take(po4_units, po4_cost)

    # If still remaining (should not happen), assume zero cost for missing layers
    return total_cost / cur_inv

print("Row | Current Inv (L) | Computed Cost (Python FIFO)")
for r in range(2, min(7, ws.max_row + 1)):
    # Extract row values as a list (1‑based indexing for simplicity)
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    cur_inv = row_vals[11]  # column L
    py_cost = fifo_cost(row_vals)
    print(f"{r}   | {cur_inv}            | {py_cost}")

# End of verification
```
