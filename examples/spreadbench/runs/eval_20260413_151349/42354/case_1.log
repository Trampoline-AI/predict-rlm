from openpyxl import load_workbook

# Load the workbook from the provided path
wb = load_workbook(input_spreadsheet)

# Gather basic info about the workbook
sheet_infos = []
for ws in wb.worksheets:
    info = {
        "title": ws.title,
        "max_row": ws.max_row,
        "max_column": ws.max_column,
    }
    sheet_infos.append(info)

print("Workbook contains", len(wb.sheetnames), "sheet(s)")
for info in sheet_infos:
    print(f"Sheet '{info['title']}' – rows: {info['max_row']}, cols: {info['max_column']}")

# Inspect the first sheet (assuming that's the target)
ws = wb[wb.sheetnames[0]]
print("\nFirst 5 rows of columns A-D (including header if present):")
for r in range(1, min(6, ws.max_row + 1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, 5)]  # A=1, B=2, C=3, D=4
    print(f"Row {r}: {row_vals}")

# Store workbook for later use
_workbook = wb
