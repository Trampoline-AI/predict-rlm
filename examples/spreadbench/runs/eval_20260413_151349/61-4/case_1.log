import openpyxl
from pathlib import Path

# Load the workbook (read_only for faster inspection)
wb_path = Path(input_spreadsheet)
wb = openpyxl.load_workbook(wb_path, data_only=True)  # data_only to get any cached values

# Print sheet names
print("Sheets:", wb.sheetnames)

# Inspect the first sheet (assume it contains the data)
ws = wb[wb.sheetnames[0]]

# Determine max column and row
max_row = ws.max_row
max_col = ws.max_column
print(f"Rows: {max_row}, Columns: {max_col}")

# Print header row (first row)
header = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
print("Header:", header)

# Print first 5 data rows (rows 2-6)
for r in range(2, min(7, max_row + 1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
    print(f"Row {r}:", row_vals)
