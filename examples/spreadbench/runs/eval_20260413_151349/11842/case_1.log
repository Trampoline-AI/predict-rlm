import openpyxl, os, json

# Load the workbook (read_only for faster inspection)
wb_path = '/sandbox/input/input_spreadsheet/1_11842_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=True, read_only=True)

# Gather sheet information
sheet_names = wb.sheetnames
print('Sheet names:', sheet_names)

# Function to preview a sheet: header row and first few data rows

def preview_sheet(name, max_rows=5):
    ws = wb[name]
    rows = []
    for i, row in enumerate(ws.iter_rows(values_only=True)):
        rows.append(row)
        if i >= max_rows:
            break
    return rows

# Preview the 'Total' sheet (if it exists)
if 'Total' in sheet_names:
    total_preview = preview_sheet('Total')
    print('\nTotal sheet preview (first rows rows):')
    for r in total_preview:
        print(r)
else:
    print('\nNo sheet named "Total" found.')

# Preview a sample monthly sheet (e.g., the first sheet that looks like a month)
monthly_sheet = None
for name in sheet_names:
    # heuristic: sheet name not 'Total' and not empty
    if name != 'Total':
        monthly_sheet = name
        break
if monthly_sheet:
    month_preview = preview_sheet(monthly_sheet)
    print(f'\nMonthly sheet "{monthly_sheet}" preview (first {len(month_preview)} rows):')
    for r in month_preview:
        print(r)
else:
    print('\nNo monthly sheet found.')
