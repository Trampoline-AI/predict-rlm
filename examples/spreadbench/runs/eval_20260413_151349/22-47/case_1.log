Code:
```repl
import os
import openpyxl

# -------------------------------------------------
# Paths
# -------------------------------------------------
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# -------------------------------------------------
# Load workbook for reading (data_only to get cached values)
# -------------------------------------------------
wb = openpyxl.load_workbook(input_path, data_only=True)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# -------------------------------------------------
# 1. Build priority list from column J (skip header, empty, dedup)
# -------------------------------------------------
priority = []
seen_prio = set()
for row in ws.iter_rows(min_row=2, max_col=10, max_row=ws.max_row, values_only=True):
    val = row[9]  # column J (0‑based index 9)
    if val is None:
        continue
    if val not in seen_prio:
        priority.append(val)
        seen_prio.add(val)

# -------------------------------------------------
# 2. Collect data rows from columns A‑C (skip header)
# -------------------------------------------------
data_rows = []  # (item, name, ref, original_row_index)
row_idx = 2
for row in ws.iter_rows(min_row=2, max_col=3, max_row=ws.max_row, values_only=True):
    item, name, ref = row
    # Skip rows where name or ref is None (treated as empty)
    if name is None or ref is None:
        row_idx += 1
        continue
    data_rows.append((item, name, ref, row_idx))
    row_idx += 1

# -------------------------------------------------
# 3. Deduplicate based on (name, ref) – keep first occurrence
# -------------------------------------------------
unique_keys = set()
deduped = []
for item, name, ref, orig_row in data_rows:
    key = (name, ref)
    if key in unique_keys:
        continue
    unique_keys.add(key)
    deduped.append((item, name, ref, orig_row))

# -------------------------------------------------
# 4. Priority index function
# -------------------------------------------------
if not priority:
    # No helper list → alphabetical order by name (A‑Z)
    sorted_names = sorted({name for _, name, _, _ in deduped})
    name_to_rank = {name: i for i, name in enumerate(sorted_names)}
    def get_priority(name):
        return name_to_rank.get(name, len(sorted_names))
else:
    # Normal case: order defined by appearance in column J
    name_to_prio = {name: i for i, name in enumerate(priority)}
    def get_priority(name):
        return name_to_prio.get(name, len(priority))

# -------------------------------------------------
# 5. Safe REF conversion for sorting
# -------------------------------------------------
def safe_ref(ref):
    """Return a numeric value for sorting; non‑numeric become +inf."""
    if isinstance(ref, (int, float)):
        return float(ref)
    try:
        return float(ref)
    except (TypeError, ValueError):
        return float('inf')

# -------------------------------------------------
# 6. Sort rows by (priority, REF) – stable sort keeps original order within ties
# -------------------------------------------------
sorted_rows = sorted(
    deduped,
    key=lambda tup: (get_priority(tup[1]), safe_ref(tup[2]))
)

# -------------------------------------------------
# 7. Write output to columns G (NAME) and H (REF)
# -------------------------------------------------
# Load workbook in write mode (full workbook, not data_only)
wb_w = openpyxl.load_workbook(input_path)
ws_w = wb_w[wb_w.sheetnames[0]]

# Write headers (copy from B1 and C1 if present)
ws_w["G1"] = ws_w["B1"].value if ws_w["B1"].value else "NAME"
ws_w["H1"] = ws_w["C1"].value if ws_w["C1"].value else "REF"

# Write sorted data starting at row 2
out_row = 2
for _, name, ref, _ in sorted_rows:
    ws_w.cell(row=out_row, column=7, value=name)   # column G
    ws_w.cell(row=out_row, column=8, value=ref)    # column H
    out_row += 1

# -------------------------------------------------
# 8. Save to output path
# -------------------------------------------------
wb_w.save(output_path)

# -------------------------------------------------
# 9. Verify: reload with data_only and print first few G:H rows
# -------------------------------------------------
verify_wb = openpyxl.load_workbook(output_path, data_only=True)
verify_ws = verify_wb[verify_wb.sheetnames[0]]
print("Verification – first 5 rows of G:H after sorting:")
for r in range(1, min(6, verify_ws.max_row + 1)):
    g_val = verify_ws.cell(row=r, column=7).value
    h_val = verify_ws.cell(row=r, column=8).value
    print(f"Row {r}: G={g_val!r}, H={h_val!r}")
