import openpyxl
from pathlib import Path

# Load the workbook (read/write mode)
wb_path = Path(input_spreadsheet)
wb = openpyxl.load_workbook(wb_path)

# Print sheet names
print("Sheets:", wb.sheetnames)

# Helper to show a preview of a sheet (first few rows, selected columns)
def preview_sheet(ws, cols, n=5):
    rows = []
    for r in range(1, n+1):
        row = [ws.cell(row=r, column=c).value for c in cols]
        rows.append(row)
    return rows

# Inspect sheet A
ws_A = wb["A"]
print("Sheet A preview (cols P=16, L=12, F=6):")
print(preview_sheet(ws_A, cols=[16,12,6], n=5))

# Inspect sheet B
ws_B = wb["B"]
print("Sheet B preview (col C=3):")
print(preview_sheet(ws_B, cols=[3], n=5))

# Show the value in cell F1 of sheet A
print("A!F1:", ws_A.cell(row=1, column=6).value)
