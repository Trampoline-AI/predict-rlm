Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_55976_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_55976_init.xlsx"

# Load workbook for editing
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # Assuming single sheet

# Initialize counters for the four group columns (F=6, G=7, H=8, I=9)
group_counts = {6: 0, 7: 0, 8: 0, 9: 0}  # column index -> count

# Process rows 5 through 84 (inclusive)
for row in range(5, ws.max_row + 1):
    yes_cell = ws.cell(row=row, column=3)  # Column C
    if yes_cell.value != "x":
        continue  # No 'Yes' response for this question

    # Determine which group column this question belongs to.
    # The group column is the first non‑empty value among F‑I.
    group_col = None
    for col in range(6, 10):  # Columns F (6) to I (9)
        val = ws.cell(row=row, column=col).value
        if val is not None and val != "":
            group_col = col
            break
    if group_col is None:
        # No group identifier found; skip this row
        continue

    # Increment the appropriate counter
    group_counts[group_col] += 1

# Write totals into F25, G25, H25, I25 (row 25)
for col, count in group_counts.items():
    ws.cell(row=25, column=col, value=count)

# Save the modified workbook
wb.save(output_path)

# Verify by re‑loading with data_only=True and printing the totals
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
totals = [ws_check.cell(row=25, column=col).value for col in range(6, 10)]
print("Totals written to F25‑I25:", totals)
```
