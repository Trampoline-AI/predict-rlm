Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_55976_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_55976_init.xlsx"

# Load workbook for editing
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # Assuming a single sheet

# Initialize counters for the four category columns (F=6, G=7, H=8, I=9)
category_counts = {6: 0, 7: 0, 8: 0, 9: 0}

# Process rows 5 through the last row (inclusive)
for row in range(5, ws.max_row + 1):
    yes_cell = ws.cell(row=row, column=3)  # Column C = "Yes"
    if yes_cell.value != "x":
        continue  # No Yes response for this row

    # For each category column, if the cell is non‑empty, count this Yes response
    for col in range(6, 10):  # Columns F (6) to I (9)
        cat_val = ws.cell(row=row, column=col).value
        if cat_val is not None and cat_val != "":
            category_counts[col] += 1

# Write totals into row 25, columns F‑I
for col, total in category_counts.items():
    ws.cell(row=25, column=col, value=total)

# Save the modified workbook
wb.save(output_path)

# Verify totals by re‑loading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
totals = [ws_check.cell(row=25, column=col).value for col in range(6, 10)]
print("Totals written to F25‑I25:", totals)
```
