import openpyxl
from pathlib import Path

# Load the workbook (read data_only to get actual cell values, not formulas)
wb_path = Path("/sandbox/input/input_spreadsheet/1_55976_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=True)

# Store basic info
sheet_info = []
for ws in wb.worksheets:
    # Get dimensions
    max_row = ws.max_row
    max_col = ws.max_column
    # Preview first 5 rows (as list of lists)
    preview = []
    for r in range(1, min(6, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        preview.append(row_vals)
    sheet_info.append({
        "title": ws.title,
        "max_row": max_row,
        "max_col": max_col,
        "preview": preview,
    })

# Print summary
print(f"Workbook loaded from: {wb_path}")
print(f"Number of sheets: {len(wb.sheetnames)}")
print("Sheet names:", wb.sheetnames)
for info in sheet_info:
    print(f"\nSheet: {info['title']}")
    print(f"  Rows: {info['max_row']}, Columns: {info['max_col']}")
    print("  First 5 rows preview:")
    for row in info["preview"]:
        print("   ", row)
```
