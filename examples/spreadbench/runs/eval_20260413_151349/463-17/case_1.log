import os
from openpyxl import load_workbook

output_path = "/sandbox/output/output_spreadsheet/1_463-17_init.xlsx"

# Load the saved workbook (read_only is fine for verification)
wb = load_workbook(output_path, data_only=True)
ws = wb.active

# Determine the range we wrote to (starting at row 19)
start_row = 19
# Count how many rows have values in column D from start_row onward
written_names = []
row = start_row
while True:
    val = ws.cell(row=row, column=4).value
    if val is None or val == "":
        break
    written_names.append(val)
    row += 1

print(f"Rows written in column D: {len(written_names)}")
print("First 10 names written:", written_names[:10])
print("Last 5 names written:", written_names[-5:])
