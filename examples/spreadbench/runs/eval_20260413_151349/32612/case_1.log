Code:
```repl
import openpyxl, os, datetime

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_32612_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_32612_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)  # keep formulas if any
ws = wb.active  # assuming single sheet

# Column indices (1‑based)
COL_DATE = 1          # DATE
COL_WORKDAY = 5        # WORKDAY (target)
COL_HOLIDAY_DATE = 9  # Date (holiday date)
COL_HOLIDAY_TYPE = 10 # Type (PH(...))

# Process rows
for row in ws.iter_rows(min_row=2, max_row=ws.max_row):
    # Extract values
    date_cell = row[COL_DATE - 1]
    holiday_date_cell = row[COL_HOLIDAY_DATE - 1]
    holiday_type_cell = row[COL_HOLIDAY_TYPE - 1]
    workday_cell = row[COL_WORKDAY - 1]

    date_val = date_cell.value
    holiday_date_val = holiday_date_cell.value
    holiday_type_val = holiday_type_cell.value

    # Ensure date_val is a date/datetime
    if isinstance(date_val, (datetime.datetime, datetime.date)):
        # Compare dates (ignore time component)
        if isinstance(date_val, datetime.datetime):
            date_cmp = date_val.date()
        else:
            date_cmp = date_val

        if isinstance(holiday_date_val, (datetime.datetime, datetime.date)):
            holiday_cmp = holiday_date_val.date() if isinstance(holiday_date_val, datetime.datetime) else holiday_date_val
            if date_cmp == holiday_cmp and holiday_type_val:
                # Holiday match – write holiday type
                workday_cell.value = holiday_type_val
                continue  # go to next row

        # Not a holiday – write weekday abbreviation
        workday_cell.value = date_cmp.strftime("%a")
    else:
        # If DATE is not a proper date, leave WORKDAY blank
        workday_cell.value = None

# Save to output
wb.save(output_path)

# Verify a few rows of the new WORKDAY column
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification (first 5 rows):")
for i in range(2, min(7, ws_check.max_row + 1)):
    print(f"Row {i}: DATE={ws_check.cell(i, COL_DATE).value}, WORKDAY={ws_check.cell(i, COL_WORKDAY).value}")
```
