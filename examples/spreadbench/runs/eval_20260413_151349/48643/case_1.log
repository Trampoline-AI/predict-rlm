import openpyxl
from pathlib import Path

# Load workbook (keep formulas)
input_path = Path("/sandbox/input/input_spreadsheet/1_48643_init.xlsx")
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet1"]

# Print first few rows of relevant columns to understand existing data
print("Sample data rows (Year, Deposit, Efficiency, Inflation):")
for r in range(2, min(8, ws.max_row + 1)):
    year = ws.cell(row=r, column=1).value
    deposit = ws.cell(row=r, column=2).value
    efficiency = ws.cell(row=r, column=3).value
    inflation = ws.cell(row=r, column=4).value
    print(f"Row {r}: Year={year}, Deposit={deposit}, Efficiency={efficiency}, Inflation={inflation}")

# Determine column indexes for target columns
col_eff_amount = 5   # "Efficiency amount"
col_end_amount = 6   # "End amount"
col_total_ability = 8  # "Total ability"

# Compute values row by row
prev_end = 0
for r in range(2, ws.max_row + 1):
    deposit = ws.cell(row=r, column=2).value or 0
    efficiency = ws.cell(row=r, column=3).value or 0  # assume stored as decimal (e.g., 0.06)
    # Efficiency amount = Deposit * (1 + Efficiency)
    eff_amount = deposit * (1 + efficiency)
    ws.cell(row=r, column=col_eff_amount).value = eff_amount

    # End amount = previous end + efficiency amount
    end_amount = prev_end + eff_amount
    ws.cell(row=r, column=col_end_amount).value = end_amount

    # Total ability = cumulative sum of end amounts (same as end_amount here)
    ws.cell(row=r, column=col_total_ability).value = end_amount

    prev_end = end_amount

# Save to output directory
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_48643_init.xlsx"
wb.save(output_path)

# Recalculate formulas (if any) to cache values
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Reload with data_only=True to verify computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("\nVerification of computed columns (first 5 rows):")
for r in range(2, min(7, ws_check.max_row + 1)):
    eff_amount = ws_check.cell(row=r, column=col_eff_amount).value
    end_amount = ws_check.cell(row=r, column=col_end_amount).value
    total_ability = ws_check.cell(row=r, column=col_total_ability).value
    print(f"Row {r}: Efficiency amount={eff_amount}, End amount={end_amount}, Total ability={total_ability}")
