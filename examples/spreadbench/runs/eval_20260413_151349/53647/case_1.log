```repl
import os
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_53647_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_53647_init.xlsx")

# Load workbook
wb = load_workbook(input_path)
# Assume the first sheet is the target (could be adjusted after inspection)
ws = wb.active

# Write formulas to E7:E16
for row in range(7, 17):
    formula = f"=IF(NOT(ISBLANK(C{row})), C{row}, IF(NOT(ISBLANK(D{row})), D{row}, \"\"))"
    ws[f"E{row}"] = formula

# Save workbook
wb.save(output_path)

# Quick verification: print a few formulas
for row in range(7, 10):
    print(f"E{row} formula:", ws[f"E{row}"].value)
```
