Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_472-15_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_472-15_init.xlsx"

# Load workbook (preserve existing sheets and data)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Ensure a clean VBA_Code sheet (remove if already exists)
if "VBA_Code" in wb.sheetnames:
    ws_old = wb["VBA_Code"]
    wb.remove(ws_old)

# Create new sheet for VBA code
ws = wb.create_sheet(title="VBA_Code")

# VBA code to implement the described logic
vba_code = '''
Private Sub Worksheet_Change(ByVal Target As Range)
    If Not Intersect(Target, Range("A1")) Is Nothing Then
        Select Case LCase(Range("A1").Value)
            Case "4ozark"
                Range("B2").Value = 1
            Case "3tall"
                Range("B2").Value = 2
            Case "1jasper"
                Range("B2").Value = 3
            Case "2gwood"
                Range("B2").Value = 4
            Case "5dawson"
                Range("B2").Value = 5
            Case "8cpark"
                Range("B2").Value = 6
            Case Else
                Range("B2").Value = ""
        End Select
    End If
End Sub
'''
# Write the VBA code into cell A1 of the new sheet (preserves line breaks)
ws["A1"].value = vba_code

# Save the modified workbook to the output directory
wb.save(output_path)
print("Workbook saved with VBA code sheet at:", output_path)
```
