The code below performs all these steps in one pass, guaranteeing that the output file contains both the editable `Patterns` sheet and the conditional formatting applied to column BD.
Code:
```repl
import os
import openpyxl
from openpyxl.formatting.rule import FormulaRule
from openpyxl.styles import PatternFill
from openpyxl.utils import column_index_from_string

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_73-45_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_73-45_init.xlsx')

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# -------------------------------------------------
# 1. Ensure a Patterns sheet exists with example entries
# -------------------------------------------------
if 'Patterns' not in wb.sheetnames:
    pat_ws = wb.create_sheet('Patterns')
    pat_ws['A1'] = 'Pattern'          # header
    # Example patterns – user can edit later
    example_patterns = ['example', 'test', '123']
    for i, pat in enumerate(example_patterns, start=2):
        pat_ws[f'A{i}'] = pat
else:
    pat_ws = wb['Patterns']
    # If the sheet exists but is empty, add header and examples
    if pat_ws.max_row < 1 or pat_ws['A1'].value is None:
        pat_ws['A1'] = 'Pattern'
        for i, pat in enumerate(['example', 'test', '123'], start=2):
            pat_ws[f'A{i}'] = pat

# -------------------------------------------------
# 2. Read all pattern strings (skip header)
# -------------------------------------------------
patterns = []
for row in pat_ws.iter_rows(min_row=2, max_col=1, values_only=True):
    val = row[0]
    if isinstance(val, str) and val.strip():
        patterns.append(val.strip())

print(f'Loaded {len(patterns)} patterns:', patterns[:5])

# -------------------------------------------------
# 3. Apply conditional formatting to column BD
# -------------------------------------------------
# Assume the main data is in the first sheet
ws = wb[wb.sheetnames[0]]
max_row = ws.max_row
bd_col_letter = 'BD'          # column to highlight

# Yellow fill for highlighting
highlight_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")

# Apply a rule for each pattern
for idx, pat in enumerate(patterns, start=2):   # pattern rows start at 2 in Patterns sheet
    pat_cell = f'Patterns!$A${idx}'
    # Anchor the formula at row 2; Excel will adjust the row number automatically
    formula = f'=ISNUMBER(SEARCH({pat_cell}, {bd_col_letter}2))'
    rule = FormulaRule(formula=[formula], fill=highlight_fill)
    ws.conditional_formatting.add(f'{bd_col_letter}2:{bd_col_letter}{max_row}', rule)

# -------------------------------------------------
# 4. Save the modified workbook
# -------------------------------------------------
wb.save(output_path)
print('Saved workbook with patterns and conditional formatting to', output_path)
```
