Reasoning: We need to load the input workbook, inspect its sheets, then for each row in the 'Base' sheet write the value from column F of the 'Streets' sheet into column E of 'Base' when two conditions are met: (1) Base!C matches Streets!B exactly, and (2) Base!D falls within the numeric range defined by Streets!C (Start) and Streets!D (End). Only consider Streets rows where both Start and End are populated. We'll implement this with openpyxl, iterating over rows, performing the lookup, and writing the result. After processing, we save the workbook to the output directory preserving the original filename. We'll also print a brief summary of how many rows were updated.
Code:
```repl
import os
from openpyxl import load_workbook

# Paths from the provided variables
input_path = input_spreadsheet  # e.g., /sandbox/input/input_spreadsheet/initial.xlsx
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write, keep formulas)
wb = load_workbook(input_path)

# Verify sheets exist
if 'Base' not in wb.sheetnames or 'Streets' not in wb.sheetnames:
    raise ValueError("Required sheets 'Base' or 'Streets' not found in workbook")

base_ws = wb['Base']
streets_ws = wb['Streets']

# Build an index for Streets rows keyed by column B (the matching value).
# For each key we store a list of rows where Start (C) and End (D) are both populated.
streets_index = {}
for row in streets_ws.iter_rows(min_row=2, values_only=False):
    # columns: A=1, B=2, C=3, D=4, E=5, F=6
    key_cell = row[1]   # column B
    start_cell = row[2] # column C
    end_cell = row[3]   # column D
    value_cell = row[5] # column F
    # Skip rows where Start or End is missing
    if start_cell.value is None or end_cell.value is None:
        continue
    # Ensure numeric start/end
    try:
        start_val = float(start_cell.value)
        end_val = float(end_cell.value)
    except (TypeError, ValueError):
        continue
    key = key_cell.value
    if key is None:
        continue
    streets_index.setdefault(key, []).append({
        "start": start_val,
        "end": end_val,
        "value": value_cell.value,
    })

# Process Base rows
updated_count = 0
for row in base_ws.iter_rows(min_row=2, values_only=False):
    # columns: A=1, B=2, C=3, D=4, E=5, F=6 ...
    base_key_cell = row[2]   # column C
    base_num_cell = row[3]   # column D
    target_cell = row[4]     # column E (where we write)
    base_key = base_key_cell.value
    if base_key is None:
        continue
    # Ensure Base D is numeric
    try:
        base_num = float(base_num_cell.value)
    except (TypeError, ValueError):
        continue
    # Look up matching street rows
    candidates = streets_index.get(base_key, [])
    matched_value = None
    for cand in candidates:
        if cand["start"] <= base_num <= cand["end"]:
            matched_value = cand["value"]
            break  # take first matching range
    if matched_value is not None:
        target_cell.value = matched_value
        updated_count += 1

# Save the modified workbook
wb.save(output_path)

print(f"Processing complete. Updated {updated_count} rows in 'Base' sheet.")
print(f"Output saved to: {output_path}")
```
