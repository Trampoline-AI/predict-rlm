Code:
```repl
import openpyxl
from pathlib import Path
import os

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_54274_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_54274_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume the relevant sheet is the active one

# Find header row (where column B == "Target")
header_row = None
for r in range(1, ws.max_row + 1):
    if ws.cell(row=r, column=2).value == "Target":
        header_row = r
        break

if header_row is None:
    raise ValueError("Header row with 'Target' not found.")

# Write nested IF formula into column G (Points) for each data row
for r in range(header_row + 1, ws.max_row + 1):
    total_cell = ws.cell(row=r, column=6)   # column F
    # Only write formula if there is a total value (skip empty rows)
    if total_cell.value is None:
        continue

    # Build the formula string using row‑specific references
    formula = (
        f"=IF(F{r}<=B{r}, F{r}/B{r}, "
        f"IF(F{r}<=C{r}, (F{r}-B{r})/(C{r}-B{r})*E{r}, 0))"
    )
    ws.cell(row=r, column=7).value = formula  # column G (Points)

# Save the workbook to the output location
wb.save(output_path)

# Recalculate formulas to cache values (using the provided tool)
# The tool is async; we call it and wait for completion.
await recalculate(str(output_path))

# Reload the workbook with data_only=True to verify the cached results
wb_verified = openpyxl.load_workbook(output_path, data_only=True)
ws_verified = wb_verified.active

# Print a quick verification of the first few Points values
print("Verification of Points column (first 5 data rows):")
for r in range(header_row + 1, min(header_row + 6, ws_verified.max_row + 1)):
    points = ws_verified.cell(row=r, column=7).value
    print(f"Row {r}: Points = {points}")

# Close workbooks
wb.close()
wb_verified.close()
```
