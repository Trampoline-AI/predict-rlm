import os
from pathlib import Path
import openpyxl

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_82-30_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_82-30_init.xlsx"

# Load workbook (read raw for extracting values)
wb = openpyxl.load_workbook(input_path, data_only=True)

# Get worksheets
raw_ws = wb["Raw Data"]
numbers_ws = wb["Numbers"]  # target sheet

# ----------------------------------------------------------------------
# Step 1: collect whole numbers from Raw Data (columns A-F)
# ----------------------------------------------------------------------
whole_numbers = []
for row in raw_ws.iter_rows(min_row=1, max_row=raw_ws.max_row,
                            min_col=1, max_col=6, values_only=True):
    for val in row:
        # Accept ints or floats that are mathematically whole numbers
        if isinstance(val, (int, float)):
            if val == int(val):
                whole_numbers.append(int(val))

print(f"Collected {len(whole_numbers)} whole numbers from Raw Data.")

# ----------------------------------------------------------------------
# Step 2: write them into Numbers sheet, max 6 per row (columns A-F)
# ----------------------------------------------------------------------
# Clear existing content (optional, but we overwrite anyway)
for r in numbers_ws.iter_rows(min_row=1, max_row=numbers_ws.max_row,
                              min_col=1, max_col=6):
    for cell in r:
        cell.value = None

for idx, num in enumerate(whole_numbers):
    out_row = idx // 6 + 1          # 1‑based row index
    out_col = (idx % 6) + 1         # 1‑based column index (A‑F)
    numbers_ws.cell(row=out_row, column=out_col, value=num)

# ----------------------------------------------------------------------
# Step 3: Save to output location
# ----------------------------------------------------------------------
wb.save(output_path)

# ----------------------------------------------------------------------
# Verification: reload with data_only=True and preview first few rows
# ----------------------------------------------------------------------
vb = openpyxl.load_workbook(output_path, data_only=True)
num_ws = vb["Numbers"]
def preview(ws, rows=5, cols=6):
    data = []
    for r in ws.iter_rows(min_row=1, max_row=rows,
                          min_col=1, max_col=cols, values_only=True):
        data.append(r)
    return data

print("Preview of Numbers sheet (first 5 rows, columns A‑F):")
print(preview(num_ws))
