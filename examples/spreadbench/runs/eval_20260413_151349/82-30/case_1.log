Code:
```repl
import os
from pathlib import Path
import openpyxl

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_82-30_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_82-30_init.xlsx"

# Load workbook for reading (data_only to get raw numbers)
wb = openpyxl.load_workbook(input_path, data_only=True)
raw_ws = wb["Raw Data"]

# Collect whole numbers column‑wise (A, C, E) then B, D, F (if any whole numbers there)
whole_numbers = []
# Columns A-F are 1‑6; we will iterate columns first, then rows
for col in range(1, 7):  # 1‑based column index
    for row in range(1, raw_ws.max_row + 1):
        val = raw_ws.cell(row=row, column=col).value
        if isinstance(val, (int, float)) and val == int(val):
            whole_numbers.append(int(val))

print(f"Collected {len(whole_numbers)} whole numbers column‑wise.")

# Load workbook again for writing (default mode keeps formulas etc.)
wb_write = openpyxl.load_workbook(input_path)
numbers_ws = wb_write["Numbers"]

# Clear existing content in target range (A‑F, up to needed rows)
max_needed_rows = (len(whole_numbers) - 1) // 6 + 1
for r in range(1, max_needed_rows + 1):
    for c in range(1, 7):
        numbers_ws.cell(row=r, column=c).value = None

# Write numbers row‑major into A‑F
for idx, num in enumerate(whole_numbers):
    out_row = idx // 6 + 1
    out_col = (idx % 6) + 1
    numbers_ws.cell(row=out_row, column=out_col, value=num)

# Save to output path
wb_write.save(output_path)

# Verify by re‑loading with data_only and preview first few rows of Numbers
vb = openpyxl.load_workbook(output_path, data_only=True)
num_ws = vb["Numbers"]

def preview(ws, rows=5, cols=6):
    data = []
    for r in ws.iter_rows(min_row=1, max_row=rows, min_col=1, max_col=cols, values_only=True):
        data.append(r)
    return data

print("First 5 rows of Numbers sheet (A‑F):")
print(preview(num_ws))
```
