import os
import re
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
ws = wb.active  # assume the first sheet is the target

# -------------------------------------------------
# 1. Unmerge any merged cells (make them writable)
# -------------------------------------------------
for merged_range in list(ws.merged_cells.ranges):
    ws.unmerge_cells(str(merged_range))

# -------------------------------------------------
# 2. Determine start row for data (first row after header)
# -------------------------------------------------
# Header is row 2 (based on inspection). Data starts at row 3.
start_row = 3

# -------------------------------------------------
# 3. Process each data row
# -------------------------------------------------
max_row = ws.max_row
for row in range(start_row, max_row + 1):
    src_cell = ws.cell(row=row, column=1)  # column A
    raw = src_cell.value
    if raw is None:
        # Clear any existing target cells
        for i in range(9):
            ws.cell(row=row, column=3 + i).value = None
        continue

    # Split on '/' or '-' (both act as delimiters)
    text = str(raw)
    parts = re.split(r"[/-]", text)
    # Trim whitespace and drop empty strings
    parts = [p.strip() for p in parts if p.strip()]

    # Write up to 9 parts into columns C‑K (3‑11)
    for i in range(9):
        target_cell = ws.cell(row=row, column=3 + i)  # C is column 3
        if i < len(parts):
            target_cell.value = parts[i]
        else:
            target_cell.value = None  # clear leftover cells

# -------------------------------------------------
# 4. Save the workbook
# -------------------------------------------------
wb.save(output_path)

# -------------------------------------------------
# 5. Verification summary
# -------------------------------------------------
data_rows = max_row - start_row + 1
print(f"Processed {data_rows} data rows (rows {start_row}-{max_row}).")
sample_row = start_row if max_row >= start_row else None
if sample_row:
    orig = ws.cell(row=sample_row, column=1).value
    split = [ws.cell(row=sample_row, column=3 + i).value for i in range(9)]
    print(f"Sample split from row {sample_row}:")
    print(f"  Original: {orig}")
    print(f"  Parts: {split}")
else:
    print("No data rows found.")
