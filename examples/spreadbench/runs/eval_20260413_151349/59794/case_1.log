import os
import re
from openpyxl import load_workbook

# Paths from the variables
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = load_workbook(input_path)
ws = wb.active  # assume the first sheet is the target

# Determine max rows and columns
max_row = ws.max_row
max_col = ws.max_column

# Ensure headers for final columns (C-K = columns 3 to 11)
header_row = 1
for col_idx in range(3, 12):  # 3..11 inclusive
    cell = ws.cell(row=header_row, column=col_idx)
    if not cell.value:
        # Simple header name, could be refined if needed
        cell.value = f"FINAL INFORMATION {col_idx-2}"

# Process each data row
for row in range(2, max_row + 1):
    src_cell = ws.cell(row=row, column=1)  # column A
    raw = src_cell.value
    if raw is None:
        continue
    # Ensure we work with a string
    text = str(raw)
    # Split on '/' or '-' (both act as delimiters)
    parts = re.split(r'[/-]', text)
    # Trim whitespace from each part
    parts = [p.strip() for p in parts if p.strip() != ""]
    # Write up to 9 parts into columns C-K
    for i in range(9):
        target_col = 3 + i  # C is 3
        target_cell = ws.cell(row=row, column=target_col)
        if i < len(parts):
            target_cell.value = parts[i]
        else:
            target_cell.value = None  # clear any previous data

# Save the modified workbook
wb.save(output_path)

# Print a brief verification summary
print(f"Processed {max_row-1} data rows.")
print(f"Sample split from row 2: {ws.cell(row=2, column=1).value} ->", end=" ")
sample_parts = [ws.cell(row=2, column=3+i).value for i in range(9)]
print(sample_parts)
