```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_343-20_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_343-20_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Identify source and target sheets (use exact names if present, otherwise fallback)
source_name = "Imported Data"  # as observed
if source_name not in wb.sheetnames:
    # try a fuzzy match
    for name in wb.sheetnames:
        if "import" in name.lower():
            source_name = name
            break
source_ws = wb[source_name]

target_name = "Duplicates"
if target_name not in wb.sheetnames:
    target_ws = wb.create_sheet(title=target_name)
else:
    target_ws = wb[target_name]

# Column indices (1‑based)
col_reference = 3   # C
col_invoiced = 4    # D
col_balance = 5     # E

# First pass: count references
ref_counts = {}
for row in source_ws.iter_rows(min_row=2, max_col=col_reference, values_only=True):
    ref = row[col_reference - 1]
    if ref is None:
        continue
    ref_counts[ref] = ref_counts.get(ref, 0) + 1

# Determine which references are duplicated
duplicate_refs = {ref for ref, cnt in ref_counts.items() if cnt > 1}

# Collect rows that have a duplicated reference
rows_to_copy = []
for row in source_ws.iter_rows(min_row=2, max_col=source_ws.max_column, values_only=True):
    ref = row[col_reference - 1]
    if ref in duplicate_refs:
        rows_to_copy.append(row)

# Sort rows by Balance (numeric) then Invoiced Date (datetime or string)

def sort_key(row):
    balance = row[col_balance - 1]
    invoiced = row[col_invoiced - 1]
    # Ensure balance is numeric; treat None as 0
    try:
        bal = float(balance) if balance is not None else 0.0
    except Exception:
        bal = 0.0
    # For date, keep as is; None sorts before any date
    return (bal, invoiced)

rows_to_copy.sort(key=sort_key)

# Write to target sheet: keep existing header row, then overwrite rows starting at 2
# Clear existing data rows (if any)
max_row_target = target_ws.max_row
if max_row_target > 1:
    target_ws.delete_rows(2, max_row_target - 1)

# Write rows
for idx, row_vals in enumerate(rows_to_copy, start=2):
    for col_idx, value in enumerate(row_vals, start=1):
        target_ws.cell(row=idx, column=col_idx, value=value)

# Save to output location
wb.save(output_path)

print(f"Rows written to '{target_name}': {len(rows_to_copy)}")
print(f"Output saved to {output_path}")
