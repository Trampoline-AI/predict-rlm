```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_343-20_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_343-20_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Identify source and target sheets
source_name = "Imported Data"
if source_name not in wb.sheetnames:
    # fallback to any sheet containing "import"
    for name in wb.sheetnames:
        if "import" in name.lower():
            source_name = name
            break
source_ws = wb[source_name]

target_name = "Duplicates"
if target_name not in wb.sheetnames:
    target_ws = wb.create_sheet(title=target_name)
else:
    target_ws = wb[target_name]

# Column indices (1‑based)
col_reference = 3   # C
col_invoiced = 4    # D
col_balance = 5     # E

# First pass: count references
ref_counts = {}
for row in source_ws.iter_rows(min_row=2, max_col=col_reference, values_only=True):
    ref = row[col_reference - 1]
    if ref is None:
        continue
    ref_counts[ref] = ref_counts.get(ref, 0) + 1

# Determine duplicated references
duplicate_refs = {ref for ref, cnt in ref_counts.items() if cnt > 1}

# Collect rows with duplicated reference
rows_to_copy = []
for row in source_ws.iter_rows(min_row=2, max_col=source_ws.max_column, values_only=True):
    ref = row[col_reference - 1]
    if ref in duplicate_refs:
        rows_to_copy.append(row)

# Sorting key: (balance as float, invoiced date as string)
def sort_key(row):
    # Balance
    bal_raw = row[col_balance - 1]
    try:
        bal = float(bal_raw) if bal_raw is not None else 0.0
    except Exception:
        bal = 0.0
    # Invoiced Date
    invoiced_raw = row[col_invoiced - 1]
    invoiced_str = "" if invoiced_raw is None else str(invoiced_raw)
    return (bal, invoiced_str)

rows_to_copy.sort(key=sort_key)

# Clear existing data rows in target sheet (preserve header)
if target_ws.max_row > 1:
    target_ws.delete_rows(2, target_ws.max_row - 1)

# Write sorted rows to target sheet
for idx, row_vals in enumerate(rows_to_copy, start=2):
    for col_idx, value in enumerate(row_vals, start=1):
        target_ws.cell(row=idx, column=col_idx, value=value)

# Save workbook
wb.save(output_path)

print(f"Duplicated rows written to '{target_name}': {len(rows_to_copy)}")
print(f"Output saved at: {output_path}")
