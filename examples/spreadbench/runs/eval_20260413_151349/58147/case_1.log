import openpyxl
from pathlib import Path

output_path = Path("/sandbox/output/output_spreadsheet/1_58147_init.xlsx")

# Reload workbook (default data_only=False to see formulas)
wb = openpyxl.load_workbook(output_path)
ws = wb.active

# Verify first few rows in column J
for row in range(2, 6):
    cell = ws.cell(row=row, column=10)  # column J
    print(f"Row {row} J cell: value={cell.value}")

# Verify last row
last_row = ws.max_row
cell = ws.cell(row=last_row, column=10)
print(f"Row {last_row} J cell: value={cell.value}")

# Confirm path exists
print("Output file exists:", output_path.is_file())
```
