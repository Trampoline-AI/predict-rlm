Code:
```repl
import openpyxl, os, pathlib

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50486_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_50486_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)  # keep formulas if any
ws = wb.active  # assume first sheet

# Counters for reporting
updated = 0
unchanged = 0

# Process rows (skip header row)
for row in range(2, ws.max_row + 1):
    chep_val = ws.cell(row=row, column=3).value  # column C
    loscam_val = ws.cell(row=row, column=4).value  # column D

    # Determine target text
    target = None
    if isinstance(chep_val, (int, float)):
        target = "Chep"
    elif isinstance(loscam_val, (int, float)):
        target = "Loscam"

    # Write to column A if we have a target
    if target is not None:
        ws.cell(row=row, column=1).value = target
        updated += 1
    else:
        # Optionally clear existing value if neither column is numeric
        ws.cell(row=row, column=1).value = None
        unchanged += 1

# Save the modified workbook
wb.save(output_path)

# Verify a few rows after saving (reload with data_only to see cached values)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

print(f"Rows updated: {updated}, rows unchanged/cleared: {unchanged}")
print("Sample of column A values after update (first 5 data rows):")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f"Row {r}: {ws_check.cell(row=r, column=1).value}")
```
