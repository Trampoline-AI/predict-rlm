Reasoning: We inspected the input workbook and found it has one sheet with columns PO, ITEM, DEC, Price. The task is to count how many rows each ITEM appears, then write a summary starting at cell I3 with headers "ITEM" and "Qty". The items must be listed in the specific order A006, A004, A005 (any missing items get a count of 0). We will compute the counts in Python, write the headers and rows, set left‑alignment for the whole output range, and save the modified workbook to the required output directory while preserving the original filename.
Code:
```repl
import os
import openpyxl
from openpyxl.styles import Alignment

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet contains the data

# Count ITEM occurrences (column B = 2)
item_counts = {}
for row in ws.iter_rows(min_row=2, max_col=2, values_only=True):
    item = row[1]  # column B
    if item is None:
        continue
    item_counts[item] = item_counts.get(item, 0) + 1

# Desired order
order = ["A006", "A004", "A005"]

# Write output starting at I3 (column 9, row 3)
start_col = 9  # I
header_row = 3
ws.cell(row=header_row, column=start_col, value="ITEM")
ws.cell(row=header_row, column=start_col + 1, value="Qty")

# Left alignment style
left_align = Alignment(horizontal="left")

# Apply alignment to header cells
ws.cell(row=header_row, column=start_col).alignment = left_align
ws.cell(row=header_row, column=start_col + 1).alignment = left_align

# Write each item and its count
out_row = header_row + 1
for itm in order:
    count = item_counts.get(itm, 0)
    ws.cell(row=out_row, column=start_col, value=itm).alignment = left_align
    ws.cell(row=out_row, column=start_col + 1, value=count).alignment = left_align
    out_row += 1

# Save to output location
wb.save(output_path)

# Print a short verification
print(f"Written summary for {len(order)} items to {output_path}")
```
