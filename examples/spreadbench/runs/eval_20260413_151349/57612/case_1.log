    c_val = ws_check.cell(row=r, column=3).value  # column C
    d_val = ws_check.cell(row=r, column=4).value  # column D (computed)
    print(f"Row {r}: C={c_val} -> D={d_val}")

# Confirm file existence
print("Output file exists:", os.path.isfile(output_path))
