import os
import openpyxl

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_353-29_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume first sheet is the target

# Track the last numeric URN and suffix index
last_numeric = None
suffix_idx = 0

# Helper to test if a value is an integer (or integer‑like string)
def is_int(val):
    if isinstance(val, int):
        return True
    if isinstance(val, str):
        return val.isdigit()
    return False

# Process rows (skip header row 1)
for row in range(2, ws.max_row + 1):
    cell = ws.cell(row=row, column=1)  # column A
    val = cell.value

    if val is None:
        # Blank cell – fill if we have a preceding numeric URN
        if last_numeric is not None:
            suffix = chr(ord('a') + suffix_idx)
            cell.value = f"{last_numeric}{suffix}"
            suffix_idx += 1
        # else: no preceding numeric, leave blank
    else:
        # Non‑blank cell
        if is_int(val):
            # New numeric URN – reset suffix counter
            last_numeric = int(val)
            suffix_idx = 0
        else:
            # Existing suffix (e.g., "5a") – treat as part of the sequence
            # Do not change last_numeric or suffix_idx; just continue
            pass

# Save the modified workbook
wb.save(output_path)

# Verify by re‑loading with cached values (data_only=True) and printing samples
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

print("Verification samples (row, col A):")
samples = []
# first few rows after header
for r in range(2, min(ws_check.max_row, 15) + 1):
    samples.append((r, ws_check.cell(row=r, column=1).value))
# a few rows near the middle
mid = ws_check.max_row // 2
for r in range(mid, min(mid + 5, ws_check.max_row) + 1):
    samples.append((r, ws_check.cell(row=r, column=1).value))
print(samples)
