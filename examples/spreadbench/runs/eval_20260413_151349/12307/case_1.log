import openpyxl, pandas as pd
from pathlib import Path

# Load the workbook
wb_path = Path("/sandbox/input/input_spreadsheet/1_12307_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# Print sheet names
print("Sheets:", wb.sheetnames)

# Function to show first few rows of a sheet as a DataFrame (limited columns)
def preview_sheet(ws, max_rows=5, max_cols=8):
    data = []
    for r in ws.iter_rows(min_row=1, max_row=max_rows, max_col=max_cols, values_only=True):
        data.append(r)
    df = pd.DataFrame(data)
    return df

# Preview each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\nPreview of sheet '{name}':")
    print(preview_sheet(ws))
```
