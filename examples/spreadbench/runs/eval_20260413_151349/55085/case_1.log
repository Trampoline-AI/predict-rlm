import openpyxl
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook for editing (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Result"]

# Helper to set same formula across a range of columns in row 10
def set_formula(col_start, col_end, base_col_letter, master_col_letter):
    """
    col_start, col_end: integer column indices (1‑based) inclusive.
    base_col_letter: column letter of the filter column in row 2/3 (e.g., 'G')
    master_col_letter: column letter in Master-RM to pull from (e.g., 'I')
    """
    for col in range(col_start, col_end + 1):
        # Determine the filter column letter for this cell (same as column)
        filter_letter = openpyxl.utils.get_column_letter(col)
        # Build formula string
        formula = (
            f"=INDEX('Master-RM'!{master_col_letter}:{master_col_letter}, "
            f"SUMPRODUCT(('Master-RM'!A:A={filter_letter}2)*"
            f"('Master-RM'!B:B={filter_letter}3)*"
            f"ROW('Master-RM'!A:A)))"
        )
        ws.cell(row=10, column=col).value = formula

# Columns G‑I (7‑9) pull from Master‑RM column I
set_formula(7, 9, "G", "I")

# Columns J‑L (10‑12) pull from Master‑RM column K
set_formula(10, 12, "J", "K")

# Save workbook to output location
wb.save(output_path)

# Optionally recalculate formulas to cache values (LibreOffice fallback)
# This ensures that when the file is opened with data_only=True, cells have values.
try:
    result = await recalculate(output_path)
    print("Recalculate result:", result)
except Exception as e:
    print("Recalculate failed:", e)

# Verify that formulas were written (print a few)
print("G10 formula:", ws["G10"].value)
print("J10 formula:", ws["J10"].value)
