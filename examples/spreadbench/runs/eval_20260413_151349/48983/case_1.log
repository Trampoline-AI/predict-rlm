Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the saved workbook (with formulas)
output_path = "/sandbox/output/output_spreadsheet/1_48983_init.xlsx"
wb = openpyxl.load_workbook(output_path, data_only=False)
src_ws = wb["Hárok1"]
lookup_ws = wb["Lookup"]

# Get categories from header row (row 1, columns B onward)
categories = [lookup_ws.cell(row=1, column=c).value for c in range(2, lookup_ws.max_column + 1)]

# Get brands from column A (rows 2 onward)
brands = [lookup_ws.cell(row=r, column=1).value for r in range(2, lookup_ws.max_row + 1)]

print("Categories:", categories)
print("Brands (first 10):", brands[:10])

# Helper to fetch source value for a given brand and category
def source_value(brand, category):
    # Find row of brand in source table (column B)
    for r in range(7, src_ws.max_row + 1):
        if src_ws.cell(row=r, column=2).value == brand:
            # Find column of category in row 5 (row C-I)
            for c in range(3, 10):
                if src_ws.cell(row=5, column=c).value == category:
                    return src_ws.cell(row=r, column=c).value
    return None

# Test a few known pairs
test_pairs = [("Bref", "HDD"), ("Cif", "TWC"), ("Clin", "FFI"), ("Domestos", "ADW")]
for brand, cat in test_pairs:
    val = source_value(brand, cat)
    # Locate the cell in Lookup sheet where this formula resides
    row_idx = brands.index(brand) + 2  # +2 because brands start at row 2
    col_idx = categories.index(cat) + 2  # +2 because categories start at column B
    formula = lookup_ws.cell(row=row_idx, column=col_idx).value
    print(f"Brand={brand}, Category={cat} -> source value={val}, formula={formula}")

# Verify that a sample formula matches the expected pattern
sample_formula = lookup_ws.cell(row=2, column=2).value
print("Sample formula (row 2, col 2):", sample_formula)
