Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_52532_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_52532_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine the last row with data (excluding header)
max_row = ws.max_row
# Write formula into column H for each player row (starting at row 2)
for r in range(2, max_row + 1):
    # Build the formula string for this row
    parts = []
    for col_idx, col_letter in enumerate(['B','C','D','E','F','G'], start=2):
        # Absolute range for the column max: $B$2:$B${max_row}
        abs_range = f"${col_letter}$2:${col_letter}${max_row}"
        part = f"IF({col_letter}{r}=MAX({abs_range}),1,0)"
        parts.append(part)
    formula = "=" + "+".join(parts)
    ws[f"H{r}"] = formula

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
# Using the provided async tool 'recalculate'
# Note: we need to await it, but in this REPL block we can just call it
# and then reload the workbook with data_only=True to verify.
# The REPL environment supports async calls directly.

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only=True to see computed values
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data[wb_data.sheetnames[0]]

# Print the win counts from column H for verification
win_counts = [ws_data.cell(row=r, column=8).value for r in range(2, max_row + 1)]
print("Win counts (column H):", win_counts)
```
