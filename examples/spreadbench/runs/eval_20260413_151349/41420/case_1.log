    # Get the value from column A
    cell_val = ws.cell(row=row, column=1).value
    s = str(cell_val) if cell_val is not None else ""
    # Extract digit characters
    digits = [ch for ch in s if ch.isdigit()]
    # Unique and sorted ascending
    uniq_sorted = sorted(set(digits), key=lambda x: int(x))
    # Write digits starting at column C (index 3)
    for offset, digit in enumerate(uniq_sorted):
