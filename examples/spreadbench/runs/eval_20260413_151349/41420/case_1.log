    # Clear any remaining cells up to column G (index 7)
    for col in range(3 + len(uniq_sorted), 8):  # columns 3..7 inclusive
        ws.cell(row=row, column=col, value=None)

# Save the modified workbook
wb.save(output_path)

# Verification output
print("Workbook processed and saved to:", output_path)
# Show row 2 values (columns A‑G) after processing
