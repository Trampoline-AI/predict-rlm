import openpyxl
from openpyxl.styles import PatternFill

output_path = '/sandbox/output/output_spreadsheet/1_254-34_init.xlsx'
wb = openpyxl.load_workbook(output_path, data_only=False)
after_ws = wb['After']

# Rows that were highlighted (as per previous step)
selected_rows = [1, 2, 4, 7, 9, 14, 16]

# Compute sum of values in those rows (column A)
values = [after_ws.cell(row=r, column=1).value for r in selected_rows]
sum_selected = sum(values)
print('Highlighted values:', values)
print('Sum of highlighted values:', sum_selected)

# Verify fill color is green (RGB 00FF00) for each highlighted cell
for r in selected_rows:
    cell = after_ws.cell(row=r, column=1)
    fill = cell.fill
    # openpyxl stores colors as ARGB; we compare start_color (ignore alpha)
    color = fill.start_color.rgb if fill.start_color.type == 'rgb' else None
    print(f'Row {r} fill color:', color)

# Also verify that non‑highlighted rows have no fill (or default)
non_selected = [r for r in range(1, after_ws.max_row+1) if r not in selected_rows]
for r in non_selected[:5]:  # show a few examples
    cell = after_ws.cell(row=r, column=1)
    fill = cell.fill
    color = fill.start_color.rgb if fill.start_color.type == 'rgb' else None
    print(f'Row {r} (non‑highlighted) fill color:', color)
