3. Write that value into the **Category Value** column of the report row.

Implementation steps:
- Load the workbook (read‑only not inspection, then normal mode for writing).
- Build a dictionary keyed by `(work, material)` that stores the three category values.
- Iterate over the report rows, perform the lookup, and write the result into column D.
- Save the modified workbook to the output directory, preserving the original filename.
- Print a short verification of a few report rows after the write.

The code below follows this plan.
Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_18935_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_18935_init.xlsx"

# Load workbook (data_only to get any cached formula results)
wb = openpyxl.load_workbook(input_path, data_only=True)
ws = wb.active  # only one sheet

# ----------------------------------------------------------------------
# 1. Build lookup dictionary from the Data Table
# ----------------------------------------------------------------------
# Header row for the data table is row 4
header_row = 4
col_work = 1          # A
col_material = 2      # B
col_cat1 = 3          # C
col_cat2 = 4          # D
col_cat3 = 5          # E

data_lookup = {}  # (work, material) -> {'Category 1': val, ...}
row = header_row + 1  # start at row 5
while row <= ws.max_row:
    work_val = ws.cell(row=row, column=col_work).value
    # Stop when the first column is empty (end of table)
    if work_val is None:
        break
    material_val = ws.cell(row=row, column=col_material).value
    cat1 = ws.cell(row=row, column=col_cat1).value
    cat2 = ws.cell(row=row, column=col_cat2).value
    cat3 = ws.cell(row=row, column=col_cat3).value
    data_lookup[(work_val, material_val)] = {
        "Category 1": cat1,
        "Category 2": cat2,
        "Category 3": cat3,
    }
    row += 1

# ----------------------------------------------------------------------
# 2. Perform lookup for each report row and write the result
# ----------------------------------------------------------------------
# Report header is row 16
report_header_row = 16
col_report_work = 1          # A
col_report_cat_type = 2      # B
col_report_material = 3      # C
col_report_value = 4         # D (where we write)

row = report_header_row + 1  # start at row 17
while row <= ws.max_row:
    work_val = ws.cell(row=row, column=col_report_work).value
    # Stop when the first column of the report section is empty
    if work_val is None:
        break
    cat_type = ws.cell(row=row, column=col_report_cat_type).value
    material_val = ws.cell(row=row, column=col_report_material).value

    # Lookup the matching data row
    key = (work_val, material_val)
    result_val = None
    if key in data_lookup:
        result_val = data_lookup[key].get(cat_type)
    else:
        # No matching data; keep None (could also raise or log)
        result_val = None

    # Write the result into the Category Value column
    ws.cell(row=row, column=col_report_value, value=result_val)

    row += 1

# ----------------------------------------------------------------------
# 3. Save the modified workbook
# ----------------------------------------------------------------------
wb.save(output_path)

# ----------------------------------------------------------------------
# 4. Verify a few rows of the report after writing
# ----------------------------------------------------------------------
print("Verification of report rows (Work, Category Type, Material, Category Value):")
for r in range(report_header_row + 1, min(report_header_row + 6, ws.max_row + 1)):
    vals = [
        ws.cell(row=r, column=col_report_work).value,
        ws.cell(row=r, column=col_report_cat_type).value,
        ws.cell(row=r, column=col_report_material).value,
        ws.cell(row=r, column=col_report_value).value,
    ]
    print(f"Row {r}: {vals}")
```
