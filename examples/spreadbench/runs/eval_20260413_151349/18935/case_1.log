import openpyxl
from pathlib import Path

# Load the workbook (read-only is fine for inspection)
input_path = Path('/sandbox/input/input_spreadsheet/1_18935_init.xlsx')
wb = openpyxl.load_workbook(input_path, data_only=True)
print(f"Workbook loaded: {input_path}")
print(f"Sheets: {wb.sheetnames}")

# Function to print a preview of a sheet

def preview_sheet(ws, max_rows=6):
    # Get header row (assume first row is header)
    headers = [cell.value for cell in ws[1]]
    print(f"\nSheet: {ws.title}")
    print("Headers:", headers)
    # Print up to max_rows-1 data rows
    for r in range(2, min(ws.max_row, max_rows) + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)

# Preview each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    preview_sheet(ws)
