import openpyxl
from openpyxl.utils import get_column_letter

wb = openpyxl.load_workbook(input_spreadsheet)
ws = wb.active

# Scan first 15 rows and all columns for any non‑None values
found = {}
for r in range(1, 16):
    for c in range(1, ws.max_column + 1):
        val = ws.cell(row=r, column=c).value
        if isinstance(val, str) and val.strip():
            found[(r, c)] = val.strip()

# Print a summary of discovered header‑like cells
print("Discovered non‑empty cells (up to row 15):")
for (r, c), val in sorted(found.items()):
    print(f"R{r}C{c} ({get_column_letter(c)}{r}): {val}")

# Attempt to locate the needed columns by searching all rows
def locate_column(name):
    for (r, c), val in found.items():
        if val.lower() == name.lower():
            return c, r
    return None, None

over_col, over_row = locate_column("Over Due Days")
amount_col, amount_row = locate_column("Amount Outstanding")
remarks_col, remarks_row = locate_column("Remarks")

print("\nColumn locations:")
print(f"Over Due Days: column {over_col} ({get_column_letter(over_col) if over_col else '?'}) at row {over_row}")
print(f"Amount Outstanding: column {amount_col} ({get_column_letter(amount_col) if amount_col else '?'}) at row {amount_row}")
print(f"Remarks: column {remarks_col} ({get_column_letter(remarks_col) if remarks_col else '?'}) at row {remarks_row}")
```
