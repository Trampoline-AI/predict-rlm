import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active

# Column indices (1‑based) discovered earlier
remarks_col = 10   # J
overdue_col = 9    # I
amount_col = 8     # H

# Formula string using structured references (Table2)
formula = (
    '=IF(Table2[[#This Row],[Amount Outstanding]]<0,'
    '"Prepaid",'
    'IF(Table2[[#This Row],[Over Due Days]]="",'
    '",'
    'IF(Table2[[#This Row],[Over Due Days]]<90,'
    '"Call Customer",'
    '"Bad Debts")))'
)

# Write formula to each data row (starting after header row 5)
start_row = 6
for r in range(start_row, ws.max_row + 1):
    ws.cell(row=r, column=remarks_col).value = formula

# Save to output path
wb.save(output_path)

print(f"Saved modified workbook to: {output_path}")
print(f"Formula written to column {get_column_letter(remarks_col)} rows {start_row}-{ws.max_row}")
```
