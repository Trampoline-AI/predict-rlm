```python
import openpyxl
import os
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_382-10_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas if any)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Determine target sheet (use "Call QC" if present, else first sheet)
sheet_name = "Call QC" if "Call QC" in wb.sheetnames else wb.sheetnames[0]
ws = wb[sheet_name]

# Process column A (1 = column A)
for row in range(1, ws.max_row + 1):
    cell = ws.cell(row=row, column=1)
    # Keep only cells that are the word "comments" (case‑insensitive)
    if isinstance(cell.value, str) and cell.value.strip().lower() == "comments":
        # Preserve the value
        continue
    else:
        # Clear the cell
        cell.value = None

# Save the modified workbook
wb.save(output_path)

# Verify a few rows after modification
print(f"Modified sheet: {sheet_name}")
for row in range(1, min(11, ws.max_row + 1)):
    cell = ws.cell(row=row, column=1)
    print(f"Row {row}: {cell.value!r}")
