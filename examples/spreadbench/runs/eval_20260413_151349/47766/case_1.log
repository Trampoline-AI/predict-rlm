import openpyxl
from pathlib import Path

# Load workbook
wb_path = Path("/sandbox/input/input_spreadsheet/1_47766_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # "Total (2)"

# Check column A values for rows 8-74 to confirm they are dates
dates = []
for r in range(8, 75):
    val = ws.cell(row=r, column=1).value
    dates.append(val)

print("Sample dates (rows 8-12):", dates[:5])
print("Data type of first date cell:", type(dates[0]))

# If column A is not dates, try column B (which holds numbers) – but dates are usually column A.
# We'll assume column A is the date column.

# Insert start and end date placeholders in A1 and B1 if they are empty
if ws.cell(row=1, column=1).value is None:
    ws.cell(row=1, column=1).value = "StartDate"
if ws.cell(row=1, column=2).value is None:
    ws.cell(row=1, column=2).value = "EndDate"

# Define the three ranges we need to replace
ranges = [
    (8, 37),
    (41, 58),
    (62, 74),
]

# For each range, replace the existing SUM(C... ) total (row after the block) with a SUMIFS
# The total rows are 38, 59, 75 respectively (one row after each block)
total_rows = [38, 59, 75]

for (start, end), total_row in zip(ranges, total_rows):
    # Build SUMIFS formula:
    # =SUMIFS($C$start:$C$end, $H$start:$H$end, "*PE*", $A$start:$A$end, ">="&$A$1, $A$start:$A$end, "<="&$B$1)
    formula = (
        f"=SUMIFS($C${start}:$C${end}, $H${start}:$H${end}, \"*PE*\", "
        f"$A${start}:$A${end}, \">=\"&$A$1, $A${start}:$A${end}, \"<=\"&$B$1)"
    )
    ws.cell(row=total_row, column=3).value = formula
    print(f"Set formula in C{total_row}: {formula}")

# Save to output directory
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_47766_init.xlsx"
wb.save(output_path)
print("Workbook saved to:", output_path)
