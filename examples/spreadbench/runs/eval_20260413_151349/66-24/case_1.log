```repl
import openpyxl
from pathlib import Path
from datetime import datetime, timedelta

# Paths
input_path = Path(input_spreadsheet)  # provided variable
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas, we will write values)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Source and destination sheets
src = wb["Imported Data"]
dest = wb["Items Older than 30 days"]

# --- 1. Find max date in column E (5) ---
max_date = None
for r in range(2, src.max_row + 1):
    cell = src.cell(row=r, column=5)
    val = cell.value
    if isinstance(val, datetime):
        if max_date is None or val > max_date:
            max_date = val

if max_date is None:
    raise ValueError("No datetime values found in column E")

# --- 2. Determine rows older than 30 days ---
threshold = max_date - timedelta(days=30)
rows_to_copy = []  # list of row numbers (including header later)
# Include header row (row 1)
rows_to_copy.append(1)

for r in range(2, src.max_row + 1):
    cell = src.cell(row=r, column=5)
    val = cell.value
    if isinstance(val, datetime) and val < threshold:
        rows_to_copy.append(r)

# --- 3. Clear destination sheet (keep only header later) ---
dest.delete_rows(1, dest.max_row)  # remove all existing rows

# --- 4. Copy rows preserving values and date number format ---
out_row = 1
for src_row in rows_to_copy:
    for col in range(1, src.max_column + 1):
        src_cell = src.cell(row=src_row, column=col)
        dest_cell = dest.cell(row=out_row, column=col)
        # Copy value
        dest_cell.value = src_cell.value
        # Copy number format (important for dates)
        dest_cell.number_format = src_cell.number_format
        # Copy style (font, fill, alignment, border) if desired
        if src_cell.has_style:
            dest_cell.font = src_cell.font
            dest_cell.fill = src_cell.fill
            dest_cell.alignment = src_cell.alignment
            dest_cell.border = src_cell.border
    out_row += 1

# --- 5. Delete column Z (26) from destination sheet ---
if dest.max_column >= 26:
    dest.delete_cols(26)

# Save workbook
wb.save(output_path)

# Verify: load saved file data-only and print summary
wb_check = openpyxl.load_workbook(output_path, data_only=True)
sheet_check = wb_check["Items Older than 30 days"]
print("Saved sheet rows (including header):", sheet_check.max_row)
print("Sample dates after copy:")
for r in range(2, min(5, sheet_check.max_row + 1)):
    print(f"Row {r} column E:", sheet_check.cell(row=r, column=5).value)
```
