import openpyxl
from pathlib import Path

# Load the workbook (read-only is fine for inspection)
input_path = Path('/sandbox/input/input_spreadsheet/1_49333_init.xlsx')
wb = openpyxl.load_workbook(input_path, data_only=False)  # keep formulas

print('Sheets:', wb.sheetnames)

# Function to print a summary of a sheet

def sheet_summary(ws, max_rows=5):
    print(f"Sheet: {ws.title}")
    print(f"  Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    # Print column letters
    cols = [openpyxl.utils.get_column_letter(c) for c in range(1, ws.max_column+1)]
    print('  Columns:', cols)
    # Print header row (assume first row is header)
    header = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print('  Header:', header)
    # Print first few data rows
    for r in range(2, min(ws.max_row, max_rows)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f'  Row {r}:', row_vals)
    print('')

# Summarize each sheet
for ws in wb.worksheets:
    sheet_summary(ws)
