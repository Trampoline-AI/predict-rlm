Code:
```repl
import openpyxl
from pathlib import Path
import re

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_49333_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_49333_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Clean names in Sheet3 column A
ws3 = wb["Sheet3"]
for row in range(2, ws3.max_row + 1):
    cell = ws3.cell(row=row, column=1)  # column A
    name = cell.value
    if isinstance(name, str):
        # Strip leading/trailing whitespace
        cleaned = name.strip()
        # Remove apostrophes and periods
        cleaned = cleaned.replace("'", "").replace(".", "")
        # Collapse multiple spaces to a single space
        cleaned = re.sub(r"\s+", " ", cleaned)
        cell.value = cleaned

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas to cache results
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Load workbook with cached values to verify a few lookups
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws1 = wb_data["Sheet1"]
# Print a few VLOOKUP result cells (columns G, H, I correspond to index 2,3,4)
for r in range(2, 6):
    g = ws1.cell(row=r, column=7).value  # column G (index 2)
    h = ws1.cell(row=r, column=8).value  # column H (index 3)
    i = ws1.cell(row=r, column=9).value  # column I (index 4)
    print(f"Row {r} - G:{g}, H:{h}, I:{i}")
