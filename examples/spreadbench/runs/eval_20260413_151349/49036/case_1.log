Code:
```repl
import os, openpyxl

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_49036_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_49036_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Locate the dashboard sheet (case‑insensitive)
ws = None
for name in wb.sheetnames:
    if name.lower() == "dashboard":
        ws = wb[name]
        break
if ws is None:
    raise ValueError("Dashboard sheet not found")

# Write the percentage formula into B8
# Extract numeric part of B5 and B6, compute ratio, format as percentage, append " WIN RATE"
formula = (
    '=TEXT(VALUE(LEFT(B6, FIND(" ", B6)-1))/VALUE(LEFT(B5, FIND(" ", B5)-1)), "0.00%") & " WIN RATE"'
)
ws["B8"].value = formula

# Save to output location
wb.save(output_path)

# Recalculate formulas to cache values (LibreOffice fallback if needed)
result = await recalculate(output_path)
print("Recalculate result:", result)

# Reload with data_only=True to check the cached value
wb_cached = openpyxl.load_workbook(output_path, data_only=True)
ws_cached = wb_cached[ws.title]
print("B8 cached value:", ws_cached["B8"].value)
