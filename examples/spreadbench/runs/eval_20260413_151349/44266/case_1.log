lookup_ws = wb["Lookup"]

# Determine the max column to use for the range (Data sheet has 16 columns)
max_col = data_ws.max_column
# Build column letter range for row 14 and row 4
from openpyxl.utils import get_column_letter
col_start = get_column_letter(1)  # 'A'
col_end = get_column_letter(max_col)  # e.g., 'P'
row14_range = f"Data!${col_start}$14:${col_end}$14"
row4_range = f"Data!${col_start}$4:${col_end}$4"

# Write formula into Lookup!B2:B{last_row}
last_row = lookup_ws.max_row
for r in range(2, last_row + 1):
    year_cell = lookup_ws.cell(row=r, column=1).coordinate  # column A
    # Build formula string
    formula = f"=IFERROR(INDEX({row14_range}, MATCH({year_cell}, {row4_range}, 0)), \"\")"
    lookup_ws.cell(row=r, column=2).value = formula

