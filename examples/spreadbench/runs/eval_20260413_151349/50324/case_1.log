import openpyxl, os, json

# Load the workbook (read‑only for quick inspection)
wb_path = '/sandbox/input/input_spreadsheet/1_50324_init.xlsx'
wb = openpyxl.load_workbook(wb_path, read_only=True, data_only=True)

# Gather summary information
summary = {}
for ws in wb.worksheets:
    # Get max row/column (may be over‑estimated if there are empty trailing rows/cols)
    max_row = ws.max_row
    max_col = ws.max_column
    # Sample a few cells from the top‑left corner to see content
    sample = []
    for r in range(1, min(6, max_row+1)):
        row_vals = []
        for c in range(1, min(6, max_col+1)):
            val = ws.cell(row=r, column=c).value
            row_vals.append(val)
        sample.append(row_vals)
    summary[ws.title] = {
        'max_row': max_row,
        'max_col': max_col,
        'sample_top_left': sample,
    }

print(json.dumps(summary, indent=2, default=str))
