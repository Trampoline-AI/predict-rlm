import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INSTRUCTION:")
print(instruction)

path = input_spreadsheet
print("\nInput path:", path, "exists:", os.path.exists(path))

wb = load_workbook(path)
print("\nSheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print(f"\n=== SHEET: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = row_values(ws, 2, ws.max_column)
        print("Row2 values:", row2)
    # detect likely header row among first 3 rows
    for hr in range(1, min(4, ws.max_row+1)):
        vals = row_values(ws, hr, ws.max_column)
        nonempty = sum(v is not None and v != "" for v in vals)
        print(f"Row {hr} nonempty={nonempty}: {vals}")
    # print first 10 rows and last 5 rows
    first_n = min(10, ws.max_row)
    print("\nFirst rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, ws.max_column))
    if ws.max_row > 10:
        print("\nLast 5 rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            print(r, row_values(ws, r, ws.max_column))
    # identify columns containing 'remark', 'mat doc', 'doc no'
    header_row = 1
    header_map = {}
    for c in range(1, ws.max_column+1):
        v = ws.cell(header_row, c).value
        if isinstance(v, str):
            header_map[v.strip().lower()] = c
    print("\nHeader map row1:", header_map)
    # also scan first 3 rows for likely target headers
    for hr in range(1, min(4, ws.max_row+1)):
        vals = row_values(ws, hr, ws.max_column)
        targets = []
        for c, v in enumerate(vals, start=1):
            if isinstance(v, str) and any(k in v.lower() for k in ["remark", "mat doc", "doc no", "color", "border"]):
                targets.append((get_column_letter(c), c, v))
        if targets:
            print(f"Likely target headers in row {hr}:", targets)
    # print formulas in used range, capped
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formula cells count:", len(formulas))
