```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify target headers/area before writing
print("Before write:")
print("F3:G6")
for r in range(3, 7):
    print(r, ws[f"F{r}"].value, ws[f"G{r}"].value)

# Write formulas for all nonblank model names in column F starting at row 4
start_row = 4
end_row = ws.max_row
written_rows = []
for r in range(start_row, end_row + 1):
    model_cell = ws.cell(r, 6)  # F
    target_cell = ws.cell(r, 7) # G
    model = model_cell.value
    if model not in (None, ""):
        formula = f'=SUMIF($C$4:$C${ws.max_row},F{r},$D$4:$D${ws.max_row})'
        target_cell.value = formula
        written_rows.append((r, formula))
    else:
        # don't write beyond the designated output list
        pass

print("Written formulas:")
for item in written_rows:
    print(item)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, old_name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = old_name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and computed values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[orig_sheetnames[0]]

print("Verification target cells F4:G6:")
for r in range(4, 7):
    print(
        f"Row {r}:",
        "model=", repr(wsf[f"F{r}"].value),
        "formula=", repr(wsf[f"G{r}"].value),
        "value=", repr(wsv[f"G{r}"].value),
    )
```
