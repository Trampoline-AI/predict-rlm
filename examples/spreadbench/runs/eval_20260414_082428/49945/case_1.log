import os, json, textwrap, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(path), path)

wb = load_workbook(path)
orig_sheetnames = wb.sheetnames
print("Original sheet names:", orig_sheetnames)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols+1)]

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # find likely header rows among first 5 rows
