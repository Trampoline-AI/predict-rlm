import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Target sheet:", ws.title)
print("Target column A header:", ws["A1"].value)
print("Source column B header:", ws["B1"].value)

# Verify current target area before writing
for r in range(2, 8):
    print("Before", r, ws.cell(r,1).value, ws.cell(r,2).value)

written = 0
skipped_existing = 0
skipped_empty = 0

for r in range(2, ws.max_row + 1):
    result_cell = ws.cell(r, 1)
    code_cell = ws.cell(r, 2)
    code_val = code_cell.value
    
    if code_val in (None, ""):
        skipped_empty += 1
        continue
    
    # preserve existing example answers / existing valid values
    if result_cell.value not in (None, ""):
        skipped_existing += 1
        continue
    
    result_cell.value = f"=VALUE(MID(B{r},4,LEN(B{r})-3))"
    written += 1

print("Written formulas:", written)
print("Skipped existing results:", skipped_existing)
print("Skipped empty code rows:", skipped_empty)

wb.save(output_path)
print("Saved to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename sheets back positionally
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]

check_rows = [2, 3, 4, 5, 6, 50, 100, 1000, 2000, 4448, 4452]
print("\nVerification rows:")
for r in check_rows:
    print({
        "row": r,
        "code": ws_values.cell(r, 2).value,
        "formula_in_A": ws_formula.cell(r, 1).value,
        "value_in_A": ws_values.cell(r, 1).value,
    })

# Extra sanity checks for blanks/errors in target area where code exists
missing = []
for r in range(2, ws_values.max_row + 1):
    code_val = ws_values.cell(r, 2).value
    result_val = ws_values.cell(r, 1).value
    if code_val not in (None, "") and result_val in (None, ""):
        missing.append(r)
        if len(missing) >= 10:
            break

print("First missing result rows after recalculation:", missing)
print("Final sheet names:", wb_values.sheetnames)

output_spreadsheet = output_path
