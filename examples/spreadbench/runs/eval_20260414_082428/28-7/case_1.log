import os, re, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Re-open cleanly for inspection
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

def vals(r):
    return [ws.cell(r,c).value for c in range(1, ws.max_column+1)]

print("Detailed rows 1-26:")
for r in range(1, ws.max_row+1):
    print(r, vals(r))

# Identify exact deletion blocks in column A:
pat_start = re.compile(r"^400-.*-A$", re.I)
pat_any400 = re.compile(r"^400-.*", re.I)

colA = [ws.cell(r,1).value for r in range(1, ws.max_row+1)]
matches_any = [(r, v) for r, v in enumerate(colA, start=1) if isinstance(v, str) and pat_any400.match(v.strip())]
matches_start = [(r, v) for r, v in enumerate(colA, start=1) if isinstance(v, str) and pat_start.match(v.strip())]

print("All 400-* in col A:", matches_any)
print("All 400-*-A in col A:", matches_start)

deletion_blocks = []
for r, v in matches_start:
    next_400 = None
    for rr in range(r+1, ws.max_row+1):
        val = ws.cell(rr, 1).value
        if isinstance(val, str) and pat_any400.match(val.strip()):
            next_400 = rr
            break
    if next_400 is not None:
        deletion_blocks.append((r, next_400-1, v, ws.cell(next_400,1).value))

print("Deletion blocks (start_row, end_row, start_value, next_400_value):", deletion_blocks)

# Perform deletion on a copy, deleting from bottom upward
infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
shutil.copy2(infile, outfile)

wb2 = load_workbook(outfile)
orig_names = wb2.sheetnames[:]
ws2 = wb2["Sheet1"]

# recompute blocks against ws2 in case of any differences
blocks = []
for r in range(1, ws2.max_row+1):
    val = ws2.cell(r,1).value
    if isinstance(val, str) and pat_start.match(val.strip()):
        next_400 = None
        for rr in range(r+1, ws2.max_row+1):
            v2 = ws2.cell(rr,1).value
            if isinstance(v2, str) and pat_any400.match(v2.strip()):
                next_400 = rr
                break
        if next_400 is not None:
            blocks.append((r, next_400-1))

print("Blocks to delete in output copy:", blocks)

for start, end in sorted(blocks, reverse=True):
    amount = end - start + 1
    print(f"Deleting rows {start}:{end} (count={amount})")
    ws2.delete_rows(start, amount)

wb2.save(outfile)
print("Saved to:", outfile)

# recalc
result = await recalculate(outfile)
print("Recalculate result:", result)

# Restore sheet names if needed
wb3 = load_workbook(outfile)
print("Sheetnames after recalc:", wb3.sheetnames)
if wb3.sheetnames != orig_names:
    # rename by position
    for i, orig in enumerate(orig_names):
        if i < len(wb3.worksheets):
            wb3.worksheets[i].title = orig
    wb3.save(outfile)
    print("Renamed sheets back to:", orig_names)

# Verify output
wbv = load_workbook(outfile, data_only=False)
wsv = wbv["Sheet1"]
print("Verified sheetnames:", wbv.sheetnames)
print("Final row count:", wsv.max_row, "Final col count:", wsv.max_column)
for r in range(1, wsv.max_row+1):
    print(r, [wsv.cell(r,c).value for c in range(1, wsv.max_column+1)])

# specifically verify that row with 400-12345-A and following rows until next 400-* are gone
remaining_400 = [(r, wsv.cell(r,1).value) for r in range(1, wsv.max_row+1)
                 if isinstance(wsv.cell(r,1).value, str) and pat_any400.match(wsv.cell(r,1).value.strip())]
print("Remaining 400-* rows in A:", remaining_400)
print("Output exists:", os.path.exists(outfile))
output_spreadsheet = outfile
