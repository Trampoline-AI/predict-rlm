```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Inspect full relevant ranges
print("Sheet:", ws.title)
print("Rows:", ws.max_row, "Cols:", ws.max_column)

print("\nFull column D values:")
d_vals = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 4).value
    d_vals.append(v)
    print(r, repr(v))

print("\nFull A/B rows:")
for r in range(1, ws.max_row + 1):
    print(r, {"A": ws.cell(r,1).value, "B": ws.cell(r,2).value})

# Build allowed colors from column D, excluding header-ish items/blanks, preserving order and de-duplicating case-insensitively
colors = []
seen = set()
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 4).value
    if v is None:
        continue
    s = str(v).strip()
    if not s:
        continue
    if s.lower() == "colour":
        continue
    key = s.lower()
    if key not in seen:
        seen.add(key)
        colors.append(s)

print("\nAllowed colors from D:", colors)

# Identify target rows: data rows with product names in column A, starting at row 2
target_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    if a is not None and str(a).strip() != "":
        target_rows.append(r)

print("Target rows:", target_rows)

# Write formula in column B for every relevant row.
# Case-insensitive matching via SEARCH; return canonical capitalization from list in D.
def make_formula(row):
    formula = '""'
    for color in reversed(colors):
        esc = color.replace('"', '""')
        formula = f'IF(ISNUMBER(SEARCH("{esc}",A{row})),"{esc}",{formula})'
    return "=" + formula

print("\nFormulas to write:")
for r in target_rows:
    f = make_formula(r)
    print(r, f)
    ws.cell(r, 2).value = f

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if changed
wb_after = load_workbook(output_path)
current_names = wb_after.sheetnames
print("Sheet names after recalc:", current_names)
original_names = [ws.title for ws in wb.worksheets]
if current_names != original_names and len(current_names) == len(original_names):
    for ws_obj, orig_name in zip(wb_after.worksheets, original_names):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names:", original_names)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_names[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_names[0]]

print("\nVerification B2:B17:")
for r in target_rows:
    print(
        r,
        {
            "A": ws_values.cell(r, 1).value,
            "B_formula": ws_formula.cell(r, 2).value,
            "B_value": ws_values.cell(r, 2).value,
        }
    )

output_spreadsheet = output_path
