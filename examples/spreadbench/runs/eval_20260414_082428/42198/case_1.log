from openpyxl import load_workbook
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally for writing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Write cumulative formulas in C2:C7
for r in range(2, ws.max_row + 1):
    formula = (
        f'=IF(COUNTIFS($A$2:A{r},"Potato",$B$2:B{r},FALSE)>0,"Worst",'
        f'IF(COUNTIFS($A$2:A{r},"Tomato",$B$2:B{r},FALSE)>0,"Ignore",'
        f'IF(COUNTIFS($A$2:A{r},"Pickle",$B$2:B{r},FALSE)>0,"Bad","Good")))'
    )
    ws[f"C{r}"] = formula

print("Written formulas C2:C7:")
for r in range(2, ws.max_row + 1):
    print(f"C{r}:", ws[f'C{r}'].value)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position back to original
    for i, name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Renamed sheets back to original:", orig_sheet_names)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("\nFinal formulas in C2:C7:")
for r in range(2, ws_formula.max_row + 1):
    print(f"C{r} formula:", ws_formula[f'C{r}'].value)

# Verify evaluated values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]
print("\nEvaluated values in A:C rows 1:7:")
for r in range(1, ws_values.max_row + 1):
    print(r, [ws_values.cell(r, c).value for c in range(1, 4)])

target_values = [ws_values[f"C{r}"].value for r in range(2, ws_values.max_row + 1)]
print("Target C2:C7 values:", target_values)

# basic sanity checks
assert all(v is not None and str(v).strip() != "" for v in target_values), "Some target cells are blank"
assert wb_values.sheetnames == orig_sheet_names, "Sheet names changed unexpectedly"
```
