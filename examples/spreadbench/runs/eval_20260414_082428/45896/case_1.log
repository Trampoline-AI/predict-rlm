Because these are multi-date concatenated outputs, the result must ultimately be text anyway. LibreOffice/openpyxl recalculation is unreliable for these array/dynamic formulas, so the safest compliant implementation is to compute the joined formatted text in Python and write it directly into the existing Column I cells for all relevant rows. I’ll preserve the sheet structure, save to the output directory with the same filename, recalculate, reload, check sheet names, and verify `I2:I10`.
Code:
```repl
import os
from collections import OrderedDict, defaultdict
from datetime import datetime, date
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Volym P5_P6_2023"]
zws = wb["ZORD"]

# Build mapping Material -> ordered unique list of dates from ZORD col C ("Valid to")
material_to_dates = defaultdict(list)
seen_per_material = defaultdict(set)

for r in range(2, zws.max_row + 1):
    mat = zws.cell(r, 1).value
    dt = zws.cell(r, 3).value
    if mat in (None, "") or dt in (None, ""):
        continue

    if isinstance(dt, datetime):
        d = dt.date()
    elif isinstance(dt, date):
        d = dt
    else:
        # If a non-date slips in, keep as string
        d = dt

    key = d.isoformat() if isinstance(d, date) else str(d)
    if key not in seen_per_material[mat]:
        seen_per_material[mat].add(key)
        material_to_dates[mat].append(d)

def fmt_joined(vals):
    out = []
    for v in vals:
        if isinstance(v, date):
            out.append(v.strftime("%d/%m/%Y"))
        else:
            out.append(str(v).strip())
    return ",".join(out)

# Print current targets before modification
print("Before modification:")
for r in range(2, ws.max_row + 1):
    print(f"I{r} raw={ws.cell(r, 9).value!r}")

# Write values directly into existing Column I cells
written = {}
for r in range(2, ws.max_row + 1):
    mat = ws.cell(r, 1).value
    joined = fmt_joined(material_to_dates.get(mat, []))
    ws.cell(r, 9).value = joined
    written[r] = joined

print("\nPlanned written values:")
for r, val in written.items():
    print(f"I{r}={val!r}")

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # Rename sheets back by position
    for idx, orig_name in enumerate(orig_sheet_names):
        wb2.worksheets[idx].title = orig_name
    wb2.save(outfile)
    print("Renamed sheets back to original:", orig_sheet_names)

# Verify after recalculation using data_only=True
verify_wb = load_workbook(outfile, data_only=True)
print("\nVerification sheet names:", verify_wb.sheetnames)
vws = verify_wb["Volym P5_P6_2023"]

print("Verified target cells I2:I10:")
for r in range(2, ws.max_row + 1):
    print(f"I{r}={vws.cell(r, 9).value!r}")

output_spreadsheet = outfile
