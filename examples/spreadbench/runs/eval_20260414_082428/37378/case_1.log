import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Inspect exact target cells before modifying
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Pre-write inspection of target cells A2:B6:")
for r in range(2, min(ws.max_row, 6) + 1):
    print(
        f"Row {r}: A{r} value={ws[f'A{r}'].value!r}, "
        f"B{r} value={ws[f'B{r}'].value!r}"
    )

# Determine true last relevant row from column B (last non-empty in B)
last_b_row = 1
for r in range(ws.max_row, 1, -1):
    v = ws[f"B{r}"].value
    if v is not None and str(v) != "":
        last_b_row = r
        break

print("Last relevant row in column B:", last_b_row)

# Write formulas in column A from row 2 through last relevant row
for r in range(2, last_b_row + 1):
    ws[f"A{r}"] = f'=IF(B{r}<>"",COUNTA($B$2:B{r}),"")'

# Leave rows below last relevant row untouched unless already blank; just inspect
print("Written formulas A2:A{0}:".format(last_b_row))
for r in range(2, last_b_row + 1):
    print(f"A{r} formula -> {ws[f'A{r}'].value}")

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for idx, name in enumerate(orig_sheet_names):
        wb_after.worksheets[idx].title = name
    wb_after.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify cached results
wb_verify = load_workbook(output_path, data_only=False)
wb_verify_vals = load_workbook(output_path, data_only=True)
wsf = wb_verify[orig_sheet_names[0]]
wsv = wb_verify_vals[orig_sheet_names[0]]

print("Verification of target cells:")
for r in range(2, last_b_row + 1):
    print(
        f"Row {r}: formula={wsf[f'A{r}'].value!r}, "
        f"cached_value={wsv[f'A{r}'].value!r}, "
        f"B{r}={wsv[f'B{r}'].value!r}"
    )

output_spreadsheet = output_path
```
