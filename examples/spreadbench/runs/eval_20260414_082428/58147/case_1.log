Code:
```repl
import os, shutil
from openpyxl import load_workbook

# Inspect evaluated values to confirm the exact extraction rule
wb_vals = load_workbook(input_spreadsheet, data_only=True)
wsv = wb_vals["Here"]

print("Evaluated values for Here!H:J rows 2:10")
for r in range(2, 11):
    print(r, "H=", wsv.cell(r,8).value, "| I=", wsv.cell(r,9).value, "| J=", wsv.cell(r,10).value)

# Build output path
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

# Write formulas into the existing target column J on sheet 'Here'
wb = load_workbook(outfile)
ws = wb["Here"]

print("\nPre-write check for J2:J10")
for r in range(2, 11):
    print(r, ws.cell(r,9).value, "=>", ws.cell(r,10).value)

# Robust extraction:
# - If I has two delimiters " - ", extract text between first and second.
# - Else if I has one delimiter, extract text before it.
# - Else return I as-is.
# Uses SUBSTITUTE+FIND, compatible with LibreOffice.
for r in range(2, ws.max_row + 1):
    formula = (
        f'=IF(I{r}="","",'
        f'IF(LEN(I{r})-LEN(SUBSTITUTE(I{r}," - ",""))=6,'
        f'MID(I{r},FIND(" - ",I{r})+3,FIND("♦",SUBSTITUTE(I{r}," - ","♦",2))-FIND(" - ",I{r})-3),'
        f'IFERROR(LEFT(I{r},FIND(" - ",I{r})-1),I{r})))'
    )
    ws.cell(r, 10).value = formula

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalc changed them
orig_names = load_workbook(input_spreadsheet).sheetnames
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_names and len(wb_after.sheetnames) == len(orig_names):
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_names)
    for i, s in enumerate(orig_names):
        wb_after.worksheets[i].title = s
    wb_after.save(outfile)

# Verify output values after recalculation
wb_verify = load_workbook(outfile, data_only=True)
print("\nVerified sheet names:", wb_verify.sheetnames)
wsv2 = wb_verify["Here"]

print("Verified Here!I:J rows 2:10")
for r in range(2, 11):
    print(r, "I=", wsv2.cell(r,9).value, "| J=", wsv2.cell(r,10).value)

# Also verify all non-empty I rows
nonempty_rows = [r for r in range(2, wsv2.max_row + 1) if wsv2.cell(r,9).value not in (None, "")]
print("\nNon-empty I rows and resulting J values:")
for r in nonempty_rows:
    print(r, "I=", wsv2.cell(r,9).value, "| J=", wsv2.cell(r,10).value)

output_spreadsheet = outfile
