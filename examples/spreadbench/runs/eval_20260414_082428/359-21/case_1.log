import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction preview:")
print(instruction[:1200])

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_summary(ws, max_sample_cols=20):
    print(f"\n=== Sheet: {ws.title} ===")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Detect non-empty rows/cols more realistically
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("first non-empty row:", nonempty_rows[0], "last non-empty row:", nonempty_rows[-1])
    
    # Print first 10 rows and last 5 rows, truncated to first max_sample_cols columns
    def row_vals(r):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_sample_cols) + 1)]
        return vals
    
    rows_to_show = []
    rows_to_show.extend(range(1, min(ws.max_row, 10) + 1))
    if ws.max_row > 10:
        rows_to_show.extend(range(max(1, ws.max_row - 4), ws.max_row + 1))
    
    seen = set()
    for r in rows_to_show:
        if r not in seen:
            seen.add(r)
            print(f"Row {r}: {row_vals(r)}")
    
    # Header candidates: first few non-empty rows
    print("Header candidates:")
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = row_vals(r)
        print(f"  row {r}: {vals}")
    
    # Print formulas if any in first 20x20 area
    formulas = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, min(ws.max_column, 20) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formulas in first 20x20 area:", formulas[:20], "count=", len(formulas))

for ws in wb.worksheets:
    sheet_summary(ws)

# Extra targeted inspection for sheet named Delete if present
if "Delete" in wb.sheetnames:
    ws = wb["Delete"]
    print("\nDetailed inspection of 'Delete' sheet:")
    # print columns A:Z for first 15 and last 10 rows
    sample_cols = min(ws.max_column, 26)
    headers = [ws.cell(1, c).value for c in range(1, sample_cols + 1)]
    print("Row1 headers/values A:Z:", headers)
    if ws.max_row >= 2:
        print("Row2 A:Z:", [ws.cell(2, c).value for c in range(1, sample_cols + 1)])
    for r in range(1, min(ws.max_row, 15) + 1):
        print(f"Delete row {r}:", [ws.cell(r, c).value for c in range(1, sample_cols + 1)])
    if ws.max_row > 15:
        for r in range(max(1, ws.max_row - 9), ws.max_row + 1):
            print(f"Delete row {r}:", [ws.cell(r, c).value for c in range(1, sample_cols + 1)])

# Save workbook object for next iteration
orig_sheetnames = wb.sheetnames[:]
print("\nDone initial inspection.")
