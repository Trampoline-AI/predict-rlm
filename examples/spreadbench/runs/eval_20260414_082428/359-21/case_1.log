import os
from openpyxl import load_workbook

# Reload clean workbook
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Delete"]

print("Before deletion:")
for r in range(1, ws.max_row + 1):
    print(r, ws.cell(r, 1).value, ws.cell(r, 2).value)

# Identify rows to delete based on column B values
targets = {"STATIONERY", "VEGETABLES"}
rows_to_delete = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(r, 2).value
    if val in targets:
        rows_to_delete.append(r)

print("Rows to delete:", rows_to_delete)

# Delete from bottom to top
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position to restore original names
    for i, expected in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = expected
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Delete"]

print("After deletion:")
final_rows = []
for r in range(1, wsv.max_row + 1):
    row_vals = [wsv.cell(r, 1).value, wsv.cell(r, 2).value]
    final_rows.append(row_vals)
    print(r, row_vals)

# Sanity checks
remaining_types = [wsv.cell(r, 2).value for r in range(2, wsv.max_row + 1)]
print("Remaining TYPE values:", remaining_types)
print("Any forbidden types remain?", any(v in targets for v in remaining_types))

output_spreadsheet = output_path
```
