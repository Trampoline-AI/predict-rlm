import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Inspect exact target and source values again
wb = load_workbook(infile)
ws = wb["AB"]
print("Target cell C14 current formula/value:", ws["C14"].value)
print("Source range C2:C13:")
for r in range(2, 14):
    print(f"C{r} =", ws[f"C{r}"].value)

# Replace broken formula with one that ignores errors
ws["C14"] = "=SUMPRODUCT(IFERROR(C2:C13,0))"

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
original_names = ["AB"]
if wb_after.sheetnames != original_names and len(wb_after.sheetnames) == len(original_names):
    for ws_tmp, orig in zip(wb_after.worksheets, original_names):
        ws_tmp.title = orig
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_names)

# Verify formula and evaluated result
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["AB"]
print("Final formula in C14:", ws_formula["C14"].value)

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["AB"]
print("Evaluated C14:", ws_values["C14"].value)

# Also sanity-check expected numeric total from non-error entries
total = 0
for r in range(2, 14):
    v = ws_values[f"C{r}"].value
    if isinstance(v, (int, float)):
        total += v
print("Sanity-check Python numeric sum of non-error cells:", total)
