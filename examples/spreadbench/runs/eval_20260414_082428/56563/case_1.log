import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook path:", path)
print("Sheet names:", wb.sheetnames)

def display(v):
    if v is None:
        return None
    return str(v)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Find likely header row among first 5 rows by non-empty count
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v is not None and v != "" for v in vals)
        print(f"Row {r} nonempty={nonempty} values={vals}")
    
    # Column headers guess = first non-empty row in first 5 rows
    header_row = None
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            header_row = r
            break
    if header_row:
        headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
        print("Guessed header row:", header_row, "headers:", headers)
    
    # First 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Scan formulas and error-like values
    formula_cells = []
    error_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
            if isinstance(v, str) and v.startswith("#"):
                error_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formula_cells[:20], "count=", len(formula_cells))
    print("Error-like cells:", error_cells[:20], "count=", len(error_cells))
```
