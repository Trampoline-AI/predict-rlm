import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)

print("Workbook:", input_path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 values / headers:", headers)
    
    # first 10 rows
    first_end = min(ws.max_row, 10)
    print(f"First rows 1-{first_end}:")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}-{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # specific cells
    for coord in ["I12", "J23"]:
        cell = ws[coord]
        print(f"{ws.title}!{coord} value:", cell.value, "data_type:", cell.data_type)
