```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh from input to avoid carrying over failed formulas
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws_data = wb["Data"]
ws_sum = wb["Summary"]

# Reconfirm source matches and target area
matches = []
for r in range(2, ws_data.max_row + 1):
    if ws_data.cell(r, 4).value == "Lowest Performing":
        matches.append((ws_data.cell(r, 2).value, ws_data.cell(r, 3).value))

print("Lowest Performing count:", len(matches))
print("Matches:", matches)

print("\nPre-write Summary B2:C20:")
for r in range(2, 21):
    print(r, ws_sum[f"B{r}"].value, ws_sum[f"C{r}"].value)

# Write results into existing Summary sheet, columns B:C starting row 3
start_row = 3
for i, (student_no, student_name) in enumerate(matches, start=start_row):
    ws_sum[f"B{i}"] = student_no
    ws_sum[f"C{i}"] = student_name

# Clear remaining rows in the visible target area below the results
clear_to = max(ws_sum.max_row, start_row + len(matches) + 10)
for r in range(start_row + len(matches), clear_to + 1):
    ws_sum[f"B{r}"] = None
    ws_sum[f"C{r}"] = None

wb.save(outfile)
print("\nSaved fallback value-based output to:", outfile)

# Recalculate anyway per requirement
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if changed
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for i, original_name in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = original_name
    wb_post.save(outfile)
    print("Restored sheet names:", original_sheetnames)

# Verify final output with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
ws_verify = wb_verify["Summary"]

print("\nVerified Summary B2:C20:")
verified = []
for r in range(2, 21):
    row_vals = (ws_verify[f"B{r}"].value, ws_verify[f"C{r}"].value)
    print(r, row_vals[0], row_vals[1])
    if r >= 3 and (row_vals[0] not in (None, "") or row_vals[1] not in (None, "")):
        verified.append(row_vals)

print("\nVerified populated count:", len(verified))
print("Expected count:", len(matches))
print("Verified matches exactly:", verified == matches)

output_spreadsheet = outfile
```
