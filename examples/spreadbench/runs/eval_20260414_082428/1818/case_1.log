        expected.append((ws_data_values.cell(r, 2).value, ws_data_values.cell(r, 3).value))

actual = []
for r in range(3, target_end_row + 1):
    b = ws_sum_values[f"B{r}"].value
    c = ws_sum_values[f"C{r}"].value
    if b not in (None, "") or c not in (None, ""):
        actual.append((b, c))

print("\nExpected lowest-performing students count:", len(expected))
print("Actual Summary populated count:", len(actual))
print("Expected first/last:", expected[:5], expected[-5:] if expected else [])
print("Actual first/last:", actual[:5], actual[-5:] if actual else [])

