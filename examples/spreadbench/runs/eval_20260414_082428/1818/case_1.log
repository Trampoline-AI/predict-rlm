import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and remember original sheet names
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws_data = wb["Data"]
ws_sum = wb["Summary"]

print("Original sheet names:", original_sheetnames)
print("Data max_row/max_col:", ws_data.max_row, ws_data.max_column)
print("Summary max_row/max_col before write:", ws_sum.max_row, ws_sum.max_column)

# Verify exact target cells before writing
print("Pre-write Summary B2:C20:")
for r in range(2, 21):
    print(r, ws_sum[f"B{r}"].value, ws_sum[f"C{r}"].value)

# Build Excel 2013-compatible formulas (non-dynamic-array)
data_last_row = ws_data.max_row
target_start_row = 3
target_end_row = data_last_row + 1  # enough rows to return all matches and blanks after

for r in range(target_start_row, target_end_row + 1):
    # nth match is determined by ROWS($B$3:B3), etc.
    ws_sum[f"B{r}"] = (
        f'=IFERROR(INDEX(Data!$B$2:$B${data_last_row},'
        f'AGGREGATE(15,6,(ROW(Data!$D$2:$D${data_last_row})-ROW(Data!$D$2)+1)/'
        f'(Data!$D$2:$D${data_last_row}="Lowest Performing"),ROWS(B$3:B{r}))),"")'
    )
    ws_sum[f"C{r}"] = (
        f'=IFERROR(INDEX(Data!$C$2:$C${data_last_row},'
        f'AGGREGATE(15,6,(ROW(Data!$D$2:$D${data_last_row})-ROW(Data!$D$2)+1)/'
        f'(Data!$D$2:$D${data_last_row}="Lowest Performing"),ROWS(C$3:C{r}))),"")'
    )

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for i, original_name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = original_name
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas exist in target cells
wb_formula = load_workbook(outfile, data_only=False)
ws_sum_formula = wb_formula["Summary"]
print("\nFormula check Summary B3:C10:")
for r in range(3, 11):
    print(r, ws_sum_formula[f"B{r}"].value, " | ", ws_sum_formula[f"C{r}"].value)

# Verify calculated values
wb_values = load_workbook(outfile, data_only=True)
ws_sum_values = wb_values["Summary"]
ws_data_values = wb_values["Data"]

print("\nCalculated Summary values B2:C25:")
for r in range(2, 26):
    print(r, ws_sum_values[f"B{r}"].value, ws_sum_values[f"C{r}"].value)

# Build expected list from input data for sanity-check
expected = []
for r in range(2, ws_data_values.max_row + 1):
