import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def sheet_headers(ws, max_cols=None):
    mc = ws.max_column if max_cols is None else min(ws.max_column, max_cols)
    return [ws.cell(1, c).value for c in range(1, mc+1)]

def row_values(ws, r, max_cols=None):
    mc = ws.max_column if max_cols is None else min(ws.max_column, max_cols)
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    headers = sheet_headers(ws, max_cols=ws.max_column)
    print("Headers row 1:", headers)
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end+1):
        print(r, row_values(ws, r))
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r))

# Inspect formulas/non-empty cells in Summary-like sheets or all sheets if small
for s in wb.sheetnames:
    ws = wb[s]
    formula_cells = []
    nonempty = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                nonempty += 1
                if isinstance(cell.value, str) and cell.value.startswith("="):
                    formula_cells.append((cell.coordinate, cell.value))
    print(f"\nSheet {s}: nonempty={nonempty}, formula_count={len(formula_cells)}")
    if formula_cells[:20]:
        print("Sample formulas:", formula_cells[:20])

# If there is a Summary sheet, inspect used range more explicitly
for s in wb.sheetnames:
    if "summary" in s.lower():
        ws = wb[s]
        print(f"\nDetailed Summary inspection for {s}")
        for r in range(1, min(ws.max_row, 20)+1):
            vals = row_values(ws, r)
            print(r, vals)
