```repl
import os, re, shutil
from openpyxl import load_workbook

# Load fresh workbook
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
out = wb["OUT CAS"]

source_sheets = [s for s in wb.sheetnames if s != "OUT CAS"]

# Determine bucket mapping from OUT CAS headers so we write to exact intended columns
bucket_layout = {
    "PUR PURCHASE": (1, 2, 3),   # item, ref, amount
    "PUR PAID": (5, 6, 7),
    "CASH SS": (9, 10, 11),
    "EXPRR": (13, 14, 15),
}
print("Bucket layout:", bucket_layout)

def infer_bucket(ref):
    if ref is None:
        return None
    s = str(ref).strip()
    if s.startswith("PUR PURCHASE"):
        return "PUR PURCHASE"
    if s.startswith("PUR PAID"):
        return "PUR PAID"
    if s.startswith("CASH SS"):
        return "CASH SS"
    if s.startswith("EXPRR"):
        return "EXPRR"
    return None

def amount_from_row(ws, r):
    debit = ws.cell(r, 3).value
    credit = ws.cell(r, 4).value
    return credit if credit not in (None, "") else debit

def sort_key(ref):
    s = str(ref).strip()
    # Prefer trailing numeric part in final token, keeping prefix letters for EX009-style cases
    tokens = s.split()
    last = tokens[-1] if tokens else s
    m = re.match(r"([A-Za-z]*)(\d+)$", last)
    if m:
        prefix, num = m.groups()
        return (prefix, int(num), s)
    # fallback: last number anywhere
    nums = re.findall(r"(\d+)", s)
    if nums:
        return ("", int(nums[-1]), s)
    return ("", float("inf"), s)

# Collect rows from the 3 source sheets
bucket_rows = {k: [] for k in bucket_layout}
unmatched = []
for s in source_sheets:
    ws = wb[s]
    for r in range(2, ws.max_row + 1):
        ref = ws.cell(r, 2).value
        if ref in (None, ""):
            continue
        bucket = infer_bucket(ref)
        amt = amount_from_row(ws, r)
        rec = {
            "sheet": s,
            "row": r,
            "ref": str(ref).strip(),
            "amount": amt
        }
        if bucket is None:
            unmatched.append(rec)
        else:
            bucket_rows[bucket].append(rec)

print("Counts by bucket from source sheets:", {k: len(v) for k, v in bucket_rows.items()})
print("Unmatched rows count:", len(unmatched))
if unmatched[:10]:
    print("Unmatched sample:", unmatched[:10])

# Sort rows in each bucket
for bucket in bucket_rows:
    bucket_rows[bucket] = sorted(bucket_rows[bucket], key=lambda x: sort_key(x["ref"]))

# Print samples before writing
for bucket in bucket_rows:
    rows = bucket_rows[bucket]
    print(f"\n{bucket}: count={len(rows)}")
    print(" first 5:", [(x["ref"], x["amount"], x["sheet"], x["row"]) for x in rows[:5]])
    print(" last 5:", [(x["ref"], x["amount"], x["sheet"], x["row"]) for x in rows[-5:]])

# Clear existing OUT CAS data below headers in target columns only
for bucket, (c_item, c_ref, c_amt) in bucket_layout.items():
    for r in range(2, out.max_row + 1):
        out.cell(r, c_item).value = None
        out.cell(r, c_ref).value = None
        out.cell(r, c_amt).value = None

# Rebuild each table
for bucket, (c_item, c_ref, c_amt) in bucket_layout.items():
    rows = bucket_rows[bucket]
    start_row = 2
    for i, rec in enumerate(rows, start=1):
        rr = start_row + i - 1
        out.cell(rr, c_item).value = i
        out.cell(rr, c_ref).value = rec["ref"]
        out.cell(rr, c_amt).value = rec["amount"]
    total_row = start_row + len(rows)
    out.cell(total_row, c_item).value = "TOTAL"
    if len(rows) > 0:
        out.cell(total_row, c_amt).value = f"=SUM({out.cell(start_row, c_amt).coordinate}:{out.cell(total_row-1, c_amt).coordinate})"
    else:
        out.cell(total_row, c_amt).value = 0

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalculation changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    for idx, expected_name in enumerate(orig_sheetnames):
        if idx < len(wb_after.worksheets):
            wb_after.worksheets[idx].title = expected_name
    wb_after.save(output_path)

# Verify with formulas and data_only views
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
out_f = wb_formula["OUT CAS"]
out_v = wb_values["OUT CAS"]

print("\nVerification on OUT CAS:")
for bucket, (c_item, c_ref, c_amt) in bucket_layout.items():
    rows = bucket_rows[bucket]
    total_row = 2 + len(rows)
    print(f"\nBucket {bucket}")
    # first 5 rows
    for rr in list(range(2, min(6, 2 + len(rows)))) + ([] if len(rows) < 5 else []):
        print(" row", rr, [out_v.cell(rr, c).value for c in (c_item, c_ref, c_amt)])
    # last 5 data rows
    start_last = max(2, 1 + len(rows) - 3)
    for rr in range(start_last, 2 + len(rows)):
        print(" tail", rr, [out_v.cell(rr, c).value for c in (c_item, c_ref, c_amt)])
    print(" total label/value/formula:", 
          out_v.cell(total_row, c_item).value,
          out_v.cell(total_row, c_amt).value,
          out_f.cell(total_row, c_amt).value)

# Additional exact-target checks
checks = {
    "B2": out_v["B2"].value, "C2": out_v["C2"].value,
    "F2": out_v["F2"].value, "G2": out_v["G2"].value,
    "J2": out_v["J2"].value, "K2": out_v["K2"].value,
    "N2": out_v["N2"].value, "O2": out_v["O2"].value,
}
print("\nKey target cells:", checks)

# Keep output path in variable for submission
final_output_path = output_path
print("\nReady to submit:", final_output_path)
```
