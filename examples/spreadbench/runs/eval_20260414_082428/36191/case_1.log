infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify target area before writing
print("Before write:")
for r in range(1, ws.max_row + 1):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value)

# Write amended formula into the existing target column C ("Result Should Be")
# Preserve any already-populated correct-looking cells such as C2.
for r in range(2, ws.max_row + 1):
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    if isinstance(b, str) and b.strip():
        if c is None or str(c).strip() == "":
            ws[f"C{r}"] = f'=LEFT(B{r},FIND(" ",B{r},FIND(" ",B{r})+1)-1)'

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheet_names)
    for i, old_name in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = old_name
    wb2.save(outfile)

# Verify formulas and evaluated results
