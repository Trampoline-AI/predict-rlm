import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find non-empty rows/cols more accurately
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                nonempty_cols.add(c)
        if row_has:
            nonempty_rows.append(r)
    print("Non-empty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("Non-empty cols:", [f"{get_column_letter(c)}" for c in sorted(nonempty_cols)])
    
    # Print first several rows in full used width
    max_used_col = max(nonempty_cols) if nonempty_cols else ws.max_column
    print("\nFirst 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_used_col + 1)]
        print(f"Row {r}: {vals}")
    
    print("\nLast 5 rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_used_col + 1)]
        print(f"Row {r}: {vals}")
    
    # Header candidates
    print("\nPotential header rows (first 5):")
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_used_col + 1)]
        print(f"Header candidate row {r}: {vals}")
    
    # Print formulas if any in first 20 rows
    formulas = []
    for r in range(1, min(ws.max_row, 25) + 1):
        for c in range(1, max_used_col + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print(f"\nFormulas found in first 25 rows: {len(formulas)}")
    for r, c, v in formulas[:20]:
        print(f"{get_column_letter(c)}{r} = {v}")

for ws in wb.worksheets:
    sheet_summary(ws)
