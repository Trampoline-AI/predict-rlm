import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
filename = os.path.basename(input_path)
output_path = os.path.join(output_dir, filename)

# Load workbook normally (with formulas)
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Summary"]
src = wb["Sheet1"]

# Confirm current target cells before writing
print("Current target formulas/values before modification:")
for r in range(2, 7):
    print(
        r,
        {
            "A": ws[f"A{r}"].value,
            "B": ws[f"B{r}"].value,
            "C": ws[f"C{r}"].value,
            "F": ws[f"F{r}"].value,
        },
    )

last_row = src.max_row  # bounded actual data range

# Write corrected formulas into the existing target cells B2:C6
for r in range(2, 7):
    for c in (2, 3):  # B and C
        col_letter = get_column_letter(c)
        header_ref = f"Summary!${col_letter}$1"
        name_ref = f"Summary!$A{r}"
        status_ref = f"Summary!$F{r}"
        formula = (
            f'=IF({status_ref}="Both",'
            f'SUM('
            f'SUMIFS(Sheet1!$D$2:$D${last_row},Sheet1!$B$2:$B${last_row},{name_ref},Sheet1!$C$2:$C${last_row},{header_ref},Sheet1!$A$2:$A${last_row},"Completed"),'
            f'SUMIFS(Sheet1!$D$2:$D${last_row},Sheet1!$B$2:$B${last_row},{name_ref},Sheet1!$C$2:$C${last_row},{header_ref},Sheet1!$A$2:$A${last_row},"Not Completed")'
            f'),'
            f'IF(OR({status_ref}="Completed",{status_ref}="Not Completed"),'
            f'SUMIFS(Sheet1!$D$2:$D${last_row},Sheet1!$B$2:$B${last_row},{name_ref},Sheet1!$C$2:$C${last_row},{header_ref},Sheet1!$A$2:$A${last_row},{status_ref}),'
            f'0))'
        )
        ws.cell(r, c).value = formula

print("\nFormulas after modification:")
for r in range(2, 7):
    print(f"Row {r}: B{r}={ws[f'B{r}'].value}")
    print(f"        C{r}={ws[f'C{r}'].value}")

# Save workbook
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and ensure sheet names still match original
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # rename in order back to originals if lengths match
    if len(wb_after.sheetnames) == len(orig_sheet_names):
        for i, orig_name in enumerate(orig_sheet_names):
            wb_after.worksheets[i].title = orig_name
        wb_after.save(output_path)
        print("Renamed sheets back to:", orig_sheet_names)
    else:
        print("Unexpected sheet count; not renaming.")
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verification with data_only=True
wb_val = load_workbook(output_path, data_only=True)
ws_val = wb_val["Summary"]

print("\nVerified cached values in target cells:")
for r in range(2, 7):
    vals = {
        "Name": ws_val[f"A{r}"].value,
        "Status": ws_val[f"F{r}"].value,
        "HD(B)": ws_val[f"B{r}"].value,
        "SD(C)": ws_val[f"C{r}"].value,
    }
    print(f"Row {r}: {vals}")

# Also reload formulas for explicit verification
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Summary"]
print("\nVerified stored formulas in target cells:")
for r in range(2, 7):
    print(f"B{r}: {ws_formula[f'B{r}'].value}")
    print(f"C{r}: {ws_formula[f'C{r}'].value}")

final_output_path = output_path
