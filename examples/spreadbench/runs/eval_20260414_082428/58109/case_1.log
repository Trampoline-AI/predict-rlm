```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original input fresh
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Current target cells before rewrite:")
print("I4:", ws["I4"].value)
print("I6 existing:", ws["I6"].value)

# Determine actual data extent in A/B
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_data_row = r
        break
print("Detected last data row:", last_data_row)

# Try a simpler bounded formula
candidate_formula = f'=SUM(OFFSET(B2,COUNTIF(A2:A{last_data_row},"<="&I4)-4,0,4,1))'
ws["I6"] = candidate_formula
print("Candidate formula written to I6:", ws["I6"].value)

wb.save(output_path)
print("Saved:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Restore sheet names if changed
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    for i, expected in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = expected
    wb_post.save(output_path)
    print("Restored sheet names:", orig_sheetnames)

# Verify
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification after candidate formula:")
print("I6 formula cell:", ws_formula["I6"].value)
print("I6 cached value:", ws_values["I6"].value)

# Python sanity check
target_date = ws_values["I4"].value
matching_rows = []
for r in range(2, last_data_row + 1):
    d = ws_values.cell(r, 1).value
    v = ws_values.cell(r, 2).value
    if d is not None and d <= target_date:
        matching_rows.append((r, d, v))
last4 = matching_rows[-4:]
py_sum = sum(v for _, _, v in last4)
print("Last 4 workday rows:", last4)
print("Python expected sum:", py_sum)

# If formula still didn't verify, write literal fallback
if ws_values["I6"].value in (None, 0) and py_sum != ws_values["I6"].value:
    print("Formula verification failed; applying literal fallback.")
    wb_fix = load_workbook(output_path)
    ws_fix = wb_fix["Sheet1"]
    ws_fix["I6"] = py_sum
    wb_fix.save(output_path)

    # Re-open to verify fallback
    wb_formula2 = load_workbook(output_path, data_only=False)
    ws_formula2 = wb_formula2["Sheet1"]
    wb_values2 = load_workbook(output_path, data_only=True)
    ws_values2 = wb_values2["Sheet1"]
    print("Fallback I6 stored value (formula view):", ws_formula2["I6"].value)
    print("Fallback I6 stored value (data_only):", ws_values2["I6"].value)

final_output_spreadsheet = output_path
