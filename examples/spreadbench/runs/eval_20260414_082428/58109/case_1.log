import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print current relevant values before modifying
print("Before change:")
print("I4:", ws["I4"].value)
print("I6 formula:", ws["I6"].value)

# Use a dynamic formula based on the matched row for I4 in column A.
# Since the dataset has no weekend entries, summing the matched row and prior 3 rows
# correctly returns the last four workdays up to and including I4.
new_formula = "=SUM(INDEX(B:B,MATCH(I4,A:A,0)-3):INDEX(B:B,MATCH(I4,A:A,0)))"
ws["I6"] = new_formula

print("New I6 formula:", ws["I6"].value)

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # Rename sheets back by position
    for i, expected in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected
    wb_after.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and cached values
