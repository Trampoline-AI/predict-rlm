target_date = ws_values["I4"].value
match_row = None
for r in range(2, ws_values.max_row + 1):
    if ws_values.cell(r, 1).value == target_date:
        match_row = r
        break

print("Matched row for I4 in column A:", match_row)
if match_row:
    rows_used = list(range(match_row - 3, match_row + 1))
    print("Rows used for 4 workday sum:", rows_used)
    vals = [(r, ws_values.cell(r, 1).value, ws_values.cell(r, 2).value) for r in rows_used]
