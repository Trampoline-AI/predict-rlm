import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for editing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect exact target area before writing
print("Before writing, B3:E16:")
for r in range(3, 17):
    vals = [ws.cell(r, c).value for c in range(2, 6)]
    print(r, vals)

# Write formulas in E for all actual data rows (rows with serial/date/weight)
start_row = 4
end_row = ws.max_row
for r in range(start_row, end_row + 1):
    serial = ws[f"B{r}"].value
    date_val = ws[f"C{r}"].value
    weight = ws[f"D{r}"].value
    # only write where there's an actual data row
    if serial is not None and date_val is not None and weight is not None:
        formula = f'=IF(COUNTIF($B$4:B{r},{ "B"+str(r) })=1,0,LOOKUP(2,1/($B$4:B{r-1}=B{r}),$D$4:D{r-1})-D{r})'
        ws[f"E{r}"] = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc; if sheet names changed, rename back
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename by position to original names
    for i, orig_name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = orig_name
    wb2.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verification with formulas visible
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nFormulas now in E4:E16:")
for r in range(4, 17):
    print(f"E{r}:", wsf[f"E{r}"].value)

# Verification with computed values
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Sheet1"]
print("\nComputed values B3:E16 after recalc:")
for r in range(3, 17):
    vals = [wsv.cell(r, c).value for c in range(2, 6)]
    print(r, vals)

# Store for submit
final_output_path = output_path
