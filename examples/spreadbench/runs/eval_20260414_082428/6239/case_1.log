import os, json, textwrap, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

print("INPUT FILE:", input_spreadsheet)
print("INSTRUCTION:\n", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("\nSHEETS:", orig_sheet_names)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # Determine non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty_row_count:", len(nonempty_rows), 
          "first_nonempty_row:", (nonempty_rows[0] if nonempty_rows else None),
          "last_nonempty_row:", (nonempty_rows[-1] if nonempty_rows else None))
    # Print first 10 rows and last 5 nonempty rows
    sample_rows = []
    if nonempty_rows:
        sample_rows.extend(nonempty_rows[:10])
        for r in nonempty_rows[-5:]:
            if r not in sample_rows:
                sample_rows.append(r)
    for r in sample_rows:
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    # headers from first few rows
    for hr in range(1, min(4, ws.max_row) + 1):
        print(f"Potential header row {hr}:", [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)])

for ws in wb.worksheets:
    sheet_info(ws)

# Also inspect formulas if present in used range
for ws in wb.worksheets:
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print(f"\nFormulas in {ws.title}: count={len(formulas)}")
    for item in formulas[:20]:
        r, c, v = item
        print(f"  {get_column_letter(c)}{r} = {v}")
