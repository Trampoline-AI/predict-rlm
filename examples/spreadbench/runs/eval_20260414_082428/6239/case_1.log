import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Load original workbook
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Writing formulas to target range G2:G23")
print("Current header G1:", ws["G1"].value)
print("Current sample target cells before write:", {f"G{r}": ws[f"G{r}"].value for r in range(2, 8)})

# Determine actual employee rows with data in A:F
target_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    if any(v is not None and v != "" for v in vals):
        target_rows.append(r)

print("Target rows:", target_rows)

# Formula:
# If not eligible / negative variance => 0
# else return payout based on:
#   goal bucket (D vs J2:M2),
#   variance row determined within selected goal column (E vs selected col in J3:M6),
#   metric2 bucket (F vs P2:T2)
for r in target_rows:
    formula = (
        f'=IF(OR(E{r}<0,B{r}="Not Eligible"),0,'
        f'INDEX($P$3:$T$6,'
        f'MATCH(E{r},INDEX($J$3:$M$6,0,MATCH(D{r},$J$2:$M$2,1)),1),'
        f'MATCH(F{r},$P$2:$T$2,1)'
        f'))'
    )
    ws[f"G{r}"] = formula
    ws[f"G{r}"].number_format = "0%"

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    print("Restoring original sheet names...")
    for i, name in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification of target cells G2:G23:")
verification = []
for r in target_rows:
    f = ws_formula[f"G{r}"].value
    v = ws_values[f"G{r}"].value
    verification.append((r, ws_values[f"A{r}"].value, ws_values[f"B{r}"].value, ws_values[f"D{r}"].value, ws_values[f"E{r}"].value, ws_values[f"F{r}"].value, v))
    print(f"G{r}: formula={f} | value={v}")

# Sanity-check blanks/errors
blanks = [r for r in target_rows if ws_values[f"G{r}"].value in (None, "")]
print("Blank target rows after recalc:", blanks)

# Print a compact summary of outputs
print("\nOutput summary:")
for item in verification:
    print(item)

output_spreadsheet = outfile
