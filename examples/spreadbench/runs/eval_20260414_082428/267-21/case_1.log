from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, textwrap

print("INSTRUCTION:")
print(instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # gather non-empty row/col bounds a bit more robustly
    rows = list(ws.iter_rows(values_only=True))
    nonempty_rows = [i+1 for i,r in enumerate(rows) if any(v is not None and v != "" for v in r)]
    print("non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[0], nonempty_rows[-1]) if nonempty_rows else None)

    # print first 10 rows and last 5 rows with column letters
    def row_repr(idx):
        vals = [ws.cell(idx, c).value for c in range(1, ws.max_column+1)]
        return {get_column_letter(c): vals[c-1] for c in range(1, ws.max_column+1)}
    first_rows = list(range(1, min(ws.max_row, 10)+1))
    last_rows = list(range(max(1, ws.max_row-4), ws.max_row+1))
    print("First rows:")
    for r in first_rows:
        print(r, row_repr(r))
    if last_rows[0] > first_rows[-1]:
        print("Last rows:")
        for r in last_rows:
            print(r, row_repr(r))

for ws in wb.worksheets:
    sheet_info(ws)
