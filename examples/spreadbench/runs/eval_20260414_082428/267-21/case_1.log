from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
import os, shutil

# Reload and inspect target cells more explicitly
wb = load_workbook(input_spreadsheet)
ws = wb["merging"]

print("Target sheet:", ws.title)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Column C index:", column_index_from_string("C"), "Column D index:", column_index_from_string("D"))

for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"row {r}: {vals}")

print("\nExisting formulas/values in target range C:D:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"C{r}"].value, ws[f"D{r}"].value)

# Determine source ranges
sh1 = wb["SH1"]
rp1 = wb["RP1"]
sh1_last = sh1.max_row
rp1_last = rp1.max_row

# Write formulas into merging C and D for all non-empty ID rows
for r in range(2, ws.max_row + 1):
    id_val = ws[f"B{r}"].value
    if id_val is None or str(id_val).strip() == "":
        # keep empty rows empty
        continue
    ws[f"C{r}"] = f'=IFERROR(VLOOKUP(B{r},SH1!$B$2:$C${sh1_last},2,FALSE),"-")'
    ws[f"D{r}"] = f'=IFERROR(VLOOKUP(B{r},RP1!$B$2:$C${rp1_last},2,FALSE),"-")'

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc and restore if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
original_names = ['SH1', 'RP1', 'merging']
if wb_after.sheetnames != original_names:
    for i, expected in enumerate(original_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(out_path)
    print("Renamed sheets back to original names:", wb_after.sheetnames)

# Verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver["merging"]
print("\nVerified target values in merging!C:D:")
for r in range(2, vws.max_row + 1):
    print(r, vws[f"B{r}"].value, vws[f"C{r}"].value, vws[f"D{r}"].value)

# Also print formulas from normal load for a few rows
wb_formula = load_workbook(out_path, data_only=False)
fws = wb_formula["merging"]
print("\nFormulas written:")
for r in range(2, fws.max_row + 1):
    print(r, fws[f"C{r}"].value, " | ", fws[f"D{r}"].value)

output_spreadsheet = out_path
```
