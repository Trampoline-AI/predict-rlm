import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload for clean edit pass
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect the exact region and duplicate rows in Column A
print("Sheet:", ws.title)
print("Dimensions:", ws.dimensions)
for r in range(2, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"R{r}: {row_vals}")

seen = {}
dup_rows = []
for r in range(3, ws.max_row + 1):  # data starts at row 3; row 17 is blank
    a = ws.cell(r, 1).value
    if a in (None, ""):
        continue
    if a in seen:
        dup_rows.append((r, a, seen[a]))
    else:
        seen[a] = r

print("Duplicate rows based on Column A:", dup_rows)

# Delete duplicate rows based only on Column A, keeping first occurrence
rows_to_delete = []
seen = set()
for r in range(3, ws.max_row + 1):
    a = ws.cell(r, 1).value
    if a in (None, ""):
        continue
    if a in seen:
        rows_to_delete.append(r)
    else:
        seen.add(a)

print("Rows to delete:", rows_to_delete)

for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    for i, name in enumerate(orig_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with values
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[orig_sheet_names[0]]

print("Verified sheet names:", wb_verify.sheetnames)
print("Verified dimensions:", wsv.dimensions, "max_row:", wsv.max_row, "max_col:", wsv.max_column)

verified_rows = []
for r in range(2, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    verified_rows.append((r, vals))
    print(f"VR{r}: {vals}")

colA_vals = [wsv.cell(r, 1).value for r in range(3, wsv.max_row + 1) if wsv.cell(r, 1).value not in (None, "")]
print("Verified Column A values:", colA_vals)
print("Unique count:", len(set(colA_vals)), "Total nonblank count:", len(colA_vals))

output_spreadsheet = output_path
