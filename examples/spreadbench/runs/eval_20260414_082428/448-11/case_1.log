import os, json, math, statistics
from collections import Counter, defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def sheet_info(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", ws.dimensions, "max_row:", max_row, "max_col:", max_col)
    print("Headers row 1:", headers)
    
    # first 10 rows
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(f"R{r}:", vals)
    
    # last 5 rows
    start_last = max(1, max_row - 4)
    print(f"Last {max_row - start_last + 1} rows:")
    for r in range(start_last, max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(f"R{r}:", vals)

    # inspect formulas in first few rows / all columns
    formulas = []
    for r in range(1, min(max_row, 20) + 1):
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formula cells found in first 20 rows:", formulas[:20], "count:", len(formulas))
    
    # duplicates in column A
    colA = [ws.cell(r, 1).value for r in range(1, max_row + 1)]
    counts = Counter(v for v in colA if v not in (None, ""))
    dupes = [(k, v) for k, v in counts.items() if v > 1]
    print("Duplicate values in Column A (up to 20):", dupes[:20], "total distinct dupes:", len(dupes))

for ws in wb.worksheets:
    sheet_info(ws)
