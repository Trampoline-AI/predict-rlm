import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Students"]

print("Before writing, target header E1:", ws["E1"].value)
for r in range(2, ws.max_row + 1):
    print(f"Pre-write A{r}={ws[f'A{r}'].value!r}, E{r}={ws[f'E{r}'].value!r}")

# Write dynamic formula in Students!E for all rows with a student name in col A
written_rows = []
for r in range(2, ws.max_row + 1):
    name = ws.cell(r, 1).value
    if name not in (None, ""):
        formula = f'=INDIRECT("\'"&A{r}&"\'!C2")'
        ws.cell(r, 5).value = formula
        written_rows.append((r, name, formula))

print("\nWritten formulas:")
for item in written_rows:
    print(item)

# Save output
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename by position back to originals
    for i, old_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)
    print("Renamed sheets back to originals:", orig_sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Students"]
print("\nFormula verification Students!A:E rows 1:7")
for r in range(1, ws_formula.max_row + 1):
    print(r, [ws_formula.cell(r, c).value for c in range(1, 6)])

# Verify cached/calculated results
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Students"]
print("\nCalculated values in target cells E2:E7:")
for r in range(2, ws_values.max_row + 1):
    print(f"A{r}={ws_values[f'A{r}'].value!r}, E{r}={ws_values[f'E{r}'].value!r}")

output_spreadsheet = outfile
