def sheet_info(ws, sample_first=10, sample_last=5, max_cols_preview=None):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers/values:", headers)
    # determine non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    rows_to_show = []
    rows_to_show.extend(nonempty_rows[:sample_first])
    for r in nonempty_rows[-sample_last:]:
        if r not in rows_to_show:
            rows_to_show.append(r)
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    # print formulas present in first 20 rows if any
    formulas = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    if formulas:
        print("Formulas in first 20 rows:", formulas[:20])
    else:
        print("No formulas in first 20 rows.")

for ws in wb.worksheets:
