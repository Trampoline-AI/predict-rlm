import os
from collections import Counter
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
ws3 = wb["Sheet3"]
ws4 = wb["Sheet4"]

def get_internal_rows(ws, start_row=9, end_col=7):
    rows = []
    for r in range(start_row, ws.max_row + 1):
        vals = tuple(ws.cell(r, c).value for c in range(1, end_col + 1))
        if any(v is not None and v != "" for v in vals):
            rows.append(vals)
    return rows

rows1 = get_internal_rows(ws1)
rows2 = get_internal_rows(ws2)

c1 = Counter(rows1)
c2 = Counter(rows2)

removed_counter = c1 - c2
added_counter = c2 - c1

# preserve source order, but output unique rows only
removed_unique = []
seen = set()
for vals in rows1:
    if removed_counter[vals] > 0 and vals not in seen:
        removed_unique.append(vals)
        seen.add(vals)

added_unique = []
seen = set()
for vals in rows2:
    if added_counter[vals] > 0 and vals not in seen:
        added_unique.append(vals)
        seen.add(vals)

print("Removed unique rows to write to Sheet3:", len(removed_unique))
for row in removed_unique:
    print("Sheet3 row:", row)

print("Added unique rows to write to Sheet4:", len(added_unique))
for row in added_unique:
    print("Sheet4 row:", row)

# Clear existing output areas in Sheet3 and Sheet4 across current used area (at least A:G)
for ws in (ws3, ws4):
    max_rows_to_clear = max(ws.max_row, 1)
    max_cols_to_clear = max(ws.max_column, 7)
    for r in range(1, max_rows_to_clear + 1):
        for c in range(1, max_cols_to_clear + 1):
            ws.cell(r, c).value = None

# Write outputs starting at row 1, no headers
for out_r, vals in enumerate(removed_unique, start=1):
    for c, v in enumerate(vals, start=1):
        ws3.cell(out_r, c).value = v

for out_r, vals in enumerate(added_unique, start=1):
    for c, v in enumerate(vals, start=1):
        ws4.cell(out_r, c).value = v

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and repair sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed; restoring original names")
    for ws, orig_name in zip(wb_after.worksheets, orig_sheetnames):
        ws.title = orig_name
    wb_after.save(output_path)
    wb_after = load_workbook(output_path)

print("Final sheet names:", wb_after.sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

for sname in ["Sheet3", "Sheet4"]:
    ws = wb_verify[sname]
    print(f"\nVerification for {sname}: max_row={ws.max_row}, max_column={ws.max_column}")
    # print first 10 rows across A:G
    for r in range(1, min(10, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, 8)]
        print(f"{sname} row {r}:", vals)

# Store for submit
final_output_path = output_path
