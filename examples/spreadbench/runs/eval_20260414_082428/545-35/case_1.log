import os, json, textwrap, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction full text:\n", instruction)

path = input_spreadsheet
print("Input path:", path, "exists:", os.path.exists(path))

wb = load_workbook(path)
orig_sheetnames = wb.sheetnames
print("Original sheet names:", orig_sheetnames)

def visible_value(v):
    try:
        if hasattr(v, "text"):
            return f"<{type(v).__name__}: {v.text}>"
    except Exception:
        pass
    return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    headers = [visible_value(ws.cell(1, c).value) for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = [visible_value(ws.cell(2, c).value) for c in range(1, ws.max_column + 1)]
        print("Row 2 values:", row2)
    # first up to 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [visible_value(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"R{r}: {vals}")
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [visible_value(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"R{r}: {vals}")
    # formulas in used range
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            val = cell.value
            if isinstance(val, str) and val.startswith("="):
                formulas.append((cell.coordinate, val))
            elif hasattr(val, "text"):
                formulas.append((cell.coordinate, f"<{type(val).__name__}: {val.text}>"))
    print("Formula cells found (up to 20):", formulas[:20], "count:", len(formulas))
