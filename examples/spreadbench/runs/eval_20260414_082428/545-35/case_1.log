Code:
```repl
import os, re, shutil
from openpyxl import load_workbook

# Reload clean workbook
infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb["Data"]

target_min_row, target_max_row = 3, 20
target_min_col, target_max_col = 21, 35  # U:AI

numeric_like = []
non_numeric_like = []

pure_numeric_pattern = re.compile(r'^\d+$')

for r in range(target_min_row, target_max_row + 1):
    for c in range(target_min_col, target_max_col + 1):
        cell = ws.cell(r, c)
        v = cell.value
        if isinstance(v, (int, float)) and not isinstance(v, bool):
            numeric_like.append((cell.coordinate, v, type(v).__name__))
        elif isinstance(v, str) and pure_numeric_pattern.fullmatch(v.strip() if v is not None else ""):
            numeric_like.append((cell.coordinate, v, "numeric_string"))
        else:
            non_numeric_like.append((cell.coordinate, v, type(v).__name__))

print("Target range: U3:AI20")
print("Numeric/pure-digit cells count:", len(numeric_like))
print("Sample numeric/pure-digit cells:", numeric_like[:30])
print("Non-numeric cells count:", len(non_numeric_like))
print("Sample non-numeric cells:", non_numeric_like[:30])

# Apply transformation: replace non-purely-numeric cells with 0, preserve pure numeric values
changed = []
preserved = []
for r in range(target_min_row, target_max_row + 1):
    for c in range(target_min_col, target_max_col + 1):
        cell = ws.cell(r, c)
        v = cell.value
        keep = False
        if isinstance(v, (int, float)) and not isinstance(v, bool):
            keep = True
        elif isinstance(v, str) and pure_numeric_pattern.fullmatch(v.strip()):
            # convert numeric strings to actual numbers for cleanliness
            cell.value = int(v.strip())
            keep = True
        
        if keep:
            preserved.append((cell.coordinate, cell.value))
        else:
            old = cell.value
            cell.value = 0
            changed.append((cell.coordinate, old, 0))

print("Changed cells:", len(changed))
print("Preserved cells:", len(preserved))
print("First 25 changed:", changed[:25])

# Save with same filename in output dir
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate as required
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalculate changed them
wb_check = load_workbook(outfile)
current_names = wb_check.sheetnames
print("Sheet names after recalc:", current_names)
orig_names = ["Data"]
if current_names != orig_names and len(current_names) == len(orig_names):
    for i, expected in enumerate(orig_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Renamed sheets back to:", wb_check.sheetnames)

# Verify output by reloading
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Data"]

# print header context and several first/last rows in target range
print("Verification samples:")
for r in list(range(1, 7)) + list(range(16, 21)):
    vals = [wsv.cell(r, c).value for c in range(21, 36)]
    print(f"R{r} U:AI -> {vals}")

# Verify no blanks/strings remain in target area
bad_cells = []
zeros = 0
nums = 0
for r in range(target_min_row, target_max_row + 1):
    for c in range(target_min_col, target_max_col + 1):
        v = wsv.cell(r, c).value
        if v in (None, ""):
            bad_cells.append((wsv.cell(r, c).coordinate, v, "blank"))
        elif isinstance(v, (int, float)) and not isinstance(v, bool):
            nums += 1
            if v == 0:
                zeros += 1
        else:
            bad_cells.append((wsv.cell(r, c).coordinate, v, type(v).__name__))

print("Verified numeric cells in target area:", nums)
print("Verified zero cells in target area:", zeros)
print("Bad cells after verification:", bad_cells[:20], "count:", len(bad_cells))

output_spreadsheet = outfile
```
