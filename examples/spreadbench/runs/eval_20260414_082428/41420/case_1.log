```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

def presence_expr(row, d):
    return f'(LEN($A{row})-LEN(SUBSTITUTE($A{row},"{d}",""))>0)'

def build_formula(row, col):
    # col: 3..7 for C..G
    if col == 3:
        # First smallest present digit
        expr = '""'
        for d in range(9, -1, -1):
            expr = f'IF({presence_expr(row,d)},{d},{expr})'
        return "=" + expr
    else:
        prev_col_letter = chr(ord('A') + col - 2)  # previous output col
        prev_ref = f"{prev_col_letter}{row}"
        expr = '""'
        for d in range(9, -1, -1):
            cond = f'AND({prev_ref}<{d},{presence_expr(row,d)})'
            expr = f'IF({cond},{d},{expr})'
        return f'=IF({prev_ref}="","",{expr})'

# Reload original workbook to avoid preserving bad formulas/caches
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Pre-write A2:G8:")
for r in range(2, 9):
    print(r, [ws.cell(r, c).value for c in range(1, 8)])

# Write formulas to C:G, rows 2:8
for r in range(2, 9):
    for c in range(3, 8):
        ws.cell(r, c).value = build_formula(r, c)

wb.save(outfile)
print("Saved revised formulas to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = name
    wb_post.save(outfile)
    print("Restored sheet names:", orig_sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
print("\nSample written formulas:")
for r in range(2, 4):
    print("Row", r)
    for c in range(3, 8):
        print(ws_formula.cell(r, c).coordinate, ws_formula.cell(r, c).value)

# Verify cached values
wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals[orig_sheetnames[0]]
print("\nVerified cached values C2:G8:")
for r in range(2, 9):
    print(r, [ws_vals.cell(r, c).value for c in range(3, 8)])

# Also print expected-from-input sanity check computed in Python
print("\nPython sanity check from A2:A8:")
for r in range(2, 9):
    s = str(ws_vals[f"A{r}"].value if ws_vals[f"A{r}"].value is not None else "")
    digits = sorted(set(ch for ch in s if ch.isdigit()))
    expected = [int(d) for d in digits] + [""] * (5 - len(digits))
    print(r, s, expected[:5])
