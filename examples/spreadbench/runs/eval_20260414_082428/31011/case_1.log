import os
from datetime import datetime, time
from openpyxl import load_workbook

# Reload and determine true used range
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Find actual last non-empty row in column A / table area
last_data_row = 1
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value is not None for c in range(1, 14)):  # A:M
        last_data_row = r
        break

last_data_col = 1
for c in range(ws.max_column, 0, -1):
    if any(ws.cell(r, c).value is not None for r in range(1, min(ws.max_row, 20) + 1)):
        last_data_col = c
        break

print("Detected last_data_row:", last_data_row)
print("Detected last_data_col:", last_data_col)

# Inspect current target/formula status
print("Current R6:", ws["R6"].value)
for addr in ["P6", "Q6", "R3", "R4"]:
    print(addr, ws[addr].value)

# Compute expected result in Python for sanity check
date_from = ws["P6"].value
date_to = ws["Q6"].value
time_from = ws["R3"].value
time_to = ws["R4"].value

# Data range is B:M based on inspection
sum_py = 0.0
included_rows = []
included_cols = []
for c in range(2, 14):
    hdr = ws.cell(1, c).value
    if hdr is not None and time_from <= hdr <= time_to:
        included_cols.append(c)

for r in range(2, last_data_row + 1):
    d = ws.cell(r, 1).value
    if d is not None and date_from <= d <= date_to:
        included_rows.append(r)

for r in included_rows:
    for c in included_cols:
        v = ws.cell(r, c).value
        if isinstance(v, (int, float)):
            sum_py += v

print("Included row numbers:", included_rows)
print("Included col numbers:", included_cols)
print("Included time headers:", [ws.cell(1,c).value for c in included_cols])
print("Python expected sum:", sum_py)

# Write formula to exact target cell
formula = f'=SUMPRODUCT(($A$2:$A${last_data_row}>=P6)*($A$2:$A${last_data_row}<=Q6)*($B$1:$M$1>=R3)*($B$1:$M$1<=R4)*$B$2:$M${last_data_row})'
ws["R6"] = formula
print("Written formula in R6:", ws["R6"].value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet name if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != ["Sheet1"]:
    # rename first/or matching sheet back to original if necessary
    wb_after[wb_after.sheetnames[0]].title = "Sheet1"
    wb_after.save(out_path)
    print("Renamed sheet back to Sheet1 and re-saved.")

# Verify with formulas visible
wb_verify_formula = load_workbook(out_path, data_only=False)
wsf = wb_verify_formula["Sheet1"]
print("Verified formula R6:", wsf["R6"].value)

# Verify cached result
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["Sheet1"]
print("Verified cached R6:", wsv["R6"].value)
print("Verification cells P6,Q6,R3,R4:", wsv["P6"].value, wsv["Q6"].value, wsv["R3"].value, wsv["R4"].value)

output_spreadsheet = out_path
