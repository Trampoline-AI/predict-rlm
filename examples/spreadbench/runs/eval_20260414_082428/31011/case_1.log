import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def display(v):
    if v is None:
        return None
    if hasattr(v, "text"):
        return f"FORMULA_OBJ:{v.text}"
    return v

workbook_summary = {}
for ws in wb.worksheets:
    max_row, max_col = ws.max_row, ws.max_column
    headers = [display(ws.cell(1, c).value) for c in range(1, max_col + 1)]
    workbook_summary[ws.title] = {"max_row": max_row, "max_col": max_col, "headers": headers}
    print(f"\n=== Sheet: {ws.title} | rows={max_row}, cols={max_col} ===")
    print("Headers row 1:", headers)
    
    # first 10 rows
    print("First rows:")
    for r in range(1, min(max_row, 10) + 1):
        vals = [display(ws.cell(r, c).value) for c in range(1, max_col + 1)]
        print(f"Row {r}: {vals}")
    
    # last 5 rows (if beyond first 10)
    start_last = max(1, max_row - 4)
    if start_last > 10:
        print("Last rows:")
        for r in range(start_last, max_row + 1):
            vals = [display(ws.cell(r, c).value) for c in range(1, max_col + 1)]
            print(f"Row {r}: {vals}")

# Specifically inspect target-relevant cells on each sheet
targets = ["P6","Q6","R3","R4","R6","A1","A2","A3"]
