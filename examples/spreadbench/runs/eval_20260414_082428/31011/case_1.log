# Print a focused area around columns O:R and rows 1:10
for ws in wb.worksheets:
    print(f"\nFocused area O:R rows 1:10 for {ws.title}")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [display(ws.cell(r, c).value) for c in range(15, min(18, ws.max_column) + 1)]
        print(f"Row {r} O:R => {vals}")
