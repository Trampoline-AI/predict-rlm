```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Load and inspect target sheet again briefly for exact target/formula context
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheet_names)
print("Target sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)
print("Headers A:K:", [ws.cell(1, c).value for c in range(1, 12)])
print("Existing J formulas and K values before write:")
for r in range(2, ws.max_row + 1):
    print(r, "J:", ws[f"J{r}"].value, "K:", ws[f"K{r}"].value)

# Write formulas to K for all populated data rows
# Logic: compare earliest date in J against each activity date in C/E/G/I
# Return corresponding activity header from B1/D1/F1/H1.
for r in range(2, ws.max_row + 1):
    # only write for rows that actually contain a person or any activity data
    row_has_data = any(ws.cell(r, c).value not in (None, "") for c in range(1, 11))
    if not row_has_data:
        continue
    formula = (
        f'=IF(J{r}="","",'
        f'IF(C{r}=J{r},$B$1,'
        f'IF(E{r}=J{r},$D$1,'
        f'IF(G{r}=J{r},$F$1,'
        f'IF(I{r}=J{r},$H$1,"")))))'
    )
    ws[f"K{r}"] = formula

print("Written formulas in K:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"K{r}"].value)

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename by position to original names
    for i, expected_name in enumerate(original_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)

wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

print("\nVerification of target cells K2:K{}".format(wsf.max_row))
verification = []
for r in range(2, wsf.max_row + 1):
    verification.append({
        "row": r,
        "name": wsf[f"A{r}"].value,
        "J_formula": wsf[f"J{r}"].value,
        "J_value": wsv[f"J{r}"].value,
        "K_formula": wsf[f"K{r}"].value,
        "K_value": wsv[f"K{r}"].value,
    })
for item in verification:
    print(item)

# Keep output path for submission
final_output_path = output_path
print("Ready to submit:", final_output_path)
