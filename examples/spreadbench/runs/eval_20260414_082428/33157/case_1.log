        print(f"Row {r}:", vals)
    # assume row 1 header for now; print headers
    headers = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    print("Headers row1:", headers)
    # first 10 and last 5 rows, limited to first 12 cols for readability
    first_n = min(ws.max_row, 10)
    last_start = max(1, ws.max_row - 4)
    print("First rows sample:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"R{r}: {vals}")
    print("Last rows sample:")
    for r in range(last_start, ws.max_row + 1):
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"R{r}: {vals}")

for ws in wb.worksheets:
