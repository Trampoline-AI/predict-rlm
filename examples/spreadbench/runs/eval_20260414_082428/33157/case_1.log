        if idx <= ws.max_column:
            print(col, "header/value row1:", ws[f"{col}1"].value)
    # print first 10 and last 5 rows for A:L specifically
    rows_to_show = list(range(1, min(ws.max_row, 10)+1)) + list(range(max(1, ws.max_row-4), ws.max_row+1))
    seen = set()
    for r in rows_to_show:
        if r in seen: 
            continue
        seen.add(r)
        vals = {col: ws[f"{col}{r}"].value for col in focus_cols if column_index_from_string(col) <= ws.max_column}
        print(f"Row {r}:", vals)

