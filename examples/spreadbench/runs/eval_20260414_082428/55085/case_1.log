import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for writing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames
wsr = wb["Result"]
wsm = wb["Master-RM"]

print("Original sheet names:", orig_sheetnames)
print("Pre-write target cells:")
for c in range(7, 13):
    coord = f"{get_column_letter(c)}10"
    print(coord, "->", wsr[coord].value)

# Write formulas to G10:L10
# Use item in row 2 and month in row 3:
# Shrawan -> column I (1st col of I:K range)
# Bhadra  -> column K (3rd col of I:K range)
for c in range(7, 13):
    col_letter = get_column_letter(c)
    formula = (
        f"=INDEX('Master-RM'!$I$9:$K$20,"
        f"MATCH({col_letter}$2,'Master-RM'!$A$9:$A$20,0),"
        f"IF({col_letter}$3=\"Shrawan\",1,3))"
    )
    wsr.cell(10, c).value = formula

print("\nWritten formulas:")
for c in range(7, 13):
    coord = f"{get_column_letter(c)}10"
    print(coord, "->", wsr[coord].value)

wb.save(output_path)
print("\nSaved to:", output_path, os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # Rename by position back to original
    for i, original_name in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    print("Restored sheet names:", load_workbook(output_path).sheetnames)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
wsr_formula = wb_formula["Result"]
print("\nFormula verification G10:L10:")
for c in range(7, 13):
    coord = f"{get_column_letter(c)}10"
    print(coord, "formula =", wsr_formula[coord].value)

# Verify cached values
wb_values = load_workbook(output_path, data_only=True)
wsr_values = wb_values["Result"]
print("\nCached values verification G10:L10:")
vals = {}
for c in range(7, 13):
    coord = f"{get_column_letter(c)}10"
    vals[coord] = wsr_values[coord].value
    print(coord, "value =", vals[coord])

# Also print expected source values from Master-RM totals for sanity
wsm_values = wb_values["Master-RM"]
print("\nSanity check source totals:")
for row in [12, 16, 20]:
    print(
        f"A{row}={wsm_values[f'A{row}'].value}, "
        f"I{row}={wsm_values[f'I{row}'].value}, "
        f"K{row}={wsm_values[f'K{row}'].value}"
    )

output_spreadsheet = output_path
```
