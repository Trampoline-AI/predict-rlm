import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Workbook sheets:", orig_sheet_names)

def display(v):
    if v is None:
        return None
    return str(v)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find likely header row among first 5 rows by most non-empty values
    best_row = 1
    best_nonempty = -1
    for r in range(1, min(6, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v is not None and str(v) != "" for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row = r
    header_row = best_row
    headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
    print("Detected header row:", header_row)
    print("Headers:", headers)
    
    # print first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    
    # print last 5 rows
    print("Last rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    
    # Specific inspection of columns C and K if present
    if ws.max_column >= 11:
        print("Specific inspection of columns C and K (rows 1-15):")
        for r in range(1, min(ws.max_row, 15) + 1):
            c_val = ws[f"C{r}"].value
            k_val = ws[f"K{r}"].value
            print(f"Row {r}: C={display(c_val)} | K={display(k_val)}")
            if isinstance(c_val, str) and c_val.startswith("="):
                print(f"  Formula in C{r}: {c_val}")
    elif ws.max_column >= 3:
        print("Specific inspection of column C (rows 1-15):")
        for r in range(1, min(ws.max_row, 15) + 1):
            c_val = ws[f"C{r}"].value
            print(f"Row {r}: C={display(c_val)}")
            if isinstance(c_val, str) and c_val.startswith("="):
                print(f"  Formula in C{r}: {c_val}")

# Also inspect formulas workbook-wide in column C
print("\nWorkbook-wide scan for formulas in column C:")
for ws in wb.worksheets:
    found = []
    for r in range(1, ws.max_row + 1):
        v = ws[f"C{r}"].value if ws.max_column >= 3 else None
        if isinstance(v, str) and v.startswith("="):
            found.append((r, v))
    print(ws.title, "formula rows in C:", found[:20], "count:", len(found))
