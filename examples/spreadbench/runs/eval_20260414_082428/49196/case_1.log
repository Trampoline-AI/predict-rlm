import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_path))

# Fresh copy from input
shutil.copy(input_path, output_path)

# Load and modify
wb = load_workbook(output_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheet_names)
print("Target sheet:", ws.title)
print("Target column C rows with formulas:", 2, "to", ws.max_row)

def corrected_formula(r):
    # Convert text in K like dd.mm.yy hh:mm into a true datetime
    return (
        f'=DATE(2000+VALUE(MID(K{r},7,2)),VALUE(MID(K{r},4,2)),VALUE(LEFT(K{r},2)))'
        f'+TIMEVALUE(MID(K{r},10,5))'
    )

written_rows = []
for r in range(2, ws.max_row + 1):
    k_val = ws[f"K{r}"].value
    # Only write where source K has data and C currently contains the existing formula area
    if k_val is not None and str(k_val).strip() != "":
        ws[f"C{r}"] = corrected_formula(r)
        ws[f"C{r}"].number_format = "DD/MM/YY HH:MM"
        written_rows.append(r)

# Print some formulas before save
for r in [2, 3, 10, 40, 43, 47]:
    if r <= ws.max_row:
        print(f"C{r} formula ->", ws[f"C{r}"].value, "| numfmt:", ws[f"C{r}"].number_format)

wb.save(output_path)
print("Saved modified workbook to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    print("Sheet names changed; restoring...")
    for i, original_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verification with formulas view
wvf = load_workbook(output_path)
wsv = load_workbook(output_path, data_only=True)
wsf = wvf["Sheet1"]
wss = wsv["Sheet1"]

print("\nVerification summary:")
print("Final sheet names:", wvf.sheetnames)
print("Rows written:", len(written_rows), "first/last:", written_rows[:3], written_rows[-3:])

# Verify representative cells/range mentioned in instruction
for r in [2, 3, 10, 39, 40, 43, 47]:
    if r <= wsf.max_row:
        print(
            f"Row {r}:",
            "K=", wsf[f"K{r}"].value,
            "| C_formula=", wsf[f"C{r}"].value,
            "| C_value=", wss[f"C{r}"].value,
            "| D_value=", wss[f"D{r}"].value,
            "| E_value=", wss[f"E{r}"].value,
        )

# Verify no blanks in target output range where K has data
issues = []
for r in range(2, wsf.max_row + 1):
    k = wsf[f"K{r}"].value
    c_formula = wsf[f"C{r}"].value
    c_value = wss[f"C{r}"].value
    if k is not None and str(k).strip() != "":
        if c_formula is None or c_formula == "":
            issues.append((r, "missing_formula"))
        if c_value is None:
            issues.append((r, "missing_value"))

print("Issue count:", len(issues))
print("Issue samples:", issues[:10])

# Keep path for submission
final_output_path = output_path
print("Ready to submit:", final_output_path)
