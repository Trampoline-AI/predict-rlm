Code:
```repl
import os
from datetime import datetime, date
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

# Determine the last non-empty entry in A1:A11 (final entry, not necessarily max date)
last_value = None
last_row = None
for r in range(11, 0, -1):
    v = ws[f"A{r}"].value
    if v not in (None, ""):
        last_value = v
        last_row = r
        break

print("Last non-empty entry in A1:A11:", last_row, repr(last_value))

# Extract day number as static value
if isinstance(last_value, datetime):
    day_num = last_value.day
elif isinstance(last_value, date):
    day_num = last_value.day
else:
    # fallback if stored as string or numeric-like
    parsed = None
    if isinstance(last_value, str):
        for fmt in ("%Y-%m-%d", "%m/%d/%Y", "%d/%m/%Y", "%Y/%m/%d"):
            try:
                parsed = datetime.strptime(last_value.strip(), fmt)
                break
            except Exception:
                pass
    if parsed is not None:
        day_num = parsed.day
    else:
        raise ValueError(f"Could not interpret final A-cell value as a date: {last_value!r}")

print("Computed static day number for B1:", day_num)
print("B1 before write:", ws["B1"].value)

# Write static number to B1
ws["B1"] = int(day_num)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheet_names and len(wb_after.sheetnames) == len(original_sheet_names):
    for i, expected in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verification reloads
wb_verify_formula = load_workbook(output_path, data_only=False)
wb_verify_values = load_workbook(output_path, data_only=True)

print("Verified sheet names:", wb_verify_values.sheetnames)

wsf = wb_verify_formula[original_sheet_names[0]]
wsv = wb_verify_values[original_sheet_names[0]]

# Print exact target/input range for verification
print("Verification A1:A11 and B1:")
for r in range(1, 12):
    print(f"Row {r}: A{r} formula-view={wsf[f'A{r}'].value!r}, value-view={wsv[f'A{r}'].value!r}")
print("B1 formula-view:", wsf["B1"].value, type(wsf["B1"].value))
print("B1 value-view:", wsv["B1"].value, type(wsv["B1"].value))

# Sanity checks
assert wsv["B1"].value == 10, f"Expected B1=10, got {wsv['B1'].value!r}"
assert all(wsv[f"A{r}"].value is not None for r in range(1, 12)), "Column A inputs were altered unexpectedly"

final_output_spreadsheet = output_path
print("Ready to submit:", final_output_spreadsheet)
```
