import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload original workbook for modification
wb = load_workbook(infile)
ws = wb["Sheet1"]

# Sanity-check expected results in Python using case-sensitive matching
data_rows = list(range(2, ws.max_row + 1))
def num(v):
    return 0 if v in (None, "") else float(v)

expected = {}
for jr in range(2, 6):
    key = ws[f"J{jr}"].value
    total = 0
    matched_rows = []
    for r in data_rows:
        if ws[f"A{r}"].value == key:  # case-sensitive match
            val = num(ws[f"B{r}"].value) - num(ws[f"C{r}"].value) - num(ws[f"E{r}"].value) - num(ws[f"G{r}"].value)
            total += val
            matched_rows.append((r, ws[f"A{r}"].value, val))
    expected[jr] = {"key": key, "total": round(total, 0), "matches": matched_rows}

print("Expected case-sensitive totals:")
for jr, info in expected.items():
    print(f"J{jr}={info['key']!r} -> {info['total']}, matches={info['matches']}")

# Write formulas to K2:K5
last_row = ws.max_row
for r in range(2, 6):
    formula = f'=ROUND(SUMPRODUCT(--EXACT($A$2:$A${last_row},J{r}),N($B$2:$B${last_row})-N($C$2:$C${last_row})-N($E$2:$E${last_row})-N($G$2:$G${last_row})),0)'
    ws[f"K{r}"] = formula
    ws[f"K{r}"].number_format = '0'

print("Written formulas:")
for r in range(2, 6):
    print(f"K{r} formula:", ws[f"K{r}"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc and restore if changed
wb_after = load_workbook(outfile)
current_names = wb_after.sheetnames
original_names = ["Sheet1"]
print("Sheet names after recalc:", current_names)
if current_names != original_names:
    for i, orig in enumerate(original_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_names)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("Verification target cells J2:K5")
for r in range(2, 6):
    print({
        "row": r,
        "J": ws_values[f"J{r}"].value,
        "K_formula": ws_formula[f"K{r}"].value,
        "K_value": ws_values[f"K{r}"].value,
        "expected": expected[r]["total"],
    })
