```repl
import os, copy
from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["COLLECTION"]

# Inspect current styles / formulas in exact target range before editing
print("Pre-edit target area A1:G10:")
for r in range(1, min(ws.max_row, 10) + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 8)])

print("Existing formulas in G:")
for r in range(2, ws.max_row + 1):
    print(f"G{r} =", ws[f"G{r}"].value)

# Aggregate across all non-COLLECTION sheets by BR, TY, OR
from collections import defaultdict
agg = defaultdict(lambda: {"SALE": 0.0, "RET": 0.0})

def numify(v):
    if v is None or v == "" or v == "-":
        return 0.0
    try:
        return float(v)
    except Exception:
        return 0.0

for s in wb.sheetnames:
    if s.upper() == "COLLECTION":
        continue
    sws = wb[s]
    headers = [sws.cell(1, c).value for c in range(1, sws.max_column + 1)]
    hmap = {str(v).strip().upper(): i+1 for i, v in enumerate(headers) if v is not None}
    for r in range(2, sws.max_row + 1):
        br = sws.cell(r, hmap["BR"]).value if "BR" in hmap else None
        ty = sws.cell(r, hmap["TY"]).value if "TY" in hmap else None
        orv = sws.cell(r, hmap["OR"]).value if "OR" in hmap else None
        if br is None and ty is None and orv is None:
            continue
        key = (br, ty, orv)
        if "SALE" in hmap:
            agg[key]["SALE"] += numify(sws.cell(r, hmap["SALE"]).value)
        if "RET" in hmap:
            agg[key]["RET"] += numify(sws.cell(r, hmap["RET"]).value)

# Existing rows in COLLECTION, preserving order
existing_rows = []
existing_map = {}
for r in range(2, ws.max_row + 1):
    key = (ws.cell(r, 2).value, ws.cell(r, 3).value, ws.cell(r, 4).value)
    existing_rows.append((r, key))
    existing_map[key] = r

print("Existing order:", existing_rows)
print("Aggregated keys:", list(agg.keys()))

# Helper: display value rules
def display_measure(v):
    # Missing/zero should display '-'
    return "-" if abs(v) < 1e-12 else v

def display_balance(sale_v, ret_v):
    sale_num = 0.0 if sale_v == "-" else float(sale_v)
    ret_num = 0.0 if ret_v == "-" else float(ret_v)
    bal = sale_num - ret_num
    return "-" if abs(bal) < 1e-12 else bal

# Style helpers
red = "FF0000"
black = "000000"

def apply_font_alignment(cell, col_idx, negative=False):
    horiz = "right" if col_idx in (1, 5, 6, 7) else "left"
    cell.alignment = Alignment(horizontal=horiz, vertical="center")
    cell.font = Font(
        name="Calibri",
        size=11,
        bold=False,
        italic=False,
        color=(red if negative else black)
    )

# Update existing rows' E/F/G as values, not formulas
for r, key in existing_rows:
    vals = agg.get(key, {"SALE": 0.0, "RET": 0.0})
    sale_disp = display_measure(vals["SALE"])
    ret_disp = display_measure(vals["RET"])
    bal_disp = display_balance(sale_disp, ret_disp)

    ws.cell(r, 5).value = sale_disp
    ws.cell(r, 6).value = ret_disp
    ws.cell(r, 7).value = bal_disp

# Append missing rows at bottom, without altering original order
missing_keys = [k for k in agg.keys() if k not in existing_map]
print("Missing keys to append:", missing_keys)

template_row = ws.max_row
for key in missing_keys:
    new_r = ws.max_row + 1

    # Copy style from previous last row to preserve formatting as much as possible
    for c in range(1, ws.max_column + 1):
        src = ws.cell(template_row, c)
        dst = ws.cell(new_r, c)
        if src.has_style:
            dst._style = copy.copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.fill:
            dst.fill = copy.copy(src.fill)
        if src.border:
            dst.border = copy.copy(src.border)
        if src.protection:
            dst.protection = copy.copy(src.protection)
        if src.alignment:
            dst.alignment = copy.copy(src.alignment)
        if src.font:
            dst.font = copy.copy(src.font)

    sale_disp = display_measure(agg[key]["SALE"])
    ret_disp = display_measure(agg[key]["RET"])
    bal_disp = display_balance(sale_disp, ret_disp)

    ws.cell(new_r, 1).value = new_r - 1  # continue ITEM numbering
    ws.cell(new_r, 2).value = key[0]
    ws.cell(new_r, 3).value = key[1]
    ws.cell(new_r, 4).value = key[2]
    ws.cell(new_r, 5).value = sale_disp
    ws.cell(new_r, 6).value = ret_disp
    ws.cell(new_r, 7).value = bal_disp

# Headers: unbold and left aligned, Calibri 11
for c in range(1, 8):
    cell = ws.cell(1, c)
    cell.alignment = Alignment(horizontal="left", vertical="center")
    cell.font = Font(name="Calibri", size=11, bold=False, italic=False, color=black)

# Entire used range A:G formatting rules
for r in range(2, ws.max_row + 1):
    for c in range(1, 8):
        cell = ws.cell(r, c)
        val = cell.value
        neg = isinstance(val, (int, float)) and val < 0
        apply_font_alignment(cell, c, negative=neg)

# Make sure header row also unbold overall, and all text unbold Calibri 11
for r in range(1, ws.max_row + 1):
    for c in range(1, 8):
        cell = ws.cell(r, c)
        # retain current font color from negative cells
        current_color = None
        try:
            current_color = cell.font.color.rgb if cell.font and cell.font.color and cell.font.color.type == "rgb" else None
        except Exception:
            current_color = None
        if r == 1:
            cell.font = Font(name="Calibri", size=11, bold=False, italic=False, color=black)
        else:
            neg = isinstance(cell.value, (int, float)) and cell.value < 0
            cell.font = Font(name="Calibri", size=11, bold=False, italic=False, color=(red if neg else black))

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed; restoring original names.")
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    wb2 = load_workbook(outfile)
print("Final sheet names:", wb2.sheetnames)

# Verification with data_only for values
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["COLLECTION"]

print("\nVerified target range A1:G12 (data_only):")
for r in range(1, min(wsv.max_row, 12) + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 8)])

# Verify exact rows, especially appended row and no formulas in G
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["COLLECTION"]
print("\nFormula/value check in G column:")
for r in range(2, wsf.max_row + 1):
    print(f"Row {r}: G raw={wsf.cell(r,7).value!r}, data_only={wsv.cell(r,7).value!r}")

# Verify formatting/alignment/font for a few key cells
for coord in ["A1","B1","G1","A2","B2","E2","F5","G5", f"A{wsf.max_row}", f"G{wsf.max_row}"]:
    c = wsf[coord]
    color = None
    try:
        if c.font and c.font.color and c.font.color.type == "rgb":
            color = c.font.color.rgb
    except Exception:
        color = None
    print(coord, {
        "value": c.value,
        "bold": c.font.bold,
        "font_name": c.font.name,
        "font_size": c.font.sz,
        "align": c.alignment.horizontal,
        "color": color
    })

output_spreadsheet = outfile
