from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_info = {}
for s in wb.sheetnames:
    ws = wb[s]
    # detect header row heuristically from first 5 rows: choose row with most non-empty text-ish cells
    best_row = 1
    best_score = -1
    for r in range(1, min(ws.max_row, 5)+1):
        vals = row_values(ws, r, ws.max_column)
        score = sum(v is not None and v != "" for v in vals)
        if score > best_score:
            best_score = score
            best_row = r
    headers = row_values(ws, best_row, ws.max_column)
    sheet_info[s] = {"rows": ws.max_row, "cols": ws.max_column, "header_row": best_row, "headers": headers}
    print(f"\n--- Sheet: {s} ---")
    print(f"Rows={ws.max_row}, Cols={ws.max_column}, chosen header row={best_row}")
    print("Headers:", headers)
    # first 8 rows
    first_end = min(ws.max_row, 8)
    print("First rows:")
    for r in range(1, first_end+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    # last 5 rows
    start = max(1, ws.max_row-4)
    print("Last rows:")
    for r in range(start, ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))

# Focus on collection sheet and search SALE/RET/BALANCE headers/formulas
if "collection" in wb.sheetnames:
    ws = wb["collection"]
    print("\n=== Detailed inspection: collection ===")
    for r in range(1, min(ws.max_row, 15)+1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))
    # search for keywords
    keywords = ["SALE", "RET", "BALANCE", "sale", "ret", "balance"]
    matches = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and any(k in v for k in keywords):
                matches.append((r, c, v))
    print("Keyword matches in collection:", matches[:100])
    # print formulas in used range
    formula_cells = []
    for r in range(1, min(ws.max_row, 50)+1):
        for c in range(1, min(ws.max_column, 20)+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((get_column_letter(c)+str(r), v))
    print("Formula cells in top area of collection:", formula_cells[:100])

# Search all sheets for SALE/RET/BALANCE in headers and top formulas
print("\n=== Search all sheets for target terms ===")
for s in wb.sheetnames:
    ws = wb[s]
    hits = []
