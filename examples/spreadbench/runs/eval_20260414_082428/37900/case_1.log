import os, json, textwrap, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
print("Sheet names:", wb.sheetnames)

def display(v):
    if v is None:
        return None
    s = str(v)
    return s if len(s) <= 60 else s[:57] + "..."

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # determine used rows/cols more carefully
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value is not None:
                row_has = True
                nonempty_cols.add(cell.column)
        if row_has:
            nonempty_rows.append(row[0].row)
    print("Non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("First non-empty row:", min(nonempty_rows), "Last non-empty row:", max(nonempty_rows))
    
    # print first 10 rows and last 5 rows across used columns
    max_col = ws.max_column
    headers = [display(ws.cell(1, c).value) for c in range(1, max_col+1)]
    print("Row 1 values / headers:", headers)
    
    first_rows = list(range(1, min(ws.max_row, 10)+1))
    last_rows = list(range(max(1, ws.max_row-4), ws.max_row+1))
    rows_to_show = []
    seen = set()
    for r in first_rows + last_rows:
        if r not in seen:
            seen.add(r)
            rows_to_show.append(r)
    for r in rows_to_show:
        vals = [display(ws.cell(r, c).value) for c in range(1, max_col+1)]
        print(f"Row {r}: {vals}")
    
    # formulas scan
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print("Formula cell count:", len(formulas))
    for coord, formula in formulas[:20]:
        print("Formula:", coord, formula)
    if len(formulas) > 20:
        print("... more formulas omitted")
    
    # non-empty cells summary in first 30 rows/columns for layout understanding
    print("Non-empty cells in first 30 rows (coord=value):")
    count = 0
    for r in range(1, min(ws.max_row, 30)+1):
        for c in range(1, min(ws.max_column, 20)+1):
            v = ws.cell(r, c).value
            if v is not None:
                print(f"{get_column_letter(c)}{r}={display(v)}")
                count += 1
                if count >= 60:
                    print("... truncated")
                    raise StopIteration
