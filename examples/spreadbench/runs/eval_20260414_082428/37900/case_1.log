import os
from openpyxl import load_workbook

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
print("Output exists before recalc:", os.path.exists(out_path))

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc result:", recalc_result)

# Check sheet names after recalc
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)

# If renamed, rename back to original names in order
original_wb = load_workbook(input_spreadsheet)
original_names = original_wb.sheetnames
if wb_after.sheetnames != original_names and len(wb_after.sheetnames) == len(original_names):
    for ws, orig_name in zip(wb_after.worksheets, original_names):
        ws.title = orig_name
    wb_after.save(out_path)
    print("Renamed sheets back to:", original_names)

# Reload formula and data_only versions for verification
wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)

wsf = wb_formula[original_names[0]]
wsv = wb_values[original_names[0]]

print("\nFormula version targets:")
for coord in ["D4", "E4", "D5", "E5", "A5", "B5", "A8", "B8", "A14", "B14"]:
    print(coord, "=", wsf[coord].value)

print("\nData-only version targets:")
for coord in ["D4", "E4", "D5", "E5"]:
    print(coord, "=", wsv[coord].value)

# If E5 is blank/0, fix formula to month-only lookup because source dates are monthly for one sample year
e5_val = wsv["E5"].value
needs_fix = (e5_val is None) or (isinstance(e5_val, (int, float)) and e5_val == 0)

print("\nNeeds E5 fix?", needs_fix)

if needs_fix:
    wb_fix = load_workbook(out_path)
    ws = wb_fix[original_names[0]]
    # Keep dynamic current date in E4
    ws["E4"] = "=TODAY()"
    # Match current month only against the monthly schedule in A5:B16
    ws["E5"] = '=SUMPRODUCT((MONTH($A$5:$A$16)=MONTH($E$4))*$B$5:$B$16)'
    wb_fix.save(out_path)
    print("Updated E5 formula to:", ws["E5"].value)

    recalc_result2 = await recalculate(out_path)
    print("Recalc after fix:", recalc_result2)

    wb_formula2 = load_workbook(out_path, data_only=False)
    wb_values2 = load_workbook(out_path, data_only=True)
    wsf2 = wb_formula2[original_names[0]]
    wsv2 = wb_values2[original_names[0]]

    print("\nPost-fix formula targets:")
    for coord in ["E4", "E5"]:
        print(coord, "=", wsf2[coord].value)

    print("\nPost-fix data-only targets:")
    for coord in ["E4", "E5"]:
        print(coord, "=", wsv2[coord].value)

    # Keep path for submit
    final_output_path = out_path
else:
    final_output_path = out_path

print("\nFinal output path:", final_output_path)
