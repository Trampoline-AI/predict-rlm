import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Dimensions: rows={max_row}, cols={max_col}")
    print("Headers row 1:", headers)
    
    # First 10 rows
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(f"Row {r}: {row_vals}")
    
    # Last 5 rows
    start_last = max(1, max_row - 4)
    if start_last <= max_row:
        print(f"Last {max_row - start_last + 1} rows:")
        for r in range(start_last, max_row + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
            print(f"Row {r}: {row_vals}")
    
    # Inspect column B specifically
    if max_col >= 2:
        b_samples = []
        for r in range(1, min(max_row, 20) + 1):
            b_samples.append((r, ws.cell(r, 2).value))
        print("Column B sample rows 1-20:", b_samples)

for ws in wb.worksheets:
    sheet_summary(ws)
