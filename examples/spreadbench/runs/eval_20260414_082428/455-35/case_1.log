from collections import Counter, defaultdict
from openpyxl import load_workbook
import os

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Analyze full column B
first_char_counts = Counter()
value_counts = Counter()
examples_by_char = defaultdict(list)

for r in range(2, ws.max_row + 1):  # skip header
    val = ws.cell(r, 2).value
    sval = "" if val is None else str(val)
    ch = sval[:1]
    first_char_counts[ch] += 1
    value_counts[sval] += 1
    if len(examples_by_char[ch]) < 5:
        examples_by_char[ch].append((r, sval))

print("Column B header:", ws.cell(1, 2).value)
print("Distinct first-character counts in column B (excluding header):", first_char_counts)
print("Top 10 full values in column B:", value_counts.most_common(10))
print("Example rows by first character:")
for ch, exs in list(examples_by_char.items())[:10]:
    print(repr(ch), exs)

keep_rows = []
delete_rows = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(r, 2).value
    sval = "" if val is None else str(val)
    if sval.startswith("H") or sval.startswith("A"):
        keep_rows.append(r)
    else:
        delete_rows.append(r)

print("Rows to keep:", len(keep_rows))
print("Rows to delete:", len(delete_rows))
print("First 10 keep rows:", keep_rows[:10])
print("First 10 delete rows:", delete_rows[:10])

# Perform deletion by rewriting kept rows to avoid slow repeated delete_rows
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

wb2 = load_workbook(input_spreadsheet)
ws2 = wb2[wb2.sheetnames[0]]

# Preserve header and only rows whose column B starts with H or A
kept_data = []
for r in range(2, ws2.max_row + 1):
    row_vals = [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)]
    sval = "" if row_vals[1] is None else str(row_vals[1])
    if sval.startswith("H") or sval.startswith("A"):
        kept_data.append(row_vals)

print("Kept data rows prepared:", len(kept_data))

# Clear existing data rows
for r in range(2, ws2.max_row + 1):
    for c in range(1, ws2.max_column + 1):
        ws2.cell(r, c).value = None

# Write kept rows back starting at row 2
for i, row_vals in enumerate(kept_data, start=2):
    for c, v in enumerate(row_vals, start=1):
        ws2.cell(i, c).value = v

wb2.save(out_path)
print("Saved preliminary output to:", out_path)

recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and verify
wb_check = load_workbook(out_path, data_only=True)
print("Sheet names after recalc:", wb_check.sheetnames)
ws_check = wb_check[wb_check.sheetnames[0]]

# Find non-empty rows after operation
nonempty_rows = []
for r in range(1, ws_check.max_row + 1):
    if any(ws_check.cell(r, c).value is not None for c in range(1, ws_check.max_column + 1)):
        nonempty_rows.append(r)

print("Non-empty row count:", len(nonempty_rows))
print("First 10 non-empty rows:", nonempty_rows[:10])
print("Last 10 non-empty rows:", nonempty_rows[-10:])

# Print first 10 and last 5 non-empty rows
print("First up to 10 non-empty rows after filtering:")
for r in nonempty_rows[:10]:
    print(r, [ws_check.cell(r, c).value for c in range(1, ws_check.max_column + 1)])

print("Last up to 5 non-empty rows after filtering:")
for r in nonempty_rows[-5:]:
    print(r, [ws_check.cell(r, c).value for c in range(1, ws_check.max_column + 1)])

# Verify remaining data rows satisfy condition
violations = []
for r in nonempty_rows[1:]:  # skip header row
    val = ws_check.cell(r, 2).value
    sval = "" if val is None else str(val).strip()
    if sval and not (sval.startswith("H") or sval.startswith("A")):
        violations.append((r, sval))
        if len(violations) >= 10:
            break

print("Verification violations (should be empty):", violations)
final_output_path = out_path
