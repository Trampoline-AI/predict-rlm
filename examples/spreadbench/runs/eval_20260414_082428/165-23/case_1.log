    if ws.max_row >= 2:
        print("Row2 values:", row_values(ws, 2, ws.max_column))
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))

# Inspect target candidate sheet names
candidate_names = [n for n in wb.sheetnames if n.lower().replace(" ", "") in ("sheet1", "sheet1")]
print("Candidate sheet names matching Sheet1-ish:", candidate_names)

# Print detailed column C values for candidate first sheet or first sheet
target_ws = wb[candidate_names[0]] if candidate_names else wb[wb.sheetnames[0]]
print("\nUsing target worksheet for inspection:", target_ws.title)

print("Detailed Column C inspection (rows 1..min(25,max_row)):")
for r in range(1, min(25, target_ws.max_row) + 1):
    cell = target_ws.cell(r, 3)
    print(r, repr(cell.value), type(cell.value).__name__, "data_type=", cell.data_type)

# Count value types/status in column C
summary = {"None":0, "error":0, "formula":0, "string":0, "number":0, "other":0}
na_rows = []
non_na_rows = []
for r in range(1, target_ws.max_row + 1):
    cell = target_ws.cell(r, 3)
    v = cell.value
    if v is None:
        summary["None"] += 1
        non_na_rows.append(r)
    elif cell.data_type == "e":
        summary["error"] += 1
        if v == "#N/A":
            na_rows.append(r)
        else:
            non_na_rows.append(r)
    elif isinstance(v, str) and v.startswith("="):
        summary["formula"] += 1
        non_na_rows.append(r)
    elif isinstance(v, str):
        summary["string"] += 1
        non_na_rows.append(r)
    elif isinstance(v, (int, float)):
        summary["number"] += 1
        non_na_rows.append(r)
    else:
        summary["other"] += 1
        non_na_rows.append(r)

print("Column C summary:", summary)
print("Rows where C is literal/error #N/A (first 30):", na_rows[:30], "count=", len(na_rows))
print("Rows where C is NOT #N/A (first 30):", non_na_rows[:30], "count=", len(non_na_rows))

# Inspect if row 1 is blank as instruction hints
