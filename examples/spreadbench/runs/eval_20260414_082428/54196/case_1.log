print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_info = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n=== SHEET: {sname} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # find candidate header rows among first 5 rows based on non-empty count
    header_candidates = []
    for r in range(1, min(6, ws.max_row + 1)):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v not in (None, "") for v in vals)
        header_candidates.append((r, nonempty, vals))
    print("Top header candidates (row, nonempty_count):", [(r,n) for r,n,_ in header_candidates])
    
    # print first up to 5 rows fully
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # print last 5 rows
    print("Last rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # collect likely headers from best candidate
    best_header_row = max(header_candidates, key=lambda x: x[1])[0] if header_candidates else 1
    headers = row_values(ws, best_header_row, ws.max_column)
    print("Chosen header row:", best_header_row)
    print("Headers:", headers)
    
    # search for keywords/formulas/errors
    keyword_hits = []
    formula_hits = []
    error_hits = []
    keywords = ["supplier", "item", "lead", "lookup", "match", "vlookup", "index"]
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                low = v.lower()
                if any(k in low for k in keywords):
                    keyword_hits.append((r, c, v))
                if v.startswith("="):
                    formula_hits.append((r, c, v))
                if "#N/A" in v or "#VALUE!" in v or "#REF!" in v or "#NAME?" in v:
                    error_hits.append((r, c, v))
    print("Keyword hits (first 20):", keyword_hits[:20])
    print("Formula hits (first 20):", formula_hits[:20])
    print("Error-like string hits:", error_hits[:20])
    
    sheet_info[sname] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "best_header_row": best_header_row,
        "headers": headers,
        "keyword_hits": keyword_hits,
        "formula_hits": formula_hits,
        "error_hits": error_hits,
    }

print("\nInspection complete.")
