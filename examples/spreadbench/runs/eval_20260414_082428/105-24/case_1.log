    rows = []
    first_end = min(ws.max_row, n_first)
    for r in range(1, first_end + 1):
        rows.append((r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]))
    start_last = max(first_end + 1, ws.max_row - n_last + 1)
    if start_last <= ws.max_row:
        for r in range(start_last, ws.max_row + 1):
            rows.append((r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]))
    return rows

for sname in ["Open", "Productivity"]:
