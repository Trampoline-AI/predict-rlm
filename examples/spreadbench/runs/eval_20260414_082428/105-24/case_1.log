import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
open_ws = wb["Open"]
prod_ws = wb["Productivity"]

# Build lookup from Productivity A:B, starting after header row 3
lookup = {}
for r in range(4, prod_ws.max_row + 1):
    mud = prod_ws.cell(r, 1).value
    name = prod_ws.cell(r, 2).value
    if mud not in (None, "") and name not in (None, ""):
        lookup[str(mud).strip()] = str(name).strip()

# Replace IDs with Names in Open columns C and K
changes = []
for col in [3, 11]:  # C, K
    for r in range(4, open_ws.max_row + 1):
        cell = open_ws.cell(r, col)
        v = cell.value
        if v in (None, ""):
            continue
        key = str(v).strip()
        if key in lookup:
            new_val = lookup[key]
            if str(v).strip() != new_val:
                changes.append((cell.coordinate, v, new_val))
                cell.value = new_val

print("Total replacements:", len(changes))
print("First 10 changes:", changes[:10])

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", original_sheetnames)
    # rename by position to original names
    for i, ws in enumerate(wb2.worksheets):
        if i < len(original_sheetnames):
            ws.title = original_sheetnames[i]
    wb2.save(outfile)
else:
    print("Sheet names preserved:", wb2.sheetnames)

# Verification with data_only
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)

v_open = verify_wb["Open"]

print("\nVerify Open!C4:C23 and K4:K23")
bad = []
for r in range(4, v_open.max_row + 1):
    c_val = v_open[f"C{r}"].value
    k_val = v_open[f"K{r}"].value
    print(r, "C=", c_val, "| K=", k_val)
    if c_val in (None, ""):
        bad.append(f"C{r}")
    if k_val in (None, ""):
        bad.append(f"K{r}")

print("Blank target cells after save/recalc:", bad)

# Additional sanity check: confirm they are names, not original IDs
sample_ids = set(lookup.keys())
remaining_ids = []
for col in ["C", "K"]:
    for r in range(4, v_open.max_row + 1):
        val = v_open[f"{col}{r}"].value
        if val is not None and str(val).strip() in sample_ids:
            remaining_ids.append((f"{col}{r}", val))
print("Remaining raw IDs in target columns:", remaining_ids[:20])

output_spreadsheet = outfile
print("Final output_spreadsheet:", output_spreadsheet)
