import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and inspect target rows exactly
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheetnames:", orig_sheetnames)
print("Target column B header:", ws["B1"].value)
print("Current B2:B20 formulas/values BEFORE change:")
for r in range(2, ws.max_row + 1):
    v = ws[f"B{r}"].value
    if hasattr(v, "text"):
        v = v.text
    print(r, "A/F/G=", ws[f"A{r}"].value, ws[f"F{r}"].value, ws[f"G{r}"].value, "B=", v)

# Write formulas only for actual left-side data rows (A/F/G populated)
written_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    f = ws.cell(r, 6).value
    g = ws.cell(r, 7).value
    if a is not None and f is not None and g is not None:
        formula = f'=IFERROR(INDEX($V$2:$V$20,MATCH(1,($S$2:$S$20=$A{r})*($O$2:$O$20=$F{r})*($P$2:$P$20=$G{r}),0)),"")'
        ws.cell(r, 2).value = formula
        written_rows.append(r)
    else:
        # preserve blanks for non-data rows
        if ws.cell(r, 2).value not in (None, ""):
            ws.cell(r, 2).value = None

wb.save(outfile)
print("\nSaved initial output to:", outfile)
print("Rows written in B:", written_rows)
print("Formulas AFTER write:")
for r in written_rows:
    print(f"B{r} =", ws[f"B{r}"].value)

# Recalculate
recalc_result = await recalculate(outfile)
print("\nRecalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(outfile)
print("Sheetnames after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename back by position
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("\nVerification of target cells B2:B20:")
for r in range(2, ws_formula.max_row + 1):
    if r in written_rows:
        print(
            r,
            {
                "A": ws_formula[f"A{r}"].value,
                "F": ws_formula[f"F{r}"].value,
                "G": ws_formula[f"G{r}"].value,
                "formula": ws_formula[f"B{r}"].value,
                "cached_value": ws_values[f"B{r}"].value,
            }
        )

# Compare with Python expected values for sanity check
print("\nPython expected vs cached:")
for r in written_rows:
    a, f, g = ws_formula[f"A{r}"].value, ws_formula[f"F{r}"].value, ws_formula[f"G{r}"].value
