Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1 = wb["worksheet 1"]
ws2 = wb["worksheet2"]

# Reconfirm relevant area before writing
print("Original sheet names:", orig_sheetnames)
for r in range(2, ws2.max_row + 1):
    print("Before", r, ws2[f"A{r}"].value, ws2[f"B{r}"].value, ws2[f"C{r}"].value)

# Determine actual data extent in worksheet2: rows with a name in col A from row 3 onward
target_rows = [r for r in range(3, ws2.max_row + 1) if ws2[f"A{r}"].value not in (None, "")]
print("Target rows:", target_rows)

# Determine lookup range in worksheet 1 based on non-empty names in col A from row 3 onward
source_rows = [r for r in range(3, ws1.max_row + 1) if ws1[f"A{r}"].value not in (None, "")]
src_start = min(source_rows)
src_end = max(source_rows)
print("Source lookup range:", f"'worksheet 1'!$A${src_start}:$B${src_end}")

# Write formulas into the existing target column C
for r in target_rows:
    formula = f'=IF(IFERROR(VLOOKUP(A{r},\'worksheet 1\'!$A${src_start}:$B${src_end},2,FALSE),"")=B{r},"Matched","Not Matched")'
    ws2[f"C{r}"] = formula
    print(f"Wrote C{r}:", formula)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and computed values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
ws2f = wb_formula["worksheet2"]
ws2v = wb_values["worksheet2"]

print("Verification of target cells:")
for r in target_rows:
    print(
        f"Row {r}:",
        "name=", ws2v[f"A{r}"].value,
        "status=", ws2v[f"B{r}"].value,
        "formula=", ws2f[f"C{r}"].value,
        "value=", ws2v[f"C{r}"].value
    )

output_spreadsheet = outfile
```
