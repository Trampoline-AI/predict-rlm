import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        vals.append(ws.cell(r, c).value)
    return vals

def find_last_nonempty_row(ws):
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            return r
    return 0

for ws in wb.worksheets:
    last_row = find_last_nonempty_row(ws)
    last_col = ws.max_column
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, last_nonempty_row={last_row}, max_col={last_col}")
    headers1 = row_values(ws, 1, min(last_col, 20))
    headers2 = row_values(ws, 2, min(last_col, 20)) if ws.max_row >= 2 else []
    print("Row 1 values (first 20 cols):", headers1)
    print("Row 2 values (first 20 cols):", headers2)
    
    sample_top = list(range(1, min(last_row, 10) + 1))
    sample_bottom = list(range(max(1, last_row - 4), last_row + 1)) if last_row else []
    print("Top sample rows:")
    for r in sample_top:
        print(f"R{r}:", row_values(ws, r, min(last_col, 12)))
    print("Bottom sample rows:")
    for r in sample_bottom:
        print(f"R{r}:", row_values(ws, r, min(last_col, 12)))

    # Find formulas in first 200 rows / all cols, and some notes on formatting/comments
    formulas = []
    comments = []
    bordered = []
    for r in range(1, min(last_row, 200) + 1):
        for c in range(1, last_col + 1):
            cell = ws.cell(r, c)
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((cell.coordinate, v))
            if cell.comment is not None:
                comments.append((cell.coordinate, cell.comment.text[:80]))
            b = cell.border
            if any([
                getattr(b.left, "style", None),
                getattr(b.right, "style", None),
                getattr(b.top, "style", None),
                getattr(b.bottom, "style", None)
            ]):
                bordered.append(cell.coordinate)
    print(f"Found {len(formulas)} formulas in first {min(last_row,200)} rows.")
    if formulas[:20]:
        print("Sample formulas:", formulas[:20])
    print(f"Found {len(comments)} commented cells.")
    if comments[:10]:
        print("Sample comments:", comments[:10])
    print(f"Found {len(bordered)} cells with borders in first {min(last_row,200)} rows.")
    if bordered[:30]:
        print("Sample bordered cells:", bordered[:30])

    # Search text cells for likely relevant clues
    keywords = ["sum", "start", "end", "owner", "contributes", "thread", "prime", "p1", "p2", "border"]
    hits = []
    for r in range(1, last_row + 1):
        for c in range(1, last_col + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                lv = v.lower()
                if any(k in lv for k in keywords):
                    hits.append((ws.cell(r,c).coordinate, v))
    print(f"Keyword text hits: {len(hits)}")
    if hits[:30]:
        print("Sample keyword hits:", hits[:30])

    # merged ranges
    merged = list(ws.merged_cells.ranges)
    print(f"Merged ranges: {len(merged)}")
    if merged[:20]:
        print("Sample merged:", merged[:20])
