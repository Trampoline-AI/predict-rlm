```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["DATI"]

# Verify current target cells before modification
print("Before:")
for coord in ["B15", "C15", "B16", "C16"]:
    print(coord, ws[coord].value)

# Determine every-4th columns from C:N explicitly
start_col = 3  # C
end_col = 14   # N
every4_cols = list(range(start_col, end_col + 1, 4))
every4_letters = [get_column_letter(c) for c in every4_cols]
print("Every 4th columns from C:N:", every4_letters)

# Build corrected formulas for existing target cells
sum_terms = "+".join([f"${col}$3:${col}$10" for col in every4_letters])
ws["C15"] = f"=SUMPRODUCT(($A$3:$A$10=B15)*({sum_terms}))"
ws["C16"] = f"=SUMPRODUCT(($A$3:$A$10=B16)*({sum_terms}))"

print("\nAfter writing formulas:")
for coord in ["C15", "C16"]:
    print(coord, ws[coord].value)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position back to original
    for i, name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["DATI"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["DATI"]

print("\nVerification:")
for coord in ["B15", "C15", "B16", "C16"]:
    print(coord, "formula/raw:", ws_formula[coord].value, "| data_only:", ws_values[coord].value)

# Sanity-check expected values from source data in Python
def nz(v):
    return 0 if v is None else v

source_rows = list(range(3, 11))
for target_row in [15, 16]:
    key = ws_values[f"B{target_row}"].value
    matches = []
    total = 0
    for r in source_rows:
        if ws_values[f"A{r}"].value == key:
            vals = [nz(ws_values.cell(r, c).value) for c in every4_cols]
            matches.append((r, vals, sum(vals)))
            total += sum(vals)
    print(f"Key in B{target_row}={key}, matching rows/details={matches}, python_total={total}, sheet_value={ws_values[f'C{target_row}'].value}")

output_spreadsheet = outfile
