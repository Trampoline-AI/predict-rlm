print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Find actual used rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    if nonempty_rows:
        print("Used row range:", min(nonempty_rows), "to", max(nonempty_rows))
    else:
        print("No nonempty rows")
        return
    
    # Print first 10 rows and last 5 rows
    rows_to_show = list(range(1, min(ws.max_row, 10) + 1))
    tail = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in list(range(1, min(ws.max_row, 10) + 1)) + tail:
        if r not in seen:
            seen.add(r)
            rows_to_show.append(r)
    
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        # trim trailing Nones for readability
        while vals and vals[-1] is None:
            vals.pop()
        print(f"Row {r}:", vals[:40])
    
    # headers guesses from first few rows
    print("Row 1 headers-ish:", [ws.cell(1, c).value for c in range(1, min(ws.max_column, 20)+1)])
    if ws.max_row >= 2:
        print("Row 2:", [ws.cell(2, c).value for c in range(1, min(ws.max_column, 20)+1)])
    if ws.max_row >= 3:
        row3 = [ws.cell(3, c).value for c in range(1, min(ws.max_column, 40)+1)]
        print("Row 3:", row3)
    
    # Print formulas in row 3 if any
    formulas = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(3, c).value
        if isinstance(v, str) and v.startswith("="):
            formulas.append((get_column_letter(c), v))
    print("Formulas in row 3:", formulas[:50])
    
    # Search for keywords
    keywords = ["revenue", "gp", "total"]
    matches = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                low = v.lower()
                if any(k in low for k in keywords):
                    matches.append((r, c, get_column_letter(c), v))
    print("Keyword matches (first 50):", matches[:50])

for ws in wb.worksheets:
    sheet_summary(ws)
