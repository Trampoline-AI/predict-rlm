import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original input fresh
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Test safer bounded SUMPRODUCT formulas in the exact target cells
ws["D3"] = '=SUMPRODUCT(($F$2:$U$2=D$2)*($F3:$U3))'
ws["E3"] = '=SUMPRODUCT(($F$2:$U$2=E$2)*($F3:$U3))'

print("Written formulas:")
print("D3:", ws["D3"].value)
print("E3:", ws["E3"].value)

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Check sheet names after recalc, restore if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    for i, expected in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Restored sheet names:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
print("Formula view D3:", ws_formula["D3"].value)
print("Formula view E3:", ws_formula["E3"].value)

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

targets = ["I3", "M3", "Q3", "U3", "D3", "E3", "D11", "E11"]
print("Cached values:")
for coord in targets:
    print(coord, ws_values[coord].value)

# Also compute expected totals in Python for comparison
# Revenue from H,L,P,T
rev_expected = 0
for coord in ["H3", "L3", "P3", "T3"]:
    v = ws_values[coord].value if ws_values[coord].value is not None else ws[coord].value
    if isinstance(v, (int, float)):
        rev_expected += v

gp_expected = 0
for coord in ["I3", "M3", "Q3", "U3"]:
    v = ws_values[coord].value
    if isinstance(v, (int, float)):
        gp_expected += v

print("Expected revenue total from current blocks:", rev_expected)
print("Expected GP total from current blocks:", gp_expected)

output_spreadsheet = outfile
