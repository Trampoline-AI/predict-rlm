import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
print("Original sheetnames:", original_sheetnames)

# Find target sheet robustly
target_name_requested = "Final Recon Items"
target_ws = None
for name in wb.sheetnames:
    if name.lower() == target_name_requested.lower():
        target_ws = wb[name]
        break

if target_ws is None:
    raise ValueError(f"Could not find sheet matching {target_name_requested!r}")

ws = target_ws
print("Using sheet:", ws.title)
print("Dimensions before:", ws.max_row, ws.max_column)
print("Header row:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Inspect target cells/range before modification
amounts = []
rows_to_delete = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(r, 4).value
    print(f"D{r} before =", val, type(val).__name__)
    if isinstance(val, (int, float)):
        amounts.append(val)
        rows_to_delete.append(r)
    else:
        print(f"Skipping non-numeric row {r} in column D:", val)

total = sum(amounts)
print("Numeric amounts:", amounts)
print("Sum of numeric amounts:", total)
print("Absolute sum:", abs(total))
print("Threshold check abs(sum) < 0.011:", abs(total) < 0.011)

# Perform deletion only if condition is met
deleted_rows = []
if amounts and abs(total) < 0.011:
    # delete from bottom up
    for r in sorted(rows_to_delete, reverse=True):
        deleted_rows.append(r)
        ws.delete_rows(r, 1)
    print("Deleted data rows:", sorted(deleted_rows))
else:
    print("No rows deleted; threshold condition not met or no numeric rows found.")

print("Dimensions after deletion before save:", ws.max_row, ws.max_column)
for r in range(1, ws.max_row + 1):
    print("Row", r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheetnames after recalc reload:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames:
    # rename sheets back by position
    if len(wb2.sheetnames) == len(original_sheetnames):
        for ws2, orig in zip(wb2.worksheets, original_sheetnames):
            ws2.title = orig
        wb2.save(outfile)
        print("Restored original sheetnames:", original_sheetnames)
    else:
        print("Warning: sheet count changed unexpectedly; not renaming automatically.")

# Verification with data_only=True
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", verify_wb.sheetnames)

verify_ws = None
for name in verify_wb.sheetnames:
    if name.lower() == target_name_requested.lower():
        verify_ws = verify_wb[name]
        break
if verify_ws is None:
    raise ValueError("Target sheet missing after save/recalc")

print("Final target sheet:", verify_ws.title)
print("Final dimensions:", verify_ws.max_row, verify_ws.max_column)
for r in range(1, verify_ws.max_row + 1):
    print("Final row", r, [verify_ws.cell(r, c).value for c in range(1, verify_ws.max_column + 1)])

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
