import os
from openpyxl import load_workbook

# Load original workbook again for modification
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]

# Find and delete rows above first occurrence of "Invoice No." in column A, case-insensitive
deletions = []
for ws in wb.worksheets:
    first_match_row = None
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if v is not None and "invoice no." in str(v).lower():
            first_match_row = r
            break
    print(f"Before deletion - sheet {ws.title}: max_row={ws.max_row}, first_match_row={first_match_row}, A1={ws['A1'].value!r}")
    if first_match_row and first_match_row > 1:
        ws.delete_rows(1, first_match_row - 1)
        deletions.append((ws.title, first_match_row - 1))
    else:
        deletions.append((ws.title, 0))

wb.save(outfile)
print("Saved to:", outfile)
print("Deletions:", deletions)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names match originals
wb2 = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename sheets back by position
    for ws, orig_name in zip(wb2.worksheets, orig_sheet_names):
        ws.title = orig_name
    wb2.save(outfile)
    print("Renamed sheets back to originals and re-saved:", wb2.sheetnames)

# Verification with formulas/data_only not really needed, but reload data_only=True per instructions
verify_wb = load_workbook(outfile, data_only=True)
print("Verification sheet names:", verify_wb.sheetnames)

for ws in verify_wb.worksheets:
    print(f"Verified sheet {ws.title}: rows={ws.max_row}, cols={ws.max_column}")
    top_rows = min(5, ws.max_row)
    for r in range(1, top_rows + 1):
        print(f"  Row {r}: {[ws.cell(r, c).value for c in range(1, ws.max_column + 1)]}")
    print("  A1:", ws["A1"].value)
    matches = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if v is not None and "invoice no." in str(v).lower():
            matches.append((r, v))
    print("  Matches in column A after deletion:", matches)
    assert ws["A1"].value is not None and "invoice no." in str(ws["A1"].value).lower(), "A1 is not the expected preserved Invoice No. row"

output_spreadsheet = outfile
print("Ready to submit:", output_spreadsheet)
