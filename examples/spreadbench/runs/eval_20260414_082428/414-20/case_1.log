import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

workbook_summary = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 values / headers:", headers)
    
    top_n = min(10, ws.max_row)
    print(f"First {top_n} rows:")
    for r in range(1, top_n + 1):
        print(f"  Row {r}: {row_values(ws, r, ws.max_column)}")
    
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(f"  Row {r}: {row_values(ws, r, ws.max_column)}")
    
    # Inspect column A thoroughly for the target phrase
    colA = [ws.cell(r, 1).value for r in range(1, ws.max_row + 1)]
    matches = []
    for r, v in enumerate(colA, start=1):
        if v is not None and "invoice no." in str(v).lower():
            matches.append((r, v))
    print("Column A matches for 'Invoice No.' (case-insensitive):", matches[:20], "count=", len(matches))
    
    workbook_summary[ws.title] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "row1": headers,
        "matches": matches,
    }

print("\nSummary JSON:")
print(json.dumps(workbook_summary, default=str, indent=2)[:4000])
