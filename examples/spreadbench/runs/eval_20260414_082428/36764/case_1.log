print("Written formula to Sheet1!C2:", ws1["C2"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload to check if sheet names changed after recalc; rename back if needed
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names:
    # rename by position back to original names
    for idx, desired in enumerate(original_sheet_names):
        wb_post.worksheets[idx].title = desired
    wb_post.save(outfile)
    print("Renamed sheets back to:", original_sheet_names)

# Verification reload with formulas
