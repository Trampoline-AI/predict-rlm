import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Detect non-empty rows/cols more realistically
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    
    # Print first 10 rows
    top_n = min(ws.max_row, 10)
    print("Top rows:")
    for r in range(1, top_n + 1):
        print(r, row_values(ws, r))
    
    # Print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Bottom rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r))
    
    # Candidate header rows: first 5 rows
    print("Candidate header rows 1-5:")
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r)
        print(f"Row {r} headers?", [(get_column_letter(i+1), vals[i]) for i in range(len(vals)) if vals[i] is not None])
    
    # Print formulas/blanks in used range if small enough
    formula_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formula_cells[:20], "count=", len(formula_cells))
