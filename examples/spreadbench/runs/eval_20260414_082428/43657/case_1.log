Code:
```repl
import os, shutil
from collections import Counter
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload fresh workbook for writing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

GREEN = "FF92D050"

def get_rgb(cell):
    try:
        return cell.fill.start_color.rgb
    except Exception:
        return None

# Exact target names in column L
name_rows = []
for r in range(2, ws.max_row + 1):
    val = ws[f"L{r}"].value
    if val not in (None, ""):
        # stop after the contiguous list ends, once we've started and hit blanks
        name_rows.append((r, str(val).strip()))
    elif name_rows:
        break

print("Target name rows:", name_rows)

# Count occurrences in green-highlighted non-empty cells across the sheet
counts = Counter()
details = {name: [] for _, name in name_rows}

for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        val = cell.value
        if val in (None, ""):
            continue
        if cell.fill.patternType == "solid" and get_rgb(cell) == GREEN:
            text = str(val)
            for _, name in name_rows:
                if name in text:
                    counts[name] += 1
                    details[name].append(cell.coordinate)

# Print existing and new values before writing
for r, name in name_rows:
    old = ws[f"K{r}"].value
    print(f"Before K{r} old={old!r}, name={name!r}, new_count={counts[name]}, matches={details[name]}")

# Write literal counts into K2:K8
for r, name in name_rows:
    ws[f"K{r}"] = counts[name]

wb.save(output_path)
print("Saved:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if recalc changed them
wb2 = load_workbook(output_path)
current_names = wb2.sheetnames[:]
print("Sheet names after recalc:", current_names)
if current_names != orig_sheetnames and len(current_names) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb2[current_names[i]].title = s
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify output
verify_wb = load_workbook(output_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[orig_sheetnames[0]]

verified = {}
for r, name in name_rows:
    verified[f"K{r}"] = vws[f"K{r}"].value
print("Verified target cells:", verified)

# Sanity checks
for r, name in name_rows:
    val = vws[f"K{r}"].value
    assert val is not None, f"K{r} is blank"
    print(f"{name}: K{r}={val}")

final_output_spreadsheet = output_path
```
