print("\nName list from column L:", name_list)

counts = Counter()
matches_detail = defaultdict(list)
for coord, val in green_cells:
    text = str(val)
    for name in name_list:
        if name and name in text:
            counts[name] += 1
            matches_detail[name].append((coord, text))

print("\nCounts by listed name among green-filled cells:")
