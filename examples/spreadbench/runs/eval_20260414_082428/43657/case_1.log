        return cell.fill.start_color.rgb
    except Exception:
        return None

green_cells = []
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        val = cell.value
        if val is None or val == "":
