import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
orig_sheet_names = wb.sheetnames[:]

print("Sheet names:", wb.sheetnames)
print("Dimensions:", ws.max_row, ws.max_column)

# Safer table inspection
print("Worksheet tables:")
try:
    print("table names:", list(ws.tables.keys()))
    for name in ws.tables.keys():
        tbl = ws.tables[name]
        ref = getattr(tbl, "ref", None)
        print(" ", name, "ref=", ref, "obj_type=", type(tbl))
except Exception as e:
    print("table inspection error:", repr(e))

# Detailed inspection around target area
for r in range(18, 27):
    row_data = []
    for c in range(1, 9):
        cell = ws.cell(r, c)
        row_data.append({
            "coord": cell.coordinate,
            "value": cell.value,
            "fill_type": cell.fill.fill_type,
            "fill_rgb": cell.fill.fgColor.rgb,
            "start_rgb": cell.fill.start_color.rgb,
            "bold": cell.font.bold,
            "font_rgb": cell.font.color.rgb if cell.font.color and getattr(cell.font.color, "type", None) == "rgb" else None,
        })
    print(f"Row {r}:", row_data)

print("\nSource lookup rows A3:C17:")
for r in range(3, 18):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

print("\nCurrent target cells A20:C26:")
for r in range(20, 27):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value)

# Apply formulas to existing entry rows 20:26, matching description in col C
# Return empty string when C is blank.
for r in range(20, 27):
    ws[f"A{r}"] = f'=IF(C{r}="","",INDEX($A$3:$A$17,MATCH(C{r},$C$3:$C$17,0)))'
    ws[f"B{r}"] = f'=IF(C{r}="","",INDEX($B$3:$B$17,MATCH(C{r},$C$3:$C$17,0)))'

# Apply requested fill to A20:B26
fill = PatternFill(fill_type="solid", start_color="FFF2CC", end_color="FFF2CC")
for r in range(20, 27):
    for col in ("A", "B"):
        ws[f"{col}{r}"].fill = fill

# Save
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(outfile)
print("Post-recalc sheet names:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for i, s in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = s
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("\nFormulas written A20:B26:")
for r in range(20, 27):
