from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def display(v):
    if v is None:
        return None
    try:
        return str(v)
    except Exception:
        return repr(v)

for ws in wb.worksheets:
    print(f"\n--- SHEET: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # Header rows 1-5
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", vals)
    # First 10 rows
    print("First 10 rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"  {r}: {vals}")
    # Last 5 rows
    print("Last 5 rows:")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(f"  {r}: {vals}")

    # Print row fills and formulas around 1..40 or actual range
    print("\nRows 1-40 summary (values + fill colors A:C):")
    for r in range(1, min(ws.max_row, 40)+1):
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column,6)+1)]
        fills = []
        for c in range(1, min(ws.max_column,3)+1):
            cell = ws.cell(r,c)
            fills.append((get_column_letter(c), cell.fill.fill_type, cell.fill.fgColor.rgb, cell.fill.start_color.rgb))
        print(f"Row {r}: vals={vals} fills={fills}")

    # Explicitly inspect rows 15-30 all cols
    print("\nRows 15-30 detailed:")
    for r in range(15, min(ws.max_row, 30)+1):
        row_info = []
        for c in range(1, ws.max_column+1):
            cell = ws.cell(r,c)
            row_info.append({
                "coord": cell.coordinate,
                "value": display(cell.value),
                "fill": cell.fill.fgColor.rgb if cell.fill else None,
                "start": cell.fill.start_color.rgb if cell.fill else None
            })
        print(f"Row {r}: {row_info}")

    # Print formulas in sheet
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print("Formulas found (up to 30):", formulas[:30], "count=", len(formulas))
