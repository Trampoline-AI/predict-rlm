from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

sheet_info = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # detect likely header row among first 3 rows by non-empty count / stringiness
    candidate_headers = {}
    for r in range(1, min(4, ws.max_row + 1)):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v is not None and v != "" for v in vals)
        str_count = sum(isinstance(v, str) for v in vals if v is not None and v != "")
        candidate_headers[r] = (nonempty, str_count, vals)
        print(f"Row {r} preview:", vals[:min(15, ws.max_column)])
    header_row = max(candidate_headers, key=lambda r: (candidate_headers[r][1], candidate_headers[r][0]))
    headers = row_values(ws, header_row, ws.max_column)
    print(f"Chosen header row: {header_row}")
    print("Headers with column letters:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}: {h}")
    
    # print first 10 rows and last 5 rows
    print("\nFirst rows:")
    first_end = min(ws.max_row, max(header_row + 9, 10))
    for r in range(1, first_end + 1):
        print(f"Row {r}:", row_values(ws, r, min(ws.max_column, 15)))
    
    print("\nLast rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(f"Row {r}:", row_values(ws, r, min(ws.max_column, 15)))
    
    # specifically inspect A:M if present
    inspect_cols = min(ws.max_column, 13)
    if inspect_cols >= 13:
        print("\nA:M detailed sample rows:")
        sample_rows = list(range(max(1, header_row), min(ws.max_row, header_row + 8) + 1))
        if ws.max_row > header_row + 8:
            sample_rows += list(range(max(header_row + 9, ws.max_row - 4), ws.max_row + 1))
        seen = set()
        for r in sample_rows:
            if r in seen:
                continue
            seen.add(r)
            vals = row_values(ws, r, 13)
            print(f"Row {r} A:M:", vals)
            m = ws.cell(r, 13).value
            if isinstance(m, str) and m.startswith("="):
                print(f"  M{r} formula: {m}")
    
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "header_row": header_row,
        "headers": headers,
    }

# Try to identify the most relevant sheet by presence of A:M columns or "inventory" headers
relevant = []
for sname, info in sheet_info.items():
    headers_lower = [str(h).strip().lower() if h is not None else "" for h in info["headers"]]
    score = 0
    for token in ["item", "inventory", "cost", "begin", "received", "on hand"]:
        score += sum(token in h for h in headers_lower)
    if info["max_column"] >= 13:
        score += 2
    relevant.append((score, sname))
relevant.sort(reverse=True)
print("\nRelevant sheet ranking:", relevant)
