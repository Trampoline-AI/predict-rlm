Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

print("Pre-write target area A:M:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 14)])

# General FIFO ending-inventory weighted cost formula.
# Ending inventory consists of the newest remaining layers:
# PO4, then PO3, then PO2, then PO1, then beginning inventory.
for r in range(2, ws.max_row + 1):
    item = ws[f"A{r}"].value
    current_inv = ws[f"L{r}"].value
    old_val = ws[f"M{r}"].value
    print(f"Row {r}: item={item}, L{r}={current_inv}, existing M{r}={old_val}")
    
    formula = (
        f'=IF(OR(L{r}="",L{r}<=0),"",('
        f'MIN(L{r},N(J{r}))*N(K{r})+'
        f'MAX(MIN(L{r}-N(J{r}),N(H{r})),0)*N(I{r})+'
        f'MAX(MIN(L{r}-N(J{r})-N(H{r}),N(F{r})),0)*N(G{r})+'
        f'MAX(MIN(L{r}-N(J{r})-N(H{r})-N(F{r}),N(D{r})),0)*N(E{r})+'
        f'MAX(MIN(L{r}-N(J{r})-N(H{r})-N(F{r})-N(D{r}),N(B{r})),0)*N(C{r})'
        f')/L{r})'
    )
    ws[f"M{r}"] = formula
    print(f"Written M{r}: {formula}")

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open after recalc; restore original sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
original_names = ["Sheet1"]
if wb2.sheetnames != original_names and len(wb2.sheetnames) == len(original_names):
    for i, s in enumerate(wb2.worksheets):
        s.title = original_names[i]
    wb2.save(outfile)
    print("Renamed sheets back to original:", original_names)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nFormulas in target cells M2:M5:")
for r in range(2, wsf.max_row + 1):
    print(f"M{r} formula:", wsf[f"M{r}"].value)

# Verify evaluated values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
print("\nEvaluated target cells M2:M5:")
for r in range(2, wsv.max_row + 1):
    row_snapshot = [wsv.cell(r, c).value for c in range(1, 14)]
    print(f"Row {r} A:M values:", row_snapshot)
    print(f"Verified M{r}:", wsv[f'M{r}'].value)

output_spreadsheet = outfile
```
