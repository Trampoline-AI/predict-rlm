```repl
import os, shutil
from collections import OrderedDict, defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for writing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Build grouped data from source A:B, preserving first-seen order
grouped = OrderedDict()
for r in range(2, ws.max_row + 1):
    first = ws.cell(r, 1).value
    second = ws.cell(r, 2).value
    if first in (None, ""):
        continue
    if first not in grouped:
        grouped[first] = []
    if second not in (None, ""):
        grouped[first].append(second)

print("Grouped result to write:")
for k, vals in grouped.items():
    print(k, len(vals), vals)

# Determine target area
start_row = 2
start_col = 7  # G
seconds_start_col = 9  # I
num_groups = len(grouped)
max_seconds = max((len(v) for v in grouped.values()), default=0)
end_row = max(ws.max_row, start_row + num_groups + 5)
end_col = max(ws.max_column, seconds_start_col + max_seconds - 1)

print("Target write area:",
      f"{get_column_letter(start_col)}{start_row}:{get_column_letter(end_col)}{end_row}")

# Inspect current target cells before overwrite
print("Current target preview before writing:")
for r in range(1, min(ws.max_row, 8) + 1):
    vals = [ws.cell(r, c).value for c in range(start_col, min(end_col, start_col + 7) + 1)]
    print(r, vals)

# Clear prior output area under headers, including broken formula/demo values
for r in range(start_row, ws.max_row + 1):
    for c in range(start_col, end_col + 1):
        ws.cell(r, c).value = None

# Preserve existing headers; write output starting row 2
out_row = start_row
for first, vals in grouped.items():
    ws.cell(out_row, 7).value = first      # G
    ws.cell(out_row, 8).value = len(vals)  # H
    for i, val in enumerate(vals, start=0):
        ws.cell(out_row, 9 + i).value = val  # I onward
    out_row += 1

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename back in order
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Renamed sheets back to original:", orig_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["Sheet1"]

print("\nVerified target output region:")
verify_rows = len(grouped)
verify_cols = 2 + max_seconds
for r in range(1, 1 + verify_rows + 1):
    vals = [wsv.cell(r, c).value for c in range(7, 7 + verify_cols)]
    print(f"Row {r}: {vals}")

# Additional exact verification of expected cells
print("\nExact written cells:")
for idx, (first, vals) in enumerate(grouped.items(), start=2):
    row_vals = [wsv.cell(idx, 7).value, wsv.cell(idx, 8).value] + [
        wsv.cell(idx, 9 + j).value for j in range(max_seconds)
    ]
    print(f"G{idx}:M{idx} ->", row_vals)

# Sanity checks
issues = []
for idx, (first, vals) in enumerate(grouped.items(), start=2):
    if wsv.cell(idx, 7).value in (None, ""):
        issues.append(f"G{idx} blank")
    if wsv.cell(idx, 8).value in (None, ""):
        issues.append(f"H{idx} blank")

print("Issues:", issues if issues else "None")

final_output_spreadsheet = output_path
```
