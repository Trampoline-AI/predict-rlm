```repl
import os, shutil
from openpyxl import load_workbook

# Reload for clean manipulation
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect current target cells/formulas in D
print("D1:", ws["D1"].value)
for r in range(2, ws.max_row + 1):
    print(f"D{r} current:", ws.cell(r, 4).value)

# Build repeated list from columns A and B
pairs = []
r = 2
while True:
    company = ws.cell(r, 1).value
    count = ws.cell(r, 2).value
    if company is None and count is None:
        # stop after source block ends
        break
    pairs.append((company, count))
    r += 1

print("Source pairs:", pairs)

expanded = []
for company, count in pairs:
    if company is None or count in (None, ""):
        continue
    n = int(count)
    expanded.extend([company] * n)

print("Total repeated names:", len(expanded))
print("First 15 expanded:", expanded[:15])
print("Last 10 expanded:", expanded[-10:])

# Write into existing column D where started
ws["D1"] = ws["D1"].value  # preserve header
for idx, name in enumerate(expanded, start=2):
    ws.cell(idx, 4).value = name

# Clear any leftover values below the new output range in column D
for rr in range(len(expanded) + 2, ws.max_row + 1):
    ws.cell(rr, 4).value = None

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(out_path)
print("Post-recalc sheet names:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    # rename back if needed
    for i, orig_name in enumerate(wb.sheetnames):
        wb2.worksheets[i].title = orig_name
    wb2.save(out_path)
    print("Renamed sheets back to original:", wb.sheetnames)

# Verify output values using data_only
verify_wb = load_workbook(out_path, data_only=True)
vws = verify_wb[wb.sheetnames[0]]

target_end = len(expanded) + 1
print("Verify D1:D10:")
for rr in range(1, min(target_end, 10) + 1):
    print(rr, vws.cell(rr, 4).value)

print("Verify last 10 output rows in D:")
for rr in range(max(2, target_end - 9), target_end + 1):
    print(rr, vws.cell(rr, 4).value)

print("Target end row:", target_end)
print("D cells blank within target?", [rr for rr in range(2, target_end + 1) if vws.cell(rr, 4).value in (None, "")])

output_spreadsheet = out_path
```
