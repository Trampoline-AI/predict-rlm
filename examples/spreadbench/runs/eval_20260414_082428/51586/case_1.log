```repl
import os, shutil
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Re-open and inspect exact target cells/formulas/styles
wb = load_workbook(input_path)
ws = wb["Sheet1"]

print("Target cells before modification:")
for r in range(1, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    print(r, {"A": a, "B": b, "C": c, "C_data_type": ws[f'C{r}'].data_type})

print("\nExisting fills/fonts in column C:")
for r in range(1, ws.max_row + 1):
    cell = ws[f"C{r}"]
    fill = cell.fill.fgColor.rgb if cell.fill and cell.fill.fgColor else None
    print(r, cell.coordinate, cell.value, fill, cell.font.name, cell.font.bold)

# Apply Calibri font throughout existing used range
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        cell.font = copy(cell.font)
        cell.font = Font(
            name="Calibri",
            size=cell.font.sz,
            bold=cell.font.bold,
            italic=cell.font.italic,
            vertAlign=cell.font.vertAlign,
            underline=cell.font.underline,
            strike=cell.font.strike,
            color=cell.font.color.rgb if cell.font.color and getattr(cell.font.color, "type", None) == "rgb" else None,
        )

# Formula: TRUE only if store name ends exactly with city, so no additional text after city
for r in range(2, ws.max_row + 1):
    ws[f"C{r}"] = f'=RIGHT(TRIM(A{r}),LEN(TRIM(B{r})))=TRIM(B{r})'
    ws[f"C{r}"].fill = PatternFill(start_color="00B050", end_color="00B050", fill_type="solid")

# leave header fill as-is, but ensure header font also Calibri already set above
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet name if needed
wb_post = load_workbook(output_path)
original_sheetnames = ["Sheet1"]
print("Sheet names after recalc/save:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames:
    # rename first sheet back if necessary
    if len(wb_post.sheetnames) == len(original_sheetnames):
        for i, desired in enumerate(original_sheetnames):
            wb_post.worksheets[i].title = desired
        wb_post.save(output_path)
        print("Renamed sheets back to:", wb_post.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nFormulas in target cells:")
for r in range(2, wsf.max_row + 1):
    print(f"C{r} formula:", wsf[f'C{r}'].value)

wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Sheet1"]
print("\nVerified values after recalculation:")
for r in range(1, wsv.max_row + 1):
    print(r, wsv[f"A{r}"].value, "|", wsv[f"B{r}"].value, "|", wsv[f"C{r}"].value)

print("\nVerified fills/fonts:")
wb_style = load_workbook(output_path, data_only=False)
wss = wb_style["Sheet1"]
for r in range(1, wss.max_row + 1):
    c = wss[f"C{r}"]
    print(
        r,
        c.coordinate,
        c.value,
        c.fill.fgColor.rgb if c.fill and c.fill.fgColor else None,
        c.font.name,
    )
