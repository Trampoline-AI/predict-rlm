import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload original workbook for modification
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Modifying sheet:", ws.title)
print("Before write: H1 =", ws["H1"].value, "I1 =", ws["I1"].value)

# Write headers in exact target columns
ws["H1"] = "Debits"
ws["I1"] = "Credits"

# Populate rows based on Column C Amount
written = []
for r in range(2, ws.max_row + 1):
    amount = ws.cell(r, 3).value  # Column C
    # Clear target cells first only for rows being considered
    ws.cell(r, 8).value = None
    ws.cell(r, 9).value = None
    
    if isinstance(amount, (int, float)):
        if amount < 0:
            ws.cell(r, 8).value = abs(amount)
            written.append((r, amount, ws.cell(r, 8).value, None))
        elif amount > 0:
            ws.cell(r, 9).value = abs(amount)
            written.append((r, amount, None, ws.cell(r, 9).value))
        else:
            written.append((r, amount, None, None))
    else:
        written.append((r, amount, None, None))

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and fix any sheet-name change
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    print("Renaming sheets back to original names")
    for idx, name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = name
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Final sheet names:", wb_check.sheetnames)

# Verify using data_only view
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values[original_sheet_names[0]]

print("Verification target cells/range:")
print("H1:", wsv["H1"].value, "I1:", wsv["I1"].value)

verification_rows = []
for r in range(1, wsv.max_row + 1):
    row_info = {
        "row": r,
        "C": wsv.cell(r, 3).value,
        "H": wsv.cell(r, 8).value,
        "I": wsv.cell(r, 9).value,
    }
    verification_rows.append(row_info)

for row in verification_rows:
    print(row)

# Sanity checks
errors = []
if wsv["H1"].value != "Debits":
    errors.append(f'H1 header incorrect: {wsv["H1"].value}')
if wsv["I1"].value != "Credits":
    errors.append(f'I1 header incorrect: {wsv["I1"].value}')

for r in range(2, wsv.max_row + 1):
    amount = wsv.cell(r, 3).value
    debit = wsv.cell(r, 8).value
    credit = wsv.cell(r, 9).value
    if isinstance(amount, (int, float)):
        if amount < 0:
            if debit is None or abs(debit - abs(amount)) > 1e-9:
                errors.append(f"Row {r}: expected debit {abs(amount)}, got {debit}")
            if credit not in (None, ""):
                errors.append(f"Row {r}: credit should be blank, got {credit}")
        elif amount > 0:
            if credit is None or abs(credit - abs(amount)) > 1e-9:
                errors.append(f"Row {r}: expected credit {abs(amount)}, got {credit}")
            if debit not in (None, ""):
                errors.append(f"Row {r}: debit should be blank, got {debit}")
        else:
            if debit not in (None, "") or credit not in (None, ""):
                errors.append(f"Row {r}: zero amount should leave both blank")
    else:
        if debit not in (None, "") or credit not in (None, ""):
            errors.append(f"Row {r}: nonnumeric amount should leave both blank")

print("Errors:", errors if errors else "None")
print("Output path ready:", output_path)
