import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

input_path = input_spreadsheet
print("Input path exists:", os.path.exists(input_path), input_path)

wb = load_workbook(input_path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        headers2 = row_values(ws, 2, ws.max_column)
        print("Row 2:", headers2)
    # print first 10 rows and last 5 rows
    first_n = min(10, ws.max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # inspect relevant columns C, H, I for all non-empty-ish rows
    print("Relevant columns A:I snapshot (first 15 rows):")
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 9) + 1)]
        print(r, vals)
    
    for col in [3, 8, 9]:
        letter = get_column_letter(col)
        if col <= ws.max_column:
            print(f"Column {letter} sample values:")
            sample = []
            for r in range(1, min(ws.max_row, 15) + 1):
                v = ws.cell(r, col).value
                sample.append((r, v))
            print(sample)
        else:
            print(f"Column {letter} currently beyond max_column")
    
    # print any formulas in H or I
    for col in [8, 9]:
        if col <= ws.max_column:
            formulas = []
            for r in range(1, ws.max_row + 1):
                v = ws.cell(r, col).value
                if isinstance(v, str) and v.startswith("="):
                    formulas.append((r, v))
            print(f"Existing formulas in {get_column_letter(col)}:", formulas[:20], "count=", len(formulas))
