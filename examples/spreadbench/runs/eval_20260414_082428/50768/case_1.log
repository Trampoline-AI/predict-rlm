import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    
    # print first 10 rows and last 5 non-empty rows, truncating cells
    def row_vals(r):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r,c).value
            if hasattr(v, "text"):
                v = v.text
            vals.append(v)
        return vals
    
    print("First up to 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_vals(r))
    
    if nonempty_rows:
        tail = nonempty_rows[-5:]
        print("Last 5 non-empty rows:")
        for r in tail:
            print(r, row_vals(r))
    
    # potential headers in first 5 rows
    print("Potential header rows (1-5):")
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_vals(r)
        print(f"Row {r}:", vals)
    
    # print formulas in used range
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells (up to 20):", formulas[:20], "count=", len(formulas))

for ws in wb.worksheets:
    sheet_summary(ws)

# Also inspect merged cells
for ws in wb.worksheets:
    if ws.merged_cells.ranges:
        print(f"\nMerged ranges in {ws.title}:", list(ws.merged_cells.ranges))
    else:
        print(f"\nNo merged ranges in {ws.title}")
