```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target area and labels
print("Pre-write matrix body F12:H14:")
for r in range(12, 15):
    print(r, [ws.cell(r, c).value for c in range(6, 9)])

print("Impact labels E12:E14:", [ws[f"E{r}"].value for r in range(12, 15)])
print("Likelihood labels F15:H15:", [ws.cell(15, c).value for c in range(6, 9)])

# Build grouped IDs from source risk table
groups = defaultdict(list)
source_rows = []
for r in range(4, ws.max_row + 1):
    rid = ws.cell(r, 1).value
    impact = ws.cell(r, 2).value
    likelihood = ws.cell(r, 3).value
    # include only complete data rows from the risk table
    if rid is None and impact is None and likelihood is None:
        continue
    if all(v is not None for v in (rid, impact, likelihood)):
        try:
            imp = int(impact)
            lik = int(likelihood)
            rid_str = str(rid).strip()
            groups[(imp, lik)].append(rid_str)
            source_rows.append((r, rid_str, imp, lik))
        except Exception as e:
            print(f"Skipping row {r} due to conversion issue:", (rid, impact, likelihood), e)

print("Parsed source rows:", source_rows)
print("Grouped IDs:", dict(groups))

# Map matrix cells using visible axis labels
target_cells = []
for r in range(12, 15):      # impact rows
    impact_val = ws[f"E{r}"].value
    for c in range(6, 9):    # likelihood cols F:H
        likelihood_val = ws.cell(15, c).value
        cell = ws.cell(r, c)
        target_cells.append((cell.coordinate, impact_val, likelihood_val, cell.value))

print("Target cells before write:")
for item in target_cells:
    print(item)

# Write results
for r in range(12, 15):
    impact_val = ws[f"E{r}"].value
    impact_int = int(impact_val) if impact_val is not None else None
    for c in range(6, 9):
        likelihood_val = ws.cell(15, c).value
        likelihood_int = int(likelihood_val) if likelihood_val is not None else None
        result = ", ".join(groups.get((impact_int, likelihood_int), []))
        cell = ws.cell(r, c)
        old = cell.value
        # Write computed output; blank string for empty combinations
        cell.value = result if result != "" else None
        print(f"Wrote {cell.coordinate}: old={old!r} new={cell.value!r} for (Impact={impact_int}, Liklihood={likelihood_int})")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for i, name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verification using data_only after recalc
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheetnames:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]

print("Verified matrix F12:H14:")
verified = {}
for r in range(12, 15):
    row_out = []
    for c in range(6, 9):
        coord = wsv.cell(r, c).coordinate
        val = wsv.cell(r, c).value
        row_out.append((coord, val))
        verified[coord] = val
    print(row_out)

# Sanity check against expected
expected = {}
for r in range(12, 15):
    imp = int(wsv[f"E{r}"].value)
    for c in range(6, 9):
        lik = int(wsv.cell(15, c).value)
        exp = ", ".join(groups.get((imp, lik), []))
        expected[wsv.cell(r, c).coordinate] = exp if exp != "" else None

print("Expected target values:", expected)
print("Actual target values:", verified)

mismatches = []
for coord, exp in expected.items():
    act = verified.get(coord)
    if act != exp:
        mismatches.append((coord, exp, act))

print("Mismatches:", mismatches)

final_output_path = output_path
```
