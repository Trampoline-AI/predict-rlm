import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["raw 1"]

max_row = ws.max_row
print("Using max_row:", max_row)

# Print existing target formulas/values before modification
print("Before modification:")
for r in range(3, 9):
    print(f"F{r}={ws[f'F{r}'].value!r}, G{r}={ws[f'G{r}'].value!r}")

# Write formulas to G4:G8
for r in range(4, 9):
    formula = (
        f"=COUNTIFS('raw 1'!$A$2:$A${max_row},F{r},'raw 1'!$B$2:$B${max_row},\">0\",'raw 1'!$C$2:$C${max_row},\"<0\")+"
        f"COUNTIFS('raw 1'!$A$2:$A${max_row},F{r},'raw 1'!$B$2:$B${max_row},\">0\",'raw 1'!$C$2:$C${max_row},\"=0\")+"
        f"COUNTIFS('raw 1'!$A$2:$A${max_row},F{r},'raw 1'!$B$2:$B${max_row},\"=0\",'raw 1'!$C$2:$C${max_row},\"<0\")"
    )
    ws[f"G{r}"] = formula

# Add filter to A1:C(last row)
ws.auto_filter.ref = f"A1:C{max_row}"
print("AutoFilter set to:", ws.auto_filter.ref)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames:
    # rename by position back to original
    for i, sname in enumerate(original_sheetnames):
        wb2.worksheets[i].title = sname
    wb2.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas exist in normal workbook
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["raw 1"]
print("\nFormulas written in G4:G8:")
for r in range(4, 9):
    print(f"G{r} formula:", wsf[f"G{r}"].value)

# Verify computed values after recalculation
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["raw 1"]
print("\nVerified values in target cells:")
for r in range(4, 9):
    print(f"F{r}={wsv[f'F{r}'].value!r}, G{r}={wsv[f'G{r}'].value!r}")

print("\nVerified filter ref:", wb_formula["raw 1"].auto_filter.ref)

output_spreadsheet = outfile
