import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load fresh workbook for modification
wb2 = load_workbook(input_path)
original_sheet_names = wb2.sheetnames[:]
ws = wb2["Sheet1"]

start_row, end_row = 14, 83

# Inspect rows to be deleted before deletion
rows_to_delete = []
for r in range(start_row, min(end_row, ws.max_row) + 1):
    vals_fl = [ws.cell(r, c).value for c in range(6, 13)]  # F:L
    if all(v in (None, "") for v in vals_fl):
        rows_to_delete.append(r)

print("Rows to delete based on F:L all blank:", rows_to_delete)
print("Count to delete:", len(rows_to_delete))
print("Sample rows to keep before deletion:")
kept_preview = []
for r in range(start_row, min(end_row, ws.max_row) + 1):
    vals_fl = [ws.cell(r, c).value for c in range(6, 13)]
    if not all(v in (None, "") for v in vals_fl):
        kept_preview.append((r, [ws.cell(r, c).value for c in range(5, 14)]))  # E:M
print(kept_preview[:10])

# Delete entire rows bottom-up
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload after recalc, restore original sheet names if altered
wb_check = load_workbook(output_path)
current_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != original_sheet_names and len(current_names) == len(original_sheet_names):
    for i, orig_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verification using formula results/data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

print("Post-delete max_row:", wsv.max_row, "max_col:", wsv.max_column)

# Verify rows 13 onward around the target area
