orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def nonempty_row_count(ws):
    count = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            count += 1
    return count

for ws in wb.worksheets:
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column, "nonempty_rows:", nonempty_row_count(ws))
    headers1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers/sample:", headers1[:20])
    print("Row2 headers/sample:", headers2[:20])

    # first 10 rows, first up to 15 columns
    sample_cols = min(ws.max_column, 15)
    print("First 10 rows:")
