print("Last 10 rows after deletion, columns E:M:")
for r in range(max(1, wsv.max_row - 9), wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(5, 14)])

# Check that within the surviving rows from original target region start downward,
# there are no rows with F:L all blank until data ends for this block.
remaining_blank_fl = []
for r in range(14, wsv.max_row + 1):
    vals_em = [wsv.cell(r, c).value for c in range(5, 14)]
    # stop after the block becomes entirely blank for E:M for several trailing rows isn't necessary;
    # just record surviving blank F:L rows
