        vals = [ws.cell(r, c).value for c in range(1, sample_cols + 1)]
        print(r, vals)

    print("Last 5 rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, sample_cols + 1)]
        print(r, vals)

# Inspect specific likely target sheet/range
