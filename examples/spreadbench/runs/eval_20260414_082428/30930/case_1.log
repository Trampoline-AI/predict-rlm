Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally for editing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Compute desired values for rows where B == 1
b1_rows = [r for r in range(1, ws.max_row + 1) if ws.cell(r, 2).value == 1]
expected = {}

for i, r in enumerate(b1_rows):
    prev_r = b1_rows[i-1] if i > 0 else None
    start = (prev_r + 1) if prev_r is not None else 1
    end = r - 1
    count_pos = 0
    for rr in range(start, end + 1):
        a = ws.cell(rr, 1).value
        if isinstance(a, (int, float)) and a > 0:
            count_pos += 1
    expected[r] = count_pos

print("Expected target values for rows where B=1:", expected)

# Apply only to target rows in column C; preserve correct existing values
changes = []
for r in range(1, ws.max_row + 1):
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3)
    if b == 1:
        desired = expected[r]
        if c.value != desired:
            changes.append((r, c.value, desired))
            c.value = desired
    else:
        # Leave non-target rows blank; only clear if there is unexpected content
        if c.value not in (None, ""):
            changes.append((r, c.value, None))
            c.value = None

print("Changes made:", changes)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc to check sheet names; rename back if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # Rename by position to restore original names
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["Sheet1"]

verification = []
non_target_nonblank = []
for r in range(1, wsv.max_row + 1):
    a = wsv.cell(r, 1).value
    b = wsv.cell(r, 2).value
    c = wsv.cell(r, 3).value
    if b == 1:
        verification.append((r, a, b, c, expected[r], c == expected[r]))
    else:
        if c not in (None, ""):
            non_target_nonblank.append((r, c))

print("\nVerification rows where B=1:")
for row in verification:
    print(row)

print("\nNon-target rows with nonblank C (should be empty):", non_target_nonblank)
print("All target rows correct?:", all(v[-1] for v in verification))

final_output_spreadsheet = output_path
```
