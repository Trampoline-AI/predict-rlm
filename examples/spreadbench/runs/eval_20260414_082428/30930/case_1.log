from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect existing C cells: value + type/formula
print("Existing nonblank C cells with types:")
for r in range(1, ws.max_row + 1):
    c = ws.cell(r, 3)
    if c.value not in (None, ""):
        print(f"Row {r}: C={c.value!r}, data_type={c.data_type}")

# Print each segment between B=1 rows and count positive A values in between
b1_rows = [r for r in range(1, ws.max_row + 1) if ws.cell(r, 2).value == 1]
print("\nB=1 rows:", b1_rows)

segments = []
for i, r in enumerate(b1_rows):
    prev_r = b1_rows[i-1] if i > 0 else None
    start = (prev_r + 1) if prev_r is not None else 1
    end = r - 1
    rows = []
    count_pos = 0
    for rr in range(start, end + 1):
        a = ws.cell(rr, 1).value
        b = ws.cell(rr, 2).value
        rows.append((rr, a, b))
        if isinstance(a, (int, float)) and a > 0:
            count_pos += 1
    segments.append((prev_r, r, count_pos, rows))

print("\nSegment summaries (count positive A values before each B=1 row):")
for prev_r, r, count_pos, rows in segments:
    print(f"Target row {r}, previous B=1 row {prev_r}, count={count_pos}, current C={ws.cell(r,3).value!r}")
