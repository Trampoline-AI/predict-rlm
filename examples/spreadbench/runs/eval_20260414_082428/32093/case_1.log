import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Re-open for modification
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Confirming target area and example pattern:")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 9)]
    print(r, vals)

# Write formulas into column F for all actual data rows
for r in range(2, ws.max_row + 1):
    # Skip fully empty rows just in case
    if all(ws.cell(r, c).value is None for c in range(1, 9)):
        continue
    formula = (
        f'=IF(COUNTA(C{r}:E{r})=0,'
        f'B{r},'
        f'IF(COUNTA(C{r}:E{r})=1,'
        f'IF(C{r}<>"",C{r},IF(D{r}<>"",D{r},E{r})),'
        f'"ERROR"))'
    )
    ws.cell(r, 6).value = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names and len(wb_after.sheetnames) == len(original_sheet_names):
    for i, original_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verify formulas and evaluated values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]
print("\nFormulas written in F2:F15:")
for r in range(2, ws_formula.max_row + 1):
    print(r, ws_formula.cell(r, 6).value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]
print("\nEvaluated values in F2:F15:")
for r in range(2, ws_values.max_row + 1):
    print(f"F{r} =", ws_values.cell(r, 6).value)

verified_output = output_path
```
