import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_info = {}
for s in wb.sheetnames:
    ws = wb[s]
    # Determine apparent used headers from first non-empty row among first few rows
    header_row = None
    for r in range(1, min(ws.max_row, 5)+1):
        vals = row_values(ws, r)
        if any(v is not None and v != "" for v in vals):
            header_row = r
            break
    headers = row_values(ws, header_row) if header_row else []
    # trim trailing Nones for display
    while headers and headers[-1] is None:
        headers.pop()
    sheet_info[s] = {"max_row": ws.max_row, "max_col": ws.max_column, "header_row": header_row, "headers": headers}
    print(f"\nSheet '{s}': max_row={ws.max_row}, max_col={ws.max_column}, header_row={header_row}")
    print("Headers:", headers)

    # sample first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        vals = row_values(ws, r)
        while vals and vals[-1] is None:
            vals.pop()
        print(f"  Row {r}: {vals}")
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            vals = row_values(ws, r)
            while vals and vals[-1] is None:
                vals.pop()
            print(f"  Row {r}: {vals}")

# Focus on SH and CP because instruction mentions both
for target in ["SH", "CP"]:
    if target in wb.sheetnames:
        ws = wb[target]
        print(f"\nDetailed scan for sheet {target}:")
        blank_rows = []
        nonblank_rows = []
        for r in range(1, ws.max_row+1):
            vals = row_values(ws, r)
            is_blank = not any(v is not None and v != "" for v in vals)
            if is_blank:
                blank_rows.append(r)
            else:
                nonblank_rows.append(r)
        print(f"  Total rows: {ws.max_row}")
        print(f"  Blank rows count: {len(blank_rows)}")
        print(f"  First 20 blank rows: {blank_rows[:20]}")
        print(f"  First 20 nonblank rows: {nonblank_rows[:20]}")
        # print around first few blank rows to understand layout
        for br in blank_rows[:5]:
            start = max(1, br-1)
            end = min(ws.max_row, br+1)
            print(f"  Around blank row {br}:")
            for r in range(start, end+1):
                vals = row_values(ws, r)
                while vals and vals[-1] is None:
                    vals.pop()
                print(f"    Row {r}: {vals}")
