import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Reload workbook for modification
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["SH"]

def is_blank_row(ws, r):
    return not any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1))

# Inspect target rows before modification
blank_rows_before = [r for r in range(1, ws.max_row + 1) if is_blank_row(ws, r)]
print("Before deletion:")
print("  max_row:", ws.max_row)
print("  blank rows:", blank_rows_before)

# Delete blank rows from bottom upward
for r in reversed(blank_rows_before):
    ws.delete_rows(r, 1)

print("After in-memory deletion:")
print("  max_row:", ws.max_row)
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    while vals and vals[-1] is None:
        vals.pop()
    print(f"  Row {r}: {vals}")

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position back to original names
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(outfile)
    print("Restored original sheet names:", orig_sheet_names)

# Verify using data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["SH"]

blank_rows_after = [r for r in range(1, wsv.max_row + 1) if not any(wsv.cell(r, c).value not in (None, "") for c in range(1, wsv.max_column + 1))]
print("Verification:")
print("  max_row:", wsv.max_row)
print("  blank rows remaining:", blank_rows_after)

for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    while vals and vals[-1] is None:
        vals.pop()
    print(f"  Row {r}: {vals}")

output_spreadsheet = outfile
