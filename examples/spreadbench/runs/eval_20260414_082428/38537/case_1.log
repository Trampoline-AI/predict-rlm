from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Writing formulas on sheet:", ws.title)
print("B2 =", ws["B2"].value)
print("Existing A3:A10 before:")
for r in range(3, 11):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

# Write formulas into A3:Amax_row
for r in range(3, ws.max_row + 1):
    ws[f"A{r}"] = f'=IF(B{r}="","",$B$2&"-02-"&TEXT(COUNTIF($B$3:B{r},"<>")+9,"000"))'

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename sheets back by position
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with data_only=True
