import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original workbook for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target column/cells before writing
print("Sheet names before write:", wb.sheetnames)
print("Target header F1:", ws["F1"].value)
print("Source header D1:", ws["D1"].value)
for r in range(2, ws.max_row + 1):
    print(f"Before write row {r}: D{r}={ws[f'D{r}'].value!r}, F{r}={ws[f'F{r}'].value!r}")

# Write formulas to all relevant existing data rows only
for r in range(2, ws.max_row + 1):
    d_val = ws.cell(r, 4).value
    # only populate rows that have source data in D and blank/empty F
    if d_val not in (None, ""):
        current_f = ws.cell(r, 6).value
        if current_f in (None, ""):
            ws.cell(r, 6).value = f'=IF(ISNUMBER(SEARCH("BA",D{r})),"BA",IF(ISNUMBER(SEARCH("MA",D{r})),"MA",""))'

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# After recalc, fix any changed sheet names back to original
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for idx, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas and calculated values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("Verification of target cells F2:F5:")
for r in range(2, ws_formula.max_row + 1):
    print(
        f"Row {r}: D{r}={ws_formula[f'D{r}'].value!r}, "
        f"F{r}_formula={ws_formula[f'F{r}'].value!r}, "
        f"F{r}_value={ws_values[f'F{r}'].value!r}"
    )

output_spreadsheet = output_path
