import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(input_path), input_path)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

inspection = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        row2 = row_values(ws, 2, ws.max_column)
        print("Row 2:", row2)
    first_n = min(10, ws.max_row)
    last_start = max(1, ws.max_row - 4)
    print("First rows sample:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    print("Last rows sample:")
    for r in range(last_start, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Print D and F columns specifically, since instruction references D2 and F2
    d_col = column_index_from_string("D")
    f_col = column_index_from_string("F")
    print("Column letters check:", get_column_letter(d_col), get_column_letter(f_col))
    print("D/F values and formulas for first up to 15 rows:")
    df_preview = []
    for r in range(1, min(ws.max_row, 15) + 1):
        d = ws.cell(r, d_col).value if d_col <= ws.max_column else None
        f = ws.cell(r, f_col).value if f_col <= ws.max_column else None
        df_preview.append((r, d, f))
        print(f"Row {r}: D={d!r}, F={f!r}")
    inspection[sname] = {"headers": headers, "df_preview": df_preview}

print("\nDone inspection.")
