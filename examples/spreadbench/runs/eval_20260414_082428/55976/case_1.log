Code:
```repl
import os
from openpyxl import load_workbook

# Load original workbook fresh
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Reconfirm target area before writing
print("Target labels row 24:", [ws.cell(24, c).value for c in range(6, 10)])
print("Current target cells F25:I25:", [ws.cell(25, c).value for c in range(6, 10)])

# Write formulas into the existing target cells.
# Logic: for each survey row, count it if its question number in col A appears in that category's list
# and the Yes column C contains "x". Category lists must include row 4 per instruction.
formula_map = {
    "F25": '=SUMPRODUCT((COUNTIF($F$4:$F$23,$A$5:$A$84)>0)*($C$5:$C$84="x"))',
    "G25": '=SUMPRODUCT((COUNTIF($G$4:$G$23,$A$5:$A$84)>0)*($C$5:$C$84="x"))',
    "H25": '=SUMPRODUCT((COUNTIF($H$4:$H$23,$A$5:$A$84)>0)*($C$5:$C$84="x"))',
    "I25": '=SUMPRODUCT((COUNTIF($I$4:$I$23,$A$5:$A$84)>0)*($C$5:$C$84="x"))',
}
for cell_ref, formula in formula_map.items():
    ws[cell_ref] = formula

# Save to output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved formula version to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    for i, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(out_path)
    print("Restored sheet names:", orig_sheet_names)

# Verify formulas exist
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("Stored formulas F25:I25:", [wsf.cell(25, c).value for c in range(6, 10)])

# Verify calculated values
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values[orig_sheet_names[0]]
vals = [wsv.cell(25, c).value for c in range(6, 10)]
print("Evaluated values F25:I25:", vals)

# Also compute expected values in Python for sanity check
yes_questions = {
    wsv.cell(r, 1).value
    for r in range(5, 85)
    if str(wsv.cell(r, 3).value).strip().lower() == "x"
}
expected = []
for col in range(6, 10):
    mapped = [wsv.cell(r, col).value for r in range(4, 24)]
    mapped = [m for m in mapped if isinstance(m, (int, float))]
    expected.append(sum(1 for m in mapped if m in yes_questions))
print("Expected Python totals F25:I25:", expected)

output_spreadsheet = out_path
```
