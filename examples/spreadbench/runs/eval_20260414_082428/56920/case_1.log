import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
ws = wb["Sheet1"]

# Verify target area before writing
print("Before writing, Column C rows 2-8:")
for r in range(2, 9):
    print(r, "B=", ws[f"B{r}"].value, "C=", ws[f"C{r}"].value)

# Fill only blank result cells in column C for rows with source text in column B
written = []
for r in range(3, ws.max_row + 1):
    bval = ws[f"B{r}"].value
    cval = ws[f"C{r}"].value
    if bval not in (None, "") and cval in (None, ""):
        formula = f'=IFERROR(MID(B{r},SEARCH("955",B{r}),10),IFERROR(MID(B{r},SEARCH("CHK",B{r}),10),""))'
        ws[f"C{r}"] = formula
        written.append((r, formula))

print("Written formulas:", written)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation and check sheet names
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != ["Sheet1"]:
    # Rename first sheet back if needed
    wb_after[wb_after.sheetnames[0]].title = "Sheet1"
    wb_after.save(outfile)
    print("Renamed sheet back to Sheet1 and re-saved.")

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]

print("Verified target cells C3:C8 after recalculation (data_only=True):")
for r in range(3, 9):
    print(f"C{r}:", repr(wsv[f"C{r}"].value))

# Also print formulas in normal mode for rows we wrote
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formulas/values in C3:C8 (formula view):")
for r in range(3, 9):
    print(f"C{r}:", repr(wsf[f"C{r}"].value))
