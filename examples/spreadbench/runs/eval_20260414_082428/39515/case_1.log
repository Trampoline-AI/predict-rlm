import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers:", headers)
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row2:", headers2)
    sample_first = list(range(1, min(ws.max_row, 10) + 1))
    sample_last = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in sample_first + sample_last:
        if r not in seen:
            seen.add(r)
            rows_to_show.append(r)
    # Print compact row dicts for non-empty columns
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Search for columns / cells relevant to month/year and target O
for ws in wb.worksheets:
    print(f"\nInspecting formulas/values in sheet {ws.title}")
    for c in range(1, ws.max_column + 1):
        v = ws.cell(1, c).value
        if v is not None:
            print(f"Col {get_column_letter(c)} header:", v)
    if ws.max_column >= 15:
        print("Column O header row1:", ws["O1"].value)
        # Print O for sample rows and nearby columns J:O or broader
        for r in range(1, min(ws.max_row, 15) + 1):
            row_vals = {get_column_letter(c): ws.cell(r, c).value for c in range(max(1, 9), min(ws.max_column, 17) + 1)}
            print(f"Row {r} I:Q-ish:", row_vals)
