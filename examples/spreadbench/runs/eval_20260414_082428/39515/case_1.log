```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print current target formulas before modifying
print("Before modification:")
for r in range(2, ws.max_row + 1):
    print(f"Row {r}: A={ws[f'A{r}'].value}, B={ws[f'B{r}'].value}, C={ws[f'C{r}'].value}, O={ws[f'O{r}'].value}")

# Apply updated formula to all populated data rows
for r in range(2, ws.max_row + 1):
    if ws[f"A{r}"].value is None and ws[f"B{r}"].value is None:
        continue
    ws[f"O{r}"] = f'=IF($B{r}=2022,$C{r},INDEX($C{r}:$N{r},MATCH($A{r},$C$1:$N$1,0)))'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename by position to original names
    for i, name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and computed values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification:")
for r in range(2, ws_formula.max_row + 1):
    month_val = ws_values[f"A{r}"].value
    year_val = ws_values[f"B{r}"].value
    jan_val = ws_values[f"C{r}"].value
    formula = ws_formula[f"O{r}"].value
    result = ws_values[f"O{r}"].value
    print(f"Row {r}: month={month_val}, year={year_val}, JAN={jan_val}, formula={formula}, O_value={result}")

# Additional sanity checks for 2022 rows and 2023 rows
print("\nSanity checks:")
for r in range(2, ws_values.max_row + 1):
    if ws_values[f"B{r}"].value == 2022:
        print(f"2022 row {r}: C={ws_values[f'C{r}'].value}, O={ws_values[f'O{r}'].value}")
    elif ws_values[f"B{r}"].value == 2023:
        print(f"2023 row {r}: month={ws_values[f'A{r}'].value}, O={ws_values[f'O{r}'].value}")
