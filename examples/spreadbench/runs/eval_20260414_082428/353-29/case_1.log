            prev = r
        else:
            runs.append((start, prev))
            start = prev = r
    runs.append((start, prev))

print("\nAll blank runs:", runs)
for start, end in runs:
    print(f"\nRun {start}-{end}, before={ws.cell(start-1,1).value if start>1 else None}, after={ws.cell(end+1,1).value if end<ws.max_row else None}")
    for r in range(max(1, start-2), min(ws.max_row, end+2)+1):
        print(r, ws.cell(r,1).value, ws.cell(r,2).value)

# Verify target column A currently has no formulas and identify rows to write
formula_cells_A = []
targets = []
for r in range(2, ws.max_row+1):
    a = ws.cell(r,1).value
    if isinstance(a, str) and a.startswith("="):
        formula_cells_A.append((r, a))
    if a in (None, ""):
        targets.append(r)

print("\nFormula cells in A:", formula_cells_A)
print("Target rows to fill:", targets)

# Build assignments based on previous numeric URN and sequential letters until next numeric row
letters = list(string.ascii_lowercase)

def num_to_letters(n):
    # 1 -> a, 26 -> z, 27 -> aa
    out = ""
    while n > 0:
        n -= 1
        out = chr(ord('a') + (n % 26)) + out
        n //= 26
    return out

assignments = {}
current_base = None
current_suffix_idx = 0

for r in range(2, ws.max_row+1):
    val = ws.cell(r,1).value
    if val in (None, ""):
        if current_base is None:
            raise ValueError(f"Blank URN at row {r} before any numeric base found")
        current_suffix_idx += 1
        assignments[r] = f"{current_base}{num_to_letters(current_suffix_idx)}"
    else:
        sval = str(val).strip()
        m_num = re.fullmatch(r"(\d+)", sval)
        m_alpha = re.fullmatch(r"(\d+)([A-Za-z]+)", sval)
        if m_num:
            current_base = m_num.group(1)
            current_suffix_idx = 0
        elif m_alpha:
            # Existing example rows: continue counting from current base if same base.
            base, suf = m_alpha.groups()
            current_base = base
            # convert suffix to index so that after 5f next blank would become 5g if it appeared
            idx = 0
            for ch in suf.lower():
                idx = idx * 26 + (ord(ch) - ord('a') + 1)
            current_suffix_idx = idx
        else:
            print("Nonstandard existing URN encountered:", r, sval)

print("\nPlanned assignments sample (first 30):", list(assignments.items())[:30])
print("Planned assignments sample (last 15):", list(assignments.items())[-15:])
print("Total assignments:", len(assignments), "expected blanks:", len(targets))

# Apply assignments
for r, v in assignments.items():
    ws.cell(r,1).value = v

# Verify in-memory
print("\nPost-write check around all runs:")
for start, end in runs:
    print(f"\nRun {start}-{end}")
    for r in range(max(2, start-1), min(ws.max_row, end+1)+1):
        print(r, ws.cell(r,1).value, ws.cell(r,2).value)

# Save output
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename by position to original names
    for i, expected in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[orig_sheet_names[0]]

# Check target cells
missing_after = []
verify_pairs = []
for r in targets:
    val = wsv.cell(r,1).value
    verify_pairs.append((r, val))
    if val in (None, ""):
        missing_after.append(r)

print("\nVerification sample first 30 target rows:", verify_pairs[:30])
print("Verification sample last 15 target rows:", verify_pairs[-15:])
print("Missing after save/recalc:", missing_after)

# More explicit targeted verification around runs
for start, end in runs:
    print(f"\nVerified run {start}-{end}:")
    for r in range(start, end+1):
        print(r, wsv.cell(r,1).value)

output_spreadsheet = outfile
print("\nPrepared output file:", output_spreadsheet)
