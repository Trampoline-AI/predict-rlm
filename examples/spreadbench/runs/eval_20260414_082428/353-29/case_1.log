import os, json, re, string
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction preview:", instruction[:500])

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row 2:", row_values(ws, 2, min(ws.max_column, 8)))
    # print first 10 rows, first up to 6 cols
    sample_cols = min(ws.max_column, 6)
    print(f"First {min(10, ws.max_row)} rows (cols A:{get_column_letter(sample_cols)}):")
    for r in range(1, min(10, ws.max_row)+1):
        print(r, row_values(ws, r, sample_cols))
    print(f"Last {min(5, ws.max_row)} rows (cols A:{get_column_letter(sample_cols)}):")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        print(r, row_values(ws, r, sample_cols))

# Deeper inspection on first sheet
ws = wb[wb.sheetnames[0]]
print("\nInspecting column A/B patterns on first sheet:", ws.title)

# Find blank/nonblank patterns in col A
blank_rows = []
alpha_rows = []
numericish_rows = []
for r in range(1, ws.max_row+1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a in (None, ""):
        blank_rows.append((r, a, b))
    else:
        s = str(a).strip()
        if re.fullmatch(r"\d+[A-Za-z]+", s):
            alpha_rows.append((r, s, b))
        elif re.fullmatch(r"\d+", s):
            numericish_rows.append((r, s, b))
        else:
            if len(alpha_rows) < 10:
                alpha_rows.append((r, s, b))

print("Count blank rows in col A:", len(blank_rows))
print("First 20 blank rows with col B:", blank_rows[:20])

print("First 20 numeric URNs:", numericish_rows[:20])
print("First 20 alphanumeric/nonstandard URNs:", alpha_rows[:20])

# Show neighborhoods around first few blank runs
runs = []
if blank_rows:
    start = prev = blank_rows[0][0]
    for r, _, _ in blank_rows[1:]:
        if r == prev + 1:
            prev = r
        else:
            runs.append((start, prev))
            start = prev = r
    runs.append((start, prev))
print("Blank row runs in col A (first 20):", runs[:20])

for start, end in runs[:10]:
    print(f"\nNeighborhood around blank run {start}-{end}:")
    r0 = max(1, start-3)
    r1 = min(ws.max_row, end+3)
    for r in range(r0, r1+1):
        print(r, [ws.cell(r, c).value for c in range(1, min(ws.max_column, 4)+1)])
