import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook with formulas
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Daily Numbers"]
err_ws = wb["Errors"]

print("Original sheet names:", orig_sheetnames)
print("Daily Numbers max_row/max_col:", ws.max_row, ws.max_column)
print("Errors max_row/max_col:", err_ws.max_row, err_ws.max_column)

# Determine actual data rows in Daily Numbers
data_rows = []
for r in range(3, ws.max_row + 1):
    if ws[f"A{r}"].value is not None and ws[f"L{r}"].value is not None:
        data_rows.append(r)
print("Target Daily Numbers rows:", data_rows)

# Build bounded references for LibreOffice compatibility
err_last = err_ws.max_row
qty_rng = f"Errors!$M$2:$M${err_last}"
whs_rng = f"Errors!$I$2:$I${err_last}"
date_rng = f"Errors!$Q$2:$Q${err_last}"
code_rng = f"Errors!$B$2:$B${err_last}"
user_rng = f"Errors!$AB$2:$AB${err_last}"

# Print a couple of existing formulas before overwrite
for r in data_rows[:3]:
    print("BEFORE", r, {c: ws[f"{c}{r}"].value for c in ["N","O","P","Q","R"]})

def user_or_sumifs_formula(row_num, code_ref, positive_only=False):
    parts = []
    for user_col in ["G", "H", "I", "J"]:
        crits = [
            f'SUMIFS({qty_rng},{whs_rng},$A{row_num},{date_rng},$L{row_num},{code_rng},${code_ref}{row_num},{user_rng},${user_col}{row_num}'
        ]
        if positive_only:
            crits[0] += f',{qty_rng},">0"'
        crits[0] += ")"
        parts.append(crits[0])
    return "=" + "+".join(parts)

# Replace target formulas in existing cells N:R
for r in data_rows:
    # II
    ws[f"N{r}"] = user_or_sumifs_formula(r, "B", positive_only=False)
    # IR positive-only
    ws[f"O{r}"] = user_or_sumifs_formula(r, "C", positive_only=True)
    # IT
    ws[f"P{r}"] = user_or_sumifs_formula(r, "D", positive_only=False)
    # OV
    ws[f"Q{r}"] = user_or_sumifs_formula(r, "E", positive_only=False)
    # PI
    ws[f"R{r}"] = user_or_sumifs_formula(r, "F", positive_only=False)

# Print a couple of new formulas
for r in data_rows[:3]:
    print("AFTER", r, {c: ws[f"{c}{r}"].value for c in ["N","O","P","Q","R"]})

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # Rename sheets back by position
    for idx, original_name in enumerate(orig_sheetnames):
        wb_check.worksheets[idx].title = original_name
    wb_check.save(output_path)
    print("Renamed sheets back to original names:", orig_sheetnames)

# Verify with formulas
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Daily Numbers"]
print("\nVerified written formulas (rows 3:6, N:R):")
for r in data_rows[:4]:
    print(r, {c: ws_formula[f"{c}{r}"].value for c in ["N","O","P","Q","R"]})

# Verify cached values
wb_values = load_workbook(output_path, data_only=True)
print("Sheet names value wb:", wb_values.sheetnames)
ws_values = wb_values["Daily Numbers"]

print("\nVerified cached values (rows 3:10, M:R):")
for r in data_rows[:8]:
    vals = {c: ws_values[f"{c}{r}"].value for c in ["M","N","O","P","Q","R"]}
    print(r, vals)

# Sanity checks for blanks in target cells
problems = []
for r in data_rows:
    for c in ["N","O","P","Q","R"]:
        v = ws_values[f"{c}{r}"].value
        if v is None:
            problems.append(f"{c}{r}")
print("Blank target cells after recalc:", problems[:20], "count=", len(problems))

final_output_path = output_path
