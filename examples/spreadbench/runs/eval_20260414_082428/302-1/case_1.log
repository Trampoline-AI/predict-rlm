    dmr = displayed_max_row(ws)
    dmc = displayed_max_col(ws)
    headers = row_values(ws, 1, dmc) if dmr >= 1 else []
    print(f"\n--- Sheet: {s} ---")
    print("ws.max_row/max_col:", ws.max_row, ws.max_column)
    print("displayed rows/cols:", dmr, dmc)
