def displayed_max_row(ws):
    # find last row with any non-empty cell
    last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            last = r
    return last

def displayed_max_col(ws):
    last = 0
    for c in range(1, ws.max_column + 1):
        if any(ws.cell(r, c).value is not None for r in range(1, ws.max_row + 1)):
            last = c
    return last

def row_values(ws, r, max_c):
    vals = []
    for c in range(1, max_c + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

