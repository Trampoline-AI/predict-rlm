import os, shutil
from openpyxl import load_workbook

# Reload original workbook for clean modification
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]

items_ws = wb["ITEMS"]
sheet1_ws = wb["SHEET1"]
sheet2_ws = wb["SHEET2"]
res1_ws = wb["result sheet1"]
res2_ws = wb["result sheet2"]

def last_nonempty_row(ws):
    last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            last = r
    return last

items_last = last_nonempty_row(items_ws)
sheet1_last = last_nonempty_row(sheet1_ws)
sheet2_last = last_nonempty_row(sheet2_ws)

print("Target sheets and ranges:")
print("ITEMS rows:", items_last, "target col B")
print("SHEET1 rows:", sheet1_last, "target range:", f"B2:B{sheet1_last}")
print("SHEET2 rows:", sheet2_last, "target range:", f"B2:B{sheet2_last}")

print("\nCurrent values before modification:")
for r in range(1, max(items_last, sheet1_last, sheet2_last) + 1):
    vals = {
        "ITEMS": items_ws.cell(r, 2).value if r <= items_last else None,
        "SHEET1": sheet1_ws.cell(r, 2).value if r <= sheet1_last else None,
        "result1": res1_ws.cell(r, 2).value if r <= last_nonempty_row(res1_ws) else None,
        "SHEET2": sheet2_ws.cell(r, 2).value if r <= sheet2_last else None,
        "result2": res2_ws.cell(r, 2).value if r <= last_nonempty_row(res2_ws) else None,
    }
    print(f"Row {r}: {vals}")

# Perform row-by-row replacement in column B only for existing rows in each sheet
changes1 = []
for r in range(2, min(sheet1_last, items_last) + 1):
    old = sheet1_ws.cell(r, 2).value
    new = items_ws.cell(r, 2).value
    if old != new:
        changes1.append((r, old, new))
        sheet1_ws.cell(r, 2).value = new

changes2 = []
for r in range(2, min(sheet2_last, items_last) + 1):
    old = sheet2_ws.cell(r, 2).value
    new = items_ws.cell(r, 2).value
    if old != new:
        changes2.append((r, old, new))
        sheet2_ws.cell(r, 2).value = new

print("\nPlanned/applied changes SHEET1:")
for ch in changes1:
    print(ch)
print("Total SHEET1 changes:", len(changes1))

print("\nPlanned/applied changes SHEET2:")
for ch in changes2:
    print(ch)
print("Total SHEET2 changes:", len(changes2))

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(out_path)
current_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != orig_sheetnames:
    # rename back by position
    for i, orig_name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(out_path)
    print("Renamed sheets back to original names:", orig_sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
print("\nVerification sheet names:", wb_verify.sheetnames)

v_items = wb_verify["ITEMS"]
v_s1 = wb_verify["SHEET1"]
v_s2 = wb_verify["SHEET2"]

verification_ok = True

print("\nVerify SHEET1 column B against ITEMS:")
for r in range(2, min(last_nonempty_row(v_s1), last_nonempty_row(v_items)) + 1):
    a = v_s1.cell(r, 2).value
    b = v_items.cell(r, 2).value
    print(f"Row {r}: SHEET1!B{r}={a!r} | ITEMS!B{r}={b!r} | match={a==b}")
    if a != b or a in (None, ""):
        verification_ok = False

print("\nVerify SHEET2 column B against ITEMS:")
for r in range(2, min(last_nonempty_row(v_s2), last_nonempty_row(v_items)) + 1):
    a = v_s2.cell(r, 2).value
    b = v_items.cell(r, 2).value
    print(f"Row {r}: SHEET2!B{r}={a!r} | ITEMS!B{r}={b!r} | match={a==b}")
    if a != b or a in (None, ""):
        verification_ok = False

print("\nOverall verification ok:", verification_ok)

final_output_path = out_path
