```repl
import os
from openpyxl import load_workbook

# Load workbook again for editing
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Sanity-check expected result in Python
start_date = ws["M1"].value
end_date = ws["N1"].value
asset_id = ws["L2"].value
dates = [ws.cell(1, c).value for c in range(2, 11)]

matching_rows = []
for r in range(2, 12):
    if ws.cell(r, 1).value == asset_id:
        matching_rows.append(r)

py_count = 0
matched_values_detail = []
for r in matching_rows:
    for c in range(2, 11):
        val = ws.cell(r, c).value
        dt = ws.cell(1, c).value
        if val is not None and dt is not None and val > 100 and dt >= start_date and dt < end_date:
            py_count += 1
            matched_values_detail.append((r, c, dt, val))

print("Matching asset rows:", matching_rows)
print("Python expected count:", py_count)
print("Matched cells detail:", matched_values_detail)

# Write formula to target cell M2
formula = '=SUMPRODUCT(($A$2:$A$11=L2)*(B$1:J$1>=M1)*(B$1:J$1<N1)*(B$2:J$11>100))'
print("Existing M2 before write:", ws["M2"].value)
ws["M2"] = formula
print("Written formula to M2:", ws["M2"].value)

# Save output
input_name = os.path.basename(input_spreadsheet)
output_path = os.path.join("/sandbox/output/output_spreadsheet", input_name)
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename in order if counts match
    if len(wb_after.sheetnames) == len(orig_sheet_names):
        for ws_tmp, orig_name in zip(wb_after.worksheets, orig_sheet_names):
            ws_tmp.title = orig_name
        wb_after.save(output_path)
        print("Renamed sheets back to original names:", orig_sheet_names)
    else:
        print("Warning: sheet name count changed unexpectedly")

# Verify formula cell text
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("Formula in M2 after save:", ws_formula["M2"].value)

# Verify calculated value
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]
print("Verified target cells after recalc:")
for coord in ["L2", "M1", "N1", "M2"]:
    print(coord, "=", ws_values[coord].value)

verified_value = ws_values["M2"].value
print("Verified M2 value:", verified_value, "Expected Python count:", py_count)

# Keep for submission if correct
final_output_path = output_path
