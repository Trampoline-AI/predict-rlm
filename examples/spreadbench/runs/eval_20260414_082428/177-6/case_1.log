import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        print("Header row 2:", row_values(ws, 2, ws.max_column))
    # print first 8 rows and last 5 rows, truncated wide sheets
    first_n = min(ws.max_row, 8)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = row_values(ws, r, min(ws.max_column, 18))
        print(r, vals)
    if ws.max_row > 8:
        print("Last rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            vals = row_values(ws, r, min(ws.max_column, 18))
            print(r, vals)

# Focus on likely relevant sheets
for target_name in ["combined", "Combined"]:
    if target_name in wb.sheetnames:
        ws = wb[target_name]
        print(f"\nDetailed inspect target-like sheet '{target_name}'")
        for r in range(1, min(ws.max_row, 15)+1):
            print(r, row_values(ws, r, min(ws.max_column, 18)))

# Print column letters A:R mapping for reference
print("\nA:R columns:")
print({get_column_letter(i): i for i in range(1, 19)})
