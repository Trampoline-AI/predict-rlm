```repl
import os
from collections import defaultdict
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook fresh
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws_data = wb["DATA"]
ws_comb = wb["combined"]

def is_blankish(v):
    return v is None or v == "" or v == "\xa0"

def to_num(v):
    if is_blankish(v):
        return 0.0
    if isinstance(v, (int, float)):
        return float(v)
    try:
        s = str(v).replace(",", "").strip()
        return float(s) if s else 0.0
    except Exception:
        return 0.0

# Identify actual data rows in DATA
data_rows = []
for r in range(2, ws_data.max_row + 1):
    row_vals = [ws_data.cell(r, c).value for c in range(1, 19)]
    if any(v is not None for v in row_vals):
        data_rows.append(r)

print("DATA non-empty rows:", data_rows)

# Group by column H (8)
groups = defaultdict(list)
group_order = []
for r in data_rows:
    key = ws_data.cell(r, 8).value
    if key not in groups:
        group_order.append(key)
    groups[key].append(r)

print("Group order:", group_order)
for key in group_order:
    print("Group", key, "rows", groups[key])

# Clear existing data area in combined (rows 2 downward, cols A:R), preserving sheet
for r in range(2, ws_comb.max_row + 1):
    for c in range(1, 19):
        cell = ws_comb.cell(r, c)
        cell.value = None
        # leave styles as-is for now; will overwrite on used rows

# custom number format: positive;negative;zero;text
# zeros render blank, no comma separators, 2 decimals
num_fmt_blank_zero = "0.00;-0.00;;@"

out_row = 2
written_summary = []

for key in group_order:
    src_rows = groups[key]
    src_first = src_rows[0]

    # Copy A:R style/format from first source row into combined row
    for c in range(1, 19):
        src = ws_data.cell(src_first, c)
        dst = ws_comb.cell(out_row, c)

        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.font:
            dst.font = copy(src.font)
        if src.fill:
            dst.fill = copy(src.fill)
        if src.border:
            dst.border = copy(src.border)
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.protection:
            dst.protection = copy(src.protection)

    # Copy row height from first source row
    ws_comb.row_dimensions[out_row].height = ws_data.row_dimensions[src_first].height

    # A:H from first source row
    for c in range(1, 9):
        ws_comb.cell(out_row, c).value = ws_data.cell(src_first, c).value

    # I:R summed across group
    month_values = []
    for c in range(9, 19):
        total = sum(to_num(ws_data.cell(r, c).value) for r in src_rows)
        dst = ws_comb.cell(out_row, c)
        if abs(total) < 1e-12:
            dst.value = 0
        else:
            # preserve int-like totals as numbers but show 2 decimals by format
            dst.value = total
        dst.number_format = num_fmt_blank_zero
        month_values.append(dst.value)

    written_summary.append((out_row, key, month_values))
    out_row += 1

# Clear any leftover old rows below new output
for r in range(out_row, ws_comb.max_row + 1):
    for c in range(1, 19):
        ws_comb.cell(r, c).value = None

# Save
wb.save(output_path)
print("Saved initial output to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # rename by position back to original
    for i, expected in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verification using data_only
wb_val = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)
ws_val = wb_val["combined"]

print("\nFinal combined rows 1 to", len(group_order) + 1)
for r in range(1, len(group_order) + 2):
    vals = [ws_val.cell(r, c).value for c in range(1, 19)]
    print(r, vals)

# Also verify number formats in the formula-free workbook
wb_fmt = load_workbook(output_path, data_only=False)
ws_fmt = wb_fmt["combined"]
print("\nNumber formats for combined rows 2..{} I:R".format(len(group_order)+1))
for r in range(2, len(group_order) + 2):
    print(r, [ws_fmt.cell(r, c).number_format for c in range(9, 19)])

output_spreadsheet = output_path
print("Prepared output file:", output_spreadsheet)
```
