import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Re-open and inspect exact target cells / formulas
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)
for r in range(1, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    print(f"Row {r}: A{r}={a!r}, B{r}={b!r}, B{r}_type={type(b).__name__}")

# Determine blank target rows in column B where A has data
target_rows = []
for r in range(1, ws.max_row + 1):
    aval = ws.cell(r, 1).value
    bval = ws.cell(r, 2).value
    if aval not in (None, "") and bval in (None, ""):
        target_rows.append(r)
print("Target rows to fill in column B:", target_rows)

# Formula to extract text after the second space and before dash
for r in target_rows:
    formula = f'=TRIM(MID(A{r},FIND(" ",A{r},FIND(" ",A{r})+1)+1,FIND("-",A{r})-FIND(" ",A{r},FIND(" ",A{r})+1)-1))'
    ws[f"B{r}"] = formula
    print(f"Written B{r} formula:", ws[f"B{r}"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and handle potential sheet rename
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_names and len(wb_after.sheetnames) == len(orig_names):
    for i, expected in enumerate(orig_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_names)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_names[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_names[0]]

for r in range(1, ws_formula.max_row + 1):
    print(
        f"Verify row {r}: "
        f"A{r}={ws_values[f'A{r}'].value!r}, "
        f"B{r}_formula={ws_formula[f'B{r}'].value!r}, "
        f"B{r}_value={ws_values[f'B{r}'].value!r}"
    )

output_spreadsheet = outfile
```
