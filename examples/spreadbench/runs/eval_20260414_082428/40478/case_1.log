        return None
    return str(v)

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # gather headers from first 3 rows to detect header position
    for hr in range(1, min(3, ws.max_row) + 1):
