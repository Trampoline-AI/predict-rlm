from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # detect non-empty rows/cols more accurately
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        has = False
        for cell in row:
            if cell.value is not None:
                has = True
                nonempty_cols.add(cell.column)
        if has:
            nonempty_rows.append(row[0].row)
    print("non-empty row count:", len(nonempty_rows))
    print("first non-empty row:", nonempty_rows[0] if nonempty_rows else None, "last non-empty row:", nonempty_rows[-1] if nonempty_rows else None)
    print("non-empty columns:", [f"{get_column_letter(c)}" for c in sorted(nonempty_cols)])
    
    # print first 10 rows and last 5 rows across used columns
    used_cols = sorted(nonempty_cols) if nonempty_cols else list(range(1, ws.max_column+1))
    if not used_cols:
        return
    min_col, max_col = used_cols[0], used_cols[-1]
    
    print("Row 1 headers-ish:", [ws.cell(1, c).value for c in range(min_col, max_col+1)])
    
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(min_col, max_col+1)]
    
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("\nFirst rows:")
    for r in first_rows:
        print(r, row_vals(r))
    print("\nLast rows:")
    for r in last_rows:
        print(r, row_vals(r))
    
    # specifically inspect cols A:C and a wider region
    print("\nInspect A:C first 20 rows:")
    for r in range(1, min(ws.max_row, 20)+1):
        print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value)
    
    print("\nInspect A:H first 15 rows:")
    for r in range(1, min(ws.max_row, 15)+1):
        print(r, [ws.cell(r, c).value for c in range(1, min(8, ws.max_column)+1)])

for ws in wb.worksheets:
    sheet_summary(ws)
