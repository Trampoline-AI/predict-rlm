from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Reload clean workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Build groups from column A separated by blanks
groups = []
current = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is None or (isinstance(v, str) and v.strip() == ""):
        if current:
            groups.append(current)
            current = []
    else:
        current.append(v)
if current:
    groups.append(current)

print("Detected groups from column A:")
for i, g in enumerate(groups, start=1):
    print(i, g)

# Inspect current target area starting at column C
max_group_len = max(len(g) for g in groups) if groups else 0
print("\nCurrent target rows/cols before writing:")
for row_idx in range(1, len(groups) + 1):
    vals = [ws.cell(row_idx, col).value for col in range(3, 3 + max_group_len)]
    print(f"row {row_idx}: {vals}")

# Check formulas/values in existing target cells
print("\nExisting target cell details:")
for row_idx in range(1, len(groups) + 1):
    for offset in range(max_group_len):
        cell = ws.cell(row_idx, 3 + offset)
        if cell.value is not None:
            print(cell.coordinate, repr(cell.value))

# Write transpose result starting in column C, one group per row
# Preserve existing correct values; fill/replace mismatches in the intended target region only.
for row_idx, g in enumerate(groups, start=1):
    # clear extra old values in target row beyond group length within inspected width
    for offset in range(max_group_len):
        cell = ws.cell(row_idx, 3 + offset)
        new_val = g[offset] if offset < len(g) else None
        if cell.value != new_val:
            cell.value = new_val

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
orig_sheet_names = ["Sheet1"]
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for old, new in zip(wb2.sheetnames, orig_sheet_names):
        wb2[old].title = new
    wb2.save(out_path)
    print("Renamed sheets back to original:", wb2.sheetnames)

# Verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver["Sheet1"]

print("\nVerified target rows after save:")
for row_idx in range(1, len(groups) + 1):
    vals = [vws.cell(row_idx, col).value for col in range(3, 3 + max_group_len)]
    print(f"row {row_idx}: {vals}")

# Sanity-check exact expected rows
print("\nKey target cells:")
for coord in ["C1", "D1", "C2", "D2", "E2", "C3", "D3", "E3", "C4", "D4", "C5", "D5", "E5"]:
    print(coord, vws[coord].value)

final_output_path = out_path
