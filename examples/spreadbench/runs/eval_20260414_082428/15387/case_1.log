import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target area before writing
print("Pre-write checks:")
for coord in ["B1","C1","D1","E1","F1","B3","C3","D3","E3","F3","A13","A14","B8","C8","D8","E8","F8"]:
    print(coord, ws[coord].value)

# Helper row in existing blank cells B8:F8: cumulative count of zeros in B1:current
for col in range(2, 7):  # B:F
    col_letter = chr(64 + col)
    ws.cell(8, col).value = f'=COUNTIF($B$1:{col_letter}$1,0)'

# Output formulas in A13:A17
# nth migrated customer where migrated is indicated by 0 in B1:F1
for row in range(13, 18):
    n = row - 12  # 1 for A13, 2 for A14, etc.
    ws.cell(row, 1).value = f'=IFERROR(INDEX($B$3:$F$3,MATCH(ROWS($A$13:A{row}),$B$8:$F$8,0)),"")'

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheet_names)
    for i, old_name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = old_name
    wb2.save(outfile)

# Verify formulas present
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("Written formulas:")
for coord in ["B8","C8","D8","E8","F8","A13","A14","A15","A16","A17"]:
    print(coord, "=", wsf[coord].value)

# Verify cached values after recalculation
wb_val = load_workbook(outfile, data_only=True)
wsv = wb_val[orig_sheet_names[0]]
print("Verified values after recalculation:")
for coord in ["B8","C8","D8","E8","F8","A13","A14","A15","A16","A17"]:
    print(coord, "=", wsv[coord].value)

output_spreadsheet = outfile
print("Final output path:", output_spreadsheet)
