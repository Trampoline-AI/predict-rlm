from openpyxl import load_workbook
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print current target cells before modification
print("Before write:")
for ref in ["B14", "B15", "B16", "B17"]:
    print(ref, "value:", ws[ref].value)

# Write formulas to ALL target cells B14:B17 based on corresponding A cell
for row in range(14, 18):
    formula = f'=VLOOKUP(A{row},$A$1:$B$4,2,FALSE)'
    ws[f"B{row}"] = formula

# Save initial output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # rename sheets back by position
    for i, desired in enumerate(original_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = desired
    wb_check.save(outfile)
    print("Renamed sheets back to:", original_sheet_names)

# Verify formulas exist
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("\nFormulas in target cells:")
for ref in ["B14", "B15", "B16", "B17"]:
    print(ref, "formula:", ws_formula[ref].value)

# Verify computed values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]
print("\nComputed values in target cells:")
for ref in ["A14", "B14", "A15", "B15", "A16", "B16", "A17", "B17"]:
    print(ref, "=", ws_values[ref].value)

output_spreadsheet = outfile
