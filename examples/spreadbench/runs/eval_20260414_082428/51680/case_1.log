import os, shutil
from openpyxl import load_workbook
from copy import copy

input_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_path))

# Reload for style inspection and modification
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Inspect formulas/values/styles in target column G and source headers
print("Inspecting target cells and styles:")
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 7)
    print(
        f"G{r}: value={cell.value!r}, data_type={cell.data_type}, "
        f"numfmt={cell.number_format!r}, align=({cell.alignment.horizontal},{cell.alignment.vertical})"
    )

print("Headers A1:F1:", [ws.cell(1,c).value for c in range(1,7)])
headers = [str(ws.cell(1,c).value).strip() if ws.cell(1,c).value is not None else "" for c in range(1,7)]
print("Trimmed headers used for output:", headers)

# Compute and fill only blank target cells in G2:Gmax_row
filled = {}
style_source = ws["G2"]  # use existing populated output cell as style template
for r in range(2, ws.max_row + 1):
    g = ws.cell(r, 7)
    if g.value is None or (isinstance(g.value, str) and g.value.strip() == ""):
        parts = []
        for c in range(1, 7):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.strip().upper() == "Y":
                parts.append(headers[c-1])
        new_val = ", ".join(parts)
        g.value = new_val
        # copy formatting from populated G2 to keep consistency
        g.font = copy(style_source.font)
        g.fill = copy(style_source.fill)
        g.border = copy(style_source.border)
        g.alignment = copy(style_source.alignment)
        g.number_format = copy(style_source.number_format)
        g.protection = copy(style_source.protection)
        filled[r] = new_val

print("Filled rows in G:", filled)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_sheet_names = ["Sheet1"]
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for old, new in zip(wb_after.sheetnames, orig_sheet_names):
        wb_after[old].title = new
    wb_after.save(output_path)
    print("Renamed sheets back to original names:", wb_after.sheetnames)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["Sheet1"]
print("Verification of G2:G14:")
for r in range(2, wsv.max_row + 1):
    print(f"G{r} =", wsv.cell(r, 7).value)

# Also verify row logic for newly filled rows
print("Row source A:F and joined output for rows 8:14")
for r in range(8, 15):
    src = [wsv.cell(r, c).value for c in range(1, 7)]
    out = wsv.cell(r, 7).value
    print(r, src, "=>", out)
```
