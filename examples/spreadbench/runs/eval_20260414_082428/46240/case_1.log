import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for ws in wb.worksheets:
    print("\n--- SHEET ---")
    print("Title:", ws.title)
    print("Max row:", ws.max_row, "Max col:", ws.max_column)
    
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        print("Header row 2:", row_values(ws, 2, ws.max_column))
    
    sample_first_end = min(ws.max_row, 10)
    print(f"First rows 1-{sample_first_end}:")
    for r in range(1, sample_first_end + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}-{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Specific inspection of H and J because the instruction references them
    h_col, j_col = 8, 10
    print("Column letters check:", get_column_letter(h_col), get_column_letter(j_col))
    inspect_rows = min(ws.max_row, 15)
    print("Rows 1-15, columns H and J values/formulas:")
    for r in range(1, inspect_rows + 1):
        h = ws.cell(r, h_col).value
        j = ws.cell(r, j_col).value if j_col <= ws.max_column else None
        print(f"Row {r}: H{r}={h!r}, J{r}={j!r}")
