```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

in_path = input_spreadsheet
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

def norm(x):
    return str(x).strip().lower() if x is not None else ""

def get_header_map(ws, header_row=2):
    return {norm(ws.cell(header_row, c).value): c for c in range(1, ws.max_column+1) if ws.cell(header_row, c).value is not None}

def extract_groups(path):
    wb = load_workbook(path, data_only=False)
    ws = wb[wb.sheetnames[0]]
    hm = get_header_map(ws, 2)
    lc, fc, dc, duc, rc = hm["last name"], hm["first name"], hm["date of birth"], hm["duplicate?"], hm["relationship"]
    groups = defaultdict(list)
    for r in range(3, ws.max_row + 1):
        if norm(ws.cell(r, duc).value) == "yes":
            key = (ws.cell(r, lc).value, ws.cell(r, fc).value, ws.cell(r, dc).value)
            groups[key].append({
                "row": r,
                "relationship": ws.cell(r, rc).value,
            })
    return wb.sheetnames, ws.max_row, groups

orig_sheets, orig_max_row, orig_groups = extract_groups(in_path)
out_sheets, out_max_row, out_groups = extract_groups(out_path)

print("Original sheets:", orig_sheets)
print("Output sheets:", out_sheets)
print("Original max row:", orig_max_row, "Output max row:", out_max_row)

summary = []
for key, rows in orig_groups.items():
    if len(rows) > 1:
        orig_rels = [r["relationship"] for r in rows]
        out_rels = [r["relationship"] for r in out_groups.get(key, [])]
        has_employee = any(norm(x) == "employee" for x in orig_rels)
        summary.append((key, len(rows), len(out_groups.get(key, [])), orig_rels, out_rels, has_employee))

print("\nDuplicate-group verification:")
for item in summary:
    key, orig_n, out_n, orig_rels, out_rels, has_employee = item
    print({
        "person": key,
        "orig_count": orig_n,
        "out_count": out_n,
        "orig_relationships": orig_rels,
        "out_relationships": out_rels,
        "has_employee": has_employee,
    })

# Explicit rule checks
bad = []
deleted_groups = []
preserved_groups = []

for key, orig_n, out_n, orig_rels, out_rels, has_employee in summary:
    if has_employee:
        preserved_groups.append((key, orig_n, out_n))
        if out_n != orig_n:
            bad.append(("should_preserve", key, orig_n, out_n, orig_rels, out_rels))
    else:
        deleted_groups.append((key, orig_n, out_n))
        if not (out_n == orig_n - 1):
            bad.append(("should_delete_one", key, orig_n, out_n, orig_rels, out_rels))

print("\nGroups that should have one deleted:")
for x in deleted_groups:
    print(x)

print("\nGroups that should be preserved:")
for x in preserved_groups:
    print(x)

print("\nRule violations:", bad)

# Show all remaining data rows for the affected non-employee-only groups
wb_out = load_workbook(out_path, data_only=True)
ws_out = wb_out[wb_out.sheetnames[0]]
hm = get_header_map(ws_out, 2)
lc, fc, dc, duc, rc = hm["last name"], hm["first name"], hm["date of birth"], hm["duplicate?"], hm["relationship"]

target_people = [key for key, orig_n, out_n in deleted_groups]
print("\nRemaining rows for groups where one row should have been deleted:")
for r in range(3, ws_out.max_row + 1):
    key = (ws_out.cell(r, lc).value, ws_out.cell(r, fc).value, ws_out.cell(r, dc).value)
    if key in target_people:
        print(r, key, ws_out.cell(r, duc).value, ws_out.cell(r, rc).value)

print("\nOutput file exists:", os.path.exists(out_path), out_path)
```
