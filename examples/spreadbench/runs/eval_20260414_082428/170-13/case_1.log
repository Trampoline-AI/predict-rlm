import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
print("Original sheet names:", orig_sheet_names)

def sheet_preview(ws, sample_first=8, sample_last=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find likely used rows/cols more carefully
    used_rows = []
    used_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for c in row:
            if c.value is not None:
                row_has = True
                used_cols.add(c.column)
        if row_has:
            used_rows.append(row[0].row)
    print("nonempty row count:", len(used_rows))
    if used_rows:
        print("first nonempty row:", min(used_rows), "last nonempty row:", max(used_rows))
    
    # Print first 10 rows with values
    first_rows = list(range(1, min(ws.max_row, sample_first) + 1))
    last_rows = list(range(max(1, ws.max_row - sample_last + 1), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in first_rows + last_rows:
        if r not in seen:
            seen.add(r)
            rows_to_show.append(r)
    
    # Determine meaningful width
    max_used_col = max(used_cols) if used_cols else ws.max_column
    max_show_col = min(max(max_used_col, 1), max(12, min(ws.max_column, 20)))
    
    # Potential headers from first few rows
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_show_col + 1)]
        print(f"Row {r}:", vals)
    
    print("Sample rows:")
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, max_show_col + 1)]
        print(f"Row {r}:", vals)
    
    # Print formulas if present in first/last sample areas
    formula_cells = []
    for r in rows_to_show:
        for c in range(1, max_show_col + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    if formula_cells:
        print("Sample formulas:", formula_cells[:20])

for s in wb.sheetnames:
    sheet_preview(wb[s])

# Search for key labels mentioned in instruction
keywords = ["Entry", "Output", "Header", "U4_ComponentPropertyForm"]
print("\nKeyword search:")
for s in wb.sheetnames:
    ws = wb[s]
    hits = []
    for row in ws.iter_rows():
        for cell in row:
            val = cell.value
            if isinstance(val, str):
                for kw in keywords:
                    if kw.lower() in val.lower():
                        hits.append((cell.coordinate, val))
                        break
    print(s, "hits:", hits[:30], "count:", len(hits))
```
