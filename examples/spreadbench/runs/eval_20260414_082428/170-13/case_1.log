from openpyxl import load_workbook
from collections import OrderedDict
import os, shutil

wb = load_workbook(input_spreadsheet)
ws1, ws2, ws3 = wb["Sheet1"], wb["Sheet2"], wb["Sheet3"]

# Print full contents compactly enough to infer pattern
sheet1_entries = [ws1.cell(r, 1).value for r in range(2, ws1.max_row + 1) if ws1.cell(r, 1).value is not None]
print("Sheet1 entries count:", len(sheet1_entries))
for i, v in enumerate(sheet1_entries, start=2):
    print(f"Sheet1 A{i}: {v}")

# Build Sheet2 mapping: each row1 header -> list of nonblank values below it
sheet2_map = OrderedDict()
for c in range(1, ws2.max_column + 1):
    header = ws2.cell(1, c).value
    vals = []
    for r in range(2, ws2.max_row + 1):
        v = ws2.cell(r, c).value
        if v not in (None, ""):
            vals.append(v)
    sheet2_map[header] = vals

print("\nSheet2 mapping:")
for k, vals in sheet2_map.items():
    print(k, "->", vals, "count:", len(vals))

sheet3_vals = [ws3.cell(r, 1).value for r in range(1, ws3.max_row + 1)]
print("\nSheet3 full current values:")
for i, v in enumerate(sheet3_vals, start=1):
    print(f"Sheet3 A{i}: {v}")

# Infer expected outputs: for each Sheet1 entry, if any Sheet2 header appears in the entry, append each child field
expected = ["Output"]
matches = []
for entry in sheet1_entries:
    matched = False
    for hdr, vals in sheet2_map.items():
        if hdr and hdr in entry:
            matched = True
            matches.append((entry, hdr, len(vals)))
            for sub in vals:
                expected.append(f"{entry}{sub}")
            break
    if not matched:
        matches.append((entry, None, 0))

print("\nEntry matching results:")
for m in matches:
    print(m)

print("\nExpected output rows:", len(expected))
print("First 15 expected:")
for i, v in enumerate(expected[:15], start=1):
    print(i, v)
print("Last 10 expected:")
for i, v in enumerate(expected[-10:], start=len(expected)-9):
    print(i, v)

# Compare current Sheet3 with expected
current = sheet3_vals
print("\nCurrent vs expected same length?", len(current) == len(expected))
diffs = []
for i in range(max(len(current), len(expected))):
    cv = current[i] if i < len(current) else "<missing>"
    ev = expected[i] if i < len(expected) else "<missing>"
    if cv != ev:
        diffs.append((i+1, cv, ev))
print("Diff count:", len(diffs))
print("First 20 diffs:", diffs[:20])

# Apply by rewriting Sheet3 column A to exactly expected output
# Clear existing values in col A below used range if needed
max_clear = max(ws3.max_row, len(expected))
for r in range(1, max_clear + 1):
    ws3.cell(r, 1).value = expected[r-1] if r <= len(expected) else None

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and verify
wb2 = load_workbook(out_path, data_only=False)
print("Sheet names after recalc reload:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1", "Sheet2", "Sheet3"]:
    # rename back if needed
    for i, expected_name in enumerate(["Sheet1", "Sheet2", "Sheet3"]):
        wb2[wb2.sheetnames[i]].title = expected_name
    wb2.save(out_path)
    print("Renamed sheets back to original names and re-saved.")

wbv = load_workbook(out_path, data_only=True)
ws3v = wbv["Sheet3"]
verified = [ws3v.cell(r, 1).value for r in range(1, len(expected) + 1)]
print("\nVerification length:", len(verified))
print("Verification first 15:", verified[:15])
print("Verification last 10:", verified[-10:])
bad = [(i+1, verified[i], expected[i]) for i in range(len(expected)) if verified[i] != expected[i]]
print("Verification diffs:", bad[:20], "count:", len(bad))

output_spreadsheet = out_path
```
