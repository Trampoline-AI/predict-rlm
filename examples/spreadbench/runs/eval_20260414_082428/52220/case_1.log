def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # collect header candidates from first 3 rows
    for hr in range(1, min(3, ws.max_row) + 1):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {hr} values:", vals)
    # non-empty row count scan
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty rows:", len(nonempty_rows), "first/last:", (nonempty_rows[:5], nonempty_rows[-5:] if nonempty_rows else []))
    # sample first 10 non-empty rows and last 5 non-empty rows
    sample_rows = []
    if nonempty_rows:
        sample_rows = nonempty_rows[:10]
        for r in nonempty_rows[-5:]:
            if r not in sample_rows:
                sample_rows.append(r)
    else:
        sample_rows = list(range(1, min(ws.max_row, 10)+1))
    print("Sample rows to inspect:", sample_rows)
    for r in sample_rows:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    # print A1:C5 area with formulas/values
    print("A1:C5 detailed:")
    for r in range(1, min(5, ws.max_row) + 1):
        row_info = []
        for c in range(1, min(3, ws.max_column) + 1):
            cell = ws.cell(r, c)
