from openpyxl import load_workbook
import os
from copy import copy

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing:")
for coord in ["C1", "C2", "C3"]:
    print(coord, "value=", ws[coord].value, "number_format=", ws[coord].number_format)
for coord in ["A2", "B2", "A3", "B3"]:
    print(coord, "value=", ws[coord].value, "number_format=", ws[coord].number_format)

# Write formulas in the existing target column C for all relevant data rows
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3)
    print(f"Row {r} pre-check: A={a!r}, B={b!r}, C={c.value!r}")
    # Put the formula in the output column for every populated row region;
    # it returns blank unless both A and B contain values.
    c.value = f'=IF(AND(A{r}<>"",B{r}<>""),A{r}+B{r},"")'
    # Preserve/assign a datetime-like display format matching column A
    if ws.cell(r, 1).number_format:
        c.number_format = ws.cell(r, 1).number_format

wb.save(output_path)
print("Saved to", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
