    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect likely header row among first 5 rows by non-empty count
    header_candidates = []
    for r in range(1, min(6, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v is not None and v != "" for v in vals)
        header_candidates.append((r, nonempty, vals[:min(10, ws.max_column)]))
    print("Header candidates (row, nonempty, first cols):", header_candidates)
    
    # print first 10 rows
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n + 1):
