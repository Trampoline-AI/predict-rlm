    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = [visible_value(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # print formulas found
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((cell.coordinate, v))
            elif hasattr(v, "text"):
                formulas.append((cell.coordinate, v.text))
    print("Formula cells found:", len(formulas))
    print("First 20 formulas:", formulas[:20])

    # show non-empty headers from row 1 and row 2
    for hr in [1,2]:
        if hr <= ws.max_row:
            hdrs = [(get_column_letter(c), visible_value(ws.cell(hr,c).value)) for c in range(1, ws.max_column+1) if ws.cell(hr,c).value not in (None, "")]
            print(f"Non-empty row {hr} cells:", hdrs)

# print workbook defined names if any
