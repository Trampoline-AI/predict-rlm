import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and confirm structure again briefly
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Writing formulas to target cells B2:B5")
for r in range(2, 6):
    item_cell = f"A{r}"
    target_cell = f"B{r}"
    old_val = ws[target_cell].value
    formula = f'=SUMIF($B$12:$B$22,{item_cell},$C$12:$C$22)'
    print(target_cell, "item:", ws[item_cell].value, "old:", old_val, "new formula:", formula)
    ws[target_cell] = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc, repair sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename sheets back in order
    for ws_cur, orig_name in zip(wb_after.worksheets, orig_sheet_names):
        ws_cur.title = orig_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerification of target cells:")
for r in range(2, 6):
    print(
        f"A{r}={ws_values[f'A{r}'].value!r}, "
        f"B{r} formula={ws_formula[f'B{r}'].value!r}, "
        f"B{r} value={ws_values[f'B{r}'].value!r}"
    )

# Basic checks
assert ws_values["B2"].value == 12, "B2 should evaluate to 12"
assert ws_values["B3"].value == 15, "B3 should evaluate to 15"
assert ws_values["B4"].value == 6, "B4 should evaluate to 6"
assert ws_values["B5"].value == 8, "B5 should evaluate to 8"

output_spreadsheet = outfile
