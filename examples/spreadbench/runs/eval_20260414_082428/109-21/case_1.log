```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload clean workbook for modification
wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames[:]
ws = wb2[orig_sheet_names[0]]

START_ROW = 5
DATA_COLS_END = 24  # A:X
K_COL = column_index_from_string("K")
Z_COL = column_index_from_string("Z")

def is_row_nonempty_ax(ws, r):
    return any(ws.cell(r, c).value not in (None, "") for c in range(1, DATA_COLS_END + 1))

def to_num(v):
    if v is None or v == "":
        return None
    if isinstance(v, (int, float)):
        return float(v)
    try:
        return float(str(v).strip())
    except:
        return None

# Detect groups as consecutive non-empty blocks in A:X
groups = []
in_group = False
start = None
for r in range(START_ROW, ws.max_row + 1):
    nonempty = is_row_nonempty_ax(ws, r)
    if nonempty and not in_group:
        start = r
        in_group = True
    elif not nonempty and in_group:
        groups.append((start, r - 1))
        in_group = False
if in_group:
    groups.append((start, ws.max_row))

print("Groups to process:", groups)

# Compute and write Y/N into Z
written = []
for start, end in groups:
    rows = list(range(start, end + 1))
    kvals = [(r, to_num(ws.cell(r, K_COL).value)) for r in rows]
    numeric_vals = [v for _, v in kvals if v is not None]
    
    if len(rows) == 1:
        ws.cell(rows[0], Z_COL).value = "Y"
        written.append((rows[0], ws.cell(rows[0], 1).value, ws.cell(rows[0], K_COL).value, "Y", "single-row group"))
        continue
    
    if not numeric_vals:
        # If no numeric K values exist in a multi-row group, conservatively leave blank? 
        # But instruction expects Y/N for each member. We'll mark Y for all if all blank.
        for r in rows:
            ws.cell(r, Z_COL).value = "Y"
            written.append((r, ws.cell(r, 1).value, ws.cell(r, K_COL).value, "Y", "no numeric K values"))
        continue
    
    max_k = max(numeric_vals)
    for r, kval in kvals:
        mark = "Y" if kval == max_k else "N"
        ws.cell(r, Z_COL).value = mark
        written.append((r, ws.cell(r, 1).value, ws.cell(r, K_COL).value, mark, f"group max={max_k}"))

print("Written results:")
for item in written:
    print(item)

# Save output
wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and check sheet names
wb_check = load_workbook(output_path)
print("Sheet names after recalc reload:", wb_check.sheetnames)

# If recalc changed sheet names, restore original names and save again
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for i, sname in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = sname
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with data_only=True
wb_val = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)
ws_val = wb_val[orig_sheet_names[0]]

print("\nVerification of target Z cells:")
for start, end in groups:
    print(f"Group rows {start}-{end}:")
    for r in range(start, end + 1):
        print(
            {
                "row": r,
                "name": ws_val.cell(r, 1).value,
                "K": ws_val.cell(r, K_COL).value,
                "Z": ws_val.cell(r, Z_COL).value,
            }
        )

# Basic sanity checks
issues = []
for start, end in groups:
    z_vals = []
    k_vals = []
    for r in range(start, end + 1):
        z = ws_val.cell(r, Z_COL).value
        k = to_num(ws_val.cell(r, K_COL).value)
        z_vals.append((r, z))
        k_vals.append((r, k))
        if z in (None, ""):
            issues.append(f"Blank Z at row {r}")
    numeric = [k for _, k in k_vals if k is not None]
    if numeric:
        mx = max(numeric)
        expected_y_rows = [r for r, k in k_vals if k == mx]
        actual_y_rows = [r for r, z in z_vals if z == "Y"]
        if sorted(expected_y_rows) != sorted(actual_y_rows):
            issues.append(f"Mismatch in group {start}-{end}: expected Y {expected_y_rows}, got {actual_y_rows}")
    elif len(range(start, end + 1)) == 1:
        if ws_val.cell(start, Z_COL).value != "Y":
            issues.append(f"Single-row group {start} not Y")

print("\nIssues:", issues if issues else "None")
```
