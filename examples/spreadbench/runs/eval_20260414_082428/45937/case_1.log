import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Current"]

# Close inspection around the target area
print("Detailed rows 6:11, cols B:N")
for r in range(6, 12):
    vals = [ws.cell(r, c).value for c in range(2, 15)]  # B:N
    print(r, vals)

print("\nExisting E-column cells around data rows:")
for r in range(7, 12):
    print(r, "B", ws[f"B{r}"].value, "C", ws[f"C{r}"].value, "D", ws[f"D{r}"].value, "E", ws[f"E{r}"].value)

# Determine rows to fill in column E: rows with source data and blank E
target_rows = []
for r in range(7, ws.max_row + 1):
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    e = ws.cell(r, 5).value
    if any(v is not None for v in [b, c, d]):
        if e in (None, ""):
            target_rows.append(r)

print("Rows needing E formula:", target_rows)

# Formula logic:
# - MATCH category Dn against J18:N18 to pick the category column
# - Determine kms band by checking Cn against H20:I22
# - INDEX the corresponding percentage in J20:N22
# Guard blanks with IF
for r in target_rows:
    formula = (
        f'=IF(OR(C{r}="",D{r}=""),"",'
        f'INDEX($J$20:$N$22,'
        f'MATCH(1,INDEX((C{r}>=$H$20:$H$22)*(C{r}<=$I$20:$I$22),0),0),'
        f'MATCH(D{r},$J$18:$N$18,0)'
        f'))'
    )
    ws[f"E{r}"] = formula
    print(f"Set E{r} =", formula)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload and restore original sheet name if needed
orig_sheetnames = ["Current"]
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Current"]
