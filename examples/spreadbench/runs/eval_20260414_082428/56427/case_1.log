```repl
import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Alignment
from openpyxl.utils import column_index_from_string, get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(output_path)  # fix existing output file
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

start_col = column_index_from_string("H")
end_col = column_index_from_string("S")
max_row = ws.max_row
max_col = ws.max_column

fill_rgb = "0E2EFD"  # derived from #E2EFD by left-padding to valid 6-digit RGB
fill = PatternFill(start_color=fill_rgb, end_color=fill_rgb, fill_type="solid")
center = Alignment(horizontal="center", vertical="center")
numfmt = "0.###############"

# Fix formulas: on start rows (B=1), H should pull same-row G, I next row G, etc.
for r in range(2, max_row + 1):
    runner = ws[f"B{r}"].value
    for c in range(start_col, end_col + 1):
        cell = ws.cell(r, c)
        offset = c - start_col  # H=0, I=1, ...
        if runner == 1:
            # preserve blanks as blanks; stop after runner count in C
            cell.value = f'=IF($C{r}<{offset+1},"",IF(INDEX($G:$G,ROW()+{offset})="","",VALUE(INDEX($G:$G,ROW()+{offset}))))'
        else:
            cell.value = None

# Reapply formatting exactly as requested
for r in range(2, min(28, max_row) + 1):
    for c in range(start_col, end_col + 1):
        ws.cell(r, c).fill = fill
        ws.cell(r, c).number_format = numfmt

for r in range(1, max_row + 1):
    for c in range(start_col, max_col + 1):
        ws.cell(r, c).alignment = center

wb.save(output_path)
print("Re-saved fixed workbook:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Restore sheet names if changed
wb_post = load_workbook(output_path)
if wb_post.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = name
    wb_post.save(output_path)
    print("Restored sheet names:", wb_post.sheetnames)

# Verify computed values
wbv = load_workbook(output_path, data_only=True)
wsv = wbv[orig_sheetnames[0]]

print("\nVerified target start rows H:S:")
for r in range(2, max_row + 1):
    if wsv[f"B{r}"].value == 1:
        vals = [wsv.cell(r, c).value for c in range(start_col, end_col + 1)]
        print(r, vals)

# Verify formula strings
wbf = load_workbook(output_path, data_only=False)
wsf = wbf[orig_sheetnames[0]]
print("\nFormula check H:M for start rows:")
for r in range(2, max_row + 1):
    if wsf[f"B{r}"].value == 1:
        print(r, [wsf.cell(r, c).value for c in range(start_col, start_col + 6)])

# Verify style/alignment on representative cells
for coord in ["H2", "S28", "H7", "M15"]:
    cell = wsf[coord]
    print(coord, {
        "fill": cell.fill.start_color.rgb,
        "numfmt": cell.number_format,
        "align": (cell.alignment.horizontal, cell.alignment.vertical),
        "value": cell.value
    })

output_spreadsheet = output_path
```
