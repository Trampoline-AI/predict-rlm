for r in range(2, max_row + 1):
    if ws[f"B{r}"].value == 1:
        print(f"Target start row {r}: Race={ws[f'A{r}'].value}, Runners={ws[f'C{r}'].value}")

# Fill color from instruction "#E2EFD" is 5 hex chars; pad to 6 for valid RGB
fill_rgb = "0E2EFD"
fill = PatternFill(start_color=fill_rgb, end_color=fill_rgb, fill_type="solid")
center = Alignment(horizontal="center", vertical="center")
numfmt = "0.###############"

# Write formulas only for runner-start rows; clear others in H:S target range
for r in range(2, max_row + 1):
    runner = ws[f"B{r}"].value
    runners_count = ws[f"C{r}"].value
    
    for c in range(start_col, end_col + 1):
        cell = ws.cell(r, c)
        offset = c - start_col  # 0 for H, 1 for I, ...
        if runner == 1:
            # Stop after number of runners in C; preserve blanks as blanks, otherwise coerce text-number to numeric
            # Source row = current row + offset
            cell.value = f'=IF({get_column_letter(3)}{r}<{offset+1},"",IF(INDEX($G$2:$G${max_row},ROW()-1+{offset+1})="","",VALUE(INDEX($G$2:$G${max_row},ROW()-1+{offset+1}))))'
