import os, shutil
from openpyxl import load_workbook

# Reload clean workbook from input
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb2 = load_workbook(input_path)
original_sheet_names = wb2.sheetnames
ws = wb2["Sheet1"]

print("Original sheet names:", original_sheet_names)
print("Target header:", ws["R1"].value, ws["S1"].value, ws["U1"].value)

# Inspect current target cells before modifying
print("Before writing, R2:R20:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"R{r}"].value, ws[f"S{r}"].value, ws[f"U{r}"].value)

# Write formula to all relevant populated rows in column R
# Logic:
# error in S => Upload
# else if U between -1 and 1 inclusive => Do not Upload
# else => to Check
for r in range(2, ws.max_row + 1):
    s_val = ws[f"S{r}"].value
    u_val = ws[f"U{r}"].value
    # only write where the row is actually in use
    if s_val is not None or u_val is not None:
        ws[f"R{r}"] = f'=IF(ISERROR(S{r}),"Upload",IF(AND(U{r}>=-1,U{r}<=1),"Do not Upload","to Check"))'

wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc and restore if changed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    for idx, old_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = old_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("Formulas now in R2:R20:")
for r in range(2, ws_formula.max_row + 1):
    print(r, ws_formula[f"R{r}"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Verified values in R2:R20 after recalculation:")
for r in range(2, ws_values.max_row + 1):
    print(r, repr(ws_values[f"R{r}"].value))

# Sanity-check expected key rows
checks = {
    2: "Upload",
    11: "Do not Upload",
    13: "Do not Upload",
    15: "to Check",
    16: "Do not Upload",
    19: "to Check",
    20: "Do not Upload",
}
print("Sanity checks:")
for r, expected in checks.items():
    actual = ws_values[f"R{r}"].value
    print(f"R{r}: actual={actual!r}, expected={expected!r}, match={actual == expected}")

final_output_path = output_path
