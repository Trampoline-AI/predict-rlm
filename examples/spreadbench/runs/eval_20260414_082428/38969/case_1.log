import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws, sample_rows=8):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect header row candidates 1 and 2
    row1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print("Row 1 values:", row1[:min(25, len(row1))])
    if row2:
        print("Row 2 values:", row2[:min(25, len(row2))])
    
    # Print headers with letters
    headers = []
    for c in range(1, ws.max_column + 1):
        headers.append(f"{get_column_letter(c)}:{ws.cell(1,c).value}")
    print("Headers row 1:", headers[:min(40, len(headers))])
    
    # First 5-10 rows
    first_n = min(sample_rows, ws.max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 22) + 1)]
        print(f"Row {r}:", vals)
    
    # Last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 22) + 1)]
        print(f"Row {r}:", vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Specifically inspect target columns R, S, U and neighboring columns if present
for ws in wb.worksheets:
    print(f"\n=== Target inspection for {ws.title} ===")
    for col in ["Q", "R", "S", "T", "U"]:
        idx = column_index_from_string(col)
        if idx <= ws.max_column:
            print(f"{col}1={ws[f'{col}1'].value!r}, {col}2={ws[f'{col}2'].value!r}, {col}3={ws[f'{col}3'].value!r}")
        else:
            print(f"{col} does not exist on this sheet")
    
    # show rows 1-10 and last 5 for Q:U
    if ws.max_column >= column_index_from_string("U"):
        print("Rows 1-10 for Q:U")
        for r in range(1, min(10, ws.max_row) + 1):
            print(r, [ws.cell(r, c).value for c in range(column_index_from_string("Q"), column_index_from_string("U") + 1)])
        print("Last 5 rows for Q:U")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, [ws.cell(r, c).value for c in range(column_index_from_string("Q"), column_index_from_string("U") + 1)])
    
    # existing formulas in R
    if ws.max_column >= column_index_from_string("R"):
        existing_r = []
        for r in range(1, min(ws.max_row, 20) + 1):
            val = ws[f"R{r}"].value
            if isinstance(val, str) and val.startswith("="):
                existing_r.append((r, val))
        print("Existing formulas in first 20 cells of column R:", existing_r if existing_r else "None")
