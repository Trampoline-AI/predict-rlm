```repl
import os
from copy import copy
from collections import Counter
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
dest_name = "Consolidated_ALL" if "Consolidated_ALL" in wb.sheetnames else "Consolidate_ALL"
dest = wb[dest_name]
source_sheets = [s for s in ["Jack", "Henry", "Richard"] if s in wb.sheetnames]

# Inspect existing destination contents to avoid duplication
existing_counts = Counter()
for r in range(2, dest.max_row + 1):
    sheet_name = dest.cell(r, 12).value
    if sheet_name not in (None, ""):
        existing_counts[str(sheet_name).strip()] += 1
print("Existing destination counts by source sheet:", existing_counts)

# Confirm source data row counts
source_counts = {}
for s in source_sheets:
    ws = wb[s]
    # count non-empty data rows based on yellow-highlighted mapped columns having at least one value
    count = 0
    for r in range(2, ws.max_row + 1):
        vals = [
            ws.cell(r,1).value, ws.cell(r,3).value, ws.cell(r,4).value, ws.cell(r,5).value,
            ws.cell(r,6).value, ws.cell(r,7).value, ws.cell(r,14).value, ws.cell(r,15).value,
            ws.cell(r,16).value, ws.cell(r,17).value, ws.cell(r,18).value
        ]
        if any(v not in (None, "") for v in vals):
            count += 1
    source_counts[s] = count
print("Source counts:", source_counts)

# Determine first blank row in A:L
def first_fully_blank_row_A_to_L(ws):
    for r in range(2, ws.max_row + 2):
        vals = [ws.cell(r, c).value for c in range(1, 13)]
        if all(v in (None, "") for v in vals):
            return r
    return ws.max_row + 1

start_row = first_fully_blank_row_A_to_L(dest)
print("First blank destination row A:L:", start_row)

# Use row 2 as formatting template for consolidated data rows
template_row = 2 if dest.max_row >= 2 else 1

# Map source columns to destination columns
# source: A,C,D,E,F,G,N,O,P,Q,R -> dest: A:K ; dest L = sheet name
mapped_source_cols = [1,3,4,5,6,7,14,15,16,17,18]

rows_written = 0
written_ranges = {}

for s in source_sheets:
    ws = wb[s]
    # If already fully consolidated, skip to avoid duplication
    if existing_counts.get(s, 0) >= source_counts[s] and source_counts[s] > 0:
        print(f"Skipping {s}: already present ({existing_counts.get(s,0)}/{source_counts[s]})")
        continue

    sheet_start = start_row
    for r in range(2, ws.max_row + 1):
        src_vals = [ws.cell(r, c).value for c in mapped_source_cols]
        if not any(v not in (None, "") for v in src_vals):
            continue

        # Write values to A:K
        for dest_col, src_col in enumerate(mapped_source_cols, start=1):
            tgt = dest.cell(start_row, dest_col)
            src_cell = ws.cell(r, src_col)
            tgt.value = src_cell.value

            # Copy formatting from destination template row to match layout
            tmpl = dest.cell(template_row, dest_col)
            if tmpl.has_style:
                tgt.font = copy(tmpl.font)
                tgt.border = copy(tmpl.border)
                tgt.alignment = copy(tmpl.alignment)
                tgt.protection = copy(tmpl.protection)
                tgt.number_format = tmpl.number_format

            # no fill colors in consolidated data
            tgt.fill = PatternFill(fill_type=None)

        # Write source sheet name to L
        tgt = dest.cell(start_row, 12)
        tgt.value = s
        tmpl = dest.cell(template_row, 12)
        if tmpl.has_style:
            tgt.font = copy(tmpl.font)
            tgt.border = copy(tmpl.border)
            tgt.alignment = copy(tmpl.alignment)
            tgt.protection = copy(tmpl.protection)
            tgt.number_format = tmpl.number_format
        tgt.fill = PatternFill(fill_type=None)

        start_row += 1
        rows_written += 1

    if start_row > sheet_start:
        written_ranges[s] = (sheet_start, start_row - 1)

print("Rows written:", rows_written)
print("Written ranges:", written_ranges)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # Rename by position to original names
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = orig_name
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify output values with data_only
verify_wb = load_workbook(output_path, data_only=True)
verify_dest = verify_wb[dest_name]

print("Verification destination max_row:", verify_dest.max_row)
for s, rng in written_ranges.items():
    a, b = rng
    print(f"\nVerifying {s} rows {a}:{b}")
    sample_rows = list(range(a, min(a+3, b+1))) + (list(range(max(a, b-2), b+1)) if b-a+1 > 3 else [])
    seen = set()
    for rr in sample_rows:
        if rr in seen:
            continue
        seen.add(rr)
        vals = [verify_dest.cell(rr, c).value for c in range(1, 13)]
        print(rr, vals)

# Sanity check counts in output
final_counts = Counter()
for r in range(2, verify_dest.max_row + 1):
    sheet_name = verify_dest.cell(r, 12).value
    if sheet_name not in (None, ""):
        final_counts[str(sheet_name).strip()] += 1
print("\nFinal destination counts by source sheet:", final_counts)

# quick blank-check on written rows
issues = []
for s, rng in written_ranges.items():
    a, b = rng
    for rr in [a, b]:
        row_vals = [verify_dest.cell(rr, c).value for c in range(1, 13)]
        if any(v is None for v in row_vals[:11]) and any(v is not None for v in row_vals):
            issues.append((s, rr, row_vals))
print("Verification issues:", issues[:5])

final_output_spreadsheet = output_path
print("Prepared output:", final_output_spreadsheet)
```
