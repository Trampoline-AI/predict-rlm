from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
from copy import copy
import os

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet4"]
cb = wb["CBtrans"]

def norm_str(x):
    return x.strip() if isinstance(x, str) else x

# Build compact CBtrans records
cb_rows = []
for r in range(2, cb.max_row + 1):
    company = cb.cell(r, 1).value
    if company is None:
        continue
    cb_rows.append({
        "row": r,
        "company": cb.cell(r, 1).value,
        "docid": norm_str(cb.cell(r, 3).value),
        "year": cb.cell(r, 5).value,
        "period": cb.cell(r, 6).value,
        "account": norm_str(cb.cell(r, 8).value),
        "baseval": cb.cell(r, 9).value,
        "xchar": cb.cell(r, 11).value,
    })

def period_num(v):
    v = norm_str(v)
    if isinstance(v, str) and "/" in v:
        try:
            return int(v.split("/")[-1])
        except:
            return None
    return v

print("Detailed candidate checks for rows 2:7")
results_preview = {}
for r in range(2, 8):
    company = ws[f"B{r}"].value
    docid = norm_str(ws[f"C{r}"].value)
    year = ws[f"J{r}"].value
    per = period_num(ws[f"F{r}"].value)
    acct = norm_str(ws[f"I{r}"].value)
    xchar = ws[f"E{r}"].value
    
    m3 = [row for row in cb_rows if row["company"] == company and row["xchar"] == xchar and row["account"] == acct]
    m4 = [row for row in cb_rows if row["company"] == company and row["docid"] == docid and row["year"] == year and row["period"] == per]
    m5 = [row for row in cb_rows if row["company"] == company and row["docid"] == docid and row["year"] == year and row["period"] == per and row["account"] == acct]
    print(f"Row {r}: company={company}, docid={docid}, year={year}, period={per}, acct={acct}, xchar={xchar}")
    print("  company+xchar+account:", len(m3), [x["row"] for x in m3], [(x["account"], x["xchar"]) for x in m3[:2]])
    print("  company+docid+year+period:", len(m4), [x["row"] for x in m4], [(x['account'], x['xchar']) for x in m4[:2]])
    print("  +account too:", len(m5), [x["row"] for x in m5], [(x['account'], x['xchar']) for x in m5[:2]])
    results_preview[r] = "MATCH" if len(m3) > 0 else "-"

print("Proposed K2:K7 based on 3-way company+xchar+account:", results_preview)

# Inspect existing style cues in K2/K3
for ref in ["K2", "K3"]:
    c = ws[ref]
    print(ref, "value=", c.value, "fill=", c.fill.fill_type, c.fill.fgColor.rgb, "font bold/italic/name/size=", c.font.bold, c.font.italic, c.font.name, c.font.sz)

# Write outputs
pink_fill = PatternFill(fill_type="solid", start_color="FF66CC", end_color="FF66CC")
base_font = copy(ws["K2"].font)
base_font.bold = False
base_font.italic = False

for r in range(2, 8):
    ws[f"K{r}"] = results_preview[r]
    ws[f"K{r}"].fill = pink_fill
    ws[f"K{r}"].font = copy(base_font)

# Save
infile = os.path.basename(input_spreadsheet)
out_path = os.path.join("/sandbox/output/output_spreadsheet", infile)
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_status = await recalculate(out_path)
print("Recalc:", recalc_status)

# Reload and restore sheet names if needed
