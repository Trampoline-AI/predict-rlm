print("Sheet names after recalc:", wb2.sheetnames)
orig_names = ['Sheet4', 'CBtrans']
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for i, nm in enumerate(orig_names):
        wb2.worksheets[i].title = nm
    wb2.save(out_path)
    print("Renamed sheets back to original names:", wb2.sheetnames)

# Verify outputs with data_only and style with normal load
verify = load_workbook(out_path, data_only=True)
vws = verify["Sheet4"]
print("Verified K2:K7 values after recalc:")
for r in range(2, 8):
    print(f"K{r} =", vws[f"K{r}"].value)

style_wb = load_workbook(out_path)
