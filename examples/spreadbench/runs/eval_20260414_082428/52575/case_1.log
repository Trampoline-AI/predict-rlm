import os
from collections import defaultdict
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook normally (not data_only) for editing
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Using sheet:", ws.title)
print("Rows/Cols:", ws.max_row, ws.max_column)
print("Header row:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Current F1:F15:", [ws.cell(r, 6).value for r in range(1, 16)])

# Read all data rows
records = []
for r in range(2, ws.max_row + 1):
    records.append({
        "row": r,
        "date": ws.cell(r, 1).value,
        "emp": ws.cell(r, 2).value,
        "abs": ws.cell(r, 3).value,
        "att": ws.cell(r, 4).value,
        "week": ws.cell(r, 5).value,
    })

# Aggregate by employee/week across entire sheet
agg = defaultdict(lambda: {"has_sick": False, "has_ot": False, "rows": []})
for rec in records:
    key = (rec["emp"], rec["week"])
    agg[key]["rows"].append(rec["row"])
    absv = str(rec["abs"]).strip().lower() if rec["abs"] is not None else ""
    attv = str(rec["att"]).strip().lower() if rec["att"] is not None else ""
    if absv == "sick day":
        agg[key]["has_sick"] = True
    if attv == "overtime":
        agg[key]["has_ot"] = True

qualifying_pairs = {k for k, v in agg.items() if v["has_sick"] and v["has_ot"]}
print("Qualifying (emp, week) pairs:", sorted(qualifying_pairs))

# Determine start rows of each employee-week visible block
target_rows = []
for i, rec in enumerate(records):
    prev = records[i - 1] if i > 0 else None
    is_block_start = (
        prev is None
        or rec["emp"] != prev["emp"]
        or rec["week"] != prev["week"]
    )
    if is_block_start and (rec["emp"], rec["week"]) in qualifying_pairs:
        target_rows.append(rec["row"])

print("Rows to receive 'y' in col F:", target_rows)

# Clear only existing used-range cells in F that correspond to data rows,
# then write y to qualifying block starts. Leave F1 blank (no header).
for r in range(2, ws.max_row + 1):
    ws.cell(r, 6).value = None

for r in target_rows:
    ws.cell(r, 6).value = "y"

# Explicitly ensure header area unchanged / no added header
# F1 remains untouched/blank
print("Post-write preview rows 1:20 cols A:F")
for r in range(1, 21):
    print(r, [ws.cell(r, c).value for c in range(1, 7)])

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # Rename sheets back by index order
    for i, orig_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

# Verify target column values around all relevant rows
verify_rows = sorted(set(list(range(1, 21)) + target_rows + [44, 45, 65, 66, 74, 75, 82, 89]))
print("Verification of A:F on selected rows:")
for r in verify_rows:
    if 1 <= r <= wsv.max_row:
        print(r, [wsv.cell(r, c).value for c in range(1, 7)])

# Save final path in variable for submission
final_output_spreadsheet = outfile
print("Final output file ready:", final_output_spreadsheet)
