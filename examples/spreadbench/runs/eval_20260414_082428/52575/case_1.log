import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # Find non-empty rows/cols more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row+1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    
    # Print first 10 rows and last 5 rows
    first_rows = list(range(1, min(ws.max_row, 10)+1))
    last_rows = list(range(max(1, ws.max_row-4), ws.max_row+1))
    seen = []
    print("-- First rows --")
    for r in first_rows:
        vals = row_values(ws, r, ws.max_column)
        seen.append(r)
        print(r, vals)
    print("-- Last rows --")
    for r in last_rows:
        if r in seen:
            continue
        vals = row_values(ws, r, ws.max_column)
        print(r, vals)
    
    # Try to infer headers from first few rows
    for hr in range(1, min(5, ws.max_row)+1):
        vals = row_values(ws, hr, ws.max_column)
        print(f"Header candidate row {hr}:", vals)

    # Print coordinates and values for cells with formulas in first 50 rows
    formulas = []
    for r in range(1, min(ws.max_row, 50)+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((ws.cell(r,c).coordinate, v))
    print("Formulas in first 50 rows:", formulas[:20], "count:", len(formulas))
