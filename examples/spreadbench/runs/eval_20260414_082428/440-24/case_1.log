import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find a plausible header row among first 5 rows: row with most non-empty cells
    header_candidates = []
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v is not None and v != "" for v in vals)
        header_candidates.append((nonempty, r, vals))
    header_candidates.sort(reverse=True)
    header_row = header_candidates[0][1]
    headers = row_values(ws, header_row, ws.max_column)
    print("Chosen header row:", header_row)
    print("Headers:")
    for c, v in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}{header_row}: {v}")
    
    # Print first 10 rows
    first_n = min(10, ws.max_row)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast rows {start_last} to {ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Specifically inspect columns B and H current values/formulas
    if ws.max_column >= 8:
        print("\nInspecting columns B and H (first 10 data rows and last 5 rows):")
        inspect_rows = list(range(1, min(ws.max_row, 10) + 1))
        for r in range(start_last, ws.max_row + 1):
            if r not in inspect_rows:
                inspect_rows.append(r)
        for r in inspect_rows:
            b = ws.cell(r, 2).value
            h = ws.cell(r, 8).value
            print(f"Row {r}: B={b!r}, H={h!r}")
```
