for src_row in matches:
    for src_c, dst_c in zip(range(1, 6), range(9, 14)):
        src = ws.cell(src_row, src_c)
        dst = ws.cell(target_row, dst_c)
        dst.value = src.value
        if src.has_style:
            dst.font = copy(src.font)
            dst.fill = copy(src.fill)
            dst.border = copy(src.border)
            dst.alignment = copy(src.alignment)
            dst.number_format = src.number_format
            dst.protection = copy(src.protection)
        if src._style is not None:
