# Determine date bounds
start_date = ws["I2"].value
end_date = ws["J2"].value
print("Raw criteria:", start_date, end_date, type(start_date), type(end_date))

def normalize_dt(v):
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    return v

start_d = normalize_dt(start_date)
end_d = normalize_dt(end_date)

# Identify matching rows in A6:E315 / up to max_row
