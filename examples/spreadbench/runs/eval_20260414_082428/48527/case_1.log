import os
from collections import Counter
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Target sheet:", ws.title)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Pre-write D2:D5:", [(f"D{r}", ws[f"D{r}"].value) for r in range(2, ws.max_row + 1)])

def unique_when_two_match(values):
    # Return the value that occurs once when another value occurs twice.
    counts = Counter(values)
    for v, n in counts.items():
        if n == 1:
            return v
    return None

changed = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 4)]
    current_d = ws.cell(r, 4).value
    inferred = unique_when_two_match(vals)
    print(f"Row {r} A:C={vals} -> inferred unique={inferred!r}, existing D={current_d!r}")
    if (current_d is None or current_d == "") and inferred is not None:
        ws.cell(r, 4).value = inferred
        changed.append((r, inferred))

print("Changed rows:", changed)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only
verify_wb = load_workbook(outfile, data_only=True)
verify_ws = verify_wb[orig_sheetnames[0]]

print("Verified D1:D5:")
for r in range(1, verify_ws.max_row + 1):
    print(f"D{r} =", verify_ws.cell(r, 4).value)

output_spreadsheet = outfile
