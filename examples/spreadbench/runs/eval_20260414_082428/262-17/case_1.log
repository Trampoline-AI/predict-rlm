import os
from copy import copy
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]   # Sheet1 source
ws_expected = wb[original_sheetnames[1]]  # Sheet2 reference

# Reconfirm headers and target columns dynamically
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Headers in Sheet1:", headers)

task_col = None
resp_col = None
for idx, h in enumerate(headers, start=1):
    if isinstance(h, str) and h.strip().lower() == "task":
        task_col = idx
    if isinstance(h, str) and h.strip().lower() == "responsibility":
        resp_col = idx

print("Dynamic header positions:",
      {"Task": task_col, "Responsibility": resp_col})

# Determine actual non-empty data rows in Sheet1 (exclude header)
data_rows_idx = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v is not None and v != "" for v in vals):
        data_rows_idx.append(r)

print("Sheet1 non-empty data row indices:", data_rows_idx)
print("Current Sheet1 data before sort:")
for r in data_rows_idx:
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Build sortable data
data_rows = []
for r in data_rows_idx:
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    data_rows.append(row_vals)

# Expected rows from Sheet2, excluding note row
expected_rows = []
for r in range(2, ws_expected.max_row + 1):
    row_vals = [ws_expected.cell(r, c).value for c in range(1, ws_expected.max_column + 1)]
    if any(v is not None and v != "" for v in row_vals):
        if not (row_vals[2] == "First Sort" and row_vals[5] == "Second Sort"):
            expected_rows.append(row_vals)

print("Expected data rows count from Sheet2:", len(expected_rows))

# Sort by Task ascending, then Responsibility ascending
sorted_rows = sorted(
    data_rows,
    key=lambda row: (
        "" if row[task_col - 1] is None else str(row[task_col - 1]),
        "" if row[resp_col - 1] is None else str(row[resp_col - 1]),
    ),
)

print("Sorted rows preview:")
for i, row in enumerate(sorted_rows[:10], start=1):
    print(i, row)

# Write sorted rows back into the same rows on Sheet1
for out_r, row_vals in zip(data_rows_idx, sorted_rows):
    for c, val in enumerate(row_vals, start=1):
        ws.cell(out_r, c).value = val

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb2 = load_workbook(output_path)
print("Sheet names after recalc reload:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames:
    # rename sheets back by position
    for i, old_name in enumerate(original_sheetnames):
        wb2.worksheets[i].title = old_name
    wb2.save(output_path)
    print("Renamed sheets back to original names:", original_sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

vws1 = wb_verify[original_sheetnames[0]]
vws2 = wb_verify[original_sheetnames[1]]

verified_rows = []
for r in range(2, vws1.max_row + 1):
    row_vals = [vws1.cell(r, c).value for c in range(1, vws1.max_column + 1)]
    if any(v is not None and v != "" for v in row_vals):
        verified_rows.append(row_vals)

print("Verified Sheet1 rows after sort:")
for i, row in enumerate(verified_rows, start=2):
    print(i, row)

print("Target header cells/checks:")
print("Sheet1 C1 =", vws1["C1"].value)
print("Sheet1 F1 =", vws1["F1"].value)
print("Sheet2 C20 =", vws2["C20"].value)
print("Sheet2 F20 =", vws2["F20"].value)

match = verified_rows == expected_rows
print("Does Sheet1 now exactly match expected rows from Sheet2?", match)
print("Verified row count:", len(verified_rows), "Expected row count:", len(expected_rows))

# Keep output path for submission
final_output_spreadsheet = output_path
