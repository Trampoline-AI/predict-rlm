from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("FULL INSTRUCTION:\n", instruction)

wb = load_workbook(input_spreadsheet)
ws1 = wb[wb.sheetnames[0]]
ws2 = wb[wb.sheetnames[1]]

print("\nOriginal sheet names:", wb.sheetnames)

def print_range(ws, r1, r2, c1=1, c2=None, label=None):
    if c2 is None:
        c2 = ws.max_column
    if label:
        print(label)
    for r in range(r1, r2 + 1):
        vals = [ws.cell(r, c).value for c in range(c1, c2 + 1)]
        print(f"{ws.title} row {r}: {vals}")

print("\n--- Sheet2 rows 1-20 ---")
print_range(ws2, 1, 20, 1, ws2.max_column)

print("\n--- Specific cells referenced by discovered headers/labels ---")
for coord in ["C1", "F1", "C20", "F20"]:
    print("Sheet2", coord, "=", ws2[coord].value)

# Capture data rows excluding blank rows
headers1 = [ws1.cell(1, c).value for c in range(1, ws1.max_column + 1)]
headers2 = [ws2.cell(1, c).value for c in range(1, ws2.max_column + 1)]
print("\nHeaders Sheet1:", headers1)
print("Headers Sheet2:", headers2)

data1 = []
for r in range(2, ws1.max_row + 1):
    row = [ws1.cell(r, c).value for c in range(1, ws1.max_column + 1)]
    if any(v is not None and v != "" for v in row):
        data1.append(row)

data2 = []
for r in range(2, ws2.max_row + 1):
    row = [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)]
    if any(v is not None and v != "" for v in row):
        data2.append(row)

print("\nNon-empty data rows count:")
print("Sheet1:", len(data1))
print("Sheet2 excluding header but including note rows:", len(data2))
print("Last non-empty rows Sheet2:", data2[-3:])

# Exclude obvious note row(s) from Sheet2 expected data
expected2 = [row for row in data2 if row != [None, None, 'First Sort', None, None, 'Second Sort']]
print("Expected data rows inferred from Sheet2:", len(expected2))
print("First 5 expected rows:", expected2[:5])
print("Last 5 expected rows:", expected2[-5:])

# Compare against possible sort directions
task_idx = headers1.index("Task")
resp_idx = headers1.index("Responsibility")

def sort_rows(rows, task_reverse=False, resp_reverse=False):
    # stable multi-key sort: second key first, then first key
    rows2 = rows[:]
    rows2.sort(key=lambda x: x[resp_idx], reverse=resp_reverse)
    rows2.sort(key=lambda x: x[task_idx], reverse=task_reverse)
    return rows2

candidates = {
    "Task asc, Resp asc": sort_rows(data1, False, False),
    "Task asc, Resp desc": sort_rows(data1, False, True),
    "Task desc, Resp asc": sort_rows(data1, True, False),
    "Task desc, Resp desc": sort_rows(data1, True, True),
}

for name, rows in candidates.items():
    matches = rows == expected2
    print(f"\nCandidate: {name} -> exact match with Sheet2 expected? {matches}")
    print(" first 5:", [(r[task_idx], r[resp_idx], r[1]) for r in rows[:5]])
    print(" last 5:", [(r[task_idx], r[resp_idx], r[1]) for r in rows[-5:]])

# Also compare row-by-row mismatches for the best guess likely task asc / resp asc
guess = candidates["Task asc, Resp asc"]
mismatches = []
for i, (a, b) in enumerate(zip(guess, expected2), start=2):
    if a != b:
        mismatches.append((i, a, b))
print("\nMismatch count for Task asc, Resp asc guess:", len(mismatches))
if mismatches:
    print("First few mismatches:")
    for m in mismatches[:5]:
        print(m)
