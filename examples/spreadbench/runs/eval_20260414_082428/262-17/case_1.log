import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # find actual used rows/cols roughly
    rows = list(ws.iter_rows(values_only=True))
    nonempty_rows = [i+1 for i,r in enumerate(rows) if any(v is not None and v != "" for v in r)]
    print("nonempty row count:", len(nonempty_rows), "first/last nonempty rows:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    # print first 10 rows with coordinates
    first_n = min(10, ws.max_row)
    print("-- First rows --")
    for r in range(1, first_n+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    print("-- Last 5 rows --")
    start = max(1, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    # detect candidate headers in first few rows
    print("-- Header search for Task/Responsibility --")
    for r in range(1, min(ws.max_row, 5)+1):
        hits = []
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.strip().lower() in {"task", "tasks", "responsibility", "responsibilities"}:
                hits.append((get_column_letter(c), r, v))
        if hits:
            print("row", r, "hits:", hits)

for ws in wb.worksheets:
    sheet_info(ws)
