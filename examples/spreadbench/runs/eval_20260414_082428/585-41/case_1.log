```repl
import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Reload fresh workbook for modification
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before modification Sheet1!A1:H1:")
before_vals = []
for c in range(1, 9):
    cell = ws.cell(1, c)
    before_vals.append(cell.value)
    print(cell.coordinate, repr(cell.value), cell.data_type)

def clean_preserve_decimal(value):
    # Preserve numeric values exactly as numeric
    if isinstance(value, (int, float)) and not isinstance(value, bool):
        return value
    if value is None:
        return value
    s = str(value)
    # Remove everything except digits and decimal points
    cleaned = re.sub(r"[^0-9.]", "", s)
    return cleaned

# Apply to A1:H1
for c in range(1, 9):
    cell = ws.cell(1, c)
    old_val = cell.value
    new_val = clean_preserve_decimal(old_val)
    cell.value = new_val

print("\nAfter in-memory modification Sheet1!A1:H1:")
for c in range(1, 9):
    cell = ws.cell(1, c)
    print(cell.coordinate, repr(cell.value), cell.data_type)

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open after recalc and restore original sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # Rename sheets back by position
    for i, original_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify with formulas/data cached
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

print("\nVerified final values in Sheet1!A1:H1:")
verified = {}
for c in range(1, 9):
    cell = wsv.cell(1, c)
    verified[cell.coordinate] = cell.value
    print(cell.coordinate, repr(cell.value), type(cell.value).__name__)

# Sanity checks
assert "Sheet1" in wb_verify.sheetnames
for coord in ["A1","B1","C1","D1","E1","F1","G1","H1"]:
    assert verified[coord] is not None, f"{coord} is blank"

final_output_path = output_path
print("\nFinal output path ready:", final_output_path)
```
