```repl
import os, shutil
from datetime import datetime
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load both formula workbook (for writing) and data_only workbook (for reading evaluated values)
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

wb_data = load_workbook(input_path, data_only=True)
ws_data = wb_data[wb_data.sheetnames[0]]

original_sheet_names = wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

# Helper to convert Excel serial / datetime to year
def extract_year(v):
    if v is None or v == "":
        return None
    if isinstance(v, datetime):
        return v.year
    # openpyxl data_only often returns datetime, but some cells may still be numeric serials
    if isinstance(v, (int, float)):
        try:
            return ws_data.parent.epoch.fromordinal(1).year  # dummy branch never really used
        except Exception:
            pass
        try:
            # use workbook's date system conversion
            from openpyxl.utils.datetime import from_excel
            dt = from_excel(v, ws_data.parent.epoch)
            return dt.year
        except Exception:
            return None
    return None

# Define table structure
categories = {
    "Rentals": (8, 37),
    "Sales": (41, 58),
    "Commercial": (62, 74),
}
agent_rows = {
    "PE": {"Rentals": 40, "Sales": 41, "Commercial": 42},
    "GS": {"Rentals": 45, "Sales": 46, "Commercial": 47},
    "CC": {"Rentals": 50, "Sales": 51, "Commercial": 52},
}
years = [2021, 2022, 2023, 2024, 2025]
year_to_col = {2021: 11, 2022: 12, 2023: 13, 2024: 14, 2025: 15}  # K:O

# Inspect date header cells explicitly
print("Header year cells:")
for coord in ["K43","L43","M43","N43","O43","K48","L48","M48","N48","O48","K53","L53","M53","N53","O53"]:
    print(coord, ws[coord].value)

# Compute totals using cached numeric values
totals = {agent: {cat: {yr: 0 for yr in years} for cat in categories} for agent in agent_rows}
matched_rows = []

for cat, (r1, r2) in categories.items():
    for r in range(r1, r2 + 1):
        agent = ws_data[f"H{r}"].value
        comm = ws_data[f"C{r}"].value
        date_val = ws_data[f"F{r}"].value
        year = extract_year(date_val)

        # normalize agent matching exactly by containment, per workbook convention
        if isinstance(agent, str):
            for code in agent_rows:
                if code in agent:
                    if year in year_to_col and isinstance(comm, (int, float)):
                        totals[code][cat][year] += comm
                        matched_rows.append((r, cat, code, year, comm, date_val))

print("\nMatched contributing rows:")
for item in matched_rows:
    print(item)

print("\nComputed totals:")
for code in ["PE", "GS", "CC"]:
    print(code, totals[code])

# Print existing target values before write
print("\nExisting target J39:O53 before write:")
for r in range(39, 54):
    print(r, [ws.cell(r, c).value for c in range(10, 16)])

# Write computed totals into K:O for the target rows
for code, cat_map in agent_rows.items():
    for cat, row in cat_map.items():
        for yr in years:
            col = year_to_col[yr]
            ws.cell(row=row, column=col).value = totals[code][cat][yr]

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and ensure sheet names preserved
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # rename back in order
    for i, expected in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verify output with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
ws_verify = wb_verify[original_sheet_names[0]]

print("\nVerified target J39:O53 after write/recalc:")
for r in range(39, 54):
    print(r, [ws_verify.cell(r, c).value for c in range(10, 16)])

# Sanity check the exact target rows written
print("\nSanity check target numeric cells:")
for code, cat_map in agent_rows.items():
    for cat, row in cat_map.items():
        vals = [ws_verify.cell(row, year_to_col[yr]).value for yr in years]
        print(code, cat, row, vals)

final_output_spreadsheet = output_path
```
