import os, json, textwrap, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

input_path = input_spreadsheet
print("\nInput path:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
print("Original sheet names:", wb.sheetnames)

def display_sheet_info(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find a likely header row among first 10 rows by counting non-empty cells
    best_row = None
    best_count = -1
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        count = sum(v is not None and v != "" for v in vals)
        if count > best_count:
            best_count = count
            best_row = r
    print("Likely header row:", best_row)
    headers = [ws.cell(best_row, c).value for c in range(1, ws.max_column + 1)]
    print("Headers:", headers)
    
    # Print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    display_sheet_info(ws)

# Print formulas in workbook to identify targets
print("\n=== Formula cells ===")
formula_cells = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
