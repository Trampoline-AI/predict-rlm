import os
from openpyxl import load_workbook

# Load workbook normally (with formulas)
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before modification:")
for r in range(4, ws.max_row + 1):
    print(r, ws[f"C{r}"].value, ws[f"D{r}"].value)

# Update formulas in D4:Dmax_row for rows that have values in column C
for r in range(4, ws.max_row + 1):
    c_val = ws[f"C{r}"].value
    d_cell = ws[f"D{r}"]
    if c_val is not None:
        d_cell.value = (
            f'=IF(AND(C{r}>=5,C{r}<=6),5,'
            f'IF(AND(C{r}>=3,C{r}<=4),3.75,'
            f'IF(AND(C{r}>=1,C{r}<=2),1,0)))'
        )

print("\nAfter modification (formulas written):")
for r in range(4, ws.max_row + 1):
    print(r, ws[f"D{r}"].value)

# Save to output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(out_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_sheet_names[0]]

print("\nVerification C4:D15 (data_only values):")
verified = []
for r in range(4, wsv.max_row + 1):
    c = wsv[f"C{r}"].value
    d = wsv[f"D{r}"].value
    verified.append((r, c, d))
    print(r, c, d)

# Also verify formula strings in normal load
