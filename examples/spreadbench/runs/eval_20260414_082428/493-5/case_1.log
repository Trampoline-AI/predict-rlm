import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws, sample_cols=None, first_n=10, last_n=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect header row candidates (first 3 rows)
    for r in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals[:min(12, len(vals))])
    
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    
    if ws.max_row > 1:
        print("First data/sample rows:")
        for r in range(1, min(ws.max_row, first_n) + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"  r{r}:", vals[:min(12, len(vals))])
        if ws.max_row > first_n:
            print("Last rows:")
            start = max(1, ws.max_row - last_n + 1)
            for r in range(start, ws.max_row + 1):
                vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
                print(f"  r{r}:", vals[:min(12, len(vals))])
    
    # detailed A:F inspection
    cols = list(range(1, min(6, ws.max_column) + 1))
    print("Detailed A:F preview (first 10 rows):")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in cols]
        print(f"  r{r}:", vals)
    if ws.max_row > 10:
        print("Detailed A:F preview (last 5 rows):")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in cols]
            print(f"  r{r}:", vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Try to identify possible target sheet(s) by presence of at least 6 columns
candidate_sheets = []
for ws in wb.worksheets:
    headers = [ws.cell(1, c).value for c in range(1, min(ws.max_column, 10) + 1)]
    candidate_sheets.append((ws.title, ws.max_row, ws.max_column, headers[:6]))
print("\nCandidate sheets summary:", candidate_sheets)
