```repl
import os, shutil
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb["Imported Data"]

print("Sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Print all rows A:F plus E formula explicitly
print("\nAll rows A:F:")
all_rows = []
for r in range(1, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, 7)]
    all_rows.append(row_vals)
    print(f"r{r}: {row_vals}")

print("\nColumn E formulas/values:")
for r in range(2, ws.max_row + 1):
    print(f"E{r} =", ws[f"E{r}"].value)

# Find candidate row pairs based on instruction
matches = []
for i in range(2, ws.max_row + 1):
    Ai = ws.cell(i, 1).value
    Ci = ws.cell(i, 3).value
    Di = ws.cell(i, 4).value
    Fi = ws.cell(i, 6).value
    for j in range(2, ws.max_row + 1):
        if i == j:
            continue
        Aj = ws.cell(j, 1).value
        Cj = ws.cell(j, 3).value
        Dj = ws.cell(j, 4).value
        Fj = ws.cell(j, 6).value
        if Ai == Aj and Fi == Fj and Ci == Dj:
            matches.append((i, j, Ai, Fi, Ci, Dj, Di, Cj))

print("\nDirectional matches (row i's C == row j's D, same A and F):")
for m in matches:
    i, j, A, F, Ci, Dj, Di, Cj = m
    print(f"rows ({i},{j}) | A={A!r} F={F!r} | C{i}={Ci} == D{j}={Dj} | D{i}={Di} C{j}={Cj}")

# Collapse into unordered row pairs where at least one directional match exists
pair_set = set()
for i, j, *_ in matches:
    pair_set.add(tuple(sorted((i, j))))
pair_list = sorted(pair_set)

print("\nUnique candidate row pairs to delete:")
for p in pair_list:
    i, j = p
    print(f"Pair {p}:")
    print(" ", i, [ws.cell(i, c).value for c in range(1, 7)])
    print(" ", j, [ws.cell(j, c).value for c in range(1, 7)])

# Proceed with deletion if clearly identified
rows_to_delete = sorted({r for pair in pair_list for r in pair}, reverse=True)
print("\nRows marked for deletion (descending):", rows_to_delete)

# Save a copy with deletions
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))

wb2 = load_workbook(input_path)
ws2 = wb2["Imported Data"]
for r in rows_to_delete:
    ws2.delete_rows(r, 1)

wb2.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and check sheet names; restore if altered
wb_chk = load_workbook(out_path)
print("Sheet names after recalc:", wb_chk.sheetnames)
if wb_chk.sheetnames != wb.sheetnames:
    # rename by position to original names
    for idx, orig_name in enumerate(wb.sheetnames):
        wb_chk.worksheets[idx].title = orig_name
    wb_chk.save(out_path)
    print("Restored sheet names to:", wb.sheetnames)

# Verify output with formulas cached
wb_val = load_workbook(out_path, data_only=False)
ws_val = wb_val["Imported Data"]
print("\nPost-delete rows A:F:")
for r in range(1, ws_val.max_row + 1):
    print(f"r{r}: {[ws_val.cell(r, c).value for c in range(1, 7)]}")

wb_data = load_workbook(out_path, data_only=True)
ws_data = wb_data["Imported Data"]
print("\nPost-recalc cached values A:F:")
for r in range(1, ws_data.max_row + 1):
    print(f"r{r}: {[ws_data.cell(r, c).value for c in range(1, 7)]}")

output_spreadsheet = out_path
