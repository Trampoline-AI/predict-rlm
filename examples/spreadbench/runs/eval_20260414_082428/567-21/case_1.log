import os
from collections import defaultdict
from copy import copy
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh from input for the actual write step
wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames[:]
ws2 = wb2[orig_sheet_names[0]]

print("Working on sheet:", ws2.title, "rows:", ws2.max_row, "cols:", ws2.max_column)

# Detect actual data start: based on inspection, rows 1-2 blank and row 3 begins data.
# Use first row where A/B/E has any value.
data_start = None
for r in range(1, ws2.max_row + 1):
    if any(ws2.cell(r, c).value is not None for c in [1, 2, 5]):
        data_start = r
        break
if data_start is None:
    raise ValueError("No data rows found.")
print("Detected data_start row:", data_start)

max_col = ws2.max_column
original_rows = [
    [ws2.cell(r, c).value for c in range(1, max_col + 1)]
    for r in range(1, ws2.max_row + 1)
]

# Build groups from data rows, deleting blank-E rows by simply not keeping them
groups = defaultdict(list)
for r in range(data_start, ws2.max_row + 1):
    row_vals = original_rows[r - 1]
    a = row_vals[0]
    b = row_vals[1]
    e = row_vals[4] if max_col >= 5 else None
    # Skip fully blank rows
    if all(v is None for v in row_vals):
        continue
    # Rows with blank E are to be deleted
    if e is None:
        continue
    groups[(a, b)].append((r, e, row_vals))

keep_source_rows = []
kept_records = []

for key, items in groups.items():
    max_e = max(e for _, e, _ in items)
    for r, e, row_vals in items:
        if e == max_e:
            keep_source_rows.append(r)
            kept_records.append((r, row_vals))

keep_source_rows = sorted(keep_source_rows)
kept_records.sort(key=lambda x: x[0])  # preserve original order among kept rows

print("Rows selected to keep:", keep_source_rows)
print("Number of kept data rows:", len(kept_records))

# Rewrite kept rows in place starting at data_start, preserving top blank rows/structure
write_row = data_start
for _, row_vals in kept_records:
    for c in range(1, max_col + 1):
        ws2.cell(write_row, c).value = row_vals[c - 1]
    write_row += 1

# Clear remaining old rows below rewritten data
for r in range(write_row, ws2.max_row + 1):
    for c in range(1, max_col + 1):
        ws2.cell(r, c).value = None

wb2.save(output_path)
print("Saved initial output to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(output_path)
current_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != orig_sheet_names:
    # rename sheets back by position
    for i, orig_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verification with formulas/data cached
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

# Print all rows in target area after processing
print("\nFINAL SHEET CONTENT PREVIEW:")
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, max_col + 1)]
    if r <= 12 or r > wsv.max_row - 5:
        print(r, vals)

# Detailed kept rows verification
final_nonblank_rows = []
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, max_col + 1)]
    if any(v is not None for v in vals):
        final_nonblank_rows.append((r, vals))

print("\nAll nonblank final rows:")
for r, vals in final_nonblank_rows:
    print(r, vals)

# Sanity check groups in final output
final_groups = defaultdict(list)
for r in range(data_start, wsv.max_row + 1):
    a = wsv.cell(r, 1).value
    b = wsv.cell(r, 2).value
    e = wsv.cell(r, 5).value
    row_vals = [wsv.cell(r, c).value for c in range(1, max_col + 1)]
    if all(v is None for v in row_vals):
        continue
    final_groups[(a, b)].append((r, e))

print("\nFinal group summary:")
for key, items in final_groups.items():
    print(key, items)

# Basic assertions / checks
assert wb_verify.sheetnames == orig_sheet_names, "Sheet names changed unexpectedly"
for key, items in final_groups.items():
    dates = [e for _, e in items]
    assert all(e is not None for e in dates), f"Blank E remained in group {key}"
    assert len(set(dates)) == 1, f"Non-tied multiple dates remained for group {key}"

result_file = output_path
