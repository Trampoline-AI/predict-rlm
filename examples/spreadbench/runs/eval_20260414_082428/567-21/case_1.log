def sample_sheet(ws, n_first=8, n_last=5, max_cols=15):
    mr, mc = ws.max_row, ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", mr, "max_column:", mc)
    headers = [ws.cell(1, c).value for c in range(1, mc+1)]
    print("Header row 1:", headers[:max_cols], "..." if mc > max_cols else "")
    if mr >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, mc+1)]
        print("Row 2 preview:", row2[:max_cols], "..." if mc > max_cols else "")
    # print columns A,B,E current values a bit more carefully
    for coord in ["A1","B1","E1","A2","B2","E2","A3","B3","E3"]:
        if ws.max_row >= int(coord[1:]) and ws.max_column >= ord(coord[0]) - 64:
            print(coord, "=", ws[coord].value)
    # first rows
    first_end = min(mr, n_first)
    print(f"First {first_end} rows:")
    for r in range(1, first_end+1):
        vals = [ws.cell(r, c).value for c in range(1, min(mc, max_cols)+1)]
        print(r, vals)
    # last rows
    if mr > n_first:
        start = max(1, mr - n_last + 1)
        print(f"Last rows {start}-{mr}:")
        for r in range(start, mr+1):
            vals = [ws.cell(r, c).value for c in range(1, min(mc, max_cols)+1)]
            print(r, vals)

for ws in wb.worksheets:
    sample_sheet(ws)

# Also inspect row 1-5 columns with letters to identify target columns
for ws in wb.worksheets:
    print(f"\nColumn mapping for {ws.title}:")
    for c in range(1, min(ws.max_column, 15)+1):
        print(c, get_column_letter(c), ws.cell(1, c).value)

