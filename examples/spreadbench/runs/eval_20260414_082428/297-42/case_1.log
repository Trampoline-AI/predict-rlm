import os, shutil
from openpyxl import load_workbook

# Re-open and inspect remaining details in a compact way
wb = load_workbook(input_spreadsheet)
combined_ws = wb["combined"]
target_headers = [combined_ws.cell(1, c).value for c in range(1, combined_ws.max_column + 1)]
print("Target headers:", target_headers)

summary = []
for s in wb.sheetnames:
    ws = wb[s]
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    summary.append((s, ws.max_row, ws.max_column, headers == target_headers))
print("Sheet summary (name, max_row, max_col, headers_match_combined):")
for item in summary:
    print(item)

# Show first/last few rows for sheets not fully visible before
for s in [name for name in wb.sheetnames if name != "combined"]:
    ws = wb[s]
    print(f"\n{s}: first data row =", [ws.cell(2, c).value for c in range(1, ws.max_column + 1)])
    print(f"{s}: last data row  =", [ws.cell(ws.max_row, c).value for c in range(1, ws.max_column + 1)])

# Perform the consolidation into existing combined sheet.
# Clear any existing rows below header just in case.
if combined_ws.max_row > 1:
    for row in combined_ws.iter_rows(min_row=2, max_row=combined_ws.max_row, min_col=1, max_col=combined_ws.max_column):
        for cell in row:
            cell.value = None

out_row = 2
copied_counts = {}
for s in wb.sheetnames:
    if s == "combined":
        continue
    ws = wb[s]
    src_headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    header_to_col = {h: i+1 for i, h in enumerate(src_headers)}
    count = 0
    for r in range(2, ws.max_row + 1):
        # skip entirely blank rows
        row_values = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if all(v is None for v in row_values):
            continue
        for out_c, h in enumerate(target_headers, start=1):
            combined_ws.cell(out_row, out_c).value = ws.cell(r, header_to_col[h]).value if h in header_to_col else None
        out_row += 1
        count += 1
    copied_counts[s] = count

print("\nCopied counts by sheet:", copied_counts)
print("Total copied rows:", sum(copied_counts.values()))
print("combined max_row after write:", combined_ws.max_row)

# Save
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and ensure original sheet names preserved
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    # rename back if changed
    for i, orig_name in enumerate(wb.sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = orig_name
    wb2.save(output_path)
    print("Renamed sheets back to original names:", wb2.sheetnames)

# Verify with data_only
wbv = load_workbook(output_path, data_only=True)
cv = wbv["combined"]
print("Verified combined size:", cv.max_row, "rows x", cv.max_column, "cols")
print("Combined header row:", [cv.cell(1, c).value for c in range(1, cv.max_column + 1)])
for r in range(2, min(6, cv.max_row) + 1):
    print(f"combined R{r}:", [cv.cell(r, c).value for c in range(1, cv.max_column + 1)])
if cv.max_row >= 5:
    start_last = max(2, cv.max_row - 4)
    for r in range(start_last, cv.max_row + 1):
        print(f"combined R{r}:", [cv.cell(r, c).value for c in range(1, cv.max_column + 1)])

# Save output_path for submission
final_output_path = output_path
