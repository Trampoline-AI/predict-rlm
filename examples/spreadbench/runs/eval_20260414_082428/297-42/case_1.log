wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames
print("Original sheet names:", orig_sheetnames)

def sheet_info(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    return max_row, max_col, headers

all_info = {}
for s in wb.sheetnames:
    ws = wb[s]
    max_row, max_col, headers = sheet_info(ws)
