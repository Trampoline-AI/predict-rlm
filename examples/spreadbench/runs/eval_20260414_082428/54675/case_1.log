import os, shutil, re
from openpyxl import load_workbook

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Find actual used rows (ignore fully blank tail rows)
last_data_row = 0
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
        last_data_row = r
        break

print("Max row:", ws.max_row, "Last data row:", last_data_row)
print("Current F3 formula:", ws["F3"].value)

# Inspect rows where A=4 and B contains Gary Stoddard
matches_contains = []
total_occurrences = 0
for r in range(2, last_data_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a == 4 and isinstance(b, str) and "Gary Stoddard" in b:
        count_in_cell = b.count("Gary Stoddard")
        matches_contains.append((r, a, b, count_in_cell))
        total_occurrences += count_in_cell

print("Rows where A=4 and B contains 'Gary Stoddard':", len(matches_contains))
print("Total textual occurrences across those cells:", total_occurrences)
print("Sample matching rows (up to first 15):")
for item in matches_contains[:15]:
    print(item)

# Also count exact-match cells from current formula logic
exact_match_rows = []
for r in range(2, last_data_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a == 4 and b == "Gary Stoddard":
        exact_match_rows.append(r)
print("Exact-match rows count:", len(exact_match_rows), "Rows:", exact_match_rows[:20])

# Choose formula: count all occurrences within cells while A=4
# This also naturally counts single occurrences and those embedded with other names.
new_formula = (
    '=SUMPRODUCT((A$2:A$%d=4)*'
    '((LEN(B$2:B$%d)-LEN(SUBSTITUTE(B$2:B$%d,"Gary Stoddard","")))/LEN("Gary Stoddard")))'
    % (last_data_row, last_data_row, last_data_row)
)
print("New formula for F3:", new_formula)

ws["F3"] = new_formula

# Save to output path with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if needed after recalc
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != ["Sheet1"]:
    # rename first/only sheet back when appropriate
    if len(wb_after.sheetnames) == 1:
        wb_after[wb_after.sheetnames[0]].title = "Sheet1"
        wb_after.save(out_path)
        print("Renamed sheet back to Sheet1 and saved.")

# Verify with formulas view and data_only view
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("Verified formula in F3:", ws_formula["F3"].value)

wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Cached value in F3 after recalc:", ws_values["F3"].value)
print("Target cell nonblank?:", ws_values["F3"].value is not None)
