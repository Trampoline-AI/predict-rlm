import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

sheet_info = {}
for s in wb.sheetnames:
    ws = wb[s]
    headers = row_values(ws, 1, ws.max_column)
    sheet_info[s] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers
    }
    print(f"\n--- Sheet: {s} ---")
    print("Rows:", ws.max_row, "Cols:", ws.max_column)
    print("Headers row 1:", headers)
    # print first up to 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    # print last 5 rows if beyond first_n
    if ws.max_row > first_n:
        start_last = max(first_n + 1, ws.max_row - 4)
        print(f"Last rows {start_last}:{ws.max_row}:")
        for r in range(start_last, ws.max_row + 1):
            print(r, row_values(ws, r, ws.max_column))

