import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
pricing_ws = wb["Pricing"]
pkg_ws = wb["Package & Weight Data"]

# Determine actual data extent on Package & Weight Data in rows 2+
pkg_last_row = 1
for r in range(pkg_ws.max_row, 1, -1):
    if any(pkg_ws.cell(r, c).value is not None for c in range(1, 5)):
        pkg_last_row = r
        break
print("Package data actual last row:", pkg_last_row)

# Print current target cells and any existing formulas/values in E
for r in range(1, pricing_ws.max_row + 1):
    print(f"Before write Pricing!C{r}: {pricing_ws.cell(r,3).value}, D{r}: {pricing_ws.cell(r,4).value}, E{r}: {pricing_ws.cell(r,5).value}")

# Write formula to all relevant populated data rows (rows with package type and weight)
for r in range(2, pricing_ws.max_row + 1):
    package_type = pricing_ws.cell(r, 3).value
    weight = pricing_ws.cell(r, 4).value
    if package_type not in (None, "") and weight not in (None, ""):
        formula = (
            f'=SUMIFS(\'Package & Weight Data\'!$D$2:$D${pkg_last_row},'
            f'\'Package & Weight Data\'!$A$2:$A${pkg_last_row},C{r},'
            f'\'Package & Weight Data\'!$B$2:$B${pkg_last_row},"<="&D{r},'
            f'\'Package & Weight Data\'!$C$2:$C${pkg_last_row},">="&D{r})'
        )
        pricing_ws.cell(r, 5).value = formula
        print(f"Wrote E{r} formula:", formula)

wb.save(output_path)
print("Saved to:", output_path, "exists:", os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # Rename by position to restore original names
    for i, original_name in enumerate(orig_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas persisted
wb_formula = load_workbook(output_path, data_only=False)
pricing_formula = wb_formula["Pricing"]
for r in range(2, pricing_formula.max_row + 1):
    print(f"Formula check E{r}:", pricing_formula.cell(r, 5).value)

# Verify cached calculated values
wb_values = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_values.sheetnames)
pricing_values = wb_values["Pricing"]
for r in range(1, pricing_values.max_row + 1):
    print(f"Verified row {r} A:E:", [pricing_values.cell(r, c).value for c in range(1, 6)])

result_file = output_path
print("result_file:", result_file)
```
