```repl
import os, shutil
from datetime import datetime, timedelta
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load original workbook
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Gather actual dates from column A (rows with real date values)
a_dates = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, datetime):
        a_dates.append(v)

min_d, max_d = min(a_dates), max(a_dates)
existing = set(a_dates)

# Compute missing dates across full min..max span
missing = []
cur = min_d
while cur <= max_d:
    if cur not in existing:
        missing.append(cur)
    cur += timedelta(days=1)

print("Computed missing dates:", missing)
print("Target write range in column C:", f"C2:C{1+len(missing)}")

# Inspect existing target cells before writing
before = [(r, ws.cell(r, 3).value) for r in range(2, max(ws.max_row, 1 + len(missing)) + 1) if r <= 20]
print("Column C before write (sample):", before)

# Preserve existing correct prefix values; write full expected output to C2:C...
for idx, d in enumerate(missing, start=2):
    cell = ws.cell(idx, 3)
    # Copy number format from column A nearby if C is blank/general
    if cell.number_format in ("General", None, ""):
        cell.number_format = ws.cell(2, 1).number_format
    cell.value = d

# Clear stale values below the expected output range in column C if any
for r in range(2 + len(missing), ws.max_row + 1):
    if ws.cell(r, 3).value is not None:
        ws.cell(r, 3).value = None

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position
    for i, name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with data_only=True
wb_val = load_workbook(output_path, data_only=True)
ws_val = wb_val[orig_sheet_names[0]]

verified = [(f"C{r}", ws_val.cell(r, 3).value) for r in range(2, 2 + len(missing))]
print("Verified target cells:")
for item in verified:
    print(item)

# Basic checks
blanks = [addr for addr, val in verified if val is None]
print("Blank target cells:", blanks)

# Also verify all expected values match
mismatches = []
for i, expected in enumerate(missing, start=2):
    actual = ws_val.cell(i, 3).value
    if actual != expected:
        mismatches.append((f"C{i}", actual, expected))
print("Mismatches:", mismatches)

prepared_output = output_path
```
