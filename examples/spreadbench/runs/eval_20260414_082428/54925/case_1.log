from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Support"]

# Inspect column Q formulas / array formulas and relevant neighboring columns
print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)
for r in range(1, min(ws.max_row, 12) + 1):
    q = ws.cell(r, 17).value
    q_repr = q.text if hasattr(q, "text") else q
    print(f"Row {r}: B={ws.cell(r,2).value}, H={ws.cell(r,8).value}, K={ws.cell(r,11).value}, "
          f"M={ws.cell(r,13).value}, N={ws.cell(r,14).value}, Q={q_repr!r}")

print("\nLast Q rows:")
for r in range(max(1, ws.max_row-5), ws.max_row+1):
    q = ws.cell(r, 17).value
    q_repr = q.text if hasattr(q, "text") else q
    print(f"Row {r}: Q={q_repr!r}")

# Find exact matches for H=M3 and K in {N3,N4}
m3, n3, n4 = ws["M3"].value, ws["N3"].value, ws["N4"].value
matches = []
for r in range(2, ws.max_row + 1):
    b = ws.cell(r, 2).value
    h = ws.cell(r, 8).value
    k = ws.cell(r, 11).value
    if b is None and h is None and k is None:
        continue
    if h == m3 and k in {n3, n4}:
        matches.append((r, b, h, k))
print("\nCriteria values:", m3, n3, n4)
print("Matches found:", len(matches))
print("First matches:", matches[:20])

# Print current fills in Q for any existing rows
for r in range(1, min(ws.max_row, 12) + 1):
    cell = ws.cell(r, 17)
    print(f"Q{r} fill:", cell.fill.fill_type, cell.fill.start_color.rgb)

# Write results into Q2:Q40 / actual used rows as sequential extracted list
# Clear prior target area first
yellow = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
green = PatternFill(start_color="92D050", end_color="92D050", fill_type="solid")
no_fill = PatternFill(fill_type=None)

last_data_row = 40 if ws.max_row >= 40 else ws.max_row
for r in range(2, last_data_row + 1):
    ws.cell(r, 17).value = None
    ws.cell(r, 17).fill = no_fill

out_row = 2
for source_row, b, h, k in matches:
    ws.cell(out_row, 17).value = b
    ws.cell(out_row, 17).fill = yellow if k == n3 else green
    out_row += 1

# Preserve/define header in Q1 if blank or formula object
if ws["Q1"].value is None or hasattr(ws["Q1"].value, "text"):
    ws["Q1"] = "Result"

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore original sheet name if changed
orig_names = wb.sheetnames[:]
wb2 = load_workbook(out_path)
print("Sheetnames after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Restored sheet names to:", orig_names)

# Verify values after recalc
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_names[0]]
print("\nVerified Q1:Q20 values:")
for r in range(1, 21):
    print(r, wsv.cell(r, 17).value)

# Also verify fills by loading non-data_only workbook
wbf = load_workbook(out_path)
wsf = wbf[orig_names[0]]
print("\nVerified Q2:Q20 fills (rgb):")
for r in range(2, 21):
    print(r, wsf.cell(r, 17).value, wsf.cell(r, 17).fill.start_color.rgb, wsf.cell(r, 17).fill.fill_type)
