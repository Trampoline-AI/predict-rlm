from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook normally
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Writing formulas to target column BE...")
print("Original sheet names:", orig_sheet_names)

# Verify target cells before writing
for r in range(1, ws.max_row + 1):
    print(f"Pre-write C{r}={ws[f'C{r}'].value!r}, BE{r}={ws[f'BE{r}'].value!r}")

# Write formula for all relevant data rows only
written_rows = []
for r in range(3, ws.max_row + 1):
    row_label = ws[f"C{r}"].value
    has_data = any(ws.cell(r, c).value is not None for c in range(column_index_from_string("D"), column_index_from_string("BC")+1))
    if row_label is not None and has_data:
        formula = f"=SUMPRODUCT((D$2:BC$2>=$B$2)*D{r}:BC{r})"
        # write to exact target column BE
        ws[f"BE{r}"] = formula
        written_rows.append((r, formula))

print("Rows written:", written_rows)

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    for i, old_name in enumerate(orig_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerification of target cells BE3:BE14")
verification = []
for r in range(3, ws_values.max_row + 1):
    formula = ws_formula[f"BE{r}"].value
    value = ws_values[f"BE{r}"].value
    label = ws_values[f"C{r}"].value
    verification.append((r, label, formula, value))
    print((r, label, formula, value))

# Sanity-check against Python calculation
def py_calc(row):
    cur_week = ws_values["B2"].value
    total = 0
    for c in range(column_index_from_string("D"), column_index_from_string("BC")+1):
        header_week = ws_values.cell(2, c).value
        v = ws_values.cell(row, c).value
        if isinstance(header_week, (int, float)) and header_week >= cur_week:
            total += (v or 0)
    return total

print("\nComparing recalculated values vs Python totals:")
all_good = True
for r in range(3, ws_values.max_row + 1):
    excel_val = ws_values[f"BE{r}"].value
    calc_val = py_calc(r)
    print(f"Row {r} ({ws_values[f'C{r}'].value}): BE={excel_val}, Python={calc_val}")
    if excel_val != calc_val:
        all_good = False

print("All verified:", all_good)

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
