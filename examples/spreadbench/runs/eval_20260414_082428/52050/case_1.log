wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("\nSHEETS:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        vals.append(ws.cell(r, c).value)
    return vals

workbook_summary = {}
formula_cells = []

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"SHEET: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        print("Header row 2:", row_values(ws, 2, ws.max_column))
    # first 10 rows
    first_end = min(ws.max_row, 10)
    print(f"First rows 1-{first_end}:")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}-{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    # collect formulas
    ws_formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                ws_formulas.append((cell.coordinate, cell.value))
    workbook_summary[ws.title] = {
        "rows": ws.max_row,
        "cols": ws.max_column,
        "headers_row1": headers,
        "formula_count": len(ws_formulas),
    }
    print(f"Formula cells found: {len(ws_formulas)}")
    if ws_formulas:
        print("First 20 formula cells:")
        for coord, formula in ws_formulas[:20]:
            print(coord, formula)
    formula_cells.extend([(ws.title, coord, formula) for coord, formula in ws_formulas])

print("\nTOTAL FORMULA CELLS:", len(formula_cells))
print("Workbook summary:", json.dumps(workbook_summary, default=str, indent=2)[:4000])
