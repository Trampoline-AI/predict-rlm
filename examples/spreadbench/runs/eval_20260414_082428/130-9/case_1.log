from openpyxl.styles import PatternFill
from copy import copy
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
src = wb["cdnr"]
dest = wb["b2b, sez, de"]

# Inspect headers explicitly
src_headers = {src.cell(4, c).value: c for c in range(1, src.max_column + 1) if src.cell(4, c).value not in (None, "")}
dest_headers = {dest.cell(4, c).value: c for c in range(1, dest.max_column + 1) if dest.cell(4, c).value not in (None, "")}
print("Source headers:", src_headers)
print("Destination headers:", dest_headers)

# Find true first empty destination row (completely blank row after data area)
first_empty = None
for r in range(5, dest.max_row + 1):
    vals = [dest.cell(r, c).value for c in range(1, dest.max_column + 1)]
    if all(v in (None, "") for v in vals):
        first_empty = r
        break
if first_empty is None:
    first_empty = dest.max_row + 1
print("First empty destination row:", first_empty)

# Collect source data rows (non-empty rows starting from row 5)
src_rows = []
for r in range(5, src.max_row + 1):
    vals = [src.cell(r, c).value for c in range(1, src.max_column + 1)]
    if any(v not in (None, "") for v in vals):
        src_rows.append(r)
print("Source non-empty data rows:", src_rows)

# Determine template row for style/number format preservation
template_row = first_empty - 1 if first_empty > 5 else 5
print("Template row for styles:", template_row)

# Helper: copy cell style from template row to target row
def copy_row_style(ws, from_row, to_row, max_col):
    for c in range(1, max_col + 1):
        src_cell = ws.cell(from_row, c)
        tgt_cell = ws.cell(to_row, c)
        if src_cell.has_style:
            tgt_cell._style = copy(src_cell._style)
        if src_cell.number_format:
            tgt_cell.number_format = src_cell.number_format
        if src_cell.font:
            tgt_cell.font = copy(src_cell.font)
        if src_cell.fill:
            tgt_cell.fill = copy(src_cell.fill)
        if src_cell.border:
            tgt_cell.border = copy(src_cell.border)
        if src_cell.alignment:
            tgt_cell.alignment = copy(src_cell.alignment)
        if src_cell.protection:
            tgt_cell.protection = copy(src_cell.protection)

# Explicit source columns per observed expected pattern
# Headers in row 4 are letters A..V, but actual semantic mapping is inferred from Expected.
# Most columns copy same letter-to-letter, except:
# - Dest E gets Source I
# - Dest H blank
# - Dest I = "Credit Note"
# - Dest L/M are negative of Source L/M
# Other columns copy by same header/letter.
append_map_same = [c for c in range(1, dest.max_column + 1)]  # A:V

out_rows = []
for idx, sr in enumerate(src_rows, start=0):
    dr = first_empty + idx
    copy_row_style(dest, template_row, dr, dest.max_column)

    # Start with same-letter/header copy for all columns that exist
    for c in range(1, min(dest.max_column, src.max_column) + 1):
        val = src.cell(sr, c).value
        dest.cell(dr, c).value = val

    # Apply required corrections from verified Expected pattern
    dest[f"E{dr}"] = src[f"I{sr}"].value   # gross/amount from src I
    dest[f"H{dr}"] = None                  # blank
    dest[f"I{dr}"] = "Credit Note"         # fixed text

    # Negate L and M, preserving blanks
    for col in ["L", "M"]:
        sval = src[f"{col}{sr}"].value
        if isinstance(sval, (int, float)):
            dest[f"{col}{dr}"] = -abs(sval)
        elif sval in (None, ""):
            dest[f"{col}{dr}"] = sval
        else:
            # Best effort numeric coercion if text-formatted
            try:
                num = float(sval)
                dest[f"{col}{dr}"] = -abs(num)
            except Exception:
                dest[f"{col}{dr}"] = sval

    out_rows.append(dr)

print("Appended destination rows:", out_rows)

# Print target rows before save
print("\nPreview of written rows:")
for dr in out_rows:
    vals = [dest.cell(dr, c).value for c in range(1, 23)]
    print(f"R{dr}: {vals}")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
current_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", current_names)
if current_names != orig_sheet_names and len(current_names) == len(orig_sheet_names):
    for ws_obj, orig_name in zip(wb_after.worksheets, orig_sheet_names):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verification with data_only
