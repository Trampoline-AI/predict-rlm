        print(item)
    
    sample_last = []
    start_last = max(1, max_row - 4)
    for r in range(start_last, max_row + 1):
        sample_last.append((r, row_values(ws, r, max_col)))
    print("Last rows sample:")
    for item in sample_last:
        print(item)
    
    col_i_header = ws["I1"].value if max_col >= 9 else None
    print("Cell I1 (header/value):", col_i_header)
    if max_col >= 9:
        unique_i_sample = []
        for r in range(2, min(max_row, 50) + 1):
            unique_i_sample.append(ws.cell(r, 9).value)
        print("Column I sample values rows 2-50:", unique_i_sample[:20], "... total sampled", len(unique_i_sample))
        
        matches = []
        for r in range(2, max_row + 1):
            val = ws.cell(r, 9).value
            if val == "Hub Notes":
                matches.append(r)
        print("Rows where column I == 'Hub Notes':", matches[:50], "count=", len(matches))
        if matches:
            for r in matches[:10]:
                print("Matching row", r, row_values(ws, r, max_col))
    
    sheet_summaries[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers": headers,
    }

