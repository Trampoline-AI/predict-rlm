import os
from collections import Counter
from openpyxl import load_workbook

# Re-open cleanly for inspection + edit
wb = load_workbook(input_spreadsheet)
ws = wb["Data"]

def norm(v):
    if v is None:
        return None
    return str(v).strip()

def row_vals(r):
    return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]

print("Sheet:", ws.title)
print("Max row/col:", ws.max_row, ws.max_column)
print("Header row 1:", row_vals(1))
print("Target column I header:", ws["I1"].value)

# Distinct values in column I
vals = [norm(ws.cell(r, 9).value) for r in range(2, ws.max_row + 1)]
counter = Counter(vals)
print("Distinct column I values and counts:", counter)

# Exact and case-insensitive matches
exact_matches = [r for r in range(2, ws.max_row + 1) if norm(ws.cell(r, 9).value) == "Hub Notes"]
ci_matches = [r for r in range(2, ws.max_row + 1) if (norm(ws.cell(r, 9).value) or "").lower() == "hub notes".lower()]

print("Exact 'Hub Notes' matches:", exact_matches)
print("Case-insensitive 'Hub Notes' matches:", ci_matches)

for r in ci_matches:
    print("Row to delete:", r, row_vals(r))

# Use case-insensitive trimmed comparison to reflect user's intent and actual data
rows_to_delete = ci_matches[:]
print("Deleting rows count:", len(rows_to_delete))

for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

print("Post-delete max_row:", ws.max_row)
print("First 10 rows after delete:")
for r in range(1, min(ws.max_row, 10) + 1):
    print(r, row_vals(r))

remaining_ci = [r for r in range(2, ws.max_row + 1) if (norm(ws.cell(r, 9).value) or "").lower() == "hub notes".lower()]
print("Remaining case-insensitive matches after deletion:", remaining_ci)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb_check = load_workbook(out_path)
print("Sheet names after recalc/reload:", wb_check.sheetnames)
if wb_check.sheetnames != ["Data"]:
    # restore original name(s) if needed
    for idx, expected in enumerate(["Data"]):
        if idx < len(wb_check.worksheets):
            wb_check.worksheets[idx].title = expected
    wb_check.save(out_path)
    wb_check = load_workbook(out_path)
    print("Sheet names restored to:", wb_check.sheetnames)

# Verify with data_only=False and data_only=True
wb_verify = load_workbook(out_path, data_only=False)
ws_verify = wb_verify["Data"]
print("Verified max_row:", ws_verify.max_row)
print("Verified header row:", [ws_verify.cell(1, c).value for c in range(1, ws_verify.max_column + 1)])
remaining_verify = [r for r in range(2, ws_verify.max_row + 1) if (norm(ws_verify.cell(r, 9).value) or "").lower() == "hub notes".lower()]
print("Remaining matching rows in output:", remaining_verify)

print("Last 5 rows after deletion:")
for r in range(max(1, ws_verify.max_row - 4), ws_verify.max_row + 1):
