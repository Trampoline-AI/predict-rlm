import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

sheet_summaries = {}

for ws in wb.worksheets:
    max_row, max_col = ws.max_row, ws.max_column
    headers = row_values(ws, 1, max_col)
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers:", headers)
    
    sample_first = []
    for r in range(1, min(max_row, 10) + 1):
