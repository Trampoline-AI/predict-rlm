```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["ATTENDENCE"]

start_col = column_index_from_string("F")
end_col = column_index_from_string("AJ")

# Print current target formulas/values before modification
print("Before modification:")
for c in range(start_col, end_col + 1):
    coord = f"{get_column_letter(c)}3"
    below = f"{get_column_letter(c)}4"
    print(coord, "=", ws[coord].value, "|", below, "=", ws[below].value)

# Apply correct weekday formula across F3:AJ3
for c in range(start_col, end_col + 1):
    col_letter = get_column_letter(c)
    ws[f"{col_letter}3"] = f'=TEXT({col_letter}4,"ddd")'

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheet_names)
    # rename sheets positionally
    for i, original_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Final sheet names:", wb_check.sheetnames)

# Verify formulas
ws_formula = wb_check["ATTENDENCE"]
print("\nFormulas now in F3:AJ3:")
for c in range(start_col, end_col + 1):
    coord = f"{get_column_letter(c)}3"
    print(coord, ws_formula[coord].value)

# Verify cached results with data_only=True
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["ATTENDENCE"]
print("\nEvaluated values in F3:AJ3:")
evaluated = {}
for c in range(start_col, end_col + 1):
    coord = f"{get_column_letter(c)}3"
    evaluated[coord] = ws_values[coord].value
    print(coord, "=", ws_values[coord].value)

# quick sanity checks
blanks = [k for k, v in evaluated.items() if v in (None, "")]
print("Blank target cells after recalc:", blanks)
```
