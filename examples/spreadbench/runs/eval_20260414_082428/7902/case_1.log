```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook for editing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Formula Required"]

# Print current target area before writing
print("Before writing, current D:J formulas/values:")
for r in range(3, ws.max_row + 1):
    vals = {f"{get_column_letter(c)}{r}": ws.cell(r, c).value for c in range(4, 11)}
    print(f"Row {r}:", vals)

# Write formulas to D:J for all relevant rows
# Logic:
# If exact (Main Group, Material) match exists in Grouping, use that material-specific row.
# Else fallback to group-level VLOOKUP on Main Group.
for r in range(3, ws.max_row + 1):
    group_val = ws[f"C{r}"].value
    material_val = ws[f"B{r}"].value
    # Only write for rows that actually have a main group or material context
    if group_val in (None, "") and material_val in (None, ""):
        continue
    for c in range(4, 11):  # D:J
        coord = f"{get_column_letter(c)}{r}"
        # COLUMN()-3 gives 1..7 within Grouping!C:I
        # COLUMN()-1 gives 3..9 within Grouping!A:I for fallback VLOOKUP
        formula = (
            f'=IF(AND($B{r}<>"",COUNTIFS(Grouping!$A$2:$A$7,$C{r},Grouping!$B$2:$B$7,$B{r})>0),'
            f'INDEX(Grouping!$C$2:$I$7,'
            f'SUMPRODUCT((Grouping!$A$2:$A$7=$C{r})*(Grouping!$B$2:$B$7=$B{r})*'
            f'(ROW(Grouping!$A$2:$A$7)-ROW(Grouping!$A$2)+1)),'
            f'COLUMN()-3),'
            f'VLOOKUP($C{r},Grouping!$A$2:$I$7,COLUMN()-1,FALSE))'
        )
        ws[coord] = formula

# Save initial output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # Rename sheets back to original by position
    for i, expected_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and evaluated values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
wsf = wb_formula["Formula Required"]
wsv = wb_values["Formula Required"]

print("\nWritten formulas in D:J:")
for r in range(3, wsf.max_row + 1):
    vals = {f"{get_column_letter(c)}{r}": wsf.cell(r, c).value for c in range(4, 11)}
    print(f"Row {r}:", vals)

print("\nEvaluated values in D:J:")
for r in range(3, wsv.max_row + 1):
    vals = {f"{get_column_letter(c)}{r}": wsv.cell(r, c).value for c in range(4, 11)}
    print(f"Row {r}:", vals)

# Expected values from source data for sanity check
grp = wb_values["Grouping"]
group_map = {}
material_group_map = {}
for r in range(2, grp.max_row + 1):
    g = grp.cell(r, 1).value
    m = grp.cell(r, 2).value
    buckets = [grp.cell(r, c).value for c in range(3, 10)]
    if g not in (None, "") and m in (None, ""):
        group_map[g] = buckets
    elif g not in (None, "") and m not in (None, ""):
        material_group_map[(g, m)] = buckets

print("\nVerification against expected values:")
all_ok = True
for r in range(3, wsv.max_row + 1):
    g = wsv[f"C{r}"].value
    m = wsv[f"B{r}"].value
    expected = material_group_map.get((g, m), group_map.get(g))
    actual = [wsv.cell(r, c).value for c in range(4, 11)]
    print(f"Row {r}: material={m!r}, group={g!r}, expected={expected}, actual={actual}")
    if expected != actual:
        all_ok = False

print("All rows match expected:", all_ok)

final_output_path = output_path
