import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect non-empty rows/cols more realistically
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # print first 10 rows and last 5 rows with coordinates
    def row_vals(r):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            vals.append(v)
        return vals
    
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in first_rows + last_rows:
        if r not in seen:
            rows_to_show.append(r)
            seen.add(r)
    for r in rows_to_show:
        print(f"Row {r}:", row_vals(r))
    
    # infer header candidates from first few non-empty rows
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = row_vals(r)
        print(f"Header candidate row {r}:", vals)
    
    # print formulas / special cells in first 20 rows
    formulas = []
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first 30 rows:", formulas[:30], "count:", len(formulas))

for ws in wb.worksheets:
    sheet_summary(ws)
