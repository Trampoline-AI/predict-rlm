from collections import OrderedDict
from openpyxl.utils import get_column_letter

ws = wb["Sheet1"]

# Build schedule vectors and example outputs
times = [ws.cell(12, c).value for c in range(6, 32)]
agents = [ws.cell(r, 5).value for r in range(13, 19)]
sched = {
    agent: [1 if ws.cell(r, c).value else 0 for c in range(6, 32)]
    for r, agent in zip(range(13, 19), agents)
}
out_rows = [ws.cell(r, 5).value for r in range(36, 44)]
example = {
    cat: [ws.cell(r, c).value for c in range(6, 32)]
    for r, cat in zip(range(36, 44), out_rows)
}

print("Agents:", agents)
print("Output rows:", out_rows)

# Show unique schedule states by interval
states = OrderedDict()
for idx, t in enumerate(times):
    active = tuple(a for a in agents if sched[a][idx])
    states.setdefault(active, []).append(idx)

print("\nUnique active-agent states:")
for active, idxs in states.items():
    labels = [str(times[i]) for i in idxs]
    print(active, "count", len(idxs), "first/last", labels[0], labels[-1])

# Infer per-agent contributions using schedule transitions
# Since intervals begin with only Alexis, then agents are added one by one,
# we can derive contributions by differencing states.
contrib = {cat: {} for cat in out_rows}

def vec_at(cat, idx):
    return example[cat][idx]

# Identify representative indices
# 05:00 Alexis only
i_alexis = 0
# 06:00 Alexis + Alycia
i_alexis_alycia = 2
# 07:00 + Taylor
i_plus_taylor = 4
# 08:00 + Edi
i_plus_edi = 6
# 08:30 + Brittany + Amy
i_all = 7
# 15:00 no Alexis/Alycia/Taylor/Edi? let's inspect exact set around end
for idx in [20,21,22,23,24,25]:
    print("Interval", idx, times[idx], "active", [a for a in agents if sched[a][idx]])

# Use exact states:
# idx 0: Alexis
# idx 2: Alexis+Alycia
# idx 4: Alexis+Alycia+Taylor
# idx 6: Alexis+Alycia+Taylor+Edi
# idx 7: Alexis+Alycia+Taylor+Edi+Brittany+Amy
# idx 17? Alexis+Alycia+Taylor+Edi+Brittany+Amy maybe still all
# idx 18: Alycia+Taylor+Edi+Brittany+Amy
# idx 20: Taylor+Edi+Brittany+Amy
# idx 21: Edi+Brittany+Amy
# idx 23: Brittany+Amy
# idx 25: Brittany+Amy

rep = {}
for idx, t in enumerate(times):
    active = tuple(a for a in agents if sched[a][idx])
    rep.setdefault(active, idx)
print("\nRepresentative intervals by state:")
for active, idx in rep.items():
    print(idx, times[idx], active)

# derive contributions
for cat in out_rows:
    C_A = example[cat][rep[('Alexis',)]]
    C_AA = example[cat][rep[('Alexis', 'Alycia')]]
    C_AAT = example[cat][rep[('Alexis', 'Alycia', 'Taylor')]]
    C_AATE = example[cat][rep[('Alexis', 'Alycia', 'Taylor', 'Edi')]]
    C_ALL = example[cat][rep[('Alexis', 'Alycia', 'Taylor', 'Edi', 'Brittany', 'Amy')]]
    C_noA = example[cat][rep[('Alycia', 'Taylor', 'Edi', 'Brittany', 'Amy')]]
    C_TEBA = example[cat][rep[('Taylor', 'Edi', 'Brittany', 'Amy')]]
    C_EBA = example[cat][rep[('Edi', 'Brittany', 'Amy')]]
    C_BA = example[cat][rep[('Brittany', 'Amy')]]

    contrib[cat]['Alexis'] = C_A
    contrib[cat]['Alycia'] = C_AA - C_A
    contrib[cat]['Taylor'] = C_AAT - C_AA
    contrib[cat]['Edi'] = C_AATE - C_AAT
    contrib[cat]['Amy'] = C_EBA - example[cat][rep[('Edi', 'Brittany')]] if ('Edi', 'Brittany') in rep else None

print("\nPartial derived contributions from transitions:")
for cat in out_rows:
    print(cat, contrib[cat])

# Solve Brittany/Amy separately using late states
for cat in out_rows:
    C_BA = example[cat][rep[('Brittany', 'Amy')]]
    C_EBA = example[cat][rep[('Edi', 'Brittany', 'Amy')]]
    C_TEBA = example[cat][rep[('Taylor', 'Edi', 'Brittany', 'Amy')]]
    C_noA = example[cat][rep[('Alycia', 'Taylor', 'Edi', 'Brittany', 'Amy')]]
    C_ALL = example[cat][rep[('Alexis', 'Alycia', 'Taylor', 'Edi', 'Brittany', 'Amy')]]

    alexis = example[cat][rep[('Alexis',)]]
    alycia = example[cat][rep[('Alexis', 'Alycia')]] - alexis
    taylor = example[cat][rep[('Alexis', 'Alycia', 'Taylor')]] - alexis - alycia
    edi = example[cat][rep[('Alexis', 'Alycia', 'Taylor', 'Edi')]] - alexis - alycia - taylor

    # BA = Brittany + Amy
    ba = C_BA
    # EBA = Edi + Brittany + Amy => same + edi
    # use total differences to confirm
    print(f"\n{cat}: Alexis={alexis}, Alycia={alycia}, Taylor={taylor}, Edi={edi}, Brittany+Amy={ba}")
    print("check EBA - BA =", C_EBA - C_BA, "should equal Edi")
    print("check TEBA - EBA =", C_TEBA - C_EBA, "should equal Taylor")
    print("check noA - TEBA =", C_noA - C_TEBA, "should equal Alycia")
    print("check ALL - noA =", C_ALL - C_noA, "should equal Alexis")

# Compare these derived contributions with category membership counts in input table
