```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Before write, C4:D7:")
for r in range(4, 8):
    print(r, ws[f"C{r}"].value, ws[f"D{r}"].value)

# Write corrected formulas into the existing summary output cells C4:D7.
# Match:
# - date in A[row] to BD4:BD81
# - primary header B2 to source row 2
# - secondary header C3/D3 to source row 3
for r in range(4, 8):
    for c in range(3, 5):  # C:D
        col_letter = get_column_letter(c)
        formula = (
            f'=IFERROR('
            f'ROUND('
            f'INDEX($BE$4:$BR$81,'
            f'MATCH($A{r},$BD$4:$BD$81,0),'
            f'SUMPRODUCT(($BE$2:$BR$2=$B$2)*($BE$3:$BR$3={col_letter}$3)*COLUMN($BE$2:$BR$2))'
            f'-COLUMN($BE$2)+1'
            f')'
            f',0),"-")'
        )
        ws.cell(r, c).value = formula
        ws.cell(r, c).number_format = "0"

# Clear any values/formulas below row 7 in columns C:D
for r in range(8, ws.max_row + 1):
    ws[f"C{r}"].value = None
    ws[f"D{r}"].value = None

print("\nAfter write, formulas in C4:D7:")
for r in range(4, 8):
    print(r, ws[f"C{r}"].value, "|", ws[f"D{r}"].value, "| formats:", ws[f"C{r}"].number_format, ws[f"D{r}"].number_format)

print("\nAfter clear, sample C:D rows 8:15:")
for r in range(8, min(15, ws.max_row) + 1):
    print(r, ws[f"C{r}"].value, ws[f"D{r}"].value)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheet_names)
    # rename by position
    if len(wb2.sheetnames) == len(orig_sheet_names):
        for i, name in enumerate(orig_sheet_names):
            wb2.worksheets[i].title = name
        wb2.save(outfile)
    else:
        print("Warning: sheet count changed unexpectedly:", wb2.sheetnames)
else:
    print("Sheet names preserved after recalc.")

# Verify with data_only=True
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_sheet_names[0]]

print("\nVerified target values C4:D7 (data_only):")
for r in range(4, 8):
    print(r, wsv[f"C{r}"].value, wsv[f"D{r}"].value)

print("\nVerified cleared rows C8:D15:")
for r in range(8, min(15, wsv.max_row) + 1):
    print(r, wsv[f"C{r}"].value, wsv[f"D{r}"].value)

output_spreadsheet = outfile
```
