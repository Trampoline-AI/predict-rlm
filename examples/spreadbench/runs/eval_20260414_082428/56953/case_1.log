Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]
original_sheetnames = wb.sheetnames[:]

print("Writing helper formulas to E2:E15 and output formulas to I2:L13")
print("Current F2:", ws["F2"].value)

# Helper formulas in E2:E15: mark rows to include in output
# Include:
# - rows where column A equals selected power in F2
# - header rows where next row's A equals selected power in F2
for r in range(2, ws.max_row + 1):
    if r < ws.max_row:
        formula = f'=IF(OR($A{r}=$F$2,AND($A{r}="Power (kW)",$A{r+1}=$F$2)),ROW(),"")'
    else:
        formula = f'=IF($A{r}=$F$2,ROW(),"")'
    ws[f"E{r}"] = formula

# Fill target output area I2:L13 with formulas
for r in range(2, 14):
    for c in range(9, 13):  # I:L
        col_offset = c - 8  # I->1, J->2, K->3, L->4
        nth = r - 1         # row 2 -> 1st match, row 3 -> 2nd match, etc.
        formula = (
            f'=IFERROR('
            f'INDEX($A$2:$D$15,'
            f'MATCH(SMALL($E$2:$E$15,{nth}),$E$2:$E$15,0),'
            f'{col_offset}'
            f'),"")'
        )
        ws.cell(r, c).value = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", original_sheetnames)
    # rename by position
    for i, desired in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = desired
    wb_after.save(output_path)

# Verify formulas and computed values
print("\nFormula view for I2:L13:")
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[original_sheetnames[0]]
for r in range(2, 14):
    vals = [wsf.cell(r, c).value for c in range(9, 13)]
    print(r, vals)

print("\nData-only view for E2:E15:")
wb_data = load_workbook(output_path, data_only=True)
wsd = wb_data[original_sheetnames[0]]
for r in range(2, 16):
    print(r, wsd[f"E{r}"].value)

print("\nData-only view for I2:L13:")
for r in range(2, 14):
    vals = [wsd.cell(r, c).value for c in range(9, 13)]
    print(r, vals)
```
