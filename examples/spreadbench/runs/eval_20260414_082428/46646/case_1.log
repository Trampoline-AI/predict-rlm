for ref in targets:
    cell = ws[ref]
    print(ref, "value=", cell.value, "numfmt=", cell.number_format, "style_id=", cell.style_id, "fill=", cell.fill.fill_type, cell.fill.fgColor.rgb)

# Print rows 3-15 columns A:O compactly
