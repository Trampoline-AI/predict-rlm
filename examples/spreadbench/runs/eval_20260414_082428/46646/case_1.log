```repl
import os, calendar
from fractions import Fraction
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Reconfirm exact target cells and current values before writing
print("Sheet names before write:", wb.sheetnames)
print("Target row label A11:", ws["A11"].value)
print("Year candidates: B3 =", ws["B3"].value, ", O11 =", ws["O11"].value)
print("Existing B11:M11:", [ws.cell(11, c).value for c in range(2, 14)])

target_year = ws["O11"].value  # row 11's shown year
months = [ws.cell(8, c).value for c in range(2, 14)]
counts = [ws.cell(9, c).value for c in range(2, 14)]

def choose_numfmt(frac: Fraction) -> str:
    # a) zero value has no decimal places
    if frac == 0:
        return "0"
    # b) exact single non-zero decimal place
    frac10 = frac * 10
    if frac10.denominator == 1 and (frac10.numerator % 10) != 0:
        return "0.0"
    # c) all other values have nine decimal places
    return "0.000000000"

written = []
for idx, col in enumerate(range(2, 14), start=1):
    count = counts[idx - 1]
    days = calendar.monthrange(int(target_year), idx)[1]
    frac = Fraction(int(count) * 100, days)
    value = float(frac)
    cell = ws.cell(11, col)
    cell.value = value
    cell.number_format = choose_numfmt(frac)
    written.append((get_column_letter(col), months[idx-1], count, days, value, cell.number_format))

print("Values to write:")
for item in written:
    print(item)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename back by position
    for i, old_name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = old_name
    wb2.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with formulas/data_only cache
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

verified = []
for c in range(2, 14):
    ref = f"{get_column_letter(c)}11"
    verified.append((ref, wsv[ref].value))
print("Verified B11:M11 values:", verified)

# Also inspect number formats from normal load
wb_fmt = load_workbook(output_path)
wsf = wb_fmt[orig_sheet_names[0]]
fmt_info = []
for c in range(2, 14):
    ref = f"{get_column_letter(c)}11"
    fmt_info.append((ref, wsf[ref].value, wsf[ref].number_format))
print("Stored values and formats B11:M11:", fmt_info)

output_spreadsheet = output_path
print("Output path ready:", output_spreadsheet)
```
