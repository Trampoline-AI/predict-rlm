def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find row widths and headers from first few rows
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # Header guess = first non-empty row among first 5
    header_row = None
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and str(v).strip() != "" for v in vals):
            header_row = r
            break
    if header_row:
        headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
        print("Guessed header row:", header_row)
        print("Headers:", headers)
    
    # First 10 rows
    print("\nFirst rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"{r}: {vals}")
    
    # Last 5 rows
    print("\nLast rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"{r}: {vals}")
    
    # Specific referenced cells
    for coord in ["B1", "B2", "D1", "D2", "B3", "D3"]:
        print(f"{coord} =", ws[coord].value)

for ws in wb.worksheets:
