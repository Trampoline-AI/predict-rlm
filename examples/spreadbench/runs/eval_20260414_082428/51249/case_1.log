```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Detailed row inspection A:D")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    d = ws.cell(r, 4)
    fill = d.fill
    fill_info = (fill.fill_type, fill.start_color.rgb, fill.end_color.rgb)
    print(f"Row {r}: {vals} | D{r} formula/value={d.value!r} | fill={fill_info}")

print("\nRows where C says 'Result:'")
result_rows = []
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 3).value == "Result:":
        result_rows.append(r)
        print(
            f"Result row {r}: A={ws.cell(r,1).value!r}, B={ws.cell(r,2).value!r}, "
            f"C={ws.cell(r,3).value!r}, D={ws.cell(r,4).value!r}, "
            f"B_next={ws.cell(r+1,2).value if r+1 <= ws.max_row else None!r}"
        )

# Apply logic inferred from sample:
# For each row where C == "Result:", inspect B on same row and B on next row.
# - same row B = Description A and next row B blank -> Single A
# - same row B = Description B and next row B blank -> Single B
# - same row B = Description A and next row B = Description B -> Multiple
green_fill = PatternFill(
    fill_type="solid",
    start_color="E2EFDA",
    end_color="E2EFDA"
)

def norm(v):
    return "" if v is None else str(v).strip()

for r in result_rows:
    b_curr = norm(ws.cell(r, 2).value)
    b_next = norm(ws.cell(r + 1, 2).value) if r + 1 <= ws.max_row else ""
    target = ws.cell(r, 4)
    existing = target.value
    print(f"Deciding D{r}: B{r}={b_curr!r}, B{r+1}={b_next!r}, existing={existing!r}")
    
    new_val = None
    if b_curr == "Description A" and b_next == "Description B":
        new_val = "Multiple"
    elif b_curr == "Description A" and b_next == "":
        new_val = "Single A"
    elif b_curr == "Description B" and b_next == "":
        new_val = "Single B"
    
    if new_val is not None:
        target.value = new_val
        target.fill = green_fill
        print(f" -> wrote D{r} = {new_val!r}")
    else:
        print(" -> no write")

# Save
import os
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore sheet names if changed
