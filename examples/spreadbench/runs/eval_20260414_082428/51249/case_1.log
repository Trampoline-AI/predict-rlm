print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames:
    for i, old_name in enumerate(wb.sheetnames):
        if i < len(wb_after.sheetnames):
            wb_after.worksheets[i].title = old_name
    wb_after.save(out_path)
    print("Renamed sheets back to:", wb.sheetnames)

# Verify output with data_only
verify_wb = load_workbook(out_path, data_only=True)
verify_ws = verify_wb[wb.sheetnames[0]]
print("\nVerification of target cells:")
for r in result_rows:
    d = verify_ws.cell(r, 4)
    print(f"D{r}={d.value!r}")

# Also verify fills from normal workbook
verify_wb2 = load_workbook(out_path)
verify_ws2 = verify_wb2[wb.sheetnames[0]]
print("\nVerification of fills in target cells:")
for r in result_rows:
    d = verify_ws2.cell(r, 4)
    print(f"D{r} fill:", d.fill.fill_type, d.fill.start_color.rgb, d.fill.end_color.rgb)

output_file = out_path
