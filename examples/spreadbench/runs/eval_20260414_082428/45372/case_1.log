import os, shutil
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load original workbook
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print exact target cells before modification
print("Before modification E2:E15:")
for r in range(2, 16):
    print(r, ws[f"E{r}"].value)

# Write formulas into E2:E14 only (leave total in E15 intact)
for r in range(2, 15):
    formula = f'=IF(A{r}="","",IF(A{r}<TIME(9,45,0),IF(OR(B{r}="",B{r}=0),"",B{r}),IF(OR(C{r}="",C{r}=0),"",C{r})))'
    ws[f"E{r}"] = formula

# Apply requested fill to E2:E15 while preserving all other formatting
fill = PatternFill(fill_type="solid", start_color="FFC000", end_color="FFC000")
for r in range(2, 16):
    cell = ws[f"E{r}"]
    cell.fill = copy(fill)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring", orig_sheet_names)
    for i, name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = name
    wb_after.save(output_path)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verify formulas / values / fills
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerification E2:E15:")
for r in range(2, 16):
    f = ws_formula[f"E{r}"].value
    v = ws_values[f"E{r}"].value
    fill_obj = ws_formula[f"E{r}"].fill
    print(
        r,
        "formula_or_value=", f,
        "cached_value=", v,
        "fill_type=", fill_obj.fill_type,
        "start=", fill_obj.start_color.rgb,
        "end=", fill_obj.end_color.rgb,
    )

output_spreadsheet = output_path
