import os
from collections import defaultdict
from copy import copy
from openpyxl import load_workbook

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
original_sheet_names = wb.sheetnames[:]

print("Sheet:", ws.title)
print("Target headers H1:L1:", [ws.cell(1, c).value for c in range(8, 13)])

# Inspect target area carefully before changes
print("\nCurrent target area H1:L10:")
for r in range(1, min(10, ws.max_row) + 1):
    vals = [ws.cell(r, c).value for c in range(8, 13)]
    print(r, vals)

print("\nCurrent formulas/types in H2:L10:")
for r in range(2, min(10, ws.max_row) + 1):
    row_info = []
    for c in range(8, 13):
        cell = ws.cell(r, c)
        row_info.append((cell.coordinate, cell.value, cell.data_type))
    print(row_info)

# Build source records from A:E
records = []
for r in range(2, ws.max_row + 1):
    date_val = ws.cell(r, 1).value
    brand = ws.cell(r, 2).value
    batch = ws.cell(r, 3).value
    origin = ws.cell(r, 4).value
    qty = ws.cell(r, 5).value
    if all(v in (None, "") for v in [date_val, brand, batch, origin, qty]):
        continue
    records.append({
        "row": r,
        "date": date_val,
        "brand": brand,
        "batch": batch,
        "origin": origin,
        "quantity": qty
    })

print("\nParsed source records:")
for rec in records:
    print(rec)

# Find last date per brand
last_date_per_brand = {}
for rec in records:
    b = rec["brand"]
    d = rec["date"]
    if b in (None, "") or d is None:
        continue
    if b not in last_date_per_brand or d > last_date_per_brand[b]:
        last_date_per_brand[b] = d

print("\nLast date per brand:")
for k, v in last_date_per_brand.items():
    print(k, v)

# Aggregate rows that are on the brand's last date
grouped = defaultdict(lambda: {"quantity": 0, "date": None, "brand": None, "batch": None, "origin": None})
matching_rows = []
nonmatching_rows = []
for rec in records:
    if rec["brand"] in last_date_per_brand and rec["date"] == last_date_per_brand[rec["brand"]]:
        key = (rec["brand"], rec["date"], rec["batch"], rec["origin"])
        grouped[key]["date"] = rec["date"]
        grouped[key]["brand"] = rec["brand"]
        grouped[key]["batch"] = rec["batch"]
        grouped[key]["origin"] = rec["origin"]
        grouped[key]["quantity"] += rec["quantity"] if isinstance(rec["quantity"], (int, float)) else float(rec["quantity"])
        matching_rows.append(rec)
    else:
        nonmatching_rows.append(rec)

print("\nRows matching last date per brand:")
for rec in matching_rows:
    print(rec)

print("\nRows NOT matching last date per brand:")
for rec in nonmatching_rows:
    print(rec)

output_rows = list(grouped.values())
output_rows.sort(key=lambda x: (x["brand"] or "", x["date"]))

print("\nOutput rows to write:")
for row in output_rows:
    print(row)

# Ensure headers in H1:L1 remain/are correct
headers = ["date", "brand", "batch", "origin", "quantity"]
for idx, val in enumerate(headers, start=8):
    ws.cell(1, idx).value = val

# Copy style from existing sample row if present
style_source_row = 2

# Clear existing output area H2:Lmax_row
for r in range(2, ws.max_row + 1):
    for c in range(8, 13):
        ws.cell(r, c).value = None

# Write output starting at H2
for i, row in enumerate(output_rows, start=2):
    vals = [row["date"], row["brand"], row["batch"], row["origin"], row["quantity"]]
    for j, val in enumerate(vals, start=8):
        target = ws.cell(i, j)
        target.value = val
        # preserve style if there was a sample row
        src = ws.cell(style_source_row, j)
        if src.has_style:
            target._style = copy(src._style)
        if src.number_format:
            target.number_format = src.number_format

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc; restore sheet name if changed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # rename by position back to original
    for i, expected in enumerate(original_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(out_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("\nVerified target area H1:L10 after save/recalc:")
for r in range(1, 11):
    vals = [wsv.cell(r, c).value for c in range(8, 13)]
    print(r, vals)

# Store for submission
final_output_path = out_path
