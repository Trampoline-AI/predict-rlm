def sheet_preview(ws, sample_first=10, sample_last=5, max_cols=None):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    mc = ws.max_column if max_cols is None else min(ws.max_column, max_cols)
    headers = [ws.cell(1, c).value for c in range(1, mc+1)]
    print("Headers row 1:", headers)
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, mc+1)]
        print("Row 2:", row2)
    # print first rows
    first_end = min(ws.max_row, sample_first)
    print(f"First {first_end} rows:")
    for r in range(1, first_end+1):
        vals = [ws.cell(r, c).value for c in range(1, mc+1)]
        print(r, vals)
    # print last rows
    if ws.max_row > sample_first:
        start_last = max(1, ws.max_row - sample_last + 1)
        print(f"Last rows {start_last}:{ws.max_row}")
        for r in range(start_last, ws.max_row+1):
            vals = [ws.cell(r, c).value for c in range(1, mc+1)]
            print(r, vals)

for ws in wb.worksheets:
    sheet_preview(ws, sample_first=10, sample_last=5, max_cols=min(ws.max_column, 12))

# Explicitly inspect A:E and H:L because instruction references those
for ws in wb.worksheets:
    print(f"\nDetailed A:E and H:L for {ws.title}")
    for r in range(1, min(ws.max_row, 15)+1):
        vals_AE = [ws.cell(r, c).value for c in range(1, 6)]
