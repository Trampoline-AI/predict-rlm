        nonempty = sum(v is not None and str(v).strip() != "" for v in vals)
        candidate_rows.append((nonempty, r, vals))
    candidate_rows.sort(reverse=True)
    header_row_num = candidate_rows[0][1] if candidate_rows else 1
    headers = row_values(ws, header_row_num)
    print("Likely header row:", header_row_num)
    print("Headers:", headers)
    
    # print first 10 rows
