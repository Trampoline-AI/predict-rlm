Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["denomination"]

# Inspect exact employee rows: contiguous rows with salary from row 2 until first blank salary
employee_rows = []
r = 2
while r <= ws.max_row and ws.cell(r, 5).value not in (None, ""):
    employee_rows.append(r)
    r += 1

print("Employee rows:", employee_rows)

# Denominations from headers H:P
denom_cols = list(range(8, 17))
denoms = [ws.cell(1, c).value for c in denom_cols]
print("Denominations H:P:", denoms)

# Availability from summary table rows 13:21 (C:D)
available = {}
for rr in range(13, 22):
    d = ws.cell(rr, 3).value
    cnt = ws.cell(rr, 4).value
    if isinstance(d, (int, float)):
        available[int(d)] = int(cnt or 0)
print("Available counts from summary:", available)

# Make the missing 500 count explicit as 0 if blank
for rr in range(13, 22):
    if ws.cell(rr, 3).value == 500 and ws.cell(rr, 4).value in (None, ""):
        print("Setting D14-style 500-note count to 0 at", ws.cell(rr,4).coordinate)
        ws.cell(rr, 4).value = 0

# Rebuild availability after explicit 0 write
available = {}
for rr in range(13, 22):
    d = ws.cell(rr, 3).value
    cnt = ws.cell(rr, 4).value
    if isinstance(d, (int, float)):
        available[int(d)] = int(cnt or 0)
print("Availability after normalization:", available)

# Distribute notes greedily by salary
used = {int(d): 0 for d in denoms}
allocations = {}

for rr in employee_rows:
    salary = int(ws.cell(rr, 5).value)
    rem = salary
    alloc = {}
    for d in denoms:
        d = int(d)
        take = rem // d
        # respect remaining availability
        take = min(take, available[d] - used[d])
        alloc[d] = int(take)
        used[d] += int(take)
        rem -= int(take) * d
    allocations[rr] = alloc
    print(f"Row {rr} salary={salary} alloc={alloc} remainder={rem}")
    if rem != 0:
        raise ValueError(f"Could not exactly allocate salary for row {rr}; remainder {rem}")

print("Used totals:", used)
print("Available totals:", available)

if used != available:
    raise ValueError(f"Allocated note totals do not match availability. used={used}, available={available}")

# Write allocations to H:P and formula to Q
for rr in employee_rows:
    for c, d in zip(denom_cols, denoms):
        current = ws.cell(rr, c).value
        print(f"Before write {get_column_letter(c)}{rr}={current}")
        ws.cell(rr, c).value = allocations[rr][int(d)]
    # Total amount formula
    ws.cell(rr, 17).value = f"=SUMPRODUCT($H$1:$P$1,H{rr}:P{rr})"

# Optional total formula for Q10 to mirror salary total if empty
if ws.cell(10, 17).value in (None, ""):
    ws.cell(10, 17).value = "=SUM(Q2:Q8)"

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb_after.sheetnames, "-> restoring", orig_sheet_names)
    # Rename sheets in order
    for i, old_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)

# Verification with data_only=True
wbv = load_workbook(output_path, data_only=False)
wbv_data = load_workbook(output_path, data_only=True)
wsf = wbv["denomination"]
wsd = wbv_data["denomination"]

print("\nVerification: employee allocations H:Q")
for rr in employee_rows:
    formula_row = [wsf.cell(rr, c).value for c in range(8, 18)]
    data_row = [wsd.cell(rr, c).value for c in range(8, 18)]
    print("Row", rr, "formula/raw:", formula_row, "data:", data_row, "salary:", wsd.cell(rr,5).value)

print("\nVerification: row totals vs salaries")
for rr in employee_rows:
    sal = wsd.cell(rr, 5).value
    total = wsd.cell(rr, 17).value
    print(rr, "salary", sal, "Q", total)

print("\nVerification: denomination sums by column H:P")
col_sums = {}
for c, d in zip(denom_cols, denoms):
    total_count = sum((wsd.cell(rr, c).value or 0) for rr in employee_rows)
    col_sums[int(d)] = total_count
    print(get_column_letter(c), d, total_count)

print("Summary table counts C13:D21")
for rr in range(13, 22):
    print(rr, wsd.cell(rr,3).value, wsd.cell(rr,4).value, wsd.cell(rr,5).value)

output_spreadsheet = output_path
