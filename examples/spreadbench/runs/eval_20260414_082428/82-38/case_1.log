from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
sh1 = wb["SH1"]
data = wb["DATA"]
fake = wb["FAKE"]

print("=== Full SH1 non-empty rows with key columns A:H ===")
for r in range(1, sh1.max_row + 1):
    vals = [sh1.cell(r, c).value for c in range(1, 9)]
    if any(v not in (None, "") for v in vals):
        print(r, vals)

print("\n=== Extract SH1 invoice headers and TOTAL rows ===")
invoice_headers = []
total_rows = []
for r in range(1, sh1.max_row + 1):
    d = sh1.cell(r, 4).value
    g = sh1.cell(r, 7).value
    if isinstance(d, str) and d.strip().upper() == "INVOICE NO":
        inv = sh1.cell(r+1, 4).value if r+1 <= sh1.max_row else None
        invoice_headers.append((r, r+1, inv))
    if isinstance(g, str) and g.strip().upper() == "TOTAL":
        total_rows.append(r)
print("invoice_headers:", invoice_headers)
print("total_rows:", total_rows)

# infer each invoice block as from line after row with table headers until TOTAL row
blocks = []
for idx, (hdr_row, inv_row, inv) in enumerate(invoice_headers):
    # next non-empty TOTAL after this invoice
    trow = next((tr for tr in total_rows if tr > inv_row), None)
    blocks.append({"invoice": inv, "invoice_row": inv_row, "total_row": trow})
print("Inferred SH1 blocks:", blocks)

print("\n=== DATA rows A:K ===")
for r in range(1, data.max_row + 1):
    vals = [data.cell(r, c).value for c in range(1, 12)]
    print(r, vals)

print("\n=== Group DATA by TOTAL rows ===")
groups = []
start = 2
r = 2
while r <= data.max_row:
    if str(data.cell(r,1).value).strip().upper() == "TOTAL":
        group_rows = list(range(start, r+1))
        custs = [data.cell(rr,5).value for rr in group_rows]
        invs = [data.cell(rr,4).value for rr in group_rows]
        groups.append({
            "rows": group_rows,
            "customer_set": sorted(set(custs)),
            "invoice_set": sorted(set(str(x) for x in invs if x is not None)),
            "first_row_vals": [data.cell(start,c).value for c in range(1,12)],
            "total_row_vals": [data.cell(r,c).value for c in range(1,12)],
        })
        start = r + 1
    r += 1
for i, g in enumerate(groups, 1):
    print(f"Group {i}: rows {g['rows']}, customers={g['customer_set']}, invoices={g['invoice_set']}")
    print("  first row:", g["first_row_vals"])
    print("  total row:", g["total_row_vals"])

print("\n=== Compare DATA vs FAKE column D/E by row ===")
for r in range(1, max(data.max_row, fake.max_row) + 1):
    dv = data.cell(r,4).value if r <= data.max_row else None
    de = data.cell(r,5).value if r <= data.max_row else None
    fv = fake.cell(r,4).value if r <= fake.max_row else None
    fe = fake.cell(r,5).value if r <= fake.max_row else None
    if r == 1 or dv != fv or de != fe:
        print(f"Row {r}: DATA D/E=({dv!r}, {de!r}) | FAKE D/E=({fv!r}, {fe!r})")
