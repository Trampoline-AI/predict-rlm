import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load fresh workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]

# --- Extract ordered invoice numbers from SH1 ---
sh1 = wb["SH1"]
sh1_invoices = []
for r in range(1, sh1.max_row + 1):
    v = sh1.cell(r, 4).value  # column D
    if isinstance(v, str) and v.strip().upper() == "INVOICE NO":
        inv = sh1.cell(r + 1, 4).value if r + 1 <= sh1.max_row else None
        if inv not in (None, ""):
            sh1_invoices.append(str(inv).strip())

print("Ordered SH1 invoices:", sh1_invoices)

# --- Inspect current DATA target values before modification ---
data = wb["DATA"]
print("\nBefore update: DATA rows with D/E")
for r in range(1, data.max_row + 1):
    d = data.cell(r, 4).value
    e = data.cell(r, 5).value
    a = data.cell(r, 1).value
    if r == 1 or d is not None or e is not None:
        print(f"Row {r}: A={a!r}, D={d!r}, E={e!r}")

# --- Group DATA rows by TOTAL row in column A ---
groups = []
start = 2
for r in range(2, data.max_row + 1):
    aval = data.cell(r, 1).value
    if isinstance(aval, str) and aval.strip().upper() == "TOTAL":
        rows = list(range(start, r + 1))
        customer = data.cell(start, 5).value
        groups.append({"rows": rows, "customer": customer})
        start = r + 1

print("\nDetected DATA groups:")
for i, g in enumerate(groups, 1):
    print(f"Group {i}: rows {g['rows']}, customer={g['customer']!r}")

# --- Apply mapping only to groups whose customer/sheet name is SH1 ---
target_sheet_name = "SH1"
matching_groups = [g for g in groups if str(g["customer"]).strip() == target_sheet_name]
print("\nMatching groups for SH1:", [(g["rows"], g["customer"]) for g in matching_groups])

if len(matching_groups) > len(sh1_invoices):
    raise ValueError(f"More matching DATA groups ({len(matching_groups)}) than SH1 invoices ({len(sh1_invoices)})")

updates = []
for inv, g in zip(sh1_invoices, matching_groups):
    for r in g["rows"]:
        old = data.cell(r, 4).value
        data.cell(r, 4).value = inv
        updates.append((r, old, inv, data.cell(r, 5).value))

print("\nApplied updates to DATA!D:")
for u in updates:
    print(f"Row {u[0]}: old={u[1]!r} -> new={u[2]!r}, customer={u[3]!r}")

# Verify ignored non-matching groups remain unchanged
print("\nNon-matching groups left unchanged:")
for g in groups:
    if str(g["customer"]).strip() != target_sheet_name:
        rows = g["rows"]
        vals = [(r, data.cell(r,4).value, data.cell(r,5).value) for r in rows]
        print(vals)

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position if same count
    if len(wb_check.sheetnames) == len(orig_sheetnames):
        for current, original in zip(wb_check.sheetnames[:], orig_sheetnames):
            wb_check[current].title = original
        wb_check.save(outfile)
    else:
        print("Unexpected sheet count; not renaming automatically.")
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verification reload data_only=True
wb_val = load_workbook(outfile, data_only=True)
print("\nVerification sheet names:", wb_val.sheetnames)
data_val = wb_val["DATA"]

print("\nVerified DATA rows 1-17 columns A, D, E, K:")
for r in range(1, data_val.max_row + 1):
    print(
        r,
        {
            "A": data_val.cell(r,1).value,
            "D": data_val.cell(r,4).value,
            "E": data_val.cell(r,5).value,
            "K": data_val.cell(r,11).value,
        }
    )

# Compact target verification summary
print("\nTarget group verification:")
for i, g in enumerate(groups, 1):
    vals_d = [data_val.cell(r,4).value for r in g["rows"]]
    vals_e = [data_val.cell(r,5).value for r in g["rows"]]
    print(f"Group {i}: rows={g['rows']}, D values={vals_d}, E values={vals_e}")

output_spreadsheet = outfile
