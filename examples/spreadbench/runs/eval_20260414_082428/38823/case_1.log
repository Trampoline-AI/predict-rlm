import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(path), path)

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def row_vals(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols+1)]

for s in wb.sheetnames:
    ws = wb[s]
    print("\n=== SHEET:", s, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find likely header row among first few rows by non-empty count
    best_row = 1
    best_nonempty = -1
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = row_vals(ws, r, ws.max_column)
        nonempty = sum(v is not None and v != "" for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row = r
    print("Likely header row:", best_row)
    
    headers = row_vals(ws, best_row, ws.max_column)
    print("Headers with letters:")
    for i, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)}: {h}")
    
    print("First 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_vals(ws, r, ws.max_column))
    
    print("Last 5 rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
