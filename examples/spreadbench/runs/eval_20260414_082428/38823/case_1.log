import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]
original_sheetnames = wb.sheetnames[:]

print("Inspect target area E:I rows 3:8 before changes")
for r in range(3, 9):
    vals = [ws.cell(r, c).value for c in range(5, 10)]
    print(r, dict(zip(["E","F","G","H","I"], vals)))

for cell_ref in ["E4", "F4", "H4", "I4", "H5", "I5", "H6", "I6", "H7", "I7"]:
    print(cell_ref, "=>", ws[cell_ref].value, "type:", type(ws[cell_ref].value).__name__)

# Determine actual rows to fill: all rows with a non-empty search term in column H
target_rows = []
for r in range(1, ws.max_row + 1):
    h = ws.cell(r, 8).value
    if h not in (None, "") and r >= 4:
        target_rows.append(r)
print("Target rows with search terms in H:", target_rows)

# Build formula using the demonstrated date range in E4:F4 and data in A:C
# Sum units sold in C where date in A is between E4 and F4 inclusive and B contains term in H[row]
for r in target_rows:
    formula = f'=SUMPRODUCT(($A$3:$A$15>=$E$4)*($A$3:$A$15<=$F$4)*ISNUMBER(SEARCH(H{r},$B$3:$B$15))*($C$3:$C$15))'
    print(f"Writing I{r} formula:", formula)
    ws.cell(r, 9).value = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb_post = load_workbook(out_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for old, new in zip(original_sheetnames, wb_post.sheetnames):
        if old != new:
            wb_post[new].title = old
    wb_post.save(out_path)
    print("Restored original sheet names:", original_sheetnames)

# Verify formulas and computed values
wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)
wsf = wb_formula[original_sheetnames[0]]
wsv = wb_values[original_sheetnames[0]]

print("\nVerification of target cells H:I")
for r in target_rows:
    print(
        f"Row {r}:",
        "H=", repr(wsf.cell(r, 8).value),
        "I_formula=", repr(wsf.cell(r, 9).value),
        "I_value=", repr(wsv.cell(r, 9).value),
    )

# Also sanity-check expected values from source data in Python
from datetime import datetime
start_date = wsf["E4"].value
end_date = wsf["F4"].value
print("\nPython sanity-check totals:")
for r in target_rows:
    term = wsf.cell(r, 8).value
    total = 0
    matched_rows = []
    for rr in range(3, 16):
        dt = wsf.cell(rr, 1).value
        fabric = wsf.cell(rr, 2).value
        units = wsf.cell(rr, 3).value
        if isinstance(dt, datetime) and start_date <= dt <= end_date and isinstance(fabric, str) and term in fabric:
            total += units
            matched_rows.append(rr)
    print(f"term={term!r} total={total} matched_rows={matched_rows}")

output_spreadsheet = out_path
