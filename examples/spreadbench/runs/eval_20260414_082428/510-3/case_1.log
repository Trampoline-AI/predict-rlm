Code:
```repl
import os, shutil, re
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Data"]

# Helper to clean weird directionality / invisible chars and extract date parts
def clean_text(v):
    if v is None:
        return ""
    s = str(v)
    # remove common bidi/invisible formatting chars
    for ch in ["\u202d", "\u202c", "\u200e", "\u200f", "\ufeff"]:
        s = s.replace(ch, "")
    return s.strip()

# Inspect formulas / existing values in H before overwriting
print("Pre-write sample H values:", [ws[f"H{r}"].value for r in range(2, min(ws.max_row, 8)+1)])

changed_rows = []
for r in range(2, ws.max_row + 1):
    dcell = ws.cell(r, 4)
    raw = dcell.value
    d_clean = clean_text(raw)
    if d_clean == "":
        # skip empty rows
        continue

    parts = d_clean.split("/")
    if len(parts) != 3:
        print(f"Row {r}: unexpected D value {raw!r} cleaned {d_clean!r}")
        continue

    try:
        year = int(clean_text(parts[0]))
        month = int(clean_text(parts[1]))
        day = int(clean_text(parts[2]))
    except Exception as e:
        print(f"Row {r}: parse error for {raw!r} -> {parts!r}: {e}")
        continue

    # preserve exact existing number formatting for D:G by leaving/copying number_format
    fmt_d = ws.cell(r, 4).number_format
    fmt_e = ws.cell(r, 5).number_format
    fmt_f = ws.cell(r, 6).number_format
    fmt_g = ws.cell(r, 7).number_format

    ws.cell(r, 5).value = year
    ws.cell(r, 6).value = month
    ws.cell(r, 7).value = day

    ws.cell(r, 4).number_format = fmt_d
    ws.cell(r, 5).number_format = fmt_e
    ws.cell(r, 6).number_format = fmt_f
    ws.cell(r, 7).number_format = fmt_g

    total = year * 365 + month * 12 + day
    ws.cell(r, 8).value = total

    changed_rows.append((r, d_clean, year, month, day, total))

# Ensure headers are not bold
for c in range(4, 9):
    ws.cell(1, c).font = ws.cell(1, c).font.copy(bold=False)

wb.save(outfile)
print("Saved to:", outfile)
print("Changed rows:", len(changed_rows))
print("Sample parsed rows:", changed_rows[:8])
print("Last parsed rows:", changed_rows[-5:])

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore any renamed sheets if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position back to originals
    for i, expected in enumerate(orig_sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verification with data_only for computed values
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv["Data"]

# print target cells/ranges
sample_rows = list(range(2, min(11, wsv.max_row + 1))) + list(range(max(2, wsv.max_row - 4), wsv.max_row + 1))
sample_rows = sorted(set(sample_rows))
for r in sample_rows:
    vals = [wsv.cell(r, c).value for c in range(4, 9)]
    print(f"Row {r} D:H ->", vals)

# sanity checks
nonblank_h = 0
blank_problem_rows = []
for r in range(2, wsv.max_row + 1):
    d = wsv.cell(r, 4).value
    if d not in (None, ""):
        h = wsv.cell(r, 8).value
        if h in (None, ""):
            blank_problem_rows.append(r)
        else:
            nonblank_h += 1

print("Nonblank H count:", nonblank_h)
print("Blank problem rows:", blank_problem_rows[:20])

# also verify headers non-bold in output workbook (style check from normal load)
wb_style = load_workbook(outfile)
ws_style = wb_style["Data"]
print("Header bold states D:H:", {ws_style.cell(1,c).coordinate: ws_style.cell(1,c).font.bold for c in range(4,9)})
```
