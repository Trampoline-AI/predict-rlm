import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for modification
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames.copy()
ws = wb["Statement"]

# Find first exact instance of 'Invoice No.' in column A
target_row = None
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None and str(v).strip() == "Invoice No.":
        target_row = r
        break

print("Original sheet names:", original_sheet_names)
print("Found target row:", target_row)
print("Current A1 before change:", repr(ws["A1"].value))
if target_row:
    print(f"Current values around target row {target_row}:")
    for r in range(max(1, target_row-2), min(ws.max_row, target_row+2) + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

if target_row is None:
    raise ValueError("Could not find 'Invoice No.' in column A of Statement sheet.")

# Delete all preceding rows so the target row becomes row 1
if target_row > 1:
    ws.delete_rows(1, target_row - 1)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if recalculate changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # rename by position to restore original names
    for i, expected in enumerate(original_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verification with data_only after recalculation
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Statement"]

print("Statement dimensions after change:", wsv.max_row, "x", wsv.max_column)
print("A1 after change:", repr(wsv["A1"].value))
print("First 5 rows after change:")
for r in range(1, min(5, wsv.max_row) + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

# keep output path for submission
final_output_path = output_path
