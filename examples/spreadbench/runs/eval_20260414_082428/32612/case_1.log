```repl
import os, shutil
from datetime import datetime, date
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Re-open fresh for deeper inspection
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)

# Inspect target column E and holiday table H:J thoroughly
print("Target header E1:", ws["E1"].value)
for r in range(2, min(ws.max_row, 15)+1):
    print(f"E{r} current:", ws[f'E{r}'].value, "A"+str(r), ws[f"A{r}"].value)

# Find actual last data row in main table (A:D/E area) and holiday list (H:J area)
main_last = 1
for r in range(ws.max_row, 1, -1):
    if any(ws.cell(r, c).value is not None for c in range(1, 6)):
        main_last = r
        break

holiday_last = 1
for r in range(ws.max_row, 1, -1):
    if any(ws.cell(r, c).value is not None for c in range(8, 11)):
        holiday_last = r
        break

print("Detected main data rows: 2 to", main_last)
print("Detected holiday list rows: 2 to", holiday_last)

print("Holiday table sample/all rows:")
for r in range(1, holiday_last+1):
    print(r, [ws.cell(r, c).value for c in range(8, 11)])

# Build holiday mapping from columns I (Date) and J (Type)
holiday_map = {}
holiday_name_map = {}
for r in range(2, holiday_last+1):
    holiday_dt = ws.cell(r, 9).value
    holiday_type = ws.cell(r, 10).value
    holiday_name = ws.cell(r, 8).value
    if holiday_dt is None:
        continue
    key = holiday_dt.date() if hasattr(holiday_dt, "date") else holiday_dt
    holiday_map[key] = holiday_type
    holiday_name_map[key] = holiday_name

print("Total holidays mapped:", len(holiday_map))
print("Holiday mapping preview:", list(holiday_map.items())[:10])

# Fill WORKDAY column E
weekday_abbr = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
written_preview = []

for r in range(2, main_last+1):
    dt = ws.cell(r, 1).value
    if dt is None:
        continue
    d = dt.date() if hasattr(dt, "date") else dt
    if d in holiday_map:
        new_val = holiday_map[d]
    else:
        new_val = weekday_abbr[d.weekday()]
    ws.cell(r, 5).value = new_val
    if len(written_preview) < 20 or r > main_last - 5:
        written_preview.append((r, d.isoformat(), new_val, holiday_name_map.get(d)))

print("Written preview:")
for item in written_preview[:20]:
    print(item)
print("Last written rows preview:")
for item in written_preview[-5:]:
    print(item)

# Save
in_name = os.path.basename(input_spreadsheet)
out_path = os.path.join("/sandbox/output/output_spreadsheet", in_name)
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames:
    # rename back by position
    for idx, orig_name in enumerate(wb.sheetnames):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(out_path)
    print("Renamed sheets back to:", wb.sheetnames)

# Verify with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver[wb.sheetnames[0]]
print("Verification target cells E2:E15:")
for r in range(2, min(main_last, 15)+1):
    print(r, vws[f"A{r}"].value, vws[f"E{r}"].value)

print("Verification holiday match rows:")
matched = 0
for r in range(2, main_last+1):
    a = vws.cell(r, 1).value
    e = vws.cell(r, 5).value
    if a is not None:
        ad = a.date() if hasattr(a, "date") else a
        if ad in holiday_map:
            print(f"Row {r}: date={ad}, E={e}, expected={holiday_map[ad]}")
            matched += 1
            if matched >= 10:
                break

print("Verification last 5 rows:")
for r in range(max(2, main_last-4), main_last+1):
    print(r, vws[f"A{r}"].value, vws[f"E{r}"].value)

output_spreadsheet = out_path
