import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)
print("Input:", input_spreadsheet)
print("Exists:", os.path.exists(input_spreadsheet))

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    vals = []
    for c in range(1, max_cols+1):
        vals.append(ws.cell(r, c).value)
    return vals

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    
    # show non-empty headers by column
    nonempty = []
    for c in range(1, ws.max_column+1):
        v1 = ws.cell(1, c).value
        v2 = ws.cell(2, c).value if ws.max_row >= 2 else None
        if v1 is not None or v2 is not None:
            nonempty.append((get_column_letter(c), v1, v2))
    print("Columns with row1/row2 values:", nonempty[:50])
    
    # print first 10 rows
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # detect date-like values in first few rows by column
    date_candidates = []
    for c in range(1, ws.max_column+1):
        sample = [ws.cell(r, c).value for r in range(1, min(ws.max_row, 20)+1)]
        if any(hasattr(v, "year") and hasattr(v, "month") and hasattr(v, "day") for v in sample if v is not None):
            date_candidates.append((c, get_column_letter(c), ws.cell(1,c).value, ws.cell(2,c).value, sample[:8]))
    print("Date-like column candidates:", date_candidates)
