import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load fresh workbook
wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb["Q"]

# Identify candidate rows from actual block
candidates = []
for r in range(3, ws.max_row + 1):
    symbol = ws[f"A{r}"].value
    r_days = ws[f"E{r}"].value
    if r_days not in (None, ""):
        candidates.append({"row": r, "symbol": symbol, "r_days": r_days})

print("Candidates before sort:", candidates)

# Stable sort by R DAYS descending; Python sort is stable, so ties preserve original row order
sorted_candidates = sorted(candidates, key=lambda x: -float(x["r_days"]))
target_rows = [x["row"] for x in candidates]

print("Sorted candidates:", sorted_candidates)
print("Target rows:", target_rows)

# Show current target values before writing
print("Current F targets before write:", {r: ws[f"F{r}"].value for r in target_rows})

# Write sorted symbols into F at the existing target rows
for target_row, item in zip(target_rows, sorted_candidates):
    ws[f"F{target_row}"] = item["symbol"]

# Clear any other F cells? No — preserve structure and existing blanks/formulas elsewhere.
# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc, check sheet names, restore if altered
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheet_names:
    # rename back positionally
    for idx, expected_name in enumerate(original_sheet_names):
        if idx < len(wb2.worksheets):
            wb2.worksheets[idx].title = expected_name
    wb2.save(outfile)
    print("Restored sheet names to:", original_sheet_names)

# Verify output with data_only=True
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv["Q"]

verified = {f"F{r}": wsv[f"F{r}"].value for r in target_rows}
print("Verified target F cells:", verified)

# Also compare against expected example on the right
expected_compare = {f"N{r}": wsv[f"N{r}"].value for r in target_rows}
print("Expected example N cells:", expected_compare)

# Sanity checks
for r in target_rows:
    val = wsv[f"F{r}"].value
    if val in (None, ""):
        print("WARNING blank target:", r)

output_spreadsheet = outfile
