import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input:", path, os.path.exists(path))

wb = load_workbook(path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # find first 10 non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
        if len(nonempty_rows) >= 10:
            break
    print("First non-empty rows:", nonempty_rows)
    for r in nonempty_rows:
        print(f"Row {r}:", row_values(ws, r, min(ws.max_column, 12)))
    
    # last 5 non-empty rows
    last_nonempty = []
    for r in range(ws.max_row, 0, -1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            last_nonempty.append(r)
        if len(last_nonempty) >= 5:
            break
    last_nonempty = list(reversed(last_nonempty))
    print("Last non-empty rows:", last_nonempty)
    for r in last_nonempty:
        print(f"Row {r}:", row_values(ws, r, min(ws.max_column, 12)))
    
    headers_guess = None
    for r in range(1, min(ws.max_row, 8) + 1):
        vals = row_values(ws, r, ws.max_column)
        text_count = sum(isinstance(v, str) and v.strip() != "" for v in vals)
        nonempty_count = sum(v is not None and v != "" for v in vals)
        if nonempty_count >= 3 and text_count >= max(2, nonempty_count//2):
            headers_guess = r
            break
    print("Guessed header row:", headers_guess)
    if headers_guess:
        headers = row_values(ws, headers_guess, ws.max_column)
        print("Headers:", [(get_column_letter(i+1), headers[i]) for i in range(len(headers)) if headers[i] is not None])
        if ws.max_row > headers_guess:
            sample_rows = list(range(headers_guess+1, min(ws.max_row, headers_guess+6)+1))
            for r in sample_rows:
                print(f"Data sample row {r}:", row_values(ws, r, min(ws.max_column, 12)))
