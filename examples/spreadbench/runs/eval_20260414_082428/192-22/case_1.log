```repl
import os, shutil, re
from openpyxl import load_workbook

# Reload cleanly
input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb["Sheet1"]

keywords = [
    "Core Activation",
    "Core Design",
    "Mobile Terminology",
    "Mobile Design",
    "Mobile Integration",
    "Testing Layer",
    "Testing Offshore",
    "Carrier",
    "Barrier",
]

def is_populated(v):
    return v not in (None, "")

def matches_keyword(text):
    if text is None:
        return False
    s = str(text).lower()
    return any(k.lower() in s for k in keywords)

# Inspect all populated D rows and compare to F
rows_info = []
for r in range(2, ws.max_row + 1):
    d = ws.cell(r, 4).value
    f = ws.cell(r, 6).value
    if is_populated(d):
        rows_info.append((r, d, matches_keyword(d), f))

print("Total populated D rows:", len(rows_info))
print("First 20 populated D rows with match status and current F:")
for row in rows_info[:20]:
    print(row)
print("Last 15 populated D rows with match status and current F:")
for row in rows_info[-15:]:
    print(row)

matched_rows = [r for r, d, m, f in rows_info if m]
nonmatched_rows = [r for r, d, m, f in rows_info if not m]
print("Matched row count:", len(matched_rows), "rows:", matched_rows[:50])
print("Non-matched row count:", len(nonmatched_rows), "first rows:", nonmatched_rows[:50])

# Check any nonblank existing F values
existing_f = [(r, ws.cell(r, 6).value) for r in range(2, ws.max_row + 1) if is_populated(ws.cell(r, 6).value)]
print("Existing nonblank F values:", existing_f)

# Apply logic in-place to column F for populated D rows:
# - if D matches keyword => Billing PO
# - else blank
for r in range(2, ws.max_row + 1):
    d = ws.cell(r, 4).value
    if is_populated(d):
        ws.cell(r, 6).value = "Billing PO" if matches_keyword(d) else None

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames and len(wb_after.sheetnames) == len(wb.sheetnames):
    for idx, name in enumerate(wb.sheetnames):
        wb_after.worksheets[idx].title = name
    wb_after.save(output_path)
    print("Restored original sheet names:", wb.sheetnames)

# Verify using data_only and formula view
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb["Sheet1"]
verify_formula_wb = load_workbook(output_path, data_only=False)
verify_formula_ws = verify_formula_wb["Sheet1"]

print("\nVerification of target column F for all populated D rows:")
bad = []
for r in range(2, verify_ws.max_row + 1):
    d = verify_ws.cell(r, 4).value
    f = verify_ws.cell(r, 6).value
    if is_populated(d):
        expected = "Billing PO" if matches_keyword(d) else None
        if f != expected:
            bad.append((r, d, f, expected))
print("Verification mismatches:", bad[:20], "count:", len(bad))

print("\nSample verified rows (first 20 populated D rows):")
shown = 0
for r in range(2, verify_ws.max_row + 1):
    d = verify_ws.cell(r, 4).value
    if is_populated(d):
        print(r, "D=", d, "| F=", verify_ws.cell(r, 6).value)
        shown += 1
        if shown >= 20:
            break

print("\nSample verified rows (last 15 populated D rows):")
tail = []
for r in range(2, verify_ws.max_row + 1):
    d = verify_ws.cell(r, 4).value
    if is_populated(d):
        tail.append((r, d, verify_ws.cell(r, 6).value))
for item in tail[-15:]:
