import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

# Reconfirm target area and build formula
target_cell = "M2"
part_ref = "A2"
last_row = ws.max_row

pn_cols = list(range(column_index_from_string("O"), ws.max_column + 1, 2))
terms = []
for c in pn_cols:
    qty_c = c + 1
    if qty_c <= ws.max_column:
        pn_col_letter = get_column_letter(c)
        qty_col_letter = get_column_letter(qty_c)
        terms.append(f'SUMIF(${pn_col_letter}$2:${pn_col_letter}${last_row},$A2,${qty_col_letter}$2:${qty_col_letter}${last_row})')

formula = "=" + "+".join(terms)

print("Target sheet:", ws.title)
print("Target cell before:", target_cell, "=", ws[target_cell].value)
print("Formula to write:", formula)

# Write formula
ws[target_cell] = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    for i, expected_name in enumerate(original_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas and calculated values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]
print("Verified formula in M2:", ws_formula[target_cell].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]
print("Verified calculated A2:", ws_values["A2"].value)
print("Verified calculated L2:", ws_values["L2"].value)
print("Verified calculated M2:", ws_values["M2"].value)

# Extra sanity check against direct Python computation
part = ws_values["A2"].value
python_total = 0
for c in pn_cols:
    qty_c = c + 1
    if qty_c <= ws_values.max_column:
        for r in range(2, ws_values.max_row + 1):
            if ws_values.cell(r, c).value == part:
                qty = ws_values.cell(r, qty_c).value
                if isinstance(qty, (int, float)):
                    python_total += qty
print("Python-computed total for A2 across O:X:", python_total)

output_spreadsheet = output_path
```
