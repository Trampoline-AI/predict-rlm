import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect exact target cells before modification, including formulas if any
print("Pre-modification target B2:C11:")
for r in range(2, 12):
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    print(r, {"A": ws[f"A{r}"].value, "B": b, "C": c})

# Build source mapping from E2:F6 (ignore blank rows)
source_map = {}
for r in range(2, ws.max_row + 1):
    d = ws[f"E{r}"].value
    v = ws[f"F{r}"].value
    if d is not None:
        source_map[d] = v

print("Source map entries:")
for k, v in source_map.items():
    print(k, "->", v)

# Fill B2:C11 according to timeline dates in A2:A11
for r in range(2, 12):
    timeline_date = ws[f"A{r}"].value
    if timeline_date in source_map:
        # preserve if already correct; otherwise write expected values
        if ws[f"B{r}"].value != timeline_date:
            ws[f"B{r}"] = timeline_date
        if ws[f"C{r}"].value != source_map[timeline_date]:
            ws[f"C{r}"] = source_map[timeline_date]
    else:
        # leave unmatched rows blank; if already blank, keep blank
        if ws[f"B{r}"].value not in (None, ""):
            ws[f"B{r}"] = None
        if ws[f"C{r}"].value not in (None, ""):
            ws[f"C{r}"] = None

wb.save(outfile)
print("Saved to:", outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# restore sheet names if recalculation changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for i, old_name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = old_name
    wb2.save(outfile)
    print("Restored original sheet names:", orig_sheet_names)

# verify after reload with data_only=True
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[orig_sheet_names[0]]

print("Post-save verification B2:C11:")
for r in range(2, 12):
    print(r, {
        "A": vws[f"A{r}"].value,
        "B": vws[f"B{r}"].value,
        "C": vws[f"C{r}"].value
    })

# keep output path in variable for submission
final_output_spreadsheet = outfile
print("Ready to submit:", final_output_spreadsheet)
