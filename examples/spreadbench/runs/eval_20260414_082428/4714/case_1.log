Code:
```repl
import os
from datetime import datetime
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Determine true non-empty data rows
data_rows = []
for r in range(2, ws.max_row + 1):
    if any(ws.cell(r, c).value is not None for c in range(1, 7)):
        data_rows.append(r)

print("Data rows:", data_rows[0], "to", data_rows[-1], "count", len(data_rows))

def month_index(dt):
    return dt.year * 12 + dt.month

# Collect rows by employee
rows_by_emp = {}
for r in data_rows:
    emp = ws.cell(r, 1).value
    dt = ws.cell(r, 3).value
    hrs = ws.cell(r, 4).value
    rows_by_emp.setdefault(emp, []).append((r, dt, hrs))

# Sort each employee's records by date just in case
for emp in rows_by_emp:
    rows_by_emp[emp].sort(key=lambda x: x[1])

# Compute and write outputs
computed = {}
for emp, records in rows_by_emp.items():
    for r, current_dt, hrs in records:
        cur_idx = month_index(current_dt)
        window = [(rr, dt, h) for rr, dt, h in records if (cur_idx - 3) <= month_index(dt) <= cur_idx]
        # Count rows in 4-month date window for same employee
        if len(window) < 4:
            avg_out = "n/a"
            flag_out = "n/a - less that 4 weeks"
        else:
            avg = sum(h for _, _, h in window) / len(window)
            avg = round(avg, 1)
            if float(avg).is_integer():
                avg_out = int(avg)
            else:
                avg_out = avg
            flag_out = "More than 48" if avg > 48 else "Less that 48"
        computed[r] = (avg_out, flag_out)

# Print before/after for target cells
print("\nBefore -> After preview:")
for r in data_rows:
    old_e = ws.cell(r, 5).value
    old_f = ws.cell(r, 6).value
    new_e, new_f = computed[r]
    print(f"Row {r}: E {old_e!r} -> {new_e!r} | F {old_f!r} -> {new_f!r}")

# Write values into existing columns E and F
for r in data_rows:
    new_e, new_f = computed[r]
    ws.cell(r, 5).value = new_e
    ws.cell(r, 5).number_format = "0.#"
    ws.cell(r, 6).value = new_f

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames and len(wb2.sheetnames) == len(original_sheetnames):
    for i, expected in enumerate(original_sheetnames):
        wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify with data_only=True
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[original_sheetnames[0]]

print("\nVerification of target cells E:F")
verification_ok = True
for r in data_rows:
    a = vws.cell(r, 1).value
    b = vws.cell(r, 2).value
    d = vws.cell(r, 4).value
    e = vws.cell(r, 5).value
    f = vws.cell(r, 6).value
    print(f"Row {r}: Emp={a}, Month={b}, Hours={d}, E={e!r}, F={f!r}")
    if e in (None, "") or f in (None, ""):
        verification_ok = False

print("Verification OK:", verification_ok)

output_spreadsheet = outfile
```
