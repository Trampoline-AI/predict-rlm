    # detect non-empty cells in a wider area
    print("Non-empty cells in A1:T40:")
    for r in range(1, min(ws.max_row, 40) + 1):
        row_pairs = []
        for c in range(1, min(ws.max_column, 20) + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_pairs.append(f"{get_column_letter(c)}{r}={v!r}")
        if row_pairs:
