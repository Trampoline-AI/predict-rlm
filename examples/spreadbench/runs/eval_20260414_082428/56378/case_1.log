import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Alignment

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Using sheet:", ws.title)
print("Original sheetnames:", original_sheetnames)

# Confirm exact target/source regions again
source_start_row = 5
source_end_row = 21   # data block ends before row 22 summary area
target_start_row = 5
target_end_row = 21

print("Source headers:", [ws.cell(4, c).value for c in range(3, 10)])   # C:I
print("Target headers:", [ws.cell(4, c).value for c in range(12, 19)])  # L:R

# Count expected qualifying source rows
qualifying = []
for r in range(source_start_row, source_end_row + 1):
    qty = ws[f"I{r}"].value
    if qty not in (None, "") and not (isinstance(qty, str) and qty.strip() == ""):
        qualifying.append(r)
print("Qualifying source rows:", qualifying)

# Preserve existing styles where sensible
for r in range(target_start_row, target_end_row + 1):
    # Formula that returns nth matching source row offset within C:I / I:I block
    nth_expr = f'_xlfn.AGGREGATE(15,6,(ROW($I${source_start_row}:$I${source_end_row})-ROW($I${source_start_row})+1)/($I${source_start_row}:$I${source_end_row}<>""),ROWS($L${target_start_row}:L{r}))'
    ws[f"L{r}"] = f'=IFERROR(INDEX($C${source_start_row}:$C${source_end_row},{nth_expr}),"")'
    ws[f"M{r}"] = f'=IFERROR(INDEX($D${source_start_row}:$D${source_end_row},{nth_expr}),"")'
    ws[f"N{r}"] = f'=IFERROR(INDEX($E${source_start_row}:$E${source_end_row},{nth_expr}),"")'
    ws[f"O{r}"] = f'=IFERROR(INDEX($F${source_start_row}:$F${source_end_row},{nth_expr}),"")'
    ws[f"P{r}"] = f'=IFERROR(INDEX($G${source_start_row}:$G${source_end_row},{nth_expr}),"")'
    ws[f"Q{r}"] = f'=IFERROR(INDEX($H${source_start_row}:$H${source_end_row},{nth_expr}),"")'
    ws[f"R{r}"] = f'=IFERROR(INDEX($I${source_start_row}:$I${source_end_row},{nth_expr}),"")'

# Apply requested alignments:
# Product names in column M left aligned.
# Values in columns O:R right aligned.
for r in range(target_start_row, target_end_row + 1):
    ws[f"M{r}"].alignment = copy(ws[f"M{r}"].alignment)
    ws[f"M{r}"].alignment = Alignment(
        horizontal="left",
        vertical=ws[f"M{r}"].alignment.vertical,
        text_rotation=ws[f"M{r}"].alignment.textRotation,
        wrap_text=ws[f"M{r}"].alignment.wrap_text,
        shrink_to_fit=ws[f"M{r}"].alignment.shrink_to_fit,
        indent=ws[f"M{r}"].alignment.indent
    )
    for col in ["O", "P", "Q", "R"]:
        cell = ws[f"{col}{r}"]
        cell.alignment = copy(cell.alignment)
        cell.alignment = Alignment(
            horizontal="right",
            vertical=cell.alignment.vertical,
            text_rotation=cell.alignment.textRotation,
            wrap_text=cell.alignment.wrap_text,
            shrink_to_fit=cell.alignment.shrink_to_fit,
            indent=cell.alignment.indent
        )

# Keep header alignments unchanged, but print formulas for inspection
print("Sample formulas written:")
for addr in ["L5","M5","N5","O5","P5","Q5","R5","L6","R6","L21","R21"]:
    print(addr, "=>", ws[addr].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open and restore original sheet names if LibreOffice changed them
wb_post = load_workbook(outfile)
print("Sheetnames after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for ws_post, old_name in zip(wb_post.worksheets, original_sheetnames):
        ws_post.title = old_name
    wb_post.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify cached values after recalculation
wb_val = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", wb_val.sheetnames)
wsv = wb_val[original_sheetnames[0]]

# Print target range values row-by-row
verified_rows = []
for r in range(target_start_row, target_end_row + 1):
    row_vals = [wsv[f"{col}{r}"].value for col in ["L","M","N","O","P","Q","R"]]
    verified_rows.append((r, row_vals))
    print(f"Row {r}:", row_vals)

# Focused verification of expected nonblank rows
nonblank_target_rows = []
for r, vals in verified_rows:
    if any(v not in (None, "") for v in vals):
        nonblank_target_rows.append((r, vals))

print("Nonblank target rows count:", len(nonblank_target_rows))
print("Nonblank target rows:", nonblank_target_rows)

# Check alignment in formula workbook (not data_only)
wb_chk = load_workbook(outfile)
wsc = wb_chk[original_sheetnames[0]]
for addr in ["M5","M6","M7","O5","P5","Q5","R5","O6","R6"]:
    print("Alignment", addr, "=>", wsc[addr].alignment.horizontal)

# Save output path for submission
final_output_spreadsheet = outfile
print("Final output file ready:", final_output_spreadsheet)
