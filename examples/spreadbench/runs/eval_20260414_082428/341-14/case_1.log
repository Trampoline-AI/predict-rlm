```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

path = input_spreadsheet
wb = load_workbook(path)
src = wb["problem"]
res = wb["result"]

print("Problem rows expanded preview:")
expanded = []
for r in range(1, src.max_row + 1):
    key = src.cell(r, 1).value
    raw = src.cell(r, 2).value
    print(f"source row {r}: key={key!r}, raw={raw!r}")
    if raw is None or str(raw).strip() == "":
        expanded.append((key, None))
    else:
        parts = [p.strip() for p in str(raw).split("\n")]
        if len(parts) == 0:
            expanded.append((key, None))
        else:
            for p in parts:
                expanded.append((key, p if p != "" else None))

print("\nExpanded total rows:", len(expanded))
print("Expanded rows:")
for i, row in enumerate(expanded, 1):
    print(i, row)

print("\nExisting result sheet cells and formulas/styles check:")
for r in range(1, max(res.max_row, 20) + 1):
    vals = []
    for c in range(1, max(res.max_column, 2) + 1):
        cell = res.cell(r, c)
        vals.append((cell.coordinate, cell.value, cell.data_type))
    if any(v[1] is not None for v in vals):
        print(vals)

print("result max_row/max_col:", res.max_row, res.max_column)

# Write the full transformed output in-place to result sheet.
# First clear existing used area in columns A:B for enough rows.
clear_rows = max(res.max_row, len(expanded))
for r in range(1, clear_rows + 1):
    for c in range(1, 3):
        res.cell(r, c).value = None

for i, (k, v) in enumerate(expanded, 1):
    res.cell(i, 1).value = k
    res.cell(i, 2).value = v

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate and restore sheet names if needed
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_names:
    # rename by position to original names
    for ws_obj, orig in zip(wb_after.worksheets, orig_names):
        ws_obj.title = orig
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify output
wb_verify = load_workbook(out_path, data_only=True)
res_v = wb_verify["result"]
print("\nVerified result sheet dimensions:", res_v.max_row, res_v.max_column)
print("All result rows:")
for r in range(1, res_v.max_row + 1):
    print(r, [res_v.cell(r,1).value, res_v.cell(r,2).value])

# keep path for submission
final_output_path = out_path
```
