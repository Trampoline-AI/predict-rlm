import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]

ws = wb["Sheet1"]

# Print existing target cells before modification
print("Before modification:")
for r in range(2, ws.max_row + 1):
    print(f"C{r} current:", ws.cell(r, 3).value)

# Write corrected 2D INDEX/MATCH formula into column C for all populated data rows
for r in range(2, ws.max_row + 1):
    job = ws.cell(r, 1).value
    month = ws.cell(r, 2).value
    if job is None and month is None:
        continue
    formula = (
        f'=INDEX(Data!$C$3:$AY$4,'
        f'MATCH(A{r},Data!$B$3:$B$4,0),'
        f'MATCH(B{r},Data!$C$2:$AY$2,0))'
    )
    ws.cell(r, 3).value = formula
    print(f"Wrote C{r}:", formula)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename by position to preserve original names
    for i, desired in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = desired
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)

print("\nVerification:")
print("Final sheet names:", wb_formula.sheetnames)

wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

for r in range(1, wsf.max_row + 1):
    print(
        f"Row {r}:",
        "A=", repr(wsf.cell(r,1).value),
        "B=", repr(wsf.cell(r,2).value),
        "C formula=", repr(wsf.cell(r,3).value),
        "C value=", repr(wsv.cell(r,3).value),
    )

output_spreadsheet = outfile
```
