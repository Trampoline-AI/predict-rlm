```repl
import os
from collections import Counter
from openpyxl import load_workbook

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames

ws_cons = wb["Consolidated Tracker"]
ws_existing = wb["Existing Task"]
ws_add = wb["Additions"]
ws_ret = wb["Retired"]

TARGET_COLS = 5
START_ROW = 3
HEADER_ROW = 2

def get_data_rows(ws, start_row=3, ncols=5):
    rows = []
    for r in range(start_row, ws.max_row + 1):
        vals = tuple(ws.cell(r, c).value for c in range(1, ncols + 1))
        # include only rows with any non-empty value
        if any(v not in (None, "") for v in vals):
            rows.append(vals)
    return rows

existing_rows = get_data_rows(ws_existing, 3, TARGET_COLS)
add_rows = get_data_rows(ws_add, 3, TARGET_COLS)
retired_rows = get_data_rows(ws_ret, 3, TARGET_COLS)

print("Existing rows:", existing_rows)
print("Additions rows:", add_rows)
print("Retired rows:", retired_rows)

# Row-level subtraction with multiplicity support
combined = existing_rows + add_rows
combined_counter = Counter(combined)
retired_counter = Counter(retired_rows)
final_counter = combined_counter - retired_counter

final_rows = []
# preserve original ordering: existing first, then additions
for row in combined:
    if final_counter[row] > 0:
        final_rows.append(row)
        final_counter[row] -= 1

print("Final consolidated rows count:", len(final_rows))
for i, row in enumerate(final_rows, start=1):
    print(i, row)

# Inspect target area before writing
print("Headers in Consolidated Tracker row 2:", [ws_cons.cell(HEADER_ROW, c).value for c in range(1, TARGET_COLS + 1)])
print("Current target cells A3:E11 before writing:")
for r in range(3, min(ws_cons.max_row, 11) + 1):
    print(r, [ws_cons.cell(r, c).value for c in range(1, TARGET_COLS + 1)])

# Clear old contents in output area under the headers for these 5 columns
clear_to_row = max(ws_cons.max_row, START_ROW + len(final_rows) + 10)
for r in range(START_ROW, clear_to_row + 1):
    for c in range(1, TARGET_COLS + 1):
        ws_cons.cell(r, c).value = None

# Write final rows to A3:E...
for i, row in enumerate(final_rows, start=START_ROW):
    for c, val in enumerate(row, start=1):
        ws_cons.cell(i, c).value = val

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename by position to original names
    for idx, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(out_path)
    print("Renamed sheets back to original names:", wb_after.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Consolidated Tracker"]

print("Verified target output A3:E{}".format(START_ROW + len(final_rows) - 1))
verified_rows = []
for r in range(START_ROW, START_ROW + len(final_rows)):
    vals = [wsv.cell(r, c).value for c in range(1, TARGET_COLS + 1)]
    verified_rows.append(vals)
    print(r, vals)

# Additional sanity checks
print("Any blank target rows?", any(all(v in (None, "") for v in row) for row in verified_rows))
print("Number of output rows written:", len(verified_rows))
print("Expected number of output rows:", len(final_rows))
```
