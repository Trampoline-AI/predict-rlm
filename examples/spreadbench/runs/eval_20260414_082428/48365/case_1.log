Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and verify exact target cells again
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
dash = wb["Dashboard"]
data = wb["Data"]

print("Original sheet names:", orig_sheetnames)
print("Dashboard target area before write:")
for coord in ["B4", "C4", "C2", "C3", "C11", "C12", "C13", "Q1", "Q2", "Q3", "Q4", "Q5"]:
    print(coord, "=>", dash[coord].value)

print("Data headers:", [data.cell(1, c).value for c in range(1, data.max_column + 1)])
print("Data rows sample first 5:")
for r in range(2, min(data.max_row, 6) + 1):
    print(r, [data.cell(r, c).value for c in range(1, data.max_column + 1)])
print("Data rows sample last 5:")
for r in range(max(2, data.max_row - 4), data.max_row + 1):
    print(r, [data.cell(r, c).value for c in range(1, data.max_column + 1)])

# Build bounded ranges
last_row = data.max_row
last_col = data.max_column

# Target is Dashboard!C4 (next to "Outcome")
target = dash["C4"]
print("Existing target value/formula at C4:", target.value)

# Dynamic measure-aware formula using SUMPRODUCT + MATCH
# - If any selected region is "All" (Q1), sum all amounts for the selected product
# - Else sum rows where Data region matches any chosen region in C11:C13
formula = (
    f'=IF(COUNTIF($C$11:$C$13,$Q$1)>0,'
    f'SUMPRODUCT((Data!$A$2:$A${last_row}=$C$2)*INDEX(Data!$A$2:${chr(64+last_col)}${last_row},0,MATCH($C$3,Data!$A$1:${chr(64+last_col)}$1,0))),'
    f'SUMPRODUCT((Data!$A$2:$A${last_row}=$C$2)*ISNUMBER(MATCH(Data!$B$2:$B${last_row},$C$11:$C$13,0))*INDEX(Data!$A$2:${chr(64+last_col)}${last_row},0,MATCH($C$3,Data!$A$1:${chr(64+last_col)}$1,0))))'
)
target.value = formula

print("Written formula to Dashboard!C4:")
print(dash["C4"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position back to originals
    for ws_obj, original_name in zip(wb2.worksheets, orig_sheetnames):
        ws_obj.title = original_name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formula text and cached value
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)

dash_formula = wb_formula["Dashboard"]
dash_values = wb_values["Dashboard"]

print("\nVerification:")
print("Dashboard!C4 formula:", dash_formula["C4"].value)
print("Dashboard!C4 cached value:", dash_values["C4"].value)
print("Selectors:",
      {"product": dash_values["C2"].value, "measure": dash_values["C3"].value,
       "r1": dash_values["C11"].value, "r2": dash_values["C12"].value, "r3": dash_values["C13"].value,
       "all_token": dash_values["Q1"].value})

# Sanity-check current expected value in Python for present selections
product = dash_values["C2"].value
measure = dash_values["C3"].value
regions = [dash_values["C11"].value, dash_values["C12"].value, dash_values["C13"].value]
all_token = dash_values["Q1"].value

headers = [data.cell(1, c).value for c in range(1, data.max_column + 1)]
measure_col = headers.index(measure) + 1

py_total = 0
for r in range(2, data.max_row + 1):
    prod = data.cell(r, 1).value
    region = data.cell(r, 2).value
    amt = data.cell(r, measure_col).value
    if prod == product:
        if all_token in regions:
            py_total += amt or 0
        else:
            if region in regions:
                py_total += amt or 0

print("Python expected total for current selections:", py_total)

output_spreadsheet = outfile
```
