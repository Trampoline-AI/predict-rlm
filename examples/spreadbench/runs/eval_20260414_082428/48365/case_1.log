hits = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                if v.startswith("=") or any(k in v for k in keywords):
                    if v.startswith("=") or any(k.lower() in v.lower() for k in keywords):
                        hits.append((ws.title, cell.coordinate, v))
print("\nPotential formula/keyword hits (up to 100):")
for item in hits[:100]:
    print(item)
print("Total hits:", len(hits))
