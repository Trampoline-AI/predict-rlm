import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames
print("Workbook:", input_path)
print("Sheets:", orig_sheetnames)

def sheet_info(ws, sample_first=8, sample_last=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # detect header row candidates 1 and 2
    for hr in [1, 2]:
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {hr} values:", vals[:20])
    # headers assumed row1 for now
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row1:", headers[:30])
    
    first_rows = list(range(1, min(ws.max_row, sample_first) + 1))
    last_rows = list(range(max(1, ws.max_row - sample_last + 1), ws.max_row + 1))
    shown = []
    for r in first_rows + [x for x in last_rows if x not in first_rows]:
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        shown.append((r, row_vals))
    for r, vals in shown:
        print(f"Row {r}:", vals[:20])

for ws in wb.worksheets:
    sheet_info(ws)

# inspect Imported Data rows with Column A starting with **
if "Imported Data" in wb.sheetnames:
    ws = wb["Imported Data"]
    matches = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if isinstance(v, str) and v.startswith("**"):
            # last non-empty cell in row
            last_nonempty = 0
            row_vals = []
            for c in range(1, ws.max_column + 1):
                val = ws.cell(r, c).value
                row_vals.append(val)
                if val not in (None, ""):
                    last_nonempty = c
            matches.append((r, last_nonempty, row_vals[:last_nonempty]))
    print("\nImported Data matches in col A starting with '**':", len(matches))
    for item in matches[:20]:
        r, last_nonempty, vals = item
        print(f"Row {r}, last_nonempty={get_column_letter(last_nonempty) if last_nonempty else None}, values={vals}")
else:
    print("No 'Imported Data' sheet found")

# inspect Summary Limits more closely
if "Summary Limits" in wb.sheetnames:
    ws = wb["Summary Limits"]
    print("\nDetailed view of 'Summary Limits':")
    for r in range(1, min(ws.max_row, 20) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals[:20]}")
    # print formulas if any in used area first 20 rows, 20 cols
    formulas = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, min(ws.max_column, 20) + 1):
            val = ws.cell(r, c).value
            if isinstance(val, str) and val.startswith("="):
                formulas.append((r, c, val))
    print("Formulas in first 20x20 area:", formulas[:30], "count=", len(formulas))
