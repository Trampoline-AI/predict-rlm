I’ll store the validation source in a hidden helper column on the same `Overview` sheet to avoid creating sheets. `B2/C2` will continue to work because `A2` remains a date value, just displayed as a month.
Code:
```repl
import os
from collections import OrderedDict
from openpyxl import load_workbook
from openpyxl.worksheet.datavalidation import DataValidation
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ov = wb["Overview"]
pd = wb["Pay Dates"]

# Build one representative real date per month from Pay Dates (use last pay date each month)
month_last_date = OrderedDict()
for r in range(2, pd.max_row + 1):
    d = pd.cell(r, 1).value
    if d is None:
        continue
    key = (d.year, d.month)
    month_last_date[key] = d  # last one encountered for the month

print("Month representative dates:")
for k, d in month_last_date.items():
    print(k, d)

# Place helper month-list dates in hidden column E on Overview
helper_col = 5  # E
ov.cell(1, helper_col).value = "Month List"
ov.column_dimensions[get_column_letter(helper_col)].hidden = True

start_row = 2
for i, d in enumerate(month_last_date.values(), start=start_row):
    cell = ov.cell(i, helper_col)
    cell.value = d
    cell.number_format = "mmmm"

end_row = start_row + len(month_last_date) - 1
helper_range = f"$E${start_row}:$E${end_row}"

# Remove any validation affecting A2, then add a list validation to A2
existing_dvs = list(ov.data_validations.dataValidation)
for dv in existing_dvs:
    if "A2" in str(dv.sqref):
        ov.data_validations.dataValidation.remove(dv)

dv = DataValidation(type="list", formula1=f"=Overview!{helper_range}", allow_blank=False)
dv.prompt = "Select month"
dv.error = "Please select a month from the list."
ov.add_data_validation(dv)
dv.add(ov["A2"])

# Keep A2 as date, but display month only
ov["A2"].number_format = "mmmm"

# Write monthly total formula in B5
last_row = pd.max_row
formula_b5 = (
    f"=SUMPRODUCT((MONTH('Pay Dates'!$A$2:$A${last_row})=MONTH($A$2))"
    f"*(YEAR('Pay Dates'!$A$2:$A${last_row})=YEAR($A$2))"
    f"*('Pay Dates'!$B$2:$B${last_row}+'Pay Dates'!$C$2:$C${last_row}))"
)
ov["B5"] = formula_b5
ov["B5"].number_format = '"$"#,##0.00'

print("Written B5 formula:", ov["B5"].value)
print("A2 number_format:", ov["A2"].number_format)
print("Validation formula1:", dv.formula1)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and repair sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    for i, expected in enumerate(orig_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only=True
wbv = load_workbook(outfile, data_only=False)
wbv_data = load_workbook(outfile, data_only=True)
ovf = wbv["Overview"]
ovd = wbv_data["Overview"]

print("\nVerification:")
for ref in ["A2", "B2", "C2", "B4", "B5", "E2", f"E{end_row}"]:
    print(
        f"{ref}: formula_wb={ovf[ref].value!r}, "
        f"data_only={ovd[ref].value!r}, "
        f"numfmt={ovf[ref].number_format!r}"
    )

# Print helper list and expected monthly total for selected month
print("\nHelper month list values:")
for r in range(start_row, end_row + 1):
    print(r, ovd.cell(r, helper_col).value)

selected = ovd["A2"].value
print("Selected A2 data_only:", selected)

# Compute expected total from source for selected month to sanity-check
expected = 0
if selected is not None:
    for r in range(2, pd.max_row + 1):
        d = pd.cell(r, 1).value
        if d and d.year == selected.year and d.month == selected.month:
            expected += (pd.cell(r, 2).value or 0) + (pd.cell(r, 3).value or 0)
print("Expected total for selected month:", expected)
print("B5 cached value:", ovd["B5"].value)
```
