from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from collections import defaultdict
import os
from datetime import datetime

wb = load_workbook(input_spreadsheet)
print("Sheet names exact:", wb.sheetnames)

ov = wb["Overview"]
pd = wb["Pay Dates"]

# Inspect key cells/formulas/number formats
for ref in ["A1","A2","B2","C2","A4","B4","A5","B5","C5"]:
    c = ov[ref]
    print(f"Overview!{ref}: value={c.value!r}, number_format={c.number_format!r}, data_type={c.data_type!r}")

# Inspect data validation rules and whether A2 is covered
print("\nData Validations on Overview:")
dvs = list(ov.data_validations.dataValidation)
print("Count:", len(dvs))
for i, dv in enumerate(dvs, 1):
    print(f"DV {i}: type={dv.type}, formula1={dv.formula1!r}, formula2={dv.formula2!r}, sqref={dv.sqref}")
    if "A2" in str(dv.sqref):
        print("  -> A2 is included in this validation rule")

# Print column widths / nearby rows for context
print("\nNearby rows on Overview:")
for r in range(1, 7):
    vals = [ov.cell(r, c).value for c in range(1, 4)]
    print(r, vals)

# Compute expected totals by month from Pay Dates
monthly = defaultdict(lambda: {"p1": 0, "p2": 0, "total": 0, "dates": []})
for r in range(2, pd.max_row + 1):
    d = pd.cell(r, 1).value
    p1 = pd.cell(r, 2).value or 0
    p2 = pd.cell(r, 3).value or 0
    if d is None:
        continue
    key = (d.year, d.month)
    monthly[key]["p1"] += p1
    monthly[key]["p2"] += p2
    monthly[key]["total"] += p1 + p2
    monthly[key]["dates"].append(d.strftime("%Y-%m-%d"))

print("\nMonthly totals from Pay Dates:")
for key in sorted(monthly):
    y, m = key
    info = monthly[key]
    print(f"{y}-{m:02d}: p1={info['p1']}, p2={info['p2']}, total={info['total']}, count={len(info['dates'])}, dates={info['dates']}")

# Check if selected A2 matches a month total
a2 = ov["A2"].value
if isinstance(a2, datetime):
    key = (a2.year, a2.month)
    print("\nSelected A2 month key:", key, "expected total:", monthly[key]["total"])

# Print formulas explicitly
print("\nExplicit formulas:")
for ref in ["B2","C2","B4","B5"]:
    print(ref, "=>", ov[ref].value)
