Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine actual populated data rows based on columns A:D having any value
data_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    if any(v not in (None, "") for v in vals):
        data_rows.append(r)

print("Populated data rows:", data_rows)

if data_rows:
    first_data_row = min(data_rows)
    last_data_row = max(data_rows)
else:
    first_data_row = 2
    last_data_row = 1

print("Data range rows:", first_data_row, "to", last_data_row)
print("Current E/F before writing:")
for r in data_rows:
    print(r, "B", ws[f"B{r}"].value, "C", ws[f"C{r}"].value, "D", ws[f"D{r}"].value, "E", ws[f"E{r}"].value, "F", ws[f"F{r}"].value)

# Write formulas to all relevant rows so workbook uses formulas as requested
for r in data_rows:
    # Count whole-column populated D range only, not full column
    formula_count = f'=IF(C{r}="CANCELLED",COUNTIF($D${first_data_row}:$D${last_data_row},"*"&B{r}&"*"),0)'
    formula_yesno = f'=IF(F{r}>0,"Yes","No")'
    ws[f"F{r}"] = formula_count
    ws[f"E{r}"] = formula_yesno

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # Rename sheets positionally back to originals
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification of target cells E/F:")
for r in data_rows:
    print(
        r,
        {
            "REF": ws_values[f"B{r}"].value,
            "STATUS": ws_values[f"C{r}"].value,
            "SUBREFS": ws_values[f"D{r}"].value,
            "E_formula": ws_formula[f"E{r}"].value,
            "F_formula": ws_formula[f"F{r}"].value,
            "E_value": ws_values[f"E{r}"].value,
            "F_value": ws_values[f"F{r}"].value,
        }
    )

# Basic sanity checks
problems = []
for r in data_rows:
    ev = ws_values[f"E{r}"].value
    fv = ws_values[f"F{r}"].value
    if ev in (None, ""):
        problems.append(f"E{r} blank")
    if fv in (None, ""):
        problems.append(f"F{r} blank")

print("Problems:", problems if problems else "None")
```
