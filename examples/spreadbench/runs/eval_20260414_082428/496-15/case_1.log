import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
ws = wb[orig_sheet_names[0]]

# Thoroughly inspect all rows with "Check" in column E and current D values
matches = []
for r in range(2, ws.max_row + 1):
    d_val = ws.cell(r, 4).value  # D
    e_val = ws.cell(r, 5).value  # E
    if isinstance(e_val, str) and "check" in e_val.lower():
        nums = re.findall(r'\d+', e_val)
        matches.append((r, d_val, e_val, nums))

print("Rows in column E containing 'Check':")
for item in matches:
    print(item)

# Apply transformation
changed_rows = []
for r, d_val, e_val, nums in matches:
    if not nums:
        continue
    extracted = nums[-1]  # most likely check number; use last numeric token
    # write check number to D
    ws.cell(r, 4).value = extracted
    # normalize source text in E
    ws.cell(r, 5).value = "Check Paid"
    changed_rows.append((r, extracted))

print("Changed rows:", changed_rows)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb2 = load_workbook(output_path)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheet_names)
    # rename sheets by position
    for i, name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = name
    wb2.save(output_path)

# Verify after recalculation
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

print("Verification of target cells (D/E) for changed rows:")
verification = []
for r, extracted in changed_rows:
    d = wsv.cell(r, 4).value
    e = wsv.cell(r, 5).value
    verification.append((r, d, e))
    print((r, d, e))

# Also print non-check sample at edges to ensure untouched data nearby
print("Context rows around first few changed rows:")
for r, _ in changed_rows[:3]:
    for rr in range(max(2, r-1), min(wsv.max_row, r+1) + 1):
        print(rr, [wsv.cell(rr, c).value for c in range(1, 7)])

final_output_path = output_path
