from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook for editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm source and target areas before modifying
print("Before write:")
print("Source A1:A21:")
for r in range(1, ws.max_row + 1):
    print(f"A{r} =", ws.cell(r, 1).value)

print("\nCurrent target D1:F7:")
for r in range(1, 8):
    print(f"Row {r}:", [ws.cell(r, c).value for c in range(4, 7)])

# Collect non-empty values from column A
source_values = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None and v != "":
        source_values.append(v)

print("\nNon-empty source count:", len(source_values))

# Transpose every 3 items into columns D:F
group_size = 3
record_count = len(source_values) // group_size
print("Record count:", record_count)

for i in range(record_count):
    group = source_values[i*group_size:(i+1)*group_size]
    target_row = i + 1
    for j, value in enumerate(group, start=4):  # D=4, E=5, F=6
        cell = ws.cell(target_row, j)
        print(f"Writing {value!r} to {get_column_letter(j)}{target_row} (previous={cell.value!r})")
        cell.value = value

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names and len(wb_check.sheetnames) == len(original_sheet_names):
    for i, name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("\nVerified target range D1:F7:")
for r in range(1, 8):
    vals = [wsv.cell(r, c).value for c in range(4, 7)]
    print(f"Row {r}:", vals)

# Basic sanity checks
all_ok = True
for r in range(1, 8):
    vals = [wsv.cell(r, c).value for c in range(4, 7)]
    if any(v is None or (isinstance(v, str) and v.strip() == "") for v in vals):
        all_ok = False
        print("Problem: blank target cell in row", r, vals)

print("Verification passed:", all_ok)

final_output_spreadsheet = output_path
