from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheets:", orig_sheet_names)

def sheet_summary(ws, max_sample_cols=12):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Detect headers from row 1 and row 2 for inspection
    row1 = [ws.cell(1, c).value for c in range(1, min(ws.max_column, max_sample_cols) + 1)]
    row2 = [ws.cell(2, c).value for c in range(1, min(ws.max_column, max_sample_cols) + 1)] if ws.max_row >= 2 else []
    print("Row1:", row1)
    if row2:
        print("Row2:", row2)
    
    # Find actual non-empty bounds
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
            for c, v in enumerate(vals, start=1):
                if v is not None and v != "":
                    nonempty_cols.add(c)
    print("Non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("First non-empty row:", nonempty_rows[0], "Last non-empty row:", nonempty_rows[-1])
    print("Non-empty cols:", [(get_column_letter(c), ws.cell(1, c).value) for c in sorted(nonempty_cols)[:max_sample_cols]])
    
    # Print first 10 non-empty rows
    print("\nFirst non-empty rows sample:")
    for r in nonempty_rows[:10]:
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_sample_cols) + 1)]
        print(r, vals)
    
    # Print last 5 non-empty rows
    print("\nLast non-empty rows sample:")
    for r in nonempty_rows[-5:]:
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_sample_cols) + 1)]
        print(r, vals)
    
    # Specifically inspect columns D:F across used rows
    print("\nInspect D:F for first 15 rows:")
    for r in range(1, min(ws.max_row, 15) + 1):
        print(r, [ws.cell(r, c).value for c in range(4, 7)])

for ws in wb.worksheets:
    sheet_summary(ws)
