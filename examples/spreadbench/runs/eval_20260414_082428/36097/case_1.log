import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # find probable header row among first 5 rows (most non-empty)
    best_row = 1
    best_nonempty = -1
    for r in range(1, min(6, ws.max_row+1)):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row = r
    headers = row_values(ws, best_row, ws.max_column)
    print("Probable header row:", best_row)
    print("Headers:", headers)
    
    # print first 10 rows and last 5 rows
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    print("Last rows:")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # specifically inspect columns H and I and nearby columns for all used rows
    print("Column letters/headers around target:")
    for c in range(max(1, 6), min(ws.max_column, 10)+1):
        print(c, get_column_letter(c), ws.cell(best_row, c).value)
    
    print("Sample H/I values and formulas:")
    for r in range(1, min(ws.max_row, 15)+1):
        hv = ws[f"H{r}"].value if ws.max_column >= 8 else None
        iv = ws[f"I{r}"].value if ws.max_column >= 9 else None
        print(f"Row {r}: H={hv!r}, I={iv!r}")
    if ws.max_row > 15:
        for r in range(max(1, ws.max_row-5), ws.max_row+1):
            hv = ws[f"H{r}"].value if ws.max_column >= 8 else None
            iv = ws[f"I{r}"].value if ws.max_column >= 9 else None
            print(f"Row {r}: H={hv!r}, I={iv!r}")
    
    # print styles/number formats in H/I for data rows
