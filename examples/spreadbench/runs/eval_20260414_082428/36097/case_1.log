from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title, "max_row:", ws.max_row, "max_col:", ws.max_column)
print("Merged ranges:", list(ws.merged_cells.ranges))
print("Hidden columns:", [k for k,v in ws.column_dimensions.items() if getattr(v, 'hidden', False)])
print("Dimensions A:J headers/row2/row3:")
for c in range(1, 11):
    print(c, get_column_letter(c), "r1=", ws.cell(1,c).value, "r2=", ws.cell(2,c).value, "r3=", ws.cell(3,c).value)

print("\nRow-by-row data and H styles:")
for r in range(3, 8):
    vals = [ws.cell(r,c).value for c in range(1,9)]
    h = ws.cell(r,8)
    print(
        "row", r, vals,
        "| H.value=", h.value,
        "| H.numfmt=", h.number_format,
        "| H.fill=", h.fill.fill_type, h.fill.fgColor.rgb,
        "| H.font_bold=", h.font.bold,
        "| H.border_left=", h.border.left.style
    )

# Fill only blank H cells in actual asset rows, preserving existing examples
for r in range(3, ws.max_row):
    asset = ws.cell(r,1).value
    if asset in (None, "", "Total"):
        continue
    hcell = ws.cell(r,8)
    if hcell.value not in (None, ""):
        print(f"Leaving existing H{r} unchanged:", hcell.value)
        continue
    # Instruction:
    # if profit sold at a loss -> recoup ITV adjusted by the loss
    # elif profit < original cost -> recoup full profit
    # else -> recoup cost basis reduced by ITV
    # Columns: C cost, E ITV, F profit
    hcell.value = f'=IF(F{r}<0,MAX(0,E{r}+F{r}),IF(F{r}<C{r},F{r},C{r}-E{r}))'
    print(f"Wrote H{r} formula:", hcell.value)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalc:", result)

# Reload verify and restore sheet names if needed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    # rename in order
    for wsx, desired in zip(wb2.worksheets, orig_names):
        wsx.title = desired
    wb2.save(out_path)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
wb_vals = load_workbook(out_path, data_only=True)
wsv = wb_vals[orig_names[0]]

print("\nVerification H3:H7 formulas and values:")
for r in range(3, 8):
    print(
        r,
        "formula/raw=", wsf.cell(r,8).value,
        "cached=", wsv.cell(r,8).value
    )
