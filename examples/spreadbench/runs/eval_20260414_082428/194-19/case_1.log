import os, shutil
from datetime import datetime
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

def norm_date(v):
    if isinstance(v, datetime):
        return v.date()
    return v.date() if hasattr(v, "date") and not isinstance(v, str) else v

# Load source workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws1 = wb[original_sheetnames[0]]
ws2 = wb[original_sheetnames[1]]

# Build mapping from Sheet2
mapping = {}
dupes = []
for r in range(2, ws2.max_row + 1):
    key = (norm_date(ws2.cell(r, 2).value), ws2.cell(r, 4).value, ws2.cell(r, 8).value)
    rank_map = {}
    for pos, col in enumerate(range(10, 14), start=1):  # J:M => ranks 1..4
        tab_num = ws2.cell(r, col).value
        if tab_num is not None and tab_num != "":
            rank_map[tab_num] = pos
    rec = {"top": ws2.cell(r, 9).value, "ranks": rank_map, "src_row": r}
    if key in mapping:
        dupes.append((key, mapping[key]["src_row"], r))
    mapping[key] = rec

print("Duplicate mapping keys in Sheet2:", len(dupes))
if dupes[:5]:
    print("Sample dupes:", dupes[:5])

# Apply to Sheet1
changed_h = 0
changed_i = 0
nonmatched = 0
for r in range(2, ws1.max_row + 1):
    key = (norm_date(ws1.cell(r, 2).value), ws1.cell(r, 4).value, ws1.cell(r, 7).value)
    tab = ws1.cell(r, 10).value
    rec = mapping.get(key)
    if not rec:
        nonmatched += 1
        continue

    target_top = rec["top"]
    target_rank = rec["ranks"].get(tab)

    # Column H
    if ws1.cell(r, 8).value != target_top:
        ws1.cell(r, 8).value = target_top
        changed_h += 1

    # Column I
    if ws1.cell(r, 9).value != target_rank:
        ws1.cell(r, 9).value = target_rank
        changed_i += 1

print("Changed H cells:", changed_h)
print("Changed I cells:", changed_i)
print("Rows with no matching Sheet2 key:", nonmatched)

# Save before recalc
wb.save(outfile)
print("Saved:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    print("Restoring original sheet names...")
    for ws, orig in zip(wb_check.worksheets, original_sheetnames):
        ws.title = orig
    wb_check.save(outfile)
    print("Restored sheet names and re-saved.")

# Verification using data_only
wb_val = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)
vws1 = wb_val[original_sheetnames[0]]
vws2 = wb_val[original_sheetnames[1]]

# Verify headers/target columns explicitly
print("Sheet1 headers A:J:", [vws1.cell(1, c).value for c in range(1, 11)])
print("Target col H header:", vws1.cell(1, 8).value, "col I header:", vws1.cell(1, 9).value)

# Print sample target cells/ranges mentioned by instruction
print("\nVerify Sheet1 rows 2:20 cols D,G,H,I,J")
for r in range(2, 21):
    print(
        r,
        {
            "date": norm_date(vws1.cell(r, 2).value),
