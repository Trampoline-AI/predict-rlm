import os, shutil
from collections import OrderedDict, Counter
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["merge"]

# Verify target range G:J current contents and formulas
print("Target headers G1:J5 and existing values:")
for r in range(1, 6):
    print(r, [ws.cell(r, c).value for c in range(7, 11)])

# Determine true used rows in A:D
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if any(ws.cell(r, c).value is not None for c in range(1, 5)):
        last_data_row = r
        break
print("True last data row in A:D:", last_data_row)

# Inspect sample source rows first 10 and last 5 in A:D
print("Source A:D first 10 rows:")
for r in range(1, min(last_data_row, 10) + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])
print("Source A:D last 5 rows:")
for r in range(max(1, last_data_row - 4), last_data_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])

# Group and sum by A,B,C
grouped = OrderedDict()
for r in range(2, last_data_row + 1):
    key = tuple(ws.cell(r, c).value for c in range(1, 4))
    total = ws.cell(r, 4).value
    if key == (None, None, None):
        continue
    grouped[key] = grouped.get(key, 0) + (total if total is not None else 0)

print("Unique grouped results count:", len(grouped))
print("Grouped results preview:", list(grouped.items())[:10])

# Clear existing target output rows only in G:J where needed
for r in range(2, ws.max_row + 1):
    for c in range(7, 11):
        ws.cell(r, c).value = None

# Ensure headers match/source correspondence in G1:J1
headers = [ws.cell(1, c).value for c in range(1, 5)]
for idx, c in enumerate(range(7, 11), start=0):
    ws.cell(1, c).value = headers[idx]

# Write grouped output starting at G2
out_row = 2
for (idv, brand, typ), total_sum in grouped.items():
    ws.cell(out_row, 7).value = idv
    ws.cell(out_row, 8).value = brand
    ws.cell(out_row, 9).value = typ
    ws.cell(out_row, 10).value = total_sum
    out_row += 1

print("Wrote output rows:", out_row - 2)
for r in range(1, min(out_row, 8)):
    print("After write row", r, [ws.cell(r, c).value for c in range(7, 11)])

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and reload
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if recalculate changed them
wb2 = load_workbook(out_path)
if wb2.sheetnames != wb.sheetnames:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", wb.sheetnames)
    # rename by position
    for i, orig_name in enumerate(wb.sheetnames):
        wb2.worksheets[i].title = orig_name
    wb2.save(out_path)

# Verify output values with data_only
ver = load_workbook(out_path, data_only=True)
vws = ver["merge"]
print("Verified target G1:J6:")
for r in range(1, 7):
    print(r, [vws.cell(r, c).value for c in range(7, 11)])

output_spreadsheet = out_path
