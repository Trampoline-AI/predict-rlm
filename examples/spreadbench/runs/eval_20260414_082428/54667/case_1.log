    print("Headers:", headers)

    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]

    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_start = max(1, ws.max_row - 4)
    last_rows = list(range(last_start, ws.max_row + 1))
    print("First rows sample:")
    for r in first_rows:
