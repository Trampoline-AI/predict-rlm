import os, shutil
from datetime import datetime
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheetnames:", orig_sheetnames)
print("Before edit, row 6:", [ws.cell(6, c).value for c in range(1, 10)])
print("Before edit, Group B header rows 17:19:",
      [[ws.cell(r, c).value for c in range(1, 3)] for r in range(17, 20)])

# Insert April row between Mar and May
ws.insert_rows(6, 1)
ws["A6"] = "1951-04"
for c in range(2, 33):
    ws.cell(6, c).value = None  # blanks for April in Group A

print("After insert, rows 3:7 col A:", [ws.cell(r, 1).value for r in range(3, 8)])
print("April row preview:", [ws.cell(6, c).value for c in range(1, 10)])

# Build Group A month/day mapping after insertion
month_map = {}
for r in range(3, 14):  # rows containing 1951-01..1951-12 after insertion
    ym = ws.cell(r, 1).value
    if isinstance(ym, str) and len(ym) == 7 and ym[4] == "-":
        day_vals = {}
        for c in range(2, 33):
            day_num = ws.cell(2, c).value
            day_vals[int(day_num)] = ws.cell(r, c).value
        month_map[ym] = day_vals

print("Month keys in Group A after insertion:", list(month_map.keys()))

# Identify Group B date rows after insertion (header moved down by 1)
date_rows = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, datetime):
        date_rows.append((r, v))
print("Group B date rows count after insertion:", len(date_rows), "first:", date_rows[:3], "last:", date_rows[-3:])

def convert_value(ym, day, source_value):
    # April special rule: Group B should contain 0s
    if ym == "1951-04":
        return 0
    # Irrelevant markers -> blank
    if source_value in ("M", "NA", None, ""):
        return None
    if isinstance(source_value, (int, float)) and source_value <= -9999:
        return None
    # keep numeric values including 0
    return source_value

# Populate Group B Data column B
written = 0
blanked = 0
samples = []
for r, dt in date_rows:
    ym = f"{dt.year:04d}-{dt.month:02d}"
    day = dt.day
    src_val = month_map.get(ym, {}).get(day, None)
    out_val = convert_value(ym, day, src_val)
    ws.cell(r, 2).value = out_val
    if out_val is None:
        blanked += 1
    else:
        written += 1
    if len(samples) < 20 and (ym in {"1951-01", "1951-02", "1951-04", "1951-05", "1951-07"}):
        samples.append((r, dt.strftime("%Y-%m-%d"), src_val, out_val))

print("Written Group B values:", written, "blank Group B values:", blanked)
print("Sample mappings:")
for s in samples[:20]:
    print(s)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and fix sheet names if changed
wb2 = load_workbook(outfile)
print("Sheetnames after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename back by position
    for i, name in enumerate(orig_sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verification with formulas/data cache
wbv = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", wbv.sheetnames)
wsv = wbv[orig_sheetnames[0]]

# Verify Group A April row and nearby rows
print("Verify Group A col A rows 3:7:", [wsv.cell(r, 1).value for r in range(3, 8)])
print("Verify April row 6 A:AF sample:", [wsv.cell(6, c).value for c in range(1, 12)])

# Verify exact target area in Group B
check_dates = {
    "1951-01-04": None,   # should be 35
    "1951-01-05": None,   # should be 0
    "1951-02-29": None,   # doesn't exist
    "1951-02-28": None,   # should be 0
    "1951-03-22": None,   # should be 20
    "1951-04-01": None,   # should be 0
    "1951-04-30": None,   # should be 0
    "1951-05-11": None,   # should be 4.5
    "1951-07-12": None,   # source NA -> blank
    "1951-08-15": None,   # should be 0
}
for r in range(1, wsv.max_row + 1):
    v = wsv.cell(r, 1).value
    if isinstance(v, datetime):
        key = v.strftime("%Y-%m-%d")
        if key in check_dates:
            check_dates[key] = (r, wsv.cell(r, 2).value)

print("Verification target dates:")
for k, v in check_dates.items():
    print(k, "->", v)

# Additional checks for invalid markers in February
for key in ["1951-02-29", "1951-02-30", "1951-02-31"]:
    print(key, "not in Group B date series")
# real invalid-marker-related dates in source:
# 1951-02-29 absent by calendar; 1951-02-30 was 'M'; 1951-02-31 was -99999 in source, so no corresponding dates
# verify a real NA and a real irrelevant within date range:
extra = {}
for r in range(1, wsv.max_row + 1):
    v = wsv.cell(r, 1).value
    if isinstance(v, datetime):
        key = v.strftime("%Y-%m-%d")
        if key in {"1951-07-12", "1951-01-01", "1951-06-31"}:
            extra[key] = (r, wsv.cell(r, 2).value)
print("Extra verification:", extra)
