import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook path:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print("SHEET:", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect likely used rows/cols
    nonempty_rows = []
    for r in range(1, ws.max_row+1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # print first 10 rows
    print("\nFirst up to 10 rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))
    
    # print last 5 rows
    print("\nLast up to 5 rows:")
    start = max(1, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 20)))
    
    # search for Group A/B labels and interesting tokens
    hits = []
    tokens = {"group a", "group b", "april", "-9999", "m", "na"}
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                lv = v.strip().lower()
                if lv in tokens or "group a" in lv or "group b" in lv:
                    hits.append((r, c, v))
    print("\nInteresting text hits (up to 30):", hits[:30])
    
    # print formulas if any in first area
    formula_hits = []
    for r in range(1, min(ws.max_row, 30)+1):
        for c in range(1, min(ws.max_column, 20)+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_hits.append((r, c, v))
    print("Formula hits in top-left area:", formula_hits[:20])
