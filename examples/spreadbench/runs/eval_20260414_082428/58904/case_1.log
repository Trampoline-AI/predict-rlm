import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
print("Input path exists:", os.path.exists(path), path)

wb = load_workbook(path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find actual used rows/cols based on non-empty cells
    nonempty_rows = set()
    nonempty_cols = set()
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                nonempty_rows.add(cell.row)
                nonempty_cols.add(cell.column)
    print("Non-empty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("Non-empty col range:", (min(nonempty_cols), max(nonempty_cols)) if nonempty_cols else None)
    
    # Print row 1-5 and last 5 with coordinates and values
    rows_to_show = []
    for r in range(1, min(ws.max_row, 10) + 1):
        rows_to_show.append(r)
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        if r not in rows_to_show:
            rows_to_show.append(r)
    print("Sample rows:")
    for r in rows_to_show:
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                vals.append(f"{get_column_letter(c)}{r}={v!r}")
        print(f"Row {r}: {vals[:20]}{' ...' if len(vals) > 20 else ''}")
    
    # candidate header rows 1-5
    print("Candidate header rows 1-5:")
    for r in range(1, min(5, ws.max_row) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {row_vals}")
    
    # Print formulas and non-empty cells in a moderate region
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
    print(f"Formula cells count: {len(formula_cells)}")
    print("First 20 formula cells:", formula_cells[:20])

for ws in wb.worksheets:
    sheet_summary(ws)
