from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import re, os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Detailed inspection around target area rows 10:17, cols A:I")
for r in range(10, 18):
    vals = []
    for c in range(1, 10):
        v = ws.cell(r, c).value
        vals.append(f"{get_column_letter(c)}{r}={v!r}")
    print(" | ".join(vals))

print("\nAll non-empty cells rows 11:17:")
for r in range(11, 18):
    row_nonempty = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None:
            row_nonempty.append((get_column_letter(c), v))
    print(r, row_nonempty)

# Parse all matrix entries in C3:I9 and collect by leading letter
totals = {}
cells_by_letter = {}
pattern = re.compile(r'^([A-Z])(\d+)$')

for r in range(3, 10):
    for c in range(3, 10):
        v = ws.cell(r, c).value
        if isinstance(v, str):
            m = pattern.match(v.strip())
            if m:
                letter = m.group(1)
                num = int(m.group(2))
                totals[letter] = totals.get(letter, 0) + num
                cells_by_letter.setdefault(letter, []).append((ws.cell(r, c).coordinate, v))

print("\nParsed matrix values by letter:")
for letter in sorted(cells_by_letter):
    print(letter, "total=", totals[letter], "cells=", cells_by_letter[letter])

# Also inspect labels in A11:A17 and current values in B11:B17
