import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and confirm target area again
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Writing formulas to target cells B11:B17")
for r in range(11, 18):
    label = ws[f"A{r}"].value
    current = ws[f"B{r}"].value
    print(f"Before: A{r}={label!r}, B{r}={current!r}")
    # Sum numbers attached to the letter shown in A-row label, across the matrix C3:I9
    formula = f'=SUMPRODUCT((LEFT($C$3:$I$9,1)=RIGHT($A{r},1))*IFERROR(VALUE(RIGHT($C$3:$I$9,LEN($C$3:$I$9)-1)),0))'
    ws[f"B{r}"] = formula
    print(f"Written B{r} formula: {formula}")

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    print("Restoring original sheet names...")
    for i, name in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)

# Verify formulas exist
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nFormulas now in B11:B17:")
for r in range(11, 18):
    print(f"B{r} formula -> {wsf[f'B{r}'].value!r}")

# Verify computed values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
print("\nVerified output A11:B17 (data_only):")
for r in range(11, 18):
    print(f"A{r}={wsv[f'A{r}'].value!r}, B{r}={wsv[f'B{r}'].value!r}")

# Plausibility check against expected totals from inspection
expected = {'A': 2, 'B': 3, 'C': 7, 'D': 14, 'E': 6, 'F': 3, 'G': 2}
actual = {}
for r in range(11, 18):
    letter = str(wsv[f"A{r}"].value).replace("Sum ", "").strip()
    actual[letter] = wsv[f"B{r}"].value
print("\nExpected totals:", expected)
print("Actual totals:", actual)

output_spreadsheet = outfile
