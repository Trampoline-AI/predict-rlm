import os, re, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Inspect exact target cells and data types / formats
for coord in ["B2","C2","B3","C3","B4","C4","B5","C5"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "data_type=", cell.data_type, "number_format=", cell.number_format)

def extract_numeric_text(s):
    """Extract numeric value from currency-ish text and return normalized string with '.' decimal."""
    if s is None:
        return None
    s = str(s).strip()
    # keep only digits, separators, sign, spaces
    cleaned = re.sub(r"[^0-9,.\-\s]", "", s).strip()
    cleaned = re.sub(r"\s+", " ", cleaned)

    # Determine decimal separator: last comma/dot followed by 1-2 digits is treated as decimal sep
    last_comma = cleaned.rfind(",")
    last_dot = cleaned.rfind(".")
    sep_idx = max(last_comma, last_dot)

    if sep_idx != -1:
        digits_after = re.sub(r"\D", "", cleaned[sep_idx+1:])
        if 1 <= len(digits_after) <= 2:
            dec_sep = cleaned[sep_idx]
        else:
            dec_sep = None
    else:
        dec_sep = None

    if dec_sep:
        int_part = cleaned[:sep_idx]
        frac_part = cleaned[sep_idx+1:]
        int_digits = re.sub(r"[^0-9\-]", "", int_part)
        frac_digits = re.sub(r"\D", "", frac_part)
        normalized = int_digits + "." + frac_digits
    else:
        normalized = re.sub(r"[^0-9\-]", "", cleaned)

    # normalize minus placement if any stray
    if normalized.count("-") > 1:
        normalized = "-" + normalized.replace("-", "")
    elif "-" in normalized and not normalized.startswith("-"):
        normalized = "-" + normalized.replace("-", "")
    return normalized

# Show what we plan to write
targets = []
for r in range(2, ws.max_row + 1):
    src = ws.cell(r, 2).value
    dest = ws.cell(r, 3).value
    computed = extract_numeric_text(src)
    print(f"Row {r}: src={src!r}, existing C={dest!r}, computed={computed!r}")
    if dest in (None, ""):
        targets.append((r, computed))

# Write only blank target cells, preserving examples
for r, computed in targets:
    ws.cell(r, 3).value = computed

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and verify sheet names; rename back if needed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"]:
    # rename first/only sheet back if needed
    if len(wb2.sheetnames) == 1:
        wb2[wb2.sheetnames[0]].title = "Sheet1"
        wb2.save(out_path)
        print("Renamed sheet back to Sheet1")
    else:
        print("Unexpected sheetnames mismatch; leaving as-is")

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
for coord in ["C2","C3","C4","C5"]:
    print(coord, "=>", wsv[coord].value)

output_file = out_path
