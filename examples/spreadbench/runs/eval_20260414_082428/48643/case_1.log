        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append((r, vals))
    print("First non-empty rows (up to 10):")
    for r, vals in nonempty_rows[:10]:
        print(f"Row {r}: {vals}")
    
    # Assume first non-empty row is header-like for reporting
    if nonempty_rows:
        header_row_num, headers = nonempty_rows[0]
        print(f"Candidate header row {header_row_num}:")
        for idx, h in enumerate(headers, start=1):
            print(f"  {get_column_letter(idx)}: {h}")
    
    # print first 10 rows
