import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload workbook for clean manipulation
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
orig_sheetnames = wb.sheetnames[:]

print("Target sheet:", ws.title)
print("Headers A:H:", [ws.cell(1, c).value for c in range(1, 9)])

print("\nInspecting target area A1:H10 before changes:")
for r in range(1, 11):
    print(r, [ws.cell(r, c).value for c in range(1, 9)])

print("\nCurrent H2:H10 values/formulas before changes:")
for r in range(2, 11):
    print(f"H{r}:", ws[f"H{r}"].value)

# Write formulas into existing output column H ("Total ability")
for r in range(2, ws.max_row + 1):
    b = f"B{r}"
    c = f"C{r}"
    if r == 2:
        formula = f'=IF(OR({b}="",{c}=""),"",{b}*(1+{c}))'
    else:
        prev_h = f"H{r-1}"
        formula = f'=IF(OR({b}="",{c}=""),"",({prev_h}+{b})*(1+{c}))'
    ws[f"H{r}"] = formula

print("\nWritten formulas H2:H10:")
for r in range(2, 11):
    print(f"H{r}:", ws[f"H{r}"].value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    for i, old_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(out_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("\nVerification of target cells H2:H10 (formula | value):")
for r in range(2, 11):
    print(f"H{r}: {ws_formula[f'H{r}'].value} | {ws_values[f'H{r}'].value}")

print("\nSanity check first 5 rows A:H with cached values:")
for r in range(1, 7):
    print(r, [ws_values.cell(r, c).value for c in range(1, 9)])

output_spreadsheet = out_path
```
