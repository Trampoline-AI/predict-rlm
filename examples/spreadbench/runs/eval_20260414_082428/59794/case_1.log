import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
from openpyxl.cell.cell import MergedCell

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load fresh workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["SOURCE"]

# Identify data rows from column A (skip headers rows 1-2)
data_rows = []
for r in range(3, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v not in (None, ""):
        parts = str(v).split("/")  # preserve exact segments, including "-"
        data_rows.append((r, str(v), parts))

print("Data rows and split parts:")
for r, v, parts in data_rows:
    print(r, len(parts), parts)

max_parts = max(len(parts) for _, _, parts in data_rows) if data_rows else 0
start_col = 3  # C
end_col = start_col + max_parts - 1
print("Need output columns:", get_column_letter(start_col), "to", get_column_letter(end_col), "(", max_parts, "parts )")

# Existing final info area currently starts at C
existing_end_col = 11  # K based on inspection
if end_col > existing_end_col:
    # Unmerge old merged header and extend it
    merged_ranges = list(ws.merged_cells.ranges)
    for mr in merged_ranges:
        if str(mr) == "C1:K1":
            ws.unmerge_cells(str(mr))
            break
    
    # Copy formatting/dimensions from the adjacent leftmost existing last column (K) to new columns
    template_col = existing_end_col
    for c in range(existing_end_col + 1, end_col + 1):
        letter = get_column_letter(c)
        template_letter = get_column_letter(template_col)
        if template_letter in ws.column_dimensions:
            ws.column_dimensions[letter].width = ws.column_dimensions[template_letter].width
        
        # copy style row 1 and row 2 and existing data rows from template col
        for r in range(1, ws.max_row + 1):
            src = ws.cell(r, template_col)
            dst = ws.cell(r, c)
            if src.has_style:
                dst._style = copy(src._style)
            if src.number_format:
                dst.number_format = copy(src.number_format)
            if src.font:
                dst.font = copy(src.font)
            if src.fill:
                dst.fill = copy(src.fill)
            if src.border:
                dst.border = copy(src.border)
            if src.alignment:
                dst.alignment = copy(src.alignment)
            if src.protection:
                dst.protection = copy(src.protection)
        
        # set header names for row 2
        ws.cell(2, c).value = f"Column{c - start_col + 1}"
    
    # Re-merge header across new width
    ws.merge_cells(start_row=1, start_column=3, end_row=1, end_column=end_col)
else:
    # ensure headers exist across used part count
    for c in range(3, end_col + 1):
        if ws.cell(2, c).value in (None, ""):
            ws.cell(2, c).value = f"Column{c - start_col + 1}"

# Fill color requested
green_fill = PatternFill(start_color="E2EFDA", end_color="E2EFDA", fill_type="solid")

# Clear old output area in rows with data, from C through new end col
for r, _, parts in data_rows:
    for c in range(start_col, end_col + 1):
        ws.cell(r, c).value = None
        ws.cell(r, c).fill = copy(ws.cell(2, c).fill) if ws.cell(2, c).fill.fill_type else PatternFill(fill_type=None)

# Write split parts and shade filled cells
for r, v, parts in data_rows:
    for i, part in enumerate(parts, start=0):
        c = start_col + i
        ws.cell(r, c).value = part
        ws.cell(r, c).fill = green_fill

# Also shade header row 2 over active final information columns? instruction says once values are output, shade the cells;
# so only filled output cells are shaded, not headers.

wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
