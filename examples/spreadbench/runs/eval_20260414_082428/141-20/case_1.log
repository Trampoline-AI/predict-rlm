import os
from collections import defaultdict
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]

pl_ws = wb["PL Recon Items"]
st_ws = wb["Statement Recon Items"]

def norm(v):
    if v is None:
        return None
    if isinstance(v, float):
        if v.is_integer():
            return str(int(v))
        # normalize float text consistently
        return format(v, "g")
    return str(v).strip()

# Build key -> rows mapping
pl_key_to_rows = defaultdict(list)
for r in range(2, pl_ws.max_row + 1):
    key = (norm(pl_ws.cell(r, 3).value), norm(pl_ws.cell(r, 4).value))
    if key != (None, None):
        pl_key_to_rows[key].append(r)

st_key_to_rows = defaultdict(list)
for r in range(2, st_ws.max_row + 1):
    key = (norm(st_ws.cell(r, 6).value), norm(st_ws.cell(r, 9).value))
    if key != (None, None):
        st_key_to_rows[key].append(r)

common_keys = sorted(k for k in pl_key_to_rows if k in st_key_to_rows and k != (None, None))
print("Common keys:", common_keys)

pl_rows_to_delete = sorted({r for k in common_keys for r in pl_key_to_rows[k]}, reverse=True)
st_rows_to_delete = sorted({r for k in common_keys for r in st_key_to_rows[k]}, reverse=True)

print("PL rows to delete:", pl_rows_to_delete)
print("Statement rows to delete:", st_rows_to_delete)

# Delete from bottom up
for r in pl_rows_to_delete:
    pl_ws.delete_rows(r, 1)

for r in st_rows_to_delete:
    st_ws.delete_rows(r, 1)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and fix sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)

if wb2.sheetnames != original_sheetnames:
    # rename by position to match original names
    if len(wb2.sheetnames) == len(original_sheetnames):
        for i, s in enumerate(original_sheetnames):
            wb2.worksheets[i].title = s
        wb2.save(outfile)
        print("Renamed sheets back to original names:", original_sheetnames)

# Verify final file
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)

v_pl = verify_wb["PL Recon Items"]
v_st = verify_wb["Statement Recon Items"]

def all_rows(ws):
    return [[ws.cell(r, c).value for c in range(1, ws.max_column + 1)] for r in range(1, ws.max_row + 1)]

pl_rows_after = all_rows(v_pl)
st_rows_after = all_rows(v_st)

print("PL Recon Items final max_row/max_col:", v_pl.max_row, v_pl.max_column)
print("PL Recon Items final rows:", pl_rows_after)

print("Statement Recon Items final max_row/max_col:", v_st.max_row, v_st.max_column)
print("Statement Recon Items final rows:", st_rows_after)

# Extra verification of target columns after deletion
print("Remaining PL data rows (C,D):")
for r in range(2, v_pl.max_row + 1):
    print(r, v_pl.cell(r, 3).value, v_pl.cell(r, 4).value)

print("Remaining Statement data rows (F,I):")
for r in range(2, v_st.max_row + 1):
    print(r, v_st.cell(r, 6).value, v_st.cell(r, 9).value)

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
