def safe_color_repr(color):
    if color is None:
        return None
    parts = {}
    for attr in ("type", "rgb", "indexed", "theme", "tint", "auto"):
        try:
            val = getattr(color, attr, None)
        except Exception:
            val = None
        if val is not None:
            parts[attr] = str(val)
    return parts

def cell_fill_summary(cell):
    f = cell.fill
    return {
        "fill_type": getattr(f, "fill_type", None),
        "patternType": getattr(f, "patternType", None),
        "start_color": safe_color_repr(getattr(f, "start_color", None)),
        "end_color": safe_color_repr(getattr(f, "end_color", None)),
        "fgColor": safe_color_repr(getattr(f, "fgColor", None)),
    }

def color_tokens(cell):
    toks = []
    f = cell.fill
    for obj in (getattr(f, "start_color", None), getattr(f, "end_color", None), getattr(f, "fgColor", None)):
