import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Build lookup from Table 2 (L:N), skipping placeholders/blanks
lookup = defaultdict(list)
for r in range(7, ws.max_row + 1):
    key = ws.cell(r, 12).value  # L
    v1 = ws.cell(r, 13).value   # M
    v2 = ws.cell(r, 14).value   # N
    if key is None:
        continue
    key_str = str(key).strip()
    if key_str in {"…", "…..", "...", ""}:
        continue
    lookup[key_str].extend([v1, v2])

print("Lookup built from Table 2:")
for k, v in lookup.items():
    print(k, "->", v)

# Fill Table 1 rows based on Column C, target D:I
writes = []
for r in range(7, ws.max_row + 1):
    key = ws.cell(r, 3).value  # C
    if key is None:
        continue
    key_str = str(key).strip()
    if key_str in {"…", "…..", "...", ""}:
        continue
    if key_str not in lookup:
        continue
    
    expected = lookup[key_str]
    # Write across D onward, but preserve already-correct values
    for idx, val in enumerate(expected, start=4):  # D=4
        if idx > 9:  # up to I based on existing table design
            break
        cell = ws.cell(r, idx)
        current = cell.value
        if current is None or current == "":
            cell.value = val
            writes.append((r, idx, val))
        else:
            # leave existing example answers in place
            pass

print("\nCells written:")
for r, c, v in writes:
    print(f"{r},{c} ({ws.cell(6,c).coordinate[:-1] if False else ''}) {v}")

print("\nPost-write Table 1 rows 7:11 C:I")
for r in range(7, 12):
    print(r, [ws.cell(r, c).value for c in range(3, 10)])

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate (though there are no formulas, required by task)
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and verify sheet names, rename back if needed
orig_sheet_names = [ws.title for ws in wb.worksheets]
wb_check = load_workbook(output_path)
current_sheet_names = wb_check.sheetnames
print("Original sheet names:", orig_sheet_names)
print("Current sheet names:", current_sheet_names)

if current_sheet_names != orig_sheet_names:
    # rename by position back to original names
    for i, name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Renamed sheets back to original names:", wb_check.sheetnames)

# Final verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["Sheet1"]

print("\nVerified target cells D:I for rows 7:11")
for r in range(7, 12):
    print(r, [wsv.cell(r, c).value for c in range(4, 10)])

# Store output path for submission
final_output_path = output_path
