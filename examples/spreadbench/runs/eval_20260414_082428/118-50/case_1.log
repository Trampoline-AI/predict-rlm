        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_values(ws, r, ws.max_column))
    
    # Print merged cells if any
    merged = list(ws.merged_cells.ranges)
    print("Merged ranges:", merged[:20], "(total:", len(merged), ")")
    
    # Scan for formulas or notable non-empty cells in first few columns/rows
    formula_cells = []
    for r in range(1, min(ws.max_row, 50) + 1):
        for c in range(1, min(ws.max_column, 20) + 1):
