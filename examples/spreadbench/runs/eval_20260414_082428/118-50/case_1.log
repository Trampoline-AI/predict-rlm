Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from collections import defaultdict

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for writing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Read words from column A
words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

def transform_move_5th_to_front(word):
    if not isinstance(word, str) or len(word) < 5:
        return None
    return word[4] + word[:4] + word[5:]

word_set = set(words)

# Build valid pairs
pairs = []
for w in words:
    t = transform_move_5th_to_front(w)
    if t in word_set and t != w:
        pairs.append((w, t, w[-3:]))

# Group in requested suffix order
target_order = ["ING", "ERS", "ATE", "EST", "ONE", "IER", "ILY"]
grouped = {suf: [] for suf in target_order}
for w, t, suf in pairs:
    if suf in grouped:
        grouped[suf].append((w, t))

for suf in target_order:
    grouped[suf].sort()

ordered_pairs = []
for suf in target_order:
    ordered_pairs.extend(grouped[suf])

print("Ordered pairs to write (C=original, D=transformed):")
for i, p in enumerate(ordered_pairs, start=1):
    print(i, p)

# Sort column A alphabetically
sorted_words = sorted(words)
for r, word in enumerate(sorted_words, start=1):
    ws.cell(r, 1).value = word

# If there are extra rows beyond non-empty input words, clear them in A
for r in range(len(sorted_words) + 1, ws.max_row + 1):
    if ws.cell(r, 1).value is not None:
        ws.cell(r, 1).value = None

# Clear columns C:D existing contents over used range, then write results.
# Follow verified example orientation: C=original, D=transformed.
for r in range(1, ws.max_row + 1):
    ws.cell(r, 3).value = None
    ws.cell(r, 4).value = None

for r, (orig, trans) in enumerate(ordered_pairs, start=1):
    ws.cell(r, 3).value = orig
    ws.cell(r, 4).value = trans

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verification reload with data_only
wb_verify_formula = load_workbook(output_path, data_only=False)
wb_verify = load_workbook(output_path, data_only=True)
wsf = wb_verify_formula["Sheet1"]
wsv = wb_verify["Sheet1"]

print("\nVerification:")
print("Final sheet names:", wb_verify.sheetnames)
print("Column A first 15 sorted values:")
for r in range(1, 16):
    print(r, wsv.cell(r, 1).value)

print("\nTarget C:D rows 1-20:")
for r in range(1, 21):
    print(r, wsv.cell(r, 3).value, "|", wsv.cell(r, 4).value)

# Sanity checks
print("\nSanity checks:")
print("A column sorted check first 20 raw:", [wsv.cell(r, 1).value for r in range(1, 21)])
nonblank_cd = [(r, wsv.cell(r,3).value, wsv.cell(r,4).value) for r in range(1, wsv.max_row + 1) if wsv.cell(r,3).value or wsv.cell(r,4).value]
print("Nonblank C:D count:", len(nonblank_cd))
print("Nonblank C:D rows:", nonblank_cd[:20])

# Keep output path ready for submission
final_output_path = output_path
