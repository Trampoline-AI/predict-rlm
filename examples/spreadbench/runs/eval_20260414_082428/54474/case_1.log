import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws_whp = wb["WHP"]
ws_data = wb["WHP DATA"]

# Build source map from WHP DATA using only actual site rows:
# rows with a site name in col B that is not a section header/total and with numeric referral values
source_map = {}
for r in range(1, ws_data.max_row + 1):
    site = ws_data.cell(r, 2).value
    eeg = ws_data.cell(r, 3).value
    dis = ws_data.cell(r, 4).value
    ltu = ws_data.cell(r, 5).value
    
    if site in (None, "", "Total", "Local London Partnership", "Central London Forward", "Go Live 1/3/18"):
        continue
    
    # Keep rows that look like actual numeric data rows
    if any(isinstance(v, (int, float)) for v in (eeg, dis, ltu)):
        source_map[str(site).strip()] = {"EEG": eeg, "Dis": dis, "LTU": ltu, "row": r}

print("Clean source map:", source_map)

# Fill WHP rows by matching site name in column C
changes = []
for r in range(7, ws_whp.max_row + 1):
    site = ws_whp.cell(r, 3).value  # column C
    if site in (None, ""):
        continue
    site_key = str(site).strip()
    if site_key not in source_map:
        continue
    
    src = source_map[site_key]
    targets = {
        5: src["EEG"],  # E
        6: src["Dis"],  # F
        7: src["LTU"],  # G
    }
    for c, new_val in targets.items():
        cell = ws_whp.cell(r, c)
        old_val = cell.value
        # Preserve existing populated cells; fill blanks only
        if old_val in (None, "") and new_val is not None:
            cell.value = new_val
            changes.append((r, c, old_val, new_val))
        else:
            # report any nonblank existing values for verification
            if old_val not in (None, ""):
                print(f"Preserved existing {cell.coordinate}={old_val!r}; source={new_val!r}")

print("Changes made:", changes)

# Preserve/confirm YTD formulas in column H for populated rows
for r in range(7, ws_whp.max_row + 1):
    site = ws_whp.cell(r, 3).value
    if site not in (None, ""):
        print(f"H{r} formula/value before save:", ws_whp.cell(r, 8).value)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb_check = load_workbook(output_path)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheet_names)
    # rename by position
    for i, expected in enumerate(orig_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(output_path)

# Verify using data_only after recalculation
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

wsv = wb_verify["WHP"]
print("Final verified target rows C:H:")
