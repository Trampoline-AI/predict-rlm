import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)
print("-" * 80)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Workbook sheets:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # find likely header row among first 5 rows by most non-empty cells
    best_row = 1
    best_count = -1
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty > best_count:
            best_count = nonempty
            best_row = r
    print("Likely header row:", best_row)
    headers = [ws.cell(best_row, c).value for c in range(1, ws.max_column + 1)]
    print("Headers:", [(get_column_letter(c), headers[c-1]) for c in range(1, ws.max_column + 1)])
    
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    print("First rows:")
    for r in first_rows:
        print(r, row_vals(r))
    
    if ws.max_row > 10:
        print("Last rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_vals(r))

for s in wb.sheetnames:
    sheet_summary(wb[s])
