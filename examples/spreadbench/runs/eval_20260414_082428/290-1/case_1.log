import os, shutil, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Reload fresh workbook for modification
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Working on sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)

# Source rows are data rows 2:max_row based on inspection
source_start = 2
source_end = ws.max_row
source_rows = [r for r in range(source_start, source_end + 1) if ws.cell(r, 1).value not in (None, "")]
groups = [source_rows[i:i+4] for i in range(0, len(source_rows), 4)]

print("Total source rows:", len(source_rows))
print("Group sizes:", [len(g) for g in groups])
print("Destination rows will be:", list(range(2, 2 + len(groups))))

# Show current target area before modification
print("\nBefore writing, target rows K:V:")
for dest_r in range(2, 2 + len(groups)):
    vals = [ws.cell(dest_r, c).value for c in range(11, 23)]
    print(dest_r, vals)

# Write the transpose pattern into K:V
block_starts = [11, 14, 17, 20]  # K, N, Q, T
written = []

for gi, grp in enumerate(groups):
    dest_r = 2 + gi
    for bi, src_r in enumerate(grp):
        start_c = block_starts[bi]
        num_val = ws.cell(src_r, 9).value   # column I
        text_val = ws.cell(src_r, 8).value  # column H

        # write values only; preserve formatting/style already in cells
        ws.cell(dest_r, start_c).value = num_val
        ws.cell(dest_r, start_c + 1).value = text_val
        ws.cell(dest_r, start_c + 2).value = None
        written.append((dest_r, start_c, num_val, text_val))

    # Clear any unused remaining blocks in the last partial row
    for bi in range(len(grp), 4):
        start_c = block_starts[bi]
        ws.cell(dest_r, start_c).value = None
        ws.cell(dest_r, start_c + 1).value = None
        ws.cell(dest_r, start_c + 2).value = None

print("\nWritten mappings (dest row, start col, I-value, H-value):")
for item in written:
    print(item)

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate (not strictly needed for static values, but required)
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position back to originals
    for idx, orig_name in enumerate(orig_sheet_names):
        wb_check.worksheets[idx].title = orig_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verification with data_only
wb_val = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)
ws_val = wb_val[orig_sheet_names[0]]

print("\nAfter writing, target rows K:V:")
for dest_r in range(2, 2 + len(groups)):
    vals = [ws_val.cell(dest_r, c).value for c in range(11, 23)]
    print(dest_r, vals)

# Explicit verification of expected mapping
verification_ok = True
for gi, grp in enumerate(groups):
    dest_r = 2 + gi
    for bi in range(4):
        start_c = block_starts[bi]
        got_num = ws_val.cell(dest_r, start_c).value
        got_txt = ws_val.cell(dest_r, start_c + 1).value
        got_sep = ws_val.cell(dest_r, start_c + 2).value
        if bi < len(grp):
            src_r = grp[bi]
            exp_num = ws.cell(src_r, 9).value
            exp_txt = ws.cell(src_r, 8).value
            if got_num != exp_num or got_txt != exp_txt or got_sep not in (None, ""):
                verification_ok = False
                print("Mismatch:", {
                    "dest_row": dest_r,
                    "block": bi+1,
                    "expected": (exp_num, exp_txt, None),
                    "got": (got_num, got_txt, got_sep),
                })
        else:
            if got_num not in (None, "") or got_txt not in (None, "") or got_sep not in (None, ""):
                verification_ok = False
                print("Unexpected leftover values:", dest_r, bi+1, got_num, got_txt, got_sep)

print("\nVerification OK:", verification_ok)

# Keep path ready for submission
output_spreadsheet = outfile
print("output_spreadsheet =", output_spreadsheet)
