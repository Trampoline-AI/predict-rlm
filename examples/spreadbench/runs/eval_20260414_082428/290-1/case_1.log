import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def display(val):
    if val is None:
        return None
    return val

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # Row 1-3 headers snapshot
    for r in range(1, min(4, ws.max_row+1)):
        vals = [display(ws.cell(r,c).value) for c in range(1, min(ws.max_column, 24)+1)]
        print(f"Row {r} first {min(ws.max_column,24)} cols:", vals)
    # First 10 rows all used columns up to 24
    first_n = min(10, ws.max_row)
    print(f"\nFirst {first_n} rows (A:{get_column_letter(min(ws.max_column,24))}):")
    for r in range(1, first_n+1):
        vals = [display(ws.cell(r,c).value) for c in range(1, min(ws.max_column,24)+1)]
        print(r, vals)
    # Last 5 rows
    start_last = max(1, ws.max_row-4)
    print(f"\nLast rows {start_last}:{ws.max_row} (A:{get_column_letter(min(ws.max_column,24))}):")
    for r in range(start_last, ws.max_row+1):
        vals = [display(ws.cell(r,c).value) for c in range(1, min(ws.max_column,24)+1)]
        print(r, vals)

    # Explicit K:V inspection with row numbers
    print("\nColumns K:V detailed non-empty-ish sample:")
    for r in range(1, min(ws.max_row, 25)+1):
        vals = [display(ws.cell(r,c).value) for c in range(11, min(22, ws.max_column)+1)]
        if any(v is not None for v in vals):
            print(f"Row {r} K:V ->", vals)

    # detect rows with content in K:V across sheet
    kv_rows = []
    for r in range(1, ws.max_row+1):
        vals = [ws.cell(r,c).value for c in range(11, min(22, ws.max_column)+1)]
        if any(v not in (None, "") for v in vals):
            kv_rows.append(r)
    print("Rows with any content in K:V:", kv_rows[:50], "count=", len(kv_rows))

    # print formulas in K:V if any
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(11, min(22, ws.max_column)+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, get_column_letter(c), v))
    print("Formulas in K:V:", formulas[:20], "count=", len(formulas))
