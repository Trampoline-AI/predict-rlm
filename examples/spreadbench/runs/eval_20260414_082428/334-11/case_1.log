import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Working sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)

# Print all rows and Column C details including fills
def fill_desc(cell):
    f = cell.fill
    return {
        "fill_type": f.fill_type,
        "start": f.start_color.rgb,
        "end": f.end_color.rgb
    }

print("All rows before modification:")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(r, vals, "C_fill=", fill_desc(ws.cell(r, 3)))

# Determine rows to delete: blank C or numeric between -1 and 1 inclusive
rows_to_delete = []
for r in range(2, ws.max_row + 1):  # assume row 1 header
    v = ws.cell(r, 3).value
    delete = False
    reason = None
    if v is None or (isinstance(v, str) and v.strip() == ""):
        delete = True
        reason = "blank"
    else:
        num = None
        if isinstance(v, (int, float)):
            num = float(v)
        elif isinstance(v, str):
            try:
                num = float(v.strip())
            except:
                num = None
        if num is not None and -1 <= num <= 1:
            delete = True
            reason = "between_-1_and_1"
    if delete:
        rows_to_delete.append((r, v, reason))

print("Rows marked for deletion:", rows_to_delete)

# Delete from bottom up
for r, v, reason in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

print("After deletion, dimensions:", ws.max_row, ws.max_column)
print("Remaining rows:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # Rename back to original names by position
    for i, orig in enumerate(orig_sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = orig
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verification with data_only
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_sheetnames[0]]

print("Final rows in target sheet:")
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

# Explicit verification of remaining Column C values
remaining_c = [wsv.cell(r, 3).value for r in range(2, wsv.max_row + 1)]
print("Remaining Column C values:", remaining_c)
print("Any blanks remaining in data rows?:", any(v is None or (isinstance(v, str) and v.strip() == "") for v in remaining_c))
print("Any values in [-1,1] remaining?:", any(isinstance(v, (int, float)) and -1 <= float(v) <= 1 for v in remaining_c))
