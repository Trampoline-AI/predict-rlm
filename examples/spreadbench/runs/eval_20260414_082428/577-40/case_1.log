import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

sheet_info = {}
for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        headers2 = row_values(ws, 2, ws.max_column)
        print("Row 2:", headers2)
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("First rows sample:")
    for r in first_rows:
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    print("Last rows sample:")
    for r in last_rows:
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    # print J/K current values if columns exist
    if ws.max_column >= 11:
        print("Column J/K samples:")
        jk_rows = sorted(set(first_rows + last_rows))
        for r in jk_rows:
            jv = ws["J"+str(r)].value
            kv = ws["K"+str(r)].value
            print(f"Row {r}: J={jv!r}, K={kv!r}")
        # check formulas in J/K
        for col in ["J", "K"]:
            formulas = []
            for r in range(1, ws.max_row + 1):
                v = ws[f"{col}{r}"].value
                if isinstance(v, str) and v.startswith("="):
                    formulas.append((r, v))
                    if len(formulas) >= 5:
                        break
            print(f"First formulas found in {col}:", formulas if formulas else "None")
    sheet_info[ws.title] = {"rows": ws.max_row, "cols": ws.max_column, "headers": headers}

print("\nSheet info summary:")
print(json.dumps(sheet_info, default=str, indent=2))
