import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

invalid_strings = {"", "-", "0", "$", "$0", "$0.0"}

def is_invalid(v):
    if v is None:
        return True
    if isinstance(v, str):
        s = v.strip()
        return s in invalid_strings
    if isinstance(v, (int, float)):
        return v == 0
    return False

# Reopen fresh workbook for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet2"]

# Inspect all relevant J/K rows before deleting
matches = []
nonmatches_sample = []
for r in range(2, ws.max_row + 1):  # skip header
    jv = ws[f"J{r}"].value
    kv = ws[f"K{r}"].value
    both_invalid = is_invalid(jv) and is_invalid(kv)
    row_snapshot = {
        "row": r,
        "J": jv,
        "K": kv,
        "delete": both_invalid,
    }
    if both_invalid:
        matches.append(row_snapshot)
    elif len(nonmatches_sample) < 12:
        nonmatches_sample.append(row_snapshot)

print("Rows meeting delete condition (both J and K invalid):", len(matches))
print(matches)
print("Sample rows NOT deleted:")
print(nonmatches_sample)

# Delete bottom-up
for item in reversed(matches):
    ws.delete_rows(item["row"], 1)

print("Row count after deletion (in-memory):", ws.max_row)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # Rename sheets back by position
    for i, original_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

print("Final max_row:", wsv.max_row, "max_column:", wsv.max_column)

# Verify no remaining rows violate condition
remaining_bad = []
for r in range(2, wsv.max_row + 1):
    jv = wsv[f"J{r}"].value
    kv = wsv[f"K{r}"].value
    if is_invalid(jv) and is_invalid(kv):
        remaining_bad.append((r, jv, kv))

print("Remaining rows still violating condition:", remaining_bad)

# Print first 10 and last 5 rows of J/K after deletion
print("Post-delete first 10 data rows J/K:")
for r in range(2, min(wsv.max_row, 11) + 1):
    print(r, wsv[f"J{r}"].value, wsv[f"K{r}"].value)

print("Post-delete last 5 rows J/K:")
for r in range(max(2, wsv.max_row - 4), wsv.max_row + 1):
    print(r, wsv[f"J{r}"].value, wsv[f"K{r}"].value)
```
