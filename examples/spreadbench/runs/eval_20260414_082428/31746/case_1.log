import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
orig_sheet_names = wb.sheetnames[:]

# Inspect all Q cells to see which are blank / existing
q_status = []
for r in range(3, 39):
    q_status.append((r, ws[f"Q{r}"].value))
print("Q3:Q38 status:")
for item in q_status:
    print(item)

# Build formula pattern from headers D:P
month_cols = list(range(4, 17))  # D:P
terms_template = []
for c in month_cols:
    hdr = ws.cell(2, c).value
    month_num = int(str(hdr).split()[1])
    multiplier = 81 - (month_num - 1)
    terms_template.append((c, multiplier))
print("Template multipliers:", [(get_column_letter(c), m) for c, m in terms_template])

def q_formula_for_row(r):
    terms = [f"({get_column_letter(c)}{r}*{mult})" for c, mult in terms_template]
    return "=" + "+".join(terms)

# Check style source cells
for coord in ["Q3", "Q33", "Q34", "Q38"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "bold=", cell.font.bold, "numfmt=", cell.number_format)

# Fill Q3:Q37 with consistent formulas (safe because this column is the designated calculation column;
# some cells already have the same formula pattern, others are blank)
for r in range(3, 38):
    ws[f"Q{r}"] = q_formula_for_row(r)

# Set grand total in Q38
ws["Q38"] = "=SUM(Q3:Q37)"

# Ensure non-bold in output cells per instruction
for r in range(3, 39):
    ws[f"Q{r}"].font = ws[f"Q{r}"].font.copy(bold=False)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore original sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    for i, s in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = s
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas and computed values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("Verification target cells Q34:Q38")
for r in range(34, 39):
    print(
        f"Q{r}",
        "formula=", ws_formula[f"Q{r}"].value,
        "value=", ws_values[f"Q{r}"].value,
        "bold=", ws_formula[f"Q{r}"].font.bold
    )

print("Additional sample computed values:")
for r in [3, 5, 6, 7, 33]:
    print(
        f"Q{r}",
        "formula=", ws_formula[f"Q{r}"].value,
        "value=", ws_values[f"Q{r}"].value
    )

output_spreadsheet = out_path
