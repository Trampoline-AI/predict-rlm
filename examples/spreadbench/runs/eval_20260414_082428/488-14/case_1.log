from collections import Counter, defaultdict
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]
ref = wb["Desired Results"]

src = [ws.cell(r, 1).value for r in range(2, ws.max_row + 1) if ws.cell(r, 1).value not in (None, "")]
dst = [ref.cell(r, 1).value for r in range(2, ref.max_row + 1) if ref.cell(r, 1).value not in (None, "")]

print("Source rows:", len(src))
print("Desired rows:", len(dst))
print("Same multiset?:", Counter(src) == Counter(dst))

cnt = Counter(src)
print("\nCounts sorted by frequency desc, then item asc:")
for item, n in sorted(cnt.items(), key=lambda kv: (-kv[1], str(kv[0]))):
    print(item, n)

# compress desired-result runs
runs = []
if dst:
    cur = dst[0]
    n = 1
    for x in dst[1:]:
        if x == cur:
            n += 1
        else:
            runs.append((cur, n))
            cur = x
            n = 1
    runs.append((cur, n))

print("\nDesired result runs:")
for item, n in runs:
    print(item, n)

print("\nFirst mismatch between desired order and freq-desc/item-asc candidate:")
candidate = []
for item, n in sorted(cnt.items(), key=lambda kv: (-kv[1], str(kv[0]))):
    candidate.extend([item] * n)

mismatch = None
for i, (a, b) in enumerate(zip(candidate, dst), start=2):
    if a != b:
        mismatch = (i, a, b)
        break
print("Mismatch:", mismatch)

print("\nTop 20 source:", src[:20])
print("Top 20 desired:", dst[:20])
print("Top 20 candidate:", candidate[:20])

# Also test stable-by-first-appearance among ties
first_pos = {}
for i, x in enumerate(src):
    first_pos.setdefault(x, i)
candidate2 = []
for item, n in sorted(cnt.items(), key=lambda kv: (-kv[1], first_pos[kv[0]])):
    candidate2.extend([item] * n)

mismatch2 = None
for i, (a, b) in enumerate(zip(candidate2, dst), start=2):
    if a != b:
        mismatch2 = (i, a, b)
        break
print("\nMismatch for freq-desc + first appearance tie-break:", mismatch2)
print("Top 20 candidate2:", candidate2[:20])
