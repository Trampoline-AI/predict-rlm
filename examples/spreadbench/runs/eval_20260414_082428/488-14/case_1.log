import os
from collections import Counter
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook and inspect exact target cells before writing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]
ref = wb["Desired Results"]

print("Original sheet names:", orig_sheetnames)
print("Target sheet:", ws.title)
print("Target header A1:", ws["A1"].value)
print("Current Sheet1 A2:A15:", [ws[f"A{i}"].value for i in range(2, 16)])
print("Current Sheet1 A81:A85:", [ws[f"A{i}"].value for i in range(81, 86)])
print("Reference Desired Results A2:A15:", [ref[f"A{i}"].value for i in range(2, 16)])
print("Reference Desired Results A81:A85:", [ref[f"A{i}"].value for i in range(81, 86)])

# Read actual data extent from Sheet1 column A excluding header
data_rows = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v not in (None, ""):
        data_rows.append((r, v))

values = [v for _, v in data_rows]
counts = Counter(values)

sorted_values = []
for item, n in sorted(counts.items(), key=lambda kv: (-kv[1], str(kv[0]))):
    sorted_values.extend([item] * n)

print("Non-empty data row count:", len(values))
print("Unique counts:", sorted(counts.items(), key=lambda kv: (-kv[1], str(kv[0]))))
print("First 20 sorted output values:", sorted_values[:20])
print("Last 10 sorted output values:", sorted_values[-10:])

# Write back only across the actual populated rows in Sheet1 column A
for idx, (r, _) in enumerate(data_rows):
    ws.cell(r, 1).value = sorted_values[idx]

# Preserve any rows beyond actual data as-is unless they are part of data_rows only
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc, fix sheet names if needed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames)
    # Rename sheets back by position
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Sheet names restored:", load_workbook(outfile).sheetnames)
else:
    print("Sheet names preserved after recalc.")

# Verify output values
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]
refv = wb_verify["Desired Results"]

out_vals = [wsv.cell(r, 1).value for r in range(2, 2 + len(sorted_values))]
ref_vals = [refv.cell(r, 1).value for r in range(2, 2 + len(sorted_values))]

print("Verified Sheet1 A2:A15:", out_vals[:14])
print("Verified Sheet1 A81:A85:", out_vals[-5:])
print("Reference A2:A15:", ref_vals[:14])
print("Reference A81:A85:", ref_vals[-5:])
print("Output matches reference exactly?:", out_vals == ref_vals)
print("Any blanks in target output?:", any(v in (None, "") for v in out_vals))

final_output_path = outfile
