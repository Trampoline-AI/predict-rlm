import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally to write formulas
wb = load_workbook(input_path)
orig_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print current target area before writing
print("Before writing:")
for r in range(6, 14):
    print(r, "B=", ws[f"B{r}"].value, "E=", ws[f"E{r}"].value)

# Write formulas to the exact target range E6:E13
for r in range(6, 14):
    ws[f"E{r}"] = f'=IF(ISNUMBER(SEARCH("deposit",B{r})),"Revenue",IF(ISNUMBER(SEARCH("withdrawal",B{r})),"Expenses",""))'

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload after recalculation, check/restore original sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    # rename by position to match originals
    for i, old_name in enumerate(orig_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_names)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[orig_names[0]]
print("\nFormulas in E6:E13:")
for r in range(6, 14):
    print(f"E{r} =", wsf[f"E{r}"].value)

# Verify evaluated results
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values[orig_names[0]]
print("\nEvaluated values in E6:E13:")
verified = []
for r in range(6, 14):
    row_info = (f"B{r}", wsv[f"B{r}"].value, f"E{r}", wsv[f"E{r}"].value)
    verified.append(row_info)
    print(row_info)

# Basic sanity checks
all_nonblank = all(wsv[f"E{r}"].value not in (None, "") for r in range(6, 14))
