expected_pairs = []
for r in range(6, 14):
    b = str(wsv[f"B{r}"].value).strip().lower() if wsv[f"B{r}"].value is not None else ""
    e = wsv[f"E{r}"].value
    expected_pairs.append((r, b, e))
