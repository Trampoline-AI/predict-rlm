from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
print("Input:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def display(v):
    if v is None:
        return None
    try:
        return v.text  # for ArrayFormula-like objects
    except Exception:
        return v

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find likely header row among first few rows: row with most non-empty cells
    best_row = 1
    best_count = -1
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        count = sum(v not in (None, "") for v in vals)
        if count > best_count:
            best_count = count
            best_row = r
    headers = [display(ws.cell(best_row, c).value) for c in range(1, ws.max_column + 1)]
    print("Likely header row:", best_row)
    print("Headers:", headers)
    
    # Print first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print("-- First rows --")
    for r in range(1, first_n + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    
    print("-- Last rows --")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, row_vals)

