import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Determine actual rows needing output: rows with MRN in column A
target_rows = [r for r in range(2, ws.max_row + 1) if ws[f"A{r}"].value not in (None, "")]
print("Target rows:", target_rows)

# Print existing target cells before modification
print("Before write:")
for r in target_rows:
    print(r, {"A": ws[f"A{r}"].value, "C": ws[f"C{r}"].value})

# Write formula into column C only, matching the header "Y-U"
# Blank on no match or missing values.
for r in target_rows:
    formula = f'=IFERROR(INDEX($Y$2:$Y$124,MATCH($A{r},$Q$2:$Q$124,0))-INDEX($U$2:$U$124,MATCH($A{r},$Q$2:$Q$124,0)),"")'
    ws[f"C{r}"] = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring to", orig_sheet_names)
    # rename sheets positionally
    for i, original_name in enumerate(orig_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)

# Verification with formulas
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("\nWritten formulas in C2:C15:")
for r in target_rows:
    print(f"C{r} =", ws_formula[f"C{r}"].value)

# Verification with cached results
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]
print("\nVerified values in target cells:")
for r in target_rows:
    print(
        r,
        {
            "A": ws_values[f"A{r}"].value,
            "C": ws_values[f"C{r}"].value,
            "Qmatch_same_row": ws_values[f"Q{r}"].value,
            "U_same_row": ws_values[f"U{r}"].value,
            "Y_same_row": ws_values[f"Y{r}"].value,
        }
    )

# Sanity checks
blank_targets = [r for r in target_rows if ws_formula[f"C{r}"].value in (None, "")]
print("\nBlank formula targets:", blank_targets)
print("Output sheet names:", wb_values.sheetnames)

final_output_path = output_path
