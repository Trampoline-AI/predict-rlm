```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original input to avoid carrying forward the bad formula results
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

target_rows = [r for r in range(2, ws.max_row + 1) if ws[f"A{r}"].value not in (None, "")]
print("Target rows:", target_rows)

# Show current source situation for targets
print("\nPre-write source check:")
for r in target_rows:
    print(r, {
        "A": ws[f"A{r}"].value,
        "Q_same_row": ws[f"Q{r}"].value,
        "U_same_row": ws[f"U{r}"].value,
        "Y_same_row": ws[f"Y{r}"].value,
        "C_before": ws[f"C{r}"].value
    })

# Correct formula:
# - Find MRN from A in Q
# - If matched Y is blank, return blank
# - Else return Y-U
# - If no match, return blank
for r in target_rows:
    ws[f"C{r}"] = (
        f'=IFERROR('
        f'IF(INDEX($Y$2:$Y$124,MATCH($A{r},$Q$2:$Q$124,0))="",'
        f'"",'
        f'INDEX($Y$2:$Y$124,MATCH($A{r},$Q$2:$Q$124,0))-INDEX($U$2:$U$124,MATCH($A{r},$Q$2:$Q$124,0))'
        f'),'
        f'"")'
    )

wb.save(output_path)
print("\nSaved corrected workbook to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Restore original sheet names if recalc changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Renaming sheets back:", wb_after.sheetnames, "->", orig_sheet_names)
    for i, nm in enumerate(orig_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = nm
    wb_after.save(output_path)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("\nFormula strings in C2:C15:")
for r in target_rows:
    print(f"C{r}:", ws_formula[f"C{r}"].value)

# Verify cached results after recalculation
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerified output values in C2:C15:")
for r in target_rows:
    print(r, {
        "A": ws_values[f"A{r}"].value,
        "C": ws_values[f"C{r}"].value,
        "U_same_row": ws_values[f"U{r}"].value,
        "Y_same_row": ws_values[f"Y{r}"].value
    })

# Focused sanity checks
bad_nonblank = []
for r in target_rows:
    c = ws_values[f"C{r}"].value
    y = ws_values[f"Y{r}"].value
    if y in (None, "") and c not in (None, ""):
        bad_nonblank.append((r, c))

print("\nRows where Y is blank but C is not blank (should be none):", bad_nonblank)
print("Output sheet names:", wb_values.sheetnames)

final_output_path = output_path
```
