        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, vals)
    
    # Last 5 rows
    start_last = max(1, max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, vals)
    
    # Find formulas / non-empty cells
    formula_cells = []
    nonempty_count = 0
    for r in range(1, max_row + 1):
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if v is not None:
                nonempty_count += 1
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((r, c, v))
    print("Non-empty cells:", nonempty_count)
    print("Formula cells:", formula_cells[:20], "... total", len(formula_cells))

for ws in wb.worksheets:
