import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally to write formulas
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify intended target range again compactly
print("Writing target range C4:F6")
for r in range(4, 7):
    vals = [ws.cell(r, c).value for c in range(2, 7)]
    print(f"row {r} B:F ->", vals)

# Helper: source lookup in Python for verification of existing/sample values
source_map = {}
for r in range(3, 23):
    key1 = ws[f"I{r}"].value
    key2 = ws[f"J{r}"].value
    val = ws[f"K{r}"].value
    if key1 is not None and key2 is not None:
        source_map[(key1, key2)] = val

# Fill only blanks in C4:F6; preserve existing example values
written = []
preserved = []
for r in range(4, 7):
    row_key = ws.cell(r, 2).value   # B
    for c in range(3, 7):
        col_key = ws.cell(3, c).value  # row 3
        cell = ws.cell(r, c)
        expected = source_map.get((row_key, col_key))
        current = cell.value
        if current is None or current == "":
            formula = f'=INDEX($K$3:$K$22, MATCH(1, ($I$3:$I$22=$B{r})*($J$3:$J$22={get_column_letter(c)}$3), 0))'
            cell.value = formula
            written.append((cell.coordinate, formula, expected))
        else:
            preserved.append((cell.coordinate, current, expected))

print("Preserved existing cells:", preserved)
print("Written formulas:")
for item in written:
    print(item)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if LibreOffice changed them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names:
    # rename by position to original names
    for idx, orig_name in enumerate(orig_sheet_names):
        if idx < len(wb_post.worksheets):
            wb_post.worksheets[idx].title = orig_name
    wb_post.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

verification = []
for r in range(4, 7):
    row_key = wsv.cell(r, 2).value
    for c in range(3, 7):
        col_key = wsv.cell(3, c).value
        val = wsv.cell(r, c).value
        expected = source_map.get((row_key, col_key))
        verification.append((wsv.cell(r, c).coordinate, row_key, col_key, val, expected))

print("Verification C4:F6:")
for item in verification:
    print(item)

# Also inspect formulas from non-data_only workbook in target cells
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("Target formulas/values in formula view:")
for r in range(4, 7):
    print([(wsf.cell(r,c).coordinate, wsf.cell(r,c).value) for c in range(3,7)])

# Basic sanity check
all_ok = True
for coord, row_key, col_key, val, expected in verification:
    if val != expected:
        all_ok = False
        print("Mismatch:", coord, row_key, col_key, "got", val, "expected", expected)

print("All target cells match expected:", all_ok)

final_output_path = output_path
```
