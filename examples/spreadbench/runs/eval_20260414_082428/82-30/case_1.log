import os
from openpyxl import load_workbook

# Load fresh workbook
infile = input_spreadsheet
wb = load_workbook(infile)
raw_ws = wb["Raw Data"]
num_ws = wb["Numbers"]
manual_ws = wb["Manual Result"]

# Extract whole numbers by scanning columns A:F left-to-right, top-to-bottom
extracted = []
for c in range(1, 7):
    for r in range(1, raw_ws.max_row + 1):
        v = raw_ws.cell(r, c).value
        if v is None:
            continue
        if isinstance(v, bool):
            continue
        if isinstance(v, int):
            extracted.append(v)
        elif isinstance(v, float) and float(v).is_integer():
            extracted.append(int(v))

wrapped = [extracted[i:i+6] for i in range(0, len(extracted), 6)]

print("Extracted whole numbers count:", len(extracted))
print("First 20 extracted:", extracted[:20])
print("Wrapped rows for Numbers:")
for i, row in enumerate(wrapped, start=1):
    print(i, row)

# Compare against Manual Result first 9 rows x 6 cols
manual_first6 = []
for r in range(1, manual_ws.max_row + 1):
    manual_first6.append([manual_ws.cell(r, c).value for c in range(1, 7)])

print("\nManual Result first 6 cols:")
for i, row in enumerate(manual_first6, start=1):
    print(i, row)

# Clear relevant area in Numbers (enough to cover old/new values)
clear_rows = max(num_ws.max_row, len(wrapped) + 5)
for r in range(1, clear_rows + 1):
    for c in range(1, 7):
        num_ws.cell(r, c).value = None

# Write output to Numbers A:F
for r_idx, row in enumerate(wrapped, start=1):
    for c_idx, val in enumerate(row, start=1):
        num_ws.cell(r_idx, c_idx).value = val

# Save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalc; restore sheet names if needed
wb2 = load_workbook(outfile)
orig_names = ["Raw Data", "Numbers", "Manual Result"]
if wb2.sheetnames != orig_names:
    print("Sheet names after recalc:", wb2.sheetnames)
    # Rename sheets back by position if needed
    for i, expected in enumerate(orig_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Renamed sheets back to:", wb2.sheetnames)

# Verify with data_only workbook
verify_wb = load_workbook(outfile, data_only=True)
verify_num = verify_wb["Numbers"]

print("\nVerified Numbers!A1:F12")
for r in range(1, 13):
    vals = [verify_num.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

# Also verify exact intended rows count
print("\nExpected rows written:", len(wrapped))
print("Last written row values:", [verify_num.cell(len(wrapped), c).value for c in range(1, 7)])

output_spreadsheet = outfile
```
