import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers row1:", headers)
    # print first up to 10 rows and last 5 rows, bounded
    first_n = min(10, max_row)
    print("First rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(r, vals)
    if max_row > 10:
        print("Last rows:")
        start = max(1, max_row-4)
        for r in range(start, max_row+1):
            vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
            print(r, vals)

for s in wb.sheetnames:
    sheet_info(wb[s])

# Inspect specific mentioned sheets/ranges with concise targeted printing
for s in ["Raw Data", "Numbers", "Manual Result"]:
    if s in wb.sheetnames:
        ws = wb[s]
        print(f"\nDetailed preview for {s}:")
        mr = ws.max_row
        mc = ws.max_column
        # first 15 rows of first 8 cols
        for r in range(1, min(15, mr)+1):
            vals = [ws.cell(r, c).value for c in range(1, min(8, mc)+1)]
            print(r, vals)

        # formulas / existing values in first 30 rows first 8 cols
        found_formula = False
        for r in range(1, min(30, mr)+1):
            for c in range(1, min(8, mc)+1):
                v = ws.cell(r, c).value
                if isinstance(v, str) and v.startswith("="):
                    print(f"Formula at {s}!{get_column_letter(c)}{r}: {v}")
                    found_formula = True
        if not found_formula:
            print("No formulas found in first 30 rows / 8 cols.")

# Save some references for later
raw_ws = wb["Raw Data"] if "Raw Data" in wb.sheetnames else None
numbers_ws = wb["Numbers"] if "Numbers" in wb.sheetnames else None
manual_ws = wb["Manual Result"] if "Manual Result" in wb.sheetnames else None
