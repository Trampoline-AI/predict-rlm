outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Keep original structure and explicit formatting instructions
ws.sheet_view.showGridLines = False

target_last_row = 38
yellow_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")

# Helper to preserve existing style while swapping font name
def set_calibri(cell):
    old_font = cell.font
    try:
        cell.font = copy(old_font)
        # openpyxl style objects are immutable-ish; rebuild font with same attrs
        cell.font = Font(
            name="Calibri",
            sz=old_font.sz,
            b=old_font.b,
            i=old_font.i,
            charset=old_font.charset,
            u=old_font.u,
            strike=old_font.strike,
            color=old_font.color.type == 'rgb' and old_font.color.rgb or old_font.color.indexed if old_font.color else None,
            vertAlign=old_font.vertAlign,
            outline=old_font.outline,
            shadow=old_font.shadow,
            condense=old_font.condense,
            extend=old_font.extend,
            family=old_font.family,
            scheme=old_font.scheme,
        )
    except Exception:
        cell.font = Font(name="Calibri", size=old_font.sz, bold=old_font.bold, italic=old_font.italic)

# Recreate formulas in B exactly through row 36, with row 37/38 blank in B
for r in range(7, 37):
    ws[f"B{r}"] = f'=IF($B$3+ROWS($B$7:$B{r})-1<=$F$3,$B$3+ROWS($B$7:$B{r})-1,"")'
    ws[f"B{r}"].number_format = "mm-dd-yy"
for r in [37, 38]:
    ws[f"B{r}"] = None
    ws[f"B{r}"].number_format = "mm-dd-yy"

# Recreate formulas in D exactly as pattern shown in original Sheet1
for r in range(7, target_last_row + 1):
    end_ref = r + 31
    ws[f"D{r}"] = f'=IF($B$3+ROWS($B$7:$D{end_ref})-1<=$F$3,$B$3+ROWS($B$7:$D{end_ref})-1,"")'
    ws[f"D{r}"].number_format = "mm-dd-yy"

# Recreate formulas in F exactly as pattern shown in original Sheet1
for r in range(7, target_last_row + 1):
    end_ref = r + 31
    if r == 7:
        formula = '=IF($B$3+ROWS($D$7:$F38)-1<=$F$3,$B$3+ROWS($D$7:$F38)-1,"")'
    else:
        formula = f'=IF($B$3+ROWS($B$7:$F{end_ref})-1<=$F$3,$B$3+ROWS($B$7:$F{end_ref})-1,"")'
    ws[f"F{r}"] = formula
    ws[f"F{r}"].number_format = "mm-dd-yy"

# Corrected WORKDAY formulas in H7:H38 only.
# This returns the nth workday from B3, excluding holidays in J5:J7, and blanks after 11/2/2021.
for r in range(7, target_last_row + 1):
    formula = (
        f'=IF(WORKDAY($B$3-1,ROWS($H$7:H{r}),$J$5:$J$7)<=DATE(2021,11,2),'
        f'WORKDAY($B$3-1,ROWS($H$7:H{r}),$J$5:$J$7),"")'
    )
    ws[f"H{r}"] = formula
    ws[f"H{r}"].number_format = "mm-dd-yy"
    ws[f"H{r}"].fill = yellow_fill

# Enforce Calibri throughout used range A1:J38
for r in range(1, target_last_row + 1):
    for c in range(1, ws.max_column + 1):
        set_calibri(ws.cell(r, c))

wb.save(outfile)
print("Saved corrected file:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Restore original sheet names if needed
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    for i, orig in enumerate(orig_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = orig
    wb_post.save(outfile)
    print("Restored sheet names:", wb_post.sheetnames)

# Verification
wbf = load_workbook(outfile, data_only=False)
wbd = load_workbook(outfile, data_only=True)
wsf = wbf["Sheet1"]
wsd = wbd["Sheet1"]

print("Verify max_row/max_col:", wsf.max_row, wsf.max_column)
print("Verify gridlines:", wsf.sheet_view.showGridLines)

for coord in ["B7","B36","B37","D7","D38","F7","F38","H7","H15","H38","J5","J6","J7"]:
    print(coord, "formula=", wsf[coord].value, "cached=", wsd[coord].value)

print("Verify H cached values first 10 rows:")
for r in range(7, 17):
    print(r, wsd[f"H{r}"].value)

print("Verify H cached values last 5 rows:")
for r in range(34, 39):
    print(r, wsd[f"H{r}"].value)

print("Verify yellow fills and fonts in H7:H38 sample:")
for r in [7, 20, 38]:
    cell = wsf[f"H{r}"]
    fill = cell.fill.fgColor.rgb if cell.fill and cell.fill.fill_type else None
    print(r, fill, cell.number_format, cell.font.name)

output_spreadsheet = outfile
