import os, shutil
from copy import copy
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load source workbook
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Main"]
lk = wb["Lookup"]

# Build lookup map from Lookup sheet
lookup_map = {}
for r in range(2, lk.max_row + 1):
    emp_id = lk.cell(r, 1).value
    weeks = lk.cell(r, 2).value
    lookup_map[emp_id] = weeks

# Capture header and basic styles from existing sheet
header = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]

# Save original row styles/dimensions references where possible
col_dimensions_snapshot = {}
for key, dim in ws.column_dimensions.items():
    col_dimensions_snapshot[key] = {
        "width": dim.width,
        "hidden": dim.hidden,
        "bestFit": dim.bestFit,
        "style": dim.style,
        "min": dim.min,
        "max": dim.max,
    }

# Build transformed rows
# We'll store only values for A:H; I:M will be regenerated/written explicitly.
kept_rows = []
deleted_count = 0
inserted_blank_rows = 0
motorcycle_deleted = 0
ahmed_canada_deleted = 0
ntv_india_updated = 0
remaining_ahmed_rows = 0

for r in range(2, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    company = row_vals[0]
    location = row_vals[1]

    delete_row = False
    if company == "Motorcycle":
        delete_row = True
        motorcycle_deleted += 1
    elif company == "Ahmed Sons" and location == "Canada":
        delete_row = True
        ahmed_canada_deleted += 1

    if delete_row:
        deleted_count += 1
        continue

    # Update bill rate for National TV / India
    if company == "National TV" and location == "India":
        row_vals[6] = 180
        ntv_india_updated += 1

    kept_rows.append(row_vals)

    # Insert two blank rows after each remaining Ahmed Sons row
    if company == "Ahmed Sons":
        remaining_ahmed_rows += 1
        blank = [None] * ws.max_column
        kept_rows.append(blank[:])
        kept_rows.append(blank[:])
        inserted_blank_rows += 2

print("Transformation summary before writing:")
print({
    "original_data_rows": ws.max_row - 1,
    "deleted_total": deleted_count,
    "motorcycle_deleted": motorcycle_deleted,
    "ahmed_canada_deleted": ahmed_canada_deleted,
    "remaining_ahmed_rows": remaining_ahmed_rows,
    "inserted_blank_rows": inserted_blank_rows,
    "ntv_india_updated": ntv_india_updated,
    "final_data_rows": len(kept_rows),
})

# Clear existing data rows only (keep sheet and header)
for r in range(2, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Write header explicitly (preserve same)
for c, val in enumerate(header, start=1):
    ws.cell(1, c).value = val

# Write transformed rows
for out_r, row_vals in enumerate(kept_rows, start=2):
    is_blank_inserted = all(v is None for v in row_vals)

    # Write A:H as values
    for c in range(1, 9):
        ws.cell(out_r, c).value = row_vals[c-1]

    if not is_blank_inserted:
        # Regenerate formulas in I:L based on current row number
        ws.cell(out_r, 9).value  = f"=G{out_r}*H{out_r}"
        ws.cell(out_r, 10).value = f"=G{out_r}-30"
        ws.cell(out_r, 11).value = f"=J{out_r}*H{out_r}"
        ws.cell(out_r, 12).value = f"=I{out_r}-K{out_r}"

        emp_id = row_vals[2]
        ws.cell(out_r, 13).value = lookup_map.get(emp_id)
    else:
        # Keep inserted rows fully blank including formulas/lookups
        for c in range(9, 14):
            ws.cell(out_r, c).value = None

# If worksheet still has old trailing rows beyond final used area, blank them
final_last_row = len(kept_rows) + 1
for r in range(final_last_row + 1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Restore column dimensions
for key, attrs in col_dimensions_snapshot.items():
    dim = ws.column_dimensions[key]
    dim.width = attrs["width"]
    dim.hidden = attrs["hidden"]
    dim.bestFit = attrs["bestFit"]
    dim.style = attrs["style"]

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb2 = load_workbook(output_path)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring to", orig_sheet_names)
    for idx, desired in enumerate(orig_sheet_names):
        wb2.worksheets[idx].title = desired
    wb2.save(output_path)
else:
    print("Sheet names preserved:", wb2.sheetnames)

# Verification with data_only=True
ver = load_workbook(output_path, data_only=True)
vws = ver["Main"]

# Gather verification data
all_rows = [
    [vws.cell(r, c).value for c in range(1, 14)]
    for r in range(2, vws.max_row + 1)
    if any(vws.cell(r, c).value is not None for c in range(1, 14))
]

remaining_ahmed_canada = []
remaining_motorcycle = []
ntv_india_rates = []
lookup_blanks = []
inserted_blank_row_count = 0

for r in range(2, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, 14)]
    company = vals[0]
    location = vals[1]
    emp_id = vals[2]
    rate = vals[6]
    mval = vals[12]

    if company == "Motorcycle":
        remaining_motorcycle.append((r, vals[:7]))
    if company == "Ahmed Sons" and location == "Canada":
        remaining_ahmed_canada.append((r, vals[:7]))
    if company == "National TV" and location == "India":
        ntv_india_rates.append((r, rate, emp_id))
    if company is not None and mval is None:
        lookup_blanks.append((r, emp_id, company, location))
    if all(v is None for v in vals):
        inserted_blank_row_count += 1

print("\nVerification summary:")
print("Sheet names:", ver.sheetnames)
print("Main max_row/max_column:", vws.max_row, vws.max_column)
print("Remaining Motorcycle rows:", remaining_motorcycle)
print("Remaining Ahmed Sons Canada rows:", remaining_ahmed_canada)
print("National TV India rates:", ntv_india_rates)
print("Nonblank rows with blank Column M:", lookup_blanks[:20], "count:", len(lookup_blanks))
print("Count of completely blank rows present within used range:", inserted_blank_row_count)

print("\nFirst 25 rows A:M after transformation:")
for r in range(1, min(vws.max_row, 25) + 1):
    print(r, [vws.cell(r, c).value for c in range(1, 14)])

print("\nLast 15 rows A:M after transformation:")
