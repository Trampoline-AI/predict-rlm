import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook normally
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target area and relevant rows
print("Original sheet names:", original_sheetnames)
print("Target headers H:J:", [ws.cell(1, c).value for c in range(8, 11)])

# Detect Table 1 rows: rows with student id in A and visit date in C
table1_rows = []
for r in range(2, ws.max_row + 1):
    sid = ws.cell(r, 1).value
    vdate = ws.cell(r, 3).value
    if sid is not None and vdate is not None:
        table1_rows.append(r)

# Detect Table 2 rows: rows with student id in H and submission date in I
table2_rows = []
for r in range(2, ws.max_row + 1):
    sid = ws.cell(r, 8).value
    sdate = ws.cell(r, 9).value
    if sid is not None and sdate is not None:
        table2_rows.append(r)

print("Table1 rows:", table1_rows)
print("Table2 rows:", table2_rows)

# Build visits by student
visits_by_student = {}
for r in table1_rows:
    sid = ws.cell(r, 1).value
    vdate = ws.cell(r, 3).value
    visits_by_student.setdefault(sid, []).append(vdate)

for sid in visits_by_student:
    visits_by_student[sid] = sorted(visits_by_student[sid])

# Inspect existing target values before overwrite
print("Existing J target cells before write:")
for r in table2_rows:
    print(f"J{r} =", ws.cell(r, 10).value, "number_format:", ws.cell(r, 10).number_format)

# Use number format from Table 1 visit date column if available
source_date_format = ws["C2"].number_format if ws["C2"].number_format else "DD-MMM-YY"

# Populate J with the immediately prior visit date for each student
written = {}
for r in table2_rows:
    sid = ws.cell(r, 8).value
    submission_date = ws.cell(r, 9).value
    prior = None
    if sid in visits_by_student and submission_date is not None:
        candidates = [d for d in visits_by_student[sid] if d < submission_date]
        prior = max(candidates) if candidates else None
    
    ws.cell(r, 10).value = prior
    ws.cell(r, 10).number_format = source_date_format
    written[r] = prior

print("Written target values:")
for r, v in written.items():
    print(f"J{r} =", v)

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for idx, expected_name in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = expected_name
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify with data_only=True
