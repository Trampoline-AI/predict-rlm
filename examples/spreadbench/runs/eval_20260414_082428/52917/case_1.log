import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find a likely header row among first few rows by most non-empty cells
    candidate_rows = []
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v is not None and v != "" for v in vals)
        candidate_rows.append((nonempty, r, vals))
    candidate_rows.sort(reverse=True)
    header_row = candidate_rows[0][1] if candidate_rows else 1
    headers = row_values(ws, header_row, ws.max_column)
    print("Likely header row:", header_row)
    print("Headers:", headers)
    
    # Print first 10 rows and last 5 rows
    first_n = min(10, ws.max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # Since instruction references A, B, C, J, print those specifically
    print("Column letters present through J:", [get_column_letter(c) for c in range(1, min(ws.max_column, 10)+1)])
    for col in ["A", "B", "C", "J"]:
        idx = column_index_from_string(col)
        if idx <= ws.max_column:
            vals = [ws[f"{col}{r}"].value for r in range(1, min(ws.max_row, 12)+1)]
            print(f"{col}1:{col}{min(ws.max_row,12)} ->", vals)
        else:
            print(f"Column {col} not present in this sheet")

    # Print formulas / current values in J for all used rows if not too many
    if ws.max_column >= 10:
        j_samples = []
