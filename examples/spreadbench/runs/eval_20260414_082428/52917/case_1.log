import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload workbook for modification
wb = load_workbook(input_path)
ws = wb["whole date"]

# Inspect existing target pattern in column J
print("Existing J values and formats:")
for r in range(1, ws.max_row + 1):
    print(r, ws[f"J{r}"].value, ws[f"J{r}"].number_format)

# Determine rows needing output: rows with A/B/C data and blank J
rows_written = []
for r in range(2, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    j = ws[f"J{r}"].value
    if a not in (None, "") and b not in (None, "") and c not in (None, "") and j in (None, ""):
        ws[f"J{r}"] = f"=DATE(C{r},B{r},A{r})"
        # Match format from existing examples if available
        ws[f"J{r}"].number_format = ws["J2"].number_format
        rows_written.append(r)

print("Rows written in J:", rows_written)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check if sheet names changed after recalc; rename back if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
original_sheet_names = ["whole date"]
if wb_after.sheetnames != original_sheet_names and len(wb_after.sheetnames) == len(original_sheet_names):
    for idx, sname in enumerate(original_sheet_names):
        wb_after.worksheets[idx].title = sname
    wb_after.save(output_path)
    print("Renamed sheets back to original:", wb_after.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["whole date"]

print("Verified target cells J1:J9 after recalc:")
for r in range(1, wsv.max_row + 1):
    print(f"J{r} =", wsv[f'J{r}'].value)

# Additional exact formula verification from formula workbook
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["whole date"]
print("Formulas/values in J2:J9:")
for r in range(2, wsf.max_row + 1):
    print(f"J{r} formula/value =", wsf[f'J{r}'].value)

final_output_path = output_path
