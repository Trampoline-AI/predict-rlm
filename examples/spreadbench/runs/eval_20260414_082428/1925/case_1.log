# Write dynamic formulas into the exact target cells C6:C31.
# Match date in Sheet1!C5 against Sheet2!$C$5:$M$5, then use INDEX to pick that whole column slice C6:M23.
# Then MATCH the item from column B within that selected column. If not found, return "NEW".
for r in range(6, ws1.max_row + 1):
    item_cell = f"$B{r}"
    formula = (
        '=IFERROR('
        f'INDEX(Sheet2!$C$6:$M$23,'
        f'MATCH({item_cell},INDEX(Sheet2!$C$6:$M$23,0,MATCH($C$5,Sheet2!$C$5:$M$5,0)),0),'
        f'MATCH($C$5,Sheet2!$C$5:$M$5,0)'
        '),'
        '"NEW"'
        ')'
    )
    ws1[f"C{r}"] = formula

print("\nNew Sheet1 formulas C6:C10:")
