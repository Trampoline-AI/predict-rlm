import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def nonempty_headers(ws, header_row=1, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc+1):
        v = ws.cell(header_row, c).value
        if v is not None:
            vals.append((c, get_column_letter(c), v))
    return vals

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n--- Sheet: {s} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # print first 10 rows x all used columns (capped at 12 if very wide)
    maxc = ws.max_column
    print("Row 1 non-empty headers:", nonempty_headers(ws, 1, maxc))
    if ws.max_row >= 5:
        print("Row 5 non-empty cells:", [(get_column_letter(c), ws.cell(5,c).value) for c in range(1, maxc+1) if ws.cell(5,c).value is not None])
    sample_rows = list(range(1, min(ws.max_row, 10)+1))
    if ws.max_row > 10:
        sample_rows += list(range(max(1, ws.max_row-4), ws.max_row+1))
    seen = set()
    for r in sample_rows:
        if r in seen: 
            continue
        seen.add(r)
        vals = [ws.cell(r,c).value for c in range(1, maxc+1)]
        print(f"Row {r}:", vals)

# inspect specifically mentioned cells and nearby ranges
for sheet_name, cells in {
    "Sheet1": ["B6","C5","A1","A5","B5","C6","D6","E6","F6"],
    "Sheet2": ["F5","F6","A5","B5","C5","D5","E5","G5"]
}.items():
    if sheet_name in wb.sheetnames:
        ws = wb[sheet_name]
        print(f"\nSpecific cells in {sheet_name}:")
        for cell in cells:
            print(cell, "=", ws[cell].value)

# inspect formulas / used area around Sheet1 rows 1-20, cols A-H
if "Sheet1" in wb.sheetnames:
    ws1 = wb["Sheet1"]
    print("\nSheet1 A1:H20 detailed:")
    for r in range(1, min(20, ws1.max_row)+1):
        print(r, [ws1.cell(r,c).value for c in range(1, min(8, ws1.max_column)+1)])

if "Sheet2" in wb.sheetnames:
    ws2 = wb["Sheet2"]
    print("\nSheet2 row 5 across used columns:")
