```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target/source cells before writing
print("Before writing:")
for r in range(1, 6):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value)

# Actual populated source rows in column B (excluding header)
source_start = 2
source_end = ws.max_row  # 5 here, but use actual extent
target_rows = [2, 3, 4]  # instruction explicitly says C2:C4

# Build formulas that return the nth item in B excluding $A$2, preserving order.
# Use COUNTIF over prior output cells so each next formula returns the next unique occurrence in order.
# This pattern is a classic non-dynamic Excel formula.
for r in target_rows:
    prior_end = r - 1
    formula = (
        f'=IFERROR(INDEX($B${source_start}:$B${source_end},'
        f'MATCH(0,INDEX(COUNTIF($C$1:C{prior_end},$B${source_start}:$B${source_end})'
        f'+($B${source_start}:$B${source_end}=$A$2),0),0)),"")'
    )
    print(f"Writing C{r} formula:", formula)
    ws[f"C{r}"] = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    for i, old_name in enumerate(orig_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas and evaluated values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("Stored formulas in C2:C4:")
for r in target_rows:
    print(f"C{r} formula:", ws_formula[f"C{r}"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Evaluated values in C2:C4:")
for r in target_rows:
    print(f"C{r} value:", ws_values[f'C{r}'].value)

# Keep output path for submission
final_output_path = output_path
```
