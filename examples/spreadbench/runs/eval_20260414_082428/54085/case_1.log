import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
print("Input path:", input_path)
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def display_row(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    vals = [ws.cell(r, c).value for c in range(1, max_cols+1)]
    return vals

sheet_info = {}
for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = display_row(ws, 1)
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row2 values:", display_row(ws, 2))
    # first up to 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, display_row(ws, r))
    # last 5 rows
    start_last = max(1, ws.max_row-4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, display_row(ws, r))
    # specifically inspect A:C cells around target
    print("Specific A:C values for rows 1-10:")
    for r in range(1, min(10, ws.max_row)+1):
        print(f"A{r}={ws[f'A{r}'].value!r}, B{r}={ws[f'B{r}'].value!r}, C{r}={ws[f'C{r}'].value!r}")
    sheet_info[ws.title] = {"max_row": ws.max_row, "max_column": ws.max_column}

print("\nDone inspection.")
