import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Reload fresh workbook from input
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

TARGET1 = "OCOGS - Spares - Transfer Price Overhead"
TARGET2 = "OFSS - ORCL Consulting Prod Cost I/C"
AY_SET = {"BOA_033E", "BOA_011G"}
blue_fill = PatternFill(fill_type="solid", start_color="FF0070C0", end_color="FF0070C0")

modified_rows = []
all_lag_bn_rows = []

for r in range(2, ws.max_row + 1):
    ay = ws[f"AY{r}"].value
    bg = ws[f"BG{r}"].value
    bl = ws[f"BL{r}"].value
    current_bn = ws[f"BN{r}"].value

    new_bn = None
    if bl == "LAG" and bg in {TARGET1, TARGET2}:
        if ay in AY_SET:
            new_bn = TARGET1
        else:
            new_bn = TARGET2

    if new_bn is not None:
        if current_bn != new_bn:
            ws[f"BN{r}"] = new_bn
        ws[f"BL{r}"].fill = blue_fill
        modified_rows.append((r, ay, bg, bl, current_bn, new_bn))
        all_lag_bn_rows.append(r)

# Save
wb.save(output_path)
print("Saved to:", output_path)
print("Modified row count:", len(modified_rows))
print("Modified rows:", [x[0] for x in modified_rows])
print("First modifications sample:", modified_rows[:10])

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore sheet names if necessary
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names:
    # rename in order
    for i, old_name in enumerate(orig_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = old_name
    wb_post.save(output_path)
    print("Restored sheet names to:", wb_post.sheetnames)

# Verification with formulas/values cached
wb_val = load_workbook(output_path, data_only=True)
ws_val = wb_val["Sheet1"]
wb_fmt = load_workbook(output_path)
ws_fmt = wb_fmt["Sheet1"]

print("\nVerification of target cells:")
verification_rows = []
for r in range(2, ws_val.max_row + 1):
    bl = ws_val[f"BL{r}"].value
    bn = ws_val[f"BN{r}"].value
    ay = ws_val[f"AY{r}"].value
    bg = ws_val[f"BG{r}"].value
    if bl == "LAG" and bn is not None:
        fill = ws_fmt[f"BL{r}"].fill
        verification_rows.append({
            "row": r,
            "AY": ay,
            "BG": bg,
            "BL": bl,
            "BN": bn,
            "BL_fill_type": fill.fill_type,
            "BL_fill_rgb": getattr(fill.fgColor, "rgb", None)
        })

print("Rows with BL='LAG' and BN populated:", len(verification_rows))
for item in verification_rows:
    print(item)

# Additional sanity check: rows with BL='LAG' and qualifying BG should all have BN populated
missing_rows = []
for r in range(2, ws_val.max_row + 1):
    ay = ws_val[f"AY{r}"].value
    bg = ws_val[f"BG{r}"].value
    bl = ws_val[f"BL{r}"].value
    bn = ws_val[f"BN{r}"].value
    if bl == "LAG" and bg in {TARGET1, TARGET2} and bn is None:
        missing_rows.append(r)
print("Missing qualifying BN rows:", missing_rows)

# Keep output path for submit
final_output_spreadsheet = output_path
