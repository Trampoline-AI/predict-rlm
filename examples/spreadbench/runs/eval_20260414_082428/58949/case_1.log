from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from collections import defaultdict

# Reload and inspect exact target area before modifying
wb = load_workbook(input_spreadsheet)
ws_src = wb["Extract"]
ws_out = wb["Desired Result"]

print("Target sheet headers:")
headers = [ws_out.cell(1, c).value for c in range(1, ws_out.max_column + 1)]
print(headers)

print("\nCurrent Desired Result rows 2:5 before modification:")
for r in range(2, ws_out.max_row + 1):
    print(r, [ws_out.cell(r, c).value for c in range(1, ws_out.max_column + 1)])

# Build mapping from source
src_headers = [ws_src.cell(1, c).value for c in range(1, ws_src.max_column + 1)]
print("\nSource headers:", src_headers)

person_to_car_value = defaultdict(dict)
people_in_order = []
seen = set()
for r in range(2, ws_src.max_row + 1):
    person = ws_src.cell(r, 1).value
    car = ws_src.cell(r, 2).value
    value = ws_src.cell(r, 3).value
    if person not in seen:
        seen.add(person)
        people_in_order.append(person)
    person_to_car_value[person][car] = value

print("\nDerived mapping:")
for person in people_in_order:
    print(person, person_to_car_value[person])

# Verify output rows align with expected people
print("\nDesired Result person column before modification:")
for r in range(2, ws_out.max_row + 1):
    print(f"A{r} =", ws_out.cell(r, 1).value)

# Fill Desired Result based on existing header list
car_headers = headers[1:]  # B onward
for r in range(2, ws_out.max_row + 1):
    person = ws_out.cell(r, 1).value
    if person is None or person == "":
        continue
    car_map = person_to_car_value.get(person, {})
    for c in range(2, ws_out.max_column + 1):
        car = ws_out.cell(1, c).value
        current = ws_out.cell(r, c).value
        desired = car_map.get(car, "")
        # Preserve already-correct values; fill blanks / incorrect values with desired
        if current != desired:
            ws_out.cell(r, c).value = desired

print("\nDesired Result rows 2:5 after in-memory modification:")
for r in range(2, ws_out.max_row + 1):
    print(r, [ws_out.cell(r, c).value for c in range(1, ws_out.max_column + 1)])

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate as required
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
original_names = ["Extract", "Desired Result"]
if wb_check.sheetnames != original_names:
    # rename sheets back if needed by position
    for i, expected in enumerate(original_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(out_path)
    print("Renamed sheets back to:", wb_check.sheetnames)

# Verification with data_only
wb_verify = load_workbook(out_path, data_only=True)
ws_verify = wb_verify["Desired Result"]
print("\nVerified target range A1:I5 after save/recalc:")
for r in range(1, 6):
    print(r, [ws_verify.cell(r, c).value for c in range(1, 10)])
