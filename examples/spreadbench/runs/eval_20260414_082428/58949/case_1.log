from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

print("Instruction:")
print(instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    
    # Find first few non-empty rows
    nonempty_rows = []
    for r in range(1, min(ws.max_row, 30) + 1):
        vals = row_values(ws, r, min(ws.max_column, 20))
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("First non-empty rows:", nonempty_rows[:10])
    
    # Print first 10 rows up to 15 cols
    max_show_cols = min(ws.max_column, 15)
    print(f"First up to 10 rows (first {max_show_cols} cols):")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, max_show_cols))
    
    # Print last 5 rows
    print(f"Last 5 rows (first {max_show_cols} cols):")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        print(r, row_values(ws, r, max_show_cols))
    
    # Guess header row among first 5 rows by most non-empty cells
    best_r = None
    best_count = -1
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        cnt = sum(v is not None and v != "" for v in vals)
        if cnt > best_count:
            best_count = cnt
            best_r = r
    headers = row_values(ws, best_r, ws.max_column) if best_r else []
    print(f"Likely header row: {best_r}")
    print("Headers:", headers)
    
    # print formulas found in first 10x15 region
    formulas = []
    for r in range(1, min(ws.max_row, 15)+1):
        for c in range(1, min(ws.max_column, 15)+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Sample formulas in first region:", formulas[:10])
