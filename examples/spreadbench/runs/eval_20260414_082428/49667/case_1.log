import os, shutil
from datetime import datetime, time
from openpyxl import load_workbook

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
ws = wb["Edit"]
orig_sheet_names = wb.sheetnames[:]

start_col = 6   # F
end_col = 46    # AT

def parse_header_time(v):
    if isinstance(v, time):
        return v
    if isinstance(v, datetime):
        return v.time()
    if isinstance(v, str) and ":" in v:
        return datetime.strptime(v.strip(), "%H:%M").time()
    return None

slot_times = [parse_header_time(ws.cell(1, c).value) for c in range(start_col, end_col + 1)]

def get_blocks_for_row(r):
    vals = [ws.cell(r, c).value for c in range(start_col, end_col + 1)]
    m_idxs = [i for i, v in enumerate(vals) if isinstance(v, str) and v.strip().lower() == "m"]
    blocks = []
    if not m_idxs:
        return blocks
    s = m_idxs[0]
    prev = m_idxs[0]
    for i in m_idxs[1:]:
        if i == prev + 1:
            prev = i
        else:
            blocks.append((s, prev))
            s = i
            prev = i
    blocks.append((s, prev))
    return blocks

print("Compact block summary before writing:")
for r in range(2, ws.max_row + 1):
    blocks = get_blocks_for_row(r)
    summary = []
    for s, e in blocks:
        summary.append((ws.cell(1, start_col+s).value, ws.cell(1, start_col+e).value, e-s+1))
    print(r, ws.cell(r,1).value, "blocks=", summary, "existing B:E=", [ws.cell(r,c).value for c in range(2,6)])

# Write results to B:E based on first two contiguous 'm' blocks
for r in range(2, ws.max_row + 1):
    blocks = get_blocks_for_row(r)
    outputs = [None, None, None, None]
    if len(blocks) >= 1:
        s1, e1 = blocks[0]
        outputs[0] = slot_times[s1]
        outputs[1] = slot_times[e1]
    if len(blocks) >= 2:
        s2, e2 = blocks[1]
        outputs[2] = slot_times[s2]
        outputs[3] = slot_times[e2]
    for idx, c in enumerate(range(2, 6)):
        ws.cell(r, c).value = outputs[idx]
        ws.cell(r, c).number_format = "h:mm"

print("\nAfter writing (in-memory) B:E:")
for r in range(2, ws.max_row + 1):
    print(r, ws.cell(r,1).value, [ws.cell(r,c).value for c in range(2,6)])

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for ws2, orig_name in zip(wb2.worksheets, orig_sheet_names):
        ws2.title = orig_name
    wb2.save(out_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_sheet_names[0]]

print("\nVerification of target B:E for every data row:")
verification_rows = []
for r in range(2, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(2, 6)]
    verification_rows.append((r, wsv.cell(r,1).value, vals))
    print(r, wsv.cell(r,1).value, vals)

# Keep output path in a variable for submission
final_output_path = out_path
print("\nFinal output path ready:", final_output_path)
