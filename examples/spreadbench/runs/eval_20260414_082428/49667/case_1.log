    cand = []
    for b in blocks[:2]:
        cand.extend([b["start_header"], b["end_header"]])
    while len(cand) < 4:
        cand.append(None)
    actual = [ws.cell(r, c).value for c in range(2, 6)]
    print(r, ws.cell(r,1).value, "candidate", cand, "actual", actual)
