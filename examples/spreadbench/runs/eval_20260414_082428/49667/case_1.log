from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
from datetime import time

wb = load_workbook(input_spreadsheet)
ws = wb["Edit"]

start_col = column_index_from_string("F")
end_col = column_index_from_string("AT")
slot_headers = [ws.cell(1, c).value for c in range(start_col, end_col + 1)]

print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)
print("Headers A:AT:")
for c in range(1, end_col + 1):
    print(c, get_column_letter(c), ws.cell(1, c).value)

print("\nCheck existing formulas / values in B:E and formats:")
for r in range(2, ws.max_row + 1):
    vals = []
    for c in range(2, 6):
        cell = ws.cell(r, c)
        vals.append({
            "coord": cell.coordinate,
            "value": cell.value,
            "type": type(cell.value).__name__,
            "numfmt": cell.number_format,
        })
    print("Row", r, vals)

def contiguous_blocks(markers, headers):
    idxs = [i for i, v in enumerate(markers) if isinstance(v, str) and v.lower() == "m"]
    blocks = []
    if not idxs:
        return blocks
    s = idxs[0]
    prev = idxs[0]
    for i in idxs[1:]:
        if i == prev + 1:
            prev = i
        else:
            blocks.append((s, prev))
            s = i
            prev = i
    blocks.append((s, prev))
    out = []
    for s, e in blocks:
        out.append({
            "start_idx": s,
            "end_idx": e,
            "start_col": get_column_letter(start_col + s),
            "end_col": get_column_letter(start_col + e),
            "start_header": headers[s],
            "end_header": headers[e],
            "length": e - s + 1,
        })
    return out

print("\nDetailed row analysis:")
for r in range(2, ws.max_row + 1):
    name = ws.cell(r, 1).value
    outputs = [ws.cell(r, c).value for c in range(2, 6)]
    markers = [ws.cell(r, c).value for c in range(start_col, end_col + 1)]
    blocks = contiguous_blocks(markers, slot_headers)
    m_positions = [(get_column_letter(start_col+i), slot_headers[i]) for i,v in enumerate(markers) if isinstance(v, str) and v.lower()=="m"]
    print(f"Row {r} {name}")
    print("  B:E =", outputs)
    print("  m_positions =", m_positions)
    print("  blocks =", blocks)

# Also inspect whether row 1 headers in B:E suggest time only or date+time
print("\nTarget headers B:E:", [ws.cell(1, c).value for c in range(2, 6)])

# Show a concise candidate interpretation: first two contiguous blocks start/end headers
print("\nCandidate mapping comparison:")
for r in range(2, ws.max_row + 1):
