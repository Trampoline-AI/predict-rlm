import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))

# Re-open fresh and inspect exact target area
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Inspect target area B3:F8")
for r in range(3, 9):
    vals = []
    for c in range(2, 7):
        cell = ws.cell(r, c)
        vals.append(f"{get_column_letter(c)}{r}={cell.value!r}")
    print(" | ".join(vals))

print("Current formulas/values at referenced cells:")
for coord in ["C8", "D8", "E8", "F8", "B4", "C4", "B5", "C5"]:
    print(coord, "=>", ws[coord].value, "numfmt:", ws[coord].number_format)

# Write formula to the exact output cell under 'Wholesale price'
target = ws["F8"]
print("Before write, F8 =", target.value)
target.value = "=C8*(1-E8)"

# Match adjacent currency-style number format if available, else set a standard one
target.number_format = ws["C8"].number_format if ws["C8"].number_format not in ("General", None) else '$#,##0.00'
print("After write, F8 formula =", ws["F8"].value, "numfmt:", ws["F8"].number_format)

wb.save(out_path)
print("Saved to:", out_path)

recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for old, new in zip(orig_sheet_names, wb_after.sheetnames):
        if old != new:
            wb_after[new].title = old
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with formulas visible
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("Post-save formula check: E8 =", wsf["E8"].value, "; F8 =", wsf["F8"].value)

# Verify cached values after recalculation
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values[orig_sheet_names[0]]
print("Cached values: C8 =", wsv["C8"].value, "E8 =", wsv["E8"].value, "F8 =", wsv["F8"].value)

# Keep output path for submit
final_output_path = out_path
