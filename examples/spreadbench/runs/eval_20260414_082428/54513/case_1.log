from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def display(v):
    if v is None:
        return None
    return v

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect headers from first 3 rows
    for hdr_row in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(hdr_row, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {hdr_row}:", vals)
    
    # Non-empty rows count approximation
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in row_vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last non-empty rows:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # first 10 non-empty rows
    print("First sample rows:")
    for r in nonempty_rows[:10]:
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"  R{r}:", vals)
    
    print("Last sample rows:")
    for r in nonempty_rows[-5:]:
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"  R{r}:", vals)

    # print coordinates with formulas or notable existing answers in used range
    formula_cells = []
    filled_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
            elif v not in (None, ""):
                filled_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells sample:", formula_cells[:10])
    print("Filled cells sample:", filled_cells[:20])
