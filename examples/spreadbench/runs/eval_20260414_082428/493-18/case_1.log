Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
ws = wb["Sheet1"]

print("Before modification:")
print("auto_filter.ref =", ws.auto_filter.ref)
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 7)])

# Collect filter values from column F excluding header/blanks
filter_values = []
filter_set = set()
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 6).value
    if v is not None and str(v).strip() != "":
        sv = str(v).strip()
        filter_values.append(sv)
        filter_set.add(sv)

print("Filter values from F:", filter_values)

# Collect records from A:C whose column A is present in F list
kept_records = []
removed_records = []
for r in range(2, ws.max_row + 1):
    car = ws.cell(r, 1).value
    row_data = [ws.cell(r, c).value for c in range(1, 4)]
    if car is not None and str(car).strip() != "" and str(car).strip() in filter_set:
        kept_records.append(row_data)
    elif any(v is not None and str(v) != "" for v in row_data):
        removed_records.append((r, row_data))

print("Kept records:", kept_records)
print("Removed records:", removed_records)

# Rewrite ONLY columns A:C, pack kept records upward starting at row 2
write_row = 2
for record in kept_records:
    for c in range(1, 4):
        ws.cell(write_row, c).value = record[c-1]
    write_row += 1

# Clear remaining A:C rows below packed records
for r in range(write_row, ws.max_row + 1):
    for c in range(1, 4):
        ws.cell(r, c).value = None

# Preserve/restore autofilter
original_filter = ws.auto_filter.ref
ws.auto_filter.ref = original_filter

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalc and ensure sheet name preserved
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"]:
    # rename first sheet back if needed
    wb2[wb2.sheetnames[0]].title = "Sheet1"
    wb2.save(outfile)
    print("Renamed sheet back to Sheet1")

# Verify with formulas/data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]
print("Verification:")
print("auto_filter.ref =", wsv.auto_filter.ref)
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 7)])

output_spreadsheet = outfile
```
