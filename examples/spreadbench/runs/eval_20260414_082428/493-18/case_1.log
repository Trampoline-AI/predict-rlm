import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    print("auto_filter.ref:", ws.auto_filter.ref)
    # headers row1 and row2 preview
    row1 = [ws.cell(1,c).value for c in range(1, min(ws.max_column, 10)+1)]
    row2 = [ws.cell(2,c).value for c in range(1, min(ws.max_column, 10)+1)]
    print("Row1 first cols:", row1)
    print("Row2 first cols:", row2)
    headers = [ws.cell(1,c).value for c in range(1, ws.max_column+1)]
    print("Headers:", headers)
    
    # print columns A:F values samples
    def row_vals(r):
        return [ws.cell(r,c).value for c in range(1, min(ws.max_column, 6)+1)]
    first_rows = list(range(1, min(ws.max_row, 10)+1))
    last_start = max(1, ws.max_row-4)
    last_rows = list(range(last_start, ws.max_row+1))
    print("First rows A:F:")
    for r in first_rows:
        print(r, row_vals(r))
    print("Last rows A:F:")
    for r in last_rows:
        print(r, row_vals(r))

for ws in wb.worksheets:
    sheet_summary(ws)
