print("Sheet names:", wb.sheetnames)
print("Header row 5:", [ws.cell(5, c).value for c in range(1, ws.max_column + 1)])

# Inspect table structure safely
print("ws.tables type:", type(ws.tables))
print("ws.tables keys:", list(ws.tables.keys()))

table_refs = {}
for name in ws.tables.keys():
    tbl = ws.tables[name]
    print("Table entry:", name, "type:", type(tbl), "repr:", repr(tbl)[:300])
    ref = getattr(tbl, "ref", None)
    if ref is None and isinstance(tbl, str):
        ref = tbl
    table_refs[name] = ref
    print("Resolved ref:", ref)

# Find target table/range containing the headers on row 5
target_ref = None
target_name = None
for name, ref in table_refs.items():
    if ref:
        min_col, min_row, max_col, max_row = range_boundaries(ref)
        headers = [ws.cell(min_row, c).value for c in range(min_col, max_col + 1)]
        print(f"Table {name} boundaries:", (min_row, max_row, min_col, max_col), "headers:", headers)
        if min_row == 5 and "Remarks" in headers:
            target_ref = ref
            target_name = name
            data_start = min_row + 1
            data_end = max_row
            break

# Fallback if table parsing is odd: infer contiguous data rows under header row 5
if target_ref is None:
    print("Falling back to inferred data rows from header row 5.")
    data_start = 6
    r = data_start
    while r <= ws.max_row and any(ws.cell(r, c).value not in (None, "") for c in range(1, 11)):
        r += 1
    data_end = r - 1
    target_name = "Table2"  # visible from existing formulas
else:
    print("Chosen table:", target_name, "ref:", target_ref)

print("Target data rows:", data_start, data_end)

# Show current target region and formulas before editing
for r in range(data_start, data_end + 1):
    print(
        f"Before row {r}:",
        [ws.cell(r, c).value for c in range(1, 11)]
    )
    print(f"Current J{r} formula:", ws[f"J{r}"].value)

# Build proper formula using the existing table name/pattern
new_formula = f'=IF({target_name}[[#This Row],[Amount Outstanding]]<0,"Prepaid",IF({target_name}[[#This Row],[Over Due Days]]="","",IF({target_name}[[#This Row],[Over Due Days]]<90,"Call Customer","Bad Debts")))'
print("New formula:", new_formula)

for r in range(data_start, data_end + 1):
    ws[f"J{r}"] = new_formula

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if changed
