```repl
import os
import shutil
from copy import copy
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["RNM"]

# Find true last non-empty row
last_nonempty = 0
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
        last_nonempty = r
        break

print("Original sheet names:", orig_sheet_names)
print("RNM true last non-empty row:", last_nonempty)
print("RNM headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Inspect current target range B/C/J before modification
print("\nCurrent RNM B/C/J rows before modification:")
for r in range(2, last_nonempty + 1):
    print(r, ws.cell(r, 2).value, ws.cell(r, 3).value, ws.cell(r, 10).value)

# Build deduplicated rows preserving first occurrence order
data_rows = []
for r in range(2, last_nonempty + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v is not None for v in vals):
        data_rows.append(vals)

dedup_rows = []
seen = {}
for vals in data_rows:
    key = (vals[1], vals[2])  # B, C
    j_val = vals[9] if vals[9] is not None else 0
    if key not in seen:
        row_copy = list(vals)
        row_copy[9] = j_val
        seen[key] = len(dedup_rows)
        dedup_rows.append(row_copy)
    else:
        idx = seen[key]
        existing = dedup_rows[idx][9] if dedup_rows[idx][9] is not None else 0
        dedup_rows[idx][9] = existing + j_val

print("\nDeduplicated RNM rows to write:")
for i, vals in enumerate(dedup_rows, start=2):
    print(i, vals[1], vals[2], vals[9], vals)

print("Original data row count:", len(data_rows))
print("Deduplicated data row count:", len(dedup_rows))

# Rewrite RNM in place starting from row 2
for out_r, vals in enumerate(dedup_rows, start=2):
    for c, v in enumerate(vals, start=1):
        ws.cell(out_r, c).value = v

# Clear remaining old rows within the previously used region
for r in range(2 + len(dedup_rows), last_nonempty + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

wb.save(output_path)
print("\nSaved initial output to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if LibreOffice changed them
wb2 = load_workbook(output_path)
current_names = wb2.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != orig_sheet_names and len(current_names) == len(orig_sheet_names):
    for i, expected in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = expected
    wb2.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verification with data_only=True
ver_wb = load_workbook(output_path, data_only=True)
print("Verified sheet names:", ver_wb.sheetnames)

ver_ws = ver_wb["RNM"]

# Recompute true last non-empty row after write
ver_last = 0
for r in range(ver_ws.max_row, 0, -1):
    if any(ver_ws.cell(r, c).value is not None for c in range(1, ver_ws.max_column + 1)):
        ver_last = r
        break

print("Verified RNM true last non-empty row:", ver_last)
print("\nVerified RNM B/C/J rows after modification:")
verified_rows = []
for r in range(2, ver_last + 1):
    vals = [ver_ws.cell(r, c).value for c in range(1, ver_ws.max_column + 1)]
    if any(v is not None for v in vals):
        verified_rows.append(vals)
        print(r, ver_ws.cell(r, 2).value, ver_ws.cell(r, 3).value, ver_ws.cell(r, 10).value)

# Explicit verification of the affected rows matching the example pattern
print("\nKey target rows/cells:")
for r in range(9, min(ver_last, 12) + 1):
    print(
        f"Row {r}:",
        "B=", ver_ws.cell(r, 2).value,
        "C=", ver_ws.cell(r, 3).value,
        "I=", ver_ws.cell(r, 9).value,
        "J=", ver_ws.cell(r, 10).value,
    )

# Check no duplicate (B,C) remain
seen_keys = set()
dupes_remaining = []
for r in range(2, ver_last + 1):
    vals = [ver_ws.cell(r, c).value for c in range(1, ver_ws.max_column + 1)]
    if any(v is not None for v in vals):
        key = (vals[1], vals[2])
        if key in seen_keys:
            dupes_remaining.append((r, key))
        seen_keys.add(key)

print("Remaining duplicate (B,C) keys in RNM:", dupes_remaining)
print("Final non-empty RNM data row count:", len(verified_rows))

final_output_path = output_path
```
