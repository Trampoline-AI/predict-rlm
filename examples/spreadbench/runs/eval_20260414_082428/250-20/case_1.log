import os
from collections import Counter, defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect headers as row 1 values
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    
    # print first 10 rows and last 5 rows
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    
    first_end = min(ws.max_row, 10)
    print(f"First {first_end} rows:")
    for r in range(1, first_end + 1):
        print(r, row_vals(r))
    
    if ws.max_row > 10:
        start_last = max(1, ws.max_row - 4)
        print("Last 5 rows:")
        for r in range(start_last, ws.max_row + 1):
            print(r, row_vals(r))

for ws in wb.worksheets:
    sheet_summary(ws)

# Deeper inspection of RNM if present
if "RNM" in wb.sheetnames:
    ws = wb["RNM"]
    print("\n=== Detailed RNM inspection ===")
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    for c, h in enumerate(headers, start=1):
        print(c, get_column_letter(c), h)
    
    # print columns B, C, J specifically for all non-empty data rows summary
    pairs = []
    for r in range(2, ws.max_row + 1):
        b = ws.cell(r, 2).value
        c = ws.cell(r, 3).value
        j = ws.cell(r, 10).value
        if any(v is not None for v in (b, c, j)):
            pairs.append((r, b, c, j))
    print("RNM non-empty rows count for B/C/J:", len(pairs))
    print("First 15 B/C/J rows:", pairs[:15])
    print("Last 10 B/C/J rows:", pairs[-10:])
    
    ctr = Counter((b, c) for _, b, c, _ in pairs)
    dupes = [(k, v) for k, v in ctr.items() if v > 1]
    print("Duplicate (B,C) pair count:", len(dupes))
    print("Sample duplicate pairs:", dupes[:15])

    # For a few duplicate pairs, print all associated rows
    for pair, count in dupes[:10]:
        matching = [t for t in pairs if (t[1], t[2]) == pair]
        print("Pair", pair, "count", count, "rows", matching)

    # Check formulas/values in J for a sample
    for r in range(2, min(ws.max_row, 12) + 1):
        print(f"J{r} raw:", ws.cell(r, 10).value)

print("\nInspection complete.")
