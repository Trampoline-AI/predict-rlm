import os, json, math, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheets:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

sheet_info = {}
for s in wb.sheetnames:
    ws = wb[s]
    max_row, max_col = ws.max_row, ws.max_column
    headers = row_values(ws, 1, max_col)
    sheet_info[s] = (max_row, max_col, headers)
    print(f"\n--- Sheet: {s} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Header row 1:", headers)
    if max_row >= 2:
        print("First rows:")
        for r in range(1, min(max_row, 10) + 1):
            print(r, row_values(ws, r, max_col))
    if max_row > 10:
        print("Last rows:")
        for r in range(max(1, max_row - 4), max_row + 1):
            print(r, row_values(ws, r, max_col))

# Search for formulas / text matching clues
matches = []
for s in wb.sheetnames:
    ws = wb[s]
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                txt = v
                if txt.startswith("=") or "TABLE" in txt.upper() or "01/04/2022" in txt or "$B$8" in txt or "SUM(1/((1/B5)" in txt.replace(" ", ""):
                    matches.append((s, cell.coordinate, txt))

print("\nPotential matches:")
for m in matches[:200]:
    print(m)

# Broader formula search for formulas containing absolute refs in col B
formula_hits = []
for s in wb.sheetnames:
    ws = wb[s]
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                if "$B$" in v or "B5" in v or "SUM(1/" in v or "/((1/B" in v:
                    formula_hits.append((s, cell.coordinate, v))

print("\nFormula hits of interest:", len(formula_hits))
for hit in formula_hits[:200]:
    print(hit)

# Print nearby context around formula hits
for s, coord, formula in formula_hits[:20]:
    ws = wb[s]
    row = ws[coord].row
    print(f"\nContext around {s} {coord} {formula}")
    for r in range(max(1, row-2), min(ws.max_row, row+2)+1):
        print(r, row_values(ws, r, ws.max_column))
