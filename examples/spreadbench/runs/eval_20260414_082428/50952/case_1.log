Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Munka1"]

print("Pre-write target inspection:")
for r in range(2, ws.max_row + 1):
    print(f"Row {r}: E={ws.cell(r,5).value!r}, F={ws.cell(r,6).value!r}, G(before)={ws.cell(r,7).value!r}")

data_start = 2
data_end = ws.max_row

written_rows = []
for r in range(2, ws.max_row + 1):
    p1 = ws.cell(r, 5).value
    p2 = ws.cell(r, 6).value
    if p1 not in (None, "") and p2 not in (None, ""):
        formula = (
            f'=IFERROR(INDEX($A${data_start}:$A${data_end},'
            f'MATCH(1,INDEX((ISNUMBER(SEARCH(E{r},$B${data_start}:$B${data_end})))*'
            f'(ISNUMBER(SEARCH(F{r},$B${data_start}:$B${data_end}))),0),0)),"")'
        )
        ws.cell(r, 7).value = formula
        written_rows.append((r, formula))

print("\nWritten formulas:")
for r, f in written_rows:
    print(f"G{r} = {f}")

wb.save(outfile)
print("\nSaved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore any changed sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    for idx, old_name in enumerate(orig_sheet_names):
        if idx < len(wb_check.worksheets):
            wb_check.worksheets[idx].title = old_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas and evaluated values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Munka1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Munka1"]

print("\nVerification of target cells G2:G5:")
for r in range(2, 6):
    print(
        f"Row {r}: E={ws_values.cell(r,5).value!r}, "
        f"F={ws_values.cell(r,6).value!r}, "
        f"G(formula)={ws_formula.cell(r,7).value!r}, "
        f"G(value)={ws_values.cell(r,7).value!r}"
    )

output_spreadsheet = outfile
