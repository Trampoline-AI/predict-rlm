import os, json
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)
print("Input file exists:", os.path.exists(input_spreadsheet), input_spreadsheet)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Detect likely header row from first few rows
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = row_values(ws, r, min(ws.max_column, 15))
        print(f"Row {r}:", vals)
    
    headers = row_values(ws, 1, ws.max_column)
    print("Headers row 1:", headers)
    
    # Print first 10 and last 5 rows for columns A:K (or all if fewer)
    sample_cols = min(ws.max_column, 11)
    print(f"Sample first rows A:{get_column_letter(sample_cols)}")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, sample_cols))
    
    print(f"Sample last rows A:{get_column_letter(sample_cols)}")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, sample_cols))
    
    # Specifically inspect columns G and K if present
    if ws.max_column >= 11:
        print("Inspecting columns G and K (rows 1-15 and last 10 nonempty-ish rows):")
        for r in range(1, min(ws.max_row, 15) + 1):
            g = ws.cell(r, 7).value
            k = ws.cell(r, 11).value
            print(f"Row {r}: G={g!r}, K={k!r}")
        for r in range(max(1, ws.max_row - 9), ws.max_row + 1):
            g = ws.cell(r, 7).value
            k = ws.cell(r, 11).value
            print(f"Row {r}: G={g!r}, K={k!r}")
        
        # Print any existing formulas in K
        formulas_in_k = []
        for r in range(1, ws.max_row + 1):
            val = ws.cell(r, 11).value
            if isinstance(val, str) and val.startswith("="):
                formulas_in_k.append((r, val))
                if len(formulas_in_k) >= 10:
                    break
        print("First formulas found in K:", formulas_in_k if formulas_in_k else "None")
