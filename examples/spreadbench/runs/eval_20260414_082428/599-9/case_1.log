Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb["Before"]

changes = []
preserved = []
skipped_empty_tail = []

# Determine relevant rows: all rows with any content across the sheet
for r in range(2, ws.max_row + 1):
    row_has_data = any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1))
    if not row_has_data:
        skipped_empty_tail.append(r)
        continue
    
    g_cell = ws.cell(r, 7)   # G
    k_cell = ws.cell(r, 11)  # K
    g_val = g_cell.value
    old_k = k_cell.value
    
    if g_val is not None:
        # copy value from G to K
        k_cell.value = g_val
        # preserve date formatting if K was blank or generic
        if g_cell.has_style:
            k_cell.number_format = g_cell.number_format
        changes.append((r, g_val, old_k, k_cell.value))
    else:
        preserved.append((r, old_k))

print("Rows with data processed:", len(changes) + len(preserved))
print("Rows updated from G to K:", len(changes))
print("Rows preserved because G blank:", len(preserved))
print("Skipped fully empty rows:", skipped_empty_tail)

print("\nSample updated rows:")
for item in changes[:10]:
    print(f"Row {item[0]}: G/K set to {item[1]!r}, old K was {item[2]!r}")

print("\nPreserved rows where G blank:")
for item in preserved[:10]:
    print(f"Row {item[0]}: K preserved as {item[1]!r}")

wb.save(outfile)
print("\nSaved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheet_names)
    if len(wb_check.sheetnames) == len(original_sheet_names):
        for ws_obj, orig_name in zip(wb_check.worksheets, original_sheet_names):
            ws_obj.title = orig_name
        wb_check.save(outfile)
        wb_check = load_workbook(outfile)
print("Final sheet names:", wb_check.sheetnames)

# Verification using data_only for cached values
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Before"]

print("\nVerification Before!G:K rows 1:21")
for r in range(1, min(21, wsv.max_row) + 1):
    g = wsv.cell(r, 7).value
    k = wsv.cell(r, 11).value
    print(f"Row {r}: G={g!r}, K={k!r}")

# Explicit sanity checks for rows illustrated by reference
check_rows = [2,3,4,5,9,14,15,19]
print("\nKey row checks:")
for r in check_rows:
    g = wsv.cell(r, 7).value
    k = wsv.cell(r, 11).value
    print(f"Row {r}: G={g!r}, K={k!r}, status={'OK' if (g is not None and k == g) or (g is None) else 'MISMATCH'}")

output_spreadsheet = outfile
```
