from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
outfile = infile  # fix in place in output location

# Load the current output workbook to correct it
wb = load_workbook(outfile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Before fix: max_row/max_col =", ws.max_row, ws.max_column)
print("Headers before fix:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Exact target should be G (after existing source column F)
target_col = 7
target_letter = get_column_letter(target_col)
source_col = 6
source_letter = get_column_letter(source_col)
print("Correct target column:", target_letter, "based on source column", source_letter)

# Print current G and H values before correction
for r in range(1, ws.max_row + 1):
    print(f"Pre-fix row {r}: F={ws.cell(r, source_col).value!r}, G={ws.cell(r, 7).value!r}, H={ws.cell(r, 8).value if ws.max_column >= 8 else None!r}")

# Write header in G1
ws.cell(1, target_col).value = "Test"

# Copy formatting from prior column F to G for all used rows
for r in range(1, ws.max_row + 1):
    src = ws.cell(r, source_col)
    dst = ws.cell(r, target_col)
    dst.font = copy(src.font)
    dst.fill = copy(src.fill)
    dst.border = copy(src.border)
    dst.alignment = copy(src.alignment)
    dst.number_format = src.number_format
    dst.protection = copy(src.protection)

# Populate G based on F
for r in range(2, ws.max_row + 1):
    proc_cat = ws.cell(r, source_col).value
    ws.cell(r, target_col).value = "X" if proc_cat == "Covid Test" else ""

# Clear accidental H column if it only contains the mistaken output
if ws.max_column >= 8 and ws["H1"].value == "Test":
    print("Clearing accidental H column.")
    for r in range(1, ws.max_row + 1):
        ws.cell(r, 8).value = None

wb.save(outfile)
print("Saved corrected workbook to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for ws_tmp, orig_name in zip(wb2.worksheets, orig_sheet_names):
        ws_tmp.title = orig_name
    wb2.save(outfile)
    print("Restored sheet names:", orig_sheet_names)

# Verify with data_only
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_sheet_names[0]]

print("Final headers:", [wsv.cell(1, c).value for c in range(1, wsv.max_column + 1)])
for r in range(1, wsv.max_row + 1):
    print(f"Row {r}: F={wsv.cell(r, 6).value!r}, G={wsv.cell(r, 7).value!r}, H={wsv.cell(r, 8).value if wsv.max_column >= 8 else None!r}")

x_rows = [r for r in range(2, wsv.max_row + 1) if wsv.cell(r, 7).value == "X"]
blank_rows = [r for r in range(2, wsv.max_row + 1) if wsv.cell(r, 7).value in (None, "")]
print("Rows flagged X in G:", x_rows)
print("Blank rows in G:", blank_rows)
print("Counts:", {"X": len(x_rows), "blank": len(blank_rows)})

output_spreadsheet = outfile
