import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]
orig_sheet_names = wb.sheetnames[:]

print("Sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)

# Inspect target area explicitly
for c in range(1, ws.max_column + 2):  # include next blank column candidate
    print(f"Header {get_column_letter(c)}1 =", ws.cell(1, c).value)

print("Current values in candidate target column G:")
for r in range(1, ws.max_row + 1):
    print(f"G{r} =", ws["G"+str(r)].value)

# Inspect formatting of prior column F and header row
for coord in ["F1", "F2", "F7", "F8"]:
    cell = ws[coord]
    print(
        coord,
        "value=", cell.value,
        "numfmt=", cell.number_format,
        "font=", (cell.font.name, cell.font.sz, cell.font.bold, cell.font.italic, cell.font.color.type if cell.font.color else None, cell.font.color.rgb if cell.font.color and cell.font.color.type=="rgb" else None),
        "fill=", (cell.fill.fill_type, cell.fill.fgColor.type, cell.fill.fgColor.rgb),
        "border_left=", cell.border.left.style,
        "align=", (cell.alignment.horizontal, cell.alignment.vertical),
    )

# Determine exact target column: append new column after existing last column
target_col = ws.max_column + 1
target_letter = get_column_letter(target_col)
print("Chosen target column:", target_col, target_letter)

# Write header
ws.cell(1, target_col).value = "Test"

# Copy formatting from prior column F to new column G for all used rows
source_fmt_col = target_col - 1
for r in range(1, ws.max_row + 1):
    src = ws.cell(r, source_fmt_col)
    dst = ws.cell(r, target_col)
    if r != 1 and dst.value not in (None, ""):
        print("Warning: target cell already had value", dst.coordinate, dst.value)
    # copy style-related objects
    dst.font = copy(src.font)
    dst.fill = copy(src.fill)
    dst.border = copy(src.border)
    dst.alignment = copy(src.alignment)
    dst.number_format = src.number_format
    dst.protection = copy(src.protection)

# Populate values based on Procedure Category ID in column F
written = []
for r in range(2, ws.max_row + 1):
    proc_cat = ws.cell(r, 6).value
    val = "X" if proc_cat == "Covid Test" else ""
    ws.cell(r, target_col).value = val
    written.append((r, proc_cat, val))

print("Rows written summary:", written)

# Save
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if recalc changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for ws_tmp, orig_name in zip(wb2.worksheets, orig_sheet_names):
        ws_tmp.title = orig_name
    wb2.save(outfile)
    print("Renamed sheets back to original:", orig_sheet_names)

# Verify with formulas/values
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

print("Target header:", target_letter + "1", "=", wsv[target_letter + "1"].value)
for r in range(1, wsv.max_row + 1):
    print(f"{target_letter}{r} =", wsv.cell(r, target_col).value, "| F{r} =", wsv.cell(r, 6).value)

# additional sanity check: rows with X
x_rows = [r for r in range(2, wsv.max_row + 1) if wsv.cell(r, target_col).value == "X"]
blank_rows = [r for r in range(2, wsv.max_row + 1) if wsv.cell(r, target_col).value in (None, "")]
print("Rows flagged X:", x_rows)
print("Count X:", len(x_rows), "Count blank:", len(blank_rows))
