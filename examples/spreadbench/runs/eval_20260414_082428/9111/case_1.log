                used_cols.add(cell.column)
        if has_val:
            used_rows.append(row[0].row)
    if used_rows:
        print("used row range:", min(used_rows), "to", max(used_rows))
        print("used columns:", [(c, get_column_letter(c)) for c in sorted(used_cols)])
