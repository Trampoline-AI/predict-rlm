import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load original workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheetnames:", original_sheetnames)

# Identify the actual data extent of the main table using column A numbering
last_table_row = 1
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    if a not in (None, ""):
        last_table_row = r

print("Last table row based on column A:", last_table_row)
print("Target column D index:", column_index_from_string("D"))

# Print current target area before modification
print("Before writing, rows 2 to", last_table_row, "B:D")
for r in range(2, last_table_row + 1):
    print(r, ws.cell(r, 2).value, ws.cell(r, 3).value, ws.cell(r, 4).value)

# Write per-row LibreOffice-compatible formula into D2:Dlast_table_row
# Logic:
# if both B and C blank => ""
# else if B found in list1 => corresponding H
# else if C found in list2 => corresponding K
# else => 2500
for r in range(2, last_table_row + 1):
    formula = (
        f'=IF(AND(B{r}="",C{r}=""),"",'
        f'IF(IFERROR(MATCH(LOWER(B{r}),$L$2:$L$13,0),0)>0,INDEX($H$2:$H$13,MATCH(LOWER(B{r}),$L$2:$L$13,0)),'
        f'IF(IFERROR(MATCH(LOWER(C{r}),$M$2:$M$6,0),0)>0,INDEX($K$2:$K$6,MATCH(LOWER(C{r}),$M$2:$M$6,0)),2500)))'
    )
    ws.cell(r, 4).value = formula

# Build helper lowercase lookup columns in L:M to support case-insensitive matching safely
# Keep structure otherwise unchanged; these columns are already unused.
ws["L1"] = "list1_lower"
for r in range(2, 14):
    val = ws.cell(r, 7).value
    ws.cell(r, 12).value = str(val).strip().lower() if val not in (None, "") else None

ws["M1"] = "list2_lower"
for r in range(2, 7):
    val = ws.cell(r, 10).value
    ws.cell(r, 13).value = str(val).strip().lower() if val not in (None, "") else None

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb_check = load_workbook(output_path)
print("Sheetnames after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for i, old_name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Renamed sheets back to original names:", original_sheetnames)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheetnames:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

print("\nVerified target cells D2:D{}".format(last_table_row))
verification = []
for r in range(2, last_table_row + 1):
    row_info = {
        "row": r,
        "A": wsv.cell(r, 1).value,
        "B": wsv.cell(r, 2).value,
        "C": wsv.cell(r, 3).value,
        "D": wsv.cell(r, 4).value,
    }
    verification.append(row_info)
    print(row_info)

# Sanity checks for key rows
print("\nKey checks:")
for r in [2, 3, 4, 5, 6, 7]:
    print(f"Row {r}: B={wsv.cell(r,2).value!r}, C={wsv.cell(r,3).value!r}, D={wsv.cell(r,4).value!r}")

output_spreadsheet = output_path
