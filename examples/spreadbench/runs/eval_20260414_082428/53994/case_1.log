import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
os.makedirs(os.path.dirname(outfile), exist_ok=True)

# Reload ORIGINAL input fresh
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["TEST_SHEET"]

targets = [(10,3),(10,4),(11,3),(11,4),(12,3),(12,4)]
print("Before write:")
for r,c in targets:
    print(ws.cell(r,c).coordinate, "->", ws.cell(r,c).value)

time_rows = [19, 22, 25, 28]
machine_rows = [17, 20, 23, 26]

def build_formula(target_row, target_col):
    col_letter = chr(64 + target_col)  # C or D
    parts = []
    for tr, mr in zip(time_rows, machine_rows):
        parts.append(
            f'SUMPRODUCT(($I${tr}>=$C$4)*($J${tr}<=$C$5)*'
            f'($L$16:$W$16={col_letter}$9)*($L${mr}:$W${mr}=$B{target_row})*$L${tr}:$W${tr})'
        )
    return "=" + "+".join(parts)

print("\nFormulas to write:")
for r,c in targets:
    f = build_formula(r,c)
    print(ws.cell(r,c).coordinate, "=", f)
    ws.cell(r,c).value = f

wb.save(outfile)
print("\nSaved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore names if changed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheet_names)
    for i, nm in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = nm
    wb2.save(outfile)
else:
    print("Sheet names OK:", wb2.sheetnames)

# Verify formula text before data_only read
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["TEST_SHEET"]
print("\nStored target formulas/values:")
for r,c in targets:
    print(wsf.cell(r,c).coordinate, "=", wsf.cell(r,c).value)

# Verify calculated values
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["TEST_SHEET"]

computed = {wsv.cell(r,c).coordinate: wsv.cell(r,c).value for r,c in targets}
print("\nComputed target values:")
for addr, val in computed.items():
    print(addr, "=", val)

# Independent Python check from recalculated workbook
def py_sum(machine, phase):
    total = 0
    c4 = wsv["C4"].value
    c5 = wsv["C5"].value
    for tr, mr in zip(time_rows, machine_rows):
        if not (wsv[f"I{tr}"].value >= c4 and wsv[f"J{tr}"].value <= c5):
            continue
        for c in range(12, 24):  # L:W
            if wsv.cell(16, c).value == phase and wsv.cell(mr, c).value == machine:
                t = wsv.cell(tr, c).value
                if isinstance(t, (int, float)):
                    total += t
