Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify current target cells before modification
print("Before modification:")
for coord in ["G11","G12","G13","G20","G21","G22"]:
    print(coord, ws[coord].value)

# Write correct formulas for the two lower table sections.
# Use IFERROR so missing names don't produce #N/A.
for r in range(11, 14):
    ws[f"G{r}"] = f'=IFERROR(INDEX(Table2[START_DATE],MATCH(D{r},Table2[PARTICIPANT_NAME],0))>=E{r},FALSE())'

for r in range(20, 23):
    ws[f"G{r}"] = f'=IFERROR(INDEX(Table3[START_DATE],MATCH(D{r},Table3[PARTICIPANT_NAME],0))>=E{r},FALSE())'

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for old, new in zip(orig_sheetnames, wb2.sheetnames):
        if old != new:
            wb2[new].title = old
    wb2.save(outfile)
    print("Restored sheet names:", load_workbook(outfile).sheetnames)

# Verification with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nFormulas written:")
for coord in ["G11","G12","G13","G20","G21","G22"]:
    print(coord, "=", wsf[coord].value)

# Verification with cached values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
print("\nVerified values after recalculation:")
for r in [11,12,13,20,21,22]:
    rowvals = [wsv.cell(r, c).value for c in range(1, 8)]
    print("Row", r, rowvals)

# Keep output path in a variable for submission
final_output_spreadsheet = outfile
```
