def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for s in wb.sheetnames:
    ws = wb[s]
    print("\n=== SHEET:", s, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect likely used columns from first 15 rows
    nonempty_cols = set()
    for r in range(1, min(ws.max_row, 15) + 1):
        for c in range(1, ws.max_column + 1):
            if ws.cell(r, c).value is not None:
                nonempty_cols.add(c)
    used_cols = sorted(nonempty_cols)
    print("Used cols in first 15 rows:", [(c, get_column_letter(c), ws.cell(1,c).value) for c in used_cols[:30]])
    
    # print first 12 rows
    print("First 12 rows:")
    for r in range(1, min(ws.max_row, 12) + 1):
        vals = row_values(ws, r, min(ws.max_column, 20))
        print(r, vals)
    
    # print last 5 rows
