import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]
orig_sheet_names = wb.sheetnames[:]

def show_range(ws, r1, r2, c1, c2, title):
    print("\n" + title)
    for r in range(r1, r2 + 1):
        row = []
        for c in range(c1, c2 + 1):
            row.append(f"{get_column_letter(c)}{r}={ws.cell(r,c).value}")
        print(" | ".join(row))

# Inspect exact source and target areas
show_range(ws, 4, 19, 2, 9, "SOURCE AREA B4:I19")
show_range(ws, 4, 19, 11, 19, "TARGET AREA K4:S19")

# Capture headers/brands
source_categories = [ws.cell(5, c).value for c in range(3, 10)]   # C:I
source_brands = [ws.cell(r, 2).value for r in range(6, ws.max_row + 1)]  # B
target_categories = [ws.cell(5, c).value for c in range(13, 20)]  # M:S
target_brands = [ws.cell(r, 12).value for r in range(6, ws.max_row + 1)]  # L

print("\nSource categories C:I:", source_categories)
print("Source brands B6:B19:", source_brands)
print("Target categories M:S:", target_categories)
print("Target brands L6:L19:", target_brands)

# print any existing formulas in target data area M6:S19
existing = []
for r in range(6, ws.max_row + 1):
    for c in range(13, 20):
        v = ws.cell(r, c).value
        if isinstance(v, str) and v.startswith("="):
            existing.append((f"{get_column_letter(c)}{r}", v))
print("Existing formulas in M6:S19:", existing)

# Fill target cells with INDEX/MATCH formulas
for r in range(6, ws.max_row + 1):
    brand = ws.cell(r, 12).value  # L
    if brand in (None, ""):
        continue
    for c in range(13, 20):  # M:S
        category = ws.cell(5, c).value
        if category in (None, ""):
            continue
        cell = ws.cell(r, c)
        # Only fill blank cells / leave any plausible pre-existing values alone
        if cell.value in (None, ""):
            cell.value = f'=INDEX($C$6:$I$19,MATCH($L{r},$B$6:$B$19,0),MATCH({get_column_letter(c)}$5,$C$5:$I$5,0))'

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore sheet names if changed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename by position back to originals
    for i, old_name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = old_name
    wb2.save(out_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify formulas exist
wb_formulas = load_workbook(out_path, data_only=False)
wsf = wb_formulas[orig_sheet_names[0]]
print("\nFormulas written in target area M6:S19:")
for r in range(6, wsf.max_row + 1):
    vals = [wsf.cell(r, c).value for c in range(12, 20)]
    print(r, vals)

# Verify evaluated values
wb_vals = load_workbook(out_path, data_only=True)
wsv = wb_vals[orig_sheet_names[0]]
print("\nEvaluated target area L5:S19:")
for r in range(5, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(12, 20)]
    print(r, vals)

output_spreadsheet = out_path
