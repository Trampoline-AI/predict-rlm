    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        vals = row_values(ws, r, min(ws.max_column, 20))
        print(r, vals)

    # specifically inspect rows around 6-15 with columns A:Z
    print("Rows 6-15, cols A:Z")
    for r in range(6, min(ws.max_row, 15) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 26) + 1)]
        print(r, vals)

    # print any formulas in rows 6-15 cols A:Z
    formulas = []
