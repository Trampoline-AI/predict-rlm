print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for ws, orig_name in zip(wb_check.worksheets, orig_sheet_names):
        ws.title = orig_name
    wb_check.save(out_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verification reload
wb_verify = load_workbook(out_path, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
ws_verify = wb_verify["Output"]

print("\nVerified Output rows 1-12 after save/recalc:")
for r in range(1, min(12, ws_verify.max_row) + 1):
    print(r, [ws_verify.cell(r, c).value for c in range(1, ws_verify.max_column + 1)])

# Sanity checks on target rows
