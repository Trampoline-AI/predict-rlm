def sheet_info(ws, sample_first=10, sample_last=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", headers)
    # also inspect row 2 in case headers aren't row 1
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row 2:", row2)
    first_end = min(ws.max_row, sample_first)
    print(f"First {first_end} rows:")
    for r in range(1, first_end + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    if ws.max_row > sample_first:
        print(f"Last {sample_last} rows:")
        start = max(sample_first + 1, ws.max_row - sample_last + 1)
        for r in range(start, ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)
