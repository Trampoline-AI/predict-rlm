import os, re, itertools, shutil
from openpyxl import load_workbook

# Load workbook fresh
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
ws_in = wb["Input"]
ws_out = wb["Output"]

def parse_filter(filter_text):
    result = {}
    if not filter_text:
        return result

    # key = "value"
    for key, val in re.findall(r'\("([^"]+)"\s*=\s*"([^"]*)"\)', filter_text):
        result[key] = val

    # key IN LIST ...
    for key, vals in re.findall(r'\("([^"]+)"\s+IN\s+LIST\s+([^)]+)\)', filter_text):
        parts = [p.strip() for p in vals.split(",")]
        cleaned = []
        for p in parts:
            p = p.strip().strip('"')
            if re.fullmatch(r'\d+', p):
                cleaned.append(int(p))  # omits leading zeros
            else:
                cleaned.append(p)
        result[key] = cleaned
    return result

# Build expected output rows from Input
expected_rows = []
for r in range(2, ws_in.max_row + 1):
    wtype_id = ws_in.cell(r, 1).value
    name = ws_in.cell(r, 2).value
    status = ws_in.cell(r, 3).value
    filter_text = ws_in.cell(r, 4).value
    parsed = parse_filter(filter_text)

    specialty_vals = parsed.get("specialtyId", [None])
    context_vals = parsed.get("contextId", [None])
    if not isinstance(specialty_vals, list):
        specialty_vals = [specialty_vals]
    if not isinstance(context_vals, list):
        context_vals = [context_vals]

    for sp, ctx in itertools.product(specialty_vals, context_vals):
        expected_rows.append([
            wtype_id,
            name,
            status,
            parsed.get("orgId"),
            parsed.get("careType"),
            sp,
            ctx,
        ])

print("Expected rows to write:", len(expected_rows))
for i, row in enumerate(expected_rows, start=2):
    print(i, row)

# Verify target area before writing
print("\nCurrent Output rows 1-12 before write:")
for r in range(1, min(12, ws_out.max_row) + 1):
    print(r, [ws_out.cell(r, c).value for c in range(1, ws_out.max_column + 1)])

# Write into existing Output sheet starting at row 2
for i, row_vals in enumerate(expected_rows, start=2):
    for c, val in enumerate(row_vals, start=1):
        ws_out.cell(i, c).value = val

# Clear any remaining stale rows below expected output, within existing used range
for r in range(2 + len(expected_rows), ws_out.max_row + 1):
    for c in range(1, ws_out.max_column + 1):
        ws_out.cell(r, c).value = None

# Save output
