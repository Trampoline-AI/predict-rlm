import os, re, itertools, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Re-open for focused inspection
wb = load_workbook(input_spreadsheet)
ws_in = wb["Input"]
ws_out = wb["Output"]

print("Focused inspection:")
print("Output headers:", [ws_out.cell(1, c).value for c in range(1, ws_out.max_column + 1)])

print("\nAll input rows:")
for r in range(2, ws_in.max_row + 1):
    print(r, [ws_in.cell(r, c).value for c in range(1, ws_in.max_column + 1)])

print("\nCurrent output rows 1-10:")
for r in range(1, min(10, ws_out.max_row) + 1):
    print(r, [ws_out.cell(r, c).value for c in range(1, ws_out.max_column + 1)])

# Parse helper
def parse_filter(filter_text):
    result = {}
    if not filter_text:
        return result
    
    # = "value"
    for key, val in re.findall(r'\("([^"]+)"\s*=\s*"([^"]*)"\)', filter_text):
        result[key] = val
    
    # IN LIST values
    for key, vals in re.findall(r'\("([^"]+)"\s+IN\s+LIST\s+([^)]+)\)', filter_text):
        parts = [p.strip() for p in vals.split(",")]
        cleaned = []
        for p in parts:
            p = p.strip().strip('"')
            if re.fullmatch(r'\d+', p):
                cleaned.append(int(p))   # removes leading zeros
            else:
                cleaned.append(p)
        result[key] = cleaned
    return result

print("\nParsed input filters:")
parsed_rows = []
for r in range(2, ws_in.max_row + 1):
    data = {
        "wtype_id": ws_in.cell(r, 1).value,
        "name": ws_in.cell(r, 2).value,
        "status": ws_in.cell(r, 3).value,
        "filter": ws_in.cell(r, 4).value,
