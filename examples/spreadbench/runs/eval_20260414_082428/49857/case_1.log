import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Determine true last data row by scanning for any non-empty cell in the row
true_last_row = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
        true_last_row = r

print("Original sheet names:", orig_sheet_names)
print("max_row:", ws.max_row, "true_last_row:", true_last_row, "max_column:", ws.max_column)

# Print relevant header and data area around target columns
for r in range(3, min(true_last_row, 12) + 1):
    print(f"Row {r}: F={ws.cell(r,6).value!r}, G={ws.cell(r,7).value!r}, full={[ws.cell(r,c).value for c in range(1,10)]}")

print("Last data rows:")
for r in range(max(4, true_last_row - 4), true_last_row + 1):
    print(f"Row {r}: F={ws.cell(r,6).value!r}, G={ws.cell(r,7).value!r}, full={[ws.cell(r,c).value for c in range(1,10)]}")

# Write formulas in target cells G4:G{true_last_row} only for rows that actually have data in the record area
start_row = 4
for r in range(start_row, true_last_row + 1):
    row_has_data = any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1))
    if not row_has_data:
        continue
    formula = f'=IF(UPPER(TRIM(F{r}))="YES",COUNTIF($F$4:F{r},"Yes"),0)'
    ws.cell(r, 7).value = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    for i, old_name in enumerate(orig_sheet_names):
        if i < len(wb_after.sheetnames):
            wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", wb_after.sheetnames)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("Verification of target cells G4:G{}:".format(true_last_row))
verification = []
for r in range(4, true_last_row + 1):
    if any(ws_values.cell(r, c).value not in (None, "") for c in range(1, ws_values.max_column + 1)):
        verification.append((
            r,
            ws_values.cell(r, 6).value,
            ws_formula.cell(r, 7).value,
            ws_values.cell(r, 7).value
        ))
print(verification)

# Sanity check blanks/errors
problems = [item for item in verification if item[3] in (None, "")]
print("Problem rows with blank computed G:", problems)
