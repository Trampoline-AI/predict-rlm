import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        vals.append(ws.cell(r, c).value)
    return vals

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, min(ws.max_column, 15))
    print("Row 1 / possible headers:", headers)
    
    # print first 10 rows (or fewer) and last 5 rows
    first_n = min(ws.max_row, 10)
    last_start = max(1, ws.max_row - 4)
    print("First rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, min(ws.max_column, 10)))
    print("Last rows:")
    for r in range(last_start, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 10)))
    
    print("Specific cells A1, B2:", ws["A1"].value, ws["B2"].value)
    if isinstance(ws["B2"].value, str) and ws["B2"].value.startswith("="):
        print("B2 formula:", ws["B2"].value)
    if isinstance(ws["A1"].value, str) and ws["A1"].value.startswith("="):
        print("A1 formula:", ws["A1"].value)
