import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load and inspect target area again before writing
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Pre-write verification:")
for r in range(1, 4):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])
print("A1:", ws["A1"].value)
print("B2 before:", ws["B2"].value)

a1 = ws["A1"].value
a1_text = "" if a1 is None else str(a1).upper()

mapping = [
    ("4OZARK", 1),
    ("3TALL", 2),
    ("1JASPER", 3),
    ("2GWOOD", 4),
    ("5DAWSON", 5),
    ("8CPARK", 6),
]

result = None
for key, val in mapping:
    if key in a1_text:
        result = val
        break

print("Matched result to write into B2:", result)

# Write only if we found a match
ws["B2"] = result

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename sheets back by position
    for i, original_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Final verification using data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]
print("Verified A1:", wsv["A1"].value)
print("Verified B2:", wsv["B2"].value)
for r in range(1, 4):
    print("verify row", r, [wsv.cell(r, c).value for c in range(1, 4)])

output_spreadsheet = outfile
