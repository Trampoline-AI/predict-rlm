Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for editing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]

ws_source = wb["Source"]
ws_source2 = wb["Source2"]
ws_result = wb["Result"]

# Confirm headers / exact target cells
source_headers = [ws_source.cell(1, c).value for c in range(1, ws_source.max_column + 1)]
source2_headers = [ws_source2.cell(1, c).value for c in range(1, ws_source2.max_column + 1)]
result_headers = [ws_result.cell(1, c).value for c in range(1, ws_result.max_column + 1)]
print("Source headers:", source_headers)
print("Source2 headers:", source2_headers)
print("Result headers:", result_headers)
print("Target output column is Result!A under header:", ws_result["A1"].value)

# Identify columns by header
source_value_col = source_headers.index("Value") + 1
source2_value_col = source2_headers.index("Value") + 1
result_value_col = result_headers.index("Value") + 1

# Read full data ranges
source_values = []
for r in range(2, ws_source.max_row + 1):
    v = ws_source.cell(r, source_value_col).value
    if v not in (None, ""):
        source_values.append(v)

source2_values = []
for r in range(2, ws_source2.max_row + 1):
    v = ws_source2.cell(r, source2_value_col).value
    if v not in (None, ""):
        source2_values.append(v)

print("Source values:", source_values)
print("Source2 values:", source2_values)

source2_set = set(source2_values)

# Build ordered unique result from Source:
# include if not in Source2, except include 2 once if it is in both.
result_values = []
seen = set()
for v in source_values:
    include = (v not in source2_set) or (v == 2 and 2 in source2_set)
    if include and v not in seen:
        result_values.append(v)
        seen.add(v)

print("Computed result values:", result_values)

# Inspect current target area before writing
current_result_col = [ws_result.cell(r, result_value_col).value for r in range(1, max(ws_result.max_row, len(result_values)+3) + 1)]
print("Current Result column A before write:", current_result_col)

# Clear old values below header in target column only
for r in range(2, ws_result.max_row + 1):
    ws_result.cell(r, result_value_col).value = None

# Write results to existing Result table
for i, v in enumerate(result_values, start=2):
    ws_result.cell(i, result_value_col).value = v

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_status = await recalculate(output_path)
print("Recalculate status:", recalc_status)

# Restore sheet names if recalculation/localization changed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_post.sheetnames, "-> restoring to", orig_sheetnames)
    for i, name in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = name
    wb_post.save(output_path)
else:
    print("Sheet names unchanged after recalc:", wb_post.sheetnames)

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

wsv = wb_verify["Result"]
verified_values = [wsv.cell(r, result_value_col).value for r in range(1, len(result_values) + 2)]
print("Verified Result!A1:A{}:".format(len(result_values)+1), verified_values)

# Additional sanity checks
assert wsv["A1"].value == "Value", "Header changed unexpectedly"
assert verified_values[1:] == result_values, f"Mismatch in result values: {verified_values[1:]} vs {result_values}"
assert all(v is not None and str(v).strip() != "" for v in verified_values), "Blank target cells found"

final_output_path = output_path
print("Final output path ready:", final_output_path)
