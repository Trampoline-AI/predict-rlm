import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload for focused inspection
wb = load_workbook(input_path)
ws = wb["Sheet1"]

print("Focused inspection:")
for r in range(1, ws.max_row + 1):
    print(r, ws.cell(r, 1).value, ws.cell(r, 9).value)

print("Existing target area values:")
for r in range(11, min(ws.max_row, 20) + 1):
    print(f"A{r} =", ws.cell(r, 1).value)

# Determine source data rows: rows with branch names in col A before the blank gap/output section
source_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    i = ws.cell(r, 9).value if ws.max_column >= 9 else None
    # stop when we reach the labeled output section
    if a == "Branches not checked":
        break
    if a not in (None, "", "Branches"):
        source_rows.append((r, a, i))

print("Source rows considered:", source_rows)

# Branches without a tick mark in column I
unticked = []
for r, branch, chk in source_rows:
    if chk in (None, ""):
        unticked.append(branch)

print("Unticked branches:", unticked)

# Write results into the existing output area starting at A13 (below header row A12='branch')
start_row = 13
for idx, branch in enumerate(unticked):
    ws.cell(start_row + idx, 1).value = branch

# Clear any stale old values below the written output in that output section
for r in range(start_row + len(unticked), ws.max_row + 1):
    # Only clear rows in the output block, not source data
    if r >= 13:
        ws.cell(r, 1).value = None

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
orig_names = ["Sheet1"]
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for ws2, orig in zip(wb2.worksheets, orig_names):
        ws2.title = orig
    wb2.save(output_path)
    print("Renamed sheets back to:", orig_names)

# Verify with data_only=True
verify_wb = load_workbook(output_path, data_only=True)
vws = verify_wb["Sheet1"]

print("Verification target cells:")
for cell in ["A11", "A12", "A13", "A14", "A15"]:
    print(cell, "=", vws[cell].value)

print("Final non-empty output rows around target:")
for r in range(11, 16):
    print(r, vws.cell(r, 1).value)
