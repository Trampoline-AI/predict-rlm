import os, json, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find a likely header row among first 5 rows by most non-empty cells
    best_row = 1
    best_nonempty = -1
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r, min(ws.max_column, 15))
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row = r
    header_row = best_row
    headers = row_values(ws, header_row, ws.max_column)
    print("Chosen header row:", header_row)
    print("Headers:", headers[:20], "..." if len(headers) > 20 else "")
    
    # Print first 10 rows and last 5 rows (up to 12 cols for readability)
    show_cols = min(ws.max_column, 12)
    first_end = min(ws.max_row, 10)
    print(f"First rows 1-{first_end} (first {show_cols} cols):")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, show_cols))
    
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}-{ws.max_row} (first {show_cols} cols):")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, show_cols))
    
    # Specific inspection for columns A and I
    if ws.max_column >= 9:
        print("Column A header/current:", ws["A1"].value, "Column I header/current:", ws["I1"].value)
        sample_ai = []
        for r in range(1, min(ws.max_row, 15) + 1):
            sample_ai.append((r, ws.cell(r,1).value, ws.cell(r,9).value))
        print("Sample A/I rows 1-15:", sample_ai)
        if ws.max_row > 15:
            tail_ai = []
            for r in range(max(1, ws.max_row-4), ws.max_row+1):
                tail_ai.append((r, ws.cell(r,1).value, ws.cell(r,9).value))
            print("Tail A/I rows:", tail_ai)
    
    # Print formulas/values in nearby columns J-L to find target output area
    for c in range(9, min(ws.max_column, 12) + 1):
        col = get_column_letter(c)
        vals = [ws.cell(r, c).value for r in range(1, min(ws.max_row, 10)+1)]
        print(f"Sample {col}1:{col}{min(ws.max_row,10)} ->", vals)
