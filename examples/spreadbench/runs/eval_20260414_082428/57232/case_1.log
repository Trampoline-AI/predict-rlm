```repl
import os, re
from openpyxl import load_workbook

# Fresh load from input
wb = load_workbook(input_spreadsheet, data_only=False)
ws_rates = wb["Sea Freight Rates"]
ws_vol = wb["Volume"]
orig_sheetnames = wb.sheetnames[:]

# Inspect the only source formula and its referenced cell
print("Source formula cell Volume!E13:", ws_vol["E13"].value)
print("Referenced Volume!E36 raw value:", ws_vol["E36"].value)

# Simple resolver for same-sheet direct references like '=E36'
cell_ref_re = re.compile(r"^=([A-Z]+)(\d+)$")

def resolve_volume_value(ws, cell):
    v = cell.value
    if isinstance(v, str) and v.startswith("="):
        m = cell_ref_re.match(v)
        if m:
            ref = f"{m.group(1)}{m.group(2)}"
            ref_val = ws[ref].value
            # one-level / recursive resolution if needed
            if isinstance(ref_val, str) and ref_val.startswith("="):
                return resolve_volume_value(ws, ws[ref])
            return ref_val
        return None
    return v

# Build destination header -> column map from Volume row 2
dest_col_map = {}
for c in range(4, ws_vol.max_column + 1):
    header = ws_vol.cell(2, c).value
    if header not in (None, ""):
        dest_col_map[header] = c
print("Destination map:", dest_col_map)

# Compute outputs
computed = {}
unmatched = []
for r in range(2, ws_rates.max_row + 1):
    # Only rows with source data
    if all(ws_rates.cell(r, c).value in (None, "") for c in range(1, 8)):
        continue

    origin = ws_rates.cell(r, 2).value  # Origin Port (portcode)
    dest = ws_rates.cell(r, 4).value    # Destination Port (portcode)
    equip = ws_rates.cell(r, 5).value   # Equipment type

    if dest not in dest_col_map:
        computed[r] = "#N/A"
        unmatched.append((r, origin, dest, equip, "dest not found"))
        continue

    target_col = dest_col_map[dest]
    total = 0.0
    found_any = False

    for vr in range(3, ws_vol.max_row + 1):
        v_origin = ws_vol.cell(vr, 1).value
        v_equip = ws_vol.cell(vr, 2).value
        if v_origin == origin and v_equip == equip:
            found_any = True
            raw_val = resolve_volume_value(ws_vol, ws_vol.cell(vr, target_col))
            if raw_val in (None, ""):
                continue
            try:
                total += float(raw_val)
            except Exception:
                print(f"Non-numeric source at Volume!{ws_vol.cell(vr, target_col).coordinate}: {raw_val!r}")

    if found_any:
        # Write int when whole number, else float
        computed[r] = int(total) if abs(total - round(total)) < 1e-12 else total
    else:
        computed[r] = "#N/A"
        unmatched.append((r, origin, dest, equip, "origin/equip not found"))

print("Computed rows:", len(computed))
print("Unmatched count:", len(unmatched))
print("Unmatched sample:", unmatched[:10])

# Show some expected outputs before writing
for r in [2, 3, 4, 5, 10, 50, 100, 150, 187, 191]:
    print("Preview", r, ws_rates.cell(r,2).value, ws_rates.cell(r,4).value, ws_rates.cell(r,5).value, "->", computed.get(r))

# Write results to target column H
for r, val in computed.items():
    ws_rates.cell(r, 8).value = val

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved:", out_path)

# Recalculate (harmless even though values are static)
recalc_result = await recalculate(out_path)
print("Recalc result:", recalc_result)

# Restore sheet names if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = s
    wb_after.save(out_path)
    print("Restored sheet names:", orig_sheetnames)

# Verify output
wbv = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv["Sea Freight Rates"]

print("\nVerification target cells:")
for r in [2, 3, 4, 5, 10, 50, 100, 150, 187, 191]:
    print(f"H{r} =", wsv.cell(r, 8).value)

blank_rows = []
for r in range(2, wsv.max_row + 1):
