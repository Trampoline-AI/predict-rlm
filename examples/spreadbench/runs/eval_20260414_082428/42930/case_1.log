```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load and compute mapping from actual data
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Derive earliest year per subdivision from columns A:B
earliest = {}
for r in range(2, ws.max_row + 1):
    year = ws.cell(r, 1).value
    subd = ws.cell(r, 2).value
    if year is None or subd in (None, ""):
        continue
    if subd not in earliest or year < earliest[subd]:
        earliest[subd] = year

ordered_subds = [subd for subd, yr in sorted(earliest.items(), key=lambda x: (x[1], x[0]))]
mapping = {subd: i + 1 for i, subd in enumerate(ordered_subds)}

print("Computed mapping:", mapping)
print("Target column:", ws["C1"].value)

# Print current target cells before writing
before_vals = [(r, ws.cell(r, 2).value, ws.cell(r, 3).value) for r in range(2, ws.max_row + 1)]
print("Before (row, subdivision, C):", before_vals)

# Fill column C for all relevant rows with house data
for r in range(2, ws.max_row + 1):
    year = ws.cell(r, 1).value
    subd = ws.cell(r, 2).value
    if year is None and subd in (None, ""):
        continue
    ws.cell(r, 3).value = mapping.get(subd)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload normal mode to restore original sheet names if needed
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # Rename by position back to originals
    for i, orig_name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = orig_name
    wb2.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

verified = []
blanks = []
for r in range(2, wsv.max_row + 1):
    year = wsv.cell(r, 1).value
    subd = wsv.cell(r, 2).value
    cval = wsv.cell(r, 3).value
    if year is None and subd in (None, ""):
        continue
    verified.append((r, year, subd, cval))
    if cval in (None, ""):
        blanks.append(r)

print("Verified C column rows:")
for row in verified:
    print(row)

print("Blank target rows:", blanks)

# Keep output path in variable for submission
final_output_spreadsheet = output_path
```
