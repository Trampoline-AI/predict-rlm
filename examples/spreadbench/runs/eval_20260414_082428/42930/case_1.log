from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Max row/col:", ws.max_row, ws.max_column)

# Print all relevant rows A:F to inspect exact target and patterns
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

print("\nCell formulas/values in target/sample columns:")
for col in [3, 5, 6]:
    print(f"Column {get_column_letter(col)} header:", ws.cell(1, col).value)
    for r in range(2, ws.max_row + 1):
        v = ws.cell(r, col).value
        if v is not None:
            print(f"{get_column_letter(col)}{r} -> {v!r}")

# Infer mapping from example columns E:F
mapping = {}
for r in range(2, ws.max_row + 1):
    subd = ws.cell(r, 5).value
    num = ws.cell(r, 6).value
    if subd is not None and num is not None:
        mapping[subd] = num

print("\nInferred subdivision->number mapping from E:F:", mapping)

# Also independently verify earliest year per subdivision from A:B
earliest = {}
for r in range(2, ws.max_row + 1):
