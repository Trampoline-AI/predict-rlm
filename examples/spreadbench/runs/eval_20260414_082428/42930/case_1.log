wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    max_row, max_col = ws.max_row, ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print("Row1 headers:", headers)
    # also inspect row2 in case headers aren't in row1
    row2 = [ws.cell(2, c).value for c in range(1, max_col+1)]
    print("Row2 sample:", row2)
    
    # print first up to 8 rows and last 5 rows
    first_n = min(max_row, 8)
    print("First rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(r, vals)
    if max_row > 8:
        print("Last rows:")
        for r in range(max(1, max_row-4), max_row+1):
            vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
            print(r, vals)

for ws in wb.worksheets:
    sheet_summary(ws)
