import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames
print("Original sheetnames:", original_sheetnames)

# Identify summary sheet robustly
summary_name = None
for s in wb.sheetnames:
    if s.strip().lower() == "list":
        summary_name = s
        break
print("Summary sheet found:", summary_name)

# Compute sums for all non-summary sheets
sheet_summaries = []
for s in wb.sheetnames:
    if s == summary_name:
        continue
    ws = wb[s]
    import_sum = 0
    export_sum = 0
    contributing_rows = []
    for r in range(2, ws.max_row + 1):
        c_val = ws.cell(r, 3).value
        d_val = ws.cell(r, 4).value
        if isinstance(c_val, (int, float)):
            import_sum += c_val
        if isinstance(d_val, (int, float)):
            export_sum += d_val
        if isinstance(c_val, (int, float)) or isinstance(d_val, (int, float)):
            contributing_rows.append((r, c_val, d_val))
    sheet_summaries.append((s, import_sum, export_sum, len(contributing_rows)))

print("\nComputed per-sheet totals:")
for item in sheet_summaries:
    print(item)

# Inspect current target area before modification
ws_list = wb[summary_name]
print("\nCurrent LIST sheet rows 1:10, cols A:E before update:")
for r in range(1, min(ws_list.max_row, 10) + 1):
    print(r, [ws_list.cell(r, c).value for c in range(1, 6)])

# Clear existing detail area under header in columns A:E, but preserve header row
# Clear enough rows to cover prior data and current data + total
clear_to = max(ws_list.max_row, len(sheet_summaries) + 2)
for r in range(2, clear_to + 1):
    for c in range(1, 6):
        ws_list.cell(r, c).value = None

# Rewrite summary rows
for idx, (sheet_name, import_sum, export_sum, nrows) in enumerate(sheet_summaries, start=1):
    r = idx + 1
    ws_list.cell(r, 1).value = idx
    ws_list.cell(r, 2).value = sheet_name
    ws_list.cell(r, 3).value = import_sum
    ws_list.cell(r, 4).value = export_sum
    ws_list.cell(r, 5).value = f"=C{r}-D{r}"

# Total row
total_row = len(sheet_summaries) + 2
ws_list.cell(total_row, 2).value = "TOTAL"
ws_list.cell(total_row, 3).value = f"=SUM(C2:C{total_row-1})"
ws_list.cell(total_row, 4).value = f"=SUM(D2:D{total_row-1})"
ws_list.cell(total_row, 5).value = f"=C{total_row}-D{total_row}"

# Save
wb.save(output_path)
print("\nSaved to:", output_path, "exists:", os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames:
    # Try to restore by position
    for i, orig_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Restored sheetnames to:", original_sheetnames)

# Verification with formulas visible
wb_verify_formula = load_workbook(output_path, data_only=False)
wsv = wb_verify_formula[summary_name if summary_name in wb_verify_formula.sheetnames else original_sheetnames[-1]]
print("\nVerification (formulas view) LIST A:E rows 1 to total row:")
for r in range(1, total_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 6)])

# Verification with cached values
wb_verify_values = load_workbook(output_path, data_only=True)
verify_sheet_name = summary_name if summary_name in wb_verify_values.sheetnames else original_sheetnames[-1]
wsv2 = wb_verify_values[verify_sheet_name]
print("\nVerification (data_only=True) LIST A:E rows 1 to total row:")
for r in range(1, total_row + 1):
    print(r, [wsv2.cell(r, c).value for c in range(1, 6)])

output_spreadsheet = output_path
```
