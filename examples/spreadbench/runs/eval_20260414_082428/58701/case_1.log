import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws_entry = wb["Entry Tab"]
ws_table = wb["Table Tab"]

print("Original sheet names:", orig_sheetnames)

# Explicitly inspect target area before writing
for cell_ref in ["B1", "E1", "B2", "E2", "B3", "E3"]:
    print(f"Before {cell_ref} =", ws_entry[cell_ref].value)

# Determine true last relevant row from Entry Tab location column B
last_row = 1
for r in range(ws_entry.max_row, 1, -1):
    v = ws_entry.cell(r, 2).value
    if v is not None and str(v).strip() != "":
        last_row = r
        break
print("Detected last relevant Entry Tab row:", last_row)

# Print lookup table sample/current values
print("Table Tab values:")
for r in range(1, ws_table.max_row + 1):
    print(r, ws_table.cell(r, 1).value, ws_table.cell(r, 2).value)

# Write formulas only into designated Office Code column E for rows with locations
for r in range(2, last_row + 1):
    loc_val = ws_entry.cell(r, 2).value
    target = ws_entry.cell(r, 5)  # column E
    print(f"Row {r}: location={loc_val!r}, existing target={target.value!r}")
    if loc_val is not None and str(loc_val).strip() != "":
        # bounded lookup range for LibreOffice compatibility
        target.value = f'=IF(B{r}="","",VLOOKUP(B{r},\'Table Tab\'!$A$2:$B${ws_table.max_row},2,FALSE))'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload to check/restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename sheets back by position
    for i, original_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = original_name
    wb_after.save(outfile)
    print("Restored sheet names to:", wb_after.sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Entry Tab"]
print("Formulas in target cells:")
for r in range(2, last_row + 1):
    print(f"E{r} formula:", wsf[f"E{r}"].value)

# Verify evaluated values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Entry Tab"]
print("Evaluated target cells:")
verified = []
for r in range(2, last_row + 1):
    row_info = {
        "row": r,
        "location": wsv[f"B{r}"].value,
        "office_code": wsv[f"E{r}"].value,
    }
    verified.append(row_info)
    print(row_info)

# Basic assertions / sanity checks
assert "Entry Tab" in wb_values.sheetnames and "Table Tab" in wb_values.sheetnames
for item in verified:
    assert item["location"] is not None
    assert item["office_code"] is not None

output_spreadsheet = outfile
print("Ready to submit:", output_spreadsheet)
