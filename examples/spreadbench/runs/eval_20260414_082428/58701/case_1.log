import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames
print("Sheet names:", orig_sheetnames)

def sheet_summary(ws, sample_first=8, sample_last=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # detect non-empty rows and columns a bit more robustly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows), "first/last non-empty rows:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # print first 10 rows with headers-ish view
    for r in range(1, min(ws.max_row, sample_first) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    if ws.max_row > sample_first:
        start = max(sample_first + 1, ws.max_row - sample_last + 1)
        print("...")
        for r in range(start, ws.max_row + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}:", row_vals)

for s in wb.sheetnames:
    sheet_summary(wb[s])

# Focused inspection for likely relevant sheets
for target in ["Entry Tab", "Table Tab"]:
    if target in wb.sheetnames:
        ws = wb[target]
        print(f"\nFocused inspection for {target}")
        # print coordinates and values for first 15 rows x all used cols
        for r in range(1, min(ws.max_row, 15)+1):
            row_desc = []
            for c in range(1, ws.max_column+1):
                v = ws.cell(r,c).value
                if v is not None:
                    row_desc.append(f"{get_column_letter(c)}{r}={v!r}")
            print(" | ".join(row_desc))
