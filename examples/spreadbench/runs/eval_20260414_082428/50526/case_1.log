from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheet names:", orig_sheet_names)

def display(v):
    try:
        if hasattr(v, "text"):
            return f"FORMULA_OBJ:{v.text}"
    except Exception:
        pass
    return v

for ws in wb.worksheets:
    print("\n--- SHEET ---", ws.title)
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect likely header row among first 10 rows by max non-empty count
    best_row = None
    best_count = -1
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty > best_count:
            best_count = nonempty
            best_row = r
    print("Likely header row:", best_row)
    headers = [display(ws.cell(best_row, c).value) for c in range(1, ws.max_column + 1)]
    print("Headers:", headers)
    
    sample_rows = list(range(1, min(ws.max_row, 10) + 1))
    tail_start = max(1, ws.max_row - 4)
    tail_rows = list(range(tail_start, ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in sample_rows + tail_rows:
        if r not in seen:
            rows_to_show.append(r)
            seen.add(r)
    print("Sample rows:")
    for r in rows_to_show:
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, vals)

# Print specific cells/range referenced in instruction
for ws in wb.worksheets:
    print(f"\nRelevant area in sheet {ws.title}:")
    for r in range(1, min(ws.max_row, 15) + 1):
        row_vals = []
        for c in range(1, min(ws.max_column, 6) + 1):
            coord = f"{get_column_letter(c)}{r}"
            row_vals.append((coord, display(ws[coord].value)))
        print(row_vals)

    for coord in ["B6", "B9"]:
