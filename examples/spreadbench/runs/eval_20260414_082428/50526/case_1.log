Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Inspect full used range explicitly including column G
print("Used range values:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Print target/output area before modification
print("\nBefore modification B8:B15:")
for r in range(8, 16):
    print(r, ws[f"B{r}"].value)

# Write formula into B9:B14 (6 possible headers)
formula_template = '=IFERROR(INDEX($B$1:$G$1,MATCH(1,INDEX((INDEX($B$2:$G$3,MATCH($B$6,$A$2:$A$3,0),0)>0)*(COUNTIF(B$8:B8,$B$1:$G$1)=0),0),0)),"")'
for r in range(9, 15):
    ws[f"B{r}"] = formula_template.replace("B$8:B8", f"B$8:B{r-1}")

print("\nWritten formulas B9:B14:")
for r in range(9, 15):
    print(r, ws[f"B{r}"].value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
orig_names = wb.sheetnames
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for old, new in zip(wb2.sheetnames, orig_names):
        wb2[old].title = new
    wb2.save(out_path)
    print("Renamed sheets back to original:", orig_names)

# Verify cached values
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_names[0]]
print("\nVerified current lookup B6:", wsv["B6"].value)
print("Verified outputs B9:B14:")
verified_vals = []
for r in range(9, 15):
    v = wsv[f"B{r}"].value
    verified_vals.append(v)
    print(r, v)

output_spreadsheet = out_path
