```repl
import os, shutil
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Font
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Merged ranges before:", [str(r) for r in ws.merged_cells.ranges])

# Inspect detailed row/cell info for A:H
for r in range(1, 9):
    row_info = []
    for c in range(1, 9):
        cell = ws.cell(r, c)
        row_info.append({
            "coord": cell.coordinate,
            "value": cell.value,
            "fmt": cell.number_format,
            "bold": cell.font.bold,
            "color": cell.font.color.type + ":" + str(cell.font.color.rgb) if cell.font.color and cell.font.color.type else None
        })
    print(f"Row {r} detail:")
    for item in row_info:
        print(item)

# Determine data rows in A:D
data_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    if any(v is not None for v in vals):
        data_rows.append(r)
print("Data rows A:D:", data_rows)

# Group by ID preserving order of first appearance
groups = []
seen = {}
for r in data_rows:
    idv = ws.cell(r, 1).value
    if idv is None:
        continue
    if idv not in seen:
        seen[idv] = {"id": idv, "rows": [], "sum_amount": 0, "first_row": r}
        groups.append(seen[idv])
    seen[idv]["rows"].append(r)
    amt = ws.cell(r, 4).value
    if amt is not None:
        seen[idv]["sum_amount"] += int(round(float(amt)))

print("Groups:")
for g in groups:
    print(g["id"], g["rows"], g["sum_amount"])

# Capture F values from merged areas before unmerging
merged_f_values = []
for mr in list(ws.merged_cells.ranges):
    min_col, min_row, max_col, max_row = mr.bounds
    if min_col == 6 and max_col == 6:  # merged in column F
        val = ws.cell(min_row, min_col).value
        merged_f_values.append({"range": str(mr), "row": min_row, "value": val})
print("Column F merged values:", merged_f_values)

# Unmerge all merged cells
for mr in list(ws.merged_cells.ranges):
    ws.unmerge_cells(str(mr))
print("Merged ranges after unmerge:", [str(r) for r in ws.merged_cells.ranges])

# Apply dedup logic in A:D only:
# keep first row of each ID with summed amount, clear subsequent duplicate rows in A:D
date_fmt_source = ws["C2"].number_format
print("Reference date format:", date_fmt_source)

for g in groups:
    first = g["rows"][0]
    # keep A:C from first row as-is, update Amount in D
    ws.cell(first, 4).value = int(g["sum_amount"])
    # preserve/ensure integer-like formatting on amount
    ws.cell(first, 4).number_format = "0"
    # keep date format same
    ws.cell(first, 3).number_format = ws.cell(first, 3).number_format or date_fmt_source
    
    # clear duplicate rows A:D only
    for dup_r in g["rows"][1:]:
        for c in range(1, 5):
            ws.cell(dup_r, c).value = None
            # keep neutral font in cleared cells too
            ws.cell(dup_r, c).font = copy(ws.cell(first, c).font)

# Put former merged F values into first row of first and last duplicate-ID groups
dup_groups = [g for g in groups if len(g["rows"]) > 1]
print("Duplicate groups:", [(g["id"], g["rows"][0]) for g in dup_groups])

# Based on instruction and notes, place the two F values in same row as first and last duplicated ID number
if len(merged_f_values) == 2 and len(dup_groups) >= 2:
    dup_groups_sorted = sorted(dup_groups, key=lambda g: g["rows"][0])
    target_rows = [dup_groups_sorted[0]["rows"][0], dup_groups_sorted[-1]["rows"][0]]
    for info, target_row in zip(sorted(merged_f_values, key=lambda x: x["row"]), target_rows):
        ws.cell(target_row, 6).value = info["value"]
        print(f"Placed F value {info['value']} into F{target_row}")

# Clear old extra F values below within those former merged ranges except top cells already targeted
for info in merged_f_values:
    rng = info["range"]
    # since unmerged, clear all rows in original range other than target placements
    # ranges are vertical, like F2:F3
    import re
    m = re.match(r"F(\d+):F(\d+)", rng)
    if m:
        r1, r2 = int(m.group(1)), int(m.group(2))
        for rr in range(r1, r2 + 1):
            # if a value remains in a lower row of prior merged range, clear it
            if rr != r1 and ws.cell(rr, 6).value == info["value"]:
                ws.cell(rr, 6).value = None

# Format all table data in A:D non-bold, black font; preserve existing other font attrs where possible
for r in range(1, ws.max_row + 1):
    for c in range(1, 5):
        cell = ws.cell(r, c)
        cell.font = copy(cell.font)
        cell.font = cell.font.copy(bold=False, color="000000")
        if c == 4 and r >= 2 and cell.value is not None and isinstance(cell.value, (int, float)):
            cell.number_format = "0"

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate and then restore sheet names if needed
