import os
from openpyxl import load_workbook

# Re-inspect the relevant target area closely
wb2 = load_workbook(input_spreadsheet)
ws = wb2["Sheet1"]

print("Focused inspection rows 14-30 before change:")
for r in range(14, 31):
    print(r, {"A": ws.cell(r, 1).value, "B": ws.cell(r, 2).value})

# Apply fill-down logic in column B based on column A, preserving existing correct values where possible
last_seen = None
changes = []

for r in range(2, ws.max_row + 1):  # skip header
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    
    if a not in (None, ""):
        last_seen = a
        desired = a
    else:
        desired = last_seen
    
    # Only write if we actually have a value to propagate
    if desired is not None:
        if b != desired:
            ws.cell(r, 2).value = desired
            changes.append((r, b, desired))

print(f"Number of B-cell changes: {len(changes)}")
print("First few changes:", changes[:10])

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb2.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
original_names = ["Sheet1"]
if wb_after.sheetnames != original_names and len(wb_after.sheetnames) == len(original_names):
    for i, s in enumerate(wb_after.worksheets):
        s.title = original_names[i]
    wb_after.save(out_path)
    print("Renamed sheets back to original names:", original_names)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["Sheet1"]

print("Verification rows 2-30 after change:")
for r in range(2, 31):
    print(r, {"A": wsv.cell(r, 1).value, "B": wsv.cell(r, 2).value})

output_spreadsheet = out_path
