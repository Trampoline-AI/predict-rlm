def sheet_summary(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\nSheet '{ws.title}': rows={max_row}, cols={max_col}")
    print("Headers row 1:", headers)
    # print first 10 rows
