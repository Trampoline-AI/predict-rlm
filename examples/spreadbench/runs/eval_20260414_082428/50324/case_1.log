import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws_data = wb["Datensatz"]
ws_an = wb["Analyse"]

# Inspect target cells current values/formulas/formats
print("Target headers row 4:", [ws_an.cell(4,c).value for c in range(3,12)])
for r in range(5,13):
    vals = []
    for c in range(3,12):
        cell = ws_an.cell(r,c)
        vals.append((f"{get_column_letter(c)}{r}", cell.value, cell.number_format))
    print(vals)

# Compute sample cross-sell percentages in Python for validation
data_rows = list(range(4, 34))   # customers 1-30
data_cols = list(range(4, 12))   # product 1-8

def pct_both(col1, col2):
    both = 0
    for r in data_rows:
        v1 = ws_data.cell(r, col1).value or 0
        v2 = ws_data.cell(r, col2).value or 0
        if v1 > 0 and v2 > 0:
            both += 1
    return both / len(data_rows), both

samples = [(4,4), (4,5), (5,4), (10,11), (11,11)]
for c1, c2 in samples:
    pct, both = pct_both(c1, c2)
    print(f"Products {c1-3} & {c2-3}: both={both}, pct={pct}")

# Write formulas into Analyse!D5:K12 and fill color
fill = PatternFill(start_color="F2F2F2", end_color="F2F2F2", fill_type="solid")

for r in range(5, 13):      # target row products
    for c in range(4, 12):  # target col products
        cell = ws_an.cell(r, c)
        row_prod_col = r - 1   # maps 5->4, 12->11
        col_prod_col = c       # maps D->4, K->11
        if row_prod_col == col_prod_col:
            cell.value = "=1"
        else:
            col_letter_1 = get_column_letter(row_prod_col)
            col_letter_2 = get_column_letter(col_prod_col)
            cell.value = f'=COUNTIFS(Datensatz!${col_letter_1}$4:${col_letter_1}$33,">0",Datensatz!${col_letter_2}$4:${col_letter_2}$33,">0")/COUNTA(Datensatz!$C$4:$C$33)'
        cell.number_format = "0.#########"
        cell.fill = fill

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != ["Datensatz", "Analyse"]:
    # rename by position if names changed
    for ws, expected in zip(wb_after.worksheets, ["Datensatz", "Analyse"]):
        ws.title = expected
    wb_after.save(out_path)
    print("Renamed sheets back to original names")

# Verify with data_only=True
