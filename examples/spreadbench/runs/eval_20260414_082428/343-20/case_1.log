```repl
import os
from collections import Counter
from copy import copy
from datetime import datetime
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws_src = wb["Imported Data"]
ws_dst = wb["Duplicates"]

print("Using sheets:", wb.sheetnames)
print("Source headers:", [ws_src.cell(1, c).value for c in range(1, ws_src.max_column + 1)])
print("Target headers before write:", [ws_dst.cell(1, c).value for c in range(1, ws_dst.max_column + 1)])

# Show existing target cells before overwriting
print("Existing Duplicates rows before write:")
for r in range(1, ws_dst.max_row + 1):
    vals = [ws_dst.cell(r, c).value for c in range(1, ws_dst.max_column + 1)]
    if any(v is not None for v in vals):
        print(r, vals)

# Build duplicate groups from column C (Reference), excluding blanks, using actual data rows only
refs = []
data_rows = []
for r in range(2, ws_src.max_row + 1):
    row_vals = [ws_src.cell(r, c).value for c in range(1, ws_src.max_column + 1)]
    if any(v is not None for v in row_vals):
        data_rows.append(r)
        ref = ws_src.cell(r, 3).value
        refs.append(ref)

counter = Counter(v for v in refs if v not in (None, ""))

# Keep first occurrence only for each duplicated reference, matching the example sheet
selected_rows = []
seen_dup_refs = set()
for r in data_rows:
    ref = ws_src.cell(r, 3).value
    if ref not in (None, "") and counter[ref] > 1 and ref not in seen_dup_refs:
        seen_dup_refs.add(ref)
        selected_rows.append(r)

print("Selected first-occurrence source rows for duplicated references:", selected_rows)
for r in selected_rows:
    print(" selected", r, [ws_src.cell(r, c).value for c in range(1, ws_src.max_column + 1)])

def sort_date_key(v):
    if isinstance(v, datetime):
        return v
    if isinstance(v, str):
        for fmt in ("%d/%m/%Y", "%m/%d/%Y", "%Y-%m-%d"):
            try:
                return datetime.strptime(v, fmt)
            except Exception:
                pass
    return datetime.max

selected_rows = sorted(
    selected_rows,
    key=lambda r: (
        float(ws_src.cell(r, 5).value) if ws_src.cell(r, 5).value is not None else float("inf"),
        sort_date_key(ws_src.cell(r, 4).value),
    )
)

print("Selected rows after sort by Balance asc, Invoiced Date asc:", selected_rows)
for r in selected_rows:
    print(" sorted", r, [ws_src.cell(r, c).value for c in range(1, ws_src.max_column + 1)])

# Clear existing data rows in Duplicates (preserve header row and sheet structure)
for r in range(2, ws_dst.max_row + 1):
    for c in range(1, ws_dst.max_column + 1):
        cell = ws_dst.cell(r, c)
        cell.value = None
        cell._style = copy(ws_src.cell(2, c)._style) if ws_src.max_row >= 2 else copy(cell._style)

# Ensure header matches source header exactly, but preserve existing structure
for c in range(1, ws_src.max_column + 1):
    ws_dst.cell(1, c).value = ws_src.cell(1, c).value
    ws_dst.cell(1, c)._style = copy(ws_src.cell(1, c)._style)
    if ws_src.column_dimensions[ws_src.cell(1, c).column_letter].width is not None:
        ws_dst.column_dimensions[ws_src.cell(1, c).column_letter].width = ws_src.column_dimensions[ws_src.cell(1, c).column_letter].width

# Copy selected entire rows (existing used columns) with styles
for out_r, src_r in enumerate(selected_rows, start=2):
    for c in range(1, ws_src.max_column + 1):
        src_cell = ws_src.cell(src_r, c)
        dst_cell = ws_dst.cell(out_r, c)
        dst_cell.value = src_cell.value
        dst_cell._style = copy(src_cell._style)
        dst_cell.number_format = src_cell.number_format
        dst_cell.font = copy(src_cell.font)
        dst_cell.fill = copy(src_cell.fill)
        dst_cell.border = copy(src_cell.border)
        dst_cell.alignment = copy(src_cell.alignment)
        dst_cell.protection = copy(src_cell.protection)

# Delete any leftover old rows beyond current result range by blanking them
for r in range(2 + len(selected_rows), ws_dst.max_row + 1):
    for c in range(1, ws_dst.max_column + 1):
        ws_dst.cell(r, c).value = None

wb.save(output_path)
print("Saved to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position back to original
    for i, expected in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify output with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Duplicates"]

print("Duplicates sheet after write:")
for r in range(1, max(5, len(selected_rows) + 1) + 1):
    vals = [wsv.cell(r, c).value for c in range(1, ws_src.max_column + 1)]
    print(r, vals)

print("Target cells check:")
for r in range(2, 2 + len(selected_rows)):
    print(
        r,
        {
            "A": wsv[f"A{r}"].value,
            "B": wsv[f"B{r}"].value,
            "C": wsv[f"C{r}"].value,
            "D": wsv[f"D{r}"].value,
            "E": wsv[f"E{r}"].value,
        }
    )

# Also verify formatting/alignment from non-data_only workbook
wb_verify_fmt = load_workbook(output_path)
wsf = wb_verify_fmt["Duplicates"]
print("Date cell formatting/alignment verification:")
for r in range(2, 2 + len(selected_rows)):
    c = wsf[f"D{r}"]
    print(r, c.value, c.number_format, c.alignment.horizontal, c.alignment.vertical)

final_output_path = output_path
