import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Inspect all nonblank data rows in A:F and summarize FY occurrences
data_rows = []
for r in range(3, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    e = ws.cell(r, 5).value
    f = ws.cell(r, 6).value
    if any(v is not None for v in [a,b,c,d,e,f]):
        data_rows.append((r,a,b,c,d,e,f))

print("Total nonblank rows in A:F from row 3 down:", len(data_rows))
print("Sample first 12 nonblank rows:")
for row in data_rows[:12]:
    print(row)
print("Sample last 8 nonblank rows:")
for row in data_rows[-8:]:
    print(row)

# Keep only actual detail rows with FY and numeric C:D:E:F, excluding subtotal rows (where FY blank)
detail_rows = []
for r,a,b,c,d,e,f in data_rows:
    if b is not None and isinstance(c, (int,float)) and isinstance(d, (int,float)) and isinstance(e, (int,float)) and isinstance(f, (int,float)):
        detail_rows.append((r,a,b,float(c),float(d),float(e),float(f)))

from collections import defaultdict
by_fy = defaultdict(list)
for item in detail_rows:
    by_fy[item[2]].append(item)

print("\nFY counts and weighted averages from Python sanity check:")
for fy in sorted(by_fy):
    rows = by_fy[fy]
    total_gen = sum(x[3] for x in rows)
    wavg_d = sum(x[3]*x[4] for x in rows)/total_gen
    wavg_e = sum(x[3]*x[5] for x in rows)/total_gen
    wavg_f = sum(x[3]*x[6] for x in rows)/total_gen
    print(fy, "count", len(rows), "sum_gen", round(total_gen,2), 
          "wavg D/E/F", round(wavg_d,6), round(wavg_e,6), round(wavg_f,6))

# Print exact target labels and any existing formulas around them
print("\nTarget labels H2:L7:")
for r in range(2, 8):
    print(r, [ws.cell(r,c).value for c in range(8,13)])

# Write formulas only in J3:L6
last_row = ws.max_row
for r in range(3, 7):
    # Weighted average by FY in Hr, weight = col C, values = D/E/F
    ws[f"J{r}"] = f'=IFERROR(SUMPRODUCT(($B$3:$B${last_row}=H{r})*($C$3:$C${last_row})*($D$3:$D${last_row}))/SUMIF($B$3:$B${last_row},H{r},$C$3:$C${last_row}),"")'
    ws[f"K{r}"] = f'=IFERROR(SUMPRODUCT(($B$3:$B${last_row}=H{r})*($C$3:$C${last_row})*($E$3:$E${last_row}))/SUMIF($B$3:$B${last_row},H{r},$C$3:$C${last_row}),"")'
    ws[f"L{r}"] = f'=IFERROR(SUMPRODUCT(($B$3:$B${last_row}=H{r})*($C$3:$C${last_row})*($F$3:$F${last_row}))/SUMIF($B$3:$B${last_row},H{r},$C$3:$C${last_row}),"")'

print("\nWritten formulas J3:L6:")
for r in range(3,7):
    print(r, [ws.cell(r,c).value for c in range(10,13)])

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore original sheet names if needed
orig_names = wb.sheetnames[:]
wb2 = load_workbook(out_path)
if wb2.sheetnames != orig_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_names)
    for i, old_name in enumerate(orig_names):
        wb2.worksheets[i].title = old_name
    wb2.save(out_path)

# Verify with cached values
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_names[0]]
print("\nVerified cached values J3:L6:")
for r in range(3,7):
    print(r, [wsv.cell(r,c).value for c in range(10,13)])
