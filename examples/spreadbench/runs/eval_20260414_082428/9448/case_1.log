import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb["Data"]

print("Inspect Data rows 7:18, cols A:U")
for r in range(7, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 22)]
    print(r, vals)

print("\nCurrent U column values/formulas:")
for r in range(8, ws.max_row + 1):
    print(r, ws[f"U{r}"].value)

print("\nMonth headers I7:T7:")
print([ws.cell(7, c).value for c in range(9, 21)])

# Identify actual data rows based on item ref / code columns G/H or sales presence in I:T
data_rows = []
for r in range(9, ws.max_row + 1):
    g = ws.cell(r, 7).value
    h = ws.cell(r, 8).value
    sales = [ws.cell(r, c).value for c in range(9, 21)]
    if g is not None or h is not None or any(v is not None for v in sales):
        data_rows.append(r)
        print(f"row {r}: G={g!r}, H={h!r}, sales={sales}")
print("data_rows:", data_rows)

# Write formulas in U for all data rows, only if blank or to replace missing answers
for r in data_rows:
    formula = f'=LOOKUP(2,1/(I{r}:T{r}>0),$I$7:$T$7)'
    print(f"Writing U{r} = {formula}")
    ws[f"U{r}"] = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("Saved to", out_path)

# recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# restore sheet names if recalc changed them
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
orig_names = ["Data", "MetaData"]
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for idx, name in enumerate(orig_names):
        wb2.worksheets[idx].title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify formulas and cached values
