from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

# Confirm current target cells before writing
print("Before writing L7:L9:")
for r in range(7, 10):
    print(r, {"J": ws[f"J{r}"].value, "K": ws[f"K{r}"].value, "L": ws[f"L{r}"].value})

# Write formulas only to the intended target cells L7:L9
# Use bounded ranges exactly as referenced by the instruction.
for r in range(7, 10):
    formula = f'=IF(OR(J{r}="",K{r}=""),"",INDEX($F$2:$F$23,MATCH(1,INDEX(($D$2:$D$23=J{r})*($B$2:$B$23=K{r}),0),0)))'
    ws[f"L{r}"] = formula
    print(f"Wrote {ws[f'L{r}'].coordinate}: {ws[f'L{r}'].value}")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if changed
