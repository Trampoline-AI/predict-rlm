import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[wb.sheetnames[0]]

# Identify rows to delete based on the verified rule:
# delete row r and r+1 when A[r] == "Line No" and A[r+1] is blank
rows_to_delete = set()
for r in range(1, ws.max_row):
    cur = ws.cell(r, 1).value
    nxt = ws.cell(r + 1, 1).value
    if isinstance(cur, str) and cur.strip() == "Line No":
        if nxt is None or (isinstance(nxt, str) and nxt.strip() == ""):
            rows_to_delete.update([r, r + 1])

print("Rows to delete:", sorted(rows_to_delete))

# Snapshot all cell values so we can rewrite compactly
all_rows = []
for r in range(1, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    all_rows.append(row_vals)

kept_rows = [row for idx, row in enumerate(all_rows, start=1) if idx not in rows_to_delete]
print("Original row count:", len(all_rows), "Kept row count:", len(kept_rows))

# Rewrite kept rows at top
for r_idx, row_vals in enumerate(kept_rows, start=1):
    for c_idx, val in enumerate(row_vals, start=1):
        ws.cell(r_idx, c_idx).value = val

# Clear remaining rows
for r in range(len(kept_rows) + 1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas/cached values
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if altered
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheet_names)
    for i, old_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Final sheet names:", wb_check.sheetnames)

# Verify output with data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

def vals(r, cmax=5):
    return [wsv.cell(r, c).value for c in range(1, cmax + 1)]

print("Verified rows 1-16 A:E after modification:")
for r in range(1, 17):
    print(r, vals(r, 5))

# Additional sanity checks
print("Row 2:", vals(2, 5))
print("Row 9:", vals(9, 5))
print("Nonblank col A rows after rewrite:",
      [(r, wsv.cell(r,1).value) for r in range(1, wsv.max_row + 1)
       if wsv.cell(r,1).value is not None and not (isinstance(wsv.cell(r,1).value, str) and wsv.cell(r,1).value.strip() == "")])

final_output_path = output_path
