```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Reconfirm target layout briefly
print("Sheet:", ws.title)
print("Country list:", [ws[f"A{r}"].value for r in range(2, 4)])
print("Headers B11:H11:", [ws.cell(11, c).value for c in range(2, 9)])
print("Before:", ws["I12"].value, ws["I13"].value)

# Determine country list extent: contiguous nonblank values below A1 until first blank
country_start = 2
country_end = country_start
while country_end <= ws.max_row and ws.cell(country_end, 1).value not in (None, ""):
    country_end += 1
country_end -= 1

# Determine company row extent: contiguous nonblank company names below A11
company_start = 12
company_end = company_start
while company_end <= ws.max_row and ws.cell(company_end, 1).value not in (None, ""):
    company_end += 1
company_end -= 1

print("country range:", f"$A${country_start}:$A${country_end}")
print("company rows:", company_start, "to", company_end)

# Write formulas into existing target column I
for r in range(company_start, company_end + 1):
    formula = f'=SUMPRODUCT(COUNTIF($A${country_start}:$A${country_end},B$11:H$11)*(B{r}:H{r}>0))'
    ws.cell(r, 9).value = formula
    print(f"I{r} formula ->", formula)

wb.save(output_path)
print("Saved to", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(output_path)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb2.sheetnames, "-> restoring", orig_sheet_names)
    for i, name in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(output_path)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("Stored formulas:")
print("I12:", wsf["I12"].value)
print("I13:", wsf["I13"].value)

wb_val = load_workbook(output_path, data_only=True)
wsv = wb_val[orig_sheet_names[0]]
print("Verified values:")
for coord in ["I12", "I13"]:
    print(coord, "=", wsv[coord].value)

output_spreadsheet = output_path
```
