import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load source workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Reconfirm exact target area and source data
source_vals = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None and str(v) != "":
        source_vals.append(v)

print("Source non-empty values in A2:Amax:", len(source_vals))
chunks = [source_vals[i:i+7] for i in range(0, len(source_vals), 7)]
print("Chunk lengths:", [len(ch) for ch in chunks])

# Print current target area before changes
print("Current target area B1:H10 before writing:")
for r in range(1, 11):
    print(r, [ws.cell(r, c).value for c in range(2, 9)])

# Write output starting at B2, one chunk per row
start_row = 2
start_col = 2  # B
written_rows = 0
for i, chunk in enumerate(chunks):
    if len(chunk) < 7:
        print(f"Skipping incomplete trailing chunk {i+1}: {chunk}")
        continue
    target_row = start_row + i
    for j, val in enumerate(chunk):
        cell = ws.cell(target_row, start_col + j)
        before = cell.value
        # preserve if already correct, else write literal value
        if before != val:
            cell.value = val
    written_rows += 1

print(f"Wrote/confirmed {written_rows} rows into B:H starting at row 2")

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # Rename sheets back by position
    for idx, original_name in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = original_name
    wb_after.save(outfile)
    print("Renamed sheets back to original:", original_sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]

print("Verified target cells B1:H6 (data_only=True):")
for r in range(1, 7):
    vals = [wsv.cell(r, c).value for c in range(2, 9)]
    print(r, vals)

# Sanity-check against expected chunks
issues = []
for i, chunk in enumerate(chunks[:written_rows], start=0):
    tr = start_row + i
    actual = [wsv.cell(tr, c).value for c in range(2, 9)]
    expected = chunk
    if actual != expected:
        issues.append((tr, expected, actual))

print("Mismatch count:", len(issues))
if issues:
    for item in issues[:10]:
        print("Mismatch:", item)

# Also show formulas/raw values from normal load for target area
wb_raw = load_workbook(outfile, data_only=False)
ws_raw = wb_raw[original_sheetnames[0]]
print("Raw target area B1:H6 after write:")
for r in range(1, 7):
    print(r, [ws_raw.cell(r, c).value for c in range(2, 9)])

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
