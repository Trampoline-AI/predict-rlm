import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook path:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols if max_cols is not None else ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 values / headers:", headers)
    
    # Determine a practical visible range
    visible_cols = min(ws.max_column, 10)
    print("First 10 rows (up to 10 cols):")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, visible_cols))
    
    print("Last 5 rows (up to 10 cols):")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, visible_cols))
    
    # Print relevant A/B/C area more deeply since instruction references column A and start in B2
    print("Relevant area A1:J20:")
    for r in range(1, min(ws.max_row, 20) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 10)+1)]
        print(r, vals)
