import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Blad1"]

# Determine actual data extent in column A
last_data_row = 1
for r in range(ws.max_row, 0, -1):
    if ws.cell(r, 1).value not in (None, ""):
        last_data_row = r
        break

print("Last non-empty row in column A:", last_data_row)

# Based on inspected layout and instruction examples, use expanding average from row 11 onward.
start_row = 11
end_row = last_data_row

# Show pre-write target area
print("Before writing B11:B{}:".format(end_row))
for r in range(start_row, end_row + 1):
    print(r, "A=", ws[f"A{r}"].value, "B=", ws[f"B{r}"].value, "fmt=", ws[f"B{r}"].number_format)

# Write formulas only where source exists
for r in range(start_row, end_row + 1):
    if ws[f"A{r}"].value not in (None, ""):
        ws[f"B{r}"] = f'=AVERAGE($A$11:A{r})'
        ws[f"B{r}"].number_format = '0.000'

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # Rename by position back to original names
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with cached values
wb_val = load_workbook(output_path, data_only=True)
ws_val = wb_val[orig_sheet_names[0]]

print("Verified target cells B11:B{} after recalculation:".format(end_row))
for r in range(start_row, end_row + 1):
    print(r, "A=", ws_val[f"A{r}"].value, "B=", ws_val[f"B{r}"].value)

# Also verify formulas remain in normal workbook
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("Formula strings in B11:B{}:".format(end_row))
for r in range(start_row, end_row + 1):
    print(r, ws_formula[f"B{r}"].value, ws_formula[f"B{r}"].number_format)

final_output_path = output_path
