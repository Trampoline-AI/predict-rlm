from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Print rows 1-25 across all 33 columns compactly to verify the sample/output pattern
all_rows = []
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    all_rows.append(vals)

print("Rows 1-25 summary with key cols A,D,H,S,AE,AF,AG:")
key_cols = [1,4,8,19,31,32,33]
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in key_cols]
    print(r, vals)

# Compare source block rows 2:7 to output block rows 17:25
source_rows = [[ws.cell(r, c).value for c in range(1, ws.max_column+1)] for r in range(2, 8)]
expanded = []
for row in source_rows:
    count = row[32]  # AG
    if isinstance(count, (int, float)):
        expanded.extend([row[:] for _ in range(int(count))])
print("\nSource rows:", len(source_rows), "Expected expanded rows from AG:", len(expanded))

output_rows = [[ws.cell(r, c).value for c in range(1, ws.max_column+1)] for r in range(17, 26)]
print("Existing bottom output rows:", len(output_rows))
matches = expanded == output_rows
print("Does existing bottom block exactly match expansion logic?", matches)
if not matches:
    for i, (a,b) in enumerate(zip(expanded, output_rows), start=1):
        if a != b:
            print("First mismatch at expanded row", i, "expected", a, "got", b)
            break

# Determine source rows by scanning contiguous non-empty rows after header until first blank in col A:AG
data_start = 2
data_end = data_start - 1
for r in range(data_start, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if all(v is None for v in row_vals):
        break
    data_end = r
print("Detected source block rows:", data_start, "to", data_end)

# Build desired final workbook preserving same pattern: source, one blank block as existing, repeated header, expanded output
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
source_rows = [[ws.cell(r, c).value for c in range(1, ws.max_column + 1)] for r in range(data_start, data_end + 1)]
expanded_rows = []
for row in source_rows:
    cnt = row[32]
    try:
        n = int(cnt) if cnt is not None else 0
    except Exception:
        n = 0
    if n <= 0:
        continue
    for _ in range(n):
        expanded_rows.append(list(row))

print("Expanded row count to write:", len(expanded_rows))

# Rewrite sheet cleanly to match demonstrated structure
# Clear existing used range
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Write top header + source data
for c, v in enumerate(headers, start=1):
    ws.cell(1, c).value = v
for i, row in enumerate(source_rows, start=2):
    for c, v in enumerate(row, start=1):
        ws.cell(i, c).value = v

# Preserve existing separation style: blank rows until row 15, repeated header at row 16
repeat_header_row = 16
for c, v in enumerate(headers, start=1):
    ws.cell(repeat_header_row, c).value = v

# Write expanded rows starting row 17
for i, row in enumerate(expanded_rows, start=17):
    for c, v in enumerate(row, start=1):
        ws.cell(i, c).value = v

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate and then verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != wb.sheetnames:
    # rename back if needed
    for idx, old_name in enumerate(wb.sheetnames):
        wb2.worksheets[idx].title = old_name
    wb2.save(out_path)
    print("Renamed sheets back to original names:", wb.sheetnames)

# Final verification with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[wb.sheetnames[0]]
print("\nVerification target rows 16-25 key cols:")
for r in range(16, 26):
    vals = [wsv.cell(r, c).value for c in key_cols]
    print(r, vals)

# Store path for submit
final_output_spreadsheet = out_path
print("Final output path ready:", final_output_spreadsheet)
