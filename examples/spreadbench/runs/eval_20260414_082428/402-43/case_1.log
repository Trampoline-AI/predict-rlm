from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def sheet_summary(ws, sample_rows=8):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}: {h!r}")
    # Also inspect row 2 in case headers are there
    row2 = [ws.cell(2, c).value for c in range(1, min(ws.max_column, 40) + 1)]
    print("Row 2 first 40 cols:", row2)

    # First sample rows
    first_end = min(ws.max_row, sample_rows + 1)
    print(f"\nFirst {first_end-1} data rows (showing first 35 cols):")
    for r in range(1, first_end + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 35) + 1)]
        print(f"Row {r}: {vals}")

    # Last sample rows
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast {ws.max_row - start_last + 1} rows (showing first 35 cols):")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 35) + 1)]
        print(f"Row {r}: {vals}")

    # Specific AG inspection
    ag_col = column_index_from_string("AG")
    if ws.max_column >= ag_col:
        print("\nColumn AG values (first 15 rows and last 10 rows):")
        for r in range(1, min(ws.max_row, 15) + 1):
            print(f"AG{r} =", ws.cell(r, ag_col).value)
        if ws.max_row > 15:
            for r in range(max(16, ws.max_row - 9), ws.max_row + 1):
                print(f"AG{r} =", ws.cell(r, ag_col).value)
        # print current row around AG and neighboring columns
        start_c = max(1, ag_col - 3)
        end_c = min(ws.max_column, ag_col + 3)
        print("\nRows with neighboring cols around AG (first 10 rows):")
        hdrs = [ws.cell(1, c).value for c in range(start_c, end_c + 1)]
        print("Cols", [get_column_letter(c) for c in range(start_c, end_c + 1)], hdrs)
        for r in range(1, min(ws.max_row, 10) + 1):
            vals = [ws.cell(r, c).value for c in range(start_c, end_c + 1)]
            print(f"Row {r}: {vals}")
    else:
        print("Sheet has fewer than AG columns.")

for ws in wb.worksheets:
    sheet_summary(ws)
