import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Reload workbook for editing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Calc"]

# Inspect exact target region and current target cell properties
print("Original sheet names:", orig_sheetnames)
print("Calc!B7 before:", ws["B7"].value)
for r in range(6, 11):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    print(f"Row {r}:", vals)

# Write formula into exact target cell B7
formula_b7 = '=IFERROR(IF(VLOOKUP($A$10,Supplier_1!$A$2:$D$10,1,FALSE)=$A$10,"Supplier_1",""),IFERROR(IF(VLOOKUP($A$10,Supplier_2!$A$2:$D$10,1,FALSE)=$A$10,"Supplier_2",""),IFERROR(IF(VLOOKUP($A$10,Supplier_3!$A$2:$D$10,1,FALSE)=$A$10,"Supplier_3",""),"")))'
ws["B7"] = formula_b7
print("Calc!B7 formula written:", ws["B7"].value)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and ensure sheet names preserved
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename back if altered
    if len(wb_check.sheetnames) == len(orig_sheetnames):
        for old_name, desired_name in zip(wb_check.sheetnames, orig_sheetnames):
            if old_name != desired_name:
                wb_check[old_name].title = desired_name
        wb_check.save(outfile)
        print("Renamed sheets back to:", orig_sheetnames)

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Calc"]
print("Verified formula in Calc!B7:", wsf["B7"].value)

# Verify evaluated value
wb_data = load_workbook(outfile, data_only=True)
wsd = wb_data["Calc"]
print("Verified data-only Calc!A10:", wsd["A10"].value)
print("Verified data-only Calc!B7:", wsd["B7"].value)
print("Verified data-only Calc!B10:F10:", [wsd.cell(10, c).value for c in range(2, 7)])

output_spreadsheet = outfile
