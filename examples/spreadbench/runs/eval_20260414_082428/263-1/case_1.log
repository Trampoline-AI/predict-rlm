        if any(v is not None and v != "" for v in vals):
            nonempty_cols.append(c)
    print("Non-empty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("Non-empty columns:", [f"{get_column_letter(c)}" for c in nonempty_cols])
    
    # print first 10 rows and last 5 non-empty rows, trimmed to used columns
