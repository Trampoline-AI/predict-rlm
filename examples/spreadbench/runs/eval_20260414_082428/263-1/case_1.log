infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Target area before writing:")
for r in range(1, 6):
    print(r, [ws.cell(r, c).value for c in range(7, 10)])

# Determine practical dynamic bound from actual data, with extra room
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 4)):
        last_data_row = r
        break
formula_end_row = max(last_data_row + 200, 1000)  # dynamic enough for future additions

print("Detected last data row in A:C:", last_data_row)
print("Using formula range end row:", formula_end_row)

# Write dynamic formulas into H2:H5 based on material names in G2:G5
for r in range(2, 6):
    material = ws[f"G{r}"].value
    existing = ws[f"H{r}"].value
    unit = ws[f"I{r}"].value
    print(f"Row {r} before -> material={material!r}, H={existing!r}, I={unit!r}")
    if material not in (None, ""):
        formula = (
            f'=SUMPRODUCT(($A$2:$A${formula_end_row}=G{r})*'
            f'($B$2:$B${formula_end_row})*($C$2:$C${formula_end_row}))'
        )
        ws[f"H{r}"] = formula
        print(f"Row {r} formula written:", formula)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename sheets back by position
    for idx, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verification with formulas visible
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula[orig_sheet_names[0]]
print("\nVerification of formulas in target cells:")
for r in range(2, 6):
    print(f"H{r} formula/value:", wsf[f"H{r}"].value)

# Verification with calculated values
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[orig_sheet_names[0]]
print("\nVerification of calculated target area G1:I5:")
for r in range(1, 6):
    vals = [wsv.cell(r, c).value for c in range(7, 10)]
    print(f"Row {r}: {vals}")

# Sanity check against Python-computed totals from source data
totals = {}
for r in range(2, wsv.max_row + 1):
    m = wsv.cell(r, 1).value
    w = wsv.cell(r, 2).value
    h = wsv.cell(r, 3).value
    if m not in (None, "") and w not in (None, "") and h not in (None, ""):
        totals[m] = totals.get(m, 0) + float(w) * float(h)

print("\nExpected totals from source data:", totals)
