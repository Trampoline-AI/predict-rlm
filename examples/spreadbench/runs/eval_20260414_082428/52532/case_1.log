import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing, H column contents:")
for r in range(1, ws.max_row + 1):
    print(r, ws[f"H{r}"].value)

# Identify data extent
start_row = 2
end_row = ws.max_row
start_col = 2  # B
end_col = 7    # G

# Write formulas into H2:H8
for r in range(start_row, end_row + 1):
    parts = []
    for c in range(start_col, end_col + 1):
        col_letter = get_column_letter(c)
        parts.append(f'--({col_letter}{r}=MAX({col_letter}${start_row}:{col_letter}${end_row}))')
    formula = "=" + "+".join(parts)
    ws.cell(r, 8).value = formula

print("\nWritten formulas in H2:H8:")
for r in range(start_row, end_row + 1):
    print(f"H{r} -> {ws.cell(r,8).value}")

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename sheets back in order
    for i, original_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify formulas and computed values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerification of target cells H2:H8:")
for r in range(start_row, end_row + 1):
    player = ws_values.cell(r, 1).value
    formula = ws_formula.cell(r, 8).value
    value = ws_values.cell(r, 8).value
    print(f"Row {r} {player}: formula={formula} | value={value}")

# Also verify winners by game from source data for sanity
print("\nSanity check by game columns:")
for c in range(start_col, end_col + 1):
    col_letter = get_column_letter(c)
    game_name = ws_values.cell(1, c).value
    scores = [(ws_values.cell(r, 1).value, ws_values.cell(r, c).value) for r in range(start_row, end_row + 1)]
    max_score = max(v for _, v in scores if isinstance(v, (int, float)))
    winners = [name for name, v in scores if v == max_score]
    print(game_name, "max", max_score, "winner(s)", winners)
