from itertools import combinations

before_ws = wb["Before"]
after_ws = wb["After"]

values = [before_ws.cell(r, 1).value for r in range(1, before_ws.max_row + 1)]
rows = list(range(1, before_ws.max_row + 1))

# Example highlighted rows in After
after_highlighted_rows = []
for r in rows:
    cell = after_ws.cell(r, 1)
    if cell.fill and cell.fill.fill_type == "solid" and getattr(cell.fill.start_color, "rgb", None):
        after_highlighted_rows.append(r)

after_highlighted_vals = [after_ws.cell(r, 1).value for r in after_highlighted_rows]
after_sum = sum(after_highlighted_vals)

print("After highlighted rows:", after_highlighted_rows)
print("After highlighted values:", after_highlighted_vals)
print("After highlighted sum:", after_sum)

# Find all combinations whose sum is between 994108 and 994112 inclusive
target_low, target_high = 994108, 994112
valid_combos = []

# 2^16 is manageable, but prune via combinations by size
for k in range(1, len(values) + 1):
    for idxs in combinations(range(len(values)), k):
        s = sum(values[i] for i in idxs)
        if target_low <= s <= target_high:
            valid_combos.append((idxs, s))

print("Valid combos count:", len(valid_combos))
for combo in valid_combos[:20]:
    idxs, s = combo
    combo_rows = [i+1 for i in idxs]
    combo_vals = [values[i] for i in idxs]
    print("rows", combo_rows, "vals", combo_vals, "sum", s)

# Check if example in After matches one of the valid combos
example_set = tuple(r-1 for r in after_highlighted_rows)
matching_example = [(idxs, s) for idxs, s in valid_combos if idxs == example_set]
print("Example combo is valid?:", bool(matching_example), matching_example[:3])

# Also inspect current C2 values on Before/After
print("Before!C2 current:", before_ws["C2"].value)
print("After!C2 current:", after_ws["C2"].value)
