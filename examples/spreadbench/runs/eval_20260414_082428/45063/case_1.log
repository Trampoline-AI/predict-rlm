from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Determine actual used rows in Sheet1 based on non-empty col A
used_rows_sheet1 = [r for r in range(1, ws1.max_row + 1) if ws1.cell(r, 1).value not in (None, "")]
print("Sheet1 non-empty column A rows:", used_rows_sheet1)

print("\nDetailed target area inspection Sheet1 A:C rows 1:10")
for r in range(1, 11):
    vals = []
    for c in range(1, 4):
        cell = ws1.cell(r, c)
        vals.append({
            "coord": cell.coordinate,
            "value": cell.value,
            "data_type": cell.data_type
        })
    print(vals)

print("\nInspect existing formulas/values in likely target column B for active rows")
for r in used_rows_sheet1:
    cell = ws1.cell(r, 2)
    print(cell.coordinate, "value=", cell.value, "data_type=", cell.data_type)

print("\nSheet2 lookup table:")
for r in range(1, ws2.max_row + 1):
    print(r, ws2.cell(r,1).value, ws2.cell(r,2).value)

# Write formulas into existing target column B for rows with products (excluding header)
for r in used_rows_sheet1:
    if r == 1:
        continue
    product = ws1.cell(r, 1).value
    if product not in (None, ""):
        # exact lookup; blank if not found
        ws1.cell(r, 2).value = f'=IFERROR(VLOOKUP(A{r},Sheet2!$A$2:$B$6,2,FALSE),"")'

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and ensure sheet names preserved
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
orig_names = ["Sheet1", "Sheet2"]
if wb_check.sheetnames != orig_names:
    # rename by position if needed
    for i, name in enumerate(orig_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Renamed sheets back to:", [ws.title for ws in wb_check.worksheets])

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)
print("\nVerification Sheet1 target cells B2:B6")
for r in range(2, 7):
    print(
        f"Row {r}",
        "A=", wb_values["Sheet1"][f"A{r}"].value,
        "FormulaB=", wb_formula["Sheet1"][f"B{r}"].value,
        "ValueB=", wb_values["Sheet1"][f"B{r}"].value
    )

output_spreadsheet = out_path
```
