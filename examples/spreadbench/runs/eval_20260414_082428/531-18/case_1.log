from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
data_ws = wb["Data"]
trans_ws = wb["Transpose"]

def used_range(ws):
    min_r = min_c = None
    max_r = max_c = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                r, c = cell.row, cell.column
                if min_r is None or r < min_r: min_r = r
                if min_c is None or c < min_c: min_c = c
                if r > max_r: max_r = r
                if c > max_c: max_c = c
    return min_r, min_c, max_r, max_c

for ws in [data_ws, trans_ws]:
    mr1, mc1, mr2, mc2 = used_range(ws)
    print(f"\nSheet {ws.title} used range: rows {mr1}-{mr2}, cols {mc1}-{mc2} ({get_column_letter(mc1)}-{get_column_letter(mc2)})")
    # print all non-empty cells in used range if reasonably small; otherwise compact preview
    print("Top rows in used range:")
    for r in range(mr1, min(mr1 + 9, mr2) + 1):
        vals = [ws.cell(r, c).value for c in range(mc1, mc2 + 1)]
        print(f"Row {r}:", vals)
    print("Bottom rows in used range:")
    for r in range(max(mr1, mr2 - 4), mr2 + 1):
        vals = [ws.cell(r, c).value for c in range(mc1, mc2 + 1)]
        print(f"Row {r}:", vals)

print("\nDetailed Transpose sheet coordinates:")
mr1, mc1, mr2, mc2 = used_range(trans_ws)
for r in range(mr1, mr2 + 1):
    entries = []
    for c in range(mc1, mc2 + 1):
        v = trans_ws.cell(r, c).value
        if v is not None:
            entries.append(f"{get_column_letter(c)}{r}={v!r}")
    print(" | ".join(entries) if entries else f"Row {r}: blank")

# Also inspect formulas if any
print("\nTranspose formulas/non-empty values by cell:")
for r in range(mr1, mr2 + 1):
    for c in range(mc1, mc2 + 1):
        cell = trans_ws.cell(r, c)
        if cell.value is not None:
            print(cell.coordinate, type(cell.value).__name__, repr(cell.value))
