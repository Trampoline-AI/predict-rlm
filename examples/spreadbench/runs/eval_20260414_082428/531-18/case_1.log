```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
data_ws = wb["Data"]
trans_ws = wb["Transpose"]

# Inspect exact target cells/headers before writing
print("Original sheet names:", orig_sheetnames)
print("Transpose header cells before write:", trans_ws["A2"].value, trans_ws["B2"].value, trans_ws["C2"].value)
print("Existing sample rows A2:C8:")
for r in range(2, 9):
    print(r, [trans_ws.cell(r, c).value for c in range(1, 4)])

# Source structure verification
header_row = 6
item_col = 1
date_start_col = 7
date_end_col = data_ws.max_column

print("Data header row 6 A:K preview:")
print([data_ws.cell(header_row, c).value for c in range(1, 12)])

# Build full transpose records including zeros, matching example pattern
records = []
for r in range(header_row + 1, data_ws.max_row + 1):
    item = data_ws.cell(r, item_col).value
    if item in (None, ""):
        continue
    for c in range(date_start_col, date_end_col + 1):
        dt = data_ws.cell(header_row, c).value
        qty = data_ws.cell(r, c).value
        records.append((item, dt, qty))

print("Total output records:", len(records))
print("First 10 records:", records[:10])
print("Last 5 records:", records[-5:])

# Make sure header row is correct in target cells
trans_ws["A2"] = "ITEM"
trans_ws["B2"] = "Date"
trans_ws["C2"] = "Qty's"

# Preserve example row formatting by copying style from row 3 if present
style_sources = {}
for c in range(1, 4):
    style_sources[c] = trans_ws.cell(3, c)

# Clear old output area in A:C from row 3 downward
for r in range(3, trans_ws.max_row + 1):
    for c in range(1, 4):
        trans_ws.cell(r, c).value = None

# Write all records starting at row 3
start_row = 3
for i, (item, dt, qty) in enumerate(records, start=start_row):
    trans_ws.cell(i, 1).value = item
    trans_ws.cell(i, 2).value = dt
    trans_ws.cell(i, 3).value = qty
    # copy style/number formatting from sample row if available
    for c in range(1, 4):
        src = style_sources[c]
        dst = trans_ws.cell(i, c)
        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.font:
            dst.font = copy(src.font)
        if src.fill:
            dst.fill = copy(src.fill)
        if src.border:
            dst.border = copy(src.border)
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.protection:
            dst.protection = copy(src.protection)

# If there are any stale rows beyond new output, clear them in A:C
final_row = start_row + len(records) - 1
for r in range(final_row + 1, max(final_row + 50, trans_ws.max_row) + 1):
    for c in range(1, 4):
        trans_ws.cell(r, c).value = None

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload after recalculation; fix sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename sheets back by position
    for idx, expected in enumerate(orig_sheetnames):
        wb2.worksheets[idx].title = expected
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verification using data_only=True
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vtrans = verify_wb["Transpose"]

print("Verify target headers A2:C2:", [vtrans.cell(2, c).value for c in range(1, 4)])
print("Verify first 10 output rows:")
for r in range(3, 13):
    print(r, [vtrans.cell(r, c).value for c in range(1, 4)])

print("Verify last 5 output rows:")
for r in range(final_row - 4, final_row + 1):
    print(r, [vtrans.cell(r, c).value for c in range(1, 4)])

print("Expected final row:", final_row)
print("Cell A3/C3:", vtrans["A3"].value, vtrans["C3"].value)
print(f"Cell A{final_row}:C{final_row}:", [vtrans.cell(final_row, c).value for c in range(1, 4)])

# Basic sanity checks
assert verify_wb.sheetnames == orig_sheetnames
assert vtrans["A2"].value == "ITEM"
assert vtrans["B2"].value == "Date"
assert vtrans["C2"].value == "Qty's"
assert vtrans["A3"].value is not None
assert vtrans.cell(final_row, 1).value is not None

output_spreadsheet = outfile
```
