import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheet names:", original_sheetnames)

# Verify exact target area again before writing
print("Pre-write target area E:F")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"E{r}"].value, ws[f"F{r}"].value)

# Write formulas only where E has a value and F is blank
written = []
for r in range(2, ws.max_row + 1):
    e_val = ws[f"E{r}"].value
    f_val = ws[f"F{r}"].value
    if e_val not in (None, "") and f_val in (None, ""):
        formula = f'=IF(E{r}="","",INDEX($C$2:$C$12,MATCH(E{r},$B$2:$B$12,1)))'
        ws[f"F{r}"] = formula
        written.append((r, formula))

print("Written formulas:", written)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for i, old_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target cells F2:F6")
for r in range(2, 7):
    print({
        "row": r,
        "E": ws_values[f"E{r}"].value,
        "F_formula": ws_formula[f"F{r}"].value,
        "F_value": ws_values[f"F{r}"].value,
    })

# Sanity check expected outputs
expected = {2: 1, 3: 2, 4: 3, 5: 8, 6: 9}
ok = True
for r, exp in expected.items():
    got = ws_values[f"F{r}"].value
    if got != exp:
        ok = False
        print(f"Mismatch at F{r}: expected {exp}, got {got!r}")

print("Verification passed:", ok)

final_output_path = output_path
