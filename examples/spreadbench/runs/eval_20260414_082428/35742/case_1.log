import os, json, math, statistics
from collections import Counter, defaultdict
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def cell_display(v):
    if v is None:
        return None
    try:
        s = str(v)
    except Exception:
        s = repr(v)
    return s

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find likely header rows among first 5 rows
    for hr in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v is not None and v != "" for v in vals)
        print(f"Row {hr} nonempty={nonempty} values:", [cell_display(v) for v in vals[:20]])
    # choose row with most nonempty among first 5 as likely header
    header_row = max(range(1, min(5, ws.max_row) + 1), key=lambda r: sum(ws.cell(r,c).value not in (None,"") for c in range(1, ws.max_column+1)))
    headers = [cell_display(ws.cell(header_row, c).value) for c in range(1, ws.max_column + 1)]
    print("Likely header row:", header_row)
    print("Headers:", headers)

    # first 10 rows
    top_end = min(ws.max_row, 10)
    print("Top sample rows:")
    for r in range(1, top_end + 1):
        vals = [cell_display(ws.cell(r,c).value) for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last 5 rows
    print("Bottom sample rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        vals = [cell_display(ws.cell(r,c).value) for c in range(1, ws.max_column + 1)]
        print(r, vals)

    # inspect fills/colors and formulas
    fill_counts = Counter()
    colored_cells = []
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
            fill = cell.fill
            color = None
            if fill and fill.fill_type == "solid":
                sc = fill.start_color
                color = sc.rgb or sc.indexed or sc.theme
            if color not in (None, '00000000', '000000', 0, '0'):
                fill_counts[str(color)] += 1
                if len(colored_cells) < 60:
                    colored_cells.append((cell.coordinate, cell_display(cell.value), str(color)))
    print("Formula cells count:", len(formula_cells))
    print("First formulas:", formula_cells[:20])
    print("Solid fill counts:", fill_counts.most_common(10))
    print("Sample colored cells:", colored_cells[:40])
