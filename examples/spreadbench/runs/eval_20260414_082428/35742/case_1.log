import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load fresh workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Confirm target cells before writing
print("Writing formulas into Section Total column O for rows 4-7")
for r in range(4, 8):
    print("Before", f"O{r}", "=", ws[f"O{r}"].value)

# Write formulas to existing target cells
for r in range(4, 8):
    ws[f"O{r}"] = f'=SUM(IFERROR(VALUE(F{r}),0),IFERROR(VALUE(H{r}),0),IFERROR(VALUE(J{r}),0),IFERROR(VALUE(L{r}),0),IFERROR(VALUE(N{r}),0))'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Restored original sheet names:", orig_sheetnames)

# Verify formulas and computed values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[orig_sheetnames[0]]

print("\nVerification of target cells O4:O7")
for r in range(4, 8):
    formula = wsf[f"O{r}"].value
    value = wsv[f"O{r}"].value
    pts = {col: wsv[f"{col}{r}"].value for col in ["F","H","J","L","N"]}
    print(f"Row {r}: formula={formula} value={value} points={pts}")

output_spreadsheet = outfile
```
