from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Current max_row/max_col:", ws.max_row, ws.max_column)

# Inspect target area including column N as referenced by instruction
for r in range(2, 7):
    row_vals = [ws.cell(r, c).value for c in range(12, 15)]  # L:M:N
    print(f"Row {r} L:N -> {row_vals}")

print("N4 current value:", ws["N4"].value)
print("N3 current value:", ws["N3"].value)
print("Column letters around output:")
for c in range(11, 15):
    print(c, get_column_letter(c), "row3=", ws.cell(3, c).value, "row4=", ws.cell(4, c).value)

# Determine customer rows: rows with label in col A and any monthly data in B:M
data_rows = []
for r in range(4, ws.max_row + 1):
    label = ws.cell(r, 1).value
    vals = [ws.cell(r, c).value for c in range(2, 14)]
    if label is not None and any(v is not None for v in vals):
        data_rows.append(r)
print("Detected data rows:", data_rows)

# Write header in N3 if blank, and formulas in N4:N...
if ws["N3"].value is None:
    ws["N3"] = "Gap Count"

for r in data_rows:
    # Formula logic:
    # - If no numeric entries, blank
    # - If only one numeric entry, blank
    # - If first numeric entry > 1, return 1
    # - Else return position(second numeric) - position(first numeric)
    row_range = f"B{r}:M{r}"
    formula = (
        f'=IF(COUNT({row_range})<2,"",'
        f'IF(INDEX({row_range},1,MATCH(TRUE,ISNUMBER({row_range}),0))>1,1,'
        f'MATCH(TRUE,INDEX((ISNUMBER({row_range})*(COLUMN(B{r}:M{r})>'
        f'COLUMN(B{r})-1+MATCH(TRUE,ISNUMBER({row_range}),0)),0),0)-'
        f'MATCH(TRUE,ISNUMBER({row_range}),0)))'
    )
    ws[f"N{r}"] = formula
    print(f"N{r} formula:", formula)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate result:", result)

# Reload and restore original sheet name if needed
