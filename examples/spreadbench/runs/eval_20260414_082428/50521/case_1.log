from openpyxl import load_workbook
import os

# Reload original workbook fresh
orig_wb = load_workbook(input_spreadsheet)
orig_sheetnames = orig_wb.sheetnames[:]
ws = orig_wb[orig_sheetnames[0]]

# Reconfirm target area
print("Using sheet:", ws.title)
print("N3 before:", ws["N3"].value)
for r in range(4, ws.max_row + 1):
    print(f"Row {r} source B:M:", [ws.cell(r, c).value for c in range(2, 14)], "current N:", ws.cell(r, 14).value)

# Identify actual data rows
data_rows = []
for r in range(4, ws.max_row + 1):
    label = ws.cell(r, 1).value
    vals = [ws.cell(r, c).value for c in range(2, 14)]
    if label is not None and any(v is not None for v in vals):
        data_rows.append(r)

def compute_gap(row_vals):
    # positions among B:M, 1-indexed within the row segment
    numeric_positions = []
    numeric_values = []
    for idx, v in enumerate(row_vals, start=1):
        if isinstance(v, (int, float)) and not isinstance(v, bool):
            numeric_positions.append(idx)
            numeric_values.append(v)
    if len(numeric_positions) < 2:
        return ""
    first_pos, second_pos = numeric_positions[0], numeric_positions[1]
    first_val = numeric_values[0]
    if first_val > 1:
        return 1
    return second_pos - first_pos

# Write header and computed outputs into column N
if ws["N3"].value in (None, ""):
    ws["N3"] = "Gap Count"

written = {}
for r in data_rows:
    row_vals = [ws.cell(r, c).value for c in range(2, 14)]
    result = compute_gap(row_vals)
    ws.cell(r, 14).value = result
    written[r] = result
    print(f"Computed N{r} =", result)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
orig_wb.save(out_path)
print("Saved:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload after recalculation
check_wb = load_workbook(out_path)
print("Sheet names after recalc:", check_wb.sheetnames)
if check_wb.sheetnames != orig_sheetnames and len(check_wb.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(check_wb.worksheets):
        s.title = orig_sheetnames[i]
    check_wb.save(out_path)
    print("Restored sheet names:", check_wb.sheetnames)

# Verify with data_only
verify_wb = load_workbook(out_path, data_only=True)
vws = verify_wb[orig_sheetnames[0]]

print("Verification of target cells:")
print("N3:", vws["N3"].value)
for r in data_rows:
    print(f"N{r}:", vws.cell(r, 14).value, "| label:", vws.cell(r, 1).value)

output_spreadsheet = out_path
```
