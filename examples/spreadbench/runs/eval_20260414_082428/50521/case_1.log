if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for i, s in enumerate(wb2.worksheets):
        s.title = orig_names[i]
    wb2.save(out_path)
    print("Restored sheet names:", orig_names)

# Verify with formulas and data_only values
