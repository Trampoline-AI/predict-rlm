import os
from openpyxl import load_workbook
from openpyxl.styles import Alignment

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Reload fresh workbook for modification
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws_main = wb["main sheet"]
ws_res = wb["result"]

# Inspect exact target range and current values before writing
print("Original sheet names:", orig_sheetnames)
print("Target result range before writing:")
for r in range(1, ws_res.max_row + 1):
    print(r, [ws_res.cell(r, c).value for c in range(1, ws_res.max_column + 1)])

# Build lookup from main sheet by location
allowed_designations = {"Branch Manager", "Branch Credit Manager"}
main_lookup = {}
for r in range(2, ws_main.max_row + 1):
    location = ws_main.cell(r, 1).value
    name = ws_main.cell(r, 2).value
    contact = ws_main.cell(r, 3).value
    mail = ws_main.cell(r, 4).value
    designation = ws_main.cell(r, 5).value
    main_lookup[location] = {
        "name": name,
        "contact": contact,
        "mail": mail,
        "designation": designation,
    }

print("\nMain lookup preview:")
for k, v in list(main_lookup.items())[:10]:
    print(k, v)

# Write outputs to result sheet B:D based on location in A
left_align = Alignment(horizontal="left")

written = []
for r in range(2, ws_res.max_row + 1):
    location = ws_res.cell(r, 1).value
    rec = main_lookup.get(location)

    if rec and rec["designation"] in allowed_designations:
        b_val = rec["designation"]
        c_val = str(rec["contact"]).strip() if rec["contact"] is not None else "N/A"
        d_val = str(rec["mail"]).strip() if rec["mail"] is not None else "N/A"
    else:
        b_val = "N/A"
        c_val = "N/A"
        d_val = "N/A"

    ws_res.cell(r, 2).value = b_val
    ws_res.cell(r, 3).value = c_val
    ws_res.cell(r, 4).value = d_val

    ws_res.cell(r, 2).alignment = left_align
    ws_res.cell(r, 3).alignment = left_align
    ws_res.cell(r, 4).alignment = left_align

    written.append((r, location, b_val, c_val, d_val))

print("\nWritten values preview:")
for item in written:
    print(item)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # Rename sheets back in order
    for i, expected_name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
ws_verify = wb_verify["result"]

print("\nFinal result sheet values:")
for r in range(1, ws_verify.max_row + 1):
    print(r, [ws_verify.cell(r, c).value for c in range(1, ws_verify.max_column + 1)])

# Verify alignment from non-data_only workbook
wb_align = load_workbook(output_path)
ws_align = wb_align["result"]
print("\nAlignment verification for target cells B2:D12:")
for r in range(2, ws_align.max_row + 1):
    print(
        r,
        ws_align.cell(r, 2).alignment.horizontal,
        ws_align.cell(r, 3).alignment.horizontal,
        ws_align.cell(r, 4).alignment.horizontal,
    )
