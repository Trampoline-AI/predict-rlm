import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames
print("Sheet names:", orig_sheetnames)

def visible_value(v):
    try:
        if hasattr(v, "text"):
            return f"<FORMULA_OBJ {v.text}>"
    except Exception:
        pass
    return v

workbook_info = {}

for ws in wb.worksheets:
    max_r, max_c = ws.max_row, ws.max_column
    headers = [visible_value(ws.cell(1, c).value) for c in range(1, max_c+1)]
    workbook_info[ws.title] = {"max_row": max_r, "max_col": max_c, "headers": headers}
    print("\n=== SHEET:", ws.title, "===")
    print("Dimensions:", max_r, "rows x", max_c, "cols")
    print("Row 1 headers/values:")
    print([(get_column_letter(c), visible_value(ws.cell(1, c).value)) for c in range(1, max_c+1)])
    
    # Also inspect row 2 in case headers start there
    if max_r >= 2:
        print("Row 2:")
        print([(get_column_letter(c), visible_value(ws.cell(2, c).value)) for c in range(1, max_c+1)])
    
    # First up to 10 rows
    first_n = min(max_r, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        row_vals = [visible_value(ws.cell(r, c).value) for c in range(1, max_c+1)]
        print(r, row_vals)
    
    # Last 5 rows
    start_last = max(1, max_r - 4)
    print("Last rows:")
    for r in range(start_last, max_r+1):
        row_vals = [visible_value(ws.cell(r, c).value) for c in range(1, max_c+1)]
        print(r, row_vals)

# Search workbook for keywords likely relevant to task
keywords = ["location", "designation", "contact", "mail", "email", "branch", "manager", "credit", "result", "name"]
matches = []
for ws in wb.worksheets:
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            val = ws.cell(r, c).value
            sval = str(visible_value(val)).strip().lower() if val is not None else ""
            if any(k in sval for k in keywords):
                matches.append((ws.title, r, c, get_column_letter(c), visible_value(val)))

print("\nKeyword-related cells (first 120):")
for item in matches[:120]:
    print(item)
print("Total keyword matches:", len(matches))
