wb = load_workbook(input_path)
print("Workbook loaded:", input_path)
print("Sheet names:", wb.sheetnames)

def sheet_nonempty_bounds(ws):
    max_row, max_col = ws.max_row, ws.max_column
    # find actual non-empty rows/cols
    last_row = 0
    last_col = 0
    first_nonempty_row = None
    for r in range(1, max_row + 1):
        row_has = False
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                last_row = r
                if first_nonempty_row is None:
                    first_nonempty_row = r
                if c > last_col:
                    last_col = c
        if row_has and first_nonempty_row is None:
            first_nonempty_row = r
    return first_nonempty_row or 1, last_row or 1, last_col or 1

def row_values(ws, r, upto=None):
    if upto is None:
        upto = ws.max_column
    vals = []
    for c in range(1, upto + 1):
        vals.append(ws.cell(r, c).value)
    return vals

for s in wb.sheetnames:
    ws = wb[s]
