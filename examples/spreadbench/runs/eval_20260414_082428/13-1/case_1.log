```repl
import os
from collections import OrderedDict
from copy import copy
from datetime import datetime
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws_r = wb["RANGES"]
ws_l = wb["LISTS"]

def row_vals(ws, r, c1=1, c2=6):
    return [ws.cell(r, c).value for c in range(c1, c2 + 1)]

def find_section_blocks(ws, title_col=3):
    blocks = []
    rows = ws.max_row
    for r in range(1, rows + 1):
        title = ws.cell(r, title_col).value
        next_row = r + 1
        if next_row > rows:
            continue
        header = row_vals(ws, next_row, 1, 5)
        h0 = str(header[0]).strip().upper() if header[0] is not None else ""
        if isinstance(title, str) and h0 in ("S.N", "SN"):
            # find next section title row
            next_title_row = None
            for rr in range(r + 1, rows + 1):
                t = ws.cell(rr, title_col).value
                if isinstance(t, str):
                    hdr2 = row_vals(ws, rr + 1, 1, 5) if rr + 1 <= rows else [None]*5
                    h02 = str(hdr2[0]).strip().upper() if hdr2[0] is not None else ""
                    if rr != r and h02 in ("S.N", "SN"):
                        next_title_row = rr
                        break
            end_row = (next_title_row - 1) if next_title_row else rows
            # trim trailing blank rows within the block
            while end_row > r and not any(v not in (None, "") for v in row_vals(ws, end_row, 1, 5)):
                end_row -= 1
            blocks.append({
                "title": str(title).strip(),
                "title_row": r,
                "header_row": r + 1,
                "data_start": r + 2,
                "end_row": end_row,
            })
    return blocks

r_blocks = {b["title"].upper(): b for b in find_section_blocks(ws_r)}
l_blocks = {b["title"].upper(): b for b in find_section_blocks(ws_l)}

print("Detected RANGES blocks:", r_blocks)
print("Detected LISTS blocks:", l_blocks)

def normalize_date(v):
    if isinstance(v, datetime):
        return v.replace(hour=0, minute=0, second=0, microsecond=0)
    if isinstance(v, str):
        s = v.strip()
        for fmt in ("%m/%d/%Y", "%d/%m/%Y", "%Y-%m-%d"):
            try:
                return datetime.strptime(s, fmt)
            except Exception:
                pass
    return v

def aggregate_ranges_block(ws, block):
    out = OrderedDict()
    for r in range(block["data_start"], block["end_row"] + 1):
        sn = ws.cell(r, 1).value
        dt = ws.cell(r, 2).value
        ref = ws.cell(r, 4).value
        amt = ws.cell(r, 5).value
        if dt in (None, "") and ref in (None, "") and amt in (None, ""):
            continue
        nd = normalize_date(dt)
        key = (nd, str(ref).strip() if ref is not None else "")
        if key not in out:
            out[key] = {"date": nd, "ref": str(ref).strip() if ref is not None else "", "amount": 0}
        out[key]["amount"] += float(amt or 0)
    return list(out.values())

# Print current target cells before writing
for sec in ["DATA", "OPERATION"]:
    if sec in l_blocks:
        b = l_blocks[sec]
        print(f"\nCurrent LISTS block before write: {sec}")
        for r in range(b["title_row"], b["end_row"] + 1):
            print(r, row_vals(ws_l, r, 1, 5))

# Use STAGE styles as format reference
stage_l = l_blocks["STAGE"]
style_data_row = stage_l["data_start"]   # row 3
style_total_row = stage_l["end_row"]     # row 10
style_header_row = stage_l["header_row"] # row 2
style_title_row = stage_l["title_row"]   # row 1

def copy_cell_style(src, dst):
    dst.font = copy(src.font)
    dst.fill = copy(src.fill)
    dst.border = copy(src.border)
    dst.alignment = copy(src.alignment)
    dst.number_format = src.number_format
    dst.protection = copy(src.protection)

def clear_block_output(ws, block):
    # clear rows between header and total label row, plus total amount cell
    total_row = None
    for r in range(block["data_start"], block["end_row"] + 1):
        if str(ws.cell(r, 1).value).strip().upper() == "TOTAL":
            total_row = r
            break
    if total_row is None:
        total_row = block["end_row"]
    # clear existing data area
    for r in range(block["data_start"], total_row):
        for c in range(1, 5):
            ws.cell(r, c).value = None
            copy_cell_style(ws_l.cell(style_data_row, c), ws.cell(r, c))
    # ensure total row exists/formatted
    for c in range(1, 5):
        copy_cell_style(ws_l.cell(style_total_row, c), ws.cell(total_row, c))
    ws.cell(total_row, 1).value = "TOTAL"
    ws.cell(total_row, 2).value = None
    ws.cell(total_row, 3).value = None
    ws.cell(total_row, 4).value = None
    return total_row

def write_section(sec_name):
    r_block = r_blocks[sec_name]
    l_block = l_blocks[sec_name]
    agg = aggregate_ranges_block(ws_r, r_block)
    total_row = clear_block_output(ws_l, l_block)

    print(f"\nAggregated rows for {sec_name}:")
    for i, item in enumerate(agg, 1):
        print(i, item)

    available_rows = list(range(l_block["data_start"], total_row))
    needed = len(agg)
    if needed > len(available_rows):
        raise ValueError(f"Not enough rows in LISTS block {sec_name}: need {needed}, have {len(available_rows)}")

    for idx, item in enumerate(agg, 1):
        r = available_rows[idx - 1]
        ws_l.cell(r, 1).value = idx
        ws_l.cell(r, 2).value = item["date"]
        ws_l.cell(r, 3).value = item["ref"]
        # write integer if whole number
        amt = item["amount"]
        ws_l.cell(r, 4).value = int(amt) if float(amt).is_integer() else amt
        for c in range(1, 5):
            copy_cell_style(ws_l.cell(style_data_row, c), ws_l.cell(r, c))

    if agg:
        first_data_row = available_rows[0]
        last_data_row = available_rows[len(agg) - 1]
        ws_l.cell(total_row, 4).value = f"=SUM(D{first_data_row}:D{last_data_row})"
    else:
        ws_l.cell(total_row, 4).value = 0

for sec in ["DATA", "OPERATION"]:
    write_section(sec)

# Also ensure existing STAGE total formula is intact (do not alter data)
stage_total_row = None
for r in range(stage_l["data_start"], stage_l["end_row"] + 1):
    if str(ws_l.cell(r, 1).value).strip().upper() == "TOTAL":
        stage_total_row = r
        break
if stage_total_row:
    ws_l.cell(stage_total_row, 4).value = f"=SUM(D{stage_l['data_start']}:D{stage_total_row-1})"

wb.save(output_path)
print("\nSaved to:", output_path)

# recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# restore sheet names if changed
wb_post = load_workbook(output_path)
if wb_post.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalculation:", wb_post.sheetnames, "-> restoring", orig_sheetnames)
    for i, expected in enumerate(orig_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = expected
    wb_post.save(output_path)

# verification with formulas visible
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
print("\nVerification:")
print("Final sheet names:", wb_formula.sheetnames)

for sec in ["STAGE", "DATA", "OPERATION"]:
    bf = wb_formula["LISTS"]
    bv = wb_values["LISTS"]
    block = {b["title"].upper(): b for b in find_section_blocks(bf)}[sec]
    print(f"\nLISTS {sec} block (formulas):")
    for r in range(block["title_row"], block["end_row"] + 1):
        print(r, row_vals(bf, r, 1, 5))
    print(f"LISTS {sec} block (values):")
    for r in range(block["title_row"], block["end_row"] + 1):
        print(r, row_vals(bv, r, 1, 5))
