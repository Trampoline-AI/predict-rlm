from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Input path:", input_path)
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_info = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find likely non-empty row bounds
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    first_nonempty = nonempty_rows[0] if nonempty_rows else None
    last_nonempty = nonempty_rows[-1] if nonempty_rows else None
    print("first_nonempty_row:", first_nonempty, "last_nonempty_row:", last_nonempty)
    
    # Print first 10 rows and last 5 rows
    top_n = min(10, ws.max_row)
    print("\nTop rows:")
    for r in range(1, top_n + 1):
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}: {vals}")
    
    print("\nBottom rows:")
    start_bottom = max(1, ws.max_row - 4)
    for r in range(start_bottom, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}: {vals}")
    
    # Heuristically detect header row among first 5 rows
    best_header_row = None
    best_score = -1
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        score = sum(1 for v in vals if isinstance(v, str) and v.strip() != "")
        if score > best_score:
            best_score = score
            best_header_row = r
    headers = row_values(ws, best_header_row, ws.max_column) if best_header_row else []
    print(f"\nLikely header row: {best_header_row}")
    print("Headers with letters:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}{best_header_row}: {h}")
    
    # Search for relevant columns
    keywords = ["debt", "worker", "name", "employee", "week", "date", "deduction", "addition", "add", "deduct"]
    relevant_cols = []
    for c, h in enumerate(headers, start=1):
        hs = str(h).strip().lower() if h is not None else ""
        if any(k in hs for k in keywords):
            relevant_cols.append((c, h))
    print("Relevant columns by header:", relevant_cols)
    
    # Print formulas / values in relevant columns for sample rows
    if relevant_cols:
        sample_rows = list(range(best_header_row + 1, min(ws.max_row, best_header_row + 8) + 1))
        if ws.max_row >= 5:
            sample_rows += list(range(max(best_header_row + 1, ws.max_row - 4), ws.max_row + 1))
        sample_rows = sorted(set(sample_rows))
        print("\nRelevant column sample data:")
        for r in sample_rows:
            row_out = {}
            for c, h in relevant_cols:
                v = ws.cell(r, c).value
                row_out[f"{get_column_letter(c)}:{h}"] = v
            print(f"Row {r}: {row_out}")
    
    # Print any formulas found in first 50 rows
    formulas = []
    for r in range(1, min(ws.max_row, 50) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print(f"\nFormula cells in first {min(ws.max_row, 50)} rows: {len(formulas)}")
    for item in formulas[:20]:
        r, c, v = item
        print(f"  {get_column_letter(c)}{r}: {v}")
    
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "first_nonempty": first_nonempty,
        "last_nonempty": last_nonempty,
        "header_row": best_header_row,
        "headers": headers,
        "relevant_cols": relevant_cols,
        "formulas": formulas,
    }

print("\nInspection complete.")
