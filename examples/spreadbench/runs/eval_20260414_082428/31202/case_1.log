import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["NOMINA"]
orig_sheet_names = wb.sheetnames[:]

# Focused inspection before editing
payroll_rows = [r for r in range(2, ws.max_row + 1) if any(ws.cell(r, c).value not in (None, "") for c in range(1, 11))]
interesting = [r for r in payroll_rows if ws[f"G{r}"].value not in (None, "", 0) or ws[f"H{r}"].value not in (None, "", 0)]

print("Target sheet:", ws.title)
print("Target range for output:", f"J2:J{payroll_rows[-1]}")
print("Non-zero deduction/addition rows:", interesting)

for r in interesting:
    print(
        f"Row {r}: date={ws[f'A{r}'].value}, worker={ws[f'D{r}'].value}, "
        f"ded={ws[f'G{r}'].value}, add={ws[f'H{r}'].value}, current_debt={ws[f'J{r}'].value}"
    )

# Write formulas into existing DEBT column cells
# Logic:
#   first row: debt = deductions - additions
#   later rows: if first occurrence of worker so far, debt = deductions - additions
#               else debt = previous same worker debt + deductions - additions
#
# LOOKUP(2,1/(condition),range) returns the last matching earlier debt above the row.
# This avoids external references and works on the existing row order.
if payroll_rows:
    first_row = payroll_rows[0]
    ws[f"J{first_row}"] = f"=G{first_row}-H{first_row}"
    print(f"Set J{first_row} formula:", ws[f'J{first_row}'].value)

    for r in payroll_rows[1:]:
        formula = (
            f'=IF(COUNTIF($D$2:D{r},D{r})=1,'
            f'G{r}-H{r},'
            f'LOOKUP(2,1/($D$2:D{r-1}=D{r}),$J$2:J{r-1})+G{r}-H{r})'
        )
        ws[f"J{r}"] = formula

print("Sample written formulas in DEBT column:")
for r in payroll_rows[:5] + interesting[:5] + payroll_rows[-5:]:
    if r in payroll_rows:
        print(f"J{r} -> {ws[f'J{r}'].value}")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore original sheet names if needed
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename by position to match originals
    for i, sname in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = sname
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["NOMINA"]
wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals["NOMINA"]

print("\nVerification of target cells:")
verify_rows = sorted(set(payroll_rows[:5] + interesting[:10] + payroll_rows[-5:]))
for r in verify_rows:
    print(
        f"Row {r}: worker={wsv[f'D{r}'].value!r}, "
        f"ded={wsv[f'G{r}'].value!r}, add={wsv[f'H{r}'].value!r}, "
        f"formula={wsf[f'J{r}'].value!r}, value={wsv[f'J{r}'].value!r}"
