import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Fresh load for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]

# Verify exact target sheet from user's "Sheets(1)"
target_ws = wb[orig_sheet_names[0]]
orig_ws = wb["Original Data"]

def print_rows(ws, start, end, label):
    print(f"\n{label} - {ws.title} rows {start}:{end}")
    for r in range(start, min(end, ws.max_row) + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

print("Original sheet names:", orig_sheet_names)
print_rows(target_ws, 1, 12, "Before deletion target")
print_rows(orig_ws, 1, 12, "Before deletion reference")

# Find rows to delete in Sheet1 only
rows_to_delete = []
for r in range(2, target_ws.max_row + 1):  # skip header
    v = target_ws.cell(r, 5).value
    s = "" if v is None else str(v).strip()
    if s.startswith("Z1") or s.startswith("X1"):
        rows_to_delete.append((r, v))

print("\nRows to delete from target sheet:", rows_to_delete)

# Delete bottom-up
for r, _ in reversed(rows_to_delete):
    target_ws.delete_rows(r, 1)

print("\nAfter deletion target max_row:", target_ws.max_row)
print_rows(target_ws, 1, target_ws.max_row, "After deletion target")
print_rows(orig_ws, 1, 12, "After deletion reference (should be unchanged)")

# Save
wb.save(output_path)
print("\nSaved to:", output_path, os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # Rename by position to original names
    if len(wb2.worksheets) == len(orig_sheet_names):
        for ws, name in zip(wb2.worksheets, orig_sheet_names):
            ws.title = name
        wb2.save(output_path)
        print("Renamed sheets back to:", orig_sheet_names)

# Verification reload
verify_wb = load_workbook(output_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)

v_target = verify_wb[orig_sheet_names[0]]
v_orig = verify_wb["Original Data"]

remaining_matches = []
for r in range(2, v_target.max_row + 1):
    v = v_target.cell(r, 5).value
    s = "" if v is None else str(v).strip()
    if s.startswith("Z1") or s.startswith("X1"):
        remaining_matches.append((r, v))

print("\nVerification target max_row:", v_target.max_row)
print("Remaining Z1/X1 matches in target:", remaining_matches)
print_rows(v_target, 1, v_target.max_row, "Verified target")
print_rows(v_orig, 1, 12, "Verified Original Data")

final_output_path = output_path
