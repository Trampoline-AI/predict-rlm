import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers row 1:", headers)
    
    # first 10 rows
    first_n = min(max_row, 10)
    print("First rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, min(max_col, 8)+1)]
        print(f"Row {r}: {vals}")
    
    # last 5 rows
    start_last = max(1, max_row-4)
    print("Last rows:")
    for r in range(start_last, max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, min(max_col, 8)+1)]
        print(f"Row {r}: {vals}")
    
    # inspect column E specifically
    if max_col >= 5:
        print("Column E samples (row, value) first 15 non-empty/any:")
        e_samples = []
        for r in range(1, min(max_row, 20)+1):
            e_samples.append((r, ws.cell(r, 5).value))
        print(e_samples)
        
        matches = []
        for r in range(1, max_row+1):
            v = ws.cell(r, 5).value
            s = "" if v is None else str(v)
            if s.startswith("Z1") or s.startswith("X1"):
                matches.append((r, v))
        print("Rows with E starting Z1/X1:", matches[:30], "count=", len(matches))

for ws in wb.worksheets:
    sheet_summary(ws)
