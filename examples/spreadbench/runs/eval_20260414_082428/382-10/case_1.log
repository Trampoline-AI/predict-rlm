# Determine rows to clear: nonblank and not equal to 'comments' case-insensitive
rows_to_clear = []
rows_to_keep = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is None or v == "":
        continue
    if isinstance(v, str) and v.strip().lower() == "comments":
        rows_to_keep.append(r)
    else:
