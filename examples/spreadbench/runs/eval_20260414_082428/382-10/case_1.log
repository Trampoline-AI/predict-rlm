import os, json, math, statistics
from collections import Counter
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws, sample_cols=10, first_n=8, last_n=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, min(ws.max_column, sample_cols)+1)]
    print("Row1 headers/sample:", headers)
    # find real non-empty rows count rough
    nonempty_rows = []
    for r in range(1, ws.max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, sample_cols)+1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("First nonempty rows:", nonempty_rows[:first_n])
    print("Last nonempty rows:", nonempty_rows[-last_n:])
    for r in range(1, min(ws.max_row, first_n)+1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, sample_cols)+1)]
        print("row", r, vals)
    start_last = max(1, ws.max_row-last_n+1)
    print("Last rows sample:")
    for r in range(start_last, ws.max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, sample_cols)+1)]
        print("row", r, vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Inspect Call QC if exists
if "Call QC" in wb.sheetnames:
    ws = wb["Call QC"]
    print("\nDetailed inspection of 'Call QC' column A:")
    vals = []
    for r in range(1, ws.max_row+1):
        cell = ws.cell(r, 1)
        fill = cell.fill
        color = None
        if fill and fill.fill_type == "solid":
            color = fill.fgColor.rgb or fill.fgColor.indexed or fill.fgColor.type
        vals.append((r, cell.value, color))
    nonempty = [(r,v,c) for r,v,c in vals if v not in (None, "")]
    print("Non-empty count in A:", len(nonempty))
    print("First 20 non-empty A cells:", nonempty[:20])
    print("Last 20 non-empty A cells:", nonempty[-20:])
    counter = Counter(str(v).strip() if v is not None else None for _,v,_ in nonempty)
    print("Most common A values:", counter.most_common(20))
    red_like = [(r,v,c) for r,v,c in nonempty if c and ("FF0000" in str(c).upper() or str(c).upper() in {"00FF0000","FFFF0000"})]
    print("Red-like filled non-empty A cells:", red_like[:50], "count=", len(red_like))
    
    # print rows around comments and red cells
    comment_rows = [r for r,v,c in nonempty if str(v).strip().lower() == "comments"]
    print("Rows where A == 'comments':", comment_rows[:50], "count=", len(comment_rows))
    interesting = sorted(set(comment_rows[:10] + [r for r,_,_ in red_like[:20]]))
    for r in interesting[:20]:
        rowvals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8)+1)]
        print("Interesting row", r, rowvals)
else:
    print("No sheet named 'Call QC'")
