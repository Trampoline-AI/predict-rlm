from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os, shutil

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheetnames:", orig_sheetnames)

# Inspect relevant cells/formulas more carefully
print("Relevant headers A:G:", [ws.cell(1,c).value for c in range(1,8)])
for r in range(2, 9):
    vals = [ws.cell(r,c).value for c in range(1,8)]
    print(f"Row {r} A:G values:", vals)

g2 = ws["G2"].value
if isinstance(g2, ArrayFormula):
    print("G2 is ArrayFormula")
    print("G2 text:", g2.text)
    print("G2 ref:", g2.ref)
else:
    print("G2 value:", g2)

print("Existing F formulas/values:")
for r in range(2, 9):
    print(r, ws.cell(r,6).value)

# Determine actual data extent from columns A:C
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if any(ws.cell(r,c).value not in (None, "") for c in range(1,4)):
        last_data_row = r
        break
print("Last data row based on A:C:", last_data_row)

# Write working formulas into the existing target cells in column F.
# Only rows corresponding to the report area should be filled; use IF to keep blanks blank.
for r in range(2, last_data_row + 1):
    formula = f'=IF(G{r}="","",INDEX($A$2:$A${last_data_row},MATCH(G{r},$B$2:$B${last_data_row},0)))'
    ws.cell(r, 6).value = formula

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb2 = load_workbook(outfile)
print("Sheetnames after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = s
    wb2.save(outfile)
    print("Restored original sheet names:", wb2.sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("Verified written formulas in F2:F8:")
for r in range(2, 9):
    print(r, wsf.cell(r,6).value)

# Verify calculated values
wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals[orig_sheetnames[0]]
print("Verified output values F2:G8 after recalculation:")
for r in range(2, 9):
    print(r, "F=", wsv.cell(r,6).value, "G=", wsv.cell(r,7).value)

output_spreadsheet = outfile
```
