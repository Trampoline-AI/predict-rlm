from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from datetime import datetime

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
ws_rates = wb["RateHurdles"]
ws_dep = wb["Deposits"]

print("Original sheet names:", orig_sheetnames)

# Print exact target cells and relevant surrounding area before writing
print("\nDeposits target area before writing:")
for r in range(1, ws_dep.max_row + 1):
    print(r, [ws_dep.cell(r, c).value for c in range(1, ws_dep.max_column + 1)])

print("\nChecking which RateHurdles rows match each deposit row:")
rate_rows = []
for r in range(2, ws_rates.max_row + 1):
    vals = [ws_rates.cell(r, c).value for c in range(1, 6)]
    if any(v is not None for v in vals):
        rate_rows.append({
            "row": r,
            "start": ws_rates.cell(r, 1).value,
            "end": ws_rates.cell(r, 2).value,
            "type": ws_rates.cell(r, 3).value,
            "salesperson": ws_rates.cell(r, 4).value,
            "rate": ws_rates.cell(r, 5).value,
        })

for r in range(2, ws_dep.max_row + 1):
    comm = ws_dep.cell(r, 1).value
    sale_type = ws_dep.cell(r, 2).value
    salesperson = ws_dep.cell(r, 3).value
    po_date = ws_dep.cell(r, 4).value
    print(f"\nDeposit row {r}: existing A{r}={comm}, Type={sale_type}, LeadsSalesPerson={salesperson}, PODateReceived={po_date}")
    matches = []
    for rr in rate_rows:
        if rr["type"] == sale_type and rr["salesperson"] == salesperson and rr["start"] is not None and rr["end"] is not None and po_date is not None:
            if rr["start"] <= po_date <= rr["end"]:
                matches.append(rr)
    print("Matching rate rows:", matches)

# Write formulas only into blank target cells in Commission Rate column
# Use INDEX/MATCH with INDEX wrapper around boolean product for compatibility
last_rate_row = max(r["row"] for r in rate_rows)
for r in range(2, ws_dep.max_row + 1):
    target = ws_dep.cell(r, 1)
    if target.value in (None, ""):
        formula = (
            f'=INDEX(RateHurdles!$E$2:$E${last_rate_row},'
            f'MATCH(1,INDEX((RateHurdles!$D$2:$D${last_rate_row}=C{r})*'
            f'(RateHurdles!$C$2:$C${last_rate_row}=B{r})*'
            f'(D{r}>=RateHurdles!$A$2:$A${last_rate_row})*'
            f'(D{r}<=RateHurdles!$B$2:$B${last_rate_row}),0),0))'
        )
        print(f"Writing formula to A{r}: {formula}")
        target.value = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = name
    wb_after.save(out_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and evaluated values
wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)
ws_dep_f = wb_formula["Deposits"]
ws_dep_v = wb_values["Deposits"]

print("\nVerification of target cells:")
for r in range(2, ws_dep_f.max_row + 1):
    print(
        f"Row {r}: formula in A{r}={ws_dep_f[f'A{r}'].value!r}, "
        f"evaluated value={ws_dep_v[f'A{r}'].value!r}, "
        f"B{r}={ws_dep_v[f'B{r}'].value!r}, C{r}={ws_dep_v[f'C{r}'].value!r}, D{r}={ws_dep_v[f'D{r}'].value!r}"
    )

output_spreadsheet = out_path
