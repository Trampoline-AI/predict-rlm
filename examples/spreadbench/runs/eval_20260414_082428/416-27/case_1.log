```repl
import os, shutil
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]
orig_sheetnames = wb.sheetnames[:]

print("Detailed row inspection:")
row_data = []
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    row_data.append(vals)
    print(r, vals)

# Determine first and last non-empty row in column A
def nonempty(v):
    return v is not None and str(v).strip() != ""

colA_vals = {r: ws.cell(r, 1).value for r in range(1, ws.max_row + 1)}
nonempty_rows = [r for r, v in colA_vals.items() if nonempty(v)]
print("Non-empty rows in col A:", nonempty_rows)

first_row = min(nonempty_rows)
last_row = max(nonempty_rows)
blank_rows_between = [r for r in range(first_row, last_row + 1) if not nonempty(ws.cell(r, 1).value)]

print("First non-empty row:", first_row, "value:", ws.cell(first_row, 1).value)
print("Last non-empty row:", last_row, "value:", ws.cell(last_row, 1).value)
print("Blank rows to delete:", blank_rows_between)

# Apply equivalent corrected macro logic directly: delete blank rows in col A
# from last to first so row indices remain valid
for r in reversed(blank_rows_between):
    ws.delete_rows(r, 1)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for ws_obj, orig_name in zip(wb2.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    wb2.save(out_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_sheetnames[0]]
print("Verified sheet names:", wbv.sheetnames)
print("Output max_row/max_col:", wsv.max_row, wsv.max_column)
print("All output rows:")
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

# Persist path for submission
final_output_path = out_path
