import os, json, textwrap, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input:", path, os.path.exists(path))

wb = load_workbook(path)
orig_sheetnames = wb.sheetnames[:]
print("Sheet names:", orig_sheetnames)

def sheet_summary(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers row1:", headers)
    
    # first 10 rows
    first_rows = []
    for r in range(1, min(max_row, 10)+1):
        first_rows.append([ws.cell(r, c).value for c in range(1, max_col+1)])
    print("First rows sample:")
    for row in first_rows:
        print(row)
    
    # last 5 rows
    start_last = max(1, max_row-4)
    print("Last rows sample:")
    for r in range(start_last, max_row+1):
        print([ws.cell(r, c).value for c in range(1, max_col+1)])

for ws in wb.worksheets:
    sheet_summary(ws)

# Search workbook for macro-related text/instruction areas
hits = []
patterns = ["Del_Blanks", "macro", "blank", "delete", "Column A", "Sub "]
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                low = v.lower()
                if any(p.lower() in low for p in patterns):
                    hits.append((ws.title, cell.coordinate, v[:200]))
print("\nPotential instruction/macro text hits:", len(hits))
for h in hits[:50]:
    print(h)

# Also print formulas if any in workbook
formula_cells = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((ws.title, cell.coordinate, cell.value))
print("\nFormula cells found:", len(formula_cells))
for item in formula_cells[:50]:
    print(item)
