from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Inspect existing Q formulas/values explicitly
print("Existing Q cells before modification:")
for r in range(2, ws.max_row + 1):
    qv = ws.cell(r, 17).value
    print(f"Q{r} -> {repr(qv)} ; type={type(qv).__name__}")

# Build group map by Project ID (column H), based on actual sheet headers and sample pattern.
# Technology indicator is column L "Budget Type".
group_has_tech = {}
for r in range(2, ws.max_row + 1):
    project_id = ws.cell(r, 8).value   # H
    budget_type = ws.cell(r, 12).value # L
    if project_id not in (None, ""):
        bt = str(budget_type).strip().lower() if budget_type is not None else ""
        group_has_tech.setdefault(project_id, False)
        if bt == "technology":
            group_has_tech[project_id] = True

print("\nComputed project_id -> has_technology:")
for k, v in group_has_tech.items():
    print(k, v)

# Apply output to ALL relevant rows in existing column Q
for r in range(2, ws.max_row + 1):
    project_id = ws.cell(r, 8).value   # H Project ID
    linked = ws.cell(r, 9).value       # I Linked to Budget
    current_q = ws.cell(r, 17).value

    if project_id in (None, ""):
        result = "N"
    else:
        result = "Y" if group_has_tech.get(project_id, False) else "N"

    ws.cell(r, 17).value = result
    print(f"Row {r}: ProjectID={project_id!r}, Linked={linked!r}, oldQ={current_q!r} -> newQ={result!r}")

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload after recalc; restore sheet names if changed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    for idx, orig in enumerate(orig_names):
        wb2.worksheets[idx].title = orig
    wb2.save(out_path)
    print("Restored original sheet names:", orig_names)

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]

print("\nVerified target cells Q2:Q11 after save/recalc:")
for r in range(2, wsv.max_row + 1):
    row_summary = {
        "row": r,
        "H_ProjectID": wsv.cell(r, 8).value,
        "I_Linked": wsv.cell(r, 9).value,
        "L_BudgetType": wsv.cell(r, 12).value,
        "Q_Result": wsv.cell(r, 17).value,
    }
    print(row_summary)

output_spreadsheet = out_path
print("\nOutput path ready:", output_spreadsheet)
