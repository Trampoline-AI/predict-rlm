    rec = {
        "row": r,
        "URN": lookup[f"A{r}"].value,
        "LANAME": lookup[f"B{r}"].value,
        "LA": lookup[f"C{r}"].value,
        "ESTAB": lookup[f"D{r}"].value,
        "LAESTAB": lookup[f"E{r}"].value,
        "SCHNAME": lookup[f"F{r}"].value,
        "POSTCODE": lookup[f"K{r}"].value,
    }
    lookup_rows[r] = rec
    lookup_by_postcode[norm_text(rec["POSTCODE"])].append(rec)
    lookup_by_name[norm_name(rec["SCHNAME"])].append(rec)

def choose_candidate(comp_name, candidates):
