        " C OF E ": " CHURCH OF ENGLAND ",
        " CE ": " CHURCH OF ENGLAND ",
    }
    s = f" {s} "
    for k, v in repl.items():
        s = s.replace(k, v)
    s = " ".join(s.split())
    return s

# Build lookup indices
