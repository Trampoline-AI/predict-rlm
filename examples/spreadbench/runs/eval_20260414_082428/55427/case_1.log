    if not candidates:
        return None
    if len(candidates) == 1:
        return candidates[0]
    cn = norm_name(comp_name)

    # exact normalized name
    exact = [c for c in candidates if norm_name(c["SCHNAME"]) == cn]
    if len(exact) == 1:
        return exact[0]

    # contains match either direction
    contains = [
        c for c in candidates
        if cn and (cn in norm_name(c["SCHNAME"]) or norm_name(c["SCHNAME"]) in cn)
    ]
    if len(contains) == 1:
        return contains[0]

    # token overlap score
    ctoks = set(cn.split())
    scored = []
    for c in candidates:
        ntoks = set(norm_name(c["SCHNAME"]).split())
        inter = len(ctoks & ntoks)
        union = len(ctoks | ntoks) or 1
        score = inter / union
        scored.append((score, inter, c))
    scored.sort(key=lambda x: (x[0], x[1]), reverse=True)
