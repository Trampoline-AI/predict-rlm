        ntoks = set(norm_name(c["SCHNAME"]).split())
        inter = len(ctoks & ntoks)
        union = len(ctoks | ntoks) or 1
        score = inter / union
        scored.append((score, inter, c))
    scored.sort(key=lambda x: (x[0], x[1]), reverse=True)
    if len(scored) >= 2:
        if scored[0][0] >= 0.6 and scored[0][0] > scored[1][0]:
            return scored[0][2], "postcode+best_name_score"
    elif len(scored) == 1 and scored[0][0] >= 0.6:
        return scored[0][2], "postcode+best_name_score"

    # global exact name fallback if unique
    name_cands = lookup_by_name.get(cn, [])
    if len(name_cands) == 1:
        return name_cands[0], "name_unique"

    return None, "ambiguous"

# Build KS4 URN map
ks4_by_urn = {}
for r in range(2, ks4.max_row + 1):
    urn = ks4[f"C{r}"].value
    if urn not in (None, ""):
        ks4_by_urn[str(urn)] = [ks4.cell(r, c).value for c in range(5, 13)]  # E:L

# Print target columns before modification for sample rows
print("Pre-write sample target area:")
for r in list(range(2, 10)) + list(range(ws.max_row - 4, ws.max_row + 1)):
    if 2 <= r <= ws.max_row:
        print(r, {
            "A": ws[f"A{r}"].value,
            "B": ws[f"B{r}"].value,
            "C": ws[f"C{r}"].value,
            "E": ws[f"E{r}"].value,
            "L": ws[f"L{r}"].value,
            "AC_AJ": [ws.cell(r, c).value for c in range(29, 37)]
        })

# Apply updates
match_method_counts = Counter()
filled_A = filled_B = filled_C = filled_ks4_rows = 0
left_unmatched = 0

for r in range(2, ws.max_row + 1):
    row_has_data = any(ws.cell(r, c).value not in (None, "") for c in range(4, 19))
    if not row_has_data:
        continue

    comp_name = ws[f"E{r}"].value
    postcode = ws[f"L{r}"].value
    existing_c = ws[f"C{r}"].value

    candidate, method = choose_candidate(comp_name, lookup_by_postcode.get(norm_text(postcode), []), existing_c)
    match_method_counts[method] += 1

    if candidate is None:
        left_unmatched += 1
        continue

    # A = URN
    if ws[f"A{r}"].value in (None, ""):
        ws[f"A{r}"] = candidate["URN"]
        filled_A += 1
    elif str(ws[f"A{r}"].value) != str(candidate["URN"]):
        ws[f"A{r}"] = candidate["URN"]
        filled_A += 1

    # B = DFES check (ESTAB) -- replace broken formula with actual matched value
    if ws[f"B{r}"].value != candidate["ESTAB"]:
        ws[f"B{r}"] = candidate["ESTAB"]
        filled_B += 1

    # C = DfE Number -- preserve existing values, fill blanks only
    if ws[f"C{r}"].value in (None, "") and candidate["ESTAB"] not in (None, ""):
        ws[f"C{r}"] = candidate["ESTAB"]
        filled_C += 1

# Merge KS4 data into AC:AJ using URN in col A
for r in range(2, ws.max_row + 1):
    urn = ws[f"A{r}"].value
    if urn in (None, ""):
        continue
    metrics = ks4_by_urn.get(str(urn))
    if not metrics:
        continue
    wrote_any = False
    for offset, value in enumerate(metrics, start=29):  # AC=29 ... AJ=36
        if value not in (None, ""):
            ws.cell(r, offset).value = value
            wrote_any = True
    if wrote_any:
        filled_ks4_rows += 1

# Save
wb.save(outfile)
print("\nWrite summary:")
print("filled_A:", filled_A)
print("filled_B:", filled_B)
print("filled_C:", filled_C)
print("filled_ks4_rows:", filled_ks4_rows)
print("left_unmatched:", left_unmatched)
print("match methods:", dict(match_method_counts))

# Recalculate
recalc_result = await recalculate(outfile)
print("\nRecalculate:", recalc_result)

# Restore original sheet names if needed
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalculation:", wb2.sheetnames)
    for i, old_name in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = old_name
    wb2.save(outfile)
    print("Sheet names restored to:", orig_sheet_names)
else:
    print("Sheet names preserved.")

# Verification reload
verify_wb = load_workbook(outfile, data_only=True)
vws = verify_wb["Compiled and located schools da"]

print("\nVerified sample target area after recalc (data_only=True):")
sample_rows = list(range(2, 15)) + [100, 250, 500, 750, 1000, 1250, ws.max_row]
for r in sample_rows:
    if 2 <= r <= vws.max_row:
        print(r, {
            "A_URN": vws[f"A{r}"].value,
            "B_DFEScheck": vws[f"B{r}"].value,
            "C_DfENumber": vws[f"C{r}"].value,
            "E_Name": vws[f"E{r}"].value,
            "L_Postcode": vws[f"L{r}"].value,
            "AC_AJ": [vws.cell(r, c).value for c in range(29, 37)]
        })

# Verification counts
nonblank_A = nonblank_B = nonblank_C = 0
nonblank_ks4 = 0
for r in range(2, vws.max_row + 1):
    if vws[f"A{r}"].value not in (None, ""):
        nonblank_A += 1
    if vws[f"B{r}"].value not in (None, ""):
        nonblank_B += 1
    if vws[f"C{r}"].value not in (None, ""):
        nonblank_C += 1
    if any(vws.cell(r, c).value not in (None, "") for c in range(29, 37)):
        nonblank_ks4 += 1

print("\nVerification counts:")
print("Nonblank A (URN):", nonblank_A)
print("Nonblank B (DFES check):", nonblank_B)
print("Nonblank C (DfE Number):", nonblank_C)
print("Rows with any KS4 data in AC:AJ:", nonblank_ks4)
print("Final sheet names:", verify_wb.sheetnames)

output_spreadsheet = outfile
