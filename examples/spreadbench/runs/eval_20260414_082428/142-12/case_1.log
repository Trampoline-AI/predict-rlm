output_path = os.path.join(output_dir, filename)

# Reload original workbook for modification
wb2 = load_workbook(input_path)
original_sheet_names = wb2.sheetnames[:]

changed_cells = []
for ws in wb2.worksheets:
    if ws.max_column < 10:
        continue
    for r in range(1, ws.max_row + 1):
        f_cell = ws.cell(r, 6)
        j_val = ws.cell(r, 10).value
        
        is_whole = False
        if isinstance(j_val, int):
            is_whole = True
        elif isinstance(j_val, float):
            is_whole = float(j_val).is_integer()
        elif isinstance(j_val, str):
            s = j_val.strip().replace(",", "")
            try:
                is_whole = float(s).is_integer()
            except:
                is_whole = False

        if f_cell.value == "Marble Slab Creamery" and is_whole:
            changed_cells.append((ws.title, f_cell.coordinate, f_cell.value, j_val))
            f_cell.value = "Georgia State WH"

print("Cells to change:", changed_cells)
wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and fix sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    for i, old_name in enumerate(original_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verify final values
