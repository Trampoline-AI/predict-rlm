import os, shutil, json, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

sheet_info = {}
for ws in wb.worksheets:
    headers = row_values(ws, 1, ws.max_column)
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
    }
    print(f"\nSheet: {ws.title}")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    print("Headers row 1:", headers)
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_values(ws, r, min(ws.max_column, 12)))

# Inspect specific cells/ranges referenced by instruction
for ws in wb.worksheets:
    if ws.max_column >= 10:
        print(f"\nDetailed check in sheet {ws.title}: columns F and J")
        for coord in ["F10", "J10", "F13", "J13"]:
            print(coord, "=", ws[coord].value)
        print("Rows with cols A:J around 8:15")
        for r in range(8, min(ws.max_row, 15) + 1):
            vals = [ws.cell(r, c).value for c in range(1, 11)]
            print(r, vals)

# Find candidate rows
matches = []
for ws in wb.worksheets:
    if ws.max_column < 10:
        continue
    for r in range(2, ws.max_row + 1):
        f_val = ws.cell(r, 6).value
        j_val = ws.cell(r, 10).value
        is_whole = False
        if isinstance(j_val, int):
            is_whole = True
        elif isinstance(j_val, float):
            is_whole = float(j_val).is_integer()
        elif isinstance(j_val, str):
            s = j_val.strip().replace(",", "")
            try:
                num = float(s)
                is_whole = num.is_integer()
            except:
                is_whole = False
        if f_val == "Marble Slab Creamery" and is_whole:
            matches.append((ws.title, r, f_val, j_val))
print("\nCandidate matching rows:", matches)
