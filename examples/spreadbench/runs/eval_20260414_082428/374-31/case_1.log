import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

sheet_summaries = {}
for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # inspect column A for "Code" and nearby context
    code_rows = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if isinstance(v, str) and v.strip().lower() == "code":
            code_rows.append(r)
    print("Rows where column A == 'Code':", code_rows[:50], "count=", len(code_rows))
    
    for r in code_rows[:10]:
        print(f"Context around row {r}:")
        for rr in range(max(1, r-3), min(ws.max_row, r+3) + 1):
            print(" ", rr, row_values(ws, rr, min(ws.max_column, 8)))
    
    sheet_summaries[ws.title] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
        "code_rows": code_rows,
    }

print("\nSummary keys:", list(sheet_summaries.keys()))
