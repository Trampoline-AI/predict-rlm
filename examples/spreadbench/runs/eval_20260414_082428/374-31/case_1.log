```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook for modification
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]

def is_blank_row(ws, r):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None and str(v) != "":
            return False
    return True

deletions_by_sheet = {}

for ws in wb.worksheets:
    code_rows = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if isinstance(v, str) and v.strip().lower() == "code":
            code_rows.append(r)

    rows_to_delete = set()
    for r in code_rows:
        rr = r - 1
        while rr >= 1 and is_blank_row(ws, rr):
            rows_to_delete.add(rr)
            rr -= 1

    deletions_by_sheet[ws.title] = sorted(rows_to_delete)
    print(f"Sheet {ws.title}: code_rows={code_rows}, blank rows immediately above to delete={sorted(rows_to_delete)}")

    if rows_to_delete:
        # delete bottom-up
        for rr in sorted(rows_to_delete, reverse=True):
            ws.delete_rows(rr, 1)

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for ws, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws.title = orig_name
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

for ws in wb_verify.worksheets:
    print(f"\nVERIFY SHEET {ws.title}: max_row={ws.max_row}, max_col={ws.max_column}")
    # print all rows since this file is tiny
    for r in range(1, ws.max_row + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

print("Final output file ready:", outfile)
```
