```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Confirm target area before writing
print("Writing formulas to target range J3:N5 on sheet:", ws.title)
for r in range(3, 6):
    print("Before", r, [ws.cell(r, c).value for c in range(9, 15)])

# Write formulas for the full result matrix
# Compare Source1 value (same result row/name and result date) against Source2 value.
for r in range(3, 6):
    for c in range(10, 15):  # J:N
        date_header_cell = ws.cell(2, c).coordinate   # J$2 etc
        name_cell = ws.cell(r, 9).coordinate          # I3 etc
        formula = (
            f'=IFERROR('
            f'INDEX($C$8:$G$10,MATCH({name_cell},$B$8:$B$10,0),MATCH({date_header_cell},$C$7:$G$7,0))'
            f'=INDEX($C$3:$G$5,MATCH({name_cell},$B$3:$B$5,0),MATCH({date_header_cell},$C$2:$G$2,0))'
            f',FALSE)'
        )
        ws.cell(r, c).value = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    for i, old_name in enumerate(original_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas exist
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Formula check J3:N5:")
for r in range(3, 6):
    print([ws_formula.cell(r, c).value for c in range(10, 15)])

# Verify cached calculated values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("Calculated values I2:N5:")
for r in range(2, 6):
    print(r, [ws_values.cell(r, c).value for c in range(9, 15)])

# Keep for submission
final_output_path = output_path
```
