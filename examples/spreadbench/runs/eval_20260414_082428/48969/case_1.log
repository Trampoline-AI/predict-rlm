import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

def nonempty_headers(ws, header_row=1):
    vals = row_values(ws, header_row, ws.max_column)
    return [(get_column_letter(i+1), v) for i, v in enumerate(vals)]

for s in wb.sheetnames:
    ws = wb[s]
    print("\n" + "="*80)
    print(f"Sheet: {s}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    headers = nonempty_headers(ws, 1)
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row 2 values:", row_values(ws, 2, ws.max_column))
    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(f"R{r}:", row_values(ws, r, ws.max_column))
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}..{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(f"R{r}:", row_values(ws, r, ws.max_column))
    
    # Scan for formulas and non-empty cells in used range
    formulas = []
    nonempty_count = 0
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None and v != "":
                nonempty_count += 1
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Non-empty cell count:", nonempty_count)
    print("Formula cells found (up to 20):", formulas[:20])
