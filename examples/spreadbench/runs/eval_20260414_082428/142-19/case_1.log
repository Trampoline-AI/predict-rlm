```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Detect contiguous nonblank blocks in A:B
blocks = []
in_block = False
start = None
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    nonblank = not ((a is None or a == "") and (b is None or b == ""))
    if nonblank and not in_block:
        start = r
        in_block = True
    elif not nonblank and in_block:
        blocks.append((start, r - 1))
        in_block = False
if in_block:
    blocks.append((start, ws.max_row))

print("Blocks to sort:", blocks)

# Print current values before modification for exact target ranges
for start, end in blocks:
    print(f"\nBefore block {start}-{end}:")
    for r in range(start, end + 1):
        print(r, ws.cell(r,1).value, "|", ws.cell(r,2).value)

# Sort each block independently, preserving the first row if it is a header
for start, end in blocks:
    first_a = ws.cell(start, 1).value
    first_b = ws.cell(start, 2).value
    has_header = (str(first_a).strip().lower() == "number" and str(first_b).strip().lower() == "name")
    data_start = start + 1 if has_header else start
    
    rows = []
    for r in range(data_start, end + 1):
        rows.append((ws.cell(r, 1).value, ws.cell(r, 2).value))
    
    # sort by column A text, blanks last (though block detection should avoid fully blank rows)
    rows_sorted = sorted(rows, key=lambda x: (x[0] is None, str(x[0])))
    
    for i, (a, b) in enumerate(rows_sorted, start=data_start):
        ws.cell(i, 1).value = a
        ws.cell(i, 2).value = b

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # Rename by position back to original names
    for i, name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]
print("\nVerification after save:")
for start, end in blocks:
    print(f"\nAfter block {start}-{end}:")
    vals = []
    for r in range(start, end + 1):
        rowv = (wsv.cell(r,1).value, wsv.cell(r,2).value)
        vals.append(rowv)
        print(r, rowv[0], "|", rowv[1])
    # Check sort order on data rows only
    data_vals = [a for a,b in vals[1:]]  # skip header
    print("Sorted ascending check:", data_vals == sorted(data_vals, key=lambda x: (x is None, str(x))))

output_spreadsheet = outfile
print("\nPrepared output_spreadsheet:", output_spreadsheet)
```
