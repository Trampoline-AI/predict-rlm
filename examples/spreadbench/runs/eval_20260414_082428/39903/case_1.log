```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Font, Border, Side

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Reload fresh workbook for writing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["SKUs as Bins"]

def count_bins(text):
    if text is None:
        return None
    s = str(text).strip()
    if not s:
        return None
    parts = [p.strip() for p in s.split(",") if str(p).strip()]
    count = 0
    for p in parts:
        loc = p.split(":", 1)[0].strip()
        if not loc.startswith(("X", "Z")):
            count += 1
    return count

# Confirm pre-write values in targets
print("Pre-write target/source check:")
for r in range(2, 7):
    print(r, ws[f"B{r}"].value, "-> existing", ws[f"C{r}"].value)

# Apply values
written = {}
for r in range(2, 7):
    val = count_bins(ws[f"B{r}"].value)
    ws[f"C{r}"] = val
    written[f"C{r}"] = val

# Apply full borders + Courier New 9pt
thin = Side(style="thin", color="000000")
full_border = Border(left=thin, right=thin, top=thin, bottom=thin)
font = Font(name="Courier New", size=9)

for r in range(2, 7):
    cell = ws[f"C{r}"]
    cell.border = full_border
    cell.font = font

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = s
    wb2.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify values with data_only=True
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv[orig_sheetnames[0]]

print("Verified target values C2:C6:")
for r in range(2, 7):
    print(f"C{r} =", wsv[f"C{r}"].value)

# Verify styles from normal load
wbs = load_workbook(outfile)
wss = wbs[orig_sheetnames[0]]
print("Verified styles C2:C6:")
for r in range(2, 7):
    c = wss[f"C{r}"]
    print(
        c.coordinate,
        "value=", c.value,
        "font=", (c.font.name, c.font.sz),
        "border=",
        (c.border.left.style, c.border.right.style, c.border.top.style, c.border.bottom.style)
    )

output_path = outfile
```
