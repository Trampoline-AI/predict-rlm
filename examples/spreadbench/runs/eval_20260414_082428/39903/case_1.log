import os, json, math, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(path), path)

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    if headers2:
        print("Row2:", headers2)
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    # last 5 rows
    print("Last rows:")
    start = max(1, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    # specific C2:C6 current values
    print("C2:C6:")
    for r in range(2, min(6, ws.max_row)+1):
        cell = ws[f"C{r}"]
        print(f"C{r} value={cell.value!r}")

# Also inspect formulas/types in C2:C6 for all sheets
for sname in wb.sheetnames:
    ws = wb[sname]
    for r in range(2, min(6, ws.max_row)+1):
        cell = ws.cell(r, 3)
        if isinstance(cell.value, str) and cell.value.startswith("="):
            print(f"{sname}!C{r} formula:", cell.value)
