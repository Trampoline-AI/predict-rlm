```repl
from openpyxl import load_workbook
import os
from collections import Counter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Exp-DB"]

# Build mapping from A:B, preserving row order but also allowing longest-match selection
mapping = []
for r in range(1, ws.max_row + 1):
    key = ws.cell(r, 1).value
    cat = ws.cell(r, 2).value
    if key not in (None, "") and cat not in (None, ""):
        mapping.append((r, str(key).strip(), str(cat).strip()))

print("Mapping count:", len(mapping))
print("First 10 mappings:", mapping[:10])

def categorize(desc):
    if desc in (None, ""):
        return None, None
    desc_s = str(desc).strip()
    desc_u = desc_s.upper()
    matches = []
    for r, key, cat in mapping:
        key_u = key.upper().strip()
        if key_u and key_u in desc_u:
            matches.append((len(key_u), r, key, cat))
    if not matches:
        return None, None
    # Longest key wins; tie-break by earlier mapping row
    matches.sort(key=lambda x: (-x[0], x[1]))
    best = matches[0]
    return best[3], best[2]

# Inspect current target cells before writing
print("\nPre-write sample target cells:")
sample_rows = list(range(1, min(ws.max_row, 10) + 1)) + list(range(max(1, ws.max_row - 4), ws.max_row + 1))
seen = set()
for r in sample_rows:
    if r in seen:
        continue
    seen.add(r)
    print(
        f"Row {r}: D={ws[f'D{r}'].value!r}, "
        f"E={ws[f'E{r}'].value!r}, G={ws[f'G{r}'].value!r}"
    )

results = []
unmatched = []
for r in range(1, ws.max_row + 1):
    d = ws.cell(r, 4).value
    if d not in (None, ""):
        cat, matched_key = categorize(d)
        results.append((r, d, cat, matched_key))
        if cat is not None:
            ws.cell(r, 5).value = cat   # column E existing output area
            ws.cell(r, 7).value = cat   # column G existing output area
        else:
            ws.cell(r, 5).value = ""
            ws.cell(r, 7).value = ""
            unmatched.append((r, d))

print("\nCategorization sample (first 15):")
for item in results[:15]:
    print(item)

print("\nCategorization sample (last 10):")
for item in results[-10:]:
    print(item)

print("\nUnmatched rows:", len(unmatched))
for item in unmatched[:20]:
    print("UNMATCHED", item)

print("\nCategory counts:")
cnt = Counter(cat for _, _, cat, _ in results if cat)
print(cnt)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    for i, expected in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verification with data_only=True
wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Exp-DB"]

print("\nVerification of target cells E and G:")
verify_rows = [1,2,3,4,5,6,9,10,19,21,22,23,31,35,49,50,51,52,53]
for r in verify_rows:
    if r <= ws_vals.max_row and ws_vals.cell(r, 4).value not in (None, ""):
        print(
            f"Row {r}: D={ws_vals.cell(r,4).value!r} | "
            f"E={ws_vals.cell(r,5).value!r} | G={ws_vals.cell(r,7).value!r}"
        )

# Sanity check for blanks in targets where D has data
blank_targets = []
for r in range(1, ws_vals.max_row + 1):
    d = ws_vals.cell(r, 4).value
    if d not in (None, ""):
        e = ws_vals.cell(r, 5).value
        g = ws_vals.cell(r, 7).value
        if e in (None, "") or g in (None, ""):
            blank_targets.append((r, d, e, g))
print("\nBlank target rows after verification:", len(blank_targets))
for item in blank_targets[:20]:
    print(item)
