import os, re, json, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def display_sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect headers from row 1 and row 2 for safety
    row1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print("Row 1 values:", row1)
    if row2:
        print("Row 2 values:", row2)
    
    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # print coordinates/values in columns A-F for more detail
    print("Detailed A-F preview:")
    for r in range(1, min(ws.max_row, 12) + 1):
        pairs = []
        for c in range(1, min(ws.max_column, 6) + 1):
            cell = ws.cell(r, c)
            pairs.append(f"{cell.coordinate}={cell.value!r}")
        print(" | ".join(pairs))

for ws in wb.worksheets:
    display_sheet_info(ws)
