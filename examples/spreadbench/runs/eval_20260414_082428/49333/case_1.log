```repl
from openpyxl import load_workbook
import re
from collections import defaultdict

wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
ws3 = wb["Sheet3"]

def norm(s):
    if s is None:
        return None
    s = str(s)
    s = s.strip()
    s = s.replace("'", "").replace(".", "")
    s = re.sub(r"\s+", " ", s)
    return s

sheet1_names = [ws1[f"F{r}"].value for r in range(2, ws1.max_row + 1) if ws1[f"F{r}"].value]
sheet3_names = [ws3[f"A{r}"].value for r in range(2, ws3.max_row + 1) if ws3[f"A{r}"].value]
sheet2_names = [ws2[f"G{r}"].value for r in range(2, ws2.max_row + 1) if ws2[f"G{r}"].value]

sheet3_raw_set = set(sheet3_names)
sheet3_norm_map = defaultdict(list)
for i, v in enumerate(sheet3_names, start=2):
    sheet3_norm_map[norm(v)].append((i, v, ws3.cell(i,2).value, ws3.cell(i,3).value, ws3.cell(i,4).value))

sheet2_norm_map = defaultdict(list)
for i, v in enumerate(sheet2_names, start=2):
    sheet2_norm_map[norm(v)].append((i, v, ws2.cell(i,8).value, ws2.cell(i,9).value, ws2.cell(i,10).value))

print("Sheet1 target rows and current formulas/results:")
for r in range(2, ws1.max_row + 1):
    print(
        r,
        "F=", ws1.cell(r,6).value,
        "G=", ws1.cell(r,7).value,
        "H=", ws1.cell(r,8).value,
        "I=", ws1.cell(r,9).value,
        "Correct=", ws1.cell(r,10).value,
        "Results=", ws1.cell(r,11).value,
        "Manually=", ws1.cell(r,12).value,
    )

print("\nMatch diagnostics:")
for r in range(2, ws1.max_row + 1):
    name = ws1.cell(r,6).value
    n = norm(name)
    raw_in_sheet3 = name in sheet3_raw_set
    norm_sheet3 = sheet3_norm_map.get(n, [])
    norm_sheet2 = sheet2_norm_map.get(n, [])
    print(f"Row {r}: name={name!r}, norm={n!r}, raw_in_sheet3={raw_in_sheet3}, norm_matches_sheet3={len(norm_sheet3)}, norm_matches_sheet2={len(norm_sheet2)}")
    if norm_sheet3:
        print("  Sheet3 matches:", norm_sheet3[:3])
    if norm_sheet2:
        print("  Sheet2 matches:", norm_sheet2[:3])

print("\nSearch for exact Bow Thai and others in Sheet2/3:")
targets = [ws1.cell(r,6).value for r in range(2, ws1.max_row+1)]
for t in targets:
    n = norm(t)
    s2 = [x for x in sheet2_norm_map.get(n, [])[:5]]
    s3 = [x for x in sheet3_norm_map.get(n, [])[:5]]
    print(t, "-> Sheet2", s2, "| Sheet3", s3)
