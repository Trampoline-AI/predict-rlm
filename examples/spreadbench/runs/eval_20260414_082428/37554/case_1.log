from openpyxl import load_workbook
from openpyxl.worksheet.formula import ArrayFormula
from openpyxl.utils import get_column_letter
import os, shutil

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Target cells and current formulas/values around D:E:F:")
for r in range(1, 20):
    d = ws[f"D{r}"].value
    e = ws[f"E{r}"].value
    f = ws[f"F{r}"].value
    if isinstance(f, ArrayFormula):
        f_repr = f"ArrayFormula text={f.text!r}, ref={f.ref!r}"
    else:
        f_repr = repr(f)
    print(r, {"D": d, "E": e, "F": f_repr})

# Also inspect cached values with data_only to understand current intended outputs if any
wb_data = load_workbook(input_path, data_only=True)
ws_data = wb_data[wb_data.sheetnames[0]]
print("\nData-only view for rows 2:19, cols A:F")
for r in range(2, 20):
    vals = [ws_data.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

# Build exact-match formulas in F2:F17
# Left lookup table is A2:B17; right requested types are D2:D17
for r in range(2, 18):
    target_type = ws[f"D{r}"].value
    old = ws[f"F{r}"].value
    old_text = old.text if isinstance(old, ArrayFormula) else old
    print(f"Replacing F{r}: target={target_type!r}, old_formula={old_text!r}")
    ws[f"F{r}"] = f'=SUMPRODUCT(($A$2:$A$17=D{r})*($B$2:$B$17))'

# Save
