def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # gather first 10 headers from row 1 and row 2 in case headers aren't obvious
    row1 = [ws.cell(1, c).value for c in range(1, min(ws.max_column, 15)+1)]
    row2 = [ws.cell(2, c).value for c in range(1, min(ws.max_column, 15)+1)]
    print("Row1:", row1)
    print("Row2:", row2)
    
    # detect used rows more carefully
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # print first 10 non-empty rows
    first_rows = nonempty_rows[:10]
    last_rows = nonempty_rows[-5:] if len(nonempty_rows) > 10 else []
    print("First sample rows:")
    for r in first_rows:
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 10)+1)]
        print(r, vals)
    if last_rows:
        print("Last sample rows:")
        for r in last_rows:
            vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 10)+1)]
            print(r, vals)

for ws in wb.worksheets:
