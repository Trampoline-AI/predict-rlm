```repl
import os
from datetime import datetime, date
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
wsm = wb["mechanic"]
wsd = wb["data"]

def normalize_excel_date(v):
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    if isinstance(v, str):
        s = v.strip()
        for fmt in ("%m-%d-%y", "%m-%d-%Y", "%Y-%m-%d", "%m/%d/%y", "%m/%d/%Y"):
            try:
                return datetime.strptime(s, fmt).date()
            except:
                pass
    return None

def to_float(v):
    if v is None or v == "":
        return None
    if isinstance(v, (int, float)):
        return float(v)
    try:
        return float(v)
    except:
        return None

# Build totals from source data
totals = {}
source_matches = []
for r in range(2, wsd.max_row + 1):
    d = normalize_excel_date(wsd.cell(r, 1).value)
    name = wsd.cell(r, 3).value
    k = to_float(wsd.cell(r, 11).value)
    if d and name and k is not None:
        key = (d, str(name).strip().lower())
        totals[key] = totals.get(key, 0.0) + k
        source_matches.append((r, d, str(name).strip().lower(), k))

# Fill mechanic output matrix B2:E32 with actual totals per day/mechanic
for r in range(2, wsm.max_row + 1):
    row_date = normalize_excel_date(wsm.cell(r, 1).value)
    if not row_date:
        continue
    for c in range(2, wsm.max_column + 1):
        mech_header = wsm.cell(1, c).value
        if mech_header is None or str(mech_header).strip() == "":
            continue
        mech_key = str(mech_header).strip().lower()
        val = totals.get((row_date, mech_key), 0.0)
        wsm.cell(r, c).value = val
        wsm.cell(r, c).number_format = "0.00"

# Put corrected formulas into the explicit example area on data sheet
# N3: total by mechanic text in M3
# O3: total by mechanic text in M3 AND date in N5
last_row = wsd.max_row
wsd["N3"] = f'=SUMPRODUCT(--ISNUMBER(SEARCH($M$3,$C$2:$C${last_row})),$K$2:$K${last_row})'
wsd["O3"] = f'=SUMPRODUCT(--ISNUMBER(SEARCH($M$3,$C$2:$C${last_row})),--(IFERROR(INT($A$2:$A${last_row}),DATEVALUE($A$2:$A${last_row}))=INT($N$5)),$K$2:$K${last_row})'

wb.save(outfile)
print("Saved initial output to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for ws, original_name in zip(wb2.worksheets, orig_sheetnames):
        ws.title = original_name
    wb2.save(outfile)
    print("Restored sheet names:", orig_sheetnames)
else:
    print("Sheet names after recalc:", wb2.sheetnames)

# Verification with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
wsm_f = wb_formula["mechanic"]
wsd_f = wb_formula["data"]

print("\nVerification - formulas written:")
print("data!N3 formula:", wsd_f["N3"].value)
print("data!O3 formula:", wsd_f["O3"].value)

print("\nVerification - mechanic sample rows 2:6, cols A:E (formula workbook view):")
for r in range(2, 7):
    print(r, [wsm_f.cell(r, c).value for c in range(1, 6)])

# Verification with cached/calculated values
wb_vals = load_workbook(outfile, data_only=True)
wsm_v = wb_vals["mechanic"]
wsd_v = wb_vals["data"]

print("\nVerification - cached values:")
for coord in ["M3", "N5", "N3", "O3"]:
    print(f"data!{coord} =", wsd_v[coord].value)

print("\nVerification - mechanic daily totals rows 2:6, cols A:E:")
for r in range(2, 7):
    print(r, [wsm_v.cell(r, c).value for c in range(1, 6)])

# Sanity-check specific expected lookup for M3/N5 from Python
lookup_name = str(load_workbook(infile, data_only=False)["data"]["M3"].value).strip().lower()
lookup_date = normalize_excel_date(load_workbook(infile, data_only=False)["data"]["N5"].value)
expected = sum(
    k for (_, d, nm, k) in source_matches
    if d == lookup_date and lookup_name in nm
)
print("\nExpected Python total for data!M3 + data!N5:", expected)
print("Recalculated data!O3 cached value:", wsd_v["O3"].value)

# Final checks for blanks in target matrix
blank_count = 0
for r in range(2, wsm_v.max_row + 1):
    for c in range(2, wsm_v.max_column + 1):
        if wsm_v.cell(r, c).value is None:
            blank_count += 1
print("Blank target cells in mechanic!B2:E32:", blank_count)

output_spreadsheet = outfile
print("\nReady to submit:", output_spreadsheet)
