from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, textwrap

print("INSTRUCTION:\n", instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # find non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[0], nonempty_rows[-1]) if nonempty_rows else None)
    
    # print first 10 rows with coordinates->values
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    for r in first_rows + last_rows:
        if r not in rows_to_show:
            rows_to_show.append(r)
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # print headers assuming row 1 and row 2 candidates
    for header_row in [1, 2, 3]:
        if header_row <= ws.max_row:
            vals = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
            print(f"Header candidate row {header_row}: {vals}")
    
    # print formulas present in first 20 rows
    formulas = []
    for r in range(1, min(ws.max_row, 25) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first 25 rows:", formulas[:50])

for ws in wb.worksheets:
    sheet_info(ws)
