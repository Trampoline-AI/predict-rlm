from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

# Load source workbook
src_path = input_spreadsheet
filename = os.path.basename(src_path)
out_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(src_path)
original_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Determine true last non-empty row for relevant data
def last_nonempty_row(ws, cols=None):
    cols = cols or range(1, ws.max_column + 1)
    last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in cols):
            last = r
    return last

sheet1_last = last_nonempty_row(ws1, cols=range(1, 9))
sheet2_last = last_nonempty_row(ws2, cols=range(1, 5))

print("Sheet1 target range: H2:H{}".format(sheet1_last))
print("Sheet2 data range: A2:D{}".format(sheet2_last))

# Print existing target formulas/values before overwrite
for r in range(2, sheet1_last + 1):
    print(f"Before H{r}:", ws1[f"H{r}"].value)

# Write formula to all relevant rows in Expected outcome
# Logic:
# total incoming for same Order No + Item code
# minus sum of Order Qty on prior rows with same Order No + Item code
# allocate min(remaining stock, current Order Qty), never below 0
for r in range(2, sheet1_last + 1):
    formula = (
        f"=MAX(0,MIN(G{r},"
        f"SUMIFS(Sheet2!$D$2:$D${sheet2_last},Sheet2!$A$2:$A${sheet2_last},A{r},Sheet2!$B$2:$B${sheet2_last},D{r})"
        f"-SUMPRODUCT(($A$2:$A${sheet1_last}=A{r})*($D$2:$D${sheet1_last}=D{r})*(ROW($A$2:$A${sheet1_last})<ROW(A{r}))*($G$2:$G${sheet1_last}))))"
    )
    ws1[f"H{r}"] = formula

# Print formulas written
for r in range(2, sheet1_last + 1):
    print(f"Written H{r}:", ws1[f'H{r}'].value)

# Save
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb_after = load_workbook(out_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", original_sheetnames)
    # rename by position
    for i, expected_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = expected_name
    wb_after.save(out_path)
    wb_after = load_workbook(out_path)

print("Final sheet names:", wb_after.sheetnames)

# Verify using data_only=True
wb_verify = load_workbook(out_path, data_only=True)
ws1v = wb_verify["Sheet1"]

print("\nVerified target cells H2:H{} (data_only):".format(sheet1_last))
verified_vals = {}
for r in range(2, sheet1_last + 1):
    val = ws1v[f"H{r}"].value
    verified_vals[r] = val
    print(f"H{r} =", val)

# Sanity-check expected examples and blanks now filled
print("\nSanity checks:")
for r in range(2, 10):
    print(f"Example row {r}: expected pattern value ->", verified_vals[r])

# Keep output path for submission
output_file = out_path
