Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
front = wb["Front"]

# Formula logic:
# - MATCH(B$1, Data!$A:$A, 0) finds the date row in Data column A.
# - Agent rows start 3 rows below the date row (date, header, totals, then agents).
# - Dynamic block height is found by looking for the first blank in col A within 50 rows.
# - MATCH($A2, ...) finds the agent letter within that block.
# - INDEX(...) returns the value from Data column F for that agent/date.
# - IFERROR returns blank for missing dates/agents.
formula_template = (
    '=IFERROR('
    'INDEX('
      'OFFSET(Data!$F$1, MATCH({date_ref}, Data!$A:$A, 0)+2, 0, '
        'MATCH(TRUE, INDEX(OFFSET(Data!$A$1, MATCH({date_ref}, Data!$A:$A, 0)+2, 0, 50, 1)="", 0), 0)-1, 1'
      '), '
      'MATCH('
        '{agent_ref}, '
        'OFFSET(Data!$A$1, MATCH({date_ref}, Data!$A:$A, 0)+2, 0, '
          'MATCH(TRUE, INDEX(OFFSET(Data!$A$1, MATCH({date_ref}, Data!$A:$A, 0)+2, 0, 50, 1)="", 0), 0)-1, 1'
        '), '
        '0'
      ')'
    '), '
    '""'
    ')'
)

# Write formulas to Front!B2:N12
for r in range(2, front.max_row + 1):
    for c in range(2, front.max_column + 1):
        cell = front.cell(r, c)
        date_ref = f"{front.cell(1, c).coordinate}"   # e.g., B1, C1...
        agent_ref = f"$A{r}"                          # e.g., $A2, $A3...
        formula = formula_template.format(date_ref=date_ref, agent_ref=agent_ref)
        cell.value = formula

# Save before recalc
wb.save(outfile)
print("Saved:", outfile)
print("Original sheet names:", original_sheetnames)

# Print a few formulas before recalc for verification
wb_check = load_workbook(outfile, data_only=False)
front_check = wb_check["Front"]
for coord in ["B2", "B3", "C2", "F7", "N12"]:
    print(coord, "formula =", front_check[coord].value)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for ws, original_name in zip(wb_after.worksheets, original_sheetnames):
        ws.title = original_name
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas still present
wb_formula = load_workbook(outfile, data_only=False)
front_formula = wb_formula["Front"]
print("\nFormula verification:")
for coord in ["B2", "B3", "C2", "F7", "N12"]:
    print(coord, "=", front_formula[coord].value)

# Verify evaluated values
wb_values = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_values.sheetnames)
front_values = wb_values["Front"]

print("\nEvaluated Front grid B2:N12:")
for r in range(2, front_values.max_row + 1):
    row_vals = [front_values.cell(r, c).value for c in range(2, front_values.max_column + 1)]
    print(f"Row {r} agent {front_values.cell(r,1).value}: {row_vals}")

# Print key cells explicitly mentioned / representative
print("\nKey evaluated cells:")
for coord in ["B2", "B3", "B4", "B7", "C2", "C7", "N2", "N12"]:
    print(coord, "=", front_values[coord].value)

output_spreadsheet = outfile
