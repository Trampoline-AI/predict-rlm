import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload from original input to avoid leaving non-working formulas in place
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet2"]

# Reconfirm target area and existing example answers
print("Before writing:")
for cell in ["A15", "B15", "C15", "D15", "E15"]:
    print(cell, "->", ws[cell].value)

# Compute totals for columns B:E across rows 3:14:
# count all 1s that belong to consecutive runs of length >= 2
def qualifying_total(values):
    total = 0
    run_len = 0
    for v in values:
        if v == 1:
            run_len += 1
        else:
            if run_len >= 2:
                total += run_len
            run_len = 0
    if run_len >= 2:
        total += run_len
    return total

results = {}
for col in ["B", "C", "D", "E"]:
    vals = [ws[f"{col}{r}"].value for r in range(3, 15)]
    results[col] = qualifying_total(vals)
    print(col, vals, "=>", results[col])

# Preserve existing example answers; only fill blanks
if ws["D15"].value in (None, ""):
    ws["D15"] = results["D"]
if ws["E15"].value in (None, ""):
    ws["E15"] = results["E"]

wb.save(output_path)
print("Saved literal values to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalc changed them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names:
    for i, name in enumerate(orig_sheet_names):
        wb_post.worksheets[i].title = name
    wb_post.save(output_path)
    print("Restored sheet names:", orig_sheet_names)

# Final verification
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["Sheet2"]
print("Verified answer row:")
for cell in ["A15", "B15", "C15", "D15", "E15"]:
    print(cell, "->", wsv[cell].value)

print("Target checks:")
print("D15 nonblank?", wsv["D15"].value is not None)
print("E15 nonblank?", wsv["E15"].value is not None)
print("Expected D15=9, got", wsv["D15"].value)
print("Expected E15=4, got", wsv["E15"].value)
