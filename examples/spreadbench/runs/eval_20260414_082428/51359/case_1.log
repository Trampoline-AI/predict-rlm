import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames[:]
ws = wb2["Sheet2"]

# Reconfirm target cells and nearby values
for cell in ["A15", "B15", "C15", "D15", "E15"]:
    print(cell, "current:", ws[cell].value)

# Data rows are 3:14; fill only blank target cells D15 and E15
data_start, data_end = 3, 14

def qualifying_runs_formula(col_letter, start_row, end_row):
    # Counts 1s that are adjacent to another 1 above or below.
    # This equals total size of runs of consecutive 1s with length >= 2.
    rng = f"{col_letter}{start_row}:{col_letter}{end_row}"
    prev_rng = f"{col_letter}{start_row-1}:{col_letter}{end_row-1}"
    next_rng = f"{col_letter}{start_row+1}:{col_letter}{end_row+1}"
    return f'=SUMPRODUCT(({rng}=1)*((({prev_rng}=1)+({next_rng}=1))>0))'

targets = {"D15": "D", "E15": "E"}
for target_cell, col_letter in targets.items():
    current = ws[target_cell].value
    formula = qualifying_runs_formula(col_letter, data_start, data_end)
    if current in (None, ""):
        ws[target_cell] = formula
        print(f"Wrote {target_cell} formula:", formula)
    else:
        print(f"Skipped {target_cell}; existing value:", current)

wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position
    for i, expected_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = expected_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with formulas visible
