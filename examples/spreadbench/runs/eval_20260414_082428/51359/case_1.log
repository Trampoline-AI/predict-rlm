import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect non-empty rows/cols more accurately
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value is not None:
                row_has = True
                nonempty_cols.add(cell.column)
        if row_has:
            nonempty_rows.append(row[0].row)
    if nonempty_rows:
        print("non-empty row span:", min(nonempty_rows), "to", max(nonempty_rows))
    else:
        print("sheet appears empty")
        return
    
    max_nonempty_col = max(nonempty_cols) if nonempty_cols else 0
    headers = [ws.cell(1, c).value for c in range(1, max_nonempty_col + 1)]
    print("Row 1 headers/values:", headers)
    
    # print sample rows: first 10 and last 5 non-empty
    rows_to_show = []
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    for r in first_rows + last_rows:
        if r not in rows_to_show:
            rows_to_show.append(r)
    print("Sample rows:")
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, max_nonempty_col + 1)]
        print(f"Row {r}:", vals)
    
    # print formulas found in used range
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, max_nonempty_col + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formula count:", len(formulas))
    for item in formulas[:20]:
        r, c, f = item
        print(f"Formula {get_column_letter(c)}{r}: {f}")

for ws in wb.worksheets:
    sheet_info(ws)
