print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = []
    if ws.max_row >= 1:
        for c in range(1, ws.max_column + 1):
            headers.append(ws.cell(1, c).value)
    print("Row1 headers/values:", headers)

    # Print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

    # Print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Specifically inspect columns around H and target Q:V
for ws in wb.worksheets:
