```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Find actual non-empty rows in column H
h_nonempty = [(r, ws[f"H{r}"].value) for r in range(1, ws.max_row + 1) if ws[f"H{r}"].value not in (None, "")]
print("Column H non-empty rows:", h_nonempty)
last_h_row = max(r for r, v in h_nonempty)
print("last_h_row:", last_h_row)

# Inspect fills/colors for H1:Hlast and Q1:V2
def fill_info(cell):
    f = cell.fill
    return {
        "value": cell.value,
        "fill_type": f.fill_type,
        "start_color": f.start_color.rgb,
        "end_color": f.end_color.rgb,
    }

print("\nH1:H{} fill/value info:".format(last_h_row))
for r in range(1, last_h_row + 1):
    if r <= 10 or r >= last_h_row - 4:
        print(f"H{r}", fill_info(ws[f"H{r}"]))

print("\nQ1:V2 fill/value/formula info:")
for r in [1, 2]:
    for c in range(17, 23):
        cell = ws.cell(r, c)
        print(cell.coordinate, {"value": cell.value, "data_type": cell.data_type, "fill": fill_info(cell)})

# Compute expected unique sorted values from H
h_values = [v for r, v in h_nonempty if r >= 2 and isinstance(v, (int, float))]
unique_sorted = sorted(set(h_values))
print("\nComputed unique sorted numeric values from H2:H{}:".format(last_h_row), unique_sorted)

# Write formulas into Q2:V2
orig_sheetnames = wb.sheetnames[:]
source_range = f"$H$2:$H${last_h_row}"
targets = ["Q2", "R2", "S2", "T2", "U2", "V2"]

# Print existing target cells before modification
print("\nExisting target cells before write:")
for t in targets:
    print(t, ws[t].value)

# Formulas: first uses MIN, subsequent use next greater unique via MINIFS
ws["Q2"] = f'=IFERROR(MIN({source_range}),"")'
prev = "Q2"
for t in targets[1:]:
    ws[t] = f'=IFERROR(_xlfn.MINIFS({source_range},{source_range},">"&{prev}),"")'
    prev = t

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = s
    wb2.save(out_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("\nWritten formulas:")
for t in targets:
    print(t, "formula/value:", wsf[t].value)

wb_data = load_workbook(out_path, data_only=True)
wsd = wb_data[orig_sheetnames[0]]
print("\nCached values after recalc in Q2:V2:")
verified = [wsd[t].value for t in targets]
for t in targets:
    print(t, wsd[t].value)

print("Expected first values from Python:", unique_sorted)
print("Verified nonblank target values:", [v for v in verified if v not in (None, "")])

output_spreadsheet = out_path
