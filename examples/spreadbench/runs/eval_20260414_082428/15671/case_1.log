from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook normally
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Target sheet:", ws.title)
print("Target output column B index:", column_index_from_string("B"))
print("Pre-write check B1:B5 and last 5:")
for r in list(range(1, min(5, ws.max_row)+1)) + list(range(max(1, ws.max_row-4), ws.max_row+1)):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

# Apply formula to column B for every non-empty row in column A
written_rows = []
for r in range(1, ws.max_row + 1):
    a_val = ws[f"A{r}"].value
    if a_val is not None and a_val != "":
        ws[f"B{r}"] = f'=A{r}&""'
        ws[f"B{r}"].number_format = "@"
        written_rows.append(r)

print("Rows written to column B:", len(written_rows), "first/last:", written_rows[:3], written_rows[-3:])

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    for i, old_name in enumerate(original_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas exist in target cells
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]
print("Formula verification B1:B5 and last 5:")
for r in list(range(1, min(5, ws_formula.max_row)+1)) + list(range(max(1, ws_formula.max_row-4), ws_formula.max_row+1)):
    print(r, "A=", ws_formula[f"A{r}"].value, "B_formula=", ws_formula[f"B{r}"].value)

# Verify calculated/cached values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]
print("Cached value verification B1:B5 and last 5:")
for r in list(range(1, min(5, ws_values.max_row)+1)) + list(range(max(1, ws_values.max_row-4), ws_values.max_row+1)):
    b_val = ws_values[f"B{r}"].value
    print(r, "A=", ws_values[f"A{r}"].value, "B=", b_val, "type=", type(b_val).__name__)

# Additional blank check on target column
blank_targets = []
for r in written_rows:
    if ws_values[f"B{r}"].value in (None, ""):
        blank_targets.append(r)
print("Blank target cells after recalc:", blank_targets[:20], "count=", len(blank_targets))

final_output_path = output_path
