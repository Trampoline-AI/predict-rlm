from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheet names:", orig_sheet_names)

def sample_rows(ws, start_row, end_row, max_cols=6):
    rows = []
    for r in range(start_row, min(end_row, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(max_cols, ws.max_column) + 1)]
        rows.append((r, vals))
    return rows

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    print("First 10 rows (up to first 6 cols):")
    for r, vals in sample_rows(ws, 1, min(10, ws.max_row), max_cols=min(6, ws.max_column)):
        print(r, vals)
    print("Last 5 rows (up to first 6 cols):")
    for r, vals in sample_rows(ws, max(1, ws.max_row - 4), ws.max_row, max_cols=min(6, ws.max_column)):
        print(r, vals)

    # Specific inspection for columns A and B
    print("Column A/B detailed samples:")
    for r in list(range(1, min(10, ws.max_row)+1)) + list(range(max(1, ws.max_row-4), ws.max_row+1)):
        a = ws[f"A{r}"]
        b = ws[f"B{r}"] if ws.max_column >= 2 else None
        print({
            "row": r,
