import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula

path = input_spreadsheet
wb = load_workbook(path)
ws1 = wb["book1"]
ws2 = wb["book2"]

# Find true used rows in book2 based on any non-empty cell
nonempty_rows = []
for r in range(1, ws2.max_row + 1):
    vals = [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)]
    if any(v is not None for v in vals):
        nonempty_rows.append(r)

true_last_row = max(nonempty_rows) if nonempty_rows else ws2.max_row
print("book2 true used last row:", true_last_row)

# Print target area in book1 and exact existing formulas / array formulas
print("\nbook1 target area A2:B23:")
for r in range(2, min(ws1.max_row, 23) + 1):
    a = ws1[f"A{r}"].value
    b = ws1[f"B{r}"].value
    if isinstance(b, ArrayFormula):
        b_display = f"ArrayFormula text={b.text!r}, ref={b.ref!r}"
    else:
        b_display = repr(b)
    print(r, a, b_display)

# Print book2 relevant columns A, H, I, J first 10 and last 10 used rows
print("\nbook2 relevant sample rows (A,H,I,J) first 10 used rows:")
for r in nonempty_rows[:10]:
    print(r, ws2[f"A{r}"].value, ws2[f"H{r}"].value, ws2[f"I{r}"].value, ws2[f"J{r}"].value)

print("\nbook2 relevant sample rows (A,H,I,J) last 10 used rows:")
for r in nonempty_rows[-10:]:
    print(r, ws2[f"A{r}"].value, ws2[f"H{r}"].value, ws2[f"I{r}"].value, ws2[f"J{r}"].value)

# Determine exact target rows in book1: rows with Place values starting row 3 and column B as output
target_rows = []
for r in range(3, ws1.max_row + 1):
    if ws1[f"A{r}"].value not in (None, ""):
        target_rows.append(r)
print("\nTarget rows in book1:", target_rows)

# Replace existing broken array formulas with regular SUMPRODUCT formulas bounded to used range
for r in target_rows:
    formula = f'=SUMPRODUCT((book2!$A$2:$A${true_last_row}=A{r})*(book2!$H$2:$H${true_last_row}+book2!$I$2:$I${true_last_row}+book2!$J$2:$J${true_last_row}))'
    ws1[f"B{r}"] = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore sheet names if recalc changed them
orig_names = wb.sheetnames[:]
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names and len(wb_check.sheetnames) == len(orig_names):
    for i, nm in enumerate(orig_names):
        wb_check.worksheets[i].title = nm
    wb_check.save(out_path)
    print("Restored original sheet names:", orig_names)

# Verify formulas and calculated values
wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)
vws1f = wb_formula["book1"]
vws1v = wb_values["book1"]

print("\nVerification of book1!B3:B23:")
for r in target_rows:
    print(
        r,
        "A=", vws1v[f"A{r}"].value,
        "FORMULA=", vws1f[f"B{r}"].value,
        "VALUE=", vws1v[f"B{r}"].value
    )

output_spreadsheet = out_path
```
