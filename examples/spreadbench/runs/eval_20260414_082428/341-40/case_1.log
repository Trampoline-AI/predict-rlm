import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
print("Input path:", input_path)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def nonempty_row_count(ws):
    max_r = ws.max_row
    max_c = ws.max_column
    last = 0
    for r in range(1, max_r + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_c + 1)]
        if any(v is not None and v != "" for v in vals):
            last = r
    return last

sheet_info = {}
for s in wb.sheetnames:
    ws = wb[s]
    last_row = nonempty_row_count(ws)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    sheet_info[s] = {"max_row": ws.max_row, "last_nonempty_row": last_row, "max_col": ws.max_column, "headers": headers}
    print(f"\nSheet: {s}")
    print(f"  max_row={ws.max_row}, last_nonempty_row={last_row}, max_col={ws.max_column}")
    print("  Headers row 1:", headers)

    # print sample rows first 10 and last 5, bounded to first 17 cols (A:Q) or all if fewer
    sample_cols = min(ws.max_column, 17)
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, sample_cols + 1)]
    first_rows = list(range(1, min(last_row, 10) + 1))
    last_rows = list(range(max(1, last_row - 4), last_row + 1)) if last_row else []
    print("  First rows A:Q/all:")
    for r in first_rows:
        print(f"    Row {r}: {row_vals(r)}")
    print("  Last rows A:Q/all:")
    for r in last_rows:
        print(f"    Row {r}: {row_vals(r)}")

    # inspect column Q specifically
    q_idx = 17
    if ws.max_column >= q_idx:
        q_header = ws.cell(1, q_idx).value
        print(f"  Column Q header/value at Q1: {q_header!r}")
        for r in range(2, min(last_row, 8) + 1):
            print(f"    Q{r}={ws.cell(r, q_idx).value!r}")
    else:
        print("  Sheet has fewer than 17 columns; column Q not present yet.")

# Find candidate matches across sheets
matches = {}
for s in wb.sheetnames:
    ws = wb[s]
    last_row = sheet_info[s]["last_nonempty_row"]
    cur = []
    for r in range(2, last_row + 1):
        a = ws.cell(r, 1).value
        b = ws.cell(r, 2).value
        c = ws.cell(r, 3).value
        if a == "Government" and b == "Germany" and c == "Carretera":
            cur.append((r, ws.cell(r, 17).value if ws.max_column >= 17 else None))
    matches[s] = cur
    print(f"\nMatches in sheet {s}: {len(cur)}")
    print("  Sample matches (row, current Q):", cur[:10])

# Keep workbook objects/state
inspection = {"sheet_info": sheet_info, "matches": matches, "orig_sheet_names": orig_sheet_names}
