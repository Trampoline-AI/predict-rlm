import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for writing
wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames
ws = wb2["Sheet1"]

# Determine last non-empty row robustly
last_row = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
        last_row = r

print("Target sheet:", ws.title)
print("Header row A:Q:", [ws.cell(1, c).value for c in range(1, 18)])
print("Q header:", ws["Q1"].value)

modified_rows = []
already_correct = []
unexpected_existing = []

for r in range(2, last_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    q = ws.cell(r, 17).value
    if a == "Government" and b == "Germany" and c == "Carretera":
        if q == "Volkswagen":
            already_correct.append(r)
        elif q in (None, ""):
            ws.cell(r, 17).value = "Volkswagen"
            modified_rows.append(r)
        else:
            unexpected_existing.append((r, q))
            # preserve unexpected nonblank values unless task explicitly says replace

print("Rows already correct:", already_correct)
print("Rows modified:", modified_rows)
print("Unexpected existing nonblank target values preserved:", unexpected_existing)

# Save
wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
