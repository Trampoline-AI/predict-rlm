print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position to original names
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = orig_name
    wb_check.save(output_path)
    print("Restored sheet names to:", wb_check.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

verification = []
for r in range(2, last_row + 1):
    if wsv.cell(r, 1).value == "Government" and wsv.cell(r, 2).value == "Germany" and wsv.cell(r, 3).value == "Carretera":
        verification.append((r, wsv.cell(r, 17).value))

print("All matching rows and Q values after save:")
