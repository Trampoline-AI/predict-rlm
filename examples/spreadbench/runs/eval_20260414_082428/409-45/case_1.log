```repl
import os, shutil
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Working sheet:", ws.title)
print("I2 current value:", ws["I2"].value)

def is_blank_row(vals):
    return all(v in (None, "") for v in vals)

def get_row(ws, r, max_col):
    return [ws.cell(r, c).value for c in range(1, max_col + 1)]

max_col = ws.max_column
rows = [get_row(ws, r, max_col) for r in range(1, ws.max_row + 1)]

# Detect repeated section headers by matching the first row exactly.
header_template = rows[0]
header_rows = [i + 1 for i, row in enumerate(rows) if row == header_template]
print("Detected header rows:", header_rows)
print("Header template:", header_template)

# Build section metadata: each section starts at a header row and ends before next header or last nonempty row.
last_nonempty = 0
for i in range(len(rows) - 1, -1, -1):
    if not is_blank_row(rows[i]):
        last_nonempty = i + 1
        break
print("Last nonempty row:", last_nonempty)

sections = []
for idx, start in enumerate(header_rows):
    end = (header_rows[idx + 1] - 1) if idx + 1 < len(header_rows) else last_nonempty
    sec_rows = rows[start - 1:end]
    # infer section id from first nonblank data row after header, column B
    sec_id = None
    for rr in sec_rows[1:]:
        if not is_blank_row(rr):
            sec_id = rr[1]
            break
    sections.append({
        "start": start,
        "end": end,
        "id": sec_id,
        "rows": sec_rows
    })

print("Sections detected:")
for s in sections:
    print(f" start={s['start']} end={s['end']} id={s['id']} rowcount={len(s['rows'])}")

target_id = ws["I2"].value
target_id_norm = str(target_id).strip() if target_id not in (None, "") else ""

def compact_section(sec_rows):
    """Keep header + nonblank rows only."""
    header = sec_rows[0]
    kept = [header]
    for r in sec_rows[1:]:
        if not is_blank_row(r):
            kept.append(r)
    return kept

# Rebuild first-sheet rows according to instruction
new_rows = []
if target_id_norm == "":
    # All sections compacted, with exactly one blank row between sections and none after last.
    for i, sec in enumerate(sections):
        new_rows.extend(compact_section(sec["rows"]))
        if i < len(sections) - 1:
            new_rows.append([None] * max_col)
    mode = "all sections compacted"
else:
    # Only compact matching id sections; preserve nonmatching sections as-is (within used area).
    for i, sec in enumerate(sections):
        sec_matches = str(sec["id"]).strip() == target_id_norm
        if sec_matches:
            new_rows.extend(compact_section(sec["rows"]))
        else:
            # preserve original rows in this section exactly as in used area
            new_rows.extend(sec["rows"])
    mode = f"only matching sections compacted for id={target_id_norm}"

print("Mode:", mode)
print("New used row count:", len(new_rows))
print("Preview new rows:")
for i, r in enumerate(new_rows[:12], start=1):
    print(i, r)

# Write back to first sheet. Clear existing used area first.
for r in range(1, ws.max_row + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = None

for r_idx, row in enumerate(new_rows, start=1):
    for c_idx, val in enumerate(row, start=1):
        ws.cell(r_idx, c_idx).value = val

wb.save(outfile)
print("Saved initial output to:", outfile)

# Recalculate and handle possible sheet rename issues
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for old, new in zip(orig_sheetnames, wb2.sheetnames):
        if old != new:
            wb2[new].title = old
    wb2.save(outfile)
    print("Renamed sheets back to original:", orig_sheetnames)

# Verify output
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
vws = wbv[orig_sheetnames[0]]

# Determine verified used range
v_last_nonempty = 0
for r in range(vws.max_row, 0, -1):
    vals = [vws.cell(r, c).value for c in range(1, max_col + 1)]
    if any(v not in (None, "") for v in vals):
        v_last_nonempty = r
        break

print("Verified DATA!I2:", vws["I2"].value)
print("Verified last nonempty row on first sheet:", v_last_nonempty)
print("Verified first sheet rows 1 to", min(v_last_nonempty, 15))
for r in range(1, min(v_last_nonempty, 15) + 1):
    print(r, [vws.cell(r, c).value for c in range(1, 10)])

output_spreadsheet = outfile
```
