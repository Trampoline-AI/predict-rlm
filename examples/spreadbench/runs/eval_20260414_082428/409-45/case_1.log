import os, json, textwrap, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_info = []
for ws in wb.worksheets:
    headers = row_values(ws, 1, min(ws.max_column, 20))
    sheet_info.append((ws.title, ws.max_row, ws.max_column, headers))
    print(f"\nSHEET: {ws.title}")
    print(" max_row/max_column:", ws.max_row, ws.max_column)
    print(" row1 headers/sample:", headers)
    
    # find likely last nonempty row by scanning upward
    last_nonempty = 0
    for r in range(ws.max_row, 0, -1):
        vals = row_values(ws, r, ws.max_column)
        if any(v not in (None, "") for v in vals):
            last_nonempty = r
            break
    print(" last_nonempty_row:", last_nonempty)
    
    # print first 10 rows limited to first 12 cols
    show_cols = min(ws.max_column, 12)
    print(" First rows:")
    for r in range(1, min(last_nonempty, 10) + 1):
        print(r, row_values(ws, r, show_cols))
    print(" Last 5 nonempty-area rows:")
    start = max(1, last_nonempty - 4)
    for r in range(start, last_nonempty + 1):
        print(r, row_values(ws, r, show_cols))

# Inspect first sheet specifically for referenced cells/columns
ws1 = wb[wb.sheetnames[0]]
print("\nFirst sheet title:", ws1.title)
for coord in ["I2", "B1", "B2", "I1", "A1", "A2"]:
    print(coord, "=", ws1[coord].value)

# Print columns A:I for first 25 rows to understand ranges and blanks
print("\nFirst sheet rows 1-25, cols A:I")
for r in range(1, min(ws1.max_row, 25)+1):
    vals = [ws1.cell(r, c).value for c in range(1, 10)]
    print(r, vals)

# Look for formulas in used range (limited sample)
formula_cells = []
for ws in wb.worksheets:
    for r in range(1, min(ws.max_row, 40)+1):
        for c in range(1, min(ws.max_column, 15)+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
