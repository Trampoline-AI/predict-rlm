import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target/output area before writing
print("Pre-write target area A1:E7:")
for r in range(1, 8):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Write formulas into B5:E7
# Source rows: 1,2,3 corresponding to A,B,C
# Target rows: 5,6,7 corresponding to A,B,C
for c in range(2, 6):  # B:E
    col = get_column_letter(c)
    rng = f"{col}$1:{col}$3"
    max_expr = f"MAX({rng})"
    cnt_expr = f'COUNTIF({rng},{max_expr})'
    
    # A row (5) based on source row 1
    ws[f"{col}5"] = f'=IF({col}1={max_expr},IF({cnt_expr}=1,6,IF({cnt_expr}=2,3,2)),0)'
    # B row (6) based on source row 2
    ws[f"{col}6"] = f'=IF({col}2={max_expr},IF({cnt_expr}=1,6,IF({cnt_expr}=2,3,2)),0)'
    # C row (7) based on source row 3
    ws[f"{col}7"] = f'=IF({col}3={max_expr},IF({cnt_expr}=1,6,IF({cnt_expr}=2,3,2)),0)'

print("\nWritten formulas B5:E7:")
for r in range(5, 8):
    print(r, [ws.cell(r, c).value for c in range(2, 6)])

wb.save(output_path)
print("\nSaved to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for i, old_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify with data_only
