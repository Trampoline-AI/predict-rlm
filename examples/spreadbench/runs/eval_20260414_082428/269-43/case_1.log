import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original workbook for modification
wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames[:]
ws = wb2["Sheet1"]

# Identify rows to delete based on actual content
rows_to_delete = []
for r in range(1, ws.max_row + 1):
    h = ws.cell(r, 8).value
    i = ws.cell(r, 9).value
    h_blank = h is None or (isinstance(h, str) and h.strip() == "")
    i_has = i is not None and (not isinstance(i, str) or i.strip() != "")
    if i_has and h_blank:
        rows_to_delete.append(r)

print("Rows to delete:", rows_to_delete)

# Delete bottom-up
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

# Save
wb2.save(output_path)
print("Saved to:", output_path, "exists:", os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and fix any sheet-name changes if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != orig_sheet_names:
    # rename to match original order/names
    for idx, expected_name in enumerate(orig_sheet_names):
        if idx < len(wb_check.worksheets):
            wb_check.worksheets[idx].title = expected_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

print("Final dimensions:", wsv.max_row, "rows x", wsv.max_column, "cols")
print("Final rows:")
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    print(r, vals)

remaining_matches = []
hi_values = []
for r in range(1, wsv.max_row + 1):
    h = wsv.cell(r, 8).value
    i = wsv.cell(r, 9).value
    hi_values.append((r, h, i))
    h_blank = h is None or (isinstance(h, str) and h.strip() == "")
    i_has = i is not None and (not isinstance(i, str) or i.strip() != "")
    if i_has and h_blank:
        remaining_matches.append((r, h, i))

print("Final H/I values:", hi_values)
print("Remaining rows matching delete condition:", remaining_matches)

final_output_path = output_path
