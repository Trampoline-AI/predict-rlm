import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(input_path), input_path)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers row 1:", headers)
    
    # first 10 rows
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(r, vals)
    
    # last 5 rows
    start_last = max(1, max_row-4)
    print(f"Last rows {start_last} to {max_row}:")
    for r in range(start_last, max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(r, vals)
    
    # inspect H and I specifically
    if max_col >= 9:
        print("Column H header:", ws["H1"].value, "| Column I header:", ws["I1"].value)
        sample_hi = []
        for r in range(1, max_row+1):
            h = ws.cell(r, 8).value
            i = ws.cell(r, 9).value
            if h is not None or i is not None:
                sample_hi.append((r, h, i))
        print("Rows with any value in H or I (up to first 20):", sample_hi[:20])
        matches = []
        for r in range(2, max_row+1):
            h = ws.cell(r, 8).value
            i = ws.cell(r, 9).value
            h_blank = h is None or (isinstance(h, str) and h.strip() == "")
            i_has = i is not None and (not isinstance(i, str) or i.strip() != "")
            if i_has and h_blank:
                matches.append((r, h, i))
        print("Rows matching delete condition (I has value, H blank):", matches[:50], "count=", len(matches))
    else:
        print("Sheet has fewer than 9 columns; no H/I to inspect.")

for ws in wb.worksheets:
    sheet_summary(ws)
