import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Re-open workbook for final inspection + modification
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Determine true used rows based on cols A:C
def nonempty(v):
    return v is not None and v != ""

used_rows = [r for r in range(1, ws.max_row + 1) if any(nonempty(ws.cell(r,c).value) for c in range(1, 4))]
first_used, last_used = used_rows[0], used_rows[-1]
header_row = 3
data_start = 4
print("Original sheet names:", orig_sheet_names)
print("Used rows:", first_used, "to", last_used)

# Print target header / target column verification
headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
print("Header row values:", headers)
print("Target column C header:", ws["C3"].value)

# Inspect table details
print("Tables:", list(ws.tables.keys()))
for tname, table in ws.tables.items():
    print("Table", tname, "ref:", table.ref)

# Print current formulas/values in target cells mentioned by examples
for cell_ref in ["C70", "C71", "C72", "C80", "C99"]:
    print(cell_ref, "before:", ws[cell_ref].value)

# Check nearby sample rows before editing
for r in [68,69,70,71,72,79,80,98,99,100,198,199,200]:
    if r <= last_used:
        print(r, [ws.cell(r,c).value for c in range(1,4)])

# Apply rolling 365-day average formula in column C for all populated data rows.
# Use table structured references so new rows in the table auto-extend.
# Formula averages Beans Counted for dates between current row Date-365 and current row Date.
formula = '=IF(OR([@Date]="",[@[Beans Counted]]=""),"",AVERAGEIFS(Table1[Beans Counted],Table1[Date],">="&[@Date]-365,Table1[Date],"<="&[@Date]))'
print("Formula to write:", formula)

written_rows = []
for r in range(data_start, last_used + 1):
    date_val = ws.cell(r, 1).value
    bean_val = ws.cell(r, 2).value
    if date_val is not None and bean_val is not None:
        ws.cell(r, 3).value = formula
        written_rows.append(r)

print("Rows written in column C:", len(written_rows), "from", written_rows[:3], "...", written_rows[-3:])

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for i, s in enumerate(orig_sheet_names):
        wb2[wb2.sheetnames[i]].title = s
    wb2.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify formulas are present in target column
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
for cell_ref in ["C4", "C70", "C71", "C72", "C80", "C99", f"C{last_used}"]:
    print(cell_ref, "formula:", wsf[cell_ref].value)

# Verify cached values after recalc
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values[orig_sheet_names[0]]
verify_cells = ["C4", "C70", "C71", "C72", "C80", "C99", f"C{last_used}"]
for cell_ref in verify_cells:
    print(cell_ref, "value:", wsv[cell_ref].value)

# Also print matching row triplets for sanity
for r in [4,5,6,70,71,72,80,99,198,199,200]:
    if r <= last_used:
        print("Row", r, "=>", [wsv.cell(r,c).value for c in range(1,4)])

final_output_spreadsheet = output_path
