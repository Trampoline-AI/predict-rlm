import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Load workbook twice:
# - formula view for structure/writing
# - data_only view for evaluated source values
wb = load_workbook(input_path)
wb_vals = load_workbook(input_path, data_only=True)

orig_sheet_names = wb.sheetnames[:]
ws_in = wb["Input"]
ws_in_vals = wb_vals["Input"]
ws_out = wb["Output"]

# Reconfirm target/write plan
print("Original sheet names:", orig_sheet_names)
print("Writing filtered values to Output!A10:B starting at row 10")

# Collect rows where Input column E == "yes", skipping empty A/B rows/cells
filtered = []
for r in range(1, ws_in.max_row + 1):
    e = ws_in.cell(r, 5).value
    e_norm = str(e).strip().lower() if e is not None else ""
    a_formula = ws_in.cell(r, 1).value
    b_formula = ws_in.cell(r, 2).value
    a_val = ws_in_vals.cell(r, 1).value
    b_val = ws_in_vals.cell(r, 2).value
    
    if e_norm == "yes":
        # Skip rows where both source cells are empty
        if (a_val in (None, "") and b_val in (None, "")):
            continue
        filtered.append((r, a_val, b_val, a_formula, b_formula))

print("Filtered source rows/count:", len(filtered))
for item in filtered:
    print("Source row:", item[0], "A value:", item[1], "B value:", item[2], "A raw:", item[3], "B raw:", item[4])

target_start = 10
target_end_clear = ws_out.max_row

# Print current target area before modification
print("\nCurrent Output target area before write:")
for r in range(target_start, ws_out.max_row + 1):
    print(r, [ws_out.cell(r, 1).value, ws_out.cell(r, 2).value])

# Write filtered literal values to Output A:B starting at row 10
out_row = target_start
for src_row, a_val, b_val, a_raw, b_raw in filtered:
    ws_out.cell(out_row, 1).value = a_val
    ws_out.cell(out_row, 2).value = b_val
    out_row += 1

# Clear remaining old incorrect entries in the target area
for r in range(out_row, target_end_clear + 1):
    ws_out.cell(r, 1).value = None
    ws_out.cell(r, 2).value = None

# Show written area before save
print("\nOutput target area after write, before save:")
for r in range(target_start, ws_out.max_row + 1):
    vals = [ws_out.cell(r, 1).value, ws_out.cell(r, 2).value]
    if r < out_row or any(v not in (None, "") for v in vals):
        print(r, vals)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc, check/restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # Rename by position back to original names
    for i, expected_name in enumerate(orig_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Final verification using data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
ws_verify = wb_verify["Output"]

print("\nVerified Output target cells:")
for r in range(target_start, target_start + len(filtered)):
    print(f"A{r}={ws_verify.cell(r,1).value!r}, B{r}={ws_verify.cell(r,2).value!r}")

print("\nVerified cleared trailing rows:")
for r in range(target_start + len(filtered), min(ws_verify.max_row, target_start + len(filtered) + 5) + 1):
    print(f"A{r}={ws_verify.cell(r,1).value!r}, B{r}={ws_verify.cell(r,2).value!r}")

# Sanity checks
all_ok = True
for i, (_, a_val, b_val, _, _) in enumerate(filtered, start=target_start):
    va = ws_verify.cell(i, 1).value
    vb = ws_verify.cell(i, 2).value
    if va != a_val or vb != b_val:
        all_ok = False
        print("Mismatch at row", i, "expected", (a_val, b_val), "got", (va, vb))

print("Verification status:", all_ok)

final_output_spreadsheet = output_path
