wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", max_row, "max_col:", max_col)
    print("Headers row 1:", headers)
    
    # print first 10 rows
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, vals)
    
    # print last 5 rows
    start_last = max(1, max_row - 4)
    print(f"Last rows {start_last}-{max_row}:")
    for r in range(start_last, max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Inspect relevant sheets/areas more closely
for sname in ["Input", "Output"]:
    if sname in wb.sheetnames:
        ws = wb[sname]
        print(f"\nDetailed inspection for {sname}:")
        for r in range(1, min(ws.max_row, 15) + 1):
            vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
            print(f"Row {r}: {vals}")
        
        # print current values in A:B and E for all non-empty-ish rows
        print(f"Selected columns A,B,E for {sname}:")
        for r in range(1, ws.max_row + 1):
            a = ws[f"A{r}"].value
            b = ws[f"B{r}"].value
            e = ws[f"E{r}"].value if ws.max_column >= 5 else None
            if any(v not in (None, "") for v in [a, b, e]):
                print(r, {"A": a, "B": b, "E": e})

# Save workbook object in variables for next iteration
inspected_wb = wb
