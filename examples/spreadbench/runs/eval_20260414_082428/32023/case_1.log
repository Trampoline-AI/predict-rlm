import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

# Print current target cells before modification
print("Pre-write B4:B19:")
for r in range(4, ws.max_row + 1):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

# Write formulas to Current Dept. column for employee rows only
for r in range(4, ws.max_row + 1):
    name = ws[f"A{r}"].value
    if name is None or str(name).strip() == "":
        continue
    # Based on today's date in C3, return the latest department reached
    formula = (
        f'=IF($C$3>={f"K{r}"},{f"L{r}"},'
        f'IF($C$3>={f"I{r}"},{f"J{r}"},'
        f'IF($C$3>={f"G{r}"},{f"H{r}"},'
        f'IF($C$3>={f"E{r}"},{f"F{r}"},'
        f'IF($C$3>={f"D{r}"},$D$1,"")))))'
    )
    ws[f"B{r}"] = formula

print("\nWritten formulas B4:B19:")
for r in range(4, ws.max_row + 1):
    print(f"B{r} =", ws[f"B{r}"].value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculation changed them
wb_post = load_workbook(out_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != original_sheet_names and len(post_names) == len(original_sheet_names):
    for i, old_name in enumerate(original_sheet_names):
        wb_post[wb_post.sheetnames[i]].title = old_name
    wb_post.save(out_path)
    print("Restored original sheet names:", original_sheet_names)

# Verify formulas + cached values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]

wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("\nVerification of target cells B4:B19:")
for r in range(4, ws_values.max_row + 1):
    print({
        "row": r,
        "name": ws_values[f"A{r}"].value,
        "formula": ws_formula[f"B{r}"].value,
        "value": ws_values[f"B{r}"].value
    })

print("\nExample rows requested by instruction:")
for r in [14, 17, 19]:
    print({
        "row": r,
        "employee": ws_values[f"A{r}"].value,
        "today_ref": ws_values["C3"].value,
        "B_value": ws_values[f"B{r}"].value,
        "milestones": {
            "D": ws_values[f"D{r}"].value,
            "E/F": (ws_values[f"E{r}"].value, ws_values[f"F{r}"].value),
            "G/H": (ws_values[f"G{r}"].value, ws_values[f"H{r}"].value),
            "I/J": (ws_values[f"I{r}"].value, ws_values[f"J{r}"].value),
            "K/L": (ws_values[f"K{r}"].value, ws_values[f"L{r}"].value),
        }
    })

output_spreadsheet = out_path
