Code:
```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Reconfirm target area before writing
print("Target sheet:", ws.title)
for r in range(1, ws.max_row + 1):
    print(f"Before: A{r}={ws.cell(r,1).value}, B{r}={ws.cell(r,2).value}, C{r}={ws.cell(r,3).value}")

# Write formulas into existing blank column C for all populated rows
# Logic: round to nearest 5, but exact midpoint (remainder 2.5) rounds down.
for r in range(1, ws.max_row + 1):
    b_ref = f"B{r}"
    formula = f'=INT({b_ref}/5)*5+IF(ROUND(MOD({b_ref},5),10)>2.5,5,0)'
    ws.cell(r, 3).value = formula
    ws.cell(r, 3).number_format = '0.00'

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for i, name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

for r in range(1, ws_formula.max_row + 1):
    print(
        f"Verify row {r}:",
        "B formula/value =", ws_formula[f'B{r}'].value,
        "| C formula =", ws_formula[f'C{r}'].value,
        "| C cached =", ws_values[f'C{r}'].value
    )

output_spreadsheet = output_path
```
