import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect exact target area and current values/formulas before modifying
print("Pre-write inspection:")
for r in range(4, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 12)]
    print(f"Row {r} A:K ->", vals)

# Determine rows needing output: rows with source in col A and blank outputs D:K
rows_to_fill = []
for r in range(5, ws.max_row + 1):  # preserve sample row 4
    source = ws.cell(r, 1).value
    if source not in (None, ""):
        rows_to_fill.append(r)

print("Rows to fill:", rows_to_fill)

# Write formulas across D:K
for r in rows_to_fill:
    for c in range(4, 12):  # D:K
        cell = ws.cell(r, c)
        current = cell.value
        print(f"Before {cell.coordinate}:", repr(current))
        formula = f'=IF(COLUMN()-3<=LEN($A{r}),MID($A{r},COLUMN()-3,1),"")'
        cell.value = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and fix sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename sheets back by position
    for i, orig_name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas exist in target cells
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("Formula verification:")
for r in rows_to_fill:
    print(f"Row {r} formulas D:K:", [ws_formula.cell(r, c).value for c in range(4, 12)])

# Verify calculated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]
print("Calculated values verification:")
for r in range(4, ws_values.max_row + 1):
    print(f"Row {r} A:K:", [ws_values.cell(r, c).value for c in range(1, 12)])

output_spreadsheet = outfile
