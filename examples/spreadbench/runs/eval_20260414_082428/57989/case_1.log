    print("\nApplying fallback: writing computed counts directly into B25:H43")
    wb_fix = load_workbook(out_path)
    ws_fix = wb_fix["Sheet1"]
    for rr, dname in summary_drivers:
        for c, day in summary_days:
            ws_fix.cell(rr, c).value = expected[dname][day]
    wb_fix.save(out_path)
    print("Saved fallback values to", out_path)

    # reload verify
    wbd2 = load_workbook(out_path, data_only=True)
    wsd2 = wbd2["Sheet1"]
    post_issues = []
    print("\nPost-fallback first 6 rows:")
    for rr, dname in summary_drivers[:6]:
        vals = [wsd2.cell(rr, c).value for c in range(summary_start_col, summary_end_col + 1)]
        expv = [expected[dname][wsf.cell(summary_header_row, c).value] for c in range(summary_start_col, summary_end_col + 1)]
        print(rr, dname, vals, expv)
    for rr, dname in summary_drivers:
        for c, day in summary_days:
            if wsd2.cell(rr, c).value != expected[dname][day]:
                post_issues.append((rr, c, dname, day, wsd2.cell(rr, c).value, expected[dname][day]))
    print("Post-fallback issue count:", len(post_issues))
    print("First post-fallback issues:", post_issues[:10])

