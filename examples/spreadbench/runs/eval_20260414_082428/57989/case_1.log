                if low in keywords:
                    text_hits.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells found (up to 20):", formula_cells[:20])
    print("Keyword text hits:", text_hits[:50])

    # print merged cells if any
    print("Merged ranges:", list(ws.merged_cells.ranges))
