# Reload clean workbook for inspection/manipulation
input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# 1) Identify source and synthesis areas exactly
print("Sheet:", ws.title, "rows", ws.max_row, "cols", ws.max_column)

# Driver rows in source and synthesis
source_driver_rows = [(r, ws[f"A{r}"].value) for r in range(1, ws.max_row + 1)
                      if isinstance(ws[f"A{r}"].value, str) and ws[f"A{r}"].value.startswith("Driver")]
print("Source/sheet driver labels count:", len(source_driver_rows))
