        if isinstance(v, ArrayFormula):
            pretty.append(f"{get_column_letter(c)}{r}=ArrayFormula(text={getattr(v,'text',None)!r}, ref={getattr(v,'ref',None)!r})")
        else:
            pretty.append(f"{get_column_letter(c)}{r}={v!r}")
    print(" | ".join(pretty))

# 2) Determine summary bounds
