while r <= ws.max_row and isinstance(ws.cell(r, 1).value, str) and ws.cell(r, 1).value.startswith("Driver"):
    summary_drivers.append((r, ws.cell(r, 1).value))
    r += 1
summary_end_row = r - 1

summary_days = [(c, ws.cell(summary_header_row, c).value) for c in range(summary_start_col, summary_end_col + 1)]
