from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

out_path = final_output_path if 'final_output_path' in globals() else os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
print("Checking:", out_path)

# Load formula workbook and data_only workbook
wbf = load_workbook(out_path)
wsf = wbf["Sheet1"]
wbd = load_workbook(out_path, data_only=True)
wsd = wbd["Sheet1"]

summary_header_row = 24
summary_start_row = 25
summary_end_row = 43
summary_start_col = 2
summary_end_col = 8

# Recompute expected values from formula workbook source data
source_header = {c: wsf.cell(1, c).value for c in range(2, 22)}
driver_to_source_row = {
    wsf.cell(r, 1).value: r
    for r in range(3, 22)
    if isinstance(wsf.cell(r, 1).value, str) and wsf.cell(r, 1).value.startswith("Driver")
}
summary_days = [(c, wsf.cell(summary_header_row, c).value) for c in range(summary_start_col, summary_end_col + 1)]
summary_drivers = [(r, wsf.cell(r, 1).value) for r in range(summary_start_row, summary_end_row + 1)]

expected = {}
for rr, dname in summary_drivers:
    src_r = driver_to_source_row.get(dname)
    expected[dname] = {}
    for c, day in summary_days:
        count = 0
        if src_r:
            for sc in range(2, 22):
                if source_header[sc] == day and wsf.cell(src_r, sc).value not in (None, ""):
                    count += 1
        expected[dname][day] = count

print("Sample formulas now:")
for addr in ["B25", "C25", "H25", "B26", "G31"]:
    print(addr, "->", wsf[addr].value)

print("\nWeekday headers:", [wsf.cell(summary_header_row, c).value for c in range(summary_start_col, summary_end_col + 1)])

print("\nFirst 6 summary rows actual vs expected:")
mismatches = []
blank_cells = []
for rr, dname in summary_drivers[:6]:
    actual_vals = [wsd.cell(rr, c).value for c in range(summary_start_col, summary_end_col + 1)]
    expected_vals = [expected[dname][wsf.cell(summary_header_row, c).value] for c in range(summary_start_col, summary_end_col + 1)]
    print(rr, dname, "actual", actual_vals, "expected", expected_vals)

# Full verification
for rr, dname in summary_drivers:
    for c, day in summary_days:
        actual = wsd.cell(rr, c).value
        exp = expected[dname][day]
        if actual in (None, ""):
            blank_cells.append((rr, c, dname, day, actual, exp))
        elif actual != exp:
            mismatches.append((rr, c, dname, day, actual, exp))

print("\nBlank cells count:", len(blank_cells))
print("Mismatch count:", len(mismatches))
print("First blanks:", blank_cells[:10])
print("First mismatches:", mismatches[:10])

# If formulas did not evaluate correctly, write literal values as fallback into SAME target cells
