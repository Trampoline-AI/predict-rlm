```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
data_ws = wb["Data"]
report_ws = wb["Report"]

# Determine actual data extents
data_start_row = 3
data_end_row = data_ws.max_row
report_start_row = 3
report_end_row = report_ws.max_row

# Python sanity-check expected sums from source data
data_rows = []
for r in range(data_start_row, data_end_row + 1):
    data_rows.append({
        "date": data_ws[f"A{r}"].value,
        "supplier": data_ws[f"B{r}"].value,
        "truck": str(data_ws[f"C{r}"].value).strip() if data_ws[f"C{r}"].value is not None else "",
        "qty": data_ws[f"D{r}"].value,
        "row": r,
    })

print("Sanity-check expected sums by Python:")
python_expected = {}
for r in range(report_start_row, report_end_row + 1):
    rep_date = report_ws[f"A{r}"].value
    rep_supplier = report_ws[f"B{r}"].value
    rep_trucks_raw = report_ws[f"C{r}"].value
    rep_trucks = [x.strip() for x in str(rep_trucks_raw).split(",")] if rep_trucks_raw is not None else []
    rep_trucks = [x for x in rep_trucks if x != ""]
    total = 0
    matched = []
    for d in data_rows:
        if d["date"] == rep_date and d["supplier"] == rep_supplier and d["truck"] in rep_trucks:
            total += d["qty"]
            matched.append((d["row"], d["truck"], d["qty"]))
    python_expected[r] = total if matched else None
    print(f"Report row {r}: trucks={rep_trucks} existing D{r}={report_ws[f'D{r}'].value} -> expected={python_expected[r]} matches={matched}")

# Write formulas to exact target cells D3:D10
# Use bounded ranges and delimiter-safe matching against comma-separated list
for r in range(report_start_row, report_end_row + 1):
    formula = (
        f'=SUMPRODUCT((Data!$A${data_start_row}:$A${data_end_row}=A{r})'
        f'*(Data!$B${data_start_row}:$B${data_end_row}=B{r})'
        f'*ISNUMBER(SEARCH(","&Data!$C${data_start_row}:$C${data_end_row}&",",","&SUBSTITUTE(C{r}," ","")&","))'
        f'*(Data!$D${data_start_row}:$D${data_end_row}))'
    )
    print(f"Writing D{r} formula:", formula)
    report_ws[f"D{r}"] = formula

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
original_names = ["Data", "Report"]
if wb_after.sheetnames != original_names and len(wb_after.sheetnames) == len(original_names):
    for i, name in enumerate(original_names):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_names)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)

print("Final sheet names formula view:", wb_formula.sheetnames)
print("Final sheet names values view:", wb_values.sheetnames)

report_formula = wb_formula["Report"]
report_values = wb_values["Report"]

print("\nVerification of target cells Report!D3:D10:")
for r in range(report_start_row, report_end_row + 1):
    print({
        "row": r,
        "A": report_values[f"A{r}"].value,
        "B": report_values[f"B{r}"].value,
        "C": report_values[f"C{r}"].value,
        "formula_in_D": report_formula[f"D{r}"].value,
        "cached_value_D": report_values[f"D{r}"].value,
        "python_expected": python_expected[r],
    })
```
