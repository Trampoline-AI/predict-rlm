import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    max_row, max_col = ws.max_row, ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print("Row1 headers/values:", headers)
    if max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, max_col+1)]
        print("Row2:", row2)
    # first 10 rows
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, max_row-4)
    print(f"Last rows {start_last}:{max_row}:")
    for r in range(start_last, max_row+1):
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Inspect formulas and non-empty cells in each sheet, especially Data / Report
for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\nFormula scan for {sname}:")
    found = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                found.append((cell.coordinate, v))
    print("Formula count:", len(found))
    print("First formulas:", found[:20])

# Specific deeper inspection for likely relevant sheets
for candidate in ["Data", "Report", "DATA", "REPORT"]:
    if candidate in wb.sheetnames:
        ws = wb[candidate]
        print(f"\nDetailed non-empty cells in {candidate} (up to first 50):")
        nonempty = []
        for row in ws.iter_rows():
            for cell in row:
                if cell.value not in (None, ""):
                    nonempty.append((cell.coordinate, cell.value))
        print(nonempty[:50])
        print("Total non-empty cells:", len(nonempty))
