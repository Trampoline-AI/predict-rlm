import os, json, math, statistics, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect likely non-empty rows/cols more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last nonempty rows:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # print first 10 rows and last 5 rows
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in first_rows + last_rows:
        if r not in seen:
            rows_to_show.append(r)
            seen.add(r)
    for r in rows_to_show:
        print(f"Row {r}:", row_values(ws, r))
    
    # headers: first 5 rows to infer header
    print("Potential headers:")
    for r in range(1, min(5, ws.max_row) + 1):
        print(f" header candidate row {r}:", row_values(ws, r))
    
    # find formulas and PK mentions in shown area / entire sheet
    pk_hits = []
    formula_hits = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                if "PK" in v:
                    pk_hits.append((r, c, v))
                if v.startswith("="):
                    formula_hits.append((r, c, v))
    print("PK hits count:", len(pk_hits))
    print("First 10 PK hits:", [(r, get_column_letter(c), v) for r,c,v in pk_hits[:10]])
    print("Formula count:", len(formula_hits))
    print("First 15 formulas:", [(r, get_column_letter(c), v) for r,c,v in formula_hits[:15]])
