import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for modification
wb2 = load_workbook(input_path)
orig_names = wb2.sheetnames[:]
ws = wb2["Sheet1"]

# Extract qualifying values from column B
pk_values = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 2).value
    if isinstance(v, str) and v.startswith("PK"):
        pk_values.append(v)

print("PK values found in column B:", pk_values)
print("Count:", len(pk_values))

# Target starts at E4
start_row = 4
target_col = 5

# Write results into E4 downward, preserving already-correct values where possible
for i, val in enumerate(pk_values, start=start_row):
    cell = ws.cell(i, target_col)
    if cell.value != val:
        print(f"Writing E{i}: {cell.value!r} -> {val!r}")
        cell.value = val

# Clear any stale values below the intended result range in column E
end_row = start_row + len(pk_values) - 1
for r in range(end_row + 1, ws.max_row + 1):
    cell = ws.cell(r, target_col)
    if cell.value not in (None, ""):
        print(f"Clearing E{r} stale value {cell.value!r}")
        cell.value = None

# Save
wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    for idx, name in enumerate(orig_names):
        wb_check.worksheets[idx].title = name
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_names)

# Verification reload with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

print("Verification E3:E15:")
for r in range(3, 16):
    print(f"E{r} =", wsv.cell(r, 5).value)

verified_results = [wsv.cell(r, 5).value for r in range(start_row, end_row + 1)]
print("Verified result list:", verified_results)
print("Matches expected:", verified_results == pk_values)

output_spreadsheet = output_path
