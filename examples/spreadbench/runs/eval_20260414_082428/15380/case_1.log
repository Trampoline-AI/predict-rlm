import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet3"]

# Reconfirm target area before writing
print("Target sheet:", ws.title)
for r in range(2, 16):
    print(r, "A=", ws[f"A{r}"].value, "B=", ws[f"B{r}"].value)

# Fill column B for all populated listing rows, preserving any existing nonblank values
written = []
for r in range(3, ws.max_row + 1):
    aval = ws[f"A{r}"].value
    bval = ws[f"B{r}"].value
    if aval not in (None, ""):
        if bval in (None, ""):
            formula = f'=IFERROR(INDEX(month,MATCH(MID(A{r},6,2),codes2,0)),"")'
            ws[f"B{r}"] = formula
            written.append((f"B{r}", formula))

print("Written formulas:", written)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames:
    for i, old_name in enumerate(original_sheetnames):
        wb2.worksheets[i].title = old_name
    wb2.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet3"]
print("\nFormulas in B3:B15:")
for r in range(3, 16):
    print(r, wsf[f"A{r}"].value, "=>", wsf[f"B{r}"].value)

# Verify cached values after recalculation
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet3"]
print("\nCalculated values in B3:B15:")
for r in range(3, 16):
    print(r, wsv[f"A{r}"].value, "=>", wsv[f"B{r}"].value)

output_spreadsheet = outfile
