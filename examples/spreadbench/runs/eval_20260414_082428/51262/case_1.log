from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from datetime import datetime

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Detailed relevant area inspection:")
for r in range(5, 15):
    vals = [ws.cell(r, c).value for c in range(1, 9)]
    print(f"Row {r} A:H -> {vals}")

print("\nCurrent target cells/formulas:")
for coord in ["F5","G5","H5","F6","G6","H6","F9","F10","F11","F12","F13","F14"]:
    print(coord, "=>", ws[coord].value)

# Compute expected results from source data
criteria = [ws[f"F{r}"].value for r in range(10, 15) if ws[f"F{r}"].value not in (None, "", "Criteria List")]
print("\nCriteria list extracted:", criteria)

data_rows = []
for r in range(6, 14):
    dt = ws.cell(r, 2).value
    crit = ws.cell(r, 3).value
    amt = ws.cell(r, 4).value
    if dt is not None and crit is not None and amt is not None:
        data_rows.append((r, dt, crit, amt))
print("Data rows:", data_rows)

def month_sum(month_cell):
    dt = ws[month_cell].value
    total = 0
    matches = []
    for r, d, crit, amt in data_rows:
        if d.year == dt.year and d.month == dt.month and crit in criteria:
            total += amt
            matches.append((r, d.date(), crit, amt))
    return total, matches

for mc in ["F5","G5","H5"]:
    total, matches = month_sum(mc)
    print(f"Expected for {mc} ({ws[mc].value.date()}):", total, "matches:", matches)

# Write corrected formulas into the exact existing target cells
# Use SUMPRODUCT + COUNTIF so criteria can come from a list/range.
for col in ["F", "G", "H"]:
    formula = (
        f'=SUMPRODUCT(($D$6:$D$13)*'
        f'($B$6:$B$13>=DATE(YEAR({col}$5),MONTH({col}$5),1))*'
        f'($B$6:$B$13<=EOMONTH({col}$5,0))*'
        f'(COUNTIF($F$10:$F$14,$C$6:$C$13)>0))'
    )
    print(f"Writing {col}6:", formula)
    ws[f"{col}6"] = formula

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and ensure sheet names preserved
orig_names = wb.sheetnames
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    for i, old in enumerate(orig_names):
        wb_check.worksheets[i].title = old
    wb_check.save(out_path)
    print("Renamed sheets back to original:", orig_names)

# Verify using data_only
wb_val = load_workbook(out_path, data_only=True)
ws_val = wb_val[orig_names[0]]
print("\nVerified target cells after recalc (data_only=True):")
for coord in ["F6","G6","H6"]:
    print(coord, "=>", ws_val[coord].value)

# Also print formulas from non-data_only reload
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_names[0]]
print("\nStored formulas:")
for coord in ["F6","G6","H6"]:
    print(coord, "=>", ws_formula[coord].value)

output_spreadsheet = out_path
