def sheet_info(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find first non-empty rows maybe top 10
    rows = list(ws.iter_rows(min_row=1, max_row=min(ws.max_row, 15), values_only=True))
    # infer header row among first 5 rows: most non-empty cells
    best_row_idx = None
    best_nonempty = -1
    for i, row in enumerate(rows, start=1):
        nonempty = sum(v not in (None, "") for v in row)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row_idx = i
    print("Likely header row within first 15:", best_row_idx, "nonempty cells:", best_nonempty)
    for i in range(1, min(ws.max_row, 10)+1):
        vals = [ws.cell(i, c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"Row {i}:", vals)
    start_last = max(1, ws.max_row - 4)
    for i in range(start_last, ws.max_row + 1):
        vals = [ws.cell(i, c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"Row {i}:", vals)

    # print headers from likely header row
    headers = [ws.cell(best_row_idx, c).value for c in range(1, ws.max_column + 1)]
    print("Headers from likely header row:")
    print(headers)

    # search formulas / cells containing SUMIFS or DATE or target-ish text
    hits = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and (v.startswith("=") or any(k in v.upper() for k in ["SUMIFS", "DATE(", "GOOGLE", "EXCEL"])):
                hits.append((cell.coordinate, v))
    print("Interesting formula/text hits count:", len(hits))
    for coord, v in hits[:20]:
        print(coord, "=>", v)

for ws in wb.worksheets:
    sheet_info(ws)
