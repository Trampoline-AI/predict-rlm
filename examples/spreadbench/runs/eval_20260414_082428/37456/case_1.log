import os
from datetime import datetime, date, time
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
orig_names = wb.sheetnames[:]
ws = wb[orig_names[0]]

print("Sheet names:", wb.sheetnames)
print("Target area before writing F11:J16:")
for r in range(11, 17):
    print(f"R{r}:", [ws.cell(r, c).value for c in range(6, 11)])

def as_date(v):
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    return None

def combine_dt(dv, tv):
    d = as_date(dv)
    return datetime.combine(d, tv) if d is not None and tv is not None else None

# Build transaction list for sanity check
transactions = []
for r in range(4, ws.max_row + 1):
    dv = ws.cell(r, 1).value
    tv = ws.cell(r, 2).value
    prod = ws.cell(r, 3).value
    sales = ws.cell(r, 4).value
    dt = combine_dt(dv, tv)
    if dt is not None and prod is not None and sales is not None:
        transactions.append((dt, prod, sales))

print("Transactions loaded:", len(transactions))
print("Sample transactions first 5:", transactions[:5])
print("Sample transactions last 5:", transactions[-5:])

products = [ws.cell(11, c).value for c in range(7, 11)]
start_time = ws["F1"].value
end_time = ws["F2"].value
date_rows = list(range(12, 17))

# Python sanity-check expected values
expected = {}
for r in date_rows:
    cur_date = ws.cell(r, 6).value
    next_date = ws.cell(r + 1, 6).value if r + 1 <= 16 else None
    if cur_date is None or next_date is None:
        continue
    start_dt = combine_dt(cur_date, start_time)
    end_dt = combine_dt(next_date, end_time)
    for p in products:
        total = sum(s for dt, prod, s in transactions if prod == p and start_dt <= dt <= end_dt)
        expected[(r, p)] = total

print("\nExpected values by Python:")
for r in date_rows:
    row = [ws.cell(r, 6).value]
    for p in products:
        row.append(expected.get((r, p)))
    print(row)

# Write exact cumulative-subtraction formulas into G12:J15; leave row 16 blank
for r in date_rows:
    cur_date = ws.cell(r, 6).value
    next_date = ws.cell(r + 1, 6).value if r + 1 <= 16 else None
    for c in range(7, 11):
        cell = ws.cell(r, c)
        if cur_date is not None and next_date is not None:
            col_letter = get_column_letter(c)
            # Dynamic product header from row 11 and next row's date as the upper boundary
            formula = (
                f'=SUMPRODUCT((($A$4:$A$32+$B$4:$B$32)>=$F{r}+$F$1)'
                f'*($C$4:$C$32={col_letter}$11)*$D$4:$D$32)'
                f'-SUMPRODUCT((($A$4:$A$32+$B$4:$B$32)>$F{r+1}+$F$2)'
                f'*($C$4:$C$32={col_letter}$11)*$D$4:$D$32)'
            )
            cell.value = formula
        else:
            cell.value = None

print("\nFormulas written G12:J16:")
for r in date_rows:
    print(f"R{r}:", [ws.cell(r, c).value for c in range(7, 11)])

# Save
filename = os.path.basename(input_spreadsheet)
outpath = os.path.join("/sandbox/output/output_spreadsheet", filename)
wb.save(outpath)
print("Saved:", outpath)

# Recalculate
recalc_result = await recalculate(outpath)
print("Recalculate result:", recalc_result)

# Reload normal workbook to check names/formulas
wb_after = load_workbook(outpath)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_names and len(wb_after.sheetnames) == len(orig_names):
    for i, nm in enumerate(orig_names):
        wb_after.worksheets[i].title = nm
    wb_after.save(outpath)
    print("Restored sheet names to:", orig_names)
    wb_after = load_workbook(outpath)

ws_after = wb_after[orig_names[0]]
print("\nVerify formulas in G12:J16:")
for r in date_rows:
    print(f"R{r}:", [ws_after.cell(r, c).value for c in range(7, 11)])

# Reload data_only to verify cached results
wbv = load_workbook(outpath, data_only=True)
wsv = wbv[orig_names[0]]
print("\nVerified target area F11:J16 (data_only):")
for r in range(11, 17):
    print(f"R{r}:", [wsv.cell(r, c).value for c in range(6, 11)])

# Basic blank/error sanity checks
target_values = {(r, c): wsv.cell(r, c).value for r in range(12, 17) for c in range(7, 11)}
print("\nNonblank target counts:", sum(v is not None for v in target_values.values()), "of", len(target_values))
print("Last row should be blank:", [wsv.cell(16, c).value for c in range(7, 11)])

output_spreadsheet = outpath
