            runs.append({
                "text": t.text if t is not None and t.text is not None else "",
                "bold": bold,
                "color": color,
            })
        full_text = "".join(r["text"] for r in runs)
        shared_items.append({"text": full_text, "runs": runs})
print("Shared strings count:", len(shared_items))

# Parse sheet cells in BD rows 1:40
