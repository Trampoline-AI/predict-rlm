print("Found BD XML cells rows:", sorted(bd_cells_xml.keys())[:15], "...", sorted(bd_cells_xml.keys())[-10:])

def extract_cell_xml_info(c):
    info = {"type": c.attrib.get("t"), "style": c.attrib.get("s"), "value": None, "runs": None}
    t = c.attrib.get("t")
