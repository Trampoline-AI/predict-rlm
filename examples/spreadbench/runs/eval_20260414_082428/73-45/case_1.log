                "color": None,
            })
        for r in si.findall("a:r", ns):
            t = r.find("a:t", ns)
            rpr = r.find("a:rPr", ns)
            bold = False
            color = None
            if rpr is not None:
                if rpr.find("a:b", ns) is not None:
