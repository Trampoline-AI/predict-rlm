Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing target cells:")
for r in range(11, 14):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

# Write formulas to the exact target cells in column B for all listed departments.
# Use SUMPRODUCT/COUNTIFS-compatible logic and blank if no matches.
for r in range(11, 14):
    formula = (
        f'=IF(COUNTIFS($A$2:$A$7,A{r},$B$2:$B$7,"In Progress",$C$2:$C$7,">=6")'
        f'+COUNTIFS($A$2:$A$7,A{r},$B$2:$B$7,"In Review",$C$2:$C$7,">=6")=0,"",'
        f'(SUMIFS($C$2:$C$7,$A$2:$A$7,A{r},$B$2:$B$7,"In Progress",$C$2:$C$7,">=6")'
        f'+SUMIFS($C$2:$C$7,$A$2:$A$7,A{r},$B$2:$B$7,"In Review",$C$2:$C$7,">=6"))/'
        f'(COUNTIFS($A$2:$A$7,A{r},$B$2:$B$7,"In Progress",$C$2:$C$7,">=6")'
        f'+COUNTIFS($A$2:$A$7,A{r},$B$2:$B$7,"In Review",$C$2:$C$7,">=6")))'
    )
    ws[f"B{r}"] = formula
    ws[f"B{r}"].number_format = "General"

print("\nWritten formulas:")
for r in range(11, 14):
    print(f"B{r}:", ws[f"B{r}"].value)

wb.save(outfile)
print("\nSaved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation, restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # Rename sheets back by position
    for i, orig_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]

print("\nVerified target cells (data_only):")
for r in range(11, 14):
    print(f"A{r}={wsv[f'A{r}'].value!r}, B{r}={wsv[f'B{r}'].value!r}")

# Extra sanity checks
assert "Sheet1" in wb_verify.sheetnames
assert wsv["B11"].value == 15
assert wsv["B12"].value in (None, "")
assert wsv["B13"].value == 12

output_spreadsheet = outfile
print("\nOutput ready:", output_spreadsheet)
```
