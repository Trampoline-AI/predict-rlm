import os, json, textwrap, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("\nOriginal sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # Find likely used range more accurately
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value not in (None, ""):
                row_has = True
                nonempty_cols.add(cell.column)
        if row_has:
            nonempty_rows.append(row[0].row)
    print("nonempty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("first nonempty row:", min(nonempty_rows), "last nonempty row:", max(nonempty_rows))
    headers = []
    header_row = 1
    # print first few rows raw to detect header location
    for r in range(1, min(ws.max_row, 6) + 1):
        vals = [ws.cell(r,c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"Row {r}:", vals)
    # choose row 1 and row 2 candidates
    for hr in [1,2,3]:
        if hr <= ws.max_row:
            vals = [ws.cell(hr,c).value for c in range(1, ws.max_column+1)]
            nonempty = [v for v in vals if v not in (None,"")]
            print(f"Header candidate row {hr}: {nonempty[:15]}")
    # print first 10 and last 5 rows across used columns
    used_max_col = max(nonempty_cols) if nonempty_cols else ws.max_column
    preview_cols = min(used_max_col, 12)
    print(f"Previewing first rows up to col {preview_cols}:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r,c).value for c in range(1, preview_cols+1)]
        print(f"R{r}: {vals}")
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            vals = [ws.cell(r,c).value for c in range(1, preview_cols+1)]
            print(f"R{r}: {vals}")
    # print formulas / blanks in used area
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print("Formula cells found (up to 20):", formulas[:20])

for ws in wb.worksheets:
    sheet_summary(ws)
