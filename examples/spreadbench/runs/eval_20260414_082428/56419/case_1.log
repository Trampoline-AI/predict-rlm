for r in range(1, 28):
    vals = [ws.cell(r, c).value for c in range(1, 9)]
    data_rows.append((r, vals))

print("Detailed rows 1-27 (A:H):")
for r, vals in data_rows:
    print(r, vals)

# Show current formulas/values in target range H2:H27 and helper cols D/E/G
print("\nCurrent target/helper cells:")
for r in range(2, 28):
    print(
        r,
        {
            "A": ws[f"A{r}"].value,
            "B": ws[f"B{r}"].value,
            "D": ws[f"D{r}"].value,
            "E": ws[f"E{r}"].value,
            "G": ws[f"G{r}"].value,
            "H": ws[f"H{r}"].value,
        }
    )

# Compute expected non-zero Type list from source data for sanity-check
expected = []
for r in range(2, 28):
    qty = ws[f"B{r}"].value
    typ = ws[f"A{r}"].value
    if isinstance(qty, (int, float)) and qty != 0:
        expected.append(typ)
print("\nExpected non-zero Type list:", expected)
print("Expected count:", len(expected))

# Write a single formula directly in H that returns nth non-zero Type with error handling.
# We preserve the rest of the sheet and only change the Unique List formulas.
last_data_row = 27
for r in range(2, last_data_row + 1):
    # nth item = number of rows down from H2
    formula = (
        f'=IFERROR(INDEX($A$2:$A${last_data_row},'
        f'MATCH(ROWS($H$2:H{r}),$E$2:$E${last_data_row},0)),"")'
    )
    ws[f"H{r}"] = formula

# Apply requested background color to target output cells H2:H27
fill = PatternFill(start_color="92D050", end_color="92D050", fill_type="solid")
for r in range(2, last_data_row + 1):
    ws[f"H{r}"].fill = fill

