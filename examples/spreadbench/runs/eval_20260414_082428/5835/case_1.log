```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Build lookup from basic table G:I using (stock, year) -> log value
lookup = {}
for r in range(3, ws.max_row + 1):
    year = ws[f"G{r}"].value
    stock = ws[f"H{r}"].value
    logv = ws[f"I{r}"].value
    if stock is not None and year is not None:
        lookup[(stock, year)] = logv

# Fill target column C for requested table rows 3:max_row.
# Preserve existing nonblank values. For blank/missing matches, use 0 based on existing examples.
changes = []
for r in range(3, ws.max_row + 1):
    stock = ws[f"A{r}"].value
    year = ws[f"B{r}"].value
    cell = ws[f"C{r}"]
    current = cell.value
    
    # only fill rows that actually belong to requested table
    if stock is None or year is None:
        continue
    
    if current is None or current == "":
        src = lookup.get((stock, year), None)
        new_val = 0 if (src is None or src == "") else src
        cell.value = new_val
        changes.append((r, stock, year, current, new_val))

print("Applied changes:")
for ch in changes:
    print(ch)
print("Total changed:", len(changes))

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    for i, expected in enumerate(original_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify using data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]

print("Final target values C3:C19:")
for r in range(3, 20):
    print(f"A{r}={wsv[f'A{r}'].value!r}, B{r}={wsv[f'B{r}'].value!r}, C{r}={wsv[f'C{r}'].value!r}")

output_spreadsheet = outfile
```
