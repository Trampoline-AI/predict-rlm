import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path, os.path.exists(path))

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # print row counts based on non-empty rows too
    nonempty_rows = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            nonempty_rows += 1
    print("nonempty_rows:", nonempty_rows)
    
    # print first 10 rows with coordinates and values
    first_n = min(10, ws.max_row)
    print("\nFirst rows:")
    for r in range(1, first_n + 1):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            vals.append(f"{get_column_letter(c)}{r}={v!r}")
        print(" | ".join(vals))
    
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("\nLast rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            vals.append(f"{get_column_letter(c)}{r}={v!r}")
        print(" | ".join(vals))

for ws in wb.worksheets:
    sheet_summary(ws)

# Also specifically inspect column C and I values for all non-empty rows in each sheet
