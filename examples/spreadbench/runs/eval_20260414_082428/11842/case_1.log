import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

# Reload workbook for targeted inspection
wb = load_workbook(input_spreadsheet)
tws = wb["Total"]
months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']

# 1) Inspect monthly summary headers/formulas around AG:AN
print("=== Monthly summary headers/formulas inspection ===")
for month in ["Jan", "Feb"]:
    ws = wb[month]
    print(f"\n-- {month} rows 4:10, cols AF:AO --")
    for r in range(4, 11):
        vals = []
        for c in range(column_index_from_string("AF"), column_index_from_string("AO") + 1):
            vals.append(f"{get_column_letter(c)}{r}={ws.cell(r,c).value}")
        print(" | ".join(vals))

# 2) Test lookup row for current selected name
selected_name = tws["O3"].value
print("\nSelected name:", selected_name)
for month in months[:3]:
    ws = wb[month]
    matches = [r for r in range(6, ws.max_row + 1) if ws.cell(r, 1).value == selected_name]
    print(month, "matching rows:", matches[:10])

# 3) Inspect existing target cells before writing
print("\n=== Current target range Total!O5:Z12 ===")
for r in range(5, 13):
    print(r, [tws.cell(r, c).value for c in range(column_index_from_string("O"), column_index_from_string("Z")+1)])

# Build formulas:
# Rows 5:12 correspond to monthly-sheet cols AG:AN
code_rows = {
    5: "AG",  # P
    6: "AH",  # ODK
    7: "AI",  # A
    8: "AJ",  # L
    9: "AK",  # WO
    10: "AL", # PH
    11: "AM", # CO
    12: "AN", # ML
}
month_cols_total = {15+i: month for i, month in enumerate(months)}  # O:Z

# Write formulas into exact target range
for total_col, month in month_cols_total.items():
    for total_row, month_col in code_rows.items():
        # Match selected name in monthly col A; use first match row and next row for the second half-day row
        formula = (
            f'=IFERROR(('
            f'INDEX({month}!${month_col}:${month_col},MATCH($O$3,{month}!$A:$A,0))'
            f'+INDEX({month}!${month_col}:${month_col},MATCH($O$3,{month}!$A:$A,0)+1)'
            f')/2,"")'
        )
        tws.cell(total_row, total_col).value = formula

# Save output
infile = os.path.basename(input_spreadsheet)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, infile)
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
