from openpyxl.utils import get_column_letter

ws = wb["Sheet1"]

data_rows = []
for r in range(2, 19):
    units = [ws.cell(r, c).value for c in range(2, 7)]  # B:F
    residual = ws.cell(r, 9).value  # I
    data_rows.append((r, units, residual))

mins = [ws.cell(20, c).value for c in range(2, 7)]
maxs = [ws.cell(21, c).value for c in range(2, 7)]

print("Min constraints B:F:", mins)
print("Max constraints B:F:", maxs)
print("\nAll data rows:")
for r, units, residual in data_rows:
    print(f"Row {r}: units={units}, residual={residual}")

# Check zero cells in unit columns
zero_cells = []
for r, units, residual in data_rows:
    for idx, val in enumerate(units, start=2):
        if val == 0:
            zero_cells.append(f"{get_column_letter(idx)}{r}")
print("\nZero-valued unit cells:", zero_cells if zero_cells else "None")

# Capacity analysis if residual > 0 means add, residual < 0 means subtract
print("\nCapacity analysis per row:")
for r, units, residual in data_rows:
    add_capacity = sum((mx - u) if u != 0 and u is not None else 0 for u, mx in zip(units, maxs))
    sub_capacity = sum((u - mn) if u != 0 and u is not None else 0 for u, mn in zip(units, mins))
    feasible = (residual >= 0 and residual <= add_capacity) or (residual < 0 and abs(residual) <= sub_capacity)
    print(
        f"Row {r}: residual={residual}, add_capacity={add_capacity}, "
        f"sub_capacity={sub_capacity}, feasible={feasible}"
    )

# Simulate exact redistribution rule:
# positive residual: add from unit1->unit5
# negative residual: subtract from unit5->unit1
def redistribute(units, residual, mins, maxs):
    new_units = list(units)
    rem = residual
    if rem > 0:
        for i in range(5):  # unit1 to unit5
            u = new_units[i]
            if u in (None, 0):
                continue
            room = maxs[i] - u
            delta = min(rem, room)
            new_units[i] += delta
            rem -= delta
            if rem == 0:
                break
    elif rem < 0:
        need = -rem
        for i in range(4, -1, -1):  # unit5 to unit1
            u = new_units[i]
            if u in (None, 0):
                continue
            room = u - mins[i]
            delta = min(need, room)
            new_units[i] -= delta
            need -= delta
            if need == 0:
                break
        rem = -need
    return new_units, rem

print("\nSimulated outputs:")
simulated = {}
for r, units, residual in data_rows:
    new_units, rem = redistribute(units, residual, mins, maxs)
    simulated[r] = (new_units, rem)
    print(f"Row {r}: old={units}, residual={residual}, new={new_units}, leftover={rem}")
