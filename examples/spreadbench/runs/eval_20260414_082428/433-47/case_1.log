import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb3 = load_workbook(input_path)
orig_sheet_names = wb3.sheetnames[:]
ws = wb3["Sheet1"]

data_start, data_end = 2, 18
unit_cols = list(range(2, 7))   # B:F
residual_col = 9                # I
min_row = 20
max_row = 21

mins = [ws.cell(min_row, c).value for c in unit_cols]
maxs = [ws.cell(max_row, c).value for c in unit_cols]

def to_num(x):
    if x is None or x == "":
        return None
    if isinstance(x, (int, float)):
        return x
    try:
        f = float(x)
        return int(f) if f.is_integer() else f
    except:
        return None

change_log = []

for r in range(data_start, data_end + 1):
    orig_units = [to_num(ws.cell(r, c).value) for c in unit_cols]
    residual = to_num(ws.cell(r, residual_col).value)
    if residual is None:
        residual = 0

    if all(v is None for v in orig_units) and residual == 0:
        continue

    # Step 1: clamp nonzero values to [min, max]
    new_units = list(orig_units)
    orig_sum = sum(v for v in orig_units if isinstance(v, (int, float)))
    clamped_sum = 0
    for i, v in enumerate(new_units):
        if v is None:
            continue
        if v == 0:
            clamped = 0  # do not change zero cells
        else:
            clamped = v
            if mins[i] is not None and clamped < mins[i]:
                clamped = mins[i]
            if maxs[i] is not None and clamped > maxs[i]:
                clamped = maxs[i]
        new_units[i] = clamped
        clamped_sum += clamped

    # target sum is original sum + residual
    # remaining delta to apply after clamping:
    eff_residual = (orig_sum + residual) - clamped_sum

    # Step 2: redistribute in required order without touching zero cells
    if eff_residual > 0:
        rem = eff_residual
        for i in range(5):  # unit1 -> unit5
            v = new_units[i]
            if v in (None, 0):
                continue
            room = maxs[i] - v
            if room <= 0:
                continue
            delta = min(rem, room)
            new_units[i] = v + delta
            rem -= delta
            if rem == 0:
                break
        leftover = rem
    elif eff_residual < 0:
        need = -eff_residual
        for i in range(4, -1, -1):  # unit5 -> unit1
            v = new_units[i]
            if v in (None, 0):
                continue
            room = v - mins[i]
            if room <= 0:
                continue
            delta = min(need, room)
            new_units[i] = v - delta
            need -= delta
            if need == 0:
                break
        leftover = -need
    else:
        leftover = 0

    # Write results
    for idx, c in enumerate(unit_cols):
        ws.cell(r, c).value = new_units[idx]
    ws.cell(r, residual_col).value = 0

    change_log.append({
        "row": r,
        "orig_units": orig_units,
        "orig_residual": residual,
        "clamped_units": new_units,
        "effective_residual_after_clamp": eff_residual,
        "leftover": leftover,
    })

# Save and recalc
wb3.save(output_path)
print("Saved:", output_path)

recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Restore sheet names if altered
wb_names = load_workbook(output_path)
if wb_names.sheetnames != orig_sheet_names:
    for i, nm in enumerate(orig_sheet_names):
        wb_names.worksheets[i].title = nm
    wb_names.save(output_path)
    print("Restored sheet names:", wb_names.sheetnames)

# Verify
