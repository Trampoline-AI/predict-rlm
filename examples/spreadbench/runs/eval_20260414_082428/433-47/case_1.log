    for i, v in enumerate(vals):
        c = unit_cols[i]
        if v is None:
            issues.append(f"{chr(64+c)}{r}=None")
        elif v != 0 and (v < mins[i] or v > maxs[i]):
            issues.append(f"{chr(64+c)}{r}={v} outside [{mins[i]}, {maxs[i]}]")

print("\nVerification rows:")
for r in [2,3,7,8,14,16,18]:
    print(r, [wsv.cell(r, c).value for c in unit_cols], wsv.cell(r, residual_col).value)

print("\nIssue count:", len(issues))
if issues:
    print("Issues:", issues[:20])
else:
    print("All target rows verified successfully.")

final_output_path = output_path
