```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload from original input to produce a clean final workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Rechecking target cells before final write:")
print("A26 =", ws["A26"].value)
print("B26 currently =", ws["B26"].value)

# Find actual transaction rows: rows where Date (C) and QTY (I) are present
transaction_rows = []
for r in range(2, ws.max_row + 1):
    c_val = ws.cell(r, 3).value   # Date
    i_val = ws.cell(r, 9).value   # QTY
    if c_val is not None and i_val is not None:
        transaction_rows.append(r)

print("Transaction rows detected:", transaction_rows)

# Compute value for B26 from actual data
target_month = str(ws["A26"].value).strip()
qty_sum = 0
matching_rows = []
nonmatching_rows = []
for r in transaction_rows:
    date_val = ws.cell(r, 3).value
    qty_val = ws.cell(r, 9).value
    month_name = date_val.strftime("%B")
    rec = {"row": r, "date": date_val, "month": month_name, "qty": qty_val}
    if month_name == target_month:
        qty_sum += qty_val
        matching_rows.append(rec)
    else:
        nonmatching_rows.append(rec)

print("Target month from A26:", target_month)
print("Matching rows:", matching_rows)
print("Non-matching rows:", nonmatching_rows)
print("Computed qty_sum:", qty_sum)

# Write literal value because formula evaluation failed in verification
ws["B26"] = qty_sum
print("Written literal to B26:", ws["B26"].value)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate anyway
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if changed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed:", wb_after.sheetnames, "restoring to", original_sheetnames)
    for idx, expected_name in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = expected_name
    wb_after.save(output_path)

# Final verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
ws_verify = wb_verify["Sheet1"]
print("Final verification:")
print("A26 =", ws_verify["A26"].value)
print("B26 =", ws_verify["B26"].value)
print("Sheet names =", wb_verify.sheetnames)

final_output_spreadsheet = output_path
```
