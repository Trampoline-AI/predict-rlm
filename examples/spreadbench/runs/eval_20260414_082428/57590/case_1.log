# Here rows 2..3 have actual transaction data and row 4 is blank.
last_data_row = 1
for r in range(2, ws.max_row + 1):
    row_has_data = any(ws.cell(r, c).value is not None for c in range(1, 14))
    if row_has_data and r < 20:  # source data block is clearly before summary area
