```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and confirm target area before writing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheet names:", orig_sheetnames)
print("Pre-write target cells:")
for r in range(17, 23):
    print(r, {"A": ws[f"A{r}"].value, "B": ws[f"B{r}"].value, "C": ws[f"C{r}"].value, "D": ws[f"D{r}"].value})

# Write formulas into D17:D22
for r in range(17, 23):
    formula = (
        f'=SUMPRODUCT(($A$5:$A$10=A{r})*($B$5:$B$10=C{r})*('
        f'(B{r}=$C$4)*$C$5:$C$10+'
        f'(B{r}=$D$4)*$D$5:$D$10+'
        f'(B{r}=$E$4)*$E$5:$E$10))'
    )
    ws[f"D{r}"] = formula

print("\nWritten formulas:")
for r in range(17, 23):
    print(f"D{r} =", ws[f"D{r}"].value)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # Rename by position to original names
    for i, expected in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify formulas still present in normal mode
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("\nVerification - formulas in target cells:")
for r in range(17, 23):
    print(f"D{r} formula:", wsf[f"D{r}"].value)

# Verify cached values in data_only mode
wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals[orig_sheetnames[0]]
print("\nVerification - recalculated values in target cells:")
for r in range(17, 23):
    print(
        f"Row {r}:",
        {
            "Work": wsv[f"A{r}"].value,
            "Category Type": wsv[f"B{r}"].value,
            "Material": wsv[f"C{r}"].value,
            "Category Value": wsv[f"D{r}"].value,
        },
    )

output_spreadsheet = outfile
