from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Report/Data area rows 14-22 with coordinates:")
for r in range(14, 23):
    vals = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        vals.append(f"{get_column_letter(c)}{r}={v!r}")
    print(" | ".join(vals))

print("\nNon-empty cells rows 14-22 only:")
for r in range(14, 23):
    pairs = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None:
            pairs.append(f"{get_column_letter(c)}{r}={v!r}")
    print(f"Row {r}:", " | ".join(pairs) if pairs else "(all blank)")

# Capture data table
headers = [ws.cell(4, c).value for c in range(1, 6)]
data_rows = []
for r in range(5, 11):
    row = [ws.cell(r, c).value for c in range(1, 6)]
    data_rows.append(row)

print("\nData table headers:", headers)
print("Data table rows:")
for row in data_rows:
    print(row)

# Expected lookup values for report rows assuming output goes in col D based on blank column after inputs
print("\nExpected lookup values for report rows 17-22 based on Work + Category header + Material:")
category_to_col = {ws.cell(4, c).value: c for c in range(3, 6)}
print("Category to source column:", category_to_col)

for r in range(17, 23):
    work = ws.cell(r, 1).value
    cat = ws.cell(r, 2).value
    mat = ws.cell(r, 3).value
    target_current = ws.cell(r, 4).value
    matched = None
    src_row = None
    src_col = category_to_col.get(cat)
    if src_col is not None:
        for rr in range(5, 11):
            if ws.cell(rr, 1).value == work and ws.cell(rr, 2).value == mat:
                val = ws.cell(rr, src_col).value
                if val not in (None, "") and val != 0:
                    matched = val
                    src_row = rr
                    break
    print(f"Row {r}: work={work}, cat={cat}, mat={mat}, D{r} current={target_current!r}, matched={matched!r} from row {src_row}")

# Also inspect any blank columns to the right in case output target is elsewhere
print("\nHeaders/labels around report area columns A:G:")
for c in range(1, 8):
    print(c, get_column_letter(c), [ws.cell(r, c).value for r in range(14, 18)])
