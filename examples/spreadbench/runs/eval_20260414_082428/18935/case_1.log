import os, json, textwrap, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook path:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    print("Merged ranges:", list(ws.merged_cells.ranges)[:20])
    
    # Find non-empty rows/cols more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("First/last non-empty rows:", (nonempty_rows[:5], nonempty_rows[-5:] if nonempty_rows else []))
    
    # Print first 10 rows with coordinates for non-empty cells
    print("\nTop rows sample:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}:", vals)
    
    # Print last 5 non-empty rows
    print("\nBottom non-empty rows sample:")
    for r in nonempty_rows[-5:]:
        print(f"Row {r}:", row_values(ws, r, ws.max_column))
    
    # Identify potential header rows among first 10 rows
    print("\nHeader candidates (first 10 rows with non-empty count):")
    for r in range(1, min(10, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v is not None and v != "" for v in vals)
        print(f"Row {r}: non-empty={nonempty} values={vals}")
    
    # Print cells with formulas in used range
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print(f"\nFormula cells count: {len(formulas)}")
    print("First 20 formulas:", formulas[:20])
    
    # Print non-empty cells in first 15 rows with coordinates to inspect layout
    print("\nNon-empty cells in first 15 rows:")
    for r in range(1, min(15, ws.max_row) + 1):
        pairs = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                pairs.append(f"{get_column_letter(c)}{r}={v!r}")
        if pairs:
            print(" | ".join(pairs[:30]))
