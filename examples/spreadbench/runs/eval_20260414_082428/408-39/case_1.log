import os, shutil, copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

# Reload for detailed inspection
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Detailed target inspection for Sheet1")
for r in range(4, 12):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"Row {r}: {vals}")

# Find header row/target column exactly
target = None
for hr in range(1, min(ws.max_row, 10) + 1):
    headers = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
    if "0-15" in headers:
        c = headers.index("0-15") + 1
        target = (hr, c)
        break

print("Target found:", target, "letter:", get_column_letter(target[1]) if target else None)

hr, src_col = target
print("\nCurrent values in source '0-15' column:")
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, src_col)
    print(r, cell.coordinate, "value=", cell.value, "number_format=", cell.number_format)

print("\nCurrent values in destination column B before change:")
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 2)
    print(r, cell.coordinate, "value=", cell.value, "number_format=", cell.number_format)

# Check formulas in used area
print("\nFormulas in Sheet1 used range:")
for r in range(1, ws.max_row + 1):
    row_formulas = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if isinstance(v, str) and v.startswith("="):
            row_formulas.append((get_column_letter(c), v))
    if row_formulas:
        print("Row", r, row_formulas)

# Style/dimension inspection around source and destination
print("\nColumn dimensions:")
for c in [1,2,src_col]:
    letter = get_column_letter(c)
    dim = ws.column_dimensions[letter]
    print(letter, "width=", dim.width, "hidden=", dim.hidden)

print("\nHeader/source style summary:")
for coord in [f"{get_column_letter(src_col)}5", "B5", f"{get_column_letter(src_col)}6", "B6"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "fill=", cell.fill.fill_type, cell.fill.fgColor.rgb, 
          "font_bold=", cell.font.bold, "border_left=", cell.border.left.style, "alignment=", cell.alignment.horizontal)

# Perform move on a copy
infile = input_spreadsheet
outfile = "/sandbox/output/output_spreadsheet/" + os.path.basename(infile)
shutil.copy(infile, outfile)

wb2 = load_workbook(outfile)
ws2 = wb2["Sheet1"]

# refind in copied wb
target2 = None
for hr2 in range(1, min(ws2.max_row, 10) + 1):
    headers = [ws2.cell(hr2, c).value for c in range(1, ws2.max_column + 1)]
    if "0-15" in headers:
        target2 = (hr2, headers.index("0-15") + 1)
        break
print("\nMove target in copy:", target2)

hr2, original_src_col = target2

# Insert new column B
ws2.insert_cols(2, 1)

# After insertion, original source shifts right if it was at/after B
shifted_src_col = original_src_col + 1 if original_src_col >= 2 else original_src_col
print("original_src_col:", original_src_col, "shifted_src_col after insert:", shifted_src_col, get_column_letter(shifted_src_col))

# Copy cell values and styles from shifted source column to new B
for r in range(1, ws2.max_row + 1):
    src = ws2.cell(r, shifted_src_col)
    dst = ws2.cell(r, 2)
    dst.value = src.value
    if src.has_style:
        dst._style = copy.copy(src._style)
    if src.number_format:
        dst.number_format = src.number_format
    if src.font:
        dst.font = copy.copy(src.font)
    if src.fill:
        dst.fill = copy.copy(src.fill)
    if src.border:
        dst.border = copy.copy(src.border)
    if src.alignment:
        dst.alignment = copy.copy(src.alignment)
    if src.protection:
        dst.protection = copy.copy(src.protection)

# Copy column dimension from source to B
src_letter_shifted = get_column_letter(shifted_src_col)
if src_letter_shifted in ws2.column_dimensions:
    ws2.column_dimensions["B"] = copy.copy(ws2.column_dimensions[src_letter_shifted])

# Delete the old source column to complete move
ws2.delete_cols(shifted_src_col, 1)

# Save
wb2.save(outfile)
print("\nSaved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
