import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction full text:")
print(instruction)

path = input_spreadsheet
print("\nInput path:", path, "exists:", os.path.exists(path))

wb = load_workbook(path)
orig_sheet_names = wb.sheetnames
print("\nSheet names:", orig_sheet_names)

def sheet_info(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # collect first few rows values
    rows = list(ws.iter_rows(min_row=1, max_row=min(ws.max_row, 12), values_only=True))
    for i, row in enumerate(rows, start=1):
        print(f"Row {i}:", row)
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    if start_last > 12:
        print("... last rows ...")
        for r in range(start_last, ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}:", vals)
    # header candidates
    for header_row in range(1, min(ws.max_row, 5) + 1):
        headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
        print(f"Possible header row {header_row}:", headers)
        if "0-15" in headers:
            idx = headers.index("0-15") + 1
            print(f"Found '0-15' in row {header_row}, column {idx} ({get_column_letter(idx)})")
            # print surrounding cells
            left = max(1, idx - 3)
            right = min(ws.max_column, idx + 3)
            print("Surrounding headers:", [(get_column_letter(c), ws.cell(header_row, c).value) for c in range(left, right+1)])
            for r in range(header_row, min(ws.max_row, header_row + 5) + 1):
                print(f"Row {r} around target:", [(get_column_letter(c), ws.cell(r, c).value) for c in range(left, right+1)])

for ws in wb.worksheets:
    sheet_info(ws)
