print("Sheet names after recalc:", wb_check.sheetnames)
orig_names = ['Sheet1', 'RawData']
if wb_check.sheetnames != orig_names:
    # rename by position back to originals
    for i, nm in enumerate(orig_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = nm
    wb_check.save(outfile)
    print("Renamed sheets back to:", wb_check.sheetnames)

# Verify with data_only
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]
print("\nVerification rows 5-11 after move:")
for r in range(5, 12):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
