wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def cell_display(v):
    if v is None:
        return None
    s = str(v)
    return s if len(s) <= 80 else s[:77] + "..."

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # merged ranges
    merged = list(ws.merged_cells.ranges)
    print("Merged ranges:", [str(m) for m in merged[:10]], "..." if len(merged) > 10 else "")
    
    # comments / formulas / non-empty count by first few rows
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", [cell_display(v) for v in headers])
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row 2 values:", [cell_display(v) for v in row2])
    
    # find likely header row among first 5 rows (row with most non-empty cells)
    best_row = None
    best_nonempty = -1
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row = r
    print(f"Likely header row in first 5 rows: {best_row}")
    if best_row and best_row != 1:
        vals = [ws.cell(best_row, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {best_row} values:", [cell_display(v) for v in vals])

    # sample first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [cell_display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"R{r}:", vals)

    # sample last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [cell_display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"R{r}:", vals)

    # collect comments
    comments = []
    for row in ws.iter_rows():
        for cell in row:
            if cell.comment is not None:
                comments.append((cell.coordinate, cell.comment.text))
    print("Comments:", comments[:10], "..." if len(comments) > 10 else "")
    
    # collect formulas
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((cell.coordinate, v))
    print("Formula cells sample:", formulas[:20], "..." if len(formulas) > 20 else "")

    # print dimensions with column letters
    col_info = []
    for c in range(1, ws.max_column + 1):
        col_info.append(f"{get_column_letter(c)}:{cell_display(ws.cell(best_row or 1, c).value)}")
    print("Columns:", col_info)
