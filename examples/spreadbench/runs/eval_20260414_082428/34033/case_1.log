```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original workbook for editing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Target area before writing:")
for r in range(4, 11):
    print(r, [ws.cell(r, c).value for c in range(8, 12)])

# Source bounds determined from inspection: data rows with actual records are 3:13, headers C1:E1
# Write formulas in K6:K10
for r in range(6, 11):
    item = ws[f"H{r}"].value
    param = ws[f"I{r}"].value
    recall = ws[f"J{r}"].value
    if item is None and param is None and recall is None:
        continue
    formula = (
        f'=LOOKUP(2,1/(($B$3:$B$13=H{r})*($A$3:$A$13<=J{r})),'
        f'CHOOSE(MATCH(I{r},$C$1:$E$1,0),$C$3:$C$13,$D$3:$D$13,$E$3:$E$13))'
    )
    print(f"K{r} old={ws[f'K{r}'].value!r} -> formula={formula}")
    ws[f"K{r}"] = formula

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for i, name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = name
    wb_after.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify formulas and calculated values
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("\nFormulas in K6:K10:")
for r in range(6, 11):
    print(f"K{r} formula:", wsf[f"K{r}"].value)

wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values[orig_sheet_names[0]]
print("\nCalculated values in H:K rows 6:10:")
verification = {}
for r in range(6, 11):
    row_vals = [wsv.cell(r, c).value for c in range(8, 12)]
    verification[r] = row_vals
    print(f"R{r}:", row_vals)

# Sanity check expected blanks/non-blanks
for r in range(6, 11):
    val = wsv[f"K{r}"].value
    print(f"K{r} final value -> {val!r}")

final_output_path = output_path
