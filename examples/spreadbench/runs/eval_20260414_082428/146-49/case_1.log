Code:
```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Inspect the relevant source/target area again
print("Using sheet:", ws.title)
print("Column A sample first 10 words:", [ws[f"A{i}"].value for i in range(1, 11)])
print("Existing G1:H10 before write:")
for r in range(1, 11):
    print(r, ws[f"G{r}"].value, ws[f"H{r}"].value)

# Collect dictionary words from column A
words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

word_set = set(words)
print("Total words collected from column A:", len(words), "unique:", len(word_set))

# Find unique valid pairs.
# Pattern: same length; for one word, every S is replaced by the same vowel in the other word,
# and all non-S letters match exactly in position. Either orientation is allowed.
vowels = set("AEIOU")
pairs = set()

for w in word_set:
    positions = [i for i, ch in enumerate(w) if ch == "S"]
    if not positions:
        continue
    # Candidate words created by replacing all S in w with one vowel
    for v in vowels:
        cand = "".join(v if ch == "S" else ch for ch in w)
        if cand != w and cand in word_set:
            pairs.add(tuple(sorted((w, cand), key=lambda x: x.upper())))

# Also check reverse orientation explicitly for completeness:
# words with repeated same vowel positions changed to S
for w in word_set:
    # group positions by vowel
    for v in vowels:
        positions = [i for i, ch in enumerate(w) if ch == v]
        if not positions:
            continue
        cand_chars = list(w)
        for i in positions:
            cand_chars[i] = "S"
        cand = "".join(cand_chars)
        # Need all changed positions in cand to be S and all other positions identical automatically
        if cand != w and cand in word_set:
            # Ensure this truly reflects replacing all S in one word by same vowel in the other
            # i.e. all S positions in cand became this vowel in w
            if all(w[i] == v for i, ch in enumerate(cand) if ch == "S"):
                pairs.add(tuple(sorted((cand, w), key=lambda x: x.upper())))

pairs_sorted = sorted(pairs, key=lambda p: (p[0].upper(), p[1].upper()))
print("Number of unique pairs found:", len(pairs_sorted))
print("First 20 pairs:", pairs_sorted[:20])
print("Does example pair exist?", ('KAGOULE', 'KAGOULS') in pairs_sorted or ('KAGOULS', 'KAGOULE') in pairs_sorted)

# Clear existing output area in G:H for prior contents down the used range
clear_to = max(ws.max_row, len(pairs_sorted) + 10)
for r in range(1, clear_to + 1):
    ws.cell(r, 7).value = None
    ws.cell(r, 8).value = None

# Write sorted pairs starting at G1:H1 (since after sorting first pair should appear at row 1 and no headers)
for idx, (a, b) in enumerate(pairs_sorted, start=1):
    ws.cell(idx, 7).value = a
    ws.cell(idx, 8).value = b

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = orig_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify output values after recalc using data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[orig_sheet_names[0]]
print("Verified target cells G1:H15:")
for r in range(1, min(15, len(pairs_sorted)) + 1):
    print(r, wsv.cell(r, 7).value, wsv.cell(r, 8).value)

# Basic sanity checks
all_nonblank = all(
    (wsv.cell(r, 7).value not in (None, "")) and (wsv.cell(r, 8).value not in (None, ""))
    for r in range(1, len(pairs_sorted) + 1)
)
print("All written target rows nonblank?", all_nonblank)
print("Output row count:", len(pairs_sorted))
final_output_spreadsheet = output_path
