Code:
```repl
from openpyxl import load_workbook
import os
from collections import defaultdict

output_path = final_output_spreadsheet
wbv = load_workbook(output_path, data_only=True)
wsv = wbv["Sheet1"]

# Read source words again
wb_src = load_workbook(input_spreadsheet, data_only=True)
ws_src = wb_src["Sheet1"]
words = [ws_src.cell(r, 1).value.strip() for r in range(1, ws_src.max_row + 1)
         if isinstance(ws_src.cell(r, 1).value, str) and ws_src.cell(r, 1).value.strip()]
word_set = set(words)

# Read written output pairs from G:H until first blank pair stretch
written_pairs = []
r = 1
while r <= wsv.max_row:
    g = wsv.cell(r, 7).value
    h = wsv.cell(r, 8).value
    if g in (None, "") and h in (None, ""):
        break
    written_pairs.append((g, h))
    r += 1

print("Written pair count:", len(written_pairs))
print("First 10 written pairs:", written_pairs[:10])
print("Last 10 written pairs:", written_pairs[-10:])

vowels = set("AEIOU")

def valid_pair(a, b):
    # one of the two directions must satisfy the rule
    if not (isinstance(a, str) and isinstance(b, str) and len(a) == len(b) and a != b):
        return False
    def one_direction(s_word, v_word):
        s_positions = [i for i, ch in enumerate(s_word) if ch == "S"]
        if not s_positions:
            return False
        repl = {v_word[i] for i in s_positions}
        if len(repl) != 1:
            return False
        vowel = next(iter(repl))
        if vowel not in vowels:
            return False
        for i, ch in enumerate(s_word):
            if ch != "S" and v_word[i] != ch:
                return False
        return True
    return one_direction(a, b) or one_direction(b, a)

# Validate all written pairs
invalid = [p for p in written_pairs if not valid_pair(*p)]
print("Invalid written pairs:", invalid[:20], "count=", len(invalid))

# Independent recomputation by exact transformation from S-word only
independent = set()
for w in word_set:
    if "S" not in w:
        continue
    for v in vowels:
        cand = "".join(v if ch == "S" else ch for ch in w)
        if cand != w and cand in word_set:
            independent.add(tuple(sorted((w, cand), key=lambda x: x.upper())))

independent_sorted = sorted(independent, key=lambda p: (p[0].upper(), p[1].upper()))
print("Independent count:", len(independent_sorted))
print("Matches written exactly?", independent_sorted == written_pairs)

# Check sorting case-insensitive
is_sorted = all(
    (written_pairs[i][0].upper(), written_pairs[i][1].upper()) <=
    (written_pairs[i+1][0].upper(), written_pairs[i+1][1].upper())
    for i in range(len(written_pairs)-1)
)
print("Case-insensitive sorted?", is_sorted)

# Check some rows after the output are blank
tail_check = []
for rr in range(len(written_pairs)+1, len(written_pairs)+6):
    tail_check.append((rr, wsv.cell(rr,7).value, wsv.cell(rr,8).value))
print("Rows after output:", tail_check)
