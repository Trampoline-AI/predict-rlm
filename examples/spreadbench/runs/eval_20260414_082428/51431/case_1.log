Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and write formula
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before write - B2:", ws["B2"].value)
formula = '=TRIM(LEFT(A2,FIND(";",A2&";")-1))'
ws["B2"] = formula
print("Written formula to B2:", ws["B2"].value)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for i, desired in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = desired
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Verified formula in B2:", ws_formula["B2"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("Verified A2:", ws_values["A2"].value)
print("Verified B2 cached value:", ws_values["B2"].value)

output_spreadsheet = output_path
```
