print("Exists:", os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("\nOriginal sheet names:", orig_sheet_names)

def sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", ws.dimensions)
    print("max_row:", max_row, "max_col:", max_col)
    print("Headers row 1:", headers)
    
    # Print first 10 rows and last 5 rows, bounded
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, row_vals)
    
    if max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, max_row - 4), max_row + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
            print(r, row_vals)
    
    # Inspect target columns N and O specifically
    col_n = column_index_from_string("N")
    col_o = column_index_from_string("O")
    print("Column N header:", ws.cell(1, col_n).value)
    print("Column O header:", ws.cell(1, col_o).value)
    
    target_rows = list(range(1, min(max_row, 10) + 1))
    if max_row > 10:
        target_rows += list(range(max(1, max_row - 4), max_row + 1))
    target_rows = sorted(set(target_rows))
    
    print("Sample N/O values and formulas:")
    for r in target_rows:
        n_cell = ws.cell(r, col_n)
        o_cell = ws.cell(r, col_o)
        print(
            f"Row {r}: N{r}={n_cell.value!r} (type={type(n_cell.value).__name__}), "
            f"O{r}={o_cell.value!r} (type={type(o_cell.value).__name__})"
        )
        if isinstance(n_cell.value, str) and n_cell.value.startswith("="):
            print("  N formula:", n_cell.value)
        if isinstance(o_cell.value, str) and o_cell.value.startswith("="):
            print("  O formula:", o_cell.value)

for ws in wb.worksheets:
