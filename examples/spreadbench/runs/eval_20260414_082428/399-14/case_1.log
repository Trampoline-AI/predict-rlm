```repl
from openpyxl import load_workbook
from openpyxl.styles import Font
from copy import copy
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames[:]

def is_number(x):
    return isinstance(x, (int, float)) and not isinstance(x, bool)

def is_whole_number(x):
    if not is_number(x):
        return False
    return abs(float(x) - round(float(x))) < 1e-9

for ws in wb2.worksheets:
    print(f"\nProcessing sheet: {ws.title}")
    print("Used range:", ws.dimensions)
    
    # Apply 等线 font throughout used range, preserving size/bold/italic/etc.
    for row in ws.iter_rows():
        for cell in row:
            f = copy(cell.font)
            cell.font = Font(
                name="等线",
                size=f.sz,
                bold=f.bold,
                italic=f.italic,
                vertAlign=f.vertAlign,
                underline=f.underline,
                strike=f.strike,
                color=f.color,
                charset=f.charset,
                outline=f.outline,
                shadow=f.shadow,
                condense=f.condense,
                extend=f.extend,
                family=f.family,
                scheme=f.scheme,
            )
    
    # Find actual header row by REG/OT/Tips pattern
    header_row = None
    for r in range(1, ws.max_row + 1):
        if ws.cell(r, 14).value == "REG" and ws.cell(r, 15).value == "OT":
            header_row = r
            break
    print("Detected header row:", header_row)
    
    if header_row is not None:
        for r in range(header_row + 1, ws.max_row + 1):
            n = ws.cell(r, 14)  # N / REG
            o = ws.cell(r, 15)  # O / OT
            p = ws.cell(r, 16)  # P / Tips
            
            print(f"Before row {r}: N={n.value!r}, O={o.value!r}, P={p.value!r}")
            
            if is_number(n.value):
                hours = float(n.value)
                if hours > 40:
                    overtime = hours - 40
                    n.value = 40
                    o.value = overtime
                else:
                    # leave REG unchanged; keep OT if already populated, else blank
                    if o.value in ("",):
                        o.value = None
            
            # Apply formatting for N/O/P
            for cell in (n, o, p):
                if is_number(cell.value):
                    cell.number_format = "General" if is_whole_number(cell.value) else "#,##0.##"
            
            print(f"After  row {r}: N={n.value!r}, O={o.value!r}, P={p.value!r}, "
                  f"formats=({n.number_format!r}, {o.number_format!r}, {p.number_format!r})")

wb2.save(output_path)
print("\nSaved to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for ws, orig_name in zip(wb_check.worksheets, orig_sheet_names):
        ws.title = orig_name
    wb_check.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify with formulas/data_only
wb_verify = load_workbook(output_path, data_only=True)
print("\nVerification sheet names:", wb_verify.sheetnames)

for ws in wb_verify.worksheets:
    print(f"\nVerified sheet: {ws.title}")
    # Print exact target area N:P for all relevant rows
    for r in range(6, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(14, 17)]
        print(f"Row {r} N:P -> {vals}")

# Also verify fonts from non-data_only workbook
wb_font = load_workbook(output_path)
for ws in wb_font.worksheets:
    print(f"\nFont verification in {ws.title}:")
    for coord in ["N6", "N7", "O21", "N22", "P22"]:
        cell = ws[coord]
        print(coord, "value=", cell.value, "font=", cell.font.name, "numfmt=", cell.number_format)

final_output_path = output_path
