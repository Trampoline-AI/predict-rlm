import os, shutil
from openpyxl import load_workbook

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
orig_sheet_names = wb.sheetnames[:]

print("Full original sheet contents:")
all_rows = []
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    all_rows.append(vals)
    print(f"Row {r}: {vals}")

# Determine target column by duplicate behavior and user's example
# Here it's clearly column B (2): keep last occurrence of each non-empty value
target_col = 2
print("\nTarget duplicate-key column:", target_col, "(B)")
print("Current values in target column:")
for r in range(1, ws.max_row + 1):
    print(f"B{r} =", ws.cell(r, target_col).value)

last_row_for_value = {}
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, target_col).value
    if v not in (None, ""):
        last_row_for_value[v] = r

keep_rows = sorted(last_row_for_value.values())
delete_rows = [r for r in range(1, ws.max_row + 1) if r not in keep_rows]

print("Last occurrence row for each value:", dict(sorted(last_row_for_value.items(), key=lambda x: x[0])))
print("Rows to keep:", keep_rows)
print("Rows to delete:", delete_rows)
print("Rows being kept:")
kept_data = []
for r in keep_rows:
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    kept_data.append(vals)
    print(f"Row {r}: {vals}")

# Rewrite sheet contents to only the kept rows, preserving sheet name/structure
# Clear existing cells first
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

for out_r, vals in enumerate(kept_data, start=1):
    for c, v in enumerate(vals, start=1):
        ws.cell(out_r, c).value = v

# Save with same filename in output dir
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if changed
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names and len(wb2.sheetnames) == len(orig_sheet_names):
    for ws2, orig_name in zip(wb2.worksheets, orig_sheet_names):
        ws2.title = orig_name
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify output
wbv = load_workbook(output_path, data_only=True)
wsv = wbv[orig_sheet_names[0]]
print("\nVerified output sheet names:", wbv.sheetnames)
print("Verified remaining rows:")
verified_rows = []
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    # only print non-empty rows
    if any(v not in (None, "") for v in vals):
        verified_rows.append(vals)
        print(f"Row {r}: {vals}")

print("Non-empty output row count:", len(verified_rows))
print("Output key column values:", [row[target_col-1] for row in verified_rows])

final_output_path = output_path
