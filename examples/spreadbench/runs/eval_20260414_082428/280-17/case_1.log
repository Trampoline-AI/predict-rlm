import os, json, math, statistics
from collections import Counter, defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

# Inspect all sheets thoroughly
for ws in wb.worksheets:
    print(f"\n--- SHEET: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Find likely header row among first few rows by most non-empty cells
    best_row = 1
    best_nonempty = -1
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row = r
    print("Likely header row:", best_row)
    
    headers = [ws.cell(best_row, c).value for c in range(1, ws.max_column + 1)]
    print("Headers:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}{best_row}: {h}")
    
    # Sample first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)]
        print(f"Row {r}:", row_vals)
    
    # Sample last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)]
        print(f"Row {r}:", row_vals)
    
    # Analyze duplicate frequency by column for likely data rows below header
    print("Duplicate analysis for first 12 columns (non-empty values):")
    data_start = best_row + 1
    for c in range(1, min(ws.max_column, 12) + 1):
        vals = []
        for r in range(data_start, ws.max_row + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                vals.append(v)
        unique = len(set(vals))
        total = len(vals)
        dup_count = total - unique
        sample_dups = [item for item, cnt in Counter(vals).items() if cnt > 1][:10]
        print(f"  Col {get_column_letter(c)} header={headers[c-1]!r}: total_nonempty={total}, unique={unique}, duplicates={dup_count}, sample_dup_values={sample_dups}")

