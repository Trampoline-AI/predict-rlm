import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]

ws_in = wb["INPUT"]
ws_out = wb["OUPUT"]

# Reconfirm target area and current values before writing
print("Before writing, OUPUT rows 1-6:")
for r in range(1, min(6, ws_out.max_row) + 1):
    print(r, [ws_out.cell(r, c).value for c in range(1, 5)])

mapping = {
    "UNATIDE STATES AMERICAN": "USA",
    "FRANCE": "FRA",
    "KOREA": "KOR",
    "GERMANY": "GR",
    "ITALY": "IT",
}

# Ensure headers match existing structure in output sheet
expected_headers = ["ITEM", "BRANDS", "TYPE", "ORIGIN"]
for c, header in enumerate(expected_headers, start=1):
    ws_out.cell(1, c).value = header

# Clear existing output data rows in target columns only, then rewrite all relevant rows
for r in range(2, ws_out.max_row + 1):
    for c in range(1, 5):
        ws_out.cell(r, c).value = None

# Copy INPUT -> OUPUT using designated columns:
# INPUT A (ITEM), C (BRANDS), E (TYPE), F (ORIGIN mapped)
out_row = 2
for r in range(2, ws_in.max_row + 1):
    item = ws_in.cell(r, 1).value
    brands = ws_in.cell(r, 3).value
    typ = ws_in.cell(r, 5).value
    origin = ws_in.cell(r, 6).value

    # Skip fully empty rows
    if all(v in (None, "") for v in [item, brands, typ, origin]):
        continue

    mapped_origin = mapping.get(origin, origin)

    ws_out.cell(out_row, 1).value = item
    ws_out.cell(out_row, 2).value = brands
    ws_out.cell(out_row, 3).value = typ
    ws_out.cell(out_row, 4).value = mapped_origin
    out_row += 1

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames:
    # rename by position back to original names
    for i, name in enumerate(original_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification reload
verify_wb = load_workbook(outfile, data_only=True)
print("Final sheet names:", verify_wb.sheetnames)
verify_out = verify_wb["OUPUT"]

print("Verified OUPUT rows 1-6:")
for r in range(1, 7):
    print(r, [verify_out.cell(r, c).value for c in range(1, 5)])

# Sanity checks for target cells
target_values = [verify_out.cell(r, 4).value for r in range(2, 7)]
print("Verified ORIGIN values D2:D6:", target_values)
assert target_values == ["USA", "FRA", "KOR", "GR", "IT"], f"Unexpected output values: {target_values}"

output_spreadsheet = outfile
