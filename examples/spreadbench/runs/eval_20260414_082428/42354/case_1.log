import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally for editing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Query"]

print("Before writing, current D2:D8 values/formulas:")
for r in range(2, ws.max_row + 1):
    print(r, {
        "A": ws[f"A{r}"].value,
        "B": ws[f"B{r}"].value,
        "C": ws[f"C{r}"].value,
        "D_before": ws[f"D{r}"].value,
    })

# Write formula to all relevant data rows in existing Result column D
for r in range(2, ws.max_row + 1):
    formula = f'=IF(A{r}<>"#N/A",A{r},IF(B{r}<>"#N/A",B{r},IF(C{r}<>"#N/A",C{r},"")))'
    ws[f"D{r}"] = formula

print("\nAfter writing, D2:D8 formulas:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"D{r}"].value)

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc; fix sheet names if LO changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename sheets back by position
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Query"]

print("\nVerified D2:D8 cached values:")
verified_values = {}
for r in range(2, wsv.max_row + 1):
    verified_values[r] = wsv[f"D{r}"].value
    print(r, verified_values[r])

# Keep path for submission
final_output_path = output_path
