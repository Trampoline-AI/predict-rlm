from openpyxl import load_workbook
import os

output_path = final_output_path  # from prior step

# Inspect actual source cell types/errors
wb_inspect = load_workbook(input_spreadsheet)
wsi = wb_inspect["Query"]

print("Inspecting A2:C8 values and data types:")
for r in range(2, wsi.max_row + 1):
    row_info = {}
    for col in ["A", "B", "C", "D"]:
        cell = wsi[f"{col}{r}"]
        row_info[col] = {"value": cell.value, "data_type": cell.data_type}
    print(r, row_info)

# Rewrite formulas in D using ISNA so real #N/A errors fall through correctly
wb_fix = load_workbook(input_spreadsheet)
ws = wb_fix["Query"]

for r in range(2, ws.max_row + 1):
    formula = f'=IF(ISNA(A{r}),IF(ISNA(B{r}),IF(ISNA(C{r}),"",C{r}),B{r}),A{r})'
    ws[f"D{r}"] = formula

print("\nRewritten D2:D8 formulas:")
for r in range(2, ws.max_row + 1):
    print(r, ws[f"D{r}"].value)

wb_fix.save(output_path)
print("\nSaved fixed workbook to:", output_path)

recalc_result_2 = await recalculate(output_path)
print("Recalculate result:", recalc_result_2)

# Verify sheet names and cached results
