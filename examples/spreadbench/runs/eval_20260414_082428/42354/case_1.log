import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

input_path = input_spreadsheet
wb = load_workbook(input_path)
print("Workbook loaded:", input_path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

for ws in wb.worksheets:
    print("\n--- SHEET ---", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 values / headers:", headers)
    
    # print first 10 rows and last 5 rows, bounded
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))
    if ws.max_row > 10:
        print("Last rows:")
        start_last = max(1, ws.max_row - 4)
        for r in range(start_last, ws.max_row + 1):
            print(r, row_values(ws, r, min(ws.max_column, 8)))
    
    # Focus on A:D and formulas in D
    print("Sample A:D with formula info:")
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(4, ws.max_column) + 1)]
        print(f"Row {r}: {vals}")
    
    if ws.max_column >= 4:
        existing_d = []
        for r in range(1, ws.max_row + 1):
            v = ws.cell(r, 4).value
            if v is not None:
                existing_d.append((r, v))
        print("Non-empty cells in column D (first 15 shown):", existing_d[:15])

# Keep workbook variable for later
orig_sheetnames = wb.sheetnames[:]
