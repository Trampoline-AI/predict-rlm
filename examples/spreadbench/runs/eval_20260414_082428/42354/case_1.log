        wb_post.worksheets[i].title = expected
    wb_post.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

wb_verify2 = load_workbook(output_path, data_only=True)
wsv2 = wb_verify2["Query"]

print("\nVerified D2:D8 cached values after fix:")
