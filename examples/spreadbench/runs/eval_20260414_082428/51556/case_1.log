```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter, column_index_from_string
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Sheet title:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)

# Print all columns A:S with headers and row values
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 20)]  # A:S
    print(f"Row {r} A:S -> {vals}")

# Inspect exact target and referenced cells
targets = ["P2","P3","P4","P5","P6","Q2","Q3","Q4","Q5","Q6","S1","S2"]
for coord in targets:
    cell = ws[coord]
    fill = cell.fill
    fill_info = (fill.fill_type, fill.fgColor.rgb, fill.start_color.rgb, fill.end_color.rgb)
    print(coord, "value=", cell.value, "fill=", fill_info)

# If formulas exist, print formula strings in Q2:Q6
for r in range(2, 7):
    print(f"Q{r} current raw:", ws[f"Q{r}"].value)

# Determine matching columns for each size in P2:P6 to validate logic
sizes = [ws[f"P{r}"].value for r in range(2, 7)]
header_sizes = {get_column_letter(c): ws.cell(2, c).value for c in range(2, 13)}  # B:L row2
print("Header sizes B2:L2:", header_sizes)
for size in sizes:
    matching = [col for col, val in header_sizes.items() if val == size]
    print("Size", size, "matches columns", matching)

# Write formulas in Q2:Q6
# Average across B3:L8 values where row2 size equals Pn and M3:M8 equals $S$2.
for r in range(2, 7):
    p = f"P{r}"
    q = f"Q{r}"
    formula = (
        f'=IFERROR('
        f'SUMPRODUCT(($B$2:$L$2={p})*($M$3:$M$8=$S$2)*($B$3:$L$8))/'
        f'SUMPRODUCT(($B$2:$L$2={p})*($M$3:$M$8=$S$2)*ISNUMBER($B$3:$L$8))'
        f',"")'
    )
    ws[q] = formula
    ws[q].fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
    print("Wrote", q, "->", formula)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
orig_names = wb.sheetnames
wb2 = load_workbook(out_path)
print("Post-recalc sheet names:", wb2.sheetnames)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for old, new in zip(orig_names, wb2.sheetnames):
        wb2[new].title = old
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
wb_vals = load_workbook(out_path, data_only=True)
wsv = wb_vals[orig_names[0]]

for r in range(2, 7):
    print(
        f"Row {r}: P={wsv[f'P{r}'].value}, S2={wsv['S2'].value}, "
        f"Q formula={wsf[f'Q{r}'].value}, Q value={wsv[f'Q{r}'].value}, "
        f"Q fill={wsf[f'Q{r}'].fill.fill_type, wsf[f'Q{r}'].fill.start_color.rgb}"
    )
