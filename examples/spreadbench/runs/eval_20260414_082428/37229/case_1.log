from openpyxl import load_workbook
from collections import defaultdict
import os
from datetime import datetime

outfile = output_spreadsheet
print("Output file exists:", os.path.exists(outfile), outfile)

# Load formula and data_only versions
wb_f = load_workbook(outfile, data_only=False)
wb_v = load_workbook(outfile, data_only=True)
print("Formula sheets:", wb_f.sheetnames)
print("Value sheets:", wb_v.sheetnames)

wsf = wb_f[wb_f.sheetnames[0]]
wsv = wb_v[wb_v.sheetnames[0]]

# Print a few formulas only
for addr in ["C3","G3","C4","G4","C6","C13"]:
    print(addr, "formula:", wsf[addr].value, "cached:", wsv[addr].value)

print("\nCalculated C3:G14:")
for r in range(3, 15):
    print(r, [wsv.cell(r, c).value for c in range(3, 8)])

# Compute expected results in Python from source rows
month_totals = defaultdict(lambda: [0,0,0,0,0])
for r in range(17, 25):
    d = wsv.cell(r, 2).value
    if d is None:
        continue
    key = (d.year, d.month)
    for i, c in enumerate(range(3, 8)):
        val = wsv.cell(r, c).value
        month_totals[key][i] += 0 if val in (None, "") else val

print("\nExpected by Python for rows 3:14:")
for r in range(3, 15):
    d = wsv.cell(r, 2).value
    key = (d.year, d.month)
    vals = month_totals.get(key, [0,0,0,0,0])
    expected = [("" if v == 0 else v) for v in vals]
    actual = [wsv.cell(r, c).value for c in range(3, 8)]
    print(r, d.strftime("%b"), "expected", expected, "actual", actual)

# Detect any mismatches or blanks where nonblank expected
mismatches = []
for r in range(3, 15):
    d = wsv.cell(r, 2).value
    vals = month_totals.get((d.year, d.month), [0,0,0,0,0])
    expected = [None if v == 0 else v for v in vals]
    actual = [wsv.cell(r, c).value for c in range(3, 8)]
    norm_actual = [None if v == "" else v for v in actual]
    if norm_actual != expected:
        mismatches.append((r, expected, actual))
print("\nMismatch count:", len(mismatches))
for m in mismatches[:10]:
    print("Mismatch:", m)
