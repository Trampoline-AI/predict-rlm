import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Reload fresh workbook for editing
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect current target cells/formulas before modifying
print("Current target C3:G14 values/formulas before write:")
for r in range(3, 15):
    row = []
    for c in range(3, 8):
        v = ws.cell(r, c).value
        row.append(v)
    print(r, row)

# Write formulas into C3:G14
# Sum category column in rows 17:24 where date in B17:B24 is in same month/year as B[row]
for r in range(3, 15):
    month_start_ref = f"$B{r}"
    next_month_formula = f"EDATE({month_start_ref},1)"
    for c in range(3, 8):
        col = get_column_letter(c)
        sum_formula = f'SUMIFS(${col}$17:${col}$24,$B$17:$B$24,">="&{month_start_ref},$B$17:$B$24,"<"&{next_month_formula})'
        final_formula = f'=IF({sum_formula}=0,"",{sum_formula})'
        ws.cell(r, c).value = final_formula

print("\nWritten formulas C3:G14:")
for r in range(3, 15):
    print(r, [ws.cell(r, c).value for c in range(3, 8)])

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas and cached results
