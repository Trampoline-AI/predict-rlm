```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Re-open fresh workbook for writing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet2"]

# Identify data rows by non-empty column A from row 2 downward
data_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 1).value is not None and str(ws.cell(r, 1).value).strip() != "":
        data_rows.append(r)

print("Target sheet:", ws.title)
print("Target column B header:", ws["B1"].value)
print("Data rows:", data_rows[:5], "...", data_rows[-5:], "count=", len(data_rows))

# Show current formulas/values in target range
print("\nBefore change (A/B rows 2:21):")
for r in data_rows:
    print(r, ws.cell(r,1).value, ws.cell(r,2).value)

# Compute expected occurrence order in Python for verification
seen = defaultdict(int)
expected = {}
for r in data_rows:
    key = ws.cell(r, 1).value
    seen[key] += 1
    expected[r] = seen[key]

print("\nExpected occurrence order from Python:")
for r in data_rows:
    print(f"Row {r}: A={ws.cell(r,1).value!r} -> expected B={expected[r]}")

# Replace existing incorrect formulas with correct dynamic formulas
start_row = min(data_rows)
for r in data_rows:
    formula = f"=COUNTIF($A${start_row}:A{r},A{r})"
    ws.cell(r, 2).value = formula

print("\nAfter writing formulas:")
for r in data_rows:
    print(r, ws.cell(r,1).value, ws.cell(r,2).value)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for idx, original_name in enumerate(orig_sheet_names):
        wb_check.worksheets[idx].title = original_name
    wb_check.save(output_path)
    print("Renamed sheets back to original:", orig_sheet_names)

# Verify with data_only=True
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerification of target cells B2:B21 after recalculation:")
mismatches = []
blanks = []
for r in data_rows:
    val = ws_values.cell(r, 2).value
    print(f"B{r}={val!r} (expected {expected[r]!r})")
    if val in (None, ""):
        blanks.append(r)
    elif val != expected[r]:
        mismatches.append((r, val, expected[r]))

print("\nBlanks:", blanks)
print("Mismatches:", mismatches)
print("Final sheet names:", wb_values.sheetnames)
```
