import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find headers from row 1
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    
    # Print first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
        print(r, row_vals)
    
    if ws.max_row > 10:
        print("Last 5 rows:")
        start = max(1, ws.max_row - 4)
        for r in range(start, ws.max_row + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
            print(r, row_vals)
    
    # Specific inspection for columns A and B across used rows
    print("Sample A/B values:")
    for r in range(1, min(ws.max_row, 15) + 1):
        a = ws[f"A{r}"].value
        b = ws[f"B{r}"].value
        print(f"Row {r}: A={a!r}, B={b!r}")
    if ws.max_row > 15:
        print("Tail A/B values:")
        for r in range(max(1, ws.max_row - 9), ws.max_row + 1):
            a = ws[f"A{r}"].value
            b = ws[f"B{r}"].value
            print(f"Row {r}: A={a!r}, B={b!r}")
    
    # Print formulas if present in A/B
    for col in ["A", "B"]:
        formulas = []
        for r in range(1, ws.max_row + 1):
            v = ws[f"{col}{r}"].value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, v))
        print(f"Formulas in column {col}:", formulas[:10], "count=", len(formulas))

for ws in wb.worksheets:
    sheet_summary(ws)
```
