import os
from openpyxl import load_workbook
from openpyxl.styles import Alignment

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Reconfirm source/target details before writing
print("Using sheet:", ws.title)
print("Source header B1:", ws["B1"].value)
print("Existing target area before write:")
for r in range(3, 7):
    print(r, ws[f"I{r}"].value, ws[f"J{r}"].value)

# Determine actual non-empty extent of column B
last_b_row = 1
for r in range(ws.max_row, 0, -1):
    if ws.cell(r, 2).value not in (None, ""):
        last_b_row = r
        break
print("Last non-empty row in column B:", last_b_row)

# Optional sanity-check counts in Python
items_order = ["A006", "A004", "A005"]
python_counts = {}
for item in items_order:
    cnt = 0
    for r in range(2, last_b_row + 1):
        if ws.cell(r, 2).value == item:
            cnt += 1
    python_counts[item] = cnt
print("Python counts:", python_counts)

# Write headers and items starting from I3
ws["I3"] = "ITEM"
ws["J3"] = "Qty"

start_row = 4
for idx, item in enumerate(items_order, start=start_row):
    ws[f"I{idx}"] = item
    ws[f"J{idx}"] = f'=COUNTIF($B$2:$B${last_b_row},I{idx})'

# Left align entire answer range only, no other formatting
for r in range(3, 3 + 1 + len(items_order)):
    for c in range(9, 11):  # I:J
        ws.cell(r, c).alignment = Alignment(horizontal="left")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if recalculation changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # rename by position to restore original names
    for i, original_name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    print("Restored sheet names:", original_sheetnames)

# Verify output values after recalculation
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula[original_sheetnames[0]]
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values[original_sheetnames[0]]

print("Verification I3:J6 formulas:")
for r in range(3, 7):
    print(r, wsf[f"I{r}"].value, wsf[f"J{r}"].value)

print("Verification I3:J6 cached values:")
for r in range(3, 7):
    print(r, wsv[f"I{r}"].value, wsv[f"J{r}"].value)

# Check alignment
for r in range(3, 7):
    print(
        f"Row {r} alignment:",
        wsf[f"I{r}"].alignment.horizontal,
        wsf[f"J{r}"].alignment.horizontal,
    )

output_spreadsheet = output_path
