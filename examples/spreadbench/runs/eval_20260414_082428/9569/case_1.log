```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

outpath = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
print("Output exists:", os.path.exists(outpath), outpath)

wbf = load_workbook(outpath, data_only=False)
wbv = load_workbook(outpath, data_only=True)
wsf = wbf["Sheet1"]
wsv = wbv["Sheet1"]

ao = column_index_from_string("AO")
month_start = column_index_from_string("E")
month_end = column_index_from_string("AN")

active_rows = [r for r in range(9, wsf.max_row + 1) if wsf.cell(r, 2).value not in (None, "")]
print("Active row count:", len(active_rows))

# Compact verification on selected rows
sample_rows = [9,10,11,12,13,14,15,16,50,100,200,500,1000,1284,1285,1286,1287,1288]
summary = []
for r in sample_rows:
    if r <= wsf.max_row and wsf.cell(r, 2).value not in (None, ""):
        months = [wsv.cell(r, c).value for c in range(month_start, month_end+1)]
        expected = ""
        for v in months:
            if v not in (None, "") and v != 0:
                expected = v
                break
        summary.append({
            "row": r,
            "contract": wsv.cell(r, 2).value,
            "formula_prefix": str(wsf.cell(r, ao).value)[:60] if wsf.cell(r, ao).value is not None else None,
            "ao_value": wsv.cell(r, ao).value,
            "expected": expected,
            "match": (wsv.cell(r, ao).value == expected)
        })
print("Sample verification:")
for item in summary:
    print(item)

# Broader check across all active rows
nonblank_ao = 0
matches = 0
mismatches = []
for r in active_rows:
    months = [wsv.cell(r, c).value for c in range(month_start, month_end+1)]
    expected = ""
    for v in months:
        if v not in (None, "") and v != 0:
            expected = v
            break
    ao_val = wsv.cell(r, ao).value
    if ao_val not in (None, ""):
        nonblank_ao += 1
    if ao_val == expected:
        matches += 1
    else:
        mismatches.append((r, wsv.cell(r,2).value, ao_val, expected))

print("AO nonblank count:", nonblank_ao)
print("Exact matches:", matches, "of", len(active_rows))
print("Mismatch count:", len(mismatches))
print("First 10 mismatches:", mismatches[:10])

# Check if any AO formulas are missing on active rows
missing_formulas = [r for r in active_rows if not (isinstance(wsf.cell(r, ao).value, str) and wsf.cell(r, ao).value.startswith("="))]
print("Missing formulas on active rows:", len(missing_formulas), missing_formulas[:10])

final_output_path = outpath
```
