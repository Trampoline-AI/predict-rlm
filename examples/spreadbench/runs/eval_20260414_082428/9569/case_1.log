from openpyxl.utils import get_column_letter, column_index_from_string

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Detailed inspection around actual header/data area
print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)
print("Header row 8 A:AO")
for c in range(1, ws.max_column + 1):
    print(get_column_letter(c), ws.cell(8, c).value)

print("\nRows 8-20, columns B:AO")
for r in range(8, 21):
    vals = [ws.cell(r, c).value for c in range(2, ws.max_column + 1)]
    print("row", r, vals)

# Inspect some later and last data rows
sample_rows = [9,10,11,12,13,14,15,16,50,100,200,500,1000,1284,1285,1286,1287,1288]
print("\nFocused inspection for sample rows, cols B:AO")
for r in sample_rows:
    if r <= ws.max_row:
        print("row", r, [ws.cell(r,c).value for c in range(2, ws.max_column+1)])

# Print AO cells and formulas around first data rows
ao = column_index_from_string("AO")
print("\nAO header:", ws["AO8"].value)
for r in sample_rows:
    if r <= ws.max_row:
        print(f"AO{r} =", ws.cell(r, ao).value)

# Determine active data rows based on contract number in col B
active_rows = []
for r in range(9, ws.max_row + 1):
    if ws.cell(r, 2).value not in (None, ""):
        active_rows.append(r)
print("\nActive data row count:", len(active_rows), "first:", active_rows[:10], "last:", active_rows[-10:])

# Build a non-array nested IF formula across month columns E:AN
month_start = column_index_from_string("E")
month_end = column_index_from_string("AN")
print("Month range:", get_column_letter(month_start), "to", get_column_letter(month_end))

def earliest_formula_for_row(r):
    # returns first nonblank, nonzero value from E:AN, else blank
    expr = '""'
    for c in range(month_end, month_start - 1, -1):
        ref = f"{get_column_letter(c)}{r}"
        expr = f'IF(AND({ref}<>"",{ref}<>0),{ref},{expr})'
    return "=" + expr

# Show formulas for first few rows before writing
for r in active_rows[:5]:
    print(r, earliest_formula_for_row(r))

# Write formulas only to active rows in AO (designated output column)
for r in active_rows:
    ws.cell(r, ao).value = earliest_formula_for_row(r)

# Save
