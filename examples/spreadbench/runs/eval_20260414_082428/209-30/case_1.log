import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction preview:", instruction[:300])

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
print("Original sheet names:", orig_sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

def nonempty_last_row(ws):
    last = 0
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column+1)):
            last = r
            break
    return last

for s in wb.sheetnames:
    ws = wb[s]
    last_row = nonempty_last_row(ws)
    headers = row_values(ws, 1)
    print(f"\n--- Sheet: {s} ---")
    print("max_row/max_column:", ws.max_row, ws.max_column, "last_nonempty_row:", last_row)
    print("Headers row 1:", headers)
    # print first 8 rows and last 5 rows, limited columns
    max_cols_to_show = min(ws.max_column, 10)
    print("First rows:")
    for r in range(1, min(last_row, 8)+1):
        print(r, row_values(ws, r, max_cols_to_show))
    if last_row > 8:
        print("Last rows:")
        for r in range(max(1, last_row-4), last_row+1):
            print(r, row_values(ws, r, max_cols_to_show))

# Detailed inspection of referenced sheet/column
target_sheet = "Data to Import"
if target_sheet in wb.sheetnames:
    ws = wb[target_sheet]
    print(f"\nDetailed inspection for sheet '{target_sheet}'")
    print("Column letters/headers:")
    for c in range(1, ws.max_column+1):
        print(c, get_column_letter(c), ws.cell(1, c).value)
    last_row = nonempty_last_row(ws)
    print("last nonempty row:", last_row)
    print("C1:", ws["C1"].value, "C2:", ws["C2"].value, "C3:", ws["C3"].value)
    # sample C values first 10 non-empty-ish rows
    print("Sample C values first 12 rows:")
    for r in range(1, min(last_row, 12)+1):
        cell = ws.cell(r, 3)
        print(f"C{r}: value={cell.value!r} data_type={cell.data_type}")
    print("Sample trailing C values:")
    for r in range(max(1, last_row-4), last_row+1):
        cell = ws.cell(r, 3)
        print(f"C{r}: value={cell.value!r} data_type={cell.data_type}")
else:
    print(f"Referenced sheet '{target_sheet}' not found.")
