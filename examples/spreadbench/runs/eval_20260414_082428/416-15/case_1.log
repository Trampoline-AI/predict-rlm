import os
from datetime import datetime
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

# Inspect target cells before modification
print("Pre-modification target values A2:A19:")
for r in range(2, ws.max_row + 1):
    cell = ws.cell(r, 1)
    print(r, repr(cell.value), cell.data_type, cell.number_format)

# Convert only relevant timestamp strings in column A
changed_rows = []
for r in range(2, ws.max_row + 1):
    cell = ws.cell(r, 1)
    v = cell.value
    if isinstance(v, str) and "T" in v and v.endswith("Z"):
        date_part = v.split("T", 1)[0].strip()
        try:
            dt = datetime.strptime(date_part, "%Y-%m-%d")
            cell.value = dt
            cell.number_format = "m/dd/yyyy"
            changed_rows.append((r, v, dt))
        except Exception as e:
            print(f"Failed parsing row {r}: {v} -> {e}")
    elif isinstance(v, datetime):
        # Ensure requested display format for existing date cells too
        cell.number_format = "m/dd/yyyy"

print("\nChanged rows:")
for item in changed_rows:
    print(item)

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename sheets positionally back to originals
    for ws_tmp, orig_name in zip(wb_after.worksheets, original_sheet_names):
        ws_tmp.title = orig_name
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verify with formulas/data cached
wb_verify = load_workbook(output_path, data_only=False)
wsv = wb_verify[original_sheet_names[0]]

print("\nVerification of target cells A2:A19 after save:")
for r in range(2, wsv.max_row + 1):
    cell = wsv.cell(r, 1)
    print(r, repr(cell.value), cell.data_type, cell.number_format)

# Data-only reload to confirm persisted values
wb_data = load_workbook(output_path, data_only=True)
wsd = wb_data[original_sheet_names[0]]
print("\nData-only verification A2:A19:")
for r in range(2, wsd.max_row + 1):
    cell = wsd.cell(r, 1)
    print(r, repr(cell.value))

# Sanity checks
none_rows = [r for r in range(2, wsd.max_row + 1) if wsd.cell(r, 1).value in (None, "")]
print("\nBlank target rows after processing:", none_rows)
print("Total changed rows:", len(changed_rows))
```
