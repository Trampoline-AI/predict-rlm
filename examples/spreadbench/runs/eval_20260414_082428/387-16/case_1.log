from collections import Counter
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Print exact relevant cells/ranges before modifying
print("Relevant headers/cells:")
for coord in ["A2","B2","D4","E2","G2","H2","J2","K2"]:
    print(coord, "=>", ws[coord].value)

# Determine actual populated ranges
def nonempty_in_col(ws, col, start=1, end=None):
    end = end or ws.max_row
    out = []
    for r in range(start, end+1):
        v = ws.cell(r, col).value
        if v not in (None, ""):
            out.append((r, v))
    return out

colA = nonempty_in_col(ws, 1, 1, ws.max_row)
colB = nonempty_in_col(ws, 2, 1, ws.max_row)
colD = nonempty_in_col(ws, 4, 1, ws.max_row)

print("\nColumn A non-empty:", colA)
print("Column B non-empty:", colB)
print("Column D non-empty:", colD)

values_rows = [(r, ws.cell(r,1).value, ws.cell(r,2).value) for r in range(3, ws.max_row+1) if ws.cell(r,1).value not in (None, "")]
result_rows = [(r, ws.cell(r,4).value) for r in range(5, ws.max_row+1) if ws.cell(r,4).value not in (None, "")]
print("\nA/B data rows:", values_rows)
print("Result values rows:", result_rows)

value_list = [v for _, v, _ in values_rows]
binary_list = [b for _, _, b in values_rows]
result_values = [v for _, v in result_rows]
print("\nCounts in Value column:", Counter(value_list))
print("Counts in Result values:", Counter(result_values))

# Simulate one-instance removal preserving order
remaining = values_rows.copy()
for rv in result_values:
    removed = False
    new_remaining = []
    for item in remaining:
        r, val, binv = item
        if (not removed) and val == rv:
            removed = True
            continue
        new_remaining.append(item)
    remaining = new_remaining
    if not removed:
        print("Warning: result value not found in A column during removal:", rv)

print("\nRemaining after one-instance-per-result removal:")
print(remaining)
print("Remaining count:", len(remaining), "Original count:", len(values_rows), "Removed:", len(values_rows)-len(remaining))
print("Remaining sum of A:", sum(v for _, v, _ in remaining))

# Write modifications
start_row = 3
end_row = ws.max_row

# overwrite compacted A/B rows
for idx, (_, val, binv) in enumerate(remaining, start=start_row):
    ws.cell(idx, 1).value = val
    ws.cell(idx, 2).value = binv

# clear remaining old cells below compacted area
for r in range(start_row + len(remaining), end_row + 1):
    ws.cell(r, 1).value = None
    ws.cell(r, 2).value = None

# Update formulas per instruction
last_data_row = start_row + len(remaining) - 1
if last_data_row >= start_row:
    ws["H2"] = f"=SUM(A{start_row}:A{last_data_row})"
else:
    ws["H2"] = "=0"
ws["K2"] = "=H2-E2"

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and restore sheet name if needed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"]:
    ws0 = wb2[wb2.sheetnames[0]]
    ws0.title = "Sheet1"
    wb2.save(out_path)
    print("Renamed first sheet back to Sheet1 and re-saved.")

# Verify with formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["Sheet1"]
wb_data = load_workbook(out_path, data_only=True)
wsd = wb_data["Sheet1"]

print("\nPost-save formulas:")
for coord in ["H2", "K2"]:
    print(coord, "formula =>", wsf[coord].value)

print("\nVerified output A/B rows:")
verified_rows = [(r, wsd.cell(r,1).value, wsd.cell(r,2).value) for r in range(3, wsd.max_row+1) if wsd.cell(r,1).value not in (None, "")]
print(verified_rows)

print("\nVerified target cells (cached values):")
for coord in ["E2","H2","K2"]:
    print(coord, "=>", wsd[coord].value)

print("Expected remaining sum:", sum(v for _, v, _ in remaining))
