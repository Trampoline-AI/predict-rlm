def sheet_summary(ws):
    print(f"\n=== SHEET: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[0], nonempty_rows[-1]) if nonempty_rows else None)
    
    # header candidates: first 5 rows
    for r in range(1, min(6, ws.max_row + 1)):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # choose header row as first row with at least 2 non-empty strings, else row1
    header_row = 1
    for r in range(1, min(10, ws.max_row + 1)):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        text_count = sum(isinstance(v, str) and v.strip() != "" for v in vals)
        nonempty_count = sum(v not in (None, "") for v in vals)
        if text_count >= 2 or nonempty_count >= 2:
            header_row = r
            break
    headers = [ws.cell(header_row,c).value for c in range(1, ws.max_column + 1)]
    print("Chosen header row:", header_row)
    print("Headers:", headers)
    
    # first 10 non-empty rows
    shown = 0
    print("First non-empty rows sample:")
    for r in nonempty_rows[:10]:
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        print(f"R{r}:", vals)
        shown += 1
    
    print("Last 5 non-empty rows sample:")
    for r in nonempty_rows[-5:]:
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column + 1)]
        print(f"R{r}:", vals)
    
    # find keywords in headers/cells
    keywords = ["value", "values", "binaries", "result", "solver", "difference"]
    hits = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r,c).value
            if isinstance(v, str):
                low = v.lower()
                if any(k in low for k in keywords):
                    hits.append((r, c, v))
    print("Keyword hits (up to 30):", hits[:30])

for ws in wb.worksheets:
    sheet_summary(ws)
