```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment, Border, Side

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Working on sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)

# Enforce row 4 formatting / headers
thin = Side(style="thin", color="000000")
bottom_border = Border(bottom=thin)

for c in range(1, ws.max_column + 1):
    cell = ws.cell(4, c)
    # Wrap text on all of row 4
    cell.alignment = copy(cell.alignment)
    cell.alignment = Alignment(
        horizontal=cell.alignment.horizontal,
        vertical=cell.alignment.vertical,
        text_rotation=cell.alignment.text_rotation,
        wrap_text=True,
        shrink_to_fit=cell.alignment.shrink_to_fit,
        indent=cell.alignment.indent,
    )
    # Header cells with values should be bold and bottom-bordered
    if cell.value is not None:
        cell.font = copy(cell.font)
        cell.font = Font(
            name=cell.font.name,
            sz=cell.font.sz,
            b=True,
            i=cell.font.i,
            color=cell.font.color.type and cell.font.color.rgb if cell.font.color else None,
            underline=cell.font.underline,
            strike=cell.font.strike,
            outline=cell.font.outline,
            shadow=cell.font.shadow,
            condense=cell.font.condense,
            extend=cell.font.extend,
            vertAlign=cell.font.vertAlign,
            scheme=cell.font.scheme,
            charset=cell.font.charset,
            family=cell.font.family,
        )
        cell.border = Border(
            left=copy(cell.border.left),
            right=copy(cell.border.right),
            top=copy(cell.border.top),
            bottom=thin,
            diagonal=copy(cell.border.diagonal),
            diagonal_direction=cell.border.diagonal_direction,
            outline=cell.border.outline,
            vertical=copy(cell.border.vertical),
            horizontal=copy(cell.border.horizontal),
        )

# Ensure column G has no values and no borders
for r in range(1, ws.max_row + 1):
    g = ws.cell(r, 7)
    g.value = None
    g.border = Border()

# Determine data range starting after header row 4
start_row = 5
end_row = ws.max_row
print("Target formula range: H{}:H{}".format(start_row, end_row))

# Print existing target area before writing
for r in range(start_row, end_row + 1):
    print(f"Before H{r}:", ws.cell(r, 8).value)

# Formula logic:
# On the last transfer row in a group:
# - current row must be a transfer row: D=5551234 and E<>5551234
# - next row starts a new group (E next row = 5551234) or next row is blank / end
# Count transfer rows from the row after the most recent E=5551234 up to current row.
for r in range(start_row, end_row + 1):
    next_r = r + 1
    formula = (
        f'=IF(AND(D{r}=5551234,E{r}<>5551234,OR(E{next_r}=5551234,E{next_r}="")),'
        f'COUNTIF('
        f'INDEX($D$5:$D${end_row},LOOKUP(2,1/($E$5:$E{r}=5551234),ROW($E$5:$E{r}))-ROW($D$5)+2)'
        f':D{r},5551234),'
        f'""'
        f')'
    )
    ws.cell(r, 8).value = formula

# Keep header text intact
ws["H4"] = "Expected Result"

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position back to original
    for i, name in enumerate(orig_sheetnames):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)

# Verify formulas and evaluated values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals["Sheet1"]

print("\nVerification of target cells H5:H26")
for r in range(start_row, end_row + 1):
    print(f"Row {r}: formula={wsf.cell(r,8).value!r}, value={wsv.cell(r,8).value!r}")

print("\nKey expected rows:")
for r in [6,9,11,13,15,17,19,21,25]:
    print(f"H{r} =", wsv[f'H{r}'].value)

print("\nCheck column G remains blank/unbordered on sample rows:")
for r in [4,5,6,9,25,26]:
    g = wsf.cell(r, 7)
    print(f"G{r}: value={g.value!r}, borders={(g.border.left.style, g.border.right.style, g.border.top.style, g.border.bottom.style)}")

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
