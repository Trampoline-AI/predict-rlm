import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload cleanly
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
ws_emp = wb["Emp"]
ws_lookup = wb["Lookup"]
ws_exp = wb["Expected"]

print("Source sheet names:", wb.sheetnames)

# Inspect exact source and target areas
print("\nEmp headers with column letters:")
emp_headers = [ws_emp.cell(1, c).value for c in range(1, ws_emp.max_column + 1)]
for c, h in enumerate(emp_headers, start=1):
    print(get_column_letter(c), h)

print("\nExpected headers with column letters:")
exp_headers = [ws_exp.cell(1, c).value for c in range(1, ws_exp.max_column + 1)]
for c, h in enumerate(exp_headers, start=1):
    print(get_column_letter(c), h)

print("\nCurrent nonblank rows in Expected:")
for r in range(1, ws_exp.max_row + 1):
    vals = [ws_exp.cell(r, c).value for c in range(1, ws_exp.max_column + 1)]
    if any(v is not None for v in vals):
        print(r, vals)

# Build lookup mapping
lookup_map = {}
for r in range(2, ws_lookup.max_row + 1):
    var = ws_lookup.cell(r, 1).value
    cat = ws_lookup.cell(r, 2).value
    subcat = ws_lookup.cell(r, 3).value
    if var is not None:
        lookup_map[str(var).strip()] = (cat, subcat)
print("\nLookup map:", lookup_map)

# Determine source ID columns and variable columns from Emp
id_cols = [1, 2, 3, 4]               # seqno, Empno, ename, Jobid
var_cols = list(range(5, ws_emp.max_column + 1))  # Comp1 ... performance
print("ID columns:", [(get_column_letter(c), ws_emp.cell(1, c).value) for c in id_cols])
print("Variable columns:", [(get_column_letter(c), ws_emp.cell(1, c).value) for c in var_cols])

# Generate expected output rows
out_rows = []
for r in range(2, ws_emp.max_row + 1):
    base_vals = [ws_emp.cell(r, c).value for c in id_cols]
    if all(v is None for v in base_vals):
        continue
    for c in var_cols:
        var_name = ws_emp.cell(1, c).value
        value = ws_emp.cell(r, c).value
        cat, subcat = lookup_map.get(str(var_name).strip(), (None, None))
        out_rows.append(base_vals + [var_name, cat, subcat, value])

print("\nGenerated row count:", len(out_rows))
print("First 10 generated rows:")
for row in out_rows[:10]:
    print(row)
print("Last 5 generated rows:")
for row in out_rows[-5:]:
    print(row)

# Write into existing Expected sheet
# Confirm target columns A:H
print("\nTarget columns in Expected (A:H):", exp_headers[:8])

# Clear old output data rows under header in A:H only
for r in range(2, ws_exp.max_row + 1):
    for c in range(1, 9):
        ws_exp.cell(r, c).value = None

# Ensure header row exactly as existing structure
headers = ['seqno', 'Empno', 'ename', 'Jobid', 'Variable', 'Category', 'Subcategory', 'Value']
for c, h in enumerate(headers, start=1):
    ws_exp.cell(1, c).value = h

# Write rows
for i, row in enumerate(out_rows, start=2):
    for c, v in enumerate(row, start=1):
        ws_exp.cell(i, c).value = v

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice renamed them
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    print("Renaming sheets back to original names...")
    for idx, name in enumerate(orig_sheetnames):
        wb_after.worksheets[idx].title = name
    wb_after.save(out_path)
    wb_after = load_workbook(out_path)
print("Final sheet names:", wb_after.sheetnames)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["Expected"]

print("\nVerified Expected rows 1 through", min(20, wsv.max_row))
for r in range(1, min(20, wsv.max_row) + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 9)]
    print(r, vals)

# Key verification checks
nonblank_output_rows = []
for r in range(2, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 9)]
    if any(v is not None for v in vals):
        nonblank_output_rows.append((r, vals))

print("\nNonblank output row count:", len(nonblank_output_rows))
print("Last 5 nonblank output rows:")
for item in nonblank_output_rows[-5:]:
    print(item)

# Check blanks in target output cells
problems = []
for r, vals in nonblank_output_rows:
    if any(v is None for v in vals):
        problems.append((r, vals))
print("Rows with any None in A:H:", problems[:10], "count=", len(problems))

final_output_path = out_path
