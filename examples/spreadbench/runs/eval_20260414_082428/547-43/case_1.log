    headers = sheet_headers(ws, 1)
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        headers2 = sheet_headers(ws, 2)
        print("Row2 values:", headers2)
    # print first 10 rows and last 5 rows, bounded
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n+1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
        print(r, vals)
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column+1)]
            print(r, vals)
    # tables
    try:
        table_names = list(ws.tables.keys())
    except Exception:
        table_names = []
    print("Tables on sheet:", table_names)
    for tname in table_names:
        t = ws.tables[tname]
        print("  table", tname, "ref", t.ref)

# workbook defined names
print("\n=== DEFINED NAMES ===")
for dn in wb.defined_names.definedName:
    print("Defined name:", dn.name, "attr_text:", dn.attr_text)

# Search for referenced names in sheet titles, tables, headers, cell contents
terms = ["Emp", "emp", "Comp1-performance", "category", "subcategory", "variable", "lookup"]
matches = defaultdict(list)
for ws in wb.worksheets:
    if any(term.lower() in ws.title.lower() for term in terms):
        matches["sheet_title"].append(ws.title)
    for tname in getattr(ws, "tables", {}).keys():
        if any(term.lower() in tname.lower() for term in terms):
            matches["table_name"].append((ws.title, tname, ws.tables[tname].ref))
    for r in range(1, min(ws.max_row, 15)+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and any(term.lower() in v.lower() for term in terms):
                matches["cell_text"].append((ws.title, r, c, v))
print("\nSearch matches summary:")
for k, v in matches.items():
    print(k, v[:20], "count=", len(v))
