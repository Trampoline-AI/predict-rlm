import os, re, json
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]

print("Input spreadsheet:", input_spreadsheet)
print("Instruction:", instruction)
print("Original sheet names:", orig_sheetnames)

def row_vals(ws, r, max_cols=None):
    mc = ws.max_column if max_cols is None else min(ws.max_column, max_cols)
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

def nonempty_headers(ws, row=1):
    return [(get_column_letter(c), ws.cell(row, c).value) for c in range(1, ws.max_column + 1)]

all_tables = []
search_terms = ["Emp", "emp", "Comp1-performance", "category", "subcategory", "variable", "lookup", "performance"]

for ws in wb.worksheets:
    print(f"\n=== SHEET: {ws.title} ===")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    print("Row 1 headers/values:", nonempty_headers(ws, 1))
    if ws.max_row >= 2:
        print("Row 2 values:", row_vals(ws, 2))
    
    first_n = min(ws.max_row, 8)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_vals(ws, r))
    
    if ws.max_row > 8:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_vals(ws, r))
    
    table_names = list(ws.tables.keys())
    print("Tables on sheet:", table_names)
    for tname in table_names:
        t = ws.tables[tname]
        all_tables.append((ws.title, tname, t.ref))
        print("  Table:", tname, "ref:", t.ref)
        # print headers and a few rows from the table
        start_cell, end_cell = t.ref.split(":")
        from openpyxl.utils.cell import coordinate_from_string, column_index_from_string
        sc, sr = coordinate_from_string(start_cell)
        ec, er = coordinate_from_string(end_cell)
        sc_i = column_index_from_string(sc)
        ec_i = column_index_from_string(ec)
        print("  Table header row:", sr)
        print("  Table headers:", [(get_column_letter(c), ws.cell(sr, c).value) for c in range(sc_i, ec_i + 1)])
        for rr in range(sr + 1, min(er, sr + 5) + 1):
            print("  Row", rr, [ws.cell(rr, c).value for c in range(sc_i, ec_i + 1)])
        if er > sr + 5:
            print("  Last rows in table:")
            for rr in range(max(sr + 1, er - 4), er + 1):
                print("  Row", rr, [ws.cell(rr, c).value for c in range(sc_i, ec_i + 1)])

print("\n=== ALL TABLES SUMMARY ===")
print(all_tables)

print("\n=== DEFINED NAMES ===")
try:
    dn_items = list(wb.defined_names.items())
    print("Defined names count:", len(dn_items))
    for name, defn in dn_items:
        try:
            print("Defined name:", name, "->", defn)
        except Exception as e:
            print("Defined name:", name, "-> repr failed:", e)
except Exception as e:
    print("Could not inspect defined names:", repr(e))

print("\n=== SEARCH MATCHES (sheet/table/header/cell text) ===")
matches = defaultdict(list)
for ws in wb.worksheets:
    for term in search_terms:
        if term.lower() in ws.title.lower():
            matches["sheet_title"].append((term, ws.title))
    for tname in ws.tables.keys():
        for term in search_terms:
            if term.lower() in tname.lower():
                matches["table_name"].append((term, ws.title, tname, ws.tables[tname].ref))
    for c in range(1, ws.max_column + 1):
        v1 = ws.cell(1, c).value
        v2 = ws.cell(2, c).value if ws.max_row >= 2 else None
        for term in search_terms:
            if isinstance(v1, str) and term.lower() in v1.lower():
                matches["header_row1"].append((term, ws.title, get_column_letter(c), v1))
            if isinstance(v2, str) and term.lower() in v2.lower():
                matches["header_row2"].append((term, ws.title, get_column_letter(c), v2))
    # sample scan first 20 rows x all cols
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                for term in search_terms:
                    if term.lower() in v.lower():
                        matches["cell_text"].append((term, ws.title, r, get_column_letter(c), v))

for k, vals in matches.items():
    print(k, "count=", len(vals))
    for item in vals[:25]:
        print(" ", item)
