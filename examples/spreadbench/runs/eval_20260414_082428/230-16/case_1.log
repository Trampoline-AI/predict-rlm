import os, json, re, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input spreadsheet:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

inspection = {}
for ws in wb.worksheets:
    # determine a practical width for inspection
    max_cols = ws.max_column
    max_rows = ws.max_row
    headers = row_values(ws, 1, max_cols)
    inspection[ws.title] = {"rows": max_rows, "cols": max_cols, "headers": headers}
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Dimensions: rows={max_rows}, cols={max_cols}")
    print("Headers row 1:", headers)
    
    # first 10 rows
    first_n = min(10, max_rows)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, max_cols))
    
    # last 5 rows
    start_last = max(1, max_rows - 4)
    print("Last 5 rows:")
    for r in range(start_last, max_rows + 1):
        print(r, row_values(ws, r, max_cols))
    
    # inspect target columns A and B more closely
    print("Sample A/B values (rows 1-15):")
    for r in range(1, min(15, max_rows) + 1):
        print(r, ws.cell(r, 1).value, " | ", ws.cell(r, 2).value)

# Also identify non-empty rows in col A and B for the first sheet
