nonempty_ab = []
for r in range(1, ws0.max_row + 1):
    a = ws0.cell(r, 1).value
    b = ws0.cell(r, 2).value
    if a is not None or b is not None:
        nonempty_ab.append((r, a, b))
print("\nNon-empty A/B rows in first sheet (up to 30 shown):")
for item in nonempty_ab[:30]:
