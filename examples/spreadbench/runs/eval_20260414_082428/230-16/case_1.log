Code:
```repl
import os, shutil, re
from openpyxl import load_workbook

# Reload for detailed inspection
wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

before = wb["Before"]
after = wb["After"]

def used_rows(ws):
    rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            rows.append((r, vals))
    return rows

before_used = used_rows(before)
after_used = used_rows(after)

print("Before used rows:", before_used)
print("After used rows:", after_used)

# Print exact target area values and formulas if any
for ws_name, ws in [("Before", before), ("After", after)]:
    print(f"\nInspecting {ws_name} A1:B15")
    for r in range(1, min(15, ws.max_row) + 1):
        a = ws[f"A{r}"].value
        b = ws[f"B{r}"].value
        print(r, repr(a), repr(b), "formulas:", isinstance(a, str) and a.startswith("="), isinstance(b, str) and b.startswith("="))

# Infer transformation from Before based on first letter occurrence
pattern = re.compile(r'[A-Za-z]')
transformed = []
for r, vals in before_used:
    a = vals[0]
    b = vals[1] if len(vals) > 1 else None
    if r == 1:
        transformed.append((r, a, b, "header"))
        continue
    if isinstance(a, str):
        m = pattern.search(a)
        if m:
            idx = m.start()
            left = a[:idx]
            right = a[idx:]
            transformed.append((r, left, right, idx))
        else:
            transformed.append((r, a, None, None))
    else:
        transformed.append((r, a, None, None))

print("\nInferred transformation from Before:")
for item in transformed:
    print(item)

# Compare inferred result to After example structure (After starts at row 2)
comparison = []
for i, item in enumerate(transformed, start=0):
    r_before, left, right, info = item
    after_row = r_before + 1  # row1 blank in After, header at row2
    av = after.cell(after_row, 1).value
    bv = after.cell(after_row, 2).value
    comparison.append((r_before, left, right, av, bv, left == av and right == bv))
print("\nComparison to After:")
for row in comparison:
    print(row)

# Write output workbook by ensuring After sheet matches inferred transformation
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

out_wb = load_workbook(outfile)
out_before = out_wb["Before"]
out_after = out_wb["After"]

# Preserve existing structure; populate After sheet in same layout as the example.
# Row 1 intentionally blank, row 2 header, data from row 3 onward.
# Only write the relevant rows/cells.
out_after["A1"] = out_after["A1"].value
out_after["B1"] = out_after["B1"].value
out_after["A2"] = out_before["A1"].value
out_after["B2"] = out_before["B1"].value

for r, vals in before_used:
    if r == 1:
        continue
    src = vals[0]
    target_row = r + 1
    if isinstance(src, str):
        m = pattern.search(src)
        if m:
            idx = m.start()
            out_after.cell(target_row, 1).value = src[:idx]
            out_after.cell(target_row, 2).value = src[idx:]
        else:
            out_after.cell(target_row, 1).value = src
            out_after.cell(target_row, 2).value = None
    else:
        out_after.cell(target_row, 1).value = src
        out_after.cell(target_row, 2).value = None

out_wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
re_wb = load_workbook(outfile)
print("Sheet names after recalc:", re_wb.sheetnames)
orig_names = ["Before", "After"]
if re_wb.sheetnames != orig_names and len(re_wb.sheetnames) == len(orig_names):
    for ws, orig in zip(re_wb.worksheets, orig_names):
        ws.title = orig
    re_wb.save(outfile)
    print("Renamed sheets back to original names:", re_wb.sheetnames)

# Verify using data_only
verify_wb = load_workbook(outfile, data_only=True)
print("\nVerification - After sheet used rows:")
for r in range(1, 12):
    print(r, verify_wb["After"][f"A{r}"].value, "|", verify_wb["After"][f"B{r}"].value)

output_spreadsheet = outfile
print("\nPrepared output_spreadsheet:", output_spreadsheet)
