import os
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Find last meaningful source data row in A:D
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    if any(v not in (None, "") for v in vals):
        last_data_row = r
        break

print("Original sheet names:", orig_sheetnames)
print("Detected source data rows: 2 to", last_data_row)
print("Criteria cells:",
      "I3=", ws["I3"].value,
      "K3=", ws["K3"].value)
print("Name headers J5:N5:", [ws.cell(5, c).value for c in range(10, 15)])
print("Time bins H6:I24 sample:", [(ws[f"H{r}"].value, ws[f"I{r}"].value) for r in range(6, 10)])

# Write formulas to J6:N24
for r in range(6, 25):
    for c in range(10, 15):
        header_ref = f"{get_column_letter(c)}$5"
        formula = (
            f'=SUMPRODUCT(('
            f'$A$2:$A${last_data_row}=$K$3)*'
            f'($C$2:$C${last_data_row}={header_ref})*'
            f'($D$2:$D${last_data_row}=$I$3)*'
            f'(MOD($B$2:$B${last_data_row},1)>=$H{r})*'
            f'(MOD($B$2:$B${last_data_row},1)<$I{r})'
            f')'
        )
        ws.cell(r, c).value = formula

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    for idx, sname in enumerate(orig_sheetnames):
        wb_after.worksheets[idx].title = sname
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula[orig_sheetnames[0]]
wsv = wb_values[orig_sheetnames[0]]

print("\nSample formulas in target range:")
for coord in ["J6", "K6", "J22", "J23", "K23", "N24"]:
    print(coord, "=>", wsf[coord].value)

print("\nComputed values J6:N24:")
table_vals = []
for r in range(5, 25):
    row = []
    for c in range(8, 15):
        row.append(wsv.cell(r, c).value)
    table_vals.append(row)
    print(r, row)

# Python cross-check counts
from datetime import datetime, time

def tod_fraction(v):
    if v is None:
        return None
    if isinstance(v, datetime):
        return (v.hour*3600 + v.minute*60 + v.second + v.microsecond/1e6) / 86400.0
    if hasattr(v, "hour") and hasattr(v, "minute") and hasattr(v, "second"):
        return (v.hour*3600 + v.minute*60 + v.second + getattr(v, "microsecond", 0)/1e6) / 86400.0
    return None

dest_crit = ws["I3"].value
type_crit = ws["K3"].value
names = [ws.cell(5, c).value for c in range(10, 15)]

python_counts = {}
for r in range(6, 25):
    start = tod_fraction(ws[f"H{r}"].value)
    end = tod_fraction(ws[f"I{r}"].value)
    for idx, c in enumerate(range(10, 15)):
        nm = names[idx]
        count = 0
        for sr in range(2, last_data_row + 1):
            typ = ws.cell(sr, 1).value
            dt = ws.cell(sr, 2).value
            name = ws.cell(sr, 3).value
            dest = ws.cell(sr, 4).value
            tf = tod_fraction(dt)
            if typ == type_crit and name == nm and dest == dest_crit and tf is not None and start <= tf < end:
                count += 1
        python_counts[(r, c)] = count

print("\nPython cross-check for all target cells (coord, cached, expected):")
mismatches = []
for r in range(6, 25):
    row_report = []
    for c in range(10, 15):
        coord = f"{get_column_letter(c)}{r}"
        cached = wsv.cell(r, c).value
        expected = python_counts[(r, c)]
        row_report.append((coord, cached, expected))
        if cached != expected:
            mismatches.append((coord, cached, expected))
    print(row_report)

print("\nMismatch count:", len(mismatches))
if mismatches:
    print("Mismatches:", mismatches[:20])

output_spreadsheet = outfile
