import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def display(val):
    if val is None:
        return None
    s = str(val)
    return s if len(s) <= 80 else s[:77] + "..."

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect likely header row among first 5 rows by max non-empty count
    header_candidates = []
    for r in range(1, min(6, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        header_candidates.append((r, nonempty, vals))
    print("Header row candidates (row, nonempty_count):", [(r,n) for r,n,_ in header_candidates])
    header_row = max(header_candidates, key=lambda x: x[1])[0] if header_candidates else 1
    headers = [display(ws.cell(header_row, c).value) for c in range(1, ws.max_column + 1)]
    print(f"Chosen header row {header_row} headers:")
    print(headers)
    
    # first 10 rows
    first_n = min(10, ws.max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last {ws.max_row - start_last + 1} rows:")
    for r in range(start_last, ws.max_row + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    
    # list formulas
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, display(cell.value)))
    print("Formula cell count:", len(formula_cells))
    print("First up to 30 formula cells:", formula_cells[:30])
    
    # print merged ranges if any
    merged = list(ws.merged_cells.ranges)
    print("Merged ranges:", [str(m) for m in merged[:20]], "count=", len(merged))
