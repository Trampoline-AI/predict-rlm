import os
from openpyxl import load_workbook
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original workbook for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Working on sheet:", ws.title)
print("Target headers E4:AB4:", [ws.cell(4, c).value for c in range(5, 29)])
print("Existing row 5 E5:AB5 before:", [ws.cell(5, c).value for c in range(5, 29)])

# Row 5: display "-"
for c in range(5, 29):
    ws.cell(5, c).value = "-"

# Apply formulas to E6:AB25
# Logic:
# m = months difference between EOMONTH(maturity,0) and header month
# if m < 0 -> "-"
# if m = 0 -> principal + interest
# if MOD(m, 12/frequency)=0 -> interest
# else "-"
# Guard against blank/invalid inputs
for r in range(6, 26):
    row_inputs = [ws.cell(r, c).value for c in range(1, 5)]
    print(f"Row {r} inputs A:D:", row_inputs)
    for c in range(5, 29):
        col_letter = get_column_letter(c)
        formula = (
            f'=IF(OR($A{r}="",$B{r}="",$C{r}="",$D{r}=""),"",'
            f'IF(((YEAR(EOMONTH($D{r},0))-YEAR({col_letter}$4))*12+MONTH(EOMONTH($D{r},0))-MONTH({col_letter}$4))<0,"-",'
            f'IF(((YEAR(EOMONTH($D{r},0))-YEAR({col_letter}$4))*12+MONTH(EOMONTH($D{r},0))-MONTH({col_letter}$4))=0,$A{r}+$B{r},'
            f'IF(MOD(((YEAR(EOMONTH($D{r},0))-YEAR({col_letter}$4))*12+MONTH(EOMONTH($D{r},0))-MONTH({col_letter}$4)),12/$C{r})=0,$B{r},"-"))'
            f')'
        )
        ws.cell(r, c).value = formula
        # preserve number format by not changing it
        ws.cell(r, c).alignment = Alignment(horizontal="center", vertical="center")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names:
    # rename by position back to originals
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = orig_name
    wb_post.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with formulas
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula[orig_sheet_names[0]]

print("Row 5 E5:AB5 after write:", [wsf.cell(5, c).value for c in range(5, 29)])
print("Sample formulas:")
for coord in ["E6", "L6", "X6", "F13", "L13", "R13", "G17", "J17", "M17", "V17"]:
