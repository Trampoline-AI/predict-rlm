import os, re, json, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row1:", headers1)
    print("Row2:", headers2)
    
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # last 5 rows
    print("Last rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Search for interesting patterns
    pattern_hits = []
    exact_hits = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                if v == "55260:26":
                    exact_hits.append(cell.coordinate)
                if re.fullmatch(r"\d+:\d{2}", v.strip()):
                    pattern_hits.append((cell.coordinate, v))
            elif isinstance(v, (int, float)):
                # could be time serial with custom format; capture formatted-like columns by number format
                if cell.number_format and ("[h]" in str(cell.number_format).lower() or "mm" in str(cell.number_format).lower()):
                    pattern_hits.append((cell.coordinate, f"{v} | fmt={cell.number_format}"))
    print("Exact '55260:26' hits:", exact_hits[:20])
    print("Pattern hits sample:", pattern_hits[:20])
    
    # Show columns with headers / possible blank output columns
    col_info = []
    for c in range(1, ws.max_column + 1):
        header = ws.cell(1, c).value
        nonempty = sum(1 for r in range(1, ws.max_row + 1) if ws.cell(r, c).value not in (None, ""))
        sample = [ws.cell(r, c).value for r in range(1, min(ws.max_row, 6) + 1)]
        col_info.append((get_column_letter(c), header, nonempty, sample))
    print("Column summary:")
    for info in col_info:
        print(info)
