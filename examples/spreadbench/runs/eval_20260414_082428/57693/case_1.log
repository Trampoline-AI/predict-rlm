import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # Find actual non-empty bounds
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value is not None:
                row_has = True
                nonempty_cols.add(cell.column)
        if row_has:
            nonempty_rows.append(row[0].row)
    print("non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("first non-empty row:", min(nonempty_rows), "last non-empty row:", max(nonempty_rows))
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", headers)

    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print("\nFirst rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    # print last 5 rows if different
    start_last = max(1, ws.max_row - 4)
    if start_last <= ws.max_row:
        print("\nLast rows:")
        for r in range(start_last, ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}: {vals}")

    # print formulas and non-empty cells in a compact way
    print("\nNon-empty cells with formulas/values:")
    for r in range(1, ws.max_row + 1):
        row_items = []
        for c in range(1, ws.max_column + 1):
            cell = ws.cell(r, c)
            if cell.value is not None:
                v = cell.value
                if isinstance(v, str) and v.startswith("="):
                    row_items.append(f"{get_column_letter(c)}{r}={v}")
                else:
                    row_items.append(f"{get_column_letter(c)}{r}={v}")
        if row_items:
            print(" | ".join(row_items))

for ws in wb.worksheets:
    sheet_summary(ws)
