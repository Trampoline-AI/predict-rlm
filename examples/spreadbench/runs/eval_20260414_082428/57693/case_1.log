for coord in ["D5"] + [f"D{r}" for r in range(7,33)] + [f"E{r}" for r in range(7,33)]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format, "style=", cell.style_id)

print("\nFocused area D5:E32")
for r in range(5, 33):
    print(r, ws[f"D{r}"].value, ws[f"E{r}"].value)

# Fill only blank target cells in E7:E32 with formula counting occurrences of letter in D row within D5 text
