import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    
    # find likely header row among first 5 rows: the one with most non-empty stringish values
    best_row = 1
    best_score = -1
    for r in range(1, min(6, ws.max_row)+1):
        vals = row_values(ws, r, min(ws.max_column, 20))
        score = sum(1 for v in vals if v not in (None, ""))
        if score > best_score:
            best_score = score
            best_row = r
    print("Likely header row:", best_row)
    headers = row_values(ws, best_row, ws.max_column)
    print("Headers:", headers)
    
    top_end = min(ws.max_row, max(best_row+9, 10))
    print("Top sample rows:")
    for r in range(1, top_end+1):
        print(r, row_values(ws, r, min(ws.max_column, 15)))
    
    print("Bottom sample rows:")
    start = max(1, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        print(r, row_values(ws, r, min(ws.max_column, 15)))
    
    # print cells containing formulas in first 15x20 block
    formulas = []
    for r in range(1, min(ws.max_row, 20)+1):
        for c in range(1, min(ws.max_column, 15)+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first block:", formulas[:50])

    # merged cells info
    merged = list(ws.merged_cells.ranges)
    print("Merged ranges count:", len(merged), "sample:", merged[:10])
