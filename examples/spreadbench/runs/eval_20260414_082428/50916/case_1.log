import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Reload original workbook for modification
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Target sheet:", ws.title)
print("Target formulas area before change:")
for r in [12, 13, 14]:
    vals = [(f"{get_column_letter(c)}{r}", ws.cell(r, c).value) for c in range(2, 9)]
    print(vals)

# Identify rows to populate: date in A and numeric cycle day 1..7 in B
target_rows = []
for r in range(12, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is not None and isinstance(b, int) and 1 <= b <= 7:
        target_rows.append(r)

print("Number of target rows:", len(target_rows))
print("First 15 target rows:", target_rows[:15])
print("Last 10 target rows:", target_rows[-10:])

# Write formulas into C:H for all target rows
# C=2nd column in lookup table, D=3rd, ..., H=7th
for r in target_rows:
    for c in range(3, 9):  # C:H
        lookup_index = c - 1  # C->2, D->3, ... H->7 within B:H table
        formula = f'=IFERROR(VLOOKUP($B{r},$B$2:$H$8,{lookup_index},FALSE),"")'
        ws.cell(r, c).value = formula

# Save initial output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload to inspect sheet names after recalc
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)

# Restore original sheet names if changed
if wb_after.sheetnames != orig_sheet_names:
    if len(wb_after.sheetnames) == len(orig_sheet_names):
        for old, new in zip(wb_after.sheetnames, orig_sheet_names):
            wb_after[old].title = new
        wb_after.save(outfile)
        print("Restored sheet names to:", orig_sheet_names)
    else:
        print("Warning: sheet count changed unexpectedly")

# Verification with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

# Print target cells/ranges mentioned in instruction and nearby cells
print("\nVerification rows 12:20 cols B:H (data_only):")
for r in range(12, 21):
    vals = [(f"{get_column_letter(c)}{r}", wsv.cell(r, c).value) for c in range(2, 9)]
    print(vals)

# Verify specific problem cells
specific_cells = ["C12", "E12", "F12", "G12", "H12", "D13", "D14"]
print("\nSpecific target cells after recalculation:")
for addr in specific_cells:
    print(addr, "->", wsv[addr].value)

# Sanity-check a few later numeric rows and special rows
check_rows = [17, 18, 19, 20, 21, 297, 298, 299, 300, 301]
print("\nSanity check selected rows:")
for r in check_rows:
    vals = [wsv.cell(r, c).value for c in range(1, 9)]
    print(r, vals)

# Also inspect formulas directly to ensure they are in the exact target cells
