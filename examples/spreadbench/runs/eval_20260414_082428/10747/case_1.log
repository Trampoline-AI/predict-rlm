wb_src = load_workbook(infile, data_only=True)
wss = wb_src[orig_sheetnames[0]]
for r in range(3, 9):
    source_rows.append({
        "row": r,
        "year": wss[f"A{r}"].value,
        "share": wss[f"B{r}"].value,
        "net_profit": wss[f"C{r}"].value
    })
print("Source rows A3:C8:", source_rows)
