import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_nonempty_bounds(ws):
    max_row, max_col = ws.max_row, ws.max_column
    # find last non-empty row/col more robustly
    last_row = 0
    last_col = 0
    for r in range(1, max_row + 1):
        row_has = False
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if v is not None and v != "":
                row_has = True
                last_col = max(last_col, c)
        if row_has:
            last_row = r
    return last_row, last_col

for sname in wb.sheetnames:
    ws = wb[sname]
    last_row, last_col = sheet_nonempty_bounds(ws)
    print(f"\n=== Sheet: {sname} ===")
    print("ws.max_row/max_column:", ws.max_row, ws.max_column, "nonempty bounds:", last_row, last_col)
    headers = [ws.cell(1, c).value for c in range(1, min(last_col, 15) + 1)]
    print("Row 1 headers/sample:", headers)
    if last_row >= 2:
        for r in range(1, min(last_row, 10) + 1):
            vals = [ws.cell(r, c).value for c in range(1, min(last_col, 12) + 1)]
            print(f"Row {r}:", vals)
        if last_row > 10:
            print("... last rows ...")
            for r in range(max(1, last_row - 4), last_row + 1):
                vals = [ws.cell(r, c).value for c in range(1, min(last_col, 12) + 1)]
                print(f"Row {r}:", vals)

    # print relevant cells/ranges from instruction
    for coord in ["A3","A8","B3","B8","C3","I3","J3","K3","L3"]:
        print(f"{coord} =", ws[coord].value)

    # inspect formulas in used range around A1:L12
    print("Formulas in A1:L12:")
    for r in range(1, min(last_row, 12) + 1):
        row_formulas = []
        for c in range(1, min(last_col, 12) + 1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                row_formulas.append(f"{get_column_letter(c)}{r}={v}")
        if row_formulas:
            print(" ", "; ".join(row_formulas))
