import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Before change, K6:", ws["K6"].value)
print("Reference values: I3 =", ws["I3"].value, "J3 =", ws["J3"].value)
print("Existing example outputs: K3 =", ws["K3"].value, "K4 =", ws["K4"].value)

# Correct formula
ws["K6"] = "=SUMIFS($C$3:$C$8,$A$3:$A$8,$I$3,$B$3:$B$8,$J$3)"
print("After change, K6 formula:", ws["K6"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and fix any sheet-name drift
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # Rename sheets back by position
    for i, sname in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = sname
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and calculated values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("Verified stored formula K6:", wsf["K6"].value)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[orig_sheetnames[0]]
for coord in ["I3", "J3", "K3", "K4", "K6", "L3", "L4"]:
    print(f"Value {coord} =", wsv[coord].value)

# Basic sanity check from source table
