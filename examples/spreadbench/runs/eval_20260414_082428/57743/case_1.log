from openpyxl import load_workbook
import os

# Verify actual matching logic from source data
wb_chk = load_workbook(output_spreadsheet, data_only=False)
wsf = wb_chk["Sheet1"]

# Build lookup map from C:D
lookup = {}
for r in range(2, wsf.max_row + 1):
    key = wsf[f"C{r}"].value
    val = wsf[f"D{r}"].value
    if key not in (None, ""):
        lookup[str(key).strip()] = val

print("Lookup entries:", len(lookup))

match_summary = []
for r in range(2, wsf.max_row + 1):
    a = wsf[f"A{r}"].value
    expected = lookup.get(str(a).strip()) if a not in (None, "") else None
    formula = wsf[f"B{r}"].value
    match_summary.append((r, a, expected, formula))

print("Rows with expected matches:")
for item in match_summary:
    if item[2] is not None:
        print(item)

print("Rows without expected matches (first 10 shown):")
count_no = 0
for item in match_summary:
    if item[2] is None:
        print(item[:3])
        count_no += 1
        if count_no >= 10:
            break

# Verify cached computed values
wb_vals = load_workbook(output_spreadsheet, data_only=True)
wsv = wb_vals["Sheet1"]

print("\nFinal verification B2:B19:")
for r in range(2, wsv.max_row + 1):
    a = wsv[f"A{r}"].value
    b = wsv[f"B{r}"].value
    expected = lookup.get(str(a).strip()) if a not in (None, "") else None
    print((r, a, b, expected))

print("\nFile exists:", os.path.exists(output_spreadsheet), output_spreadsheet)
