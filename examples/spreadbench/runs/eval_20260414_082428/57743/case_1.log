import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload for detailed inspection
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Inspecting target area A:D and especially column B formulas")
for r in range(1, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    d = ws[f"D{r}"].value
    b_repr = b
    if hasattr(b, "text"):
        b_repr = f"ArrayFormula(text={b.text!r}, ref={getattr(b, 'ref', None)!r})"
    print(r, {"A": a, "B": b_repr, "C": c, "D": d})

# Determine data extent for actual lookup lists
last_row_A = max(r for r in range(1, ws.max_row + 1) if ws[f"A{r}"].value not in (None, ""))
last_row_C = max(r for r in range(1, ws.max_row + 1) if ws[f"C{r}"].value not in (None, ""))
print("last_row_A:", last_row_A, "last_row_C:", last_row_C)

# Build explicit formulas for column B for rows with model numbers in A
# Use IFERROR to leave blank if not found, and bounded ranges for compatibility/performance.
for r in range(2, last_row_A + 1):
    if ws[f"A{r}"].value not in (None, ""):
        formula = f'=IFERROR(INDEX($D$2:$D${last_row_C},MATCH(A{r},$C$2:$C${last_row_C},0)),"")'
        ws[f"B{r}"] = formula

# Save to output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet name if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename by position to match originals
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig_name
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formulas in normal mode
wb_verify_formula = load_workbook(out_path, data_only=False)
wsf = wb_verify_formula["Sheet1"]
print("\nVerified formulas in B2:B19:")
for r in range(2, last_row_A + 1):
    print(r, wsf[f"A{r}"].value, "=>", wsf[f"B{r}"].value)

# Verify computed values in data_only mode
wb_verify_values = load_workbook(out_path, data_only=True)
wsv = wb_verify_values["Sheet1"]
print("\nComputed values in B2:B19:")
for r in range(2, last_row_A + 1):
    print(r, {"A": wsv[f"A{r}"].value, "B": wsv[f"B{r}"].value, "C": wsv[f"C{r}"].value, "D": wsv[f"D{r}"].value})

output_spreadsheet = out_path
