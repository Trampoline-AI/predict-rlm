from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["3 straights to 3 boxed"]

# Determine true used rows based on cols A:E
used_rows = []
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    if any(v is not None for v in vals):
        used_rows.append(r)

print("Used rows on target sheet:", used_rows)
print("Last used row:", max(used_rows))

# Inspect target range G with source columns B:D and borders
for r in range(1, max(used_rows) + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, 8)]
    g = ws.cell(r, 7)
    b = g.border
    has_border = any([b.left.style, b.right.style, b.top.style, b.bottom.style])
    fill = g.fill
    fg = getattr(fill.fgColor, "rgb", None)
    print(f"Row {r}: A:G={row_vals} | G border={has_border} bold={g.font.bold} fill_type={fill.fill_type} fg={fg}")

# Compute expected boxed values for rows with source digits
expected = {}
for r in range(2, max(used_rows) + 1):
    digits = [ws.cell(r, c).value for c in [2,3,4]]
    if all(isinstance(x, int) for x in digits):
        s = "".join(str(x) for x in sorted(digits))
        expected[r] = s

print("Expected values:", expected)

# Apply updates only on bordered/result rows in G corresponding to actual data rows
target_rows = [r for r in range(2, max(used_rows) + 1) if any(ws.cell(r, c).value is not None for c in range(1, 6))]
print("Target rows:", target_rows)

fill = PatternFill(fill_type="solid", start_color="EBF1DE", end_color="EBF1DE")
bold_font = Font(name=ws["G2"].font.name, sz=ws["G2"].font.sz, b=True, i=ws["G2"].font.i,
                 underline=ws["G2"].font.u, strike=ws["G2"].font.strike,
                 color=ws["G2"].font.color.type and ws["G2"].font.color.rgb if ws["G2"].font.color and ws["G2"].font.color.type == "rgb" else None)

changes = []
for r in target_rows:
    g = ws.cell(r, 7)
    new_val = expected.get(r)
    old_val = g.value
    if new_val is not None:
        # preserve already-correct value or overwrite blanks/incorrect values with correct string
        if old_val != new_val:
            g.value = new_val
            changes.append((r, old_val, new_val))
        # apply requested formatting to all boxed values in target column
        g.fill = fill
        g.font = g.font.copy(bold=True)

print("Value changes:", changes)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(out_path)
print("Output sheet names after recalc:", wb2.sheetnames)
orig_names = wb.sheetnames
if wb2.sheetnames != orig_names:
    # rename back by position
    for i, orig in enumerate(orig_names):
        wb2.worksheets[i].title = orig
    wb2.save(out_path)
    print("Renamed sheets back to original:", orig_names)

# Verify results with data_only and formatting with normal load
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["3 straights to 3 boxed"]
print("Verified G2:G16 values after recalc:")
for r in target_rows:
    print(r, wsv.cell(r, 7).value)

wb_fmt = load_workbook(out_path)
wsf = wb_fmt["3 straights to 3 boxed"]
print("Verified formatting G2:G16:")
for r in target_rows:
    g = wsf.cell(r, 7)
    print(r, g.value, g.font.bold, g.fill.fill_type, getattr(g.fill.fgColor, "rgb", None))
