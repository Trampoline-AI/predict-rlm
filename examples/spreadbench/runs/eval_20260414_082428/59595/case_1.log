from datetime import datetime, timedelta

ws = wb["Sheet1"]

print("Inspect C4:C19 existing values and data types:")
for r in range(4, ws.max_row + 1):
    c = ws[f"C{r}"]
    print(r, "A=", ws[f"A{r}"].value, "B=", ws[f"B{r}"].value, "C=", c.value, "data_type=", c.data_type)

# Compute expected rolling sums in Python for validation
computed = {}
for r in range(4, ws.max_row + 1):
    cur_date = ws.cell(r, 1).value
    if isinstance(cur_date, datetime):
        start_date = cur_date - timedelta(days=7)
        s = 0
        for rr in range(4, ws.max_row + 1):
            d = ws.cell(rr, 1).value
            if isinstance(d, datetime) and start_date <= d <= cur_date:
                pts = ws.cell(rr, 2).value
                if isinstance(pts, (int, float)):
                    s += pts
        computed[r] = s

print("\nComputed rolling 7-day sums (Python):")
for r in range(4, ws.max_row + 1):
    print(f"Row {r}: expected {computed.get(r)} ; existing C{r}={ws[f'C{r}'].value}")
