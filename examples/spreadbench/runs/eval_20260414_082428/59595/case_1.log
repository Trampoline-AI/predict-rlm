import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Detect likely header row(s): print first 3 rows
    for r in range(1, min(ws.max_row, 3) + 1):
        print(f"Row {r}:", row_values(ws, r, ws.max_column))
    
    headers = row_values(ws, 1, ws.max_column)
    print("Assumed headers (row 1):", headers)
    
    # First 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Last 5 rows
    print("Last rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Print columns A:C specifically, with formulas if present
    print("Column A:C detailed preview:")
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = []
        for c in range(1, min(3, ws.max_column) + 1):
            cell = ws.cell(r, c)
            vals.append((f"{get_column_letter(c)}{r}", cell.value))
        print(vals)
