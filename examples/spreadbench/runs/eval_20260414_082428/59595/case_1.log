import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload workbook for writing
wb2 = load_workbook(input_path)
original_sheet_names = wb2.sheetnames[:]
ws = wb2["Sheet1"]

data_start = 4
data_end = ws.max_row

# Print exact target cells before modification
print("Target cells before writing:")
for r in range(data_start, data_end + 1):
    print(f"C{r} =", ws[f"C{r}"].value)

# Fill only blank cells in column C, preserving existing example values
written = []
for r in range(data_start, data_end + 1):
    target = ws.cell(r, 3)
    if target.value in (None, ""):
        # Inclusive rolling 7-day total: dates between A[r]-7 and A[r]
        formula = f'=SUMIFS($B${data_start}:$B${data_end},$A${data_start}:$A${data_end},">="&A{r}-7,$A${data_start}:$A${data_end},"<="&A{r})'
        target.value = formula
        written.append((r, formula))

print("\nFormulas written:")
for item in written:
    print(item)

wb2.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check for sheet-name drift after recalculation and restore if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # Rename sheets back by position
    for i, name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)
else:
    print("Sheet names unchanged.")

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["Sheet1"]

print("\nVerified target values after recalculation:")
for r in range(4, data_end + 1):
    print(f"A{r}={wsv[f'A{r}'].value}, B{r}={wsv[f'B{r}'].value}, C{r}={wsv[f'C{r}'].value}")

# Also inspect formula strings in the written cells
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nFormula strings in written cells:")
for r, _ in written:
    print(f"C{r} formula:", wsf[f"C{r}"].value)
```
