wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Find likely header row among first 5 rows by non-empty count
    for r in range(1, min(6, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v is not None and v != "" for v in vals)
        print(f"Row {r} nonempty={nonempty}:", vals[:min(10, ws.max_column)])
    
    # Print column letters and first row values as headers view
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers by column:", [(get_column_letter(c), headers[c-1]) for c in range(1, ws.max_column + 1)])
    
    # Print first 10 rows and last 5 rows, first up to 6 columns
    max_show_cols = min(6, ws.max_column)
    print("\nFirst rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, [ws.cell(r, c).value for c in range(1, max_show_cols + 1)])
    
    print("\nLast rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
