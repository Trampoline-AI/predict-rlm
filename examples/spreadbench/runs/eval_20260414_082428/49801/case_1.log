import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before change:")
print("A1 =", ws["A1"].value)
print("B1 =", ws["B1"].value)
print("C1 =", ws["C1"].value)

# Write the concatenated formula into the existing target cell C1
ws["C1"] = '=LEFT(A1,2)&RIGHT(A1,5)'

print("After change, C1 formula =", ws["C1"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc; fix any sheet-name changes if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for i, expected in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formula exists in normal workbook
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Verified formula in C1:", ws_formula["C1"].value)

# Verify cached result in data_only workbook
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("Verified cached values:")
print("A1 =", ws_values["A1"].value)
print("B1 =", ws_values["B1"].value)
print("C1 =", ws_values["C1"].value)

output_spreadsheet = outfile
