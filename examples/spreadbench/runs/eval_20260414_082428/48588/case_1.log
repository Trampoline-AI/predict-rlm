```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Target header cells:", ws["A1"].value, "|", ws["B1"].value)
print("Pre-write target range preview:")
for r in range(19, 44):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

# Write formulas only into blank target cells in B19:B43
written = []
for r in range(19, ws.max_row + 1):
    a_val = ws[f"A{r}"].value
    b_val = ws[f"B{r}"].value
    if a_val not in (None, "") and b_val in (None, ""):
        formula = (
            f'=IF(COUNTIF($A$2:A{r-1},A{r})>0,'
            f'INDEX($B$2:B{r-1},MATCH(A{r},$A$2:A{r-1},0)),'
            f'MAX($B$2:B{r-1})+1)'
        )
        ws[f"B{r}"] = formula
        written.append((r, formula))

print("Formulas written:")
for item in written[:10]:
    print(item)
print("Total formulas written:", len(written))
print("Example formula in B19:", ws["B19"].value)
print("Example formula in B24:", ws["B24"].value)
print("Example formula in B36:", ws["B36"].value)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename by position to restore original names
    for i, orig_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names:", original_sheet_names)

# Verify formulas and evaluated values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("Verification of target cells B19:B43:")
verification = []
for r in range(19, 44):
    product = ws_values[f"A{r}"].value
    formula = ws_formula[f"B{r}"].value
    value = ws_values[f"B{r}"].value
    verification.append((r, product, formula, value))
    print(r, product, value)

# Sanity check against expected mapping inferred from first appearances
expected_map = {}
next_id = 1
for r in range(2, ws_values.max_row + 1):
    prod = ws_values[f"A{r}"].value
    if prod not in expected_map:
        expected_map[prod] = next_id
        next_id += 1

mismatches = []
blanks = []
for r in range(19, 44):
    prod = ws_values[f"A{r}"].value
    val = ws_values[f"B{r}"].value
    exp = expected_map.get(prod)
    if val in (None, ""):
        blanks.append(r)
    elif val != exp:
        mismatches.append((r, prod, val, exp))

print("Blank target cells after recalc:", blanks)
print("Mismatches vs expected:", mismatches)
print("Final sheet names:", load_workbook(output_path).sheetnames)

final_output_spreadsheet = output_path
```
