import os
from openpyxl import load_workbook

# Load original workbook
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Double-check target/source ranges before writing
print("Target cell D2 before write:", ws["D2"].value)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Source PRODUCT IDs:", [ws.cell(r, 1).value for r in range(2, ws.max_row + 1)])
print("Source QTYs:", [ws.cell(r, 2).value for r in range(2, ws.max_row + 1)])

# Write formula
ws["D2"] = "=SUMIF(A2:A12,111111,B2:B12)"
print("Formula written to D2:", ws["D2"].value)

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(out_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with formulas visible
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("D2 formula after save:", ws_formula["D2"].value)

# Verify with cached/calculated values
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]
print("D2 calculated value:", ws_values["D2"].value)

# Additional sanity check from source data
manual_sum = sum(
    ws_values.cell(r, 2).value
    for r in range(2, ws_values.max_row + 1)
    if ws_values.cell(r, 1).value == 111111
)
print("Manual sum for PRODUCT ID 111111:", manual_sum)

output_spreadsheet = out_path
```
