import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

workbook_summary = {}
for ws in wb.worksheets:
    max_row, max_col = ws.max_row, ws.max_column
    headers1 = row_values(ws, 1, max_col)
    headers2 = row_values(ws, 2, max_col) if max_row >= 2 else []
    workbook_summary[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers_row1": headers1,
        "headers_row2": headers2,
    }
    print("\n=== Sheet:", ws.title, "===")
    print("Size:", max_row, "rows x", max_col, "cols")
    print("Row 1:", headers1)
    if max_row >= 2:
        print("Row 2:", headers2)
    # first 10 rows
    first_n = min(10, max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, max_col))
    # last 5 rows
    start_last = max(1, max_row - 4)
    print("Last rows:")
    for r in range(start_last, max_row + 1):
        print(r, row_values(ws, r, max_col))

    # print column letters + row1 values for orientation
    print("Columns overview:")
    for c in range(1, max_col + 1):
        print(f"{get_column_letter(c)}: row1={ws.cell(1,c).value!r}, row2={ws.cell(2,c).value!r if max_row>=2 else None}")

    # scan top 5 rows for date-like values
    print("Date-like cells in first 5 rows:")
    found = []
    for r in range(1, min(5, max_row)+1):
        for c in range(1, max_col+1):
            v = ws.cell(r,c).value
            if v is None:
                continue
            s = str(v)
            if hasattr(v, 'year') or any(tok in s.lower() for tok in ['202', 'jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec', '/']):
                found.append((f"{get_column_letter(c)}{r}", v))
    print(found[:50])

print("\nWorkbook summary keys:", workbook_summary.keys())
