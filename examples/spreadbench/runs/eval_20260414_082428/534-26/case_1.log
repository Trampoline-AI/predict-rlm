import os
from shutil import copyfile
from datetime import datetime, date
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
ws = wb["Sheet1"]
rws = wb["Result"]

sheet1_headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
result_headers = [rws.cell(1, c).value for c in range(1, rws.max_column + 1)]

print("Sheet1 header count:", len(sheet1_headers))
print("Result header count:", len(result_headers))
print("Sheet1 first 12 headers:", sheet1_headers[:12])
print("Result first 12 headers:", result_headers[:12])

# Find exact columns to keep/delete by matching Result's header row
result_set = list(result_headers)
cols_to_keep = []
cols_to_delete = []
for c, v in enumerate(sheet1_headers, start=1):
    if v in result_set:
        cols_to_keep.append(c)
    else:
        cols_to_delete.append(c)

print("Columns to keep in Sheet1:", [(c, get_column_letter(c), sheet1_headers[c-1]) for c in cols_to_keep])
print("Columns to delete in Sheet1:", [(c, get_column_letter(c), sheet1_headers[c-1]) for c in cols_to_delete])

# verify deleting these produces exactly Result headers
simulated_headers = [sheet1_headers[c-1] for c in cols_to_keep]
print("Simulated matches Result:", simulated_headers == result_headers)

# Check exact target range before modification
print("Current target deletion range values:")
for c in cols_to_delete:
    print(f"{get_column_letter(c)}1 = {ws.cell(1,c).value!r}")

# Apply deletion right-to-left only on Sheet1
for c in sorted(cols_to_delete, reverse=True):
    ws.delete_cols(c, 1)

print("After deletion, Sheet1 max_column:", ws.max_column)
new_headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Sheet1 headers after deletion:", new_headers)
print("Now matches Result:", new_headers == result_headers)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_status = await recalculate(output_path)
print("Recalculate status:", recalc_status)

# Reload and restore sheet names if needed
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename sheets positionally back to original names
    for ws2, orig_name in zip(wb2.worksheets, orig_sheet_names):
        ws2.title = orig_name
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with formulas/data_only not really needed here, but do it per instructions
verify_wb = load_workbook(output_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)

vws = verify_wb["Sheet1"]
vrws = verify_wb["Result"]

v_sheet1_headers = [vws.cell(1, c).value for c in range(1, vws.max_column + 1)]
v_result_headers = [vrws.cell(1, c).value for c in range(1, vrws.max_column + 1)]

print("Verified Sheet1 column count:", vws.max_column)
print("Verified Result column count:", vrws.max_column)
print("Verified Sheet1 headers:", v_sheet1_headers)
print("Verified Result headers:", v_result_headers)
print("Verification match:", v_sheet1_headers == v_result_headers)

# Store path for submission
final_output_path = output_path
