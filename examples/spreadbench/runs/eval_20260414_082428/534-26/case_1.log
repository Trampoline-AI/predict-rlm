import os
from datetime import datetime, date
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def show_sheet(ws, sample_rows=10):
    print(f"\n--- {ws.title} ---")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    for r in range(1, min(sample_rows, ws.max_row) + 1):
        print("Row", r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print("Row", r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

for ws in wb.worksheets:
    show_sheet(ws, sample_rows=10)

# Identify date columns in Sheet1 exactly
ws = wb["Sheet1"]
today = date.today()
current_month_start = date(today.year, today.month, 1)
print("\nToday:", today)
print("Current month start:", current_month_start)

candidate_cols = []
for c in range(1, ws.max_column + 1):
    v = ws.cell(1, c).value
    if isinstance(v, datetime):
        header_date = v.date()
    elif isinstance(v, date):
        header_date = v
    else:
        header_date = None
    if header_date is not None:
        candidate_cols.append((c, get_column_letter(c), header_date, header_date < current_month_start))

print("\nDate-header columns in Sheet1:")
for item in candidate_cols:
    print(item)

cols_to_delete = [c for c, col_letter, d, should_delete in candidate_cols if should_delete]
print("\nColumns to delete in Sheet1:", cols_to_delete)
print("Column letters to delete in Sheet1:", [get_column_letter(c) for c in cols_to_delete])

# Show the remaining non-date and boundary columns for orientation
print("\nBoundary cells around deletion area:")
for c in range(max(1, min(cols_to_delete + [ws.max_column]) - 2), ws.max_column + 1):
    print(c, get_column_letter(c), ws.cell(1, c).value)

# Inspect Result sheet for example answer / pattern
if "Result" in wb.sheetnames:
    rws = wb["Result"]
    print("\nResult sheet detailed cell map:")
    for r in range(1, rws.max_row + 1):
        vals = []
        for c in range(1, rws.max_column + 1):
            vals.append(f"{get_column_letter(c)}{r}={rws.cell(r,c).value!r}")
        print(" | ".join(vals))
