import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print existing target area before modification
print("Before modification:")
for r in range(7, 11):
    print(f"A{r}={ws[f'A{r}'].value!r}, B{r}={ws[f'B{r}'].value!r}")

# Write corrected formula to the exact target cells
for r in range(7, 11):
    ws[f"B{r}"] = f"=SUM(INDEX($B$3:$Z$5,0,MATCH(A{r},$B$2:$Z$2,0)))"

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload after recalculation, restore sheet names if needed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring to", orig_sheet_names)
    # rename by position
    for i, sname in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = sname
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify formulas
ws_formula = wb_check["Sheet1"]
print("Formulas written:")
for r in range(7, 11):
    print(f"B{r} formula:", ws_formula[f"B{r}"].value)

# Verify calculated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]
print("Calculated values after recalc:")
for r in range(7, 11):
    print(f"A{r}={ws_values[f'A{r}'].value!r}, B{r}={ws_values[f'B{r}'].value!r}")

output_spreadsheet = outfile
