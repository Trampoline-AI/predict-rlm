import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # find a likely header row among first 5 rows: the one with most non-empty values
    best_row = 1
    best_count = -1
    for r in range(1, min(5, ws.max_row)+1):
        vals = row_values(ws, r)
        count = sum(v is not None and v != "" for v in vals)
        if count > best_count:
            best_count = count
            best_row = r
    print("Likely header row:", best_row)
    headers = row_values(ws, best_row)
    print("Headers:", headers)
    
    # first 10 rows
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r))
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r))
    
    # scan formulas
    formula_hits = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                f = cell.value
                if ("INDEX" in f.upper()) or ("MATCH" in f.upper()) or ("SUM(" in f.upper()):
                    formula_hits.append((cell.coordinate, f))
    print("Formula hits count:", len(formula_hits))
    for hit in formula_hits[:20]:
        print("Formula:", hit)

# Also search specifically for exact text fragments
search_terms = ["=SUM(INDEX(B3:B5,0,MATCH(A7,$B$2:$Z$2,0)))", "MATCH(A7", "INDEX(B3:B5", "B3:B5", "$B$2:$Z$2"]
for term in search_terms:
    found = []
    for ws in wb.worksheets:
        for row in ws.iter_rows():
            for cell in row:
                v = cell.value
                if isinstance(v, str) and term in v:
                    found.append((ws.title, cell.coordinate, v))
    print(f"\nSearch term {term!r}: {len(found)} hits")
    for item in found[:20]:
        print(item)
