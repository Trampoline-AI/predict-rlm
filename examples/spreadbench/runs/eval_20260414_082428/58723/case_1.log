        print(r, row_vals)

    # Find non-empty green-filled cells or colored cells
    colored = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            cell = ws.cell(r, c)
            info = cell_fill_info(cell)
            if info and cell.value is not None:
                colored.append((cell.coordinate, cell.value, info))
    print("Colored non-empty cells sample/count:", len(colored))
