def cell_fill_info(cell):
    fill = cell.fill
    if fill and fill.fill_type:
        return {
            "fill_type": fill.fill_type,
            "start": fill.start_color.rgb or fill.start_color.indexed or fill.start_color.type,
            "end": fill.end_color.rgb or fill.end_color.indexed or fill.end_color.type,
        }
    return None

