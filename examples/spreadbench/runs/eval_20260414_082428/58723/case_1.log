import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheet names:", orig_sheetnames)
print("Target header M1:", ws["M1"].value)
print("Existing sample formulas/values in M2:M10:", [ws[f"M{r}"].value for r in range(2, 11)])

# Write formulas only into blank cells in column M
written = []
for r in range(2, ws.max_row + 1):
    cell = ws[f"M{r}"]
    if cell.value in (None, ""):
        # Compare this row's I value with max I among rows having same C value.
        # Blank-safe wrapper included.
        formula = f'=IF(OR(C{r}="",I{r}=""),"",IF(I{r}=MAXIFS($I$2:$I$41,$C$2:$C$41,C{r}),"Latest","Not Latest"))'
        cell.value = formula
        written.append((r, formula))

print("Rows written:", [r for r, _ in written])
print("First written formulas:", written[:5])

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename by position to original names
    for idx, orig_name in enumerate(orig_sheetnames):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with formulas view
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula[orig_sheetnames[0]]
print("Formula in M22:", wsf["M22"].value)
print("Formula in M41:", wsf["M41"].value)

# Verify computed results
wb_verify = load_workbook(outfile, data_only=True)
print("Sheet names final:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheetnames[0]]

targets = list(range(22, 42))
vals = {f"M{r}": wsv[f"M{r}"].value for r in targets}
print("Verified target values M22:M41:")
for k, v in vals.items():
    print(k, repr(v))

# Sanity checks
blank_targets = [k for k, v in vals.items() if v in (None, "")]
print("Blank target cells after recalc:", blank_targets)

# Also print a compact row verification for output rows
print("Row verification (C, I, M) for rows 22:41")
for r in range(22, 42):
    print(r, {"C": wsv[f"C{r}"].value, "I": wsv[f"I{r}"].value, "M": wsv[f"M{r}"].value})

output_spreadsheet = outfile
