    # print first 10 rows x all used columns (or up to 15 if very wide)
    rows_to_show_top = list(range(1, min(ws.max_row, 10) + 1))
    rows_to_show_bottom = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    shown = []
    print("Top rows:")
    for r in rows_to_show_top:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        shown.append((r, vals))
        print(r, vals)
    print("Bottom rows:")
