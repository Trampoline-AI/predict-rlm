import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

sheet_summaries = {}
quote_cells = []

for ws in wb.worksheets:
    max_row, max_col = ws.max_row, ws.max_column
    headers = row_values(ws, 1, max_col)
    sheet_summaries[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers": headers,
    }
    print(f"\n--- Sheet: {ws.title} ---")
    print("Rows:", max_row, "Cols:", max_col)
    print("Headers row 1:", headers)

    first_rows = list(range(1, min(max_row, 10) + 1))
    last_start = max(1, max_row - 4)
    last_rows = list(range(last_start, max_row + 1))
    print("First rows sample:")
    for r in first_rows:
        print(f"Row {r}:", row_values(ws, r, max_col))
    if last_rows[0] > first_rows[-1]:
        print("Last rows sample:")
        for r in last_rows:
            print(f"Row {r}:", row_values(ws, r, max_col))

    # scan for cells containing double quotes
    ws_quote_cells = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and '"' in v:
                ws_quote_cells.append((cell.coordinate, v))
    print(f'Cells containing double quotes in "{ws.title}":', len(ws_quote_cells))
    for coord, val in ws_quote_cells[:20]:
        print(f"  {coord}: {val!r}")
    if len(ws_quote_cells) > 20:
        print("  ...")
    quote_cells.extend([(ws.title, coord, val) for coord, val in ws_quote_cells])

print("\nTotal cells containing double quotes across workbook:", len(quote_cells))
