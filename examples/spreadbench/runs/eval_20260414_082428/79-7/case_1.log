import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload workbook for editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]

print("Original sheet names:", original_sheet_names)

# Print current target values before modification
for ws in wb.worksheets:
    print(f"\nBefore changes in sheet {ws.title}:")
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and '"' in cell.value:
                print(cell.coordinate, repr(cell.value))

# Replace all double quotes in all string cells across all worksheets
changed_cells = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and '"' in cell.value:
                new_val = cell.value.replace('"', '')
                changed_cells.append((ws.title, cell.coordinate, cell.value, new_val))
                cell.value = new_val

print("\nChanged cells count:", len(changed_cells))
for item in changed_cells:
    print(item)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names and len(wb_check.sheetnames) == len(original_sheet_names):
    for ws, orig_name in zip(wb_check.worksheets, original_sheet_names):
        ws.title = orig_name
    wb_check.save(output_path)
    print("Restored original sheet names and re-saved.")

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("\nVerification:")
print("Final sheet names:", wb_verify.sheetnames)

for ws in wb_verify.worksheets:
    print(f"\nSheet: {ws.title}")
    for coord in ["A1", "A2", "A3", "A4"]:
        print(coord, repr(ws[coord].value))

# Additional sanity check: ensure no remaining double quotes
remaining = []
for ws in wb_verify.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and '"' in cell.value:
                remaining.append((ws.title, cell.coordinate, cell.value))

print("\nRemaining cells with double quotes:", remaining)
final_output_spreadsheet = output_path
```
