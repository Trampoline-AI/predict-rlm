def sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    
    # find likely header row among first 5 rows by non-empty count
    candidate_rows = []
    for r in range(1, min(6, max_row+1)):
        vals = [ws.cell(r,c).value for c in range(1, max_col+1)]
        nonempty = sum(v not in (None, "") for v in vals)
        candidate_rows.append((r, nonempty, vals[:min(15,max_col)]))
    print("Top candidate rows (row, nonempty, first cells):")
    for x in candidate_rows:
        print(x)
    
    # print headers from first 3 rows
    for r in range(1, min(4, max_row+1)):
        vals = [ws.cell(r,c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", vals)
    
    # sample first 10 rows
    print("First rows:")
    for r in range(1, min(11, max_row+1)):
        vals = [ws.cell(r,c).value for c in range(1, max_col+1)]
        print(f"{r}: {vals}")
    
    # sample last 5 rows
    print("Last rows:")
    start = max(1, max_row-4)
    for r in range(start, max_row+1):
        vals = [ws.cell(r,c).value for c in range(1, max_col+1)]
        print(f"{r}: {vals}")

for ws in wb.worksheets:
