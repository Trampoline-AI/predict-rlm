import os
from datetime import datetime
from openpyxl import load_workbook

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb["Sheet1"]

print("Existing summary formulas/values:")
for r in range(2, 7):
    print(
        r,
        "Dept", ws[f"G{r}"].value,
        "H formula", ws[f"H{r}"].value,
        "IJK current", [ws.cell(r, c).value for c in range(9, 12)]
    )

# Sanity-check expected counts from source data using Python
records = []
for r in range(2, ws.max_row + 1):
    rec_no = ws.cell(r, 1).value
    dept = ws.cell(r, 2).value
    created = ws.cell(r, 3).value
    closed = ws.cell(r, 4).value
    if rec_no is None and dept is None and created is None and closed is None:
        continue
    if dept is not None and created is not None:
        records.append((r, dept, created, closed))

months = [
    ("I", datetime(2022,5,1), datetime(2022,5,31)),
    ("J", datetime(2022,6,1), datetime(2022,6,30)),
    ("K", datetime(2022,7,1), datetime(2022,7,31)),
]

expected = {}
for r in range(2, 7):
    dept = ws[f"G{r}"].value
    expected[dept] = {}
    for col_letter, first_day, last_day in months:
        count = 0
        matching_rows = []
        for rr, d, created, closed in records:
            if d == dept and created <= last_day and (closed is None or closed >= first_day):
                count += 1
                matching_rows.append(rr)
        expected[dept][col_letter] = (count, matching_rows)

print("\nSanity-check expected counts by department:")
for dept, vals in expected.items():
    print(dept, vals)

# Write formulas into exact target cells I2:K6
# Use DATE(...) constants for LibreOffice compatibility
month_formulas = {
    "I": ('DATE(2022,5,1)', 'DATE(2022,5,31)'),
    "J": ('DATE(2022,6,1)', 'DATE(2022,6,30)'),
    "K": ('DATE(2022,7,1)', 'DATE(2022,7,31)'),
}

for r in range(2, 7):
    for col_letter, (first_day_formula, last_day_formula) in month_formulas.items():
        formula = (
            f'=COUNTIFS($B$2:$B$12,$G{r},'
            f'$C$2:$C$12,"<="&{last_day_formula},'
            f'$D$2:$D$12,"")'
            f'+COUNTIFS($B$2:$B$12,$G{r},'
            f'$C$2:$C$12,"<="&{last_day_formula},'
            f'$D$2:$D$12,">="&{first_day_formula})'
        )
        ws[f"{col_letter}{r}"] = formula

print("\nWritten formulas in target range:")
for r in range(2, 7):
    print(r, [ws[f"{col}{r}"].value for col in ["I", "J", "K"]])

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_names = ["Sheet1"]
if wb_after.sheetnames != orig_names and len(wb_after.sheetnames) == len(orig_names):
    for ws2, orig in zip(wb_after.worksheets, orig_names):
        ws2.title = orig
    wb_after.save(out_path)
    print("Renamed sheets back to original names:", orig_names)

# Verify with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["Sheet1"]

print("\nVerified target cells (data_only):")
for r in range(2, 7):
    print(f"Row {r}, Dept {wsv[f'G{r}'].value}:",
          {"I": wsv[f"I{r}"].value, "J": wsv[f"J{r}"].value, "K": wsv[f"K{r}"].value})

output_spreadsheet = out_path
```
