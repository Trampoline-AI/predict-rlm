import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect relevant cells before writing
print("Before write D2:G3:")
for r in range(2, 4):
    print(r, [ws.cell(r, c).value for c in range(4, 8)])

# Compute sums by first letter from column A, quantities in column B
totals = defaultdict(float)
matched_rows = []
unmatched_rows = []

for r in range(2, ws.max_row + 1):
    product = ws.cell(r, 1).value
    qty = ws.cell(r, 2).value
    
    if product is None and qty is None:
        continue
    
    if isinstance(product, str) and product.strip() != "" and qty is not None:
        first_letter = product.strip()[0]
        try:
            num_qty = float(qty)
            totals[first_letter] += num_qty
            matched_rows.append((r, product, qty, first_letter))
        except Exception:
            unmatched_rows.append((r, product, qty, "quantity not numeric"))
    else:
        unmatched_rows.append((r, product, qty, "missing product/qty"))

print("Matched rows:", matched_rows)
print("Unmatched rows:", unmatched_rows)
print("Computed totals:", dict(totals))

# Verify target labels and write exact target cells D3:G3 based on D2:G2
labels = [ws.cell(2, c).value for c in range(4, 8)]
print("Target labels D2:G2:", labels)

for c in range(4, 8):
    label = ws.cell(2, c).value
    value = totals.get(str(label).strip(), 0) if label is not None else 0
    # write int if whole number
    if isinstance(value, float) and value.is_integer():
        value = int(value)
    ws.cell(3, c).value = value

print("After write D2:G3:")
for r in range(2, 4):
    print(r, [ws.cell(r, c).value for c in range(4, 8)])

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring to", original_sheet_names)
    # rename by position to original names
    for i, name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = name
    wb_after.save(output_path)
    wb_after = load_workbook(output_path)

print("Final sheet names:", wb_after.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("Verified D2:G3 after save/recalc:")
for r in range(2, 4):
    print(r, [wsv.cell(r, c).value for c in range(4, 8)])

final_output_path = output_path
```
