from openpyxl import load_workbook
import os
from copy import copy

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Reconfirm target area before writing
print("Before writing F3:H6:")
for r in range(3, 7):
    print(r, [ws.cell(r, c).value for c in range(6, 9)])

# Write formulas into F4:H6
# Use array-capable INDEX/SMALL/IF formulas; LibreOffice should evaluate them on recalc.
for target_row in range(4, 7):
    row_counter_expr = f"ROWS($F$4:F{target_row})"
    ws[f"F{target_row}"] = f'=IFERROR(INDEX($B$4:$B$22,SMALL(IF($B$4:$B$22="Lighting",ROW($B$4:$B$22)-ROW($B$4)+1),{row_counter_expr})),"")'
    ws[f"G{target_row}"] = f'=IFERROR(INDEX($C$4:$C$22,SMALL(IF($B$4:$B$22="Lighting",ROW($B$4:$B$22)-ROW($B$4)+1),{row_counter_expr})),"")'
    ws[f"H{target_row}"] = f'=IFERROR(INDEX($D$4:$D$22,SMALL(IF($B$4:$B$22="Lighting",ROW($B$4:$B$22)-ROW($B$4)+1),{row_counter_expr})),"")'

# Print written formulas
print("\nWritten formulas F4:H6:")
for r in range(4, 7):
    print(r, [ws.cell(r, c).value for c in range(6, 9)])

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if recalc renamed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # Rename sheets back by position
    for i, expected in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected
    wb_after.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_data = load_workbook(output_path, data_only=True)
ws_data = wb_data[orig_sheetnames[0]]

print("\nVerification - formulas in F4:H6:")
for r in range(4, 7):
    print(r, [ws_formula.cell(r, c).value for c in range(6, 9)])

print("\nVerification - calculated values in F3:H6:")
