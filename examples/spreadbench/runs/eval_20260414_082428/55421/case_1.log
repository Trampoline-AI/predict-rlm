from openpyxl import load_workbook
from collections import defaultdict, Counter
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("F column existing values/formulas inspection:")
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 6).value
    if v not in (None, ""):
        print(r, repr(v), "is_formula" if isinstance(v, str) and v.startswith("=") else "literal")

# Print all rows compactly
all_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    all_rows.append((r, vals))
print("\nAll data rows:")
for r, vals in all_rows:
    print(r, vals)

# Group by MRN and summarize statuses / dates / current F
groups = defaultdict(list)
for r in range(2, ws.max_row + 1):
    mrn = ws.cell(r, 1).value
    groups[mrn].append({
        "row": r,
        "date": ws.cell(r, 2).value,
        "status": ws.cell(r, 4).value,
        "next_appt": ws.cell(r, 5).value,
        "f": ws.cell(r, 6).value,
    })

print("\nGrouped summaries:")
for mrn in sorted(groups, key=lambda x: (str(type(x)), x)):
    items = groups[mrn]
    statuses = [str(i["status"]).strip().upper() if i["status"] is not None else None for i in items]
    fvals = [i["f"] for i in items]
    nexts = [i["next_appt"] for i in items]
    print("MRN", mrn, "rows", [i["row"] for i in items], "statuses", statuses, "next_appt_nonblank", sum(v is not None and v != "" for v in nexts), "F", fvals)

# Derive expected result per row based on apparent rule:
# if group has SCH and NO SHOW -> NS/SCHED
# elif status is NO SHOW and next appt exists -> NO ACTION NEEDED
# elif status is NO SHOW and no next appt -> CALL PT
# elif group only has SCH -> FUTURE
print("\nExpected outputs by rule:")
expected = {}
for mrn, items in groups.items():
    statuses = set(str(i["status"]).strip().upper() for i in items if i["status"] is not None)
    has_sch = "SCH" in statuses
    has_noshow = "NO SHOW" in statuses
    for i in items:
        status = str(i["status"]).strip().upper() if i["status"] is not None else ""
        next_present = i["next_appt"] not in (None, "")
        if has_sch and has_noshow:
            exp = "NS/SCHED"
        elif has_sch and not has_noshow:
            exp = "FUTURE"
        elif status == "NO SHOW" and next_present:
            exp = "NO ACTION NEEDED"
        elif status == "NO SHOW" and not next_present:
            exp = "CALL PT"
        else:
            exp = None
        expected[i["row"]] = exp
        print(i["row"], mrn, status, next_present, "existing:", i["f"], "expected:", exp)

# Focus on blanks in F
print("\nBlank F rows and expected results:")
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 6).value in (None, ""):
        print("Row", r, [ws.cell(r, c).value for c in range(1, 6)], "=>", expected[r])
```
