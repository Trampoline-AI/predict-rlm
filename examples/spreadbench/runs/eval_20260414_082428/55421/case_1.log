```repl
from openpyxl import load_workbook
import os
from shutil import copyfile

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

max_row = ws.max_row
print("Writing formulas to Sheet1 column F for blank cells only.")
print("Original sheetnames:", original_sheetnames)
print("Target rows with blank F before write:", [r for r in range(2, max_row+1) if ws.cell(r, 6).value in (None, "")])

# Formula pattern using bounded ranges
for r in range(2, max_row + 1):
    fcell = ws.cell(r, 6)
    if fcell.value in (None, ""):
        formula = (
            f'=IF(AND(COUNTIFS($A$2:$A${max_row},A{r},$D$2:$D${max_row},"Sch")>0,'
            f'COUNTIFS($A$2:$A${max_row},A{r},$D$2:$D${max_row},"No Show")>0),'
            f'"NS/SCHED",'
            f'IF(COUNTIFS($A$2:$A${max_row},A{r},$D$2:$D${max_row},"Sch")>0,'
            f'"FUTURE",'
            f'IF(AND(D{r}="No Show",E{r}<>""),"NO ACTION NEEDED",'
            f'IF(AND(D{r}="No Show",E{r}=""),"CALL PT",""))))'
        )
        fcell.value = formula
        print(f"Row {r} formula:", formula)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_post = load_workbook(outfile)
print("Sheetnames after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for ws_obj, original_name in zip(wb_post.worksheets, original_sheetnames):
        ws_obj.title = original_name
    wb_post.save(outfile)
    print("Restored original sheet names:", original_sheetnames)

# Verify formulas and evaluated results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification of target rows 12-20:")
for r in range(12, 21):
    a = ws_values.cell(r, 1).value
    d = ws_values.cell(r, 4).value
    e = ws_values.cell(r, 5).value
    formula = ws_formula.cell(r, 6).value
    value = ws_values.cell(r, 6).value
    print({
        "row": r,
        "A": a,
        "D": d,
        "E": e,
        "F_formula": formula,
        "F_value": value
    })

# Also verify all rows in F are nonblank now
blank_after = [r for r in range(2, max_row+1) if ws_values.cell(r, 6).value in (None, "")]
print("Blank F rows after recalc:", blank_after)

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
