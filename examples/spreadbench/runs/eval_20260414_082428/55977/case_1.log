To preserve dynamic behavior, I’ll write formulas:
- Column B: `=WEEKDAY(A2,2)` for each populated date row.
- Column C: a day-name formula based on column B. To avoid locale/format issues and match the instruction, I’ll use a direct mapping formula rather than cell formatting. `CHOOSE` is LibreOffice-compatible and simpler than `INDEX` with array constants.

I’ll also inspect number formats/styles in B:C briefly before writing, then save to the output folder, recalculate, reload, verify target cells and sheet names, and ensure the expected values appear for all rows with dates.
Code:
```repl
import os, shutil
from datetime import datetime
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload workbook for editing
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["WEEKDAY"]

# Inspect styles/number formats before modifying
print("Pre-write inspection:")
print("B2 formula/value:", ws["B2"].value, "format:", ws["B2"].number_format)
print("C2 formula/value:", ws["C2"].value, "format:", ws["C2"].number_format)
print("Max row:", ws.max_row)

# Identify rows with actual dates in column A
target_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    if a not in (None, ""):
        target_rows.append(r)

print("Target rows:", target_rows)

# Replace/fill formulas in B:C for all rows with dates in column A
for r in target_rows:
    ws.cell(r, 2).value = f"=WEEKDAY(A{r},2)"
    ws.cell(r, 3).value = (
        f'=CHOOSE(B{r},"Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday")'
    )

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position to original names
    for i, sname in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = sname
    wb2.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with formulas view
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["WEEKDAY"]
print("Post-write formulas sample:")
for r in target_rows[:5]:
    print(r, wsf[f"B{r}"].value, wsf[f"C{r}"].value)

# Verify cached calculated values
wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals["WEEKDAY"]
print("Verified calculated target cells:")
for r in target_rows:
    print(r, wsv[f"A{r}"].value, wsv[f"B{r}"].value, wsv[f"C{r}"].value)

# Additional plausibility check against Python weekday
day_names = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"]
issues = []
for r in target_rows:
    dt = wsv[f"A{r}"].value
    b = wsv[f"B{r}"].value
    c = wsv[f"C{r}"].value
    if isinstance(dt, datetime):
        expected_b = dt.weekday() + 1
        expected_c = day_names[dt.weekday()]
        if b != expected_b or c != expected_c:
            issues.append((r, dt, b, c, expected_b, expected_c))
print("Verification issues:", issues[:10], "count:", len(issues))
```
