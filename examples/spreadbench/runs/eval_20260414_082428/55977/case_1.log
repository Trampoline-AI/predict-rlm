import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

input_path = input_spreadsheet
print("Input path exists:", os.path.exists(input_path), input_path)

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames
print("Original sheet names:", orig_sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n=== Sheet: {sname} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # find first 10 rows and last 5 rows, bounded by sheet size
    sample_first = list(range(1, min(ws.max_row, 10) + 1))
    sample_last = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    
    # print headers from first few rows to identify actual header row
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = row_values(ws, r, min(ws.max_column, 8))
        print(f"Row {r} first cols:", vals)
    
    # column letters + apparent header row 1
    headers = {}
    for c in range(1, ws.max_column + 1):
        headers[get_column_letter(c)] = ws.cell(1, c).value
    print("Row 1 headers by column:", headers)
    
    print("First sample rows:")
    for r in sample_first:
        vals = row_values(ws, r, min(ws.max_column, 8))
        print(f"R{r}:", vals)
    print("Last sample rows:")
    for r in sample_last:
        vals = row_values(ws, r, min(ws.max_column, 8))
        print(f"R{r}:", vals)
    
    # specifically inspect columns A:C fully enough to understand target
    print("Inspecting A:C for first 15 rows and last 10 rows")
    for r in range(1, min(ws.max_row, 15) + 1):
        print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value)
    for r in range(max(1, ws.max_row - 9), ws.max_row + 1):
        if r > 15:
            print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value)

    # if B:C have formulas/values, inspect formula strings
    print("Existing B:C formulas/values where present in first 20 rows:")
    for r in range(1, min(ws.max_row, 20) + 1):
        b = ws[f"B{r}"].value
        c = ws[f"C{r}"].value
        if b is not None or c is not None:
            print(f"R{r}: B={b!r}, C={c!r}")
