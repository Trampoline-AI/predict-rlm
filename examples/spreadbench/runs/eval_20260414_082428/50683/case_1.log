import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))

# Load workbook fresh
wb = load_workbook(path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Instruction:", instruction)
print("Sheet names:", orig_sheet_names)
print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")

# Print headers with coordinates
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Headers:")
for c, h in enumerate(headers, start=1):
    print(c, get_column_letter(c), h)

# Print first and last rows again, and explicit target cells
print("\nRows 1-5:")
for r in range(1, min(ws.max_row, 5) + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

print("\nCurrent P:Q values:")
for r in range(1, ws.max_row + 1):
    print(r, ws[f"P{r}"].value, ws[f"Q{r}"].value)

# Safely inspect tables if present
print("\nTables info:")
try:
    tbls = ws.tables
    print("Table names:", list(tbls.keys()))
    for name in tbls.keys():
        tbl = tbls[name]
        ref = getattr(tbl, "ref", None)
        print("table", name, "ref", ref, "type", type(tbl))
except Exception as e:
    print("Could not inspect tables:", repr(e))

# Compute last-4 nonblank average for score columns B:N
score_start_col = 2
score_end_col = 14
results = {}

print("\nScore analysis by row:")
for r in range(2, ws.max_row + 1):
    golfer = ws.cell(r, 1).value
    vals = [ws.cell(r, c).value for c in range(score_start_col, score_end_col + 1)]
    nonblank = [v for v in vals if v not in (None, "")]
    last4 = nonblank[-4:]
    avg = round(sum(last4) / len(last4), 2) if last4 else None
    results[r] = avg
    print(f"row {r} golfer={golfer} vals={vals} nonblank={nonblank} last4={last4} avg={avg}")

# Write into existing target column Q ("last 4 trend")
