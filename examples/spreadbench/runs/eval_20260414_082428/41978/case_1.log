import os, shutil
from openpyxl import load_workbook

# Reload for clean edit
wb = load_workbook(input_spreadsheet)
ws = wb["Cumulative"]
original_sheet_names = wb.sheetnames[:]

# Final focused inspection before writing
print("Merged ranges:", [str(rng) for rng in ws.merged_cells.ranges])
alpha_hits = []
for row in ws.iter_rows():
    for cell in row:
        v = cell.value
        if isinstance(v, str) and "alpha" in v.lower():
            alpha_hits.append((cell.coordinate, v))
print("Alpha hits:", alpha_hits)

print("Target area before write (G1:K11):")
for r in range(1, 12):
    print(r, [ws.cell(r, c).value for c in range(7, 12)])

# Decide target cells: I1:I11 (blank formatted summary column beside years)
# Preserve original formatting in column I by only writing values/formulas, not styles.
if ws["I1"].value in (None, ""):
    ws["I1"] = "Open"
for r in range(2, 12):
    year_cell = f"G{r}"
    target = f"I{r}"
    # formula bounded to actual requested ranges
    ws[target] = f'=COUNTIFS($G$14:$G$185,{year_cell},$J$14:$J$185,"Open")'

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names and len(wb_after.sheetnames) == len(original_sheet_names):
    for ws_tmp, orig in zip(wb_after.worksheets, original_sheet_names):
        ws_tmp.title = orig
    wb_after.save(out_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verify formulas and cached results
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["Cumulative"]
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values["Cumulative"]

print("\nVerification target cells I1:I11")
for r in range(1, 12):
    print(
        f"I{r}",
        "formula/raw=", wsf[f"I{r}"].value,
        "cached=", wsv[f"I{r}"].value,
