from openpyxl import load_workbook
from openpyxl.worksheet.formula import ArrayFormula
from pathlib import Path
import os, shutil

# Reload fresh workbook
infile = input_spreadsheet
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
base = wb["Base"]
streets = wb["Streets"]

# Build usable streets rows: only where Start and End are both populated
usable = []
for r in range(2, streets.max_row + 1):
    street = streets.cell(r, 2).value
    start = streets.cell(r, 3).value
    end = streets.cell(r, 4).value
    assistant = streets.cell(r, 6).value
    if street is not None and start is not None and end is not None:
        usable.append({
            "row": r,
            "street": str(street).strip(),
            "street_key": str(street).strip().casefold(),
            "start": start,
            "end": end,
            "assistant": assistant if assistant is not None else ""
        })

print("Usable Streets rows:")
for x in usable:
    print(x)

def compute_match(base_street, base_num):
    if base_street is None or base_num is None or base_street == "":
        return ""
    key = str(base_street).strip().casefold()
    for row in usable:
        if row["street_key"] == key and row["start"] <= base_num <= row["end"]:
            return row["assistant"]
    return ""

# Preview and compare with example answers in Base!F
results = {}
mismatches = []
print("\nComputed results vs Base!F examples:")
for r in range(2, base.max_row + 1):
    b_street = base.cell(r, 3).value
    b_num = base.cell(r, 4).value
    expected = base.cell(r, 6).value
    result = compute_match(b_street, b_num)
    results[r] = result
    print(f"Row {r}: street={b_street!r}, num={b_num!r}, computed={result!r}, F_example={expected!r}")
    if expected not in (None, "") and expected != result:
        mismatches.append((r, expected, result))

print("\nMismatch count against nonblank Base!F examples:", len(mismatches))
if mismatches:
    print("Mismatches:", mismatches)

# Write literal results into target cells Base!E2:Emax_row
for r in range(2, base.max_row + 1):
    base.cell(r, 5).value = results[r]

# Save output
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / Path(infile).name
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_status = await recalculate(str(outfile))
print("Recalculate status:", recalc_status)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename by position back to originals
    for i, name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = name
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verification using data_only after recalculation
verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify.sheetnames)
vbase = verify["Base"]

print("\nVerification of target Base!E:F rows:")
blanks_when_shouldnt = []
for r in range(2, vbase.max_row + 1):
    e_val = vbase.cell(r, 5).value
    f_val = vbase.cell(r, 6).value
    print(f"Row {r}: E={e_val!r}, F={f_val!r}")
    if results[r] != "" and (e_val is None or str(e_val).strip() == ""):
        blanks_when_shouldnt.append((r, results[r], e_val))

print("\nRows where verified E is blank despite expected computed value:", blanks_when_shouldnt)
output_spreadsheet = str(outfile)
print("\nPrepared output_spreadsheet:", output_spreadsheet)
