from openpyxl import load_workbook
import os, re

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(output_path if os.path.exists(output_path) else input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Current B13 formula before fix:")
print(ws["B13"].value)

no_digit_checks = "*".join([f'--ISERROR(SEARCH("{d}",$I$4:$I$10))' for d in range(10)])
new_formula = f'=SUMPRODUCT($B$4:$B$10*--ISNUMBER(SEARCH(A13,$I$4:$I$10))*{no_digit_checks})'
ws["B13"] = new_formula

print("Updated B13 formula:")
print(ws["B13"].value)

wb.save(output_path)
print("Saved:", output_path)

recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Restore original sheet names if needed
wb_names = load_workbook(output_path)
if wb_names.sheetnames != orig_sheet_names:
    print("Sheet names changed:", wb_names.sheetnames, "restoring to", orig_sheet_names)
    for i, nm in enumerate(orig_sheet_names):
        if i < len(wb_names.worksheets):
            wb_names.worksheets[i].title = nm
    wb_names.save(output_path)

# Verify
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

print("Verification target cells:")
print("A13:", wsv["A13"].value)
print("B13 formula:", wsf["B13"].value)
print("B13 cached:", wsv["B13"].value)
print("B14 cached example:", wsv["B14"].value)

# Recompute expected value in Python for sanity check
criterion = wsf["A13"].value
expected = 0
matches = []
for r in range(4, 11):
    note = wsf[f"I{r}"].value
    b = wsf[f"B{r}"].value
    if isinstance(note, str) and criterion in note and not re.search(r"\d", note):
        expected += b or 0
        matches.append((r, note, b))
print("Expected matches:", matches)
print("Expected total:", expected)

assert wsv["B13"].value == expected, f"B13 mismatch: got {wsv['B13'].value}, expected {expected}"

output_spreadsheet = output_path
```
