import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally for editing
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify headers and target columns
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Headers:", headers)

col_map = {str(ws.cell(1, c).value).strip(): c for c in range(1, ws.max_column + 1) if ws.cell(1, c).value is not None}
print("Column map:", col_map)

col1_col = col_map["Column1"]   # A
total_col = col_map["Total"]    # D

# Determine actual last non-empty row
last_row = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
        last_row = r
print("Last non-empty row:", last_row)

# Print current target cells before modification
print("Before modification:")
for r in range(2, last_row + 1):
    print(f"A{r}={ws.cell(r, col1_col).value!r}, D{r}={ws.cell(r, total_col).value!r}")

# Update formulas in existing Total column
for r in range(2, last_row + 1):
    status = ws.cell(r, col1_col).value
    current = ws.cell(r, total_col).value
    if isinstance(current, str) and current.startswith("="):
        base = current[1:]  # strip leading "=" before nesting
    else:
        # fallback if formula missing
        base = f"SUM(B{r}:C{r})"
    new_formula = f'=IF(A{r}="A",{base}+10,IF(A{r}="B",{base}-10,{base}))'
    ws.cell(r, total_col).value = new_formula

print("After modification (formulas):")
for r in range(2, last_row + 1):
    print(f"D{r}={ws.cell(r, total_col).value}")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    for i, old_name in enumerate(original_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Restored original sheet names:", original_sheetnames)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("Verified cached values in target cells:")
for r in range(2, last_row + 1):
    print(f"A{r}={wsv.cell(r, col1_col).value!r}, D{r}={wsv.cell(r, total_col).value!r}")

# Also verify formulas still present in normal load
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[original_sheetnames[0]]
print("Verified formulas in target cells:")
for r in range(2, last_row + 1):
    print(f"D{r}={wsf.cell(r, total_col).value!r}")

final_output_path = output_path
