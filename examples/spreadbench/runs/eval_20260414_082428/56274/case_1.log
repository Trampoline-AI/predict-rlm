import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path)
wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # find likely header row among first 5 rows by most non-empty cells
    best_row = None
    best_nonempty = -1
    for r in range(1, min(6, ws.max_row+1)):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row = r
    print("Likely header row:", best_row)
    print("Header values:", row_values(ws, best_row, ws.max_column))
    
    # first 10 rows
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows if distinct
