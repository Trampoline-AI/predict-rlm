```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Column letters / row 3-12 snapshot:")
for r in range(3, 13):
    vals = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None:
            vals.append(f"{get_column_letter(c)}{r}={v}")
    print(vals)

print("\nHeaders/month table in F:R rows 3:7")
for r in range(3, 8):
    print(r, [ws.cell(r, c).value for c in range(6, 19)])

print("\nSummary labels/targets A9:D12")
for r in range(9, 13):
    print(r, [ws.cell(r, c).value for c in range(1, 5)], 
          "formats:", [ws.cell(r, c).number_format for c in range(1, 5)])

# Also inspect existing formulas anywhere in workbook
print("\nExisting formula cells:")
formula_cells = []
for row in ws.iter_rows():
    for cell in row:
        if isinstance(cell.value, str) and cell.value.startswith("="):
            formula_cells.append((cell.coordinate, cell.value))
print(formula_cells[:50], "count=", len(formula_cells))

# Determine exact formula pattern:
# Match fiscal month in D7 to month headers G3:R3, then return row values from rows 4:7.
# Summary labels are in A9:A12:
# Opening Balance -> row 4
# Total Debits    -> row 5
# Total Credits   -> row 6
# Closing Balance -> row 7
# Use INDEX/MATCH formulas in D9:D12.
mapping = {
    9: 4,   # Opening Balance
    10: 5,  # Total Debits
    11: 6,  # Total Credits
    12: 7,  # Closing Balance
}
for target_row, source_row in mapping.items():
    formula = f'=INDEX($G${source_row}:$R${source_row},1,MATCH($D$7,$G$3:$R$3,0))'
    print("Writing", ws[f"D{target_row}"].coordinate, "old=", ws[f"D{target_row}"].value, "new=", formula)
    ws[f"D{target_row}"] = formula

# Preserve number format from existing numeric cells if present
for r in range(9, 13):
    ws[f"D{r}"].number_format = '#,##0.00'

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
orig_names = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_names and len(wb_after.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)
    print("Restored original sheet names:", orig_names)

# Verify cached results
wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check[orig_names[0]]
wb_vals = load_workbook(out_path, data_only=True)
ws_vals = wb_vals[orig_names[0]]

print("\nVerification formulas and values:")
for coord in ["D7", "D9", "D10", "D11", "D12"]:
    print(coord, "formula/raw=", ws_check[coord].value, "cached=", ws_vals[coord].value)

print("Sanity from source month Feb 2021 column:")
# find matching column
match_col = None
for c in range(7, 19):
    if ws_vals.cell(3, c).value == ws_vals["D7"].value:
        match_col = c
        break
print("Matched column:", get_column_letter(match_col) if match_col else None)
if match_col:
    for src_r, tgt_r in [(4,9),(5,10),(6,11),(7,12)]:
        print(f"source {get_column_letter(match_col)}{src_r}=", ws_vals.cell(src_r, match_col).value,
              "target D"+str(tgt_r), "=", ws_vals[f"D{tgt_r}"].value)

output_spreadsheet = out_path
