    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # print first 15 rows x all used columns (or up to 12 if huge)
    max_c = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_c+1)]
    print("Row 1 headers/values:", headers)
    
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, max_c+1)]
    
    first_rows = list(range(1, min(ws.max_row, 10)+1))
    last_rows = list(range(max(1, ws.max_row-4), ws.max_row+1))
    print("\nFirst rows:")
    for r in first_rows:
        print(r, row_vals(r))
    print("\nLast rows:")
    for r in last_rows:
        print(r, row_vals(r))

for ws in wb.worksheets:
