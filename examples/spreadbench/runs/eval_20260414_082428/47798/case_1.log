print("Sheet names:", wb.sheetnames)

def cell_str(v):
    if v is None:
        return ""
    return str(v)

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row =", ws.max_row, "max_col =", ws.max_column)
    
    # detect likely header row among first 3 rows by most non-empty cells
    best_row = 1
    best_nonempty = -1
    for r in range(1, min(3, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v is not None and str(v) != "" for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            best_row = r
    header_row = best_row
    headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
    print("Chosen header row:", header_row)
    print("Headers:", [(get_column_letter(c), headers[c-1]) for c in range(1, ws.max_column + 1)])
    
    # print first 10 rows
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # print last 5 rows if distinct
    start_last = max(1, ws.max_row - 4)
    if start_last <= ws.max_row:
