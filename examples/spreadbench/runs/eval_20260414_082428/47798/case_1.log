Code:
```repl
import os, re, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and inspect exact target cells again
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Verifying target column and example answers:")
for r in range(1, ws.max_row + 1):
    print(r, "A=", ws[f"A{r}"].value, "| B=", ws[f"B{r}"].value)

def extract_collection(text):
    if not isinstance(text, str):
        return None
    m = re.search(r'Collection-(.*?)(?:,|$)', text)
    if not m:
        return None
    return m.group(1).strip()

# Fill only blanks in column B, preserving existing plausible example answers
filled = []
skipped_existing = []
for r in range(2, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    b_cell = ws.cell(r, 2)
    extracted = extract_collection(a_val)
    if b_cell.value in (None, ""):
        b_cell.value = extracted
        filled.append((r, extracted))
    else:
        skipped_existing.append((r, b_cell.value, extracted))

print("Rows filled:", filled)
print("Rows preserved:", skipped_existing)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename sheets back by position
    for i, original_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = original_name
    wb_after.save(outfile)
    print("Restored original sheet names:", wb_after.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

print("Verification of target cells B2:B7:")
for r in range(2, 8):
    print(f"B{r} =", repr(wsv[f"B{r}"].value))

output_spreadsheet = outfile
```
