        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        row_nonempty[r] = sum(v not in (None, "") for v in vals)
    print("Non-empty counts first rows:", row_nonempty)
    
    # Print first 5 rows values
