                formula_rows.append(r)
        print("Rows with formulas in G:", formula_rows[:50], "count:", len(formula_rows))
        for r in formula_rows[:20]:
            print(f"G{r} formula:", ws.cell(r, 7).value)
            
        # Print nearby cells A:H for yellow rows and formula rows
        focus_rows = sorted(set(yellow_rows[:10] + formula_rows[:10]))
