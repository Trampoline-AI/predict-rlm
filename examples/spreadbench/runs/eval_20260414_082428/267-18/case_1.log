Code:
```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

def cell_is_yellow(cell):
    fill = cell.fill
    if not fill or fill.patternType != "solid":
        return False
    fg = fill.fgColor
    rgb = getattr(fg, "rgb", None)
    indexed = getattr(fg, "indexed", None)
    # common yellow encodings
    return rgb in ("FFFFFF00", "FFFF00", "00FFFF00") or indexed in (5, 6)

def row_has_yellow(ws, r):
    for c in range(1, ws.max_column + 1):
        if cell_is_yellow(ws.cell(r, c)):
            return True
    return False

# Load workbook for modification
wb2 = load_workbook(input_path)
original_sheet_names = wb2.sheetnames[:]
print("Original sheet names:", original_sheet_names)

changes = []
for ws in wb2.worksheets:
    print(f"\nProcessing sheet: {ws.title}")
    for r in range(1, ws.max_row + 1):
        yellow = row_has_yellow(ws, r)
        g = ws.cell(r, 7)
        print(f"Row {r}: yellow={yellow}, G_before={g.value!r}")
        if yellow and isinstance(g.value, str) and g.value.startswith("="):
            old_formula = g.value
            # Only add // before the opening [ output token, and avoid double-prefixing
            if 'CONCATENATE("//["' in old_formula or '"//["' in old_formula:
                new_formula = old_formula
            else:
                new_formula = old_formula.replace('CONCATENATE("[",', 'CONCATENATE("//[",', 1)
            g.value = new_formula
            changes.append((ws.title, r, old_formula, new_formula))
            print(f"  Updated G{r} to: {new_formula}")
        else:
            print("  No change")

# Save
wb2.save(output_path)
print("\nSaved to:", output_path)
print("Changes made:", len(changes))
for ch in changes:
    print("Changed:", ch[0], f"G{ch[1]}")
    print(" old:", ch[2])
    print(" new:", ch[3])

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc; if sheet names changed, restore them
wb3 = load_workbook(output_path)
print("Sheet names after recalc:", wb3.sheetnames)
if wb3.sheetnames != original_sheet_names:
    # rename by position to preserve original names
    for ws, orig_name in zip(wb3.worksheets, original_sheet_names):
        ws.title = orig_name
    wb3.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas
wb_verify_formula = load_workbook(output_path, data_only=False)
wb_verify_values = load_workbook(output_path, data_only=True)

print("\nVerification:")
print("Final sheet names:", wb_verify_formula.sheetnames)

for wsf, wsv in zip(wb_verify_formula.worksheets, wb_verify_values.worksheets):
    print(f"Sheet {wsf.title}")
    for r in range(1, wsf.max_row + 1):
        yellow = row_has_yellow(wsf, r)
        formula = wsf.cell(r, 7).value if wsf.max_column >= 7 else None
        value = wsv.cell(r, 7).value if wsv.max_column >= 7 else None
        print(f"Row {r}: yellow={yellow}, G_formula={formula!r}, G_value={value!r}")

output_spreadsheet = output_path
```
