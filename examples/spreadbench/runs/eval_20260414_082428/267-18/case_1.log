        print(f"Row {r}:", vals)
    
    # Print column headers assuming row 1 and row 2 possibilities
    headers1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print("Headers row1:", headers1)
    print("Headers row2:", headers2)
    
    # Focus on column G
    if ws.max_column >= 7:
        print("\nColumn G inspection (first 15 non-empty / interesting rows):")
        found = 0
        yellow_rows = []
        for r in range(1, ws.max_row + 1):
            cell = ws.cell(r, 7)
            row_fill_info = [rgb_of_fill(ws.cell(r, c)) for c in range(1, min(ws.max_column, 8) + 1)]
            # identify yellow-ish anywhere in row
            row_has_yellow = False
            for info in row_fill_info:
                if not info:
                    continue
                rgb = info.get("fgColor_rgb")
                idx = info.get("fgColor_indexed")
                if rgb in ("FFFFFF00", "FFFF00", "00FFFF00") or idx in (5, 6):
                    row_has_yellow = True
            if row_has_yellow:
                yellow_rows.append(r)
            if cell.value not in (None, "") or row_has_yellow:
                print(f"Row {r} G={cell.value!r} G_fill={rgb_of_fill(cell)} row_has_yellow={row_has_yellow}")
                found += 1
                if found >= 15:
                    break
        print("Yellow rows detected (first up to 30):", yellow_rows[:30], "count:", len(yellow_rows))
        
        # Print formulas specifically in G for all rows with formulas or yellow
        formula_rows = []
        for r in range(1, ws.max_row + 1):
