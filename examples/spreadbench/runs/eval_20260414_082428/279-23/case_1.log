import os, json, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

inspection = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    max_row, max_col = ws.max_row, ws.max_column
    headers = row_values(ws, 1, max_col)
    inspection[sname] = {"max_row": max_row, "max_col": max_col, "headers": headers}
    print(f"\n--- Sheet: {sname} ---")
    print(f"Dimensions: rows={max_row}, cols={max_col}")
    print("Headers row 1:", headers)
    
    # first 10 rows
    first_end = min(max_row, 10)
    print(f"First rows 1-{first_end}:")
    for r in range(1, first_end + 1):
        print(f"Row {r}:", row_values(ws, r, min(max_col, 8)))
    
    # last 5 rows
    start_last = max(1, max_row - 4)
    print(f"Last rows {start_last}-{max_row}:")
    for r in range(start_last, max_row + 1):
        print(f"Row {r}:", row_values(ws, r, min(max_col, 8)))
    
    # column B detailed inspection
    print("Column B values/formulas sample:")
    for r in list(range(1, min(max_row, 10) + 1)) + list(range(max(1, max_row - 4), max_row + 1)):
