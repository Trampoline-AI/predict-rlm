Code:
```repl
import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

print("Full sheet inspection for exact targeting:")
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    print(f"Row {r}: A={a!r}, B={b!r}")

print("\nClassifying column B rows:")
for r in range(1, ws.max_row + 1):
    b = ws.cell(r, 2).value
    if b is None or b == "":
        status = "blank"
    elif isinstance(b, str) and re.search(r"\([^)]*\)", b):
        status = "contains_parentheses"
    else:
        status = "no_parentheses_or_already_extracted"
    print(f"B{r}: {status} -> {b!r}")

# Apply transformation directly in column B:
# - blank stays blank
# - if contains parentheses, keep only content inside first parentheses
# - if no parentheses, leave as is
modified = []
skipped_existing = []
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 2)
    val = cell.value
    if val is None or val == "":
        continue
    if isinstance(val, str):
        m = re.search(r"\(([^)]*)\)", val)
        if m:
            new_val = m.group(1)
            if val != new_val:
                cell.value = new_val
                modified.append((r, val, new_val))
            else:
                skipped_existing.append((r, val))
        else:
            skipped_existing.append((r, val))
    else:
        skipped_existing.append((r, val))

print("\nModified rows in column B:")
for item in modified:
    print(item)
print("Count modified:", len(modified))

print("\nUnchanged rows in column B:")
for item in skipped_existing:
    print(item)
print("Count unchanged/non-target:", len(skipped_existing))

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names unchanged
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_names = wb.sheetnames
if wb_after.sheetnames != orig_names:
    for idx, expected in enumerate(orig_names):
        wb_after.worksheets[idx].title = expected
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verification reload
verify_wb = load_workbook(out_path, data_only=True)
verify_ws = verify_wb[orig_names[0]]

print("\nVerification of all target cells in column B:")
for r in range(1, verify_ws.max_row + 1):
    print(f"B{r}={verify_ws.cell(r, 2).value!r}")

# Sanity checks
blank_ok = all(verify_ws.cell(r, 2).value in (None, "") for r in [1, 2])
print("Blank rows preserved (B1,B2):", blank_ok)

print("\nKey transformed range check B3:B16 (source rows):")
for r in range(3, min(16, verify_ws.max_row) + 1):
    print(r, verify_ws.cell(r, 2).value)

output_spreadsheet = out_path
```
