    print(f"R{r} H:P formulas first/last = {formulas[0]} | {formulas[-1]}")
    print(f"R{r} H:P values = {values}")
    print(f"R{r} Q total = {total}")

issues = []
if wbf.sheetnames != ["Data", "Summary"]:
    issues.append(f"Unexpected sheet names: {wbf.sheetnames}")
for r in range(6, 10):
    for c in range(8, 17):
        v = wsv.cell(r, c).value
        if v in (None, ""):
            issues.append(f"Blank {r},{c}")
    if wsv[f"Q{r}"].value in (None, ""):
