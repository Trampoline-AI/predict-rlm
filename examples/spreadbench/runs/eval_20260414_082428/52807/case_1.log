import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Summary"]

print("Pre-write inspection of target area H6:P9:")
for r in range(6, 10):
    vals = [ws.cell(r, c).value for c in range(8, 17)]
    print(f"Row {r} H:P before:", vals)

print("Existing total formulas Q6:Q9:")
for r in range(6, 10):
    print(f"Q{r} =", ws[f"Q{r}"].value)

# Write combined formulas into H6:P9
for r in range(6, 10):
    for c in range(8, 17):  # H:P
        col = get_column_letter(c)
        formula = (
            f'=IF(SUMIFS(Data!$C$2:$C$13,Data!$A$2:$A$13,Summary!$C{r},'
            f'Data!$D$2:$D$13,Summary!{col}$5)<>0,'
            f'SUMIFS(Data!$C$2:$C$13,Data!$A$2:$A$13,Summary!$C{r},'
            f'Data!$D$2:$D$13,Summary!{col}$5),'
            f'SUM($E{r}:$G{r})/(12-$D$3))'
        )
        ws.cell(r, c).value = formula

print("Written formulas H6:P9:")
for r in range(6, 10):
    row_formulas = [ws.cell(r, c).value for c in range(8, 17)]
    print(f"Row {r} H:P formulas:", row_formulas)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation; restore sheet names if LO changed them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names:
    # Rename by position to original names
    for i, expected in enumerate(original_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = expected
    wb_post.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas are present
