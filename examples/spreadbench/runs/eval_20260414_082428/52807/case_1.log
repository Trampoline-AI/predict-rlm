def sample_sheet(ws, n_head=8, n_tail=5):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws.title} | rows={max_row}, cols={max_col} ---")
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print("Row 1 headers/values:", headers)
    if max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, max_col+1)]
        print("Row 2 values:", row2)
    head_rows = list(range(1, min(max_row, n_head)+1))
    tail_start = max(1, max_row - n_tail + 1)
    tail_rows = list(range(tail_start, max_row+1))
    printed = set()
    print("Head sample:")
    for r in head_rows:
        printed.add(r)
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(f"R{r}: {vals}")
    print("Tail sample:")
    for r in tail_rows:
        if r in printed:
            continue
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(f"R{r}: {vals}")

for ws in wb.worksheets:
    sample_sheet(ws)

