import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws_data = wb["DATI"]
ws_out = wb["Foglio1"]

# Build source mapping: ID -> list of TOT values in source order
by_id = {}
for r in range(2, ws_data.max_row + 1):
    tot = ws_data.cell(r, 10).value  # J
    idv = ws_data.cell(r, 11).value  # K
    if idv is not None:
        by_id.setdefault(idv, []).append(tot)

print("Source IDs and counts:")
for k in sorted(by_id):
    print(k, len(by_id[k]), "last10:", by_id[k][-10:])

# Inspect target rows before writing
print("\nBefore writing, Foglio1 E:P rows 2:18")
for r in range(2, ws_out.max_row + 1):
    vals = [ws_out.cell(r, c).value for c in range(5, 17)]  # E:P
    print(r, vals)

rows_written = []
rows_skipped_existing = []
rows_skipped_noid = []
rows_skipped_nomatch = []

for r in range(2, ws_out.max_row + 1):
    idv = ws_out.cell(r, 5).value  # E
    target_vals = [ws_out.cell(r, c).value for c in range(7, 17)]  # G:P
    
    if idv is None or idv == "":
        rows_skipped_noid.append(r)
        continue
    
    matches = by_id.get(idv, [])
    if not matches:
        rows_skipped_nomatch.append((r, idv))
        continue
    
    last10 = matches[-10:]
    # If fewer than 10, right-align under headers 10..1? Need exact pattern unknown.
    # But all relevant IDs here have >=10; still handle gracefully by padding left with blanks.
    if len(last10) < 10:
        last10 = [None] * (10 - len(last10)) + last10
    
    # Preserve pre-existing fully populated example rows if already matching
    if any(v is not None for v in target_vals):
        if target_vals == last10:
            rows_skipped_existing.append(r)
            continue
        else:
            # If partially filled or different, overwrite to enforce correct result
            pass
    
    for offset, c in enumerate(range(7, 17)):  # G:P
        ws_out.cell(r, c).value = last10[offset]
    rows_written.append((r, idv, last10))

print("\nRows skipped because already correct:", rows_skipped_existing)
print("Rows skipped because no ID:", rows_skipped_noid)
print("Rows skipped because no matches:", rows_skipped_nomatch)
print("Rows written:")
for item in rows_written:
    print(item)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheet_names and len(wb_check.sheetnames) == len(original_sheet_names):
    for idx, expected_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = expected_name
    wb_check.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verify output values after recalculation
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
ws_verify = wb_verify["Foglio1"]

print("\nVerification: Foglio1 E:P rows 2:18")
for r in range(2, ws_verify.max_row + 1):
    vals = [ws_verify.cell(r, c).value for c in range(5, 17)]
    print(r, vals)

# Additional exact verification for all rows with IDs
verification_summary = []
for r in range(2, ws_verify.max_row + 1):
    idv = ws_verify.cell(r, 5).value
    if idv is None or idv == "":
        continue
    actual = [ws_verify.cell(r, c).value for c in range(7, 17)]
    expected = by_id.get(idv, [])[-10:]
