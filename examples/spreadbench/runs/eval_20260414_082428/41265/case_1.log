```repl
import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook again for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Determine actual non-empty rows in relevant columns A:E
def is_nonempty(v):
    return v is not None and str(v).strip() != ""

nonempty_rows = []
for r in range(1, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, 6)]
    if any(is_nonempty(v) for v in row_vals):
        nonempty_rows.append(r)

print("Non-empty rows in A:E:", nonempty_rows)

print("Focused relevant area A1:E10 before changes:")
for r in range(1, 11):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Identify source rows in A:B and target rows in D:E
source_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if is_nonempty(a) and b is not None:
        source_rows.append(r)

target_rows = []
for r in range(2, ws.max_row + 1):
    d = ws.cell(r, 4).value
    if is_nonempty(d):
        target_rows.append(r)

print("Source rows A:B:", source_rows)
print("Target rows D:E:", target_rows)

for r in target_rows:
    print(f"Before write D{r}={ws.cell(r,4).value!r}, E{r}={ws.cell(r,5).value!r}")

# Compute exact whole-word matches (case-insensitive)
# Tokenize keywords as contiguous alphanumeric/underscore words.
word_pattern = re.compile(r"\b\w+\b", flags=re.UNICODE)

def tokenize(text):
    return word_pattern.findall(str(text).lower())

source_data = []
for r in source_rows:
    keyword = ws.cell(r, 1).value
    volume = ws.cell(r, 2).value
    tokens = tokenize(keyword)
    source_data.append((r, keyword, volume, tokens))

print("Parsed source data:")
for item in source_data:
    print(item)

results = {}
matches_detail = {}

for r in target_rows:
    root = str(ws.cell(r, 4).value).strip().lower()
    total = 0
    matched = []
    for src_r, keyword, volume, tokens in source_data:
        if root in tokens:
            vol_num = float(volume) if isinstance(volume, (int, float)) else float(str(volume).strip())
            total += vol_num
            matched.append((src_r, keyword, volume, tokens))
    # preserve integer type when applicable
    if abs(total - round(total)) < 1e-9:
        total = int(round(total))
    results[r] = total
    matches_detail[r] = matched

print("Match details:")
for r in target_rows:
    print(f"Root D{r}={ws.cell(r,4).value!r} -> total {results[r]}; matches={matches_detail[r]}")

# Write results to E for all target rows
for r in target_rows:
    ws.cell(r, 5).value = results[r]

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_status = await recalculate(output_path)
print("Recalculate status:", recalc_status)

# Reload and restore sheet names if recalculate changed them
wb2 = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename by position back to originals
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = orig_name
    wb2.save(output_path)
    print("Restored sheet names:", wb2.sheetnames)

# Verification using data_only
verify_wb = load_workbook(output_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[orig_sheet_names[0]]

print("Verification of target range D1:E5 after save/recalc:")
for r in range(1, 6):
    print(r, [vws.cell(r, c).value for c in range(4, 6)])

# Also verify exact outputs are present and nonblank
verified_targets = {}
for r in target_rows:
    verified_targets[f"E{r}"] = vws.cell(r, 5).value
print("Verified target cells:", verified_targets)

final_output_path = output_path
