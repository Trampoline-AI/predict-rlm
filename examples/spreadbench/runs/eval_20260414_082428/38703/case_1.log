Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Re-open for detailed inspection
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Detailed inspection of target blocks and merged top-left cells:")
for coord in ["H2", "H10", "H11", "H20", "H21", "H24"]:
    cell = ws[coord]
    print(f"{coord}: value={cell.value!r}, data_type={cell.data_type}")

# Print rows 11-20 and 21-24 with columns A:G plus H for target vicinity
for start, end in [(11,20), (21,24)]:
    print(f"\nRows {start}:{end}")
    for r in range(start, end+1):
        vals = [ws.cell(r,c).value for c in range(1,9)]  # A:H
        print(f"Row {r}: {vals}")

# Compute unique counts in requested ranges
ranges = [("E2:E10", "H10", 2, 10), ("E11:E20", "H20", 11, 20), ("E21:E24", "H24", 21, 24)]
computed = {}
for label, out_cell, r1, r2 in ranges:
    values = [ws[f"E{r}"].value for r in range(r1, r2+1)]
    cleaned = [v for v in values if v not in (None, "")]
    uniq = []
    seen = set()
    for v in cleaned:
        if v not in seen:
            seen.add(v)
            uniq.append(v)
    computed[out_cell] = len(uniq)
    print(f"\n{label} values: {cleaned}")
    print(f"{label} unique values ({len(uniq)}): {uniq}")
    print(f"Target {out_cell} currently: {ws[out_cell].value!r}")

# Prepare output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Unmerge all merged cells
merged_ranges = [str(rng) for rng in ws.merged_cells.ranges]
print("\nUnmerging ranges:", merged_ranges)
for rng in merged_ranges:
    ws.unmerge_cells(rng)

# Write counts to exact requested target cells
for out_cell, count in computed.items():
    ws[out_cell] = count

wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_names = wb.sheetnames
if wb_after.sheetnames != orig_names and len(wb_after.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)
    print("Renamed sheets back to original names:", orig_names)

# Verify with data_only
verify_wb = load_workbook(out_path, data_only=True)
verify_ws = verify_wb[orig_names[0]]

print("\nVerification of target cells:")
for cell in ["H10", "H20", "H24"]:
    print(cell, "=", verify_ws[cell].value)

print("\nVerification that merged ranges are gone:", list(load_workbook(out_path)[orig_names[0]].merged_cells.ranges))

output_spreadsheet = out_path
```
