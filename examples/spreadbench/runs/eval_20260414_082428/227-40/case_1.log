import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path, "exists:", os.path.exists(path))

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_col=None):
    if max_col is None:
        max_col = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_col+1)]

for ws in wb.worksheets:
    print("\n--- SHEET ---", ws.title)
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 values/headers:", headers)
    
    # find non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last non-empty rows:", (nonempty_rows[:5], nonempty_rows[-5:] if nonempty_rows else []))
    
    # first 10 non-empty rows
    print("First up to 10 non-empty rows:")
    for r in nonempty_rows[:10]:
        print(r, row_values(ws, r, ws.max_column))
    
    # last 5 non-empty rows
    print("Last up to 5 non-empty rows:")
    for r in nonempty_rows[-5:]:
        print(r, row_values(ws, r, ws.max_column))
    
    # print target range and nearby area
