import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

print("Original sheet names:", wb.sheetnames)
print("Merged ranges:", list(ws.merged_cells.ranges))

# Inspect example area and target area more closely
for r in range(9, 13):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    fmts = [ws.cell(r, c).number_format for c in range(1, 6)]
    print(f"Example row {r} values:", vals, "formats:", fmts)

for r in range(14, 18):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    print(f"Pre-write target row {r}:", vals)

# Build output based on source rows 1:4 structure, deduplicating within each row
source_rows = list(range(1, 5))  # header + 3 data rows as present in the sheet
output_rows = []

for r in source_rows:
    row = [ws.cell(r, c).value for c in range(1, 6)]
    if r == 1:
        output_rows.append(row)
    else:
        seen = set()
        new_row = []
        for idx, val in enumerate(row):
            if idx == 0:  # keep site name always
                new_row.append(val)
                continue
            key = val
            if val is None or val == "":
                new_row.append(val)
            elif key in seen:
                new_row.append(None)
            else:
                seen.add(key)
                new_row.append(val)
        output_rows.append(new_row)

print("Computed output rows:")
for row in output_rows:
    print(row)

# Write to A14:E17
start_row, start_col = 14, 1
for i, row in enumerate(output_rows):
    for j, val in enumerate(row):
        cell = ws.cell(start_row + i, start_col + j)
        cell.value = val

# Save first
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
orig_names = wb.sheetnames
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for s, new_name in zip(wb2.worksheets, orig_names):
        s.title = new_name
    wb2.save(outfile)
    print("Restored sheet names to:", orig_names)

# Verify values after recalculation
wbv = load_workbook(outfile, data_only=True)
wsv = wbv[orig_names[0]]
print("Verified target A14:E17:")
for r in range(14, 18):
    print(r, [wsv.cell(r, c).value for c in range(1, 6)])

output_spreadsheet = outfile
```
