Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Print relevant lookup block and source headers
print("Relevant lookup block H1:I5:")
for r in range(1, 6):
    print(r, ws[f"H{r}"].value, ws[f"I{r}"].value)

print("\nSource table headers A1:E5 and sample rows:")
for r in range(1, 8):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Compute actual Name values from formulas conceptually to confirm Name H row
# We'll derive B values by following the pattern from B2='A'
names = {}
current = ws["B2"].value
names[2] = current
for r in range(3, 26):
    if isinstance(ws[f"B{r}"].value, str) and ws[f"B{r}"].value.startswith("="):
        current = chr(ord(current) + 1)
        names[r] = current
    else:
        current = ws[f"B{r}"].value
        names[r] = current

target_name = ws["I1"].value
matching_rows = []
for r in range(2, 26):
    if names[r] == target_name:
        matching_rows.append((r, ws[f"A{r}"].value, names[r], ws[f"C{r}"].value, ws[f"D{r}"].value, ws[f"E{r}"].value))
print("\nRows matching lookup Name in I1:", target_name, matching_rows)

# Write formula to target range I2:I5 (including example-answer cells so the block is fully formula-driven)
for r in range(2, 6):
    formula = f'=INDEX($A$2:$E$25, MATCH($I$1, $B$2:$B$25, 0), MATCH(H{r}, $A$1:$E$1, 0))'
    print(f"Writing I{r}:", formula, "previous value:", ws[f"I{r}"].value)
    ws[f"I{r}"] = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and restore sheet name if LibreOffice changed it
orig_names = wb.sheetnames[:]
wb_chk = load_workbook(out_path)
print("Post-recalc sheetnames:", wb_chk.sheetnames)
if wb_chk.sheetnames != orig_names:
    for i, old in enumerate(orig_names):
        wb_chk[wb_chk.sheetnames[i]].title = old
    wb_chk.save(out_path)
    print("Restored sheet names to:", orig_names)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
wb_data = load_workbook(out_path, data_only=True)
wsd = wb_data[orig_names[0]]

print("\nVerification I2:I5 formulas and values:")
for r in range(2, 6):
    print(
        f"I{r}",
        "formula=", wsf[f"I{r}"].value,
        "value=", wsd[f"I{r}"].value,
        "header=", wsd[f"H{r}"].value
    )
```
