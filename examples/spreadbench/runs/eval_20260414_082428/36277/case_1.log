```repl
import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_used_range(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # trim trailing fully empty rows/cols a bit more carefully
    last_row = 0
    last_col = 0
    for r in range(1, max_row + 1):
        row_has = False
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if v is not None and v != "":
                row_has = True
                last_col = max(last_col, c)
        if row_has:
            last_row = r
    return last_row or max_row, last_col or max_col

for s in wb.sheetnames:
    ws = wb[s]
    lr, lc = sheet_used_range(ws)
    print(f"\n=== Sheet: {s} used rows={lr}, used cols={lc} ({get_column_letter(lc) if lc else 'n/a'}) ===")
    headers = [ws.cell(1, c).value for c in range(1, lc+1)]
    print("Row1 headers/values:", headers)
    if lr >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, lc+1)]
        print("Row2 values:", headers2)
    # first 10 rows
    print("First rows:")
    for r in range(1, min(lr, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, lc+1)]
        print(r, vals)
    # last 5 rows if beyond first 10
    if lr > 10:
        print("Last rows:")
        for r in range(max(1, lr-4), lr+1):
            vals = [ws.cell(r, c).value for c in range(1, lc+1)]
            print(r, vals)
    # print formulas cells in used range
    formula_cells = []
    for r in range(1, lr+1):
        for c in range(1, lc+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formula_cells[:50], "count=", len(formula_cells))
```
