```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws_in = wb["input"]
ws_out = wb["output"]

def vals(ws, r, c1, c2):
    return [ws.cell(r, c).value for c in range(c1, c2+1)]

# Build transformed rows from input A:H
source_rows = []
for r in range(2, ws_in.max_row + 1):
    row = vals(ws_in, r, 1, 8)
    if any(v is not None for v in row[:7]):  # actual data row
        source_rows.append({
            "rownum": r,
            "date": row[0],
            "stock": row[1],
            "open": row[2],
            "high": row[3],
            "low": row[4],
            "close": row[5],
            "volume": row[6],
            "change": row[7],
        })

def is_negative(x):
    return isinstance(x, (int, float)) and x < 0

transformed = []
i = 0
while i < len(source_rows):
    cur = source_rows[i]
    stock = cur["stock"]
    chg = cur["change"]
    if is_negative(chg):
        j = i
        streak = []
        while j < len(source_rows) and source_rows[j]["stock"] == stock and is_negative(source_rows[j]["change"]):
            streak.append(source_rows[j])
            j += 1
        
        # streak rows are in sheet order: latest date -> oldest date
        latest = streak[0]
        oldest = streak[-1]
        transformed.append([
            latest["date"],          # keep date from first/latest row in sheet
            latest["stock"],
            oldest["open"],          # opening from first date chronologically (oldest row in descending list)
            max(x["high"] for x in streak),
            min(x["low"] for x in streak),
            latest["close"],         # closing from last date chronologically (latest row in descending list)
            sum((x["volume"] or 0) for x in streak),
        ])
        i = j
    else:
        transformed.append([
            cur["date"], cur["stock"], cur["open"], cur["high"], cur["low"], cur["close"], cur["volume"]
        ])
        i += 1

print("Computed transformed row count:", len(transformed))
print("First 10 transformed rows:")
for idx, row in enumerate(transformed[:10], start=2):
    print(idx, row)
print("Last 10 transformed rows:")
for idx, row in enumerate(transformed[-10:], start=max(2, len(transformed)-8)):
    print(idx, row)

# Compare first several rows to existing example in input K:Q
print("\nCompare transformed vs example area on input for first 10 possible rows:")
for n in range(10):
    outrow = n + 2
    calc = transformed[n] if n < len(transformed) else None
    ex = vals(ws_in, outrow, 11, 17)
    print("row", outrow, "calc=", calc, "example=", ex)

# Clear existing output data rows only
for r in range(2, ws_out.max_row + 1):
    for c in range(1, 8):
        ws_out.cell(r, c).value = None

# Ensure headers in output row 1 match the sheet's existing header or source header
headers = vals(ws_out, 1, 1, 7)
if not any(headers):
    headers = vals(ws_in, 1, 1, 7)
    for c, h in enumerate(headers, start=1):
        ws_out.cell(1, c).value = h

# Write transformed rows to output
for r_idx, row in enumerate(transformed, start=2):
    for c_idx, value in enumerate(row, start=1):
        ws_out.cell(r_idx, c_idx).value = value

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
orig_names = ["input", "output"]
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    # rename by position if needed
    for i, expected in enumerate(orig_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Renamed sheets back to:", wb_check.sheetnames)

# Verify with data_only=True
wb_val = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)
wsv = wb_val["output"]
print("Output dimensions:", wsv.max_row, wsv.max_column)
print("Output header:", vals(wsv, 1, 1, 7))
print("Output first 10 rows:")
for r in range(2, min(wsv.max_row, 11) + 1):
    print(r, vals(wsv, r, 1, 7))
print("Output last 10 rows:")
for r in range(max(2, wsv.max_row - 9), wsv.max_row + 1):
    print(r, vals(wsv, r, 1, 7))

output_spreadsheet = outfile
