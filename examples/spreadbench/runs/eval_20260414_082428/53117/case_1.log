import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

print("Instruction:", instruction)
print("\nFull used rows A:G:")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 8)]
    print(r, vals)

# Analyze customer groups and expected output in Python from source data
def norm_customer(v):
    if v is None:
        return None
    s = str(v).strip()
    if s.endswith(".0"):
        s = s[:-2]
    return s

customer_rows = {}
for r in range(2, ws.max_row + 1):
    cust = norm_customer(ws.cell(r, 1).value)
    total = ws.cell(r, 2).value
    country = ws.cell(r, 3).value
    customer_rows.setdefault(cust, []).append((r, total, country, ws.cell(r,4).value))

expected_for_customer = {}
for cust, rows in customer_rows.items():
    non_us = [(total, country, r) for r, total, country, d in rows if country != "US" and isinstance(total, (int, float))]
    if non_us:
        best = max(non_us, key=lambda x: x[0])
        expected_for_customer[cust] = {"max_total": best[0], "country": best[1], "row": best[2]}
    else:
        expected_for_customer[cust] = None

print("\nExpected non-US max country per customer:")
for cust in sorted(expected_for_customer.keys()):
    print(cust, expected_for_customer[cust])

print("\nCheck each row current D vs expected:")
for r in range(2, ws.max_row + 1):
    cust = norm_customer(ws.cell(r,1).value)
    country = ws.cell(r,3).value
    current_d = ws.cell(r,4).value
    expected_d = country if country != "US" else (expected_for_customer[cust]["country"] if expected_for_customer[cust] else None)
    print(r, cust, country, "current D:", current_d, "expected:", expected_d)

# Fill D for all relevant rows, preserving existing correct values
changes = []
for r in range(2, ws.max_row + 1):
    cust = norm_customer(ws.cell(r,1).value)
    country = ws.cell(r,3).value
    if cust is None and country is None:
        continue
    expected_d = country if country != "US" else (expected_for_customer[cust]["country"] if expected_for_customer[cust] else None)
    cell = ws.cell(r, 4)
    if cell.value != expected_d:
        changes.append((r, cell.value, expected_d))
        cell.value = expected_d

print("\nPlanned/applied changes to D:")
for ch in changes:
    print(ch)
print("Total changed rows:", len(changes))

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
orig_sheetnames = wb.sheetnames[:]
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only
verify_wb = load_workbook(out_path, data_only=True)
verify_ws = verify_wb[orig_sheetnames[0]]
