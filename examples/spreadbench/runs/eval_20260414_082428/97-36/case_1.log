import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

inspection = {}

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    
    first_rows = []
    for r in range(1, min(ws.max_row, 10) + 1):
        first_rows.append((r, row_values(ws, r, ws.max_column)))
    last_start = max(1, ws.max_row - 4)
    last_rows = []
    for r in range(last_start, ws.max_row + 1):
        last_rows.append((r, row_values(ws, r, ws.max_column)))
    
    print("First rows sample:")
    for r, vals in first_rows:
        print(r, vals)
    print("Last rows sample:")
    for r, vals in last_rows:
        print(r, vals)
    
    # Search for substring "domestic" case-insensitive
    matches = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and "domestic" in v.lower():
                matches.append((r, c, get_column_letter(c), v))
    print("Matches for 'domestic':", matches[:20], "count=", len(matches))
    
    inspection[ws.title] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
        "first_rows": first_rows,
        "last_rows": last_rows,
        "matches": matches,
    }

print("\nInspection complete.")
```
