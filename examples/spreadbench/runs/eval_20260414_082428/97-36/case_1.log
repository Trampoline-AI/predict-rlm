import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Re-open workbook for editing
wb2 = load_workbook(input_path)
original_sheet_names = wb2.sheetnames[:]
ws = wb2["Sheet1"]

# Find first occurrence of substring 'domestic' scanning row-major from top-left
target_substring = "domestic"
match_row = None
match_cell = None
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if isinstance(v, str) and target_substring in v.lower():
            match_row = r
            match_cell = ws.cell(r, c).coordinate
            break
    if match_row is not None:
        break

print("First match:", match_cell, "row", match_row, "value", ws[match_cell].value if match_cell else None)

if match_row and match_row > 1:
    rows_to_delete = match_row - 1
    print("Deleting rows 1 through", rows_to_delete)
    ws.delete_rows(1, rows_to_delete)
else:
    print("No rows deleted; match not found or already in first row.")

wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate as required
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore any sheet-name changes if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # rename sheets by position back to originals
    for ws_tmp, orig_name in zip(wb_check.worksheets, original_sheet_names):
        ws_tmp.title = orig_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify[original_sheet_names[0]]
print("Verified dimensions:", vws.max_row, "rows x", vws.max_column, "cols")
print("First 5 rows after deletion:")
for r in range(1, min(5, vws.max_row) + 1):
    print(r, [vws.cell(r, c).value for c in range(1, vws.max_column + 1)])
print("Last 5 rows after deletion:")
for r in range(max(1, vws.max_row - 4), vws.max_row + 1):
    print(r, [vws.cell(r, c).value for c in range(1, vws.max_column + 1)])

output_spreadsheet = output_path
