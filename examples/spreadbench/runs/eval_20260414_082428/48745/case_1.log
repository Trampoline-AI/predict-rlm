wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

workbook_summary = {}
for sname in wb.sheetnames:
    ws = wb[sname]
    headers = row_values(ws, 1, ws.max_column)
    workbook_summary[sname] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
    }
    print(f"\n=== Sheet: {sname} ===")
    print("Rows:", ws.max_row, "Cols:", ws.max_column)
    print("Headers row 1:", headers)
    
    sample_first = list(range(1, min(ws.max_row, 10) + 1))
    sample_last = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    sample_rows = []
    seen = set()
    for r in sample_first + sample_last:
        if r not in seen:
            seen.add(r)
            sample_rows.append(r)
    print("Sample rows:")
    for r in sample_rows:
