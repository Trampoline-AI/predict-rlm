```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
ws = wb[orig_sheet_names[0]]

print("Inspect target/output cells in D5:D10 before writing:")
for r in range(5, 11):
    cell = ws[f"D{r}"]
    print(f"D{r}: value={cell.value!r}, data_type={cell.data_type}")

print("\nInspect lookup table G:H:")
lookup = {}
for r in range(5, ws.max_row + 1):
    code = ws.cell(r, 7).value  # G
    grp = ws.cell(r, 8).value   # H
    if code is not None and grp is not None:
        lookup[str(code).strip()] = str(grp).strip()
        print(f"Row {r}: {code!r} -> {grp!r}")

def compute_group_result(text, lookup_map):
    if text is None:
        return None
    s = str(text).strip()
    if s == "":
        return None
    parts = [p.strip() for p in s.split(";") if p is not None and str(p).strip() != ""]
    groups = []
    for p in parts:
        grp = lookup_map.get(p)
        if grp and grp not in groups:
            groups.append(grp)
    # sort ascending by group number if possible, otherwise lexical
    def grp_key(g):
        import re
        m = re.search(r'(\d+)', g)
        return (int(m.group(1)) if m else 10**9, g)
    groups = sorted(groups, key=grp_key)
    if not groups:
        return None
    return ", ".join(groups)

# Preview computed results for all relevant rows
print("\nComputed results preview for C5:C10:")
computed = {}
for r in range(5, ws.max_row + 1):
    source = ws.cell(r, 3).value
    result = compute_group_result(source, lookup)
    computed[r] = result
    print(f"Row {r}: C{r}={source!r} -> {result!r}")

# Write only missing/blank target cells in column D, preserve existing example answers
written_rows = []
for r in range(5, ws.max_row + 1):
    target = ws.cell(r, 4)  # D
    existing = target.value
    if existing is None or str(existing).strip() == "":
        target.value = computed[r]
        written_rows.append(r)

print("\nRows written in column D:", written_rows)
print("Post-write D5:D10:")
for r in range(5, 11):
    print(f"D{r}={ws.cell(r,4).value!r}")

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore sheet names if changed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename by position to original names
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with data_only
wb_val = load_workbook(output_path, data_only=True)
ws_val = wb_val[orig_sheet_names[0]]

print("\nVerification of target cells D5:D10 (data_only):")
for r in range(5, 11):
    print(f"D{r}={ws_val.cell(r,4).value!r}")

print("\nVerification of source-to-output rows:")
for r in range(5, 11):
    print({
        "row": r,
        "C": ws_val.cell(r,3).value,
        "D": ws_val.cell(r,4).value,
        "G": ws_val.cell(r,7).value,
        "H": ws_val.cell(r,8).value,
    })

final_output_path = output_path
