def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # detect headers from first 3 rows
    for hr in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {hr}:", vals)
    # choose likely header row as first non-empty row with >=2 non-empty cells
    header_row = None
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty >= 2:
            header_row = r
            break
    print("Likely header row:", header_row)
    if header_row:
        headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
        print("Headers:", headers)
    # first 10 rows
    top_end = min(ws.max_row, 10)
    print(f"Top sample rows 1-{top_end}:")
    for r in range(1, top_end + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last sample rows {start_last}-{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_summary(ws)
