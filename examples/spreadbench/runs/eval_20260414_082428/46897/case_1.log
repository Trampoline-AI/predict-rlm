import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Inspect exact target/query area and source area
for cell_ref in ["H1","I1","H2","I2","H3","I3","A1","B1","C1","D1"]:
    cell = ws[cell_ref]
    print(cell_ref, "value=", cell.value, "data_type=", cell.data_type)

# Print source data rows A:D
print("\nSource data A1:D15")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])

# Sanity-check expected count in Python
header_to_match = ws["I1"].value
value_to_count = ws["I2"].value
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("\nheaders:", headers)
matched_col = None
for c in range(1, ws.max_column + 1):
    if ws.cell(1, c).value == header_to_match:
        matched_col = c
        break
print("Matched column for header", header_to_match, "=", matched_col, get_column_letter(matched_col) if matched_col else None)

if matched_col:
    values = [ws.cell(r, matched_col).value for r in range(2, ws.max_row + 1)]
    py_count = sum(1 for v in values if v == value_to_count)
    print("Values in matched column:", values)
    print("Python expected count for", value_to_count, "=", py_count)

# Write formula to exact target cell I3
formula = '=COUNTIF(INDEX($A$2:$D$15,0,MATCH(I1,$A$1:$D$1,0)),I2)'
