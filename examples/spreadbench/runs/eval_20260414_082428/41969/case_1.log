import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load original workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Confirm current target cells before modification
print("Before write:")
for cell_ref in ["A6", "B6", "C6"]:
    print(cell_ref, ws[cell_ref].value)

# Write formulas in shifting 3-column groups across row 3 into A6:C6
target_cells = ["A6", "B6", "C6"]
source_ranges = ["A3:C3", "D3:F3", "G3:I3"]

for target, src in zip(target_cells, source_ranges):
    ws[target] = f"=COUNTBLANK({src})"

print("\nAfter write (formulas):")
for cell_ref in target_cells:
    print(cell_ref, ws[cell_ref].value)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc, check sheet names, restore if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename sheets back by position
    for i, original_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verify formulas exist
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("\nVerified formulas:")
for cell_ref in target_cells:
    print(cell_ref, ws_formula[cell_ref].value)

# Verify calculated values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("\nVerified cached values:")
for cell_ref in target_cells:
    print(cell_ref, ws_values[cell_ref].value)

# Sanity check expected values from source ranges
print("\nSource row 3 values by groups:")
for src in source_ranges:
    start, end = src.split(":")
    start_col = ws_values[start].column
    end_col = ws_values[end].column
    vals = [ws_values.cell(3, c).value for c in range(start_col, end_col + 1)]
    print(src, vals)

output_spreadsheet = output_path
