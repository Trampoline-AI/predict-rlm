def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", headers)
    
    # print first 10 rows or all if fewer
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # print last 5 rows if distinct
    start_last = max(1, ws.max_row - 4)
    if start_last <= ws.max_row:
        print(f"Last rows {start_last}:{ws.max_row}:")
        for r in range(start_last, ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}:", vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Inspect target cells/range and nearby area
for ws in wb.worksheets:
    print(f"\nInspecting target area on sheet {ws.title}:")
    for r in range(1, min(ws.max_row, 8) + 1):
        row_vals = []
        for c in range(1, min(ws.max_column, 9) + 1):
            cell = ws.cell(r, c)
            row_vals.append(f"{get_column_letter(c)}{r}={cell.value}")
        print(" | ".join(row_vals))
    print("A6:", ws["A6"].value, "B6:", ws["B6"].value, "C6:", ws["C6"].value)
