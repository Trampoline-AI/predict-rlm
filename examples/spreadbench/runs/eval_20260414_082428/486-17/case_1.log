import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Re-open and inspect exact target area before writing
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Verifying target area A1:B12 before writing:")
for r in range(1, min(ws.max_row, 12) + 1):
    print(r, ws.cell(r, 1).value, ws.cell(r, 2).value)

# Determine actual last row with data in column A
last_a = None
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 1).value not in (None, ""):
        last_a = r
        break
print("Last non-empty row in column A:", last_a)

# Transform A -> B, starting B2, no header
changed = []
for r in range(2, last_a + 1):
    src = ws.cell(r, 1).value
    dest = ws.cell(r, 2)
    if src in (None, ""):
        continue
    s = str(src).strip()
    # Expect 9 digits: 0yyyymmdd
    if len(s) == 9 and s.startswith("0") and s[1:].isdigit():
        formatted = f"{s[1:5]} {s[5:7]} {s[7:9]}"
    else:
        # fallback: preserve if unexpected, but print for review
        formatted = s
        print(f"Unexpected format at A{r}: {src!r}")
    # only write if blank or different
    if dest.value != formatted:
        dest.value = formatted
        changed.append((r, src, formatted))

print("Number of rows written/updated in column B:", len(changed))
print("Sample changed rows:", changed[:10])

# Ensure no header in B1
print("B1 before:", ws["B1"].value)
ws["B1"] = None
print("B1 after set to None:", ws["B1"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename in order if count matches
    if len(wb2.sheetnames) == len(orig_sheet_names):
        for ws_cur, orig_name in zip(wb2.worksheets, orig_sheet_names):
            ws_cur.title = orig_name
        wb2.save(outfile)
        print("Renamed sheets back to original names:", orig_sheet_names)
    else:
        print("WARNING: sheet name count mismatch; cannot safely restore names.")

# Verify with data_only
wbv = load_workbook(outfile, data_only=True)
wsv = wbv[orig_sheet_names[0]]

print("\nVerification of target cells B2:B12:")
for r in range(2, min(last_a, 12) + 1):
    print(f"A{r}={wsv.cell(r,1).value!r} -> B{r}={wsv.cell(r,2).value!r}")

print("\nVerification of last 5 target rows:")
for r in range(max(2, last_a - 4), last_a + 1):
    print(f"A{r}={wsv.cell(r,1).value!r} -> B{r}={wsv.cell(r,2).value!r}")

# Additional sanity checks
blank_targets = [r for r in range(2, last_a + 1) if wsv.cell(r,1).value not in (None, "") and wsv.cell(r,2).value in (None, "")]
print("Blank target count in populated rows:", len(blank_targets))
print("First few blank target rows (if any):", blank_targets[:10])

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
