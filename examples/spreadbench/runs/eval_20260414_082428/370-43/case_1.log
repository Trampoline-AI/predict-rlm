wb = load_workbook(out_path)
ws = wb["Before Insert Row"]

print("Sheet:", ws.title, "max_row:", ws.max_row, "max_col:", ws.max_column)

# Inspect total rows after insertion across more columns
x_rows_now = [r for r in range(7, min(1000, ws.max_row)+1) if str(ws[f"A{r}"].value).strip().upper() == "X"]
print("Current X rows:", x_rows_now)

for r in x_rows_now:
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"\nRow {r} full values/formulas:")
    for c, v in enumerate(vals, start=1):
        if v not in (None, ""):
            print(c, v)

# Determine the last non-empty data row in the block starting at row 5
last_nonempty = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
        last_nonempty = r
print("\nLast non-empty row:", last_nonempty)

# Rebuild formulas in each X row for numeric columns F:T (6:20)
# Sum from the next row down to the row before the next X, or last_nonempty for final group.
for i, r in enumerate(x_rows_now):
    start = r + 1
    end = (x_rows_now[i+1] - 1) if i + 1 < len(x_rows_now) else last_nonempty
    print(f"Repairing row {r}: sum range rows {start}:{end}")
    for c in range(6, ws.max_column + 1):
        col_letter = chr(64 + c) if c <= 26 else None
        existing = ws.cell(r, c).value
        # Only replace cells that had formulas or are in the quarterly/year columns area
        formula = f"=SUM({ws.cell(start, c).coordinate}:{ws.cell(end, c).coordinate})"
        ws.cell(r, c).value = formula
        if c <= 10:
            print(f"  {ws.cell(r,c).coordinate}: {existing} -> {formula}")

# Also inspect row 6 because it contains an existing example formula in A6
