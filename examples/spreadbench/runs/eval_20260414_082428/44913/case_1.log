import os
from openpyxl import load_workbook

# Load original again for writing
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Writing to sheet:", ws.title)
print("Target column D header/current D1:", ws["D1"].value)
print("Rows to process:", 2, "to", ws.max_row)

start_row = 2
end_row = ws.max_row

# Print any existing formulas in D before overwriting
existing_d = [(r, ws.cell(r, 4).value) for r in range(start_row, end_row + 1)]
print("Existing D values before write:", existing_d)

# Keep D1 blank/no header
ws["D1"] = None

# Write formulas in column D using MAX (not MAXIFS)
for r in range(start_row, end_row + 1):
    formula = (
        f'=IF(B{r}=MAX('
        f'INDEX($B${start_row}:$B${end_row},MATCH(A{r},$A${start_row}:$A${end_row},0))'
        f':INDEX($B${start_row}:$B${end_row},MATCH(A{r},$A${start_row}:$A${end_row},0)+COUNTIF($A${start_row}:$A${end_row},A{r})-1)'
        f'),B{r},"")'
    )
    ws.cell(r, 4).value = formula

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # Rename sheets back by position
    for i, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verification: formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("Verified formulas in D2:D13:")
for r in range(1, ws_formula.max_row + 1):
    print(r, ws_formula.cell(r, 1).value, ws_formula.cell(r, 2).value, ws_formula.cell(r, 4).value)

# Verification: recalculated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]
print("Verified cached values in D1:D13:")
for r in range(1, ws_values.max_row + 1):
    print(r, ws_values.cell(r, 4).value)

output_spreadsheet = outfile
