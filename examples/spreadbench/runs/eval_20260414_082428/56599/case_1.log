from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path, "exists:", os.path.exists(path))

wb = load_workbook(path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # detect likely header rows among first 5 rows by non-empty counts
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v is not None and v != "" for v in vals)
        print(f"Row {r} nonempty={nonempty}: {vals}")
    
    # print first 10 and last 5 rows, bounded
    first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, ws.max_column))
    if ws.max_row > 10:
        print("Last rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_values(ws, r, ws.max_column))

