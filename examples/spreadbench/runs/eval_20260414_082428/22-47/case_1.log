import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INSTRUCTION:")
print(instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

def row_vals(ws, r, max_col=None):
    if max_col is None:
        max_col = ws.max_column
    vals = []
    for c in range(1, max_col+1):
        vals.append(ws.cell(r,c).value)
    return vals

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    headers = row_vals(ws, 1, ws.max_column)
    print("Row 1 headers/values:")
    for i, v in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)}1 = {v!r}")
    
    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n+1):
        print(r, row_vals(ws, r, min(ws.max_column, 12)))
    
    # print last 5 rows
    start_last = max(1, ws.max_row-4)
    print(f"\nLast rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row+1):
        print(r, row_vals(ws, r, min(ws.max_column, 12)))
    
    # Focus on relevant columns B, F:H, J
    print("\nFocused columns B, F:H, J for rows 1 to min(20,max_row):")
    for r in range(1, min(20, ws.max_row)+1):
        vals = {
            "B": ws[f"B{r}"].value,
            "F": ws[f"F{r}"].value,
            "G": ws[f"G{r}"].value,
            "H": ws[f"H{r}"].value,
            "J": ws[f"J{r}"].value,
        }
        print(r, vals)
    
    # Print formulas in F:H if any in first 30 rows
    print("\nAny formulas in F:H first 30 rows:")
    found = False
    for r in range(1, min(30, ws.max_row)+1):
        for col in ["F","G","H"]:
            v = ws[f"{col}{r}"].value
            if isinstance(v, str) and v.startswith("="):
                found = True
                print(f"{col}{r}: {v}")
    if not found:
        print("None found")
