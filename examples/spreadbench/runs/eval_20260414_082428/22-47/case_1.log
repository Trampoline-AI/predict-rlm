Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["sheet1"]

def norm(v):
    if v is None:
        return None
    return str(v).strip()

def is_header_row(a, b, c):
    return norm(a) == "ITEM" and norm(b) == "NAME" and norm(c) == "REF"

# Collect helper names from J, skipping header/blank
helper_names = []
seen_helper = set()
for r in range(1, ws.max_row + 1):
    v = ws[f"J{r}"].value
    sv = norm(v)
    if not sv or sv == "LIST":
        continue
    if sv not in seen_helper:
        helper_names.append(sv)
        seen_helper.add(sv)

# Collect unique source rows from A:C in original order
unique_rows = []
seen_pairs = set()
for r in range(1, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    
    if all(v is None for v in (a, b, c)):
        continue
    if is_header_row(a, b, c):
        continue
    if b is None or c is None or str(b).strip() == "" or str(c).strip() == "":
        continue
    
    key = (str(b).strip(), c)
    if key in seen_pairs:
        continue
    seen_pairs.add(key)
    unique_rows.append({"src_row": r, "item": a, "name": str(b).strip(), "ref": c})

print("Helper names:", helper_names)
print("Unique source rows extracted:", len(unique_rows))
for row in unique_rows:
    print(row)

# Build ordered output
if helper_names:
    ordered = []
    used_indices = set()
    for helper_name in helper_names:
        for i, row in enumerate(unique_rows):
            if i in used_indices:
                continue
            if row["name"] == helper_name:
                ordered.append(row)
                used_indices.add(i)
    for i, row in enumerate(unique_rows):
        if i not in used_indices:
            ordered.append(row)
else:
    ordered = sorted(unique_rows, key=lambda x: x["name"])

print("\nFinal ordered rows:")
for i, row in enumerate(ordered, start=1):
    print(i, row)

# Verify target range and clear old output below header in F:H
# We will keep header row 1 and rewrite rows 2..max_row in F:H
for r in range(2, ws.max_row + 1):
    ws[f"F{r}"] = None
    ws[f"G{r}"] = None
    ws[f"H{r}"] = None

# Ensure headers remain correct
ws["F1"] = "ITEM"
ws["G1"] = "NAME"
ws["H1"] = "REF"

# Write output starting at row 2
for idx, row in enumerate(ordered, start=2):
    ws[f"F{idx}"] = idx - 1
    ws[f"G{idx}"] = row["name"]
    ws[f"H{idx}"] = row["ref"]

# Save
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename sheets by position back to originals
    for ws_cur, original_name in zip(wb_after.worksheets, orig_sheetnames):
        ws_cur.title = original_name
    wb_after.save(outfile)
    print("Restored original sheet names:", orig_sheetnames)

# Verification reload with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify["sheet1"]

target_end = 1 + len(ordered)
print("\nVerified output F:H:")
for r in range(1, target_end + 1):
    print(r, vws[f"F{r}"].value, vws[f"G{r}"].value, vws[f"H{r}"].value)

# Check no blanks in required output rows
issues = []
for r in range(2, target_end + 1):
    if vws[f"G{r}"].value in (None, "") or vws[f"H{r}"].value in (None, ""):
        issues.append(r)

print("Blank issue rows:", issues)
print("Output row count:", len(ordered))
print("Expected helper-first names at top:", helper_names)
```
