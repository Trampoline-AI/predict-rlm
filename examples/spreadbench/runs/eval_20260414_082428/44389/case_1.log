```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print current target cells before writing
print("Before writing:")
for r in range(2, ws.max_row + 1):
    print(f"P{r} existing:", ws[f"P{r}"].value)

# Build LibreOffice-safe concatenation formula for Seller column
# Uses O row as the minimum positive value already computed in column O.
for r in range(2, ws.max_row + 1):
    # only populate rows that have a product name / actual data
    if ws.cell(r, 1).value in (None, ""):
        continue

    pieces = []
    for c in range(2, 15):  # B:N
        col = get_column_letter(c)
        header_ref = f"{col}$1"
        cell_ref = f"{col}{r}"
        pieces.append(f'IF({cell_ref}=$O{r},{header_ref}&",","")')
    concat_expr = "&".join(pieces)
    formula = f'=IF($O{r}="","",LEFT({concat_expr},LEN({concat_expr})-1))'
    ws[f"P{r}"] = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    for idx, name in enumerate(orig_sheetnames):
        wb_check.worksheets[idx].title = name
    wb_check.save(output_path)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

print("\nVerification of target cells O:P")
for r in range(2, wsf.max_row + 1):
    print({
        "row": r,
        "O_formula": wsf[f"O{r}"].value.text if hasattr(wsf[f"O{r}"].value, "text") else wsf[f"O{r}"].value,
        "O_value": wsv[f"O{r}"].value,
        "P_formula": wsf[f"P{r}"].value,
        "P_value": wsv[f"P{r}"].value,
    })

# store for submission
final_output_path = output_path
```
