import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
wb = load_workbook(input_path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols+1)]

sheet_info = {}
for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    # Also inspect row 2 in case headers start later
    if ws.max_row >= 2:
        print("Row 2:", row_values(ws, 2, ws.max_column))
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    # print formulas found
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formula cells count:", len(formulas))
    if formulas[:20]:
        print("First formula cells:", [(f"{get_column_letter(c)}{r}", v) for r,c,v in formulas[:20]])
    sheet_info[ws.title] = {"max_row": ws.max_row, "max_column": ws.max_column, "headers": headers, "formulas": formulas}

# save for later use
exploration = sheet_info
