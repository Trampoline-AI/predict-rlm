```repl
import os, copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Border, Side

# Reload clean workbook
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
test_ws = wb["Test"]
master_ws = wb["master"]

def get_rgb(cell):
    fg = cell.fill.fgColor
    if fg.type == "rgb":
        return fg.rgb
    return None

# Collect yellow-filled cells in Test column A, preserving order; remove blanks
yellow_rows = []
for r in range(1, test_ws.max_row + 1):
    cell = test_ws.cell(r, 1)
    if cell.fill.fill_type == "solid" and get_rgb(cell) == "FFFFFF00":
        yellow_rows.append((r, cell.value))

transpose_values = [v for _, v in yellow_rows if v not in (None, "")]
print("Yellow rows in Test!A:", yellow_rows)
print("Transpose values count:", len(transpose_values))
print("Transpose values:", transpose_values)

# Inspect current master row 1 before overwrite
print("Current master row1 before write:", [master_ws.cell(1, c).value for c in range(1, max(master_ws.max_column, 10)+1)])

# Determine border to use: copy from first yellow source cell if it has borders, else thin border
sample_src = test_ws.cell(yellow_rows[0][0], 1) if yellow_rows else test_ws["A1"]
sample_border = copy.copy(sample_src.border)
if not any([sample_border.left.style, sample_border.right.style, sample_border.top.style, sample_border.bottom.style]):
    thin = Side(style="thin", color="000000")
    sample_border = Border(left=thin, right=thin, top=thin, bottom=thin)

yellow_fill = PatternFill(fill_type="solid", fgColor="FFFFFF00")

# Write across master row 1
for idx, val in enumerate(transpose_values, start=1):
    cell = master_ws.cell(1, idx)
    cell.value = val
    cell.fill = copy.copy(yellow_fill)
    cell.border = copy.copy(sample_border)

# Clear remaining old cells to the right within existing used width
existing_width = max(master_ws.max_column, len(transpose_values))
for c in range(len(transpose_values) + 1, existing_width + 1):
    cell = master_ws.cell(1, c)
    cell.value = None
    cell.fill = PatternFill(fill_type=None)
    cell.border = Border()

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    for i, nm in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = nm
    wb_after.save(out_path)
    print("Restored sheet names:", wb_after.sheetnames)

# Verify values with data_only
ver = load_workbook(out_path, data_only=True)
m = ver["master"]
verified_vals = [m.cell(1, c).value for c in range(1, len(transpose_values) + 3)]
print("Verified master row1 values:", verified_vals)

# Verify formatting with normal load
ver_fmt = load_workbook(out_path)
mf = ver_fmt["master"]
fmt_check = []
for c in range(1, len(transpose_values) + 1):
    cell = mf.cell(1, c)
    fmt_check.append((
        cell.coordinate, cell.value, cell.fill.fill_type, get_rgb(cell),
        cell.border.left.style, cell.border.right.style, cell.border.top.style, cell.border.bottom.style
    ))
print("Formatting check:", fmt_check)

output_spreadsheet = out_path
