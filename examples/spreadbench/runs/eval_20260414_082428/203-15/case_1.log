from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

# Reload fresh for inspection
wb = load_workbook(input_spreadsheet)
main_ws = wb["Main"]
out_ws = wb["Output Required"]

print("Output Required dimensions:", out_ws.max_row, out_ws.max_column)

# Inspect headers/value area up to column M to determine intended target columns
print("Output Required row 1 through M:")
print([out_ws.cell(1, c).value for c in range(1, 14)])

print("Output Required rows 1:5 through M:")
for r in range(1, min(5, out_ws.max_row) + 1):
    vals = [out_ws.cell(r, c).value for c in range(1, 14)]
    print(r, vals)

# Print formulas and fills in first few rows/cols
print("\nCell metadata in Output Required A1:M5 (value, fill):")
for r in range(1, min(5, out_ws.max_row) + 1):
    row_meta = []
    for c in range(1, 14):
        cell = out_ws.cell(r, c)
        fill = cell.fill.start_color.rgb if cell.fill and cell.fill.fill_type else None
        row_meta.append((f"{get_column_letter(c)}{r}", cell.value, fill))
    print(row_meta)

# Build grouped staff records from Main
allowance_map = {
    "Basic": "Basic",
    "Housing Allowance": "Housing Allowance",
    "Transport Allowances": "Transport Allowance",
    "Other Allowances": "Other Allowance",
    "Social Allowances": "Social Allowance",
}

records = {}
for r in range(2, main_ws.max_row + 1):
    staff_no = main_ws.cell(r, 1).value
    if staff_no in (None, ""):
        continue
    base = [main_ws.cell(r, c).value for c in range(1, 8)]  # A:G
    desc = main_ws.cell(r, 8).value
    amount = main_ws.cell(r, 9).value
    if staff_no not in records:
        records[staff_no] = {
            "base": base,
            "Basic": None,
            "Housing Allowance": None,
            "Transport Allowance": None,
            "Other Allowance": None,
            "Social Allowance": None,
        }
    mapped = allowance_map.get(desc, desc)
    if mapped in records[staff_no]:
        records[staff_no][mapped] = amount

print("\nGrouped records:")
for k, v in records.items():
    print(k, v)

# Write to existing Output Required sheet
target_headers = [
    main_ws["A1"].value, main_ws["B1"].value, main_ws["C1"].value, main_ws["D1"].value,
    main_ws["E1"].value, main_ws["F1"].value, main_ws["G1"].value,
    "Basic", "Housing Allowance", "Transport Allowance", "Other Allowance", "Social Allowance", "Total"
]
for c, h in enumerate(target_headers, start=1):
    out_ws.cell(1, c).value = h

# Clear old data rows only in target area A:M
for r in range(2, max(out_ws.max_row, len(records)+1) + 1):
    for c in range(1, 14):
        out_ws.cell(r, c).value = None

# Write grouped output
sorted_staff = list(records.keys())
for idx, staff_no in enumerate(sorted_staff, start=2):
    rec = records[staff_no]
    for c, val in enumerate(rec["base"], start=1):
        out_ws.cell(idx, c).value = val
    out_ws.cell(idx, 8).value = rec["Basic"]
    out_ws.cell(idx, 9).value = rec["Housing Allowance"]
    out_ws.cell(idx, 10).value = rec["Transport Allowance"]
    out_ws.cell(idx, 11).value = rec["Other Allowance"]
    out_ws.cell(idx, 12).value = rec["Social Allowance"]
    # Use formula for dynamic total
    out_ws.cell(idx, 13).value = f"=SUM(H{idx}:L{idx})"

print("\nPreview Output Required after writing (in-memory):")
for r in range(1, len(records) + 2):
    print(r, [out_ws.cell(r, c).value for c in range(1, 14)])

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if changed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
orig_names = ["Main", "Output Required"]
if wb_check.sheetnames != orig_names and len(wb_check.sheetnames) == len(orig_names):
    for ws_obj, orig in zip(wb_check.worksheets, orig_names):
        ws_obj.title = orig
    wb_check.save(out_path)
    print("Renamed sheets back to original names.")
else:
    print("No sheet rename needed.")

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify["Output Required"]
print("\nVerified Output Required A1:M10:")
for r in range(1, min(10, vws.max_row) + 1):
    print(r, [vws.cell(r, c).value for c in range(1, 14)])

output_path = out_path
