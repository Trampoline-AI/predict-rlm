import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

ref_value = ws["G2"].value
print("Reference G2:", ref_value)
print("Current H2 before write:", ws["H2"].value)

# Inspect all rows relevant to the condition
matches = []
nonmatches = []
total = 0

for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    vals = [ws.cell(r, c).value for c in range(3, 6)]  # C:E
    row_info = {"row": r, "A": a, "B": b, "C_E": vals}
    if a == ref_value or b == ref_value:
        numeric_vals = [v for v in vals if isinstance(v, (int, float)) and not isinstance(v, bool)]
        row_info["numeric_in_C_to_E"] = numeric_vals
        row_info["row_sum"] = sum(numeric_vals)
        matches.append(row_info)
        total += sum(numeric_vals)
    else:
        nonmatches.append(row_info)

print("Matching rows (A or B == G2):")
for m in matches:
    print(m)

print("Sample nonmatching rows:")
for nm in nonmatches[:5]:
    print(nm)

print("Computed total to place in H2:", total)

# Write result
ws["H2"] = total

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(output_path)
print("Sheet names after recalc reload:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # Rename sheets back positionally
    for i, name in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = name
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]
print("Verified G2:", wsv["G2"].value)
print("Verified H2:", wsv["H2"].value)
