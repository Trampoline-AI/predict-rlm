```repl
import os
from datetime import datetime, date, timedelta
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
wb = load_workbook(input_path)
src = wb["Imported Data"]
dst = wb["Items Older than 30 days"]

# Focused inspection before modifying
print("Destination sheet title:", dst.title)
print("Destination dimensions before:", dst.max_row, dst.max_column)
print("Destination row 1, cols T:Z:", [(get_column_letter(c), dst.cell(1,c).value) for c in range(column_index_from_string("T"), column_index_from_string("Z")+1)])
print("Destination row 2, cols T:Z:", [(get_column_letter(c), dst.cell(2,c).value) for c in range(column_index_from_string("T"), column_index_from_string("Z")+1)])

# Compute max date in source column E and qualifying rows
date_values = []
for r in range(2, src.max_row + 1):
    v = src.cell(r, 5).value
    if isinstance(v, datetime):
        date_values.append(v)
    elif isinstance(v, date):
        date_values.append(datetime.combine(v, datetime.min.time()))
max_date = max(date_values)
threshold = max_date - timedelta(days=30)

matching_rows = []
for r in range(2, src.max_row + 1):
    v = src.cell(r, 5).value
    dt = None
    if isinstance(v, datetime):
        dt = v
    elif isinstance(v, date):
        dt = datetime.combine(v, datetime.min.time())
    if dt is not None and dt < threshold:  # more than 30 days older than max date
        matching_rows.append(r)

print("Max date:", max_date)
print("Threshold (older than):", threshold)
print("Matching source rows:", matching_rows)
for r in matching_rows:
    print("Match row", r, [src.cell(r,c).value for c in range(1, min(src.max_column, 9)+1)], "E format:", src.cell(r,5).number_format)

# Clear destination sheet contents/styles in existing used range first
for row in dst.iter_rows(1, dst.max_row, 1, dst.max_column):
    for cell in row:
        cell.value = None
        cell._style = copy(cell._style)
        cell.number_format = "General"
        cell.fill = copy(cell.fill)
        cell.font = copy(cell.font)
        cell.border = copy(cell.border)
        cell.alignment = copy(cell.alignment)
        cell.protection = copy(cell.protection)

# Copy header + matching rows into destination starting at A1
rows_to_copy = [1] + matching_rows
for out_r, src_r in enumerate(rows_to_copy, start=1):
    for c in range(1, src.max_column + 1):
        s = src.cell(src_r, c)
        d = dst.cell(out_r, c)
        d.value = s.value
        if s.has_style:
            d._style = copy(s._style)
        if s.number_format:
            d.number_format = s.number_format
        if s.font:
            d.font = copy(s.font)
        if s.fill:
            d.fill = copy(s.fill)
        if s.border:
            d.border = copy(s.border)
        if s.alignment:
            d.alignment = copy(s.alignment)
        if s.protection:
            d.protection = copy(s.protection)

# Copy column widths for source columns
for c in range(1, src.max_column + 1):
    col_letter = get_column_letter(c)
    if col_letter in src.column_dimensions:
        dst.column_dimensions[col_letter].width = src.column_dimensions[col_letter].width

# Delete column Z in sheet 2 (which is destination sheet)
print("Before deleting Z, max_column:", dst.max_column, "Z1:", dst["Z1"].value)
dst.delete_cols(column_index_from_string("Z"), 1)
print("After deleting Z, max_column:", dst.max_column)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if changed
wb2 = load_workbook(out_path)
print("Sheet names after recalc/reload:", wb2.sheetnames)
original_names = ["Imported Data", "Items Older than 30 days"]
if wb2.sheetnames != original_names and len(wb2.sheetnames) == len(original_names):
    for i, expected in enumerate(original_names):
        wb2.worksheets[i].title = expected
    wb2.save(out_path)
    print("Renamed sheets back to original names and re-saved.")

# Verification reload
verify = load_workbook(out_path, data_only=False)
verify_data = load_workbook(out_path, data_only=True)
vsrc = verify["Imported Data"]
vdst = verify["Items Older than 30 days"]
vdst_data = verify_data["Items Older than 30 days"]

print("Final sheet names:", verify.sheetnames)
print("Destination final dimensions:", vdst.max_row, vdst.max_column)
print("Destination first 5 rows, first 10 cols:")
for r in range(1, min(vdst.max_row, 5) + 1):
    print(r, [vdst.cell(r,c).value for c in range(1, min(10, vdst.max_column)+1)])

print("Destination column E values/formats for copied rows:")
for r in range(1, len(rows_to_copy)+1):
    print(r, vdst.cell(r,5).value, vdst.cell(r,5).number_format, "| data_only:", vdst_data.cell(r,5).value)

print("Check Z deleted; current Y and Z headers:")
for coord in ["Y1", "Z1"]:
    print(coord, vdst[coord].value if column_index_from_string(coord[0]) <= vdst.max_column else "OUT_OF_RANGE")

output_spreadsheet = out_path
