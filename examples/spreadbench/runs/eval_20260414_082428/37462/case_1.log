import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook normally (with formulas)
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["DATABASE Countries"]

# Target styles requested
fill = PatternFill(fill_type="solid", start_color="FFC7CE", end_color="FFC7CE")
font = Font(color="9C0006", name=ws["F4"].font.name, size=ws["F4"].font.sz,
            bold=ws["F4"].font.bold, italic=ws["F4"].font.italic,
            underline=ws["F4"].font.underline)

# Replace formulas in all Revenue cells F4:F244
revised = []
for r in range(4, ws.max_row + 1):
    if ws.cell(r, 5).value is None and ws.cell(r, 6).value is None:
        continue
    formula = f'=IFERROR(SUMPRODUCT(ISNUMBER(SEARCH(E{r},$A$4:$A$36))*$C$4:$C$36),0)'
    ws.cell(r, 6).value = formula
    ws.cell(r, 6).fill = fill
    ws.cell(r, 6).font = font
    revised.append((r, formula))

# Save before recalc
wb.save(outfile)
print("Saved to:", outfile)
print("Revised formula count:", len(revised))
print("Sample revised formulas:", revised[:5], revised[-5:])

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalc changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for ws_tmp, orig_name in zip(wb2.worksheets, orig_sheetnames):
        ws_tmp.title = orig_name
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)
else:
    print("Sheet names after recalc/load:", wb2.sheetnames)

# Verify formulas exist in the correct target column
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["DATABASE Countries"]
print("\nFormula verification in F:")
for coord in ["F4", "F5", "F6", "F37", "F83", "F244"]:
    c = wsf[coord]
    print(coord, c.value, c.fill.fgColor.rgb if c.fill else None,
          c.font.color.rgb if c.font.color and c.font.color.type == "rgb" else None)

# Verify recalculated values
wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals["DATABASE Countries"]
print("\nValue verification in target cells:")
for coord in ["F4", "F5", "F6", "F37", "F83", "F244"]:
    print(coord, wsv[coord].value)

# Additional sanity checks against known source data
print("\nSanity checks:")
print("A4/C4 source:", wsv["A4"].value, wsv["C4"].value, "=> F row for Afghanistan:", wsv["F4"].value)
print("A5/C5 source:", wsv["A5"].value, wsv["C5"].value, "Country list E43 maybe India:", wsv["E43"].value, "F43:", wsv["F43"].value)
print("Nonblank revised F values among first 15 rows:", [(f"F{r}", wsv[f"F{r}"].value) for r in range(4, 16)])

