from openpyxl import load_workbook
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before changes:")
for r in range(2, ws.max_row + 1):
    print(r, "I=", ws[f"I{r}"].value, "J=", ws[f"J{r}"].value, "J_format=", ws[f"J{r}"].number_format)

# Replace broken RIGHT formulas with true time formulas in existing target column J
for r in range(2, ws.max_row + 1):
    i_val = ws[f"I{r}"].value
    if i_val is not None:
        ws[f"J{r}"] = f"=MOD(I{r},1)"
        ws[f"J{r}"].number_format = "hh:mm:ss AM/PM"

wb.save(output_path)
print("Saved to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    for idx, old_name in enumerate(original_sheetnames):
        wb_check.worksheets[idx].title = old_name
    wb_check.save(output_path)
    print("Restored original sheet names:", original_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification:")
for r in range(2, ws_formula.max_row + 1):
    print(
        f"Row {r}: "
        f"I={ws_formula[f'I{r}'].value!r}, "
        f"J_formula={ws_formula[f'J{r}'].value!r}, "
        f"J_format={ws_formula[f'J{r}'].number_format!r}, "
        f"J_value(data_only)={ws_values[f'J{r}'].value!r}"
    )

output_spreadsheet = output_path
