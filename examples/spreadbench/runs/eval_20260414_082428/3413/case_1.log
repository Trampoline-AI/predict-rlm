import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target area and any existing formulas/values before overwrite
print("Pre-write E3:G6:")
for r in range(3, 7):
    print(r, [ws.cell(r, c).value for c in range(5, 8)])

# Write formulas to G3:G6 only for rows with Dept in E and RU in F
for r in range(3, ws.max_row + 1):
    dept = ws[f"E{r}"].value
    ru = ws[f"F{r}"].value
    if dept is not None and ru is not None:
        ws[f"G{r}"] = (
            f'=IF(COUNTIFS($A$3:$A$7,E{r},$B$3:$B$7,F{r})>0,'
            f'SUMIFS($C$3:$C$7,$A$3:$A$7,E{r},$B$3:$B$7,F{r}),'
            f'SUMIF($A$3:$A$7,E{r},$C$3:$C$7))'
        )

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for i, old_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formulas and cached values
