ws_formula = wb_formula["Sheet1"]
print("Formulas in G3:G6:")
for r in range(3, 7):
    print(f"G{r} formula:", ws_formula[f'G{r}'].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Verified cached values E3:G6:")
