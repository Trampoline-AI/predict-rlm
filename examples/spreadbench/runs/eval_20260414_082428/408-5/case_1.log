import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Extra inspection: nearby rows and computed totals
for r in range(88, 96):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])
for r in range(133, 138):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

data_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    data_rows.append((r, vals))

def is_blank_row(vals):
    return all(v is None or str(v).strip() == "" for v in vals)

def is_zero(v):
    return v in (0, 0.0, "0", "0.0")

zero_rows = []
br1_rows = []
for r, vals in data_rows:
    ref = vals[2] if len(vals) >= 3 else None
    amt = vals[3] if len(vals) >= 4 else None
    matchv = vals[4] if len(vals) >= 5 else None
    if is_zero(matchv):
        zero_rows.append((r, ref, amt, matchv))
    if ref is not None and "BR1 Sales" in str(ref):
        br1_rows.append((r, ref, amt, matchv))

sum_zero_all = sum((amt or 0) for _, ref, amt, matchv in zero_rows if isinstance(amt, (int, float)))
sum_zero_excl_br1 = sum((amt or 0) for _, ref, amt, matchv in zero_rows if isinstance(amt, (int, float)) and "BR1 Sales" not in str(ref))
print("zero row count:", len(zero_rows))
print("BR1 rows:", br1_rows)
print("sum_zero_all:", sum_zero_all)
print("sum_zero_excl_br1:", sum_zero_excl_br1)

# Use the full zero-sum, consistent with existing helper formula in row 137.
target_original_row = br1_rows[0][0]
print("Original target row:", target_original_row, "current D:", ws.cell(target_original_row, 4).value)

# Build filtered dataset:
# keep nonblank rows that are NOT zero rows, plus keep BR1 Sales rows even if zero
filtered = []
for r, vals in data_rows:
    ref = vals[2] if len(vals) >= 3 else None
    matchv = vals[4] if len(vals) >= 5 else None
    blank = is_blank_row(vals)
    keep = False
    if blank:
        keep = False
    elif ref is not None and "BR1 Sales" in str(ref):
        keep = True
    elif is_zero(matchv):
        keep = False
    else:
        keep = True
    if keep:
        filtered.append(vals)

print("Rows kept:", len(filtered), "from original data rows:", len(data_rows))
print("First 10 kept refs:", [row[2] for row in filtered[:10]])
print("Remaining zero rows after filter (preview):", [(row[2], row[4]) for row in filtered if row[4] in (0,0.0,'0','0.0')][:10])

# Find BR1 row within filtered data and update column D
for vals in filtered:
    ref = vals[2] if len(vals) >= 3 else None
    if ref is not None and "BR1 Sales" in str(ref):
        vals[3] = sum_zero_all
        break

# Rewrite sheet from row 2 downward
max_col = ws.max_column
original_max_row = ws.max_row

# clear existing data area
for r in range(2, original_max_row + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = None

# write filtered rows
for i, vals in enumerate(filtered, start=2):
    for c, v in enumerate(vals, start=1):
        ws.cell(i, c).value = v

# Save
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to:", outfile)

# recalculate
