from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from shutil import copy2
import os

# Re-open for final inspection and edit
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
original_sheetnames = wb.sheetnames[:]

print("Pre-write inspection of target cells E7:E16:")
for r in range(7, 17):
    print(
        r,
        {
            "B": ws[f"B{r}"].value,
            "C": ws[f"C{r}"].value,
            "D": ws[f"D{r}"].value,
            "E": ws[f"E{r}"].value,
            "numfmt_E": ws[f"E{r}"].number_format,
            "style_E": ws[f"E{r}"].style_id,
        }
    )

# Use a single formula pattern for all target rows:
# - D has a number and C is blank -> E32
# - C has a number and D is blank -> E31
# - otherwise blank
for r in range(7, 17):
    formula = f'=IF(AND(D{r}<>"",C{r}=""),E32,IF(AND(C{r}<>"",D{r}=""),E31,""))'
    ws[f"E{r}"] = formula

print("\nFormulas written to E7:E16:")
for r in range(7, 17):
    print(f"E{r} =", ws[f"E{r}"].value)

# Save to output path with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename back by index
    for i, old_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = old_name
    wb_after.save(out_path)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formulas in normal workbook
wb_verify_formula = load_workbook(out_path, data_only=False)
wsf = wb_verify_formula[original_sheetnames[0]]

print("\nVerification - formula strings E7:E16:")
for r in range(7, 17):
    print(f"E{r} formula ->", wsf[f"E{r}"].value)

# Verify cached values in data_only workbook
wb_verify_values = load_workbook(out_path, data_only=True)
wsv = wb_verify_values[original_sheetnames[0]]

print("\nVerification - cached values and inputs rows 7:16:")
for r in range(7, 17):
    print(
        f"Row {r}: C={wsv[f'C{r}'].value!r}, D={wsv[f'D{r}'].value!r}, "
        f"E={wsv[f'E{r}'].value!r}"
    )

output_spreadsheet = out_path
print("\nPrepared output_spreadsheet:", output_spreadsheet)
