import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

path = input_spreadsheet
print("\nLoading workbook:", path)
wb = load_workbook(path)

orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find likely header row among first 5 rows: choose row with most non-empty cells
    best_row = 1
    best_count = -1
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        count = sum(v is not None and v != "" for v in vals)
        if count > best_count:
            best_count = count
            best_row = r
    header_row = best_row
    headers = row_values(ws, header_row, ws.max_column)
    print("Likely header row:", header_row)
    print("Headers:")
    for i, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)}{header_row}: {h!r}")
    
    # First 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Print formulas / non-empty cells in used range for first 15 rows
    print("Formulas/non-empty cells in first 15 rows:")
    for r in range(1, min(ws.max_row, 15) + 1):
        cells = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                cells.append(f"{get_column_letter(c)}{r}={v!r}")
        if cells:
            print(" | ".join(cells))
