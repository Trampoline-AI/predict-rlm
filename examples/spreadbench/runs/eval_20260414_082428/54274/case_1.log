Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb2 = load_workbook(infile)
orig_names = wb2.sheetnames[:]
ws = wb2["Sheet1"]

print("Writing formulas to target column G (Points)...")

written = []
for r in range(4, ws.max_row + 1):
    target = ws.cell(r, 2).value   # B
    stretch = ws.cell(r, 3).value  # C
    over = ws.cell(r, 4).value     # D
    total = ws.cell(r, 6).value    # F
    points_cell = ws.cell(r, 7)    # G
    
    # Only write to genuinely populated data rows
    if any(v not in (None, "") for v in [target, stretch, over, total]):
        formula = (
            f'=IF(OR(B{r}="",F{r}=""),"",'
            f'IF(F{r}<=B{r},F{r}/B{r},'
            f'IF(F{r}<C{r},MIN(F{r}/B{r},1.09),'
            f'IF(F{r}=C{r},MIN(F{r}/B{r},1.1),'
            f'IF(F{r}<D{r},MIN(F{r}/B{r},1.19),'
            f'MIN(F{r}/B{r},1.2))))))'
        )
        print(f"Row {r}: existing G{r}={points_cell.value!r} -> {formula}")
        points_cell.value = formula
        points_cell.number_format = '0.00'
        written.append((r, formula))

wb2.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc to verify cached values
wb_check = load_workbook(outfile, data_only=False)
print("Sheet names after recalc:", wb_check.sheetnames)

# If recalculation changed sheet names, rename back once
if wb_check.sheetnames != orig_names:
    print("Sheet names changed; restoring original names...")
    for i, old_name in enumerate(orig_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(outfile)
    wb_check = load_workbook(outfile, data_only=False)
    print("Restored sheet names:", wb_check.sheetnames)

wb_vals = load_workbook(outfile, data_only=True)
ws_formula = wb_check["Sheet1"]
ws_vals = wb_vals["Sheet1"]

print("\nVerification of target cells:")
for r, formula in written:
    print(
        f"G{r} formula:", ws_formula[f"G{r}"].value,
        "| cached value:", ws_vals[f"G{r}"].value
    )

print("\nSanity check source values for row 4:")
for coord in ["B4", "C4", "D4", "E4", "F4", "G4"]:
    print(coord, "formula_wb=", ws_formula[coord].value, "| data_only_wb=", ws_vals[coord].value)

output_spreadsheet = outfile
print("\nPrepared output file:", output_spreadsheet)
```
