def sheet_summary(ws):
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers row 1:", headers)
    
    # Print first 10 rows and last 5 rows
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, max_col + 1)]
    
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_vals(r))
    
    if max_row > 10:
        start_last = max(1, max_row - 4)
        print("Last 5 rows:")
        for r in range(start_last, max_row + 1):
            print(r, row_vals(r))

for ws in wb.worksheets:
    sheet_summary(ws)

# Extra inspection for formulas / potentially designated output columns
for ws in wb.worksheets:
    print(f"\nFormula scan in sheet {ws.title}:")
    found = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                found.append((r, c, v))
    print("Formula count:", len(found))
    for item in found[:20]:
        r, c, v = item
        print(f"  {get_column_letter(c)}{r}: {v}")
