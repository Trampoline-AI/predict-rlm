input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))

# Reload from original input to avoid carrying forward the wrong-target edits
wb = load_workbook(input_path)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

print("Rechecking intended mapping:")
print("Sheet1 headers:", [ws1.cell(1, c).value for c in range(1, ws1.max_column + 1)])
print("Sheet2 headers A:C before:", [ws2.cell(1, c).value for c in range(1, 4)])

print("\nSample key alignment:")
for r in range(2, min(ws2.max_row, 8) + 1):
    key = ws2[f"A{r}"].value
    matches = []
    for r1 in range(2, ws1.max_row + 1):
        if ws1[f"D{r1}"].value == key:
            matches.append((r1, ws1[f"B{r1}"].value, ws1[f"C{r1}"].value))
    print(f"Sheet2 A{r}={key!r} -> matches in Sheet1:", matches)

# Ensure target headers on Sheet2
if ws2["B1"].value in (None, ""):
    ws2["B1"] = "deal name"
ws2["C1"] = "Type"

last1 = ws1.max_row

# Write INDEX/MATCH formulas on Sheet2, using Sheet1 D as match column
for r in range(2, ws2.max_row + 1):
    key = ws2[f"A{r}"].value
    if key in (None, ""):
        continue
    ws2[f"B{r}"] = f'=IFERROR(INDEX(Sheet1!$B$2:$B${last1},MATCH(A{r},Sheet1!$D$2:$D${last1},0)),"")'
    ws2[f"C{r}"] = f'=IFERROR(INDEX(Sheet1!$C$2:$C${last1},MATCH(A{r},Sheet1!$D$2:$D${last1},0)),"")'

# Explicitly clear the previously added Sheet1 E:F output area if present
for r in range(1, ws1.max_row + 1):
    ws1[f"E{r}"].value = None
    ws1[f"F{r}"].value = None

wb.save(output_path)
print("\nSaved corrected workbook to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if needed
