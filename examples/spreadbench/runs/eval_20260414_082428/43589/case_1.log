import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Reload and inspect exact target cells
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing:")
print("A1:", ws["A1"].value, "| B1:", ws["B1"].value)
print("A2:", ws["A2"].value, "| B2:", ws["B2"].value)

# Write formula to count inclusive days from text like "2 to 5"
# start_day = VALUE(TRIM(LEFT(A2,FIND("to",A2)-1)))
# end_day   = VALUE(TRIM(MID(A2,FIND("to",A2)+2,99)))
# result    = end_day - start_day + 1
ws["B2"] = '=VALUE(TRIM(MID(A2,FIND("to",A2)+2,99)))-VALUE(TRIM(LEFT(A2,FIND("to",A2)-1)))+1'

print("Written formula to B2:", ws["B2"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload to ensure sheet names are preserved; if not, rename back
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename sheets back in order
    for i, sname in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = sname
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with cached values
wb_verify = load_workbook(outfile, data_only=False)
ws_verify = wb_verify[orig_sheetnames[0]]
print("Verification formula B2:", ws_verify["B2"].value)

wb_verify_values = load_workbook(outfile, data_only=True)
ws_values = wb_verify_values[orig_sheetnames[0]]
print("Verification cached values:")
print("A2:", ws_values["A2"].value)
print("B2:", ws_values["B2"].value)
