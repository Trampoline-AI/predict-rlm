import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # gather first 10 rows, all columns up to max_column
    rows = list(ws.iter_rows(min_row=1, max_row=min(ws.max_row, 10), values_only=True))
    for i, row in enumerate(rows, start=1):
        print(f"Row {i}:", row)
    if ws.max_row > 10:
        start = max(1, ws.max_row - 4)
        print("Last rows:")
        for r in range(start, ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}:", vals)
    # non-empty headers for first few rows
    for hr in range(1, min(4, ws.max_row) + 1):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Header candidate row {hr}:", vals)

for ws in wb.worksheets:
    sheet_summary(ws)
```
