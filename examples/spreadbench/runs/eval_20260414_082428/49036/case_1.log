```repl
import os, shutil
from openpyxl import load_workbook

# Load workbook again
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Dashboard"]

# Inspect exact current target values before writing
print("Before write:")
for coord in ["B5", "B6", "B8"]:
    cell = ws[coord]
    print(coord, "=", repr(cell.value), "format=", repr(cell.number_format))

# Write formula to B8.
# Parse number before first space from B6 and B5, divide, format as percent, append text.
# Guard against blanks/errors/div-by-zero.
formula_b8 = '=IFERROR(TEXT(VALUE(LEFT(B6,FIND(" ",B6)-1))/VALUE(LEFT(B5,FIND(" ",B5)-1)),"0.00%")&" WIN RATE","")'
ws["B8"] = formula_b8

print("Written formula to B8:", ws["B8"].value)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names and len(wb_post.sheetnames) == len(orig_sheet_names):
    for i, expected in enumerate(orig_sheet_names):
        wb_post.worksheets[i].title = expected
    wb_post.save(outfile)
    print("Restored original sheet names:", orig_sheet_names)

# Verify with formulas
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula["Dashboard"]
print("Verification (formula view):")
for coord in ["B5", "B6", "B8"]:
    print(coord, "=", repr(wsf[coord].value))

# Verify cached results
wb_verify_values = load_workbook(outfile, data_only=True)
wsv = wb_verify_values["Dashboard"]
print("Verification (data_only view):")
for coord in ["B5", "B6", "B8"]:
