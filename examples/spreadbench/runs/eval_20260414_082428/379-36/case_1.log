```repl
import os, math
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheetnames:", orig_sheetnames)
print("Working on sheet:", ws.title)

def is_whole_number(val):
    if val is None:
        return False
    if isinstance(val, bool):
        return False
    if isinstance(val, int):
        return True
    if isinstance(val, float):
        return math.isfinite(val) and val.is_integer()
    try:
        f = float(val)
        return math.isfinite(f) and f.is_integer()
    except Exception:
        return False

# Inspect target cells before modifying
target_rows = []
for r in range(2, ws.max_row + 1):
    e_val = ws.cell(r, 5).value
    if isinstance(e_val, str) and "Georgia Its Tax" in e_val:
        target_rows.append(r)

print("Target rows found:", target_rows)
for r in target_rows:
    print(f"Before row {r}: E={ws.cell(r,5).value!r}, F={ws.cell(r,6).value!r}, H={ws.cell(r,8).value!r}, H_fill={ws.cell(r,8).fill.fill_type}/{ws.cell(r,8).fill.start_color.rgb}")

# Update column E based on column F
changes = []
for r in target_rows:
    f_val = ws.cell(r, 6).value
    new_text = "Georgia WH Tax" if is_whole_number(f_val) else "Georgia Sales Tax"
    old_e = ws.cell(r, 5).value
    if old_e != new_text:
        ws.cell(r, 5).value = new_text
    changes.append((r, old_e, f_val, new_text))

# Clear column H and remove background color for all used rows
no_fill = PatternFill(fill_type=None)
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 8)
    if cell.value is not None or cell.fill.fill_type is not None:
        cell.value = None
        cell.fill = copy(no_fill)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(output_path)
print("Sheetnames after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Renamed sheets back to original:", orig_sheetnames)

# Verify final values
wb_verify = load_workbook(output_path, data_only=False)
wsv = wb_verify[orig_sheetnames[0]]
print("Verification:")
for r, old_e, f_val, expected in changes:
    hcell = wsv.cell(r, 8)
    print(
        f"Row {r}: E={wsv.cell(r,5).value!r} expected={expected!r}; "
        f"F={f_val!r}; H={hcell.value!r}; H_fill_type={hcell.fill.fill_type}; H_start={hcell.fill.start_color.rgb}"
    )

# also verify with data_only view
wb_verify_data = load_workbook(output_path, data_only=True)
wsd = wb_verify_data[orig_sheetnames[0]]
for r, old_e, f_val, expected in changes:
    print(f"Data-only row {r}: E={wsd.cell(r,5).value!r}, H={wsd.cell(r,8).value!r}")

final_output_spreadsheet = output_path
```
