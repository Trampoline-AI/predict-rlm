import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

# Load current output workbook
wb = load_workbook(out_path)
ws = wb["Opportunities"]
data_ws = wb["Data"]

def nonempty_last_row(sheet, col=1):
    last = 0
    for r in range(1, sheet.max_row + 1):
        if sheet.cell(r, col).value not in (None, ""):
            last = r
    return last

data_last = nonempty_last_row(data_ws, 1)
print("Data non-empty rows in col A end at:", data_last)

# Confirm current relevant cells before fixing
for r in [1,2,3]:
    print(
        f"Before row {r}:",
        "D=", ws[f"D{r}"].value,
        "E=", ws[f"E{r}"].value,
        "G=", ws[f"G{r}"].value
    )

# Fix formulas in target column G for rows with stage/revenue data
for r in range(2, ws.max_row + 1):
    stage_val = ws[f"D{r}"].value
    rev_val = ws[f"E{r}"].value
    if stage_val not in (None, "") or rev_val not in (None, ""):
        ws[f"G{r}"] = f'=IF(OR(D{r}="",E{r}=""),"",E{r}*VLOOKUP(D{r},Data!$A$1:$B${data_last},2,FALSE))'

# Save and recalculate
wb.save(out_path)
print("Saved fixed workbook to:", out_path)

recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculation changed them
orig_names = ['Accountants', 'Lawyers', 'IT', 'Inflexion', 'Accountants Info', 'Sheet3', 'Opportunities', 'Data']
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Restored sheet names:", load_workbook(out_path).sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)
wsf = wb_formula["Opportunities"]
wsv = wb_values["Opportunities"]

print("\nVerification:")
for r in [2, 3]:
    print({
        "row": r,
        "stage": wsv[f"D{r}"].value,
        "revenue": wsv[f"E{r}"].value,
        "formula_in_G": wsf[f"G{r}"].value,
        "value_in_G": wsv[f"G{r}"].value
    })

output_spreadsheet = out_path
