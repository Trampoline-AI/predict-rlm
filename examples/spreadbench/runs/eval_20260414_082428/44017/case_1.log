```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import column_index_from_string, get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Data"]

start_row = 14
end_row = ws.max_row
start_col = column_index_from_string("AD")
end_col = column_index_from_string("AO")

# Inspect target rows one more time in a compact way
target_rows = []
for r in range(start_row, end_row + 1):
    # treat as actual data row if it has effective date or any increase % or freq text or base rate
    if any(ws[f"{c}{r}"].value not in (None, "") for c in ["I", "L", "M", "N", "O", "P", "W"]):
        target_rows.append(r)

print("Rows considered for output:", target_rows)

# Build formula pattern
# Blank if no effective date or no base rate; otherwise cumulative phased increases from W
for r in range(start_row, end_row + 1):
    has_data = r in target_rows
    for c in range(start_col, end_col + 1):
        cell = ws.cell(r, c)

        # remove fill so no yellow remains
        cell.fill = PatternFill(fill_type=None)

        if not has_data:
            cell.value = None
            continue

        col_letter = get_column_letter(c)

        formula = (
            f'=IF(OR($L{r}="",$W{r}=""),"",'
            f'IF({col_letter}$9<$L{r},"",'
            f'$W{r}'
            f'*(1+IF($M{r}="",0,$M{r}))'
            f'*(1+IF(AND($N{r}<>"",{col_letter}$9>=DATE(YEAR($L{r}),MONTH($L{r})+$J{r},DAY($L{r}))),$N{r},0))'
            f'*(1+IF(AND($O{r}<>"",{col_letter}$9>=DATE(YEAR($L{r}),MONTH($L{r})+2*$J{r},DAY($L{r}))),$O{r},0))'
            f'*(1+IF(AND($P{r}<>"",{col_letter}$9>=DATE(YEAR($L{r}),MONTH($L{r})+3*$J{r},DAY($L{r}))),$P{r},0))'
            f'))'
        )
        cell.value = formula
        # match nearby rate number formatting if possible
        cell.number_format = ws[f"W{r}"].number_format

# Save
wb.save(output_path)
print("Saved to", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload and restore sheet names if needed
orig_names = wb.sheetnames[:]
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(output_path)
    print("Restored sheet names to:", orig_names)

# Verify formulas and evaluated values
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Data"]
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Data"]

print("\nVerification sample formulas row 14:")
for col in ["AD","AE","AF","AG","AH","AI","AJ","AK","AL","AM","AN","AO"]:
    print(col, wsf[f"{col}14"].value)

print("\nVerification sample computed values rows 14-20:")
for r in range(14, min(20, end_row) + 1):
    vals = {col: wsv[f"{col}{r}"].value for col in ["AD","AE","AF","AG","AH","AI","AJ","AK","AL","AM","AN","AO"]}
    print(r, vals)

print("\nCheck fills cleared in AD:AO rows 14-16:")
for r in range(14, min(16, end_row) + 1):
    fill_info = {}
    for col in ["AD","AE","AF","AG","AH","AI","AJ","AK","AL","AM","AN","AO"]:
        cell = wsf[f"{col}{r}"]
        fill_info[col] = (cell.fill.fill_type, cell.fill.start_color.rgb)
    print(r, fill_info)

# Count blanks/errors in target area for rows with actual data
issues = []
for r in target_rows:
    for col in ["AD","AE","AF","AG","AH","AI","AJ","AK","AL","AM","AN","AO"]:
        v = wsv[f"{col}{r}"].value
        if ws[f"L{r}"].value not in (None, "") and ws[f"W{r}"].value not in (None, ""):
            # can be blank only if month before effective date, so flag only if corresponding header month >= effective date
            hdr = wsv[f"{col}9"].value
            eff = ws[f"L{r}"].value
            if hdr is not None and eff is not None and hdr >= eff and v in (None, ""):
                issues.append((r, col, "blank_when_should_have_value"))

print("\nIssue count:", len(issues))
print("First issues:", issues[:10])
