import os, json, math, statistics
from collections import Counter
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_info = {}

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        headers2 = row_values(ws, 2, ws.max_column)
        print("Row 2:", headers2)
    
    # detect actual last non-empty row
    actual_last = 0
    for r in range(ws.max_row, 0, -1):
        vals = row_values(ws, r, ws.max_column)
        if any(v not in (None, "") for v in vals):
            actual_last = r
            break
    print("Actual last non-empty row:", actual_last)
    
    sample_first_end = min(actual_last, 10)
    print("First rows sample:")
    for r in range(1, sample_first_end + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))
    
    print("Last rows sample:")
    for r in range(max(1, actual_last - 4), actual_last + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))
    
    # column A analysis
    colA_counter = Counter()
    nonempty_a = 0
    matches = []
    for r in range(1, actual_last + 1):
        v = ws.cell(r, 1).value
        if v not in (None, ""):
            nonempty_a += 1
            colA_counter[str(v)] += 1
            if str(v) in {"@9T", "SAL", "T9A"}:
                matches.append(r)
    
    print("Non-empty values in col A:", nonempty_a)
    print("Target counts in col A:", {k: colA_counter.get(k, 0) for k in ['@9T', 'SAL', 'T9A']})
    print("First matching row numbers:", matches[:20])
    if matches:
        print("Sample matching rows:")
        for r in matches[:10]:
            print(r, row_values(ws, r, min(ws.max_column, 8)))
    
    print("Most common col A values:", colA_counter.most_common(15))
    
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "actual_last": actual_last,
        "headers": headers,
        "target_matches": matches,
    }
