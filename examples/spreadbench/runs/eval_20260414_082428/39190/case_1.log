import os, shutil, numbers
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Re-open and inspect more thoroughly
path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]
original_sheet_names = wb.sheetnames[:]

print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)
print("Headers row 1:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Print all relevant rows for A,B,C,F so exact target is verified
print("\nRelevant rows (A,B,C,F):")
for r in range(1, ws.max_row + 1):
    print(r, ws.cell(r,1).value, ws.cell(r,2).value, ws.cell(r,3).value, ws.cell(r,6).value)

# Gather F values actually present in data rows
f_values = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 6).value
    if v is not None and v != "":
        f_values.append(v)
f_set = set(f_values)
print("\nNonblank values in column F:", f_values)
print("Unique F values:", sorted(f_set))

# Determine matching and highlight rows
matching_rows = []
highlight_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a in f_set:
        matching_rows.append(r)
    if isinstance(a, numbers.Number) and isinstance(b, numbers.Number):
        highlight_rows.append(r)

print("Rows where A is present in F:", matching_rows)
print("Rows where A and B are numeric:", highlight_rows)

# Apply changes to existing column C
green_fill = PatternFill(fill_type="solid", start_color="92D050", end_color="92D050")

for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3)
    
    # Write Delete if A appears in F; otherwise leave blank if currently blank
    if a in f_set:
        c.value = "Delete"
    elif c.value in (None, ""):
        c.value = None
    
    # Highlight C in rows where there are numbers in A and B
    if isinstance(a, numbers.Number) and isinstance(b, numbers.Number):
        c.fill = green_fill

# Save to output path with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names and len(wb_check.sheetnames) == len(original_sheet_names):
    for i, name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify with data_only after recalculation
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("\nVerified target cells in column C (rows 1-36):")
for r in range(1, wsv.max_row + 1):
    print(r, wsv.cell(r, 1).value, wsv.cell(r, 2).value, wsv.cell(r, 3).value, wsv.cell(r, 6).value)

# Also verify fill colors from normal workbook
wb_style = load_workbook(out_path)
wss = wb_style[original_sheet_names[0]]
print("\nColumn C fill verification for data rows:")
for r in range(2, wss.max_row + 1):
    fill = wss.cell(r, 3).fill
    color = fill.start_color.rgb if fill and fill.start_color else None
    if r <= 10 or r > wss.max_row - 5:
        print(r, "C=", wss.cell(r,3).value, "fill=", color)

output_spreadsheet = out_path
print("\nFinal output path:", output_spreadsheet)
