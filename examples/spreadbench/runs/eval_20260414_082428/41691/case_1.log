import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load, modify, save
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before fix, B7 formula:", ws["B7"].value)
ws["B7"] = "=VLOOKUP(A7,A1:B5,2,FALSE)"
print("After fix, B7 formula:", ws["B7"].value)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    for i, expected in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify formula and cached value
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)

print("Verified formula in B7:", wb_formula["Sheet1"]["B7"].value)
print("Verified cached value in B7:", wb_values["Sheet1"]["B7"].value)
print("A7 value:", wb_values["Sheet1"]["A7"].value)

# Additional nearby verification
for r in range(1, 8):
    print(r, wb_values["Sheet1"][f"A{r}"].value, wb_values["Sheet1"][f"B{r}"].value)
