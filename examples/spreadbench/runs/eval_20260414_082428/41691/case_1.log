import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def cell_display(v):
    try:
        if hasattr(v, "text"):  # ArrayFormula etc.
            return f"<{type(v).__name__}:{v.text}>"
    except Exception:
        pass
    return v

for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [cell_display(ws.cell(1, c).value) for c in range(1, ws.max_column + 1)]
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = [cell_display(ws.cell(2, c).value) for c in range(1, ws.max_column + 1)]
        print("Row2:", row2)
    # print first up to 10 rows
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n + 1):
        vals = [cell_display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, vals)
    # print last 5 rows if distinct
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            vals = [cell_display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
            print(r, vals)

# Inspect B7 and nearby area on each sheet
for ws in wb.worksheets:
    print(f"\nInspecting target vicinity on sheet {ws.title}")
    for r in range(4, 10):
        row = []
        for c in range(1, 5):  # A:D
            cell = ws.cell(r, c)
            row.append(f"{get_column_letter(c)}{r}={cell_display(cell.value)}")
        print(" | ".join(row))
    print("B7 raw value:", cell_display(ws["B7"].value))
