Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Target area headers and formulas/values:")
for r in range(1, 6):
    vals = []
    for c in range(1, 17):
        cell = ws.cell(r, c)
        v = cell.value
        if isinstance(v, ArrayFormula):
            shown = f"ArrayFormula(text={v.text})"
        else:
            shown = v
        vals.append(shown)
    print(f"Row {r}: {vals}")

print("\nEmployee data rows A:C (all non-empty rows 2:22):")
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    if any(v is not None for v in (a,b,c)):
        print(r, a, b, c)

# determine target cells E2:P2
print("\nCurrent formulas in E2:P2:")
for c in range(5, 17):
    cell = ws.cell(2, c)
    v = cell.value
    if isinstance(v, ArrayFormula):
        print(cell.coordinate, "ArrayFormula", v.text)
    else:
        print(cell.coordinate, v)

# Write corrected formulas into SAME target cells.
# Logic: headcount as of first day of each month = hired on/before month AND (no term date OR term date > month)
for c in range(5, 17):
    col = get_column_letter(c)
    formula = f'=SUMPRODUCT(($A$2:$A$22<={col}$1)*(($B$2:$B$22="")+($B$2:$B$22>{col}$1)))'
    ws.cell(2, c).value = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to", out_path)

# recalc
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload and restore sheet names if needed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != ["Sheet1"]:
    # rename first sheet back if altered
    if len(wb_check.sheetnames) == 1:
        wb_check[wb_check.sheetnames[0]].title = "Sheet1"
        wb_check.save(out_path)
        print("Renamed sheet back to Sheet1")

# Verify formulas and evaluated values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_data = load_workbook(out_path, data_only=True)
ws_data = wb_data["Sheet1"]

print("\nVerified target cells E2:P2:")
for c in range(5, 17):
    col = get_column_letter(c)
    print(col, "header=", ws_data[f"{col}1"].value, "formula=", ws_formula[f"{col}2"].value, "value=", ws_data[f"{col}2"].value)

# Also print row3-row5 values for context after recalc
print("\nContext rows 2:5, cols D:P data_only:")
for r in range(2, 6):
    vals = [ws_data.cell(r, c).value for c in range(4, 17)]
    print(r, vals)
```
