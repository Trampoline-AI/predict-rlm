from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Instruction:", instruction)

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = []
    for c in range(1, max_cols+1):
        vals.append(ws.cell(r, c).value)
    return vals

workbook_info = {}
formula_hits = []

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row 1:", headers1)
    if headers2:
        print("Row 2:", headers2)

    # sample rows first 10 and last 5
    first_end = min(ws.max_row, 10)
    print("First sample rows:")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, ws.max_column))
    if ws.max_row > 10:
        print("Last sample rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_values(ws, r, ws.max_column))

    # scan formulas / relevant strings
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                f = v
                if "SUMPRODUCT" in f.upper() or "E1" in f.upper() or "$A$2:$A$22" in f.upper() or "$B2:$B$22" in f.upper():
                    formula_hits.append((ws.title, cell.coordinate, f))
    workbook_info[ws.title] = {"max_row": ws.max_row, "max_col": ws.max_column}

print("\nFormula hits potentially relevant:")
for hit in formula_hits[:50]:
    print(hit)
print("Total relevant formula hits:", len(formula_hits))
