import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook normally
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target area and current values before writing
print("Before writing, target area D:F rows 2:10")
for r in range(2, 11):
    print(r, ws[f"D{r}"].value, ws[f"E{r}"].value, ws[f"F{r}"].value)

# Identify rows needing output in Track No column
written = []
for r in range(2, ws.max_row + 1):
    album = ws[f"D{r}"].value
    song = ws[f"E{r}"].value
    track = ws[f"F{r}"].value
    if album not in (None, "") and song not in (None, "") and track in (None, ""):
        formula = f'=COUNTIF($D$2:D{r},D{r})'
        ws[f"F{r}"] = formula
        written.append((r, formula))

print("Written formulas:", written)

# Save
wb.save(outfile)
print("Saved to", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation; restore original sheet names if changed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    # rename by position
    for i, expected in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify formulas in normal mode
ws_formula = wb_check["Sheet1"]
print("\nFormulas now in F2:F10:")
for r in range(2, 11):
    print(f"F{r}:", ws_formula[f"F{r}"].value)

# Verify cached values in data_only mode
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]
print("\nVerified values D:F rows 2:10 after recalc:")
for r in range(2, 11):
    print(r, ws_values[f"D{r}"].value, ws_values[f"E{r}"].value, ws_values[f"F{r}"].value)

# Sanity checks
targets = [7, 8, 9, 10]
target_values = {r: ws_values[f"F{r}"].value for r in targets}
print("Target values:", target_values)
assert all(v not in (None, "") for v in target_values.values()), "Some target cells are blank after recalc"

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
