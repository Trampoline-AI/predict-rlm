original_sheet_names = wb.sheetnames[:]

targets = ["99250", "99251", "99252"]
deleted_rows_by_sheet = {}

for s in targets:
    ws = wb[s]
    rows_to_delete = []
    for r in range(6, ws.max_row + 1):
        v = ws.cell(r, 6).value
        if isinstance(v, str) and "to be processed" in v.lower():
            rows_to_delete.append(r)
    deleted_rows_by_sheet[s] = rows_to_delete[:]
    print(f"{s} rows to delete before action: {rows_to_delete}")
    for r in sorted(rows_to_delete, reverse=True):
        ws.delete_rows(r, 1)

wb.save(output_path)
print("Saved modified workbook to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names and len(wb_check.sheetnames) == len(original_sheet_names):
    for idx, orig_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = orig_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verification with formula/value cache
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

def row_vals(ws, r):
    return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]

for s in targets:
    ws = wb_verify[s]
    print(f"\n=== Verification for {s} ===")
