import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload for careful inspection
wb = load_workbook(input_path)
ws = wb["Sheet1"]

print("Inspecting exact target area:")
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(4, 9)]  # D:H
    print(f"Row {r} D:H ->", vals)

print("Specific target cells before write:")
for cell in ["H3", "H4", "H5"]:
    print(cell, "=", ws[cell].value)

# Identify actual data rows: rows with any values in D:G
data_rows = []
for r in range(3, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(4, 8)]
    if any(v is not None for v in row_vals):
        data_rows.append(r)
print("Data rows:", data_rows)

# Formula pattern: return header corresponding to highest value in D:G for that row
# Keep existing plausible values, fill blanks only per instructions.
for r in data_rows:
    target = ws.cell(r, 8)  # H
    current = target.value
    formula = f'=INDEX($D$2:$G$2,1,MATCH(MAX(D{r}:G{r}),D{r}:G{r},0))'
    print(f"Row {r}: current H{r}={current!r}, proposed formula={formula}")
    if current is None or current == "":
        target.value = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_names = wb.sheetnames
if wb_after.sheetnames != orig_names:
    # rename back positionally
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(output_path)
    print("Renamed sheets back to:", orig_names)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["Sheet1"]
print("Verified target cells after recalc (data_only=True):")
for r in data_rows:
    print(f"H{r} =", wsv.cell(r, 8).value)

# Also inspect formulas in normal mode
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formulas/non-formulas in H3:H5 after write:")
for r in data_rows:
    print(f"H{r} formula/raw =", wsf.cell(r, 8).value)
