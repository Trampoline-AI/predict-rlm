```repl
import os, shutil, copy
from openpyxl import load_workbook
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Load workbook
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheetnames:", orig_sheetnames)
print("Sheet1 size:", ws.max_row, ws.max_column)

# Confirm target columns
print("Headers:",
      {col: ws[f"{col}2"].value for col in ["E", "H", "I", "O"]},
      "P2 currently =", ws["P2"].value)

# Determine data rows: rows with a DOB or a name starting from row 3
data_rows = []
for r in range(3, ws.max_row + 1):
    if ws[f"A{r}"].value is not None or ws[f"C{r}"].value is not None:
        data_rows.append(r)
print("Data rows:", data_rows)

# Print existing target formulas/values before modification
for r in data_rows:
    print(f"Before row {r}: E={ws[f'E{r}'].value!r}, O={ws[f'O{r}'].value!r}, P={ws[f'P{r}'].value!r}")

# Fill Expected Result formulas in column E using exact lookup against H:I
# Use bounded range matching actual lookup table rows
lookup_start = 3
lookup_end = 11
for r in data_rows:
    if ws[f"O{r}"].value is not None:
        ws[f"E{r}"] = f'=IFERROR(VLOOKUP(O{r},$H${lookup_start}:$I${lookup_end},2,FALSE),"")'

# Add header for Actual Age in P2
ws["P2"] = "Actual Age"

# Copy header style from O2, then apply required top alignment for header
for attr in ["font", "fill", "border", "number_format", "protection"]:
    setattr(ws["P2"], attr, copy.copy(getattr(ws["O2"], attr)))
ws["P2"].alignment = copy.copy(ws["O2"].alignment)
ws["P2"].alignment = Alignment(
    horizontal=ws["O2"].alignment.horizontal,
    vertical="top",
    text_rotation=ws["O2"].alignment.textRotation,
    wrap_text=ws["O2"].alignment.wrapText,
    shrink_to_fit=ws["O2"].alignment.shrinkToFit,
    indent=ws["O2"].alignment.indent
)

# Populate Actual Age formulas in P, copy fill from O, bold + center-align, whole numbers
for r in data_rows:
    # dynamic whole-year age based on report date and DOB
    if ws[f"C{r}"].value is not None:
        ws[f"P{r}"] = f'=DATEDIF(C{r},$B$1,"Y")'
    else:
        ws[f"P{r}"] = ""

    # copy style from O cell first
    for attr in ["fill", "border", "protection"]:
        setattr(ws[f"P{r}"], attr, copy.copy(getattr(ws[f"O{r}"], attr)))

    # font based on existing font but bold
    pfont = copy.copy(ws[f"O{r}"].font)
    pfont.bold = True
    ws[f"P{r}"].font = pfont

    # center align data cells
    ws[f"P{r}"].alignment = Alignment(
        horizontal="center",
        vertical=ws[f"O{r}"].alignment.vertical if ws[f"O{r}"].alignment.vertical else "top",
        text_rotation=ws[f"O{r}"].alignment.textRotation,
        wrap_text=ws[f"O{r}"].alignment.wrapText,
        shrink_to_fit=ws[f"O{r}"].alignment.shrinkToFit,
        indent=ws[f"O{r}"].alignment.indent
    )

    # whole-number display
    ws[f"P{r}"].number_format = "0"

# Preserve column width by matching O -> P if available
ws.column_dimensions["P"].width = ws.column_dimensions["O"].width

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload after recalc and restore original sheet names if LibreOffice changed them
wb2 = load_workbook(output_path)
print("Sheetnames after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for i, s in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = s
    wb2.save(output_path)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only
wbv = load_workbook(output_path, data_only=True)
wsv = wbv[orig_sheetnames[0]]

print("\nVerification of target cells:")
print("P2 header:", load_workbook(output_path)[orig_sheetnames[0]]["P2"].value)
for r in data_rows:
    e_formula = load_workbook(output_path)[orig_sheetnames[0]][f"E{r}"].value
    p_formula = load_workbook(output_path)[orig_sheetnames[0]][f"P{r}"].value
    e_val = wsv[f"E{r}"].value
    o_val = wsv[f"O{r}"].value
    p_val = wsv[f"P{r}"].value
    print(f"r{r}: O={o_val!r}, E_formula={e_formula!r}, E_value={e_val!r}, P_formula={p_formula!r}, P_value={p_val!r}")

# Verify styles on P
wb_style = load_workbook(output_path)
wss = wb_style[orig_sheetnames[0]]
print("\nStyle verification:")
for coord in ["P2", "P3", "P4"]:
    c = wss[coord]
    print(coord, {
        "value": c.value,
        "bold": c.font.bold,
        "h": c.alignment.horizontal,
        "v": c.alignment.vertical,
        "numfmt": c.number_format,
        "fill_type": c.fill.fill_type
    })

# Keep output_path for submission
final_output_spreadsheet = output_path
print("\nFinal output path:", final_output_spreadsheet)
