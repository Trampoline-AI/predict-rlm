import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload clean workbook for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
print("Original sheet names:", orig_sheet_names)

# Since there is no 'Imported Data' sheet, use the only existing sheet without altering workbook structure.
ws = wb[wb.sheetnames[0]]
print("Operating on sheet:", ws.title)
print("Dimensions before:", ws.max_row, "rows x", ws.max_column, "cols")

# Thorough inspection of target area
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Headers with columns:", [(get_column_letter(c), headers[c-1]) for c in range(1, ws.max_column + 1)])
print("Target column E header:", ws["E1"].value)

def row_vals(r):
    return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]

print("All rows before deletion:")
for r in range(1, ws.max_row + 1):
    print(r, row_vals(r))

# Check current formulas/values in column E and identify rows to delete
rows_to_delete = []
for r in range(2, ws.max_row + 1):
    cell = ws.cell(r, 5)
    val = cell.value
    print(f"Pre-check E{r}: value={val!r}, data_type={cell.data_type}")
    num = None
    if isinstance(val, (int, float)):
        num = float(val)
    else:
        try:
            if val is not None and str(val).strip() != "":
                num = float(str(val).strip())
        except Exception:
            num = None
    if num is not None and num < 1:
        rows_to_delete.append(r)

print("Rows marked for deletion (E < 1):", rows_to_delete)

# Delete bottom-up to preserve indexing
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

print("Dimensions after deletion, before save:", ws.max_row, "rows x", ws.max_column, "cols")
print("Rows after deletion, before save:")
for r in range(1, ws.max_row + 1):
    print(r, row_vals(r))

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc; restore sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed; restoring original names.")
    for i, original_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    wb_after = load_workbook(output_path)

print("Final sheet names:", wb_after.sheetnames)

# Verify with data_only=True after recalculation
