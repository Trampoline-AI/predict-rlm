```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Re-open and inspect the true used rows more carefully
wb = load_workbook(input_spreadsheet)
ws = wb["Contact List"]

def row_vals(r, c1=1, c2=11):
    return [ws.cell(r, c).value for c in range(c1, c2+1)]

nonempty_rows = []
for r in range(1, ws.max_row + 1):
    vals = row_vals(r)
    if any(v is not None for v in vals):
        nonempty_rows.append((r, vals))

print("Non-empty rows in Contact List:")
for r, vals in nonempty_rows:
    print(r, vals)

print("Header row 3 A:K:", row_vals(3))
print("Current formulas/values in J4:J34 where anything in row exists:")
for r in range(4, ws.max_row + 1):
    if any(ws.cell(r, c).value is not None for c in range(1, 12)):
        print(r, "H=", ws[f"H{r}"].value, "I=", ws[f"I{r}"].value, "J=", ws[f"J{r}"].value)

# Determine relevant rows: rows below header where there is any data in A:K
target_rows = []
for r in range(4, ws.max_row + 1):
    if any(ws.cell(r, c).value is not None for c in range(1, 12)):
        target_rows.append(r)

print("Target rows to populate in J:", target_rows)

# Write formula only for relevant rows.
# Logic:
# IF(AND(Hr>=TODAY()-30, Ir="YES"), "HOLD",
#    IF(AND(Hr<TODAY()-30, Ir="YES"), "TOUCH BASE", "NO ACTION"))
# Guard blank H values too; all other cases return NO ACTION per instruction.
for r in target_rows:
    formula = f'=IF(AND(H{r}>=TODAY()-30,I{r}="YES"),"HOLD",IF(AND(H{r}<TODAY()-30,I{r}="YES"),"TOUCH BASE","NO ACTION"))'
    ws[f"J{r}"] = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
orig_names = ["Contact List", "Data"]
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names and len(wb2.sheetnames) == len(orig_names):
    for ws_obj, desired in zip(wb2.worksheets, orig_names):
        ws_obj.title = desired
    wb2.save(out_path)
    print("Renamed sheets back to original names:", wb2.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["Contact List"]
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values["Contact List"]

print("Verification of target J cells:")
for r in target_rows:
    print(
        r,
        "formula:", wsf[f"J{r}"].value,
        "| cached:", wsv[f"J{r}"].value,
        "| H:", wsv[f"H{r}"].value,
        "| I:", wsv[f"I{r}"].value
    )

output_spreadsheet = out_path
