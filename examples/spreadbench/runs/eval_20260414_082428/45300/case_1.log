import os, shutil, re
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original workbook for editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Writing results to Column B on sheet:", ws.title)

# Apply transformation to all relevant rows
written = []
for r in range(1, ws.max_row + 1):
    src = ws.cell(r, 1).value
    tgt = ws.cell(r, 2)
    if src is None or str(src).strip() == "":
        continue
    
    text = str(src)
    if "FT" in text:
        new_text = text.split("FT", 1)[0].rstrip()
    else:
        new_text = text.rstrip()
    
    # Only write because column B is blank; preserve if already populated plausibly
    if tgt.value in (None, ""):
        tgt.value = new_text
    written.append((r, text, new_text))

print("Rows processed:", len(written))
for item in written:
    print(f"Row {item[0]} | A={item[1]!r} | B to write={item[2]!r}")

wb.save(output_path)
print("Saved to:", output_path, os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb_after = load_workbook(output_path)
print("Sheet names after recalc/load:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename back in order
    for ws_cur, orig_name in zip(wb_after.worksheets, original_sheet_names):
        ws_cur.title = orig_name
    wb_after.save(output_path)
    print("Renamed sheets back to original:", original_sheet_names)

# Verify with data_only after recalculation
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify[original_sheet_names[0]]

print("\nVerification of target Column B:")
for r in range(1, vws.max_row + 1):
    a_val = vws.cell(r, 1).value
    b_val = vws.cell(r, 2).value
    print(f"Row {r}: A={a_val!r} | B={b_val!r}")

# Sanity checks
nonblank_b = [r for r in range(1, vws.max_row + 1) if vws.cell(r, 1).value not in (None, "") and vws.cell(r, 2).value not in (None, "")]
print("Nonblank output rows in B:", nonblank_b)
print("Column B count:", len(nonblank_b), "Expected:", sum(1 for r in range(1, vws.max_row + 1) if vws.cell(r, 1).value not in (None, "")))

final_output_spreadsheet = output_path
