import os, json, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def sheet_summary(ws, sample_rows=8):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Determine headers from row 1
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row1:", headers)
    
    # Print first rows
    first_end = min(ws.max_row, sample_rows)
    print(f"First {first_end} rows:")
    for r in range(1, first_end + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Print last 5 rows if enough
    start_last = max(1, ws.max_row - 4)
    if start_last <= ws.max_row:
        print("Last 5 rows:")
        for r in range(start_last, ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(r, vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Inspect column A and B specifically, since instruction says output answer in Column B
for ws in wb.worksheets:
    print(f"\nDetailed A:B preview for sheet {ws.title}")
    for r in range(1, min(ws.max_row, 15) + 1):
        a = ws.cell(r, 1).value
        b = ws.cell(r, 2).value
        print(f"Row {r}: A={a!r}, B={b!r}")

    # existing formulas / examples in column B
    existing_b = []
    for r in range(1, ws.max_row + 1):
        val = ws.cell(r, 2).value
        if val is not None:
            existing_b.append((r, val))
    print("Non-empty B cells (up to first 20):", existing_b[:20])
