import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

print("Inspect target area E:F and source A:B")
for r in range(1, ws.max_row + 1):
    print(f"Row {r}: A={ws[f'A{r}'].value!r}, B={ws[f'B{r}'].value!r}, E={ws[f'E{r}'].value!r}, F={ws[f'F{r}'].value!r}")

print("\nCurrent target cells/formulas:")
for cell in ["F6", "F7", "F8"]:
    print(cell, "value =", ws[cell].value, "data_type =", ws[cell].data_type)

# Compute expected counts in Python to confirm logic before writing formulas
items = [ws["E6"].value, ws["E7"].value, ws["E8"].value]
counts = {item: 0 for item in items if item is not None}
matched_rows = {item: [] for item in counts}
for r in range(2, ws.max_row + 1):  # data rows under headers
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    chosen = b if b not in (None, "") else a
    if chosen in counts:
        counts[chosen] += 1
        matched_rows[chosen].append((r, a, b, chosen))

print("\nPython-checked counts using fallback logic:")
