import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook path:", path)
print("Sheet names:", wb.sheetnames)

def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # detect non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_vals(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last nonempty rows:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    # print first 3 rows as possible headers
    for r in range(1, min(ws.max_row, 5)+1):
        print(f"Row {r}:", row_vals(ws, r, min(ws.max_column, 12)))
    # first 10 non-empty rows
    print("First up to 10 non-empty rows:")
    for r in nonempty_rows[:10]:
        print(f"  r{r}:", row_vals(ws, r, min(ws.max_column, 12)))
    print("Last up to 5 non-empty rows:")
    for r in nonempty_rows[-5:]:
        print(f"  r{r}:", row_vals(ws, r, min(ws.max_column, 12)))
    
    # search for keywords / formulas
    hits = []
    formula_hits = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                if "Expected" in v or "Answer" in v or "count" in v.lower():
                    hits.append((ws.title, f"{get_column_letter(c)}{r}", v))
                if v.startswith("="):
                    formula_hits.append((f"{get_column_letter(c)}{r}", v))
    print("Keyword hits:", hits[:20])
    print("First formula hits:", formula_hits[:20])
