    item = ws[f"E{r}"].value
    if item not in (None, ""):
        formula = f'=COUNTIF($B$2:$B$11,E{r})+COUNTIFS($B$2:$B$11,"",$A$2:$A$11,E{r})'
        print(f"Writing {formula} to F{r}")
        ws[f"F{r}"] = formula

# Save output
