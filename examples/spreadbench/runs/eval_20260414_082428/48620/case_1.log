```repl
import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def display(v):
    if hasattr(v, "text"):  # ArrayFormula etc.
        return f"<{type(v).__name__}: {v.text}>"
    return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # find true used rows/cols roughly
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for c in row:
            if c.value not in (None, ""):
                row_has = True
                nonempty_cols.add(c.column)
        if row_has:
            nonempty_rows.append(row[0].row)
    print("Nonempty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("First nonempty row:", min(nonempty_rows), "Last nonempty row:", max(nonempty_rows))
    if nonempty_cols:
        print("Used columns:", [f"{get_column_letter(c)}" for c in sorted(nonempty_cols)])
    
    # headers: first 3 rows
    for r in range(1, min(ws.max_row, 3)+1):
        vals = [display(ws.cell(r,c).value) for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", vals)
    
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        vals = [display(ws.cell(r,c).value) for c in range(1, ws.max_column+1)]
        print(f"{r}: {vals}")
    
    # last 5 rows
    if ws.max_row > 10:
        print("Last rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            vals = [display(ws.cell(r,c).value) for c in range(1, ws.max_column+1)]
            print(f"{r}: {vals}")
    
    # print formulas in used range
    formulas = []
    for row in ws.iter_rows():
        for c in row:
            v = c.value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((c.coordinate, v))
            elif hasattr(v, "text"):
                formulas.append((c.coordinate, v.text))
    print("Formula cells:", formulas[:20], f"(total {len(formulas)})")
