import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print exact target area before modification
print("Before modification:")
for r in range(1, 6):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])

def is_numeric(v):
    return isinstance(v, (int, float)) and not isinstance(v, bool)

modified = []
# Data rows start at 2 based on headers in row 1
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    
    # preserve existing valid entries; fill only blanks/empty
    if a is None or str(a).strip() == "":
        if is_numeric(c) and not is_numeric(d):
            ws.cell(r, 1).value = "CHEP"
            modified.append((r, "CHEP"))
        elif is_numeric(d) and not is_numeric(c):
            ws.cell(r, 1).value = "LOSCAM"
            modified.append((r, "LOSCAM"))
        elif is_numeric(c) and is_numeric(d):
            # if both are numeric, prefer not to guess; leave unchanged
            modified.append((r, "SKIPPED_BOTH_NUMERIC"))
    else:
        modified.append((r, f"KEPT:{a}"))

print("Modification decisions:", modified)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb2 = load_workbook(output_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheet_names and len(wb2.sheetnames) == len(original_sheet_names):
    for i, expected in enumerate(original_sheet_names):
        wb2.worksheets[i].title = expected
    wb2.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify output after recalculation with cached values
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

print("After modification / verification:")
for r in range(1, 6):
    print(r, [wsv.cell(r, c).value for c in range(1, 5)])

# Explicit target-cell verification
targets = ["A2", "A3", "A4", "A5"]
for cell_ref in targets:
    print(cell_ref, "=", wsv[cell_ref].value)

final_output_spreadsheet = output_path
```
