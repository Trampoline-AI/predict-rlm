import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload cleanly and inspect targets thoroughly
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

orig_max_row = ws.max_row
orig_max_col = ws.max_column

target_cols = []
for c in range(1, orig_max_col + 1):
    v = ws.cell(1, c).value
    if v is not None and "/description" in str(v):
        target_cols.append((c, get_column_letter(c), v))

print("Original sheet names:", orig_sheet_names)
print("Original dimensions:", orig_max_row, "rows x", orig_max_col, "cols")
print("Total target columns:", len(target_cols))
print("First 15 target columns:", target_cols[:15])
print("Last 15 target columns:", target_cols[-15:])

# Print neighboring headers around the first and last few targets to verify exact placement
def neighbor_headers(ws, col_idx, radius=2):
    start = max(1, col_idx - radius)
    end = min(ws.max_column, col_idx + radius)
    return [(get_column_letter(c), ws.cell(1, c).value) for c in range(start, end + 1)]

print("\nNeighbor headers around first 3 targets:")
for c, letter, val in target_cols[:3]:
    print(letter, val, "->", neighbor_headers(ws, c, radius=2))

print("\nNeighbor headers around last 3 targets:")
for c, letter, val in target_cols[-3:]:
    print(letter, val, "->", neighbor_headers(ws, c, radius=2))

# Delete from right to left so indexes remain valid
for c, _, _ in reversed(target_cols):
    ws.delete_cols(c, 1)

new_max_col = ws.max_column
print("\nAfter deletion, dimensions:", ws.max_row, "rows x", new_max_col, "cols")
print("Expected new column count:", orig_max_col - len(target_cols))

# Verify no '/description' headers remain before saving
remaining_matches = []
for c in range(1, ws.max_column + 1):
    v = ws.cell(1, c).value
    if v is not None and "/description" in str(v):
        remaining_matches.append((c, get_column_letter(c), v))

print("Remaining '/description' headers before save:", len(remaining_matches))
print("First 20 headers after deletion:",
      [(get_column_letter(c), ws.cell(1, c).value) for c in range(1, min(20, ws.max_column) + 1)])
print("Last 10 headers after deletion:",
      [(get_column_letter(c), ws.cell(1, c).value) for c in range(max(1, ws.max_column - 9), ws.max_column + 1)])

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and fix sheet names if needed
wb2 = load_workbook(output_path)
print("Sheet names after recalc reload:", wb2.sheetnames)

if wb2.sheetnames != orig_sheet_names:
    # Rename sheets back to original order/names
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = orig_name
    wb2.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Final verification
wb_verify = load_workbook(output_path, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

final_headers = [wsv.cell(1, c).value for c in range(1, wsv.max_column + 1)]
final_matches = [(c, get_column_letter(c), final_headers[c-1]) for c in range(1, len(final_headers)+1)
                 if final_headers[c-1] is not None and "/description" in str(final_headers[c-1])]

print("Final dimensions:", wsv.max_row, "rows x", wsv.max_column, "cols")
print("Final '/description' headers count:", len(final_matches))
print("Final first 20 headers:",
      [(get_column_letter(c), wsv.cell(1, c).value) for c in range(1, min(20, wsv.max_column) + 1)])
print("Final last 10 headers:",
      [(get_column_letter(c), wsv.cell(1, c).value) for c in range(max(1, wsv.max_column - 9), wsv.max_column + 1)])

# Store for submit
final_output_path = output_path
