import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input spreadsheet:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # gather header row candidates
    for hdr_row in [1, 2, 3]:
        if hdr_row <= ws.max_row:
            vals = [ws.cell(hdr_row, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {hdr_row} values:", vals)
    # choose row 1 as initial header display
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Column headers (row 1 assumption):", headers)
    
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Search all cells for relevant keywords and formulas
keywords = ["income", "bonus", "tier", "salary", "earned"]
hits = []
formula_hits = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                low = v.lower()
                if any(k in low for k in keywords):
                    hits.append((ws.title, cell.coordinate, v))
                if v.startswith("="):
                    if any(k in low for k in keywords):
                        formula_hits.append((ws.title, cell.coordinate, v))
            elif v is not None and cell.data_type == 'f':
                formula_hits.append((ws.title, cell.coordinate, v))
print("\nKeyword hits:", hits[:100])
print("\nFormula hits (first 50):", formula_hits[:50])
