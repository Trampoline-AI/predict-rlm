```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Reload for a focused inspection
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Focused inspection of target area A4:F10")
for r in range(4, 11):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

# Print exact target cells and any formulas currently present
targets = ["B6","B7","B8","B9","C6","C7","C8","C9","D6","D7","D8","D9","E6","E7","E8","E9","F6","F7","F8","F9","B10","C10","D10","E10","F10"]
print("\nCurrent target cell contents:")
for t in targets:
    print(t, repr(ws[t].value))

# Check example rows against expected tier calculations
def calc_tiers(income):
    t1 = max(min(income, 90000) - 60000, 0) * 0.15
    t2 = max(min(income, 120000) - 90000, 0) * 0.25
    t3 = max(income - 120000, 0) * 0.35
    return t1, t2, t3, t1+t2+t3

print("\nExpected tier amounts from sample incomes:")
for r in range(6, 10):
    income = ws[f"B{r}"].value
    if isinstance(income, (int, float)):
        t1, t2, t3, total = calc_tiers(income)
        print(f"Row {r}, income={income}: expected C={t1}, D={t2}, E={t3}, F={total}")

# Apply formulas to ALL relevant quarter rows (6:9), writing into existing columns C:E.
# Also ensure F has row total formula.
for r in range(6, 10):
    income_ref = f"$B{r}"
    # Tier 1: income over 60000 up to 90000
    ws[f"C{r}"] = f'=MAX(MIN({income_ref},90000)-60000,0)*0.15'
    # Tier 2: income over 90000 up to 120000
    ws[f"D{r}"] = f'=MAX(MIN({income_ref},120000)-90000,0)*0.25'
    # Tier 3: income over 120000
    ws[f"E{r}"] = f'=MAX({income_ref}-120000,0)*0.35'
    # Total per row
    ws[f"F{r}"] = f'=SUM(C{r}:E{r})'

# Keep totals row dynamic too
ws["B10"] = '=SUM(B6:B9)'
ws["C10"] = '=SUM(C6:C9)'
ws["D10"] = '=SUM(D6:D9)'
ws["E10"] = '=SUM(E6:E9)'
ws["F10"] = '=SUM(C10:E10)'

print("\nWritten formulas C6:F10:")
for r in range(6, 11):
    print(r, [ws.cell(r, c).value for c in range(3, 7)])

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and ensure original sheet names preserved
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename back by position
    for i, expected in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_sheet_names[0]]

print("\nVerified values A5:F10 (data_only):")
for r in range(5, 11):
    print(r, [wsv.cell(r, c).value for c in range(1, 7)])

# Print exact target verification
print("\nExact verification for C6:F10:")
for r in range(6, 11):
    print(
        r,
        {
            "C": wsv[f"C{r}"].value,
            "D": wsv[f"D{r}"].value,
            "E": wsv[f"E{r}"].value,
            "F": wsv[f"F{r}"].value,
        },
    )

output_spreadsheet = out_path
