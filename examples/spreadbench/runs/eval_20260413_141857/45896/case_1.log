import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy2(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Volym P5_P6_2023"]
z = wb["ZORD"]

z_start = 2
z_end = z.max_row

# Replace Column I formulas with a direct formula that formats each date before joining.
for r in range(2, ws.max_row + 1):
    formula = (
        f'=_xlfn.TEXTJOIN(",",TRUE,IF(ZORD!$A${z_start}:$A${z_end}=A{r},'
        f'TEXT(ZORD!$C${z_start}:$C${z_end},"DD/MM/YYYY"),""))'
    )
    cell = ws[f"I{r}"]
    cell.value = formula
    # Result is text, so use text-like display format
    cell.number_format = "@"

wb.save(outfile)

# Verify written formulas
wb2 = load_workbook(outfile, data_only=False)
ws2 = wb2["Volym P5_P6_2023"]

print("Saved to:", outfile)
for r in range(2, ws2.max_row + 1):
    c = ws2[f"I{r}"]
    print(r, c.value, c.number_format)

output_spreadsheet = outfile
