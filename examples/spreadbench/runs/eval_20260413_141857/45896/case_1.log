from openpyxl import load_workbook
from collections import defaultdict, Counter
import os

# Check whether duplicate Valid to dates exist per Material in ZORD
wb_check = load_workbook(output_spreadsheet)
z = wb_check["ZORD"]

per_material_dates = defaultdict(list)
for r in range(2, z.max_row + 1):
    mat = z[f"A{r}"].value
    valid_to = z[f"C{r}"].value
    per_material_dates[mat].append(valid_to)

dupe_summary = {}
for mat, dates in per_material_dates.items():
    counts = Counter(dates)
    dups = [d for d, n in counts.items() if n > 1]
    if dups:
        dupe_summary[mat] = dups

print("Materials with duplicate Valid to dates:", len(dupe_summary))
print(dupe_summary)

# Also print the actual ZORD dates for row 2's material to sanity check target behavior
target_mat = wb_check["Volym P5_P6_2023"]["A2"].value
