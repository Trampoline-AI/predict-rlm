import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload original workbook
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

def find_chassis_rows(sheet):
    rows = []
    for r in range(1, sheet.max_row + 1):
        v = sheet.cell(r, 1).value
        if isinstance(v, str) and v.strip() == "Chassis":
            rows.append(r)
    return rows

print("Initial rows:", find_chassis_rows(ws))
handled = 0

# Process top-down, recalculating after each deletion
while True:
    chassis_rows = find_chassis_rows(ws)
    if handled >= len(chassis_rows):
        break
    rr = chassis_rows[handled]
    start_delete = rr - 4
    if start_delete < 1:
        raise ValueError(f"Cannot delete four rows before row {rr}")
    ws.delete_rows(start_delete, 4)
    handled += 1
    print(f"After deletion {handled}, chassis rows:", find_chassis_rows(ws))

wb.save(output_path)
print("Saved:", output_path)

# Verify
wb2 = load_workbook(output_path)
ws2 = wb2[wb2.sheetnames[0]]
final_vals = [ws2.cell(r, 1).value for r in range(1, ws2.max_row + 1)]
print("Final column A:", final_vals)
print("A1/A2/A3/A4:", ws2["A1"].value, ws2["A2"].value, ws2["A3"].value, ws2["A4"].value)

output_spreadsheet = output_path
```
