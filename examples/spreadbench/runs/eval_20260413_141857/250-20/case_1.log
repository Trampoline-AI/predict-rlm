Code:
```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["RNM"]
desired = wb["Desired outcome"]

# Identify nonblank data rows and group by columns B and C
groups = defaultdict(list)
for r in range(2, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, 12)]
    if any(v is not None for v in row_vals):
        key = (ws.cell(r, 2).value, ws.cell(r, 3).value)  # B, C
        groups[key].append(r)

duplicate_groups = {k: v for k, v in groups.items() if len(v) > 1}
print("Duplicate groups found:", duplicate_groups)

# Sum column J into first row of each duplicate group; mark later rows for deletion
rows_to_delete = []
for key, rows in duplicate_groups.items():
    j_sum = 0
    for r in rows:
        val = ws.cell(r, 10).value
        j_sum += val if isinstance(val, (int, float)) else 0
    ws.cell(rows[0], 10).value = j_sum
    rows_to_delete.extend(rows[1:])
    print(f"Group {key}: keep row {rows[0]}, delete {rows[1:]}, summed J={j_sum}")

# Delete duplicate rows from bottom to top
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

wb.save(output_path)
print("Saved to:", output_path)

# Verify by reopening
check_wb = load_workbook(output_path)
check_ws = check_wb["RNM"]
check_desired = check_wb["Desired outcome"]

print("\nVerification of RNM rows 1:18 against Desired outcome rows 1:18")
all_match = True
for r in range(1, min(check_ws.max_row, check_desired.max_row) + 1):
    rnm_vals = [check_ws.cell(r, c).value for c in range(1, 12)]
    des_vals = [check_desired.cell(r, c).value for c in range(1, 12)]
    match = (rnm_vals == des_vals)
    print(r, match, rnm_vals)
    if r <= check_desired.max_row and not match:
        all_match = False

print("All compared rows match desired:", all_match)
print("RNM max_row after processing:", check_ws.max_row)
print("Desired outcome max_row:", check_desired.max_row)
```
