Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import shutil, os

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook and modify
wb2 = load_workbook(input_path)
ws = wb2[wb2.sheetnames[0]]

# Add headers in H and I
ws["H1"] = "Debits"
ws["I1"] = "Credits"

# Populate separated values from column C
for row in range(2, ws.max_row + 1):
    val = ws.cell(row=row, column=3).value  # Column C
    ws.cell(row=row, column=8).value = None
    ws.cell(row=row, column=9).value = None
    
    if isinstance(val, (int, float)) and val is not None:
        if val < 0:
            ws.cell(row=row, column=8).value = abs(val)
        elif val > 0:
            ws.cell(row=row, column=9).value = abs(val)
        # if zero, leave both blank per instruction

wb2.save(output_path)

# Verify saved workbook
verify_wb = load_workbook(output_path, data_only=False)
verify_ws = verify_wb[verify_wb.sheetnames[0]]

print("Saved to:", output_path)
print("Headers H1/I1:", verify_ws["H1"].value, verify_ws["I1"].value)
for r in range(1, verify_ws.max_row + 1):
    vals = [verify_ws.cell(r, c).value for c in range(1, 10)]
    print(r, vals)
```
