Code:
```repl
from openpyxl import load_workbook
from copy import copy
import os
from collections import defaultdict
from datetime import datetime, date

# Re-open fresh workbook for manipulation
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect nonblank rows and relevant columns
nonblank_rows = []
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 7) + 1)]
    if any(v is not None for v in vals):
        nonblank_rows.append((r, vals))

print("Nonblank rows count:", len(nonblank_rows))
for item in nonblank_rows[:15]:
    print(item)

def normalize_date(v):
    if v is None:
        return None
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    if isinstance(v, str):
        s = v.strip()
        if not s:
            return None
        # handle YYYY/MM if present as text
        for fmt in ("%Y/%m", "%Y-%m-%d", "%Y/%m/%d", "%m/%d/%Y"):
            try:
                return datetime.strptime(s, fmt).date()
            except:
                pass
    return None

# Determine data rows: rows with something in A or B or E
data_rows = []
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    e = ws.cell(r, 5).value
    if a is not None or b is not None or e is not None:
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        data_rows.append((r, row_vals, normalize_date(e)))

print("Candidate data rows:", len(data_rows))
print("First few candidate rows:")
for r, vals, e_norm in data_rows[:10]:
    print(r, vals[:7], "normalized E:", e_norm)

# Keep rows with nonblank E and max E per (A,B), keeping ties
groups = defaultdict(list)
for r, vals, e_norm in data_rows:
    a, b = vals[0], vals[1]
    if e_norm is None:
        continue
    groups[(a, b)].append((r, vals, e_norm))

kept = []
for key, items in groups.items():
    max_d = max(x[2] for x in items)
    kept.extend([(r, vals, d) for (r, vals, d) in items if d == max_d])

kept_sorted = sorted(kept, key=lambda x: x[0])

print("Groups:", len(groups))
print("Rows kept:", len(kept_sorted))
print("Kept row numbers:", [x[0] for x in kept_sorted])

# Preserve rows before first candidate data row as-is
first_data_row = min(r for r, _, _ in data_rows) if data_rows else ws.max_row + 1
prefix_rows = []
for r in range(1, first_data_row):
    prefix_rows.append([ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Prepare output path
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

# Build a new workbook by reusing existing workbook object and overwriting sheet contents
# Values-only rewrite is efficient and sufficient for this task.
new_content = prefix_rows + [vals for _, vals, _ in kept_sorted]

# Clear sheet contents
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Write back kept content
for r_idx, row_vals in enumerate(new_content, start=1):
    for c_idx, val in enumerate(row_vals, start=1):
        ws.cell(r_idx, c_idx).value = val

wb.save(out_path)
print("Saved to:", out_path)

# Verify saved workbook
vwb = load_workbook(out_path)
vws = vwb[vwb.sheetnames[0]]
result_rows = []
for r in range(1, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, min(vws.max_column, 7) + 1)]
    if any(v is not None for v in vals):
        result_rows.append((r, vals))
print("Result nonblank rows:", len(result_rows))
for row in result_rows:
    print(row)
```
