```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb2 = load_workbook(infile)
ws = wb2["Edit"]

def formulas_for_row(r):
    rng = f"F{r}:AT{r}"
    hdr = "$F$1:$AT$1"
    # First block start
    b = f'=IF(COUNTIF({rng},"m")=0,"",TIMEVALUE(INDEX({hdr},MATCH("m",{rng},0))))'
    
    # First block end position in F:AT (1-based within the range)
    end1_pos = (
        f'IFERROR('
        f'MATCH("m",{rng},0)+MATCH(TRUE,INDEX(INDEX({rng},MATCH("m",{rng},0)):AT{r}<>"m",0),0)-2,'
        f'MATCH(2,1/({rng}="m"))'
        f')'
    )
    c = f'=IF(COUNTIF({rng},"m")=0,"",TIMEVALUE(INDEX({hdr},{end1_pos})))'
    
    # Second block start position
    start2_pos = (
        f'IFERROR('
        f'({end1_pos})+MATCH("m",INDEX({rng},({end1_pos})+1):AT{r},0),'
        f'""'
        f')'
    )
    d = f'=IF(COUNTIF({rng},"m")<=COUNTIF(INDEX({rng},1):INDEX({rng},{end1_pos}),"m"),"",TIMEVALUE(INDEX({hdr},{start2_pos})))'
    
    # Second block end position
    end2_pos = (
        f'IFERROR('
        f'({start2_pos})+MATCH(TRUE,INDEX(INDEX({rng},{start2_pos}):AT{r}<>"m",0),0)-2,'
        f'MATCH(2,1/({rng}="m"))'
        f')'
    )
    e = f'=IF({start2_pos}="","",TIMEVALUE(INDEX({hdr},{end2_pos})))'
    return b, c, d, e

# Apply formulas to all data rows
for r in range(2, ws.max_row + 1):
    b, c, d, e = formulas_for_row(r)
    ws[f"B{r}"] = b
    ws[f"C{r}"] = c
    ws[f"D{r}"] = d
    ws[f"E{r}"] = e
    for col in "BCDE":
        ws[f"{col}{r}"].number_format = "h:mm"

wb2.save(outfile)
print("Saved formula workbook to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify by reopening with cached values
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Edit"]

def header_time_string_to_serial(v):
    # not needed numerically here; just compare as strings to visible values
    return v

def expected_blocks_for_row(r):
    vals = [ws.cell(r, c).value for c in range(6, 47)]
    hdrs = [ws.cell(1, c).value for c in range(6, 47)]
    blocks = []
    i = 0
    while i < len(vals):
        if vals[i] == "m":
            start = i
            while i + 1 < len(vals) and vals[i + 1] == "m":
                i += 1
            end = i
            blocks.append((hdrs[start], hdrs[end]))
        i += 1
    out = [None, None, None, None]
    if len(blocks) >= 1:
        out[0], out[1] = blocks[0]
    if len(blocks) >= 2:
        out[2], out[3] = blocks[1]
    return out

def fmt_time(v):
    if v is None:
        return None
    # data_only returns datetime.time for time-formatted values after recalc
    try:
        return v.strftime("%H:%M")
    except Exception:
        return str(v)

verification = []
for r in range(2, ws.max_row + 1):
    expected = expected_blocks_for_row(r)
    actual = [wsv[f"{col}{r}"].value for col in "BCDE"]
    verification.append((r, expected, [fmt_time(v) for v in actual]))

for item in verification:
    print(item)

# keep path available for submit
output_path = outfile
