import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Reopen fresh workbook from input
wb2 = load_workbook(input_spreadsheet)
ws4 = wb2["Sheet4"]

# Correct values determined from 3-way match
expected = {
    2: "Match",
    3: "-",
    4: "-",
    5: "Match",
    6: "Match",
    7: "Match",
}

fill = PatternFill(fill_type="solid", fgColor="FF66CC", start_color="FF66CC", end_color="FF66CC")

# Write values and apply requested formatting to K2:K7
for r, val in expected.items():
    cell = ws4[f"K{r}"]
    cell.value = val
    cell.fill = fill
    # preserve existing font characteristics but ensure regular styling
    new_font = copy(cell.font)
    new_font.bold = False
    new_font.italic = False
    cell.font = new_font

# Save to output path with same filename
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb2.save(output_path)

# Verify by reopening
verify_wb = load_workbook(output_path)
verify_ws = verify_wb["Sheet4"]

print("Saved to:", output_path)
for r in range(2, 8):
    c = verify_ws[f"K{r}"]
    print(
        r,
        c.value,
        c.fill.fill_type,
        c.fill.fgColor.rgb,
        c.font.bold,
        c.font.italic,
    )

output_spreadsheet = output_path
```
