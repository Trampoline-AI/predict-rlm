    )

# Build lookup set from CBtrans using columns company, account, xchar
cb_keys = set()
for r in range(2, wscb.max_row + 1):
    company = wscb.cell(r, 1).value   # A
    account = wscb.cell(r, 8).value   # H
    xchar = wscb.cell(r, 11).value    # K
    if company is None and account is None and xchar is None:
        continue
    cb_keys.add((company, account, xchar))

print("Sample lookup keys:", list(cb_keys)[:10])

# Determine expected results for rows 2:7
