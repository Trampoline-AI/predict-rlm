from openpyxl.styles import PatternFill

ws4 = wb["Sheet4"]
wscb = wb["CBtrans"]

# Inspect target rows 2:7 in Sheet4
print("Sheet4 rows 2:7 relevant columns:")
for r in range(2, 8):
    vals = {
        "row": r,
        "Company(B)": ws4[f"B{r}"].value,
        "xchar(E)": ws4[f"E{r}"].value,
        "account(I)": ws4[f"I{r}"].value,
        "Result(K)": ws4[f"K{r}"].value,
    }
    print(vals)

# Current styles in K2:K7
