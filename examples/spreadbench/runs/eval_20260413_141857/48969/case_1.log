import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Source 1 ranges
s1_header_row = 2
s1_name_col = 2
s1_date_cols = range(3, 8)
s1_data_rows = range(3, 6)

# Source 2 ranges
s2_header_row = 7
s2_name_col = 2
s2_date_cols = range(3, 8)
s2_data_rows = range(8, 11)

# Result ranges
res_header_row = 2
res_name_col = 9
res_date_cols = range(10, 15)   # J:N
res_data_rows = range(3, 6)     # rows for Source 1 names

# Build Source 1 lookup
source1 = {}
for r in s1_data_rows:
    name = ws.cell(r, s1_name_col).value
    for c in s1_date_cols:
        dt = ws.cell(s1_header_row, c).value
        val = ws.cell(r, c).value
        source1[(name, dt)] = val

# Build Source 2 lookup
source2 = {}
for r in s2_data_rows:
    name = ws.cell(r, s2_name_col).value
    for c in s2_date_cols:
        dt = ws.cell(s2_header_row, c).value
        val = ws.cell(r, c).value
        source2[(name, dt)] = val

# Fill result area: compare Source 1 and Source 2 at matching name/date intersections
for r in res_data_rows:
    name = ws.cell(r, res_name_col).value
    for c in res_date_cols:
        dt = ws.cell(res_header_row, c).value
        v1 = source1.get((name, dt), None)
        has_s2 = (name, dt) in source2
        result = bool(has_s2 and v1 == source2.get((name, dt)))
        ws.cell(r, c).value = result

wb.save(outfile)

# Verify
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb["Sheet1"]
verification = {}
for r in res_data_rows:
    name = check_ws.cell(r, res_name_col).value
    verification[name] = []
    for c in res_date_cols:
        verification[name].append(check_ws.cell(r, c).value)

print("Saved to:", outfile)
print("Verification:")
for k, v in verification.items():
    print(k, v)
```
