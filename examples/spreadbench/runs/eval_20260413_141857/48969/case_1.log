from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Dimensions:", ws.max_row, ws.max_column)
print("Merged ranges:", [str(r) for r in ws.merged_cells.ranges])

# Print all non-empty cells with coordinates
for r in range(1, ws.max_row + 1):
    vals = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None:
            vals.append(f"{get_column_letter(c)}{r}={v!r}")
    print(f"Row {r}:", ", ".join(vals))

# Inspect styles/number formats around headers and result area
coords = ["B1","B2","A2","I1","I2","J2","K2","L2","M2","N2","I3","J3","K3","L3","M3","N3"]
