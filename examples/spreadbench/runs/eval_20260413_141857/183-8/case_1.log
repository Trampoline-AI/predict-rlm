```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Write formulas only in J3:L6
data_start = 3
data_end = 43

for r in range(3, 7):
    fy_ref = f"$H{r}"
    weight_range = f"$C${data_start}:$C${data_end}"
    fy_range = f"$B${data_start}:$B${data_end}"
    
    formulas = {
        10: f'=IFERROR(SUMPRODUCT(({fy_range}={fy_ref})*{weight_range}*$D${data_start}:$D${data_end})/SUMIFS({weight_range},{fy_range},{fy_ref}),0)',
        11: f'=IFERROR(SUMPRODUCT(({fy_range}={fy_ref})*{weight_range}*$E${data_start}:$E${data_end})/SUMIFS({weight_range},{fy_range},{fy_ref}),0)',
        12: f'=IFERROR(SUMPRODUCT(({fy_range}={fy_ref})*{weight_range}*$F${data_start}:$F${data_end})/SUMIFS({weight_range},{fy_range},{fy_ref}),0)',
    }
    for c, formula in formulas.items():
        ws.cell(r, c).value = formula

wb.save(outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Written formulas J3:L6:")
for r in range(3, 7):
    print(r, [ws_check.cell(r, c).value for c in range(10, 13)])

wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals[wb_vals.sheetnames[0]]
print("Cached values J3:L6:")
for r in range(3, 7):
    print(r, [ws_vals.cell(r, c).value for c in range(10, 13)])

output_spreadsheet = outfile
print("Output file:", output_spreadsheet)
```
