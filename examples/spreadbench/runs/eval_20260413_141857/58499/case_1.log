Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Determine source range from the branch list at top (stop at first blank in col A after row 2)
start_row = 2
end_row = start_row
while end_row <= ws.max_row and ws.cell(end_row, 1).value not in (None, ""):
    end_row += 1
end_row -= 1

print("Source rows:", start_row, "to", end_row)

# Output starts below existing header area
output_start = 13
helper_col = 10  # J

# Helper formulas: number only rows with no tick mark in col I
for r in range(start_row, end_row + 1):
    ws.cell(r, helper_col).value = f'=IF($I{r}="",COUNTIF($I${start_row}:$I{r},""),"")'

# List formulas in A13 downward, one row per source row
for idx, r in enumerate(range(output_start, output_start + (end_row - start_row + 1)), start=1):
    ws.cell(r, 1).value = (
        f'=IFERROR(INDEX($A${start_row}:$A${end_row},'
        f'MATCH(ROW(A{idx}),$J${start_row}:$J${end_row},0)),"")'
    )

# Keep helper column hidden so workbook layout stays clean
ws.column_dimensions["J"].hidden = True

wb.save(outfile)
print("Saved:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wbv = load_workbook(outfile, data_only=False)
wsv = wbv["Sheet1"]
print("Formulas A13:A18:", [wsv[f"A{r}"].value for r in range(output_start, output_start + (end_row - start_row + 1))])

wbv2 = load_workbook(outfile, data_only=True)
wsv2 = wbv2["Sheet1"]
print("Values A11:A18:", [wsv2[f"A{r}"].value for r in range(11, output_start + (end_row - start_row + 1))])

output_spreadsheet = outfile
```
