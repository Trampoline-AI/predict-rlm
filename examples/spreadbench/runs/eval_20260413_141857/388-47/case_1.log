Code:
```repl
from openpyxl import load_workbook
import os

wb = load_workbook(input_path)

# Compare sheet contents briefly
ws1 = wb["Sheet1"]
ws2 = wb["Original Data"]

same = True
for r in range(1, max(ws1.max_row, ws2.max_row) + 1):
    for c in range(1, max(ws1.max_column, ws2.max_column) + 1):
        if ws1.cell(r, c).value != ws2.cell(r, c).value:
            same = False
            print("First difference at", r, c, ws1.cell(r, c).value, ws2.cell(r, c).value)
            break
    if not same:
        break
print("Sheets identical before edit:", same)

# Delete rows in Sheet1 where column E starts with Z1 or X1
rows_to_keep = []
for r in range(1, ws1.max_row + 1):
    row_vals = [ws1.cell(r, c).value for c in range(1, ws1.max_column + 1)]
    if r == 1:
        rows_to_keep.append(row_vals)
        continue
    ref = ws1.cell(r, 5).value
    ref_str = str(ref) if ref is not None else ""
    if not (ref_str.startswith("Z1") or ref_str.startswith("X1")):
        rows_to_keep.append(row_vals)

# Rewrite Sheet1 contents cleanly
for r in range(1, ws1.max_row + 1):
    for c in range(1, ws1.max_column + 1):
        ws1.cell(r, c).value = None

for r_idx, row_vals in enumerate(rows_to_keep, start=1):
    for c_idx, val in enumerate(row_vals, start=1):
        ws1.cell(r_idx, c_idx).value = val

# Save
wb.save(output_path)

# Verify
check_wb = load_workbook(output_path)
check_ws1 = check_wb["Sheet1"]
check_refs = [check_ws1.cell(r, 5).value for r in range(1, check_ws1.max_row + 1)]
print("Output saved to:", output_path)
print("Sheet1 rows after edit:", check_ws1.max_row)
print("Sheet1 column E after edit:", check_refs)
print("Any remaining Z1/X1 in Sheet1:", [v for v in check_refs[1:] if str(v).startswith("Z1") or str(v).startswith("X1")])
print("Original Data rows unchanged:", check_wb["Original Data"].max_row)
```
