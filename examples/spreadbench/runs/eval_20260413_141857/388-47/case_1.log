Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reopen the original workbook so we start clean
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Find rows to delete based on column E starting with Z1 or X1
rows_to_delete = []
for r in range(2, ws.max_row + 1):  # skip header
    val = ws.cell(r, 5).value
    s = "" if val is None else str(val)
    if s.startswith("Z1") or s.startswith("X1"):
        rows_to_delete.append(r)

print("Rows to delete in Sheet1:", rows_to_delete)

# Delete bottom-up so row numbers stay valid
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

wb.save(output_path)

# Verify output
check_wb = load_workbook(output_path)
sheet1 = check_wb["Sheet1"]
orig = check_wb["Original Data"]

sheet1_refs = [sheet1.cell(r, 5).value for r in range(1, sheet1.max_row + 1)]
orig_refs = [orig.cell(r, 5).value for r in range(1, orig.max_row + 1)]

print("Saved:", output_path)
print("Sheet1 max_row:", sheet1.max_row)
print("Sheet1 refs:", sheet1_refs)
print("Remaining bad refs in Sheet1:", [v for v in sheet1_refs[1:] if str(v).startswith("Z1") or str(v).startswith("X1")])
print("Original Data max_row:", orig.max_row)
print("Original Data still contains targets:", [v for v in orig_refs[1:] if str(v).startswith("Z1") or str(v).startswith("X1")])
```
