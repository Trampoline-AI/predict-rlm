from openpyxl import load_workbook
import os

outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

# Inspect current output and source values
wb_dbg = load_workbook(outfile, data_only=False)
ws1_dbg = wb_dbg["Sheet1"]
ws2_dbg = wb_dbg["Sheet2"]

print("Sheet2 A1:A20 formulas/values:")
for r in range(1, 21):
    print(r, repr(ws2_dbg.cell(r, 1).value))

print("\nSheet1 A1:B20 formulas:")
for r in range(1, 21):
    print(r, "A", repr(ws1_dbg.cell(r, 1).value), "| B", repr(ws1_dbg.cell(r, 2).value))

wb_dbg_vals = load_workbook(outfile, data_only=True)
ws1_dbgv = wb_dbg_vals["Sheet1"]
print("\nSheet1 computed A2:A20:")
for r in range(2, 21):
    print(r, repr(ws1_dbgv.cell(r, 1).value))
print("\nSheet1 computed B2:B20:")
for r in range(2, 21):
    print(r, repr(ws1_dbgv.cell(r, 2).value))

# If blanks are indeed the issue, rewrite B formulas to explicitly suppress blanks
wb_fix = load_workbook(outfile)
ws1 = wb_fix["Sheet1"]

for r in range(2, 151):
    # Classic legacy unique extraction pattern excluding blanks
    # Uses INDEX(COUNTIF(...)+IF(blank,1,0),0) to create the array for MATCH
    ws1.cell(r, 2).value = (
        f'=IFERROR(INDEX($A$2:$A$150,'
        f'MATCH(0,INDEX(COUNTIF($B$1:B{r-1},$A$2:$A$150)+IF($A$2:$A$150="",1,0),0),0)),"")'
    )

wb_fix.save(outfile)
print("\nRe-saved with blank-excluding formulas.")

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check_vals = load_workbook(outfile, data_only=True)
ws1_check = wb_check_vals["Sheet1"]
print("Computed B2:B20 after fix:", [ws1_check.cell(r, 2).value for r in range(2, 21)])
