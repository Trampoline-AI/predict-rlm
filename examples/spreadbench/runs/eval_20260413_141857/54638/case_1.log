from openpyxl import load_workbook
from openpyxl.styles import Font
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Hide Sheet2 as instructed
ws2.sheet_state = "hidden"

# Remove gridlines where appropriate
ws1.sheet_view.showGridLines = False
ws2.sheet_view.showGridLines = False

# Recreate Sheet1 exactly as it is, but with Calibri font.
# Preserve all other font attributes.
for row in ws1.iter_rows():
    for cell in row:
        if cell.value is not None:
            f = copy(cell.font)
            cell.font = Font(
                name="Calibri",
                sz=f.sz,
                b=f.b,
                i=f.i,
                underline=f.underline,
                strike=f.strike,
                color=f.color.rgb if getattr(f.color, "type", None) == "rgb" else None,
                vertAlign=f.vertAlign,
                outline=f.outline,
                shadow=f.shadow,
                condense=f.condense,
                extend=f.extend,
                charset=f.charset,
                family=f.family,
                scheme=None,
            )

# Preserve/recreate formulas in column A exactly as they are for rows 2:150
for r in range(2, 151):
    ws1.cell(r, 1).value = f'=IF(Sheet2!A{r}="","",Sheet2!A{r})'

# Legacy non-dynamic array-style unique listing formula pattern in B2:B150
# Fill-down version of:
# =IFERROR(INDEX($A$2:$A$150,MATCH(0,COUNTIF($B$1:B1,$A$2:$A$150),0)),"")
for r in range(2, 151):
    formula = f'=IFERROR(INDEX($A$2:$A$150,MATCH(0,COUNTIF($B$1:B{r-1},$A$2:$A$150),0)),"")'
    ws1.cell(r, 2).value = formula

wb.save(outfile)
print("Saved:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
ws1f = wb_check["Sheet1"]
print("Sheet states:", [(ws.title, ws.sheet_state, ws.sheet_view.showGridLines) for ws in wb_check.worksheets])
print("A2 formula:", ws1f["A2"].value)
print("B2 formula:", ws1f["B2"].value)
print("B3 formula:", ws1f["B3"].value)
print("Font A1/A2/B2:", ws1f["A1"].font.name, ws1f["A2"].font.name, ws1f["B2"].font.name)

wb_vals = load_workbook(outfile, data_only=True)
ws1v = wb_vals["Sheet1"]
print("Computed B2:B12:", [ws1v.cell(r, 2).value for r in range(2, 13)])
```
