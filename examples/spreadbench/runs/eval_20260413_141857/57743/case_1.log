Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Determine data bounds
max_row = ws.max_row

# Apply formula in column B for each data row
# Use bounded ranges for compatibility/performance
for r in range(2, max_row + 1):
    formula = f'=IFERROR(INDEX($D$2:$D${max_row},MATCH(A{r},$C$2:$C${max_row},0)),"")'
    ws.cell(r, 2).value = formula

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[wb_formula.sheetnames[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[wb_values.sheetnames[0]]

print("Verification samples:")
for r in range(2, min(max_row, 8) + 1):
    print(
        r,
        "A=", ws_formula.cell(r, 1).value,
        "B_formula=", ws_formula.cell(r, 2).value,
        "B_value=", ws_values.cell(r, 2).value,
        "C=", ws_formula.cell(r, 3).value,
        "D=", ws_formula.cell(r, 4).value,
    )

final_output_path = output_path
```
