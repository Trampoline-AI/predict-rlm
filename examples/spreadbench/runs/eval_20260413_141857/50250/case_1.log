Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("G2 =", ws["G2"].value)
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 9)]
    print(r, vals)

key = ws["G2"].value
total = 0
matched_rows = []
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a == key or b == key:
        row_vals = []
        row_sum = 0
        for c in range(3, 6):  # C:E
            v = ws.cell(r, c).value
            if isinstance(v, (int, float)) and not isinstance(v, bool):
                row_sum += v
                row_vals.append(v)
            else:
                row_vals.append(v)
        total += row_sum
        matched_rows.append((r, a, b, row_vals, row_sum))

print("Matched rows:", matched_rows)
print("Computed total:", total)

out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name

ws["H2"] = total
wb.save(out_path)

# verify
wb2 = load_workbook(out_path, data_only=False)
ws2 = wb2[wb2.sheetnames[0]]
print("Saved H2:", ws2["H2"].value)
print("Output path:", str(out_path))
```
