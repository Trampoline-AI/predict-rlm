Reasoning: I inspected the workbook and found a single sheet with values in rows 1–3 for players A, B, and C across columns B:E, and empty scoring rows 5–7 labeled A, B, and C. The instruction is best interpreted as assigning points separately within each column based on the highest value among the top three rows in that column: sole highest gets 6, two-way tie gets 3 each, three-way tie gets 2 each, others get 0. I’ll write formulas into B5:E7 that compare each corresponding source cell in rows 1–3 against the max of that column and count how many share that max. Then I’ll save to the output directory with the same filename and print the formulas plus calculated expected values for verification.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Write formulas for score rows 5:7 across columns B:E
for col in range(2, 6):  # B:E
    col_letter = ws.cell(1, col).column_letter
    for src_row, dest_row in zip([1, 2, 3], [5, 6, 7]):
        formula = (
            f'=IF({col_letter}{src_row}=MAX({col_letter}$1:{col_letter}$3),'
            f'IF(COUNTIF({col_letter}$1:{col_letter}$3,MAX({col_letter}$1:{col_letter}$3))=1,6,'
            f'IF(COUNTIF({col_letter}$1:{col_letter}$3,MAX({col_letter}$1:{col_letter}$3))=2,3,2)),0)'
        )
        ws.cell(dest_row, col).value = formula

wb.save(outfile)

# Verify formulas written
wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check["Sheet1"]

print("Saved:", outfile)
for r in range(1, 8):
    print(r, [ws_check.cell(r, c).value for c in range(1, 6)])

# Also verify expected outcomes in Python from source values
print("\nExpected point values by column B:E for rows A,B,C:")
for col in range(2, 6):
    vals = [ws_check.cell(r, col).value for r in [1, 2, 3]]
    mx = max(vals)
    count = sum(v == mx for v in vals)
    pts = 6 if count == 1 else 3 if count == 2 else 2
    assigned = [pts if v == mx else 0 for v in vals]
    print(ws_check.cell(1, col).column_letter, vals, "->", assigned)
```
