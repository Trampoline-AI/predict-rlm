import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook and modify the Statement sheet
wb = load_workbook(input_path)
ws = wb["Statement"]

first_invoice_row = None
for r in range(1, ws.max_row + 1):
    v = ws.cell(row=r, column=1).value
    if isinstance(v, str) and v.strip() == "Invoice No.":
        first_invoice_row = r
        break

print("First invoice row found:", first_invoice_row)

if first_invoice_row is None:
    raise ValueError("Could not find 'Invoice No.' in column A of Statement sheet.")

if first_invoice_row > 1:
    ws.delete_rows(1, first_invoice_row - 1)

wb.save(output_path)
print("Saved to:", output_path)

# Verify output
wb_check = load_workbook(output_path)
ws_check = wb_check["Statement"]
print("Verified Statement!A1:", ws_check["A1"].value)
print("Verified Statement dimensions:", ws_check.max_row, "rows x", ws_check.max_column, "cols")
print("First 5 rows col A after change:", [ws_check.cell(row=r, column=1).value for r in range(1, min(5, ws_check.max_row) + 1)])
```
