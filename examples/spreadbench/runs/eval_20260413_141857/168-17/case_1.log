import os
from openpyxl import load_workbook

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
print("Sheet names:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"Sheet '{ws.title}': rows={ws.max_row}, cols={ws.max_column}")
    # Show first 15 values in column A
    vals = [ws.cell(row=r, column=1).value for r in range(1, min(ws.max_row, 15) + 1)]
    print("  First col A values:", vals)

if "Statement" in wb.sheetnames:
    ws = wb["Statement"]
    matches = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(row=r, column=1).value
        if isinstance(v, str) and v.strip() == "Invoice No.":
            matches.append(r)
    print("Statement exact 'Invoice No.' matches in col A:", matches[:20], "count=", len(matches))
    
    # Also show rows around first few non-empty A values
    nonempty = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(row=r, column=1).value
        if v not in (None, ""):
            nonempty.append((r, v))
        if len(nonempty) >= 20:
            break
    print("First 20 non-empty column A cells on Statement:", nonempty)
