Code:
```repl
from openpyxl import load_workbook
from collections import Counter
from pathlib import Path
import os, shutil

# Re-open fresh workbook
input_path = input_spreadsheet
filename = Path(input_path).name
output_path = f"/sandbox/output/output_spreadsheet/{filename}"

wb2 = load_workbook(input_path)
ws = wb2["Sheet1"]
ws_desired = wb2["Desired Results"]

# Inspect whether any other columns contain data
nonempty_by_col = []
for c in range(1, ws.max_column + 1):
    count = sum(1 for r in range(1, ws.max_row + 1) if ws.cell(r, c).value not in (None, ""))
    if count:
        nonempty_by_col.append((c, count, ws.cell(1, c).value))
print("Non-empty columns in Sheet1:", nonempty_by_col)

# Read header and data rows (preserve whole row content in case variable files use more columns)
header = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
data_rows = []
for r in range(2, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v not in (None, "") for v in row_vals):
        data_rows.append(row_vals)

print("Header:", header[:5], "Data rows:", len(data_rows))

# Count frequency using first column
freq = Counter(row[0] for row in data_rows if row[0] not in (None, ""))
print("Frequencies:", freq)

# Sort rows by descending frequency of column A, then alphabetically by item, preserving row content
sorted_rows = sorted(
    data_rows,
    key=lambda row: (-freq.get(row[0], 0), "" if row[0] is None else str(row[0]))
)

# Write sorted rows back to Sheet1
for r_idx, row_vals in enumerate(sorted_rows, start=2):
    for c_idx, value in enumerate(row_vals, start=1):
        ws.cell(r_idx, c_idx).value = value

# Clear any leftover rows if necessary
for r in range(2 + len(sorted_rows), ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Save
wb2.save(output_path)
print("Saved to:", output_path, os.path.exists(output_path))

# Verify against Desired Results in column A
wb_check = load_workbook(output_path, data_only=False)
src_after = [wb_check["Sheet1"].cell(r, 1).value for r in range(1, wb_check["Sheet1"].max_row + 1)]
des_vals = [wb_check["Desired Results"].cell(r, 1).value for r in range(1, wb_check["Desired Results"].max_row + 1)]
print("Sheet1 matches Desired Results?", src_after == des_vals)
print("First 20 rows after sort:", src_after[:20])

final_output_path = output_path
```
