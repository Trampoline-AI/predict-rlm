Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Inspect styles in the shown "result" area to mimic nearby formatting if useful
for r in range(9, 13):
    print("Row", r, [ws.cell(r, c).value for c in range(1, 6)])

# Build output rows from source table A1:E4
source_rows = []
for r in range(1, 5):
    source_rows.append([ws.cell(r, c).value for c in range(1, 6)])

print("Source rows:", source_rows)

def dedupe_row(row):
    # Keep first column as-is; dedupe worker names across remaining columns
    out = [row[0]]
    seen = set()
    for val in row[1:]:
        key = val
        if key is None or key == "":
            out.append(val)
        elif key in seen:
            out.append(None)
        else:
            seen.add(key)
            out.append(val)
    return out

output_rows = [source_rows[0]] + [dedupe_row(r) for r in source_rows[1:]]
print("Output rows:", output_rows)

# Write output to A14:E17
for i, row_vals in enumerate(output_rows, start=14):
    for j, val in enumerate(row_vals, start=1):
        cell = ws.cell(i, j)
        cell.value = val
        
        # Copy style from the analogous row in the existing example/header area (9:12)
        src = ws.cell(i - 5, j)  # 14->9, 15->10, etc.
        if src.has_style:
            cell._style = copy(src._style)
        if src.number_format:
            cell.number_format = src.number_format
        if src.font:
            cell.font = copy(src.font)
        if src.fill:
            cell.fill = copy(src.fill)
        if src.border:
            cell.border = copy(src.border)
        if src.alignment:
            cell.alignment = copy(src.alignment)
        if src.protection:
            cell.protection = copy(src.protection)

# Also copy row heights/column widths if present nearby
for r in range(14, 18):
    if ws.row_dimensions[r-5].height is not None:
        ws.row_dimensions[r].height = ws.row_dimensions[r-5].height

for col_letter in ["A", "B", "C", "D", "E"]:
    if ws.column_dimensions[col_letter].width is not None:
        ws.column_dimensions[col_letter].width = ws.column_dimensions[col_letter].width

wb.save(outfile)

# Verify
wb2 = load_workbook(outfile)
ws2 = wb2["Sheet1"]
for r in range(14, 18):
    print("Verified row", r, [ws2.cell(r, c).value for c in range(1, 6)])

output_spreadsheet = outfile
print("Saved to:", output_spreadsheet)
```
