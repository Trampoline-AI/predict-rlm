Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Pay Items"]

# Put lookup formulas in A and B for rows 20-26.
# If C is blank, return empty string.
for r in range(20, 27):
    ws[f"A{r}"] = f'=IF(C{r}="","",INDEX($A$3:$A$17,MATCH(C{r},$C$3:$C$17,0)))'
    ws[f"B{r}"] = f'=IF(C{r}="","",INDEX($B$3:$B$17,MATCH(C{r},$C$3:$C$17,0)))'

# Apply requested fill color to A20:B26
fill = PatternFill(fill_type="solid", fgColor="FFF2CC")
for r in range(20, 27):
    for c in range(1, 3):
        ws.cell(r, c).fill = fill

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)

print("Saved:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalc result:", recalc_result)

wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["Pay Items"]
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values["Pay Items"]

for r in range(20, 27):
    print({
        "row": r,
        "C": wsf[f"C{r}"].value,
        "A_formula": wsf[f"A{r}"].value,
        "B_formula": wsf[f"B{r}"].value,
        "A_value": wsv[f"A{r}"].value,
        "B_value": wsv[f"B{r}"].value,
        "A_fill": wsf[f"A{r}"].fill.fgColor.rgb,
        "B_fill": wsf[f"B{r}"].fill.fgColor.rgb,
    })

output_path = out_path
```
