import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Determine data rows to complete in column E:
# rows where either B, C, or D has content, starting from row 7 until blank stretch/end.
target_rows = []
for r in range(7, ws.max_row + 1):
    if ws[f"B{r}"].value is not None or ws[f"C{r}"].value is not None or ws[f"D{r}"].value is not None:
        target_rows.append(r)

print("Target rows:", target_rows)

# Use a LibreOffice-compatible INDEX/MATCH formula
for r in target_rows:
    ws[f"E{r}"] = f'=INDEX($J$20:$N$22,MATCH(C{r},$H$20:$H$22,1),MATCH(D{r},$J$18:$N$18,0))'

# Copy style/format from E7 to the other filled cells if present
for r in target_rows:
    if r != 7:
        ws[f"E{r}"]._style = copy(ws["E7"]._style)
        if ws["E7"].number_format:
            ws[f"E{r}"].number_format = ws["E7"].number_format
        if ws["E7"].alignment:
            ws[f"E{r}"].alignment = copy(ws["E7"].alignment)
        if ws["E7"].font:
            ws[f"E{r}"].font = copy(ws["E7"].font)
        if ws["E7"].fill:
            ws[f"E{r}"].fill = copy(ws["E7"].fill)
        if ws["E7"].border:
            ws[f"E{r}"].border = copy(ws["E7"].border)
        if ws["E7"].protection:
            ws[f"E{r}"].protection = copy(ws["E7"].protection)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify cached values
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(outfile, data_only=False)
wsf = wb_check_formula[wb_check_formula.sheetnames[0]]
for r in target_rows:
    print(f"Formula E{r}:", wsf[f'E{r}'].value)

wb_check_values = load_workbook(outfile, data_only=True)
wsv = wb_check_values[wb_check_values.sheetnames[0]]
for r in target_rows:
    print(f"Value E{r}:", wsv[f'E{r}'].value)
