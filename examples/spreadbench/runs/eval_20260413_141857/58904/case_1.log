import os
from openpyxl import load_workbook

# Load workbook
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Write formulas in B11:B17 based on the letter in the "Sum X" label in column A
# Matrix range is C3:I9
for row in range(11, 18):
    label_cell = f"A{row}"
    target_cell = f"B{row}"
    formula = (
        f'=SUMPRODUCT(--(LEFT($C$3:$I$9,1)=RIGHT({label_cell},1)),'
        f'IFERROR(VALUE(RIGHT($C$3:$I$9,1)),0))'
    )
    ws[target_cell] = formula

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_check_formula = load_workbook(outfile, data_only=False)
wsf = wb_check_formula["Sheet1"]
print("Formulas written:")
for row in range(11, 18):
    print(row, wsf[f"A{row}"].value, wsf[f"B{row}"].value)

wb_check_values = load_workbook(outfile, data_only=True)
wsv = wb_check_values["Sheet1"]
print("Cached values:")
for row in range(11, 18):
    print(row, wsv[f"A{row}"].value, wsv[f"B{row}"].value)

output_spreadsheet = outfile
```
