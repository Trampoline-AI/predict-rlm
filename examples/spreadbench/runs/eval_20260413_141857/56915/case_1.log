import os
from openpyxl import load_workbook

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
cover = wb["COVER"]
data = wb["DATA"]

# Inspect relevant headers more precisely
def row_vals(ws, r, c1, c2):
    return [ws.cell(r, c).value for c in range(c1, c2+1)]

print("Selected entity on COVER!B12:", cover["B12"].value)
print("COVER row 13 A:E:", row_vals(cover, 13, 1, 5))
print("DATA row 12 B:AC:", row_vals(data, 12, 2, 29))
print("DATA row 13 B:AC:", row_vals(data, 13, 2, 29))
print("DATA row labels A18:A24:", row_vals(data, 18, 1, 24-18+1))

# Build effective row-12 entity header per column, accounting for merges
effective_entity_by_col = {}
for c in range(2, data.max_column + 1):
    val = data.cell(12, c).value
    effective_entity_by_col[c] = val

for merged in data.merged_cells.ranges:
    min_col, min_row, max_col, max_row = merged.bounds
    if min_row <= 12 <= max_row:
        top_left_val = data.cell(min_row, min_col).value
        for c in range(min_col, max_col + 1):
            effective_entity_by_col[c] = top_left_val

print("Effective entity headers B:AC:", [effective_entity_by_col[c] for c in range(2, 30)])

selected_entity = cover["B12"].value

# Find matching data columns for selected entity and row-13 labels
cover_headers = {c: cover.cell(13, c).value for c in range(2, 6)}
data_col_map = {}
for cover_col, hdr in cover_headers.items():
    match_col = None
    for c in range(2, data.max_column + 1):
        if effective_entity_by_col.get(c) == selected_entity and data.cell(13, c).value == hdr:
            match_col = c
            break
    data_col_map[cover_col] = match_col

print("Cover header to DATA column map:", {cover.cell(13,k).value: v for k,v in data_col_map.items()})

# Map row labels from DATA col A
data_row_map = {}
for r in range(18, data.max_row + 1):
    label = data.cell(r, 1).value
    if label is not None:
        data_row_map[label] = r

print("Data row map for target labels:")
for r in range(18, 24):
    label = cover.cell(r, 1).value
    print(r, repr(label), "->", data_row_map.get(label))

# Populate B18:E23 with literal rounded values
def round2(x):
    if x is None:
        return None
    return round(float(x), 2)

# number formats
num_fmt_amount = '#,##0.00;(#,##0.00)'
num_fmt_decimal = '0.00;(0.00)'

for r in range(18, 24):
    row_label = cover.cell(r, 1).value
    data_r = data_row_map.get(row_label)
    for c in range(2, 6):
        data_c = data_col_map.get(c)
        target = cover.cell(r, c)
        val = None
        if data_r is not None and data_c is not None:
            val = data.cell(data_r, data_c).value
        if isinstance(val, str):
            try:
                val = float(val)
            except:
                pass
        if isinstance(val, (int, float)):
            target.value = round2(val)
        else:
            target.value = val
        # apply number formats by column
        if c in (2, 4):
            target.number_format = num_fmt_amount
        else:
            target.number_format = num_fmt_decimal

# Save output
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Verify by reloading
wbv = load_workbook(output_path, data_only=False)
cv = wbv["COVER"]
print("Verified COVER A18:E23 after write:")
for r in range(18, 24):
    print([cv.cell(r, c).value for c in range(1, 6)])
print("Verified number formats B18:E23:")
for r in range(18, 24):
    print([(cv.cell(r,c).coordinate, cv.cell(r,c).number_format) for c in range(2,6)])
