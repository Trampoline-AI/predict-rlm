from openpyxl import load_workbook
import os

# Load workbook normally to edit formulas
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Replace Total formulas row by row
for r in range(2, ws.max_row + 1):
    ws.cell(row=r, column=4).value = f'=IF(A{r}="A",SUM(B{r}:C{r})+10,IF(A{r}="B",SUM(B{r}:C{r})-10,SUM(B{r}:C{r})))'

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

wb_check_formula = load_workbook(output_path, data_only=False)
wsf = wb_check_formula["Sheet1"]
print("Formulas after save:")
for r in range(2, wsf.max_row + 1):
    print(r, wsf.cell(r, 1).value, wsf.cell(r, 4).value)

wb_check_values = load_workbook(output_path, data_only=True)
wsv = wb_check_values["Sheet1"]
print("Calculated values:")
for r in range(2, wsv.max_row + 1):
    print(r, wsv.cell(r, 1).value, wsv.cell(r, 4).value)
```
