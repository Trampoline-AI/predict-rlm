```repl
from openpyxl import load_workbook
from collections import defaultdict, Counter
from pathlib import Path
import re, os, json

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Compiled and located schools da"]
lu = wb["URN lookup"]
ks4 = wb["KS4 data"]

def norm_text(x):
    if x is None:
        return None
    s = str(x).strip().upper()
    s = re.sub(r"\s+", " ", s)
    return s

def norm_pc(x):
    if x is None:
        return None
    s = str(x).strip().upper()
    s = re.sub(r"\s+", "", s)
    return s

# Build URN lookup structures
lookup_by_estab = defaultdict(list)
lookup_by_urn = {}
lookup_by_pc = defaultdict(list)
lookup_by_pc_name = {}

for r in range(2, lu.max_row + 1):
    rec = {
        "urn": lu.cell(r, 1).value,
        "laname": lu.cell(r, 2).value,
        "la": lu.cell(r, 3).value,
        "estab": lu.cell(r, 4).value,
        "laestab": lu.cell(r, 5).value,
        "name": lu.cell(r, 6).value,
        "street": lu.cell(r, 7).value,
        "town": lu.cell(r, 10).value,
        "postcode": lu.cell(r, 11).value,
    }
    lookup_by_estab[rec["estab"]].append(rec)
    lookup_by_urn[rec["urn"]] = rec
    lookup_by_pc[norm_pc(rec["postcode"])].append(rec)
    lookup_by_pc_name[(norm_pc(rec["postcode"]), norm_text(rec["name"]))] = rec

# Build KS4 mappings
ks4_headers = [ks4.cell(1, c).value for c in range(1, ks4.max_column + 1)]
ks4_col_idx = {h: i+1 for i, h in enumerate(ks4_headers)}
compiled_headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
compiled_col_idx = {h: i+1 for i, h in enumerate(compiled_headers)}

ks4_fields = ["ATT8SCR", "P8PUP", "P8MEA", "P8CILOW", "P8CIUPP", "P8MEA_ORIG", "PTL2BASICS_95", "EBACCAPS"]

ks4_by_urn = {}
ks4_by_estab = defaultdict(list)
for r in range(2, ks4.max_row + 1):
    rec = {h: ks4.cell(r, ks4_col_idx[h]).value for h in ks4_headers}
    urn = rec["URN"]
    estab = rec["ESTAB"]
    if urn is not None:
        ks4_by_urn[urn] = rec
    ks4_by_estab[estab].append(rec)

# Resolve compiled rows
resolution_counts = Counter()
sample_resolutions = []
ks4_fill_count = 0

for r in range(2, ws.max_row + 1):
    existing_estab = ws.cell(r, compiled_col_idx["DfE Number"]).value
    name = ws.cell(r, compiled_col_idx["Name"]).value
    pc = ws.cell(r, compiled_col_idx["Postcode"]).value
    
    np = norm_pc(pc)
    nn = norm_text(name)
    
    resolved = None
    method = None
    
    # 1) Existing DfE Number / ESTAB is strongest if unique
    if existing_estab is not None and len(lookup_by_estab.get(existing_estab, [])) == 1:
        resolved = lookup_by_estab[existing_estab][0]
        method = "existing_estab"
    # 2) Exact postcode + school name
    elif (np, nn) in lookup_by_pc_name:
        resolved = lookup_by_pc_name[(np, nn)]
        method = "postcode_name"
    # 3) Unique postcode only
    elif np is not None and len(lookup_by_pc.get(np, [])) == 1:
        resolved = lookup_by_pc[np][0]
        method = "unique_postcode"
    else:
        method = "unresolved"
    
    resolution_counts[method] += 1
    
    # Fill URN and DFES check if resolved
    if resolved:
        ws.cell(r, compiled_col_idx["URN"]).value = resolved["urn"]
        ws.cell(r, compiled_col_idx["DFES check"]).value = resolved["estab"]
        
        # Only fill DfE Number if blank; preserve existing values
        if ws.cell(r, compiled_col_idx["DfE Number"]).value in (None, ""):
            ws.cell(r, compiled_col_idx["DfE Number"]).value = resolved["estab"]
        
        # Merge KS4 by URN first, then ESTAB
        ks4_rec = ks4_by_urn.get(resolved["urn"])
        if ks4_rec is None:
            est_matches = ks4_by_estab.get(resolved["estab"], [])
            if len(est_matches) == 1:
                ks4_rec = est_matches[0]
        
        if ks4_rec:
            for field in ks4_fields:
                ws.cell(r, compiled_col_idx[field]).value = ks4_rec.get(field)
            ks4_fill_count += 1
    
    if len(sample_resolutions) < 15:
        sample_resolutions.append({
            "row": r,
            "name": name,
            "postcode": pc,
            "existing_estab": existing_estab,
            "method": method,
            "resolved_urn": resolved["urn"] if resolved else None,
            "resolved_estab": resolved["estab"] if resolved else None,
        })

# Save output
output_path = Path("/sandbox/output/output_spreadsheet") / Path(input_spreadsheet).name
wb.save(output_path)

print("Resolution counts:", dict(resolution_counts))
print("KS4 rows filled:", ks4_fill_count)
print("Output saved:", output_path)

print("\nSample resolutions:")
for s in sample_resolutions:
    print(s)

# Verification reload
wb2 = load_workbook(output_path, data_only=True)
ws2 = wb2["Compiled and located schools da"]

nonempty_A = sum(1 for r in range(2, ws2.max_row + 1) if ws2.cell(r, compiled_col_idx["URN"]).value not in (None, ""))
nonempty_B = sum(1 for r in range(2, ws2.max_row + 1) if ws2.cell(r, compiled_col_idx["DFES check"]).value not in (None, ""))
nonempty_ks4 = {f: sum(1 for r in range(2, ws2.max_row + 1) if ws2.cell(r, compiled_col_idx[f]).value not in (None, "")) for f in ks4_fields}

print("\nVerification counts:")
print("URN filled:", nonempty_A)
print("DFES check filled:", nonempty_B)
print("KS4 field fills:", nonempty_ks4)

print("\nVerification sample rows:")
for r in [2, 6, 7, 8, 12, 306, 500, 1000]:
    if r <= ws2.max_row:
        vals = {
            "row": r,
            "URN": ws2.cell(r, compiled_col_idx["URN"]).value,
            "DFES check": ws2.cell(r, compiled_col_idx["DFES check"]).value,
            "DfE Number": ws2.cell(r, compiled_col_idx["DfE Number"]).value,
            "Name": ws2.cell(r, compiled_col_idx["Name"]).value,
            "Postcode": ws2.cell(r, compiled_col_idx["Postcode"]).value,
            "ATT8SCR": ws2.cell(r, compiled_col_idx["ATT8SCR"]).value,
            "P8MEA": ws2.cell(r, compiled_col_idx["P8MEA"]).value,
        }
        print(vals)
