from openpyxl import load_workbook
from pathlib import Path
import os, json, re

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
print("Sheets:", wb.sheetnames)

sheet_info = {}
formula_hits = []
for ws in wb.worksheets:
    dims = ws.calculate_dimension()
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "dimension": dims,
    }
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                txt = cell.value
                if ("INDEX" in txt.upper()) or ("MATCH" in txt.upper()) or ("SUM(" in txt.upper()):
                    formula_hits.append((ws.title, cell.coordinate, txt))

print("Sheet info:")
for k,v in sheet_info.items():
    print(k, v)

print("Formula hits count:", len(formula_hits))
for hit in formula_hits[:50]:
    print(hit)
```
