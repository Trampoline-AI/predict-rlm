and fill it down so only the lookup cell changes (`A7`, `A8`, etc.). Then I’ll save, recalculate, and verify the output values.
Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import shutil, os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

# Reload clean workbook from input
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Write the corrected formula down B7:B10
for r in range(7, 11):
    ws[f"B{r}"] = f"=SUM(INDEX($B$3:$E$5,0,MATCH(A{r},$B$2:$E$2,0)))"

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
wsf = wb_check["Sheet1"]
print("Formulas after write:")
for r in range(7, 11):
    print(r, wsf[f"B{r}"].value)

wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals["Sheet1"]
print("Cached values:")
for r in range(7, 11):
    print(r, wsv[f"A{r}"].value, wsv[f"B{r}"].value)
```
