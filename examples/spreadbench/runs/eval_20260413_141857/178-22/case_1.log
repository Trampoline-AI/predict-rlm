Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
ws1 = wb["Sheet1"]

# Create or get Sheet2
if "Sheet2" in wb.sheetnames:
    ws2 = wb["Sheet2"]
else:
    ws2 = wb.create_sheet("Sheet2")

# Headers from Sheet1 row 1
headers = [ws1.cell(row=1, column=c).value for c in range(1, ws1.max_column + 1)]

# Write headers to Sheet2 starting at A2
for c, value in enumerate(headers, start=1):
    ws2.cell(row=2, column=c, value=value)

# Filter and copy matching rows to Sheet2 starting at A3
out_row = 3
matched_rows = []
for r in range(2, ws1.max_row + 1):
    col_b = ws1.cell(row=r, column=2).value
    col_c = ws1.cell(row=r, column=3).value
    if col_b == "TELIVISION" or col_c == "CLASS III" or col_c == "CLASS IV":
        row_vals = [ws1.cell(row=r, column=c).value for c in range(1, ws1.max_column + 1)]
        matched_rows.append(row_vals)
        for c, value in enumerate(row_vals, start=1):
            ws2.cell(row=out_row, column=c, value=value)
        out_row += 1

# Save
wb.save(output_path)

# Verify by reopening
check_wb = load_workbook(output_path, data_only=True)
check_ws2 = check_wb["Sheet2"]
verified = []
for row in check_ws2.iter_rows(min_row=1, max_row=check_ws2.max_row, values_only=True):
    verified.append(row)

print("Saved to:", output_path)
print("Matched rows:", len(matched_rows))
print("Sheet2 contents:")
for row in verified:
    print(row)
```
