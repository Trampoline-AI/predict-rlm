```repl
from openpyxl import load_workbook
import os
from collections import Counter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)

ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
ws3 = wb["Sheet3"]
ws4 = wb["Sheet4"]

def get_data_rows(ws, start_row=9, max_col=7):
    rows = []
    for r in range(start_row, ws.max_row + 1):
        vals = tuple(ws.cell(r, c).value for c in range(1, max_col + 1))
        if any(v is not None for v in vals):
            rows.append(vals)
    return rows

def ordered_unique(rows):
    seen = set()
    out = []
    for row in rows:
        if row not in seen:
            seen.add(row)
            out.append(row)
    return out

rows1 = get_data_rows(ws1)
rows2 = get_data_rows(ws2)

set2 = set(rows2)
set1 = set(rows1)

subtracts = ordered_unique([row for row in rows1 if row not in set2])  # Sheet1 - Sheet2
adds = ordered_unique([row for row in rows2 if row not in set1])       # Sheet2 - Sheet1

print("Sheet1 data rows:", len(rows1))
print("Sheet2 data rows:", len(rows2))
print("Subtracts:", len(subtracts), subtracts)
print("Adds:", len(adds), adds)

def clear_sheet(ws, max_rows_to_clear=None, max_cols=7):
    if max_rows_to_clear is None:
        max_rows_to_clear = max(ws.max_row, 1)
    for r in range(1, max_rows_to_clear + 1):
        for c in range(1, max_cols + 1):
            ws.cell(r, c).value = None

def write_rows(ws, rows, max_cols=7):
    for r_idx, row in enumerate(rows, start=1):
        for c_idx in range(1, max_cols + 1):
            ws.cell(r_idx, c_idx).value = row[c_idx - 1]

clear_sheet(ws3, max_rows_to_clear=max(ws3.max_row, len(subtracts) + 5), max_cols=7)
clear_sheet(ws4, max_rows_to_clear=max(ws4.max_row, len(adds) + 5), max_cols=7)

write_rows(ws3, subtracts, max_cols=7)
write_rows(ws4, adds, max_cols=7)

wb.save(output_path)

# Verify by reloading
check_wb = load_workbook(output_path)
for name in ["Sheet3", "Sheet4"]:
    ws = check_wb[name]
    values = []
    for r in range(1, ws.max_row + 1):
        row = tuple(ws.cell(r, c).value for c in range(1, 8))
        if any(v is not None for v in row):
            values.append(row)
    print(f"\n{name} non-empty rows ({len(values)}):")
    for row in values:
        print(row)

print("\nSaved:", output_path)
```
