Code:
```repl
import os
import re
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws = wb["Sheet1"]

def words(text):
    if text is None:
        return []
    return re.findall(r"\b\w+\b", str(text).lower())

# Read keywords/search volumes from A:B, starting at row 2 until blank keyword region
keyword_rows = []
for r in range(2, ws.max_row + 1):
    keyword = ws[f"A{r}"].value
    volume = ws[f"B{r}"].value
    if keyword is not None:
        try:
            vol_num = float(volume) if volume is not None else 0
        except Exception:
            vol_num = 0
        keyword_rows.append((r, str(keyword), vol_num, set(words(keyword))))

# Fill column E for roots in D, starting at row 2 until first blank after data block
results = []
for r in range(2, ws.max_row + 1):
    root = ws[f"D{r}"].value
    if root is None:
        # stop once we pass the contiguous roots block
        if r > 2:
            break
        continue
    root_word = str(root).strip().lower()
    total = 0
    matches = []
    for kr, keyword, vol_num, token_set in keyword_rows:
        if root_word in token_set:
            total += vol_num
            matches.append((keyword, vol_num))
    if int(total) == total:
        total_to_write = int(total)
    else:
        total_to_write = total
    ws[f"E{r}"] = total_to_write
    results.append((r, root, total_to_write, matches))

wb.save(output_path)

print("Saved to:", output_path)
for row_info in results:
    r, root, total, matches = row_info
    print(f"Row {r} root={root!r} total={total} matches={matches}")
```
