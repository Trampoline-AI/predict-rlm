To make the average “automatically update as the range expands,” the most direct spreadsheet implementation is a formula in each output cell that anchors the start of the range at row 11 and expands to the current row, e.g. `=AVERAGE($A$11:A12)`, `=AVERAGE($A$11:A13)`, etc. I should fill these formulas down through the existing data rows, format them to 3 decimal places, save to the output directory with the same filename, recalculate, and verify a few results.
Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Determine last row with data in column A
last_data_row = 0
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 1).value not in (None, ""):
        last_data_row = r

print("Last data row in A:", last_data_row)

# Fill running average formulas in column B starting at row 12
for r in range(12, last_data_row + 1):
    ws.cell(r, 2).value = f"=AVERAGE($A$11:A{r})"
    ws.cell(r, 2).number_format = "0.000"

# Save output
wb.save(output_path)
print("Saved to:", output_path, os.path.exists(output_path))

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[wb_formula.sheetnames[0]]
for r in range(11, min(last_data_row, 15) + 1):
    print("formula view", r, "A=", wsf.cell(r,1).value, "B=", wsf.cell(r,2).value, "fmt=", wsf.cell(r,2).number_format)

# Verify cached values
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values[wb_values.sheetnames[0]]
for r in range(11, min(last_data_row, 15) + 1):
    print("value view", r, "A=", wsv.cell(r,1).value, "B=", wsv.cell(r,2).value)

final_output_path = output_path
```
