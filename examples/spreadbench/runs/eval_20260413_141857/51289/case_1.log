import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Read labels and values from A1:H2
labels = [ws.cell(1, c).value for c in range(1, 9)]
values = [ws.cell(2, c).value for c in range(1, 9)]

# Find top 2 positions for each animal group
positions_by_label = {}
for idx, (lab, val) in enumerate(zip(labels, values), start=1):
    positions_by_label.setdefault(lab, []).append((idx, val))

ranked_output = {}
for lab, items in positions_by_label.items():
    # Sort descending by value
    sorted_items = sorted(items, key=lambda x: x[1], reverse=True)
    for rank, (col_idx, _) in enumerate(sorted_items[:2], start=1):
        ranked_output[col_idx] = f"{lab}{rank}"

# Clear/fill row 4 A:H
for c in range(1, 9):
    ws.cell(4, c).value = ranked_output.get(c, None)

wb.save(outfile)

# Verify by reloading
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]
row4 = [check_ws.cell(4, c).value for c in range(1, 9)]
print("Saved to:", outfile)
print("Verified Row 4:", row4)

output_spreadsheet = outfile
```
