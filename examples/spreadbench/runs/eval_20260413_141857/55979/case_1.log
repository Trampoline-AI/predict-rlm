import os
from openpyxl import load_workbook

# Inspect exact relevant cells on Calc
wb = load_workbook(input_spreadsheet)
ws = wb["Calc"]
print("Calc A10:", ws["A10"].value)
print("Calc B7 before:", ws["B7"].value)
for r in range(6, 11):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

# Build bounded ranges from the supplier sheets
supplier_sheets = ["Supplier_1", "Supplier_2", "Supplier_3"]
ranges = {}
for s in supplier_sheets:
    sws = wb[s]
    ranges[s] = f"'{s}'!$A$2:$A${sws.max_row}"
print("Ranges:", ranges)

# Write formula to Calc!B7
formula = (
    f'=IF(COUNTIF({ranges["Supplier_1"]},A10)>0,"Supplier_1",'
    f'IF(COUNTIF({ranges["Supplier_2"]},A10)>0,"Supplier_2",'
    f'IF(COUNTIF({ranges["Supplier_3"]},A10)>0,"Supplier_3","")))'
)
ws["B7"] = formula
print("Formula written to B7:", ws["B7"].value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(output_path, data_only=False)
print("Verified formula in saved file:", wb_check_formula["Calc"]["B7"].value)

wb_check_values = load_workbook(output_path, data_only=True)
print("Cached value in B7 after recalc:", wb_check_values["Calc"]["B7"].value)

final_output_path = output_path
```
