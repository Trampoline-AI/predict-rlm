Code:
```repl
from openpyxl import load_workbook
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Write formulas to E7:E16:
# - if C has input, use main line efficiency in E31
# - if D has input, use 2nd fixture line efficiency in E32
# - otherwise blank
# - IFERROR suppresses upstream #DIV/0! display
for r in range(7, 17):
    ws[f"E{r}"] = f'=IF(C{r}<>"",IFERROR($E$31,""),IF(D{r}<>"",IFERROR($E$32,""),""))'

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate to populate formula cache
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Verify formulas
wb_check = load_workbook(output_path, data_only=False)
wsf = wb_check["Sheet1"]
print("\nFormulas in E7:E16:")
for r in range(7, 17):
    print(r, wsf[f"E{r}"].value)

# Verify cached values where sample inputs exist
wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals["Sheet1"]
print("\nCached values for sample populated rows:")
for r in [7, 8]:
    print(
        r,
        {
            "C": wsv[f"C{r}"].value,
            "D": wsv[f"D{r}"].value,
            "E": wsv[f"E{r}"].value,
        },
    )

final_output_path = output_path
```
