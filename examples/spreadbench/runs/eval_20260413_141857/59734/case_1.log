```repl
import os
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.worksheet.formula import ArrayFormula

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]
last_row = ws.max_row

# Compute expected results in Python for verification:
# For each client row r, find all episode descriptions where:
# A == S and F == O and G == P
expected = {}
for r in range(2, last_row + 1):
    client_id = ws[f"A{r}"].value
    last_name = ws[f"F{r}"].value
    first_name = ws[f"G{r}"].value
    matches = []
    for j in range(2, last_row + 1):
        if (
            ws[f"S{j}"].value == client_id
            and ws[f"O{j}"].value == last_name
            and ws[f"P{j}"].value == first_name
        ):
            matches.append(ws[f"V{j}"].value)
    expected[r] = matches

# Write array formulas to column B only
for r in range(2, last_row + 1):
    formula = (
        f'=IFERROR('
        f'INDEX($V$2:$V${last_row},'
        f'SMALL('
        f'IF(($S$2:$S${last_row}=$A{r})*($O$2:$O${last_row}=$F{r})*($P$2:$P${last_row}=$G{r}),'
        f'ROW($S$2:$S${last_row})-ROW($S$2)+1,""),'
        f'ROWS($A$1:A{r-1})'
        f')'
        f'),'
        f'""'
        f')'
    )
    ws.cell(r, 2).value = ArrayFormula(ref=f"B{r}", text=formula)

# Force recalculation in spreadsheet apps on open
calc = wb.calculation
calc.calcMode = "auto"
calc.fullCalcOnLoad = True
calc.forceFullCalc = True

wb.save(outfile)

# Re-open for verification
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["Sheet1"]

print("Saved:", outfile)
print("Rows/Cols:", wsf.max_row, wsf.max_column)

print("\nExpected Python results for B2:B12 (first match per row, since only col B is filled):")
for r in range(2, min(last_row, 12) + 1):
    first_match = expected[r][0] if expected[r] else ""
    print(r, repr(first_match), "all matches:", expected[r])

print("\nFormula text in B2:B8:")
for r in range(2, min(last_row, 8) + 1):
    af = wsf.cell(r, 2).value
    print(r, getattr(af, "text", af))

# Quick consistency check for sample rows with known matches
sample_ok = True
for r in range(2, last_row + 1):
    af = wsf.cell(r, 2).value
    txt = getattr(af, "text", "")
    if f"$A{r}" not in txt or f"$F{r}" not in txt or f"$G{r}" not in txt:
        sample_ok = False
        print("Formula row reference issue at row", r, txt)
        break
print("\nFormula row references valid:", sample_ok)

output_spreadsheet = outfile
```
