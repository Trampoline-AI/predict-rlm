```repl
import os
from openpyxl import load_workbook
from openpyxl.worksheet.formula import ArrayFormula

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

last_row = ws.max_row

# Populate only Column B with corrected array formulas.
# Match on:
#   A = S
#   F = O
#   G = P
# Return:
#   V (DESCRIPTION)
for r in range(2, last_row + 1):
    formula = (
        f'=IFERROR('
        f'INDEX($V$2:$V${last_row},'
        f'SMALL('
        f'IF(($S$2:$S${last_row}=$A{r})*($O$2:$O${last_row}=$F{r})*($P$2:$P${last_row}=$G{r}),'
        f'ROW($S$2:$S${last_row})-ROW($S$2)+1,""),'
        f'ROWS($A$1:A{r-1})'
        f')'
        f'),'
        f'""'
        f')'
    )
    ws.cell(r, 2).value = ArrayFormula(ref=f"B{r}", text=formula)

wb.save(outfile)
print("Saved:", outfile)

# Recalculate cached formula results
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas and values
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["Sheet1"]
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]

print("\nVerification - formula text in B2:B8:")
for r in range(2, min(last_row, 8) + 1):
    v = wsf.cell(r, 2).value
    print(r, getattr(v, "text", v))

print("\nVerification - cached values B2:B12:")
for r in range(2, min(last_row, 12) + 1):
    print(r, repr(wsv.cell(r, 2).value))

output_spreadsheet = outfile
