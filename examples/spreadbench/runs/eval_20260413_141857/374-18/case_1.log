import os, shutil
from openpyxl import load_workbook

# Inspect full current data
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Operating sheet:", ws.title)
print("Dimensions before:", ws.max_row, ws.max_column)

all_rows = []
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    all_rows.append(vals)
print("All rows before:")
for i, row in enumerate(all_rows, start=1):
    print(i, row)

rows_to_delete = []
for r in range(2, ws.max_row + 1):  # keep header
    v = ws.cell(r, 5).value
    try:
        if float(v) < 1:
            rows_to_delete.append((r, v))
    except (TypeError, ValueError):
        pass

print("Rows marked for deletion:", rows_to_delete)

# Save copy to output path and apply deletion there
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

out_wb = load_workbook(out_path)
out_ws = out_wb[out_wb.sheetnames[0]]

# Delete bottom-up for efficiency/correctness
delete_indices = [r for r, _ in rows_to_delete]
for r in reversed(delete_indices):
    out_ws.delete_rows(r, 1)

out_wb.save(out_path)

# Verify output
check_wb = load_workbook(out_path)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Dimensions after:", check_ws.max_row, check_ws.max_column)
print("All rows after:")
for r in range(1, check_ws.max_row + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, check_ws.max_column + 1)])

remaining_lt1 = []
for r in range(2, check_ws.max_row + 1):
    v = check_ws.cell(r, 5).value
    try:
        if float(v) < 1:
            remaining_lt1.append((r, v))
    except (TypeError, ValueError):
        pass

print("Remaining rows with Column E < 1:", remaining_lt1)
print("Output path:", out_path)
