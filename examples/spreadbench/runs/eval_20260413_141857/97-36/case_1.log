# Load workbook and identify output path
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Find first row containing substring 'domestic' searching top-down in first column
target_row = None
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and "domestic" in v.lower():
        target_row = r
        break

print("Target row:", target_row)

if target_row and target_row > 1:
