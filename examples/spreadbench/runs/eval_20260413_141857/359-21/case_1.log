import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Delete"]

# Keep rows except those where TYPE is STATIONERY or VEGETABLES (header always kept)
rows_to_keep = []
for r in range(1, ws.max_row + 1):
    row_cells = [ws.cell(r, c) for c in range(1, ws.max_column + 1)]
    type_val = ws.cell(r, 2).value
    if r == 1 or type_val not in ("STATIONERY", "VEGETABLES"):
        rows_to_keep.append(row_cells)

# Clear existing cell values/styles by rewriting kept content from top.
# Small sheet, so this is safe and avoids repeated delete_rows calls.
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        cell.value = None
        cell._style = copy(ws.cell(1, 1)._style) if False else cell._style  # no-op, just keep existing style object

# Write kept rows back at the top, preserving styles from source rows
for new_r, src_row in enumerate(rows_to_keep, start=1):
    for c, src_cell in enumerate(src_row, start=1):
        dest = ws.cell(new_r, c)
        dest.value = src_cell.value
        if src_cell.has_style:
            dest._style = copy(src_cell._style)
        if src_cell.number_format:
            dest.number_format = src_cell.number_format
        if src_cell.font:
            dest.font = copy(src_cell.font)
        if src_cell.fill:
            dest.fill = copy(src_cell.fill)
        if src_cell.border:
            dest.border = copy(src_cell.border)
        if src_cell.alignment:
            dest.alignment = copy(src_cell.alignment)
        if src_cell.protection:
            dest.protection = copy(src_cell.protection)

# Remove trailing leftover rows physically
extra = ws.max_row - len(rows_to_keep)
if extra > 0:
    ws.delete_rows(len(rows_to_keep) + 1, extra)

wb.save(outfile)

# Verify
check_wb = load_workbook(outfile)
check_ws = check_wb["Delete"]
remaining = [[check_ws.cell(r, c).value for c in range(1, check_ws.max_column + 1)] for r in range(1, check_ws.max_row + 1)]
print("Saved to:", outfile)
print("Remaining rows:", check_ws.max_row)
for row in remaining:
    print(row)
```
