Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Reload fresh from original input
wb = load_workbook(infile)
ws = wb["Delete"]

# Snapshot kept rows with independent copies of values/styles
kept_rows = []
for r in range(1, ws.max_row + 1):
    type_val = ws.cell(r, 2).value
    if r == 1 or type_val not in ("STATIONERY", "VEGETABLES"):
        row_snapshot = []
        for c in range(1, ws.max_column + 1):
            src = ws.cell(r, c)
            row_snapshot.append({
                "value": src.value,
                "style": copy(src._style),
                "font": copy(src.font),
                "fill": copy(src.fill),
                "border": copy(src.border),
                "alignment": copy(src.alignment),
                "protection": copy(src.protection),
                "number_format": src.number_format,
            })
        kept_rows.append(row_snapshot)

orig_max_row = ws.max_row
max_col = ws.max_column

# Rewrite kept rows at top
for new_r, row_snapshot in enumerate(kept_rows, start=1):
    for c, data in enumerate(row_snapshot, start=1):
        dest = ws.cell(new_r, c)
        dest.value = data["value"]
        dest._style = copy(data["style"])
        dest.font = copy(data["font"])
        dest.fill = copy(data["fill"])
        dest.border = copy(data["border"])
        dest.alignment = copy(data["alignment"])
        dest.protection = copy(data["protection"])
        dest.number_format = data["number_format"]

# Clear any leftover rows before deleting them
for r in range(len(kept_rows) + 1, orig_max_row + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = None

# Physically delete trailing rows
extra = orig_max_row - len(kept_rows)
if extra > 0:
    ws.delete_rows(len(kept_rows) + 1, extra)

wb.save(outfile)

# Verify output
check_wb = load_workbook(outfile)
check_ws = check_wb["Delete"]
remaining = [[check_ws.cell(r, c).value for c in range(1, check_ws.max_column + 1)] for r in range(1, check_ws.max_row + 1)]
print("Saved:", outfile)
print("Rows/Cols:", check_ws.max_row, check_ws.max_column)
for row in remaining:
    print(row)
```
