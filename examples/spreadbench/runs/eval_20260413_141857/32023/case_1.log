from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Dimensions:", ws.calculate_dimension())
print("max_row:", ws.max_row, "max_col:", ws.max_column)

# Print all non-empty cells by row
for r in range(1, ws.max_row + 1):
    row_vals = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None:
            row_vals.append(f"{get_column_letter(c)}{r}={v!r}")
    print(f"Row {r}: ", " | ".join(row_vals) if row_vals else "(empty)")

print("\nColumn widths / hidden status:")
for c in range(1, ws.max_column + 1):
    letter = get_column_letter(c)
    cd = ws.column_dimensions[letter]
    print(letter, "hidden=" + str(cd.hidden), "width=" + str(cd.width))

print("\nMerged ranges:", list(ws.merged_cells.ranges))
```
