import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Fill Current Dept. formulas for employee rows
for r in range(4, ws.max_row + 1):
    if ws[f"A{r}"].value:
        ws[f"B{r}"] = f'=IF($C$3>=K{r},"C78",IF($C$3>=I{r},"C77",IF($C$3>=G{r},"C76",IF($C$3>=E{r},"C75",IF($C$3>=D{r},"C74","")))))'

wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas and verify
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[wb_formula.sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[wb_values.sheetnames[0]]

print("Check formulas:")
for r in [4, 14, 17, 19]:
    print(r, ws_formula[f"A{r}"].value, ws_formula[f"B{r}"].value)

print("\nCheck calculated values:")
for r in [14, 17, 19]:
    print(r, ws_values[f"A{r}"].value, "->", ws_values[f"B{r}"].value, "| date:", ws_values["C3"].value)
```
