import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy2(infile, outfile)

wb = load_workbook(outfile)
ws = wb[wb.sheetnames[0]]

# Write formulas in K6:K10
for r in range(6, 11):
    formula = (
        f'=IFERROR('
        f'INDEX($C$3:$E$13,'
        f'SUMPRODUCT(MAX(ROW($A$3:$A$13)*($B$3:$B$13=H{r})*($A$3:$A$13<=J{r})))-ROW($A$3)+1,'
        f'MATCH(I{r},$C$1:$E$1,0)'
        f'),"")'
    )
    ws[f'K{r}'] = formula

wb.save(outfile)
print("Saved:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb2 = load_workbook(outfile, data_only=False)
ws2 = wb2[wb2.sheetnames[0]]
print("Formulas:")
for r in range(6, 11):
    print(r, ws2[f'K{r}'].value)

wb3 = load_workbook(outfile, data_only=True)
ws3 = wb3[wb3.sheetnames[0]]
print("Cached results:")
for r in range(6, 11):
    print(r, ws3[f'H{r}'].value, ws3[f'I{r}'].value, ws3[f'J{r}'].value, "=>", ws3[f'K{r}'].value)

output_spreadsheet = outfile
```
