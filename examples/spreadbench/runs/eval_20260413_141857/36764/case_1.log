import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
print("Sheet names:", wb.sheetnames)

for ws in wb.worksheets:
    print({
        "title": ws.title,
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "A1": ws["A1"].value,
        "A2": ws["A2"].value,
        "C2": ws["C2"].value,
        "R2": ws["R2"].value if ws.max_column >= 18 else None,
    })

ws1 = wb.worksheets[0]
ws2 = wb.worksheets[1]

print("Sheet1 A1:C5")
for row in ws1.iter_rows(min_row=1, max_row=5, min_col=1, max_col=3, values_only=True):
    print(row)

print("Sheet2 A1:R5")
for row in ws2.iter_rows(min_row=1, max_row=5, min_col=1, max_col=18, values_only=True):
    print(row)

formula = "=SUMIF('{}'!A2:A363,A2,'{}'!R2:R363)".format(ws2.title, ws2.title)
ws1["C2"] = formula

wb.save(output_path)

# verify saved formula
wb_check = load_workbook(output_path, data_only=False)
print("Saved formula in", wb_check.worksheets[0]["C2"].value)
print("Output exists:", os.path.exists(output_path), output_path)
```
