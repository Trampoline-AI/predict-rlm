Code:
```repl
import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
ws3 = wb["Sheet3"]

# Build mapping from Sheet2 headers to non-empty values beneath them
sheet2_map = {}
for c in range(1, ws2.max_column + 1):
    header = ws2.cell(1, c).value
    vals = []
    for r in range(2, ws2.max_row + 1):
        v = ws2.cell(r, c).value
        if v not in (None, ""):
            vals.append(v)
    sheet2_map[header] = vals

# Compute desired output from Sheet1 x Sheet2
computed = []
match_summary = []
for r in range(2, ws1.max_row + 1):
    entry = ws1.cell(r, 1).value
    matched_header = None
    matched_vals = []
    if entry not in (None, ""):
        for header, vals in sheet2_map.items():
            if header and header in entry:
                matched_header = header
                matched_vals = vals
                break
    match_summary.append((r, matched_header, len(matched_vals)))
    for v in matched_vals:
        computed.append(f"{entry}{v}")

# Compare to existing Sheet3
existing = [
    ws3.cell(r, 1).value
    for r in range(2, ws3.max_row + 1)
    if ws3.cell(r, 1).value not in (None, "")
]
print("Computed rows:", len(computed))
print("Existing rows:", len(existing))
print("Computed equals existing:", computed == existing)
print("Match summary:", match_summary)

# Clear and rebuild Sheet3
# Preserve sheet name and simple one-column layout
for r in range(1, ws3.max_row + 1):
    ws3.cell(r, 1).value = None

ws3["A1"] = "Output"
for i, value in enumerate(computed, start=2):
    ws3.cell(i, 1).value = value

# Save to output directory with same filename
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

# Verify by reopening
wb_check = load_workbook(output_path)
ws3_check = wb_check["Sheet3"]
verified = [
    ws3_check.cell(r, 1).value
    for r in range(2, ws3_check.max_row + 1)
    if ws3_check.cell(r, 1).value not in (None, "")
]
print("Saved file:", output_path)
print("Verified row count:", len(verified))
print("Verified matches computed:", verified == computed)
print("First 10 verified:", verified[:10])

final_output_path = output_path
```
