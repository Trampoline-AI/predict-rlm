Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Alignment

# Load source workbook
src_path = input_spreadsheet
filename = os.path.basename(src_path)
out_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(src_path)
ws = wb["Sheet1"]

# Replace formulas in G2:I7 with formulas that trim the lookup table range
# Use INDEX/MATCH so MATCH can compare against TRIMmed Sheet3 names without altering Sheet3 itself.
for r in range(2, 8):
    ws[f"G{r}"] = f'=INDEX(Sheet3!$B$2:$B$300,MATCH(TRIM(F{r}),INDEX(TRIM(Sheet3!$A$2:$A$300),0),0))'
    ws[f"H{r}"] = f'=INDEX(Sheet3!$C$2:$C$300,MATCH(TRIM(F{r}),INDEX(TRIM(Sheet3!$A$2:$A$300),0),0))'
    ws[f"I{r}"] = f'=INDEX(Sheet3!$D$2:$D$300,MATCH(TRIM(F{r}),INDEX(TRIM(Sheet3!$A$2:$A$300),0),0))'

# Format G2:I7 as text and left align
for r in range(2, 8):
    for c in range(7, 10):
        cell = ws.cell(r, c)
        cell.number_format = "@"
        # preserve existing vertical alignment if present
        cell.alignment = copy(cell.alignment)
        cell.alignment = Alignment(
            horizontal="left",
            vertical=cell.alignment.vertical
        )

# Save workbook
wb.save(out_path)

# Recalculate formulas
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Verify formulas and formatting
wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check["Sheet1"]

print("Verification of formulas and formatting:")
for r in range(2, 8):
    vals = []
    for col in ["G", "H", "I"]:
        cell = ws_check[f"{col}{r}"]
        vals.append((cell.coordinate, cell.value, cell.number_format, cell.alignment.horizontal))
    print(vals)

# Also inspect cached results after recalculation
wb_vals = load_workbook(out_path, data_only=True)
ws_vals = wb_vals["Sheet1"]
print("\nCached values G2:I7 after recalc:")
for r in range(2, 8):
    print(r, [ws_vals[f"{col}{r}"].value for col in ["G", "H", "I"]])

output_spreadsheet = out_path
print("\nSaved to:", output_spreadsheet)
```
