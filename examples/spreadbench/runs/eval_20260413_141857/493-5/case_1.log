- Column A (`Reference`) matches
- Column F (`Narrative`) matches

Then I can remove both rows in each matched pair, save to the output folder with the same filename, and verify the remaining rows. Since the sheet is small, I can safely rebuild the sheet contents without the matched rows while preserving formatting by deleting rows from bottom to top.
Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook

# Re-open fresh workbook for manipulation
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect all rows and identify matching row pairs
all_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    row_info = {
        "row": r,
        "Reference": vals[0],
        "Date": vals[1],
        "Debit": vals[2],
        "Credit": vals[3],
        "Net Balance": vals[4],
        "Narrative": vals[5],
    }
    all_rows.append(row_info)

print("All data rows:")
for row in all_rows:
    print(row)

pairs = []
rows_to_delete = set()

for i in range(len(all_rows)):
    for j in range(i + 1, len(all_rows)):
        r1 = all_rows[i]
        r2 = all_rows[j]
        cond = (
            r1["Reference"] == r2["Reference"]
            and r1["Narrative"] == r2["Narrative"]
            and (
                (r1["Debit"] == r2["Credit"] and r1["Debit"] not in (None, 0))
                or (r2["Debit"] == r1["Credit"] and r2["Debit"] not in (None, 0))
            )
        )
        if cond:
            pairs.append((r1["row"], r2["row"]))
            rows_to_delete.add(r1["row"])
            rows_to_delete.add(r2["row"])

print("Matched pairs:", pairs)
print("Rows to delete:", sorted(rows_to_delete))

# Delete matched rows from bottom to top
for row_idx in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(row_idx, 1)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

# Verify saved workbook
check_wb = load_workbook(output_path)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Output saved to:", output_path)
print("Remaining rows:", check_ws.max_row, "x", check_ws.max_column)
for r in range(1, check_ws.max_row + 1):
    print(f"R{r}:", [check_ws.cell(r, c).value for c in range(1, check_ws.max_column + 1)])

final_output_path = output_path
```
