import os
from openpyxl import load_workbook

output_path = final_output_path

# Fix Net Balance formulas to align with current row numbers after deletions
wb_fix = load_workbook(output_path)
ws_fix = wb_fix[wb_fix.sheetnames[0]]

for r in range(2, ws_fix.max_row + 1):
    ws_fix.cell(r, 5).value = f"=+C{r}-D{r}"

wb_fix.save(output_path)

# Verify formulas and confirm no remaining matched pairs
wb_verify = load_workbook(output_path)
ws_verify = wb_verify[wb_verify.sheetnames[0]]

remaining = []
for r in range(2, ws_verify.max_row + 1):
    row_info = {
        "row": r,
        "Reference": ws_verify.cell(r, 1).value,
        "Date": ws_verify.cell(r, 2).value,
        "Debit": ws_verify.cell(r, 3).value,
        "Credit": ws_verify.cell(r, 4).value,
        "Net Balance": ws_verify.cell(r, 5).value,
        "Narrative": ws_verify.cell(r, 6).value,
    }
    remaining.append(row_info)

remaining_pairs = []
for i in range(len(remaining)):
    for j in range(i + 1, len(remaining)):
        r1, r2 = remaining[i], remaining[j]
        cond = (
            r1["Reference"] == r2["Reference"]
            and r1["Narrative"] == r2["Narrative"]
            and (
                (r1["Debit"] == r2["Credit"] and r1["Debit"] not in (None, 0))
                or (r2["Debit"] == r1["Credit"] and r2["Debit"] not in (None, 0))
            )
        )
        if cond:
            remaining_pairs.append((r1["row"], r2["row"]))

print("Verified output:", output_path)
print("Rows:", ws_verify.max_row, "Cols:", ws_verify.max_column)
for r in range(1, ws_verify.max_row + 1):
    print(f"R{r}:", [ws_verify.cell(r, c).value for c in range(1, ws_verify.max_column + 1)])
print("Remaining matched pairs:", remaining_pairs)
print("Ready to submit:", os.path.exists(output_path))
