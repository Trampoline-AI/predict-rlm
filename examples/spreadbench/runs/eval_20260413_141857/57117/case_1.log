```repl
from openpyxl import load_workbook
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Write formula in column F based on text found in column D
for row in range(2, ws.max_row + 1):
    ws.cell(row=row, column=6).value = f'=IF(ISNUMBER(SEARCH("BA",D{row})),"BA",IF(ISNUMBER(SEARCH("MA",D{row})),"MA",""))'

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Formulas in F2:F5:", [ws_check[f"F{r}"].value for r in range(2, ws_check.max_row + 1)])

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[wb_values.sheetnames[0]]
print("Cached values F2:F5:", [ws_values[f"F{r}"].value for r in range(2, ws_values.max_row + 1)])
```
