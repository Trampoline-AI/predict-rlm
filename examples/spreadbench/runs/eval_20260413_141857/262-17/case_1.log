```repl
import os
from copy import copy
from openpyxl import load_workbook

# Paths
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load fresh workbook
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]   # first worksheet
expected_ws = wb[wb.sheetnames[1]] if len(wb.sheetnames) > 1 else None

# Dynamically identify headers in row 1
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
header_map = {str(v).strip(): i for i, v in enumerate(headers, start=1) if v is not None}

task_col = header_map["Task"]
resp_col = header_map["Responsibility"]

# Capture original data rows including values and per-cell formatting
data_rows = []
for r in range(2, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    # skip fully blank rows
    if all(v is None for v in row_vals):
        continue
    data_rows.append({
        "values": row_vals,
        "styles": [copy(ws.cell(r, c)._style) for c in range(1, ws.max_column + 1)],
        "number_formats": [ws.cell(r, c).number_format for c in range(1, ws.max_column + 1)],
        "fonts": [copy(ws.cell(r, c).font) for c in range(1, ws.max_column + 1)],
        "fills": [copy(ws.cell(r, c).fill) for c in range(1, ws.max_column + 1)],
        "borders": [copy(ws.cell(r, c).border) for c in range(1, ws.max_column + 1)],
        "alignments": [copy(ws.cell(r, c).alignment) for c in range(1, ws.max_column + 1)],
        "protections": [copy(ws.cell(r, c).protection) for c in range(1, ws.max_column + 1)],
    })

# Sort by Task ascending, then Responsibility ascending
data_rows_sorted = sorted(
    data_rows,
    key=lambda d: (
        "" if d["values"][task_col - 1] is None else str(d["values"][task_col - 1]),
        "" if d["values"][resp_col - 1] is None else str(d["values"][resp_col - 1]),
    )
)

# Rewrite sorted data back to Sheet1
start_row = 2
for idx, rowdata in enumerate(data_rows_sorted, start=start_row):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(idx, c)
        cell.value = rowdata["values"][c - 1]
        cell._style = copy(rowdata["styles"][c - 1])
        cell.number_format = rowdata["number_formats"][c - 1]
        cell.font = copy(rowdata["fonts"][c - 1])
        cell.fill = copy(rowdata["fills"][c - 1])
        cell.border = copy(rowdata["borders"][c - 1])
        cell.alignment = copy(rowdata["alignments"][c - 1])
        cell.protection = copy(rowdata["protections"][c - 1])

# Clear any leftover rows below rewritten data, if any
for r in range(start_row + len(data_rows_sorted), ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

wb.save(outfile)

# Verify output
wb_check = load_workbook(outfile)
ws_check = wb_check[wb_check.sheetnames[0]]
sorted_output = [
    tuple(ws_check.cell(r, c).value for c in range(1, ws_check.max_column + 1))
    for r in range(2, ws_check.max_row + 1)
    if not all(ws_check.cell(r, c).value is None for c in range(1, ws_check.max_column + 1))
]

print("Saved:", outfile)
print("Header map:", header_map)
print("Sorted row count:", len(sorted_output))
print("First 5 sorted rows:")
for row in sorted_output[:5]:
    print(row)

if expected_ws is not None:
    expected_rows = [
        tuple(cell.value for cell in row)
        for row in expected_ws.iter_rows(min_row=2, max_col=expected_ws.max_column)
        if not all(cell.value is None for cell in row)
        and not (len(row) >= 6 and row[2].value == "First Sort" and row[5].value == "Second Sort")
    ]
    print("Matches expected data rows from Sheet2?", sorted_output == expected_rows)
```
