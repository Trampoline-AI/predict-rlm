import os
from openpyxl import load_workbook

# Reload original workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Correct INDEX/MATCH formula:
# - row match by client
# - column match by rep within the matched client's row across F:T
# - +2 to move from rep cell to corresponding % cell
for row in range(21, 24):
    formula = (
        f'=INDEX($F$5:$T$12,'
        f'MATCH($C{row},$C$5:$C$12,0),'
        f'MATCH($B{row},INDEX($F$5:$T$12,MATCH($C{row},$C$5:$C$12,0),0),0)+2)'
    )
    ws[f"D{row}"] = formula

# Keep percentage formatting
ws["D22"].number_format = ws["D21"].number_format
ws["D23"].number_format = ws["D21"].number_format

wb.save(out_path)

# Verify formulas
wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check["Sheet1"]
for row in range(21, 24):
    print(row, ws_check[f"D{row}"].value)

# Compute expected values in Python just to sanity check the targets
