import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Build output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# INDEX/MATCH formula using client + rep
# Uses CHOOSE to construct a 5-column virtual array from the non-contiguous % columns
for row in range(21, 24):
    formula = (
        f'=INDEX('
        f'CHOOSE({{1,2,3,4,5}},$H$5:$H$12,$K$5:$K$12,$N$5:$N$12,$Q$5:$Q$12,$T$5:$T$12),'
        f'MATCH($C{row},$C$5:$C$12,0),'
        f'MATCH($B{row},CHOOSE({{1,2,3,4,5}},$F$4,$I$4,$L$4,$O$4,$R$4),0)'
        f')'
    )
    ws[f"D{row}"] = formula

# Keep existing percentage formatting pattern if present
ws["D22"].number_format = ws["D21"].number_format
ws["D23"].number_format = ws["D21"].number_format

# Save
wb.save(out_path)
print("Saved to:", out_path)

# Verify formulas written
wb_check = load_workbook(out_path, data_only=False)
