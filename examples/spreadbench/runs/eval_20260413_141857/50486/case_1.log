import os
from openpyxl import load_workbook

# Re-open and inspect all rows
infile = input_spreadsheet
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

all_rows = []
for r in range(1, ws.max_row + 1):
    all_rows.append([ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
print("All rows before:")
for i, row in enumerate(all_rows, start=1):
    print(i, row)

def is_numeric(v):
    return isinstance(v, (int, float)) and not isinstance(v, bool)

# Apply instruction to column A, preserving header
for r in range(2, ws.max_row + 1):
    c_val = ws.cell(r, 3).value  # CHEP
    d_val = ws.cell(r, 4).value  # LOSCAM
    if is_numeric(c_val):
        ws.cell(r, 1).value = "Chep"
    elif is_numeric(d_val):
        ws.cell(r, 1).value = "Loscam"

# Save to output with same filename
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)

# Verify output
wb2 = load_workbook(outfile, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("\nAll rows after:")
for r in range(1, ws2.max_row + 1):
    print(r, [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)])

output_spreadsheet = outfile
print("\nSaved:", output_spreadsheet)
```
