From the inspected data, the rows are organized in 5-row ticker blocks, and only the last row of each block contains the `R DAYS` value. The correct transformation is therefore to sort these 5-row blocks by the block’s `R DAYS` value in descending order, with blank `R DAYS` blocks last. After sorting, I should rewrite the left block A:F, preserve formatting by not altering styles, rebuild the row-relative formulas in column F, save to the output path with the same filename, and verify that A:E matches I:M row by row.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Q"]

start_row = 3
end_row = ws.max_row
block_size = 5

# Read existing left-side blocks A:E (values only). F will be regenerated.
blocks = []
for block_start in range(start_row, end_row + 1, block_size):
    block_end = min(block_start + block_size - 1, end_row)
    rows = []
    for r in range(block_start, block_end + 1):
        rows.append([ws.cell(r, c).value for c in range(1, 6)])  # A:E
    # Sort key comes from R DAYS in the last row of the block
    r_days = rows[-1][4] if rows else None
    numeric_key = r_days if isinstance(r_days, (int, float)) else float("-inf")
    blocks.append({
        "rows": rows,
        "r_days": r_days,
        "sort_key": numeric_key,
        "orig_start": block_start,
    })

print("Original block order / R DAYS:")
for b in blocks:
    print(b["orig_start"], b["rows"][0][0], b["r_days"])

# Sort descending by R DAYS, blanks last
sorted_blocks = sorted(blocks, key=lambda b: b["sort_key"], reverse=True)

print("\nSorted block order / R DAYS:")
for b in sorted_blocks:
    print(b["rows"][0][0], b["r_days"])

# Rewrite A:E and regenerate F formulas
write_row = start_row
for b in sorted_blocks:
    for row_vals in b["rows"]:
        for c in range(1, 6):  # A:E
            ws.cell(write_row, c).value = row_vals[c - 1]
        # Column F formula should reference current row after sort
        ws.cell(write_row, 6).value = f'=IF(NOT(ISBLANK(E{write_row})),A{write_row},"")'
        write_row += 1

wb.save(outfile)
print("\nSaved to:", outfile)

# Verification against expected block on right side: compare A:E vs I:M
verify_wb = load_workbook(outfile, data_only=False)
verify_ws = verify_wb["Q"]

mismatches = []
for r in range(3, verify_ws.max_row + 1):
    left_vals = [verify_ws.cell(r, c).value for c in range(1, 6)]   # A:E
    right_vals = [verify_ws.cell(r, c).value for c in range(9, 14)] # I:M
    if left_vals != right_vals:
        mismatches.append((r, left_vals, right_vals))

print("Mismatch count A:E vs I:M:", len(mismatches))
if mismatches:
    print("First mismatch:", mismatches[0])
else:
    print("Verification passed: left block matches expected block.")

output_spreadsheet = outfile
```
