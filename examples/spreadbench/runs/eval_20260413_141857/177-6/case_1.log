Code:
```repl
from openpyxl import load_workbook
from copy import copy
from collections import OrderedDict
from pathlib import Path
import os

infile = input_spreadsheet
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / Path(infile).name

wb = load_workbook(infile)
src = wb["DATA"]
dst = wb["combined"]

def is_blankish(v):
    return v is None or v == "" or v == "\xa0"

def numeric_or_zero(v):
    if is_blankish(v):
        return 0.0
    if isinstance(v, (int, float)):
        return float(v)
    try:
        s = str(v).replace(",", "").strip()
        if s == "":
            return 0.0
        return float(s)
    except Exception:
        return 0.0

def copy_cell_full(src_cell, dst_cell):
    dst_cell.value = src_cell.value
    if src_cell.has_style:
        dst_cell.font = copy(src_cell.font)
        dst_cell.fill = copy(src_cell.fill)
        dst_cell.border = copy(src_cell.border)
        dst_cell.alignment = copy(src_cell.alignment)
        dst_cell.number_format = src_cell.number_format
        dst_cell.protection = copy(src_cell.protection)
    if src_cell._comment is not None:
        dst_cell.comment = copy(src_cell.comment)

# Preserve sheet-level layout from DATA
for col_letter, dim in src.column_dimensions.items():
    dst.column_dimensions[col_letter].width = dim.width
    dst.column_dimensions[col_letter].hidden = dim.hidden
    dst.column_dimensions[col_letter].bestFit = dim.bestFit
for r_idx, dim in src.row_dimensions.items():
    if dim.height is not None:
        dst.row_dimensions[r_idx].height = dim.height
    dst.row_dimensions[r_idx].hidden = dim.hidden
dst.freeze_panes = src.freeze_panes

# Clear existing combined values/styles in used range by resetting cells
# We rewrite the relevant area A:R and blank out old extra rows if any.
max_rows_to_clear = max(dst.max_row, src.max_row + 5)
for r in range(1, max_rows_to_clear + 1):
    for c in range(1, 19):
        cell = dst.cell(r, c)
        cell.value = None
        # reset style to default by assigning a fresh style copy from empty source? not needed since we'll overwrite used cells

# Copy header row A:R from DATA exactly
for c in range(1, 19):
    copy_cell_full(src.cell(1, c), dst.cell(1, c))

# Group source rows by ComboKey (column H), preserving first-seen order
groups = OrderedDict()
for r in range(2, src.max_row + 1):
    key = src.cell(r, 8).value
    if is_blankish(key):
        continue
    groups.setdefault(key, []).append(r)

# Build combined sheet
out_row = 2
group_summaries = []
for key, row_idxs in groups.items():
    first_r = row_idxs[0]
    # Copy A:R formatting/value from first row
    for c in range(1, 19):
        copy_cell_full(src.cell(first_r, c), dst.cell(out_row, c))
    # Sum I:R
    sums = []
    for c in range(9, 19):
        total = sum(numeric_or_zero(src.cell(r, c).value) for r in row_idxs)
        sums.append(total)
        out_cell = dst.cell(out_row, c)
        if abs(total) < 1e-12:
            out_cell.value = ""
        else:
            # write numeric literal so workbook displays numeric formatting
            out_cell.value = round(total, 10)
            out_cell.number_format = "0.00"
    group_summaries.append((key, row_idxs, sums))
    out_row += 1

# Blank any leftover rows in old combined area
for r in range(out_row, max_rows_to_clear + 1):
    for c in range(1, 19):
        dst.cell(r, c).value = None

wb.save(outfile)

# Verify by reloading
check_wb = load_workbook(outfile, data_only=False)
check = check_wb["combined"]

print("Saved to:", outfile)
print("combined size:", check.max_row, "rows x", check.max_column, "cols")
print("Expected groups:", len(groups), "=> output data rows:", out_row - 2)
for r in range(1, min(check.max_row, 8) + 1):
    vals = [check.cell(r, c).value for c in range(1, 19)]
    print(r, vals)

print("\nVerification of number formats in I:R for output rows:")
for r in range(2, check.max_row + 1):
    fmts = [check.cell(r, c).number_format for c in range(9, 19)]
    vals = [check.cell(r, c).value for c in range(9, 19)]
    print("row", r, "vals", vals, "fmts", fmts)

output_spreadsheet = str(outfile)
```
