Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

for r in range(1, ws.max_row + 1):
    val = ws.cell(r, 1).value
    if isinstance(val, str):
        idx = val.find("FT")
        cleaned = val[:idx].rstrip() if idx != -1 else val
    else:
        cleaned = val
    ws.cell(r, 2).value = cleaned

wb.save(output_path)

# Verify
check_wb = load_workbook(output_path, data_only=True)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Saved to:", output_path)
for r in range(1, check_ws.max_row + 1):
    print(r, "A:", check_ws.cell(r, 1).value)
    print(r, "B:", check_ws.cell(r, 2).value)
```
