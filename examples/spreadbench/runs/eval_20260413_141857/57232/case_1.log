import os, shutil
from openpyxl import load_workbook

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

# Reopen output and replace formulas with a more LibreOffice-friendly version
wb = load_workbook(out_path)
ws = wb["Sea Freight Rates"]

for r in range(2, ws.max_row + 1):
    formula = (
        f'=IF('
        f'SUMPRODUCT((Volume!$A$3:$A$69=B{r})*(Volume!$B$3:$B$69=E{r})*(Volume!$D$2:$F$2=D{r}))=0,'
        f'NA(),'
        f'SUMPRODUCT((Volume!$A$3:$A$69=B{r})*(Volume!$B$3:$B$69=E{r})*(Volume!$D$2:$F$2=D{r})*Volume!$D$3:$F$69)'
        f')'
    )
    ws[f"H{r}"] = formula

wb.save(out_path)
print("Saved revised formulas to:", out_path)

# Recalculate formulas and verify computed values
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

wb_check = load_workbook(out_path, data_only=True)
ws_check = wb_check["Sea Freight Rates"]

sample_rows = list(range(2, 12))
sample_vals = [(r, ws_check[f"B{r}"].value, ws_check[f"D{r}"].value, ws_check[f"E{r}"].value, ws_check[f"H{r}"].value) for r in sample_rows]
print("Sample computed rows (row, origin code, dest code, equip, volume):")
for item in sample_vals:
    print(item)

# Also inspect a few later rows and count non-empty computed results
non_none = 0
for r in range(2, ws_check.max_row + 1):
    if ws_check[f"H{r}"].value is not None:
        non_none += 1
print("Non-empty cached results in H:", non_none, "out of", ws_check.max_row - 1)

output_path = out_path
