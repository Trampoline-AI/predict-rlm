Code:
```repl
from openpyxl import load_workbook
import os
from copy import copy

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

wb2 = load_workbook(input_path)
ws = wb2["Sheet1"]

start_row = 5
score_col = 11  # K
out_col = 26    # Z

def row_has_data(r):
    # data is in A:X per instruction
    return any(ws.cell(r, c).value is not None for c in range(1, 25))

# Build contiguous non-empty blocks from row 5 onward
blocks = []
current = []
for r in range(start_row, ws.max_row + 1):
    if row_has_data(r):
        current.append(r)
    else:
        if current:
            blocks.append(current)
            current = []
if current:
    blocks.append(current)

# Write Y/N to column Z
block_summaries = []
for block in blocks:
    scores = []
    for r in block:
        val = ws.cell(r, score_col).value
        try:
            num = float(val)
        except (TypeError, ValueError):
            num = None
        scores.append((r, num))
    valid_scores = [num for _, num in scores if num is not None]
    max_score = max(valid_scores) if valid_scores else None

    for r, num in scores:
        mark = "Y" if (len(block) == 1 or (max_score is not None and num == max_score)) else "N"
        ws.cell(r, out_col).value = mark

    # capture summary for verification
    block_summaries.append({
        "rows": block,
        "names": [ws.cell(r, 1).value for r in block],
        "scores": [ws.cell(r, score_col).value for r in block],
        "marks": [ws.cell(r, out_col).value for r in block],
        "max": max_score,
    })

wb2.save(output_path)

print("Saved to:", output_path)
print("Block count:", len(blocks))
for i, b in enumerate(block_summaries, 1):
    print(f"Block {i}: rows={b['rows']} names={b['names']} scores={b['scores']} max={b['max']} marks={b['marks']}")

# Reopen and verify written values in Z
verify_wb = load_workbook(output_path, data_only=False)
verify_ws = verify_wb["Sheet1"]
print("\nVerification of Z values:")
for b in blocks:
    print([(r, verify_ws.cell(r, 1).value, verify_ws.cell(r, 11).value, verify_ws.cell(r, 26).value) for r in b])

output_spreadsheet = output_path
```
