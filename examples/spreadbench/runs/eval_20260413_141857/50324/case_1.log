```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os, shutil

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Start from a copy of the original file
shutil.copy2(input_path, output_path)

wb = load_workbook(output_path)
ws_data = wb["Datensatz"]
ws_an = wb["Analyse"]

# Data ranges
data_start_row = 4
data_end_row = 33
total_customers = data_end_row - data_start_row + 1  # 30

# Product columns in Datensatz are D:K (4:11)
analysis_start_row, analysis_end_row = 5, 12
analysis_start_col, analysis_end_col = 4, 11  # D:K

fill = PatternFill(fill_type="solid", fgColor="F2F2F2")
numfmt = "0.#########"

for r in range(analysis_start_row, analysis_end_row + 1):
    data_col_1 = get_column_letter(r - 1)  # row 5 -> D, row 12 -> K
    for c in range(analysis_start_col, analysis_end_col + 1):
        data_col_2 = get_column_letter(c)   # col D:K
        
        cell = ws_an.cell(r, c)
        if data_col_1 == data_col_2:
            cell.value = "=1"
        else:
            cell.value = (
                f'=COUNTIFS(Datensatz!${data_col_1}${data_start_row}:${data_col_1}${data_end_row},">0",'
                f'Datensatz!${data_col_2}${data_start_row}:${data_col_2}${data_end_row},">0")/{total_customers}'
            )
        cell.number_format = numfmt
        cell.fill = fill

wb.save(output_path)
print("Saved:", output_path)

# Recalculate formulas and verify
recalc_status = await recalculate(output_path)
print("Recalc:", recalc_status)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Analyse"]

# Print formulas from a few cells
for coord in ["D5", "E5", "D6", "K12"]:
    print(coord, "formula:", ws_check[coord].value, "numfmt:", ws_check[coord].number_format, "fill:", ws_check[coord].fill.fgColor.rgb)

wb_vals = load_workbook(output_path, data_only=True)
ws_vals = wb_vals["Analyse"]
for coord in ["D5", "E5", "D6", "F7", "K12"]:
    print(coord, "value:", ws_vals[coord].value)
```
