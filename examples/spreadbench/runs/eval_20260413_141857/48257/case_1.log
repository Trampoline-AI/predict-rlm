from openpyxl import load_workbook
from pathlib import Path
import re, os

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect cell types/styles around target area
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        if r <= 5:
            print(cell.coordinate, "value=", cell.value, "data_type=", cell.data_type, "numfmt=", cell.number_format)

def extract_number(text):
    s = str(text).strip()
    # Keep only digits, separators, spaces, and sign
    t = re.sub(r"[^0-9,.\-\s]", "", s).strip()
    t = re.sub(r"\s+", " ", t)

    # Find last decimal separator followed by 1-2 digits at end
    m = re.search(r"([,.])(\d{1,2})\s*$", t)
    if m:
        dec = m.group(1)
        frac = m.group(2)
        integer = t[:m.start(1)]
        integer = re.sub(r"[^\d\-]", "", integer)
        num = integer + "." + frac
    else:
        num = re.sub(r"[^\d\-]", "", t)

    return float(num) if num not in ("", "-", None) else None

# Compute expected values from column B
computed = {}
for r in range(2, ws.max_row + 1):
    computed[r] = extract_number(ws.cell(r, 2).value)
print("Computed:", computed)
