from openpyxl import load_workbook
from pathlib import Path
import re, os

infile = Path(input_spreadsheet)
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / infile.name

def extract_number(text):
    s = str(text).strip()
    t = re.sub(r"[^0-9,.\-\s]", "", s).strip()
    t = re.sub(r"\s+", " ", t)
    m = re.search(r"([,.])(\d{1,2})\s*$", t)
    if m:
        frac = m.group(2)
        integer = t[:m.start(1)]
        integer = re.sub(r"[^\d\-]", "", integer)
        num = integer + "." + frac
    else:
        num = re.sub(r"[^\d\-]", "", t)
    return float(num) if num not in ("", "-", None) else None

wb = load_workbook(infile)
ws = wb["Sheet1"]

for r in range(2, ws.max_row + 1):
    if ws.cell(r, 3).value is None:
        ws.cell(r, 3).value = extract_number(ws.cell(r, 2).value)

wb.save(outfile)

# Verify saved output
check_wb = load_workbook(outfile, data_only=True)
check_ws = check_wb["Sheet1"]
verification = {f"C{r}": check_ws.cell(r, 3).value for r in range(2, check_ws.max_row + 1)}
print("Saved to:", outfile)
print("Verification:", verification)

output_spreadsheet = str(outfile)
```
