Code:
```repl
import os, statistics, math
from openpyxl import load_workbook
from openpyxl.styles import Border, Side, Alignment

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Compute expected medians in Python for verification
src_wb = load_workbook(infile, data_only=True)
src_ws = src_wb[src_wb.sheetnames[0]]

data = []
for r in range(2, src_ws.max_row + 1):
    mc = src_ws.cell(r, 2).value
    pct = src_ws.cell(r, 3).value
    if isinstance(mc, (int, float)) and isinstance(pct, (int, float)):
        data.append((mc, pct))

expected = {}
for r in range(2, 7):
    low = (r - 2) / 100
    high = (r - 1) / 100
    vals = [mc for mc, pct in data if pct >= low and pct < high]
    expected[r] = statistics.median(vals) if vals else None

print("Expected medians by row:", expected)

# Rewrite workbook with simpler formulas
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

thin = Side(style="thin", color="000000")
border = Border(left=thin, right=thin, top=thin, bottom=thin)
left_align = Alignment(horizontal="left", vertical="center")

for r in range(1, 7):
    c = ws[f"E{r}"]
    c.border = border
    c.alignment = left_align
    if r >= 2:
        c.number_format = "0"

# Header already exists; keep it.
for r in range(2, 7):
    formula = (
        f'=IFERROR(MEDIAN(IF(($C$2:$C${ws.max_row}>=(ROW()-2)/100)*'
        f'($C$2:$C${ws.max_row}<(ROW()-1)/100),$B$2:$B${ws.max_row})),"")'
    )
    ws[f"E{r}"] = formula
    ws[f"E{r}"].border = border
    ws[f"E{r}"].alignment = left_align
    ws[f"E{r}"].number_format = "0"

wb.save(outfile)

recalc_result = await recalculate(outfile)
print("recalc:", recalc_result)

# Verify formulas, cached values, and formatting
wbf = load_workbook(outfile, data_only=False)
wsf = wbf[wbf.sheetnames[0]]
wbv = load_workbook(outfile, data_only=True)
wsv = wbv[wbv.sheetnames[0]]

print("Formulas E2:E6:")
for r in range(2, 7):
    print(r, wsf[f"E{r}"].value)

print("Cached values E2:E6:")
for r in range(2, 7):
    print(r, wsv[f"E{r}"].value)

print("Formats E1:E6:")
for r in range(1, 7):
    c = wsf[f"E{r}"]
    print(r, c.number_format, c.alignment.horizontal,
          c.border.left.style, c.border.right.style, c.border.top.style, c.border.bottom.style)

output_spreadsheet = outfile
