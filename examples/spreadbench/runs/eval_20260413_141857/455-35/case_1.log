import os, shutil
from openpyxl import load_workbook

# Re-open fresh workbook
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Verify actual matches in column B
keep_rows = [1]  # always keep header
sample_kept = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 2).value
    s = "" if v is None else str(v)
    if s[:1] in ("H", "A"):
        keep_rows.append(r)
        if len(sample_kept) < 10:
            sample_kept.append((r, s))

print("Total original rows:", ws.max_row)
print("Rows to keep including header:", len(keep_rows))
print("Matching data rows:", len(keep_rows) - 1)
print("Sample kept rows from col B:", sample_kept)

# Build output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Copy workbook structure/styles by saving modified original workbook
# Delete rows by reconstructing sheet contents in place, preserving workbook/sheet metadata as much as possible.
rows_data = []
for r in keep_rows:
    rows_data.append([ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Clear all data rows below header and rewrite kept rows
# Simpler and safer here: create fresh workbook from original then blank/rewrite cells.
for r in range(2, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

for out_r, row_vals in enumerate(rows_data[1:], start=2):
    for c, val in enumerate(row_vals, start=1):
        ws.cell(out_r, c).value = val

# Save
wb.save(out_path)

# Verify output
vwb = load_workbook(out_path)
vws = vwb[vwb.sheetnames[0]]
nonempty_rows = 0
for r in range(1, vws.max_row + 1):
    if any(vws.cell(r, c).value is not None for c in range(1, vws.max_column + 1)):
        nonempty_rows += 1

print("Saved to:", out_path)
print("Verified sheet size:", vws.max_row, "x", vws.max_column)
print("Verified nonempty rows:", nonempty_rows)
for r in range(1, min(5, vws.max_row) + 1):
    print(r, [vws.cell(r, c).value for c in range(1, vws.max_column + 1)])

output_spreadsheet = out_path
