from openpyxl import load_workbook
from collections import Counter, defaultdict

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# First-character distributions for each column
for c in range(1, ws.max_column + 1):
    header = ws.cell(1, c).value
    counter = Counter()
    nonempty = 0
    for r in range(2, ws.max_row + 1):
        v = ws.cell(r, c).value
        if v is None or v == "":
            continue
        s = str(v)
        counter[s[:1]] += 1
        nonempty += 1
    print(f"Col {c} {header!r}: nonempty={nonempty}, top first chars={counter.most_common(10)}")

# Show sample rows where any cell in a row starts with H or A, to locate likely target columns
matches = []
for r in range(2, min(ws.max_row, 200) + 1):
    row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    for c, v in enumerate(row, start=1):
        if v is None or v == "":
            continue
        s = str(v)
        if s.startswith("H") or s.startswith("A"):
            matches.append((r, c, ws.cell(1, c).value, s))
            if len(matches) >= 30:
                break
    if len(matches) >= 30:
        break

print("\nSample H/A-leading cell hits:")
for hit in matches:
    print(hit)

# Count rows that would remain if filtering by each column for first char H or A
print("\nRows retained if keep first char H/A by column:")
for c in range(1, ws.max_column + 1):
    kept = 0
    total_nonblank = 0
    for r in range(2, ws.max_row + 1):
        v = ws.cell(r, c).value
        if v is None or v == "":
            continue
        total_nonblank += 1
        s = str(v)
        if s[:1] in ("H", "A"):
            kept += 1
    print(c, ws.cell(1, c).value, "kept", kept, "of nonblank", total_nonblank)
