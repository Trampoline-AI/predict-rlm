Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Write formula to the left of the names list (column K, names in column L)
for r in range(2, 9):
    formula = (
        f"=SUMPRODUCT(--ISNUMBER(SEARCH(L{r},C3:G3)))+"
        f"SUMPRODUCT(--ISNUMBER(SEARCH(L{r},C10:G10)))+"
        f"SUMPRODUCT(--ISNUMBER(SEARCH(L{r},C17:G17)))+"
        f"SUMPRODUCT(--ISNUMBER(SEARCH(L{r},C24:G24)))"
    )
    ws[f"K{r}"] = formula

wb.save(outfile)

# Verify formulas were written
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]
for r in range(2, 9):
    print(r, check_ws[f"L{r}"].value, check_ws[f"K{r}"].value)

output_spreadsheet = outfile
print("Saved to:", output_spreadsheet)
```
