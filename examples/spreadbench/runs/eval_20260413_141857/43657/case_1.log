from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Array/formula cells in K/L area:")
for r in range(2, ws.max_row + 1):
    kval = ws[f"K{r}"].value
    lval = ws[f"L{r}"].value
    if kval is not None or lval is not None:
        print(r, "K:", kval, "type:", type(kval).__name__, "| L:", lval)

