Code:
```repl
import os
from openpyxl import load_workbook

# Load source workbook
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Fill desired results in column C using every 16th row from column A, starting at row 25
start_a_row = 25
step = 16
target_row = 2
a_row = start_a_row

while a_row <= ws.max_row:
    ws.cell(target_row, 3).value = f"=A{a_row}"
    target_row += 1
    a_row += step

wb.save(outfile)

# Verify saved workbook contents
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]

print("Saved to:", outfile)
for r in range(1, 8):
    print(r, [check_ws.cell(r, c).value for c in range(1, 4)])
print("Filled formulas in C:", [(r, check_ws.cell(r, 3).value) for r in range(1, check_ws.max_row + 1) if check_ws.cell(r, 3).value is not None])
```
