        "E_formula=", wsf[f"E{r}"].value,
        "E_val=", wsv[f"E{r}"].value,
        "O_formula=", wsf[f"O{r}"].value,
        "O_val=", wsv[f"O{r}"].value,
        "P_formula=", wsf[f"P{r}"].value,
        "P_val=", wsv[f"P{r}"].value
    )

