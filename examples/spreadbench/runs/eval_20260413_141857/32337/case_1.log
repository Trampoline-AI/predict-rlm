from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font, Alignment
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Insert new column after O -> new P
ws.insert_cols(16, 1)

# Match column width from O to new P
ws.column_dimensions["P"].width = ws.column_dimensions["O"].width

# Set header for new column
ws["P2"] = "Actual Age"

# Copy header fill from O2 and enforce requested alignment/font for header
ws["P2"].fill = copy(ws["O2"].fill)
ws["P2"].border = copy(ws["O2"].border)
ws["P2"].font = copy(ws["O2"].font)
ws["P2"].alignment = copy(ws["O2"].alignment)
ws["P2"].protection = copy(ws["O2"].protection)
ws["P2"].number_format = ws["O2"].number_format

# Requested header formatting: bold, centered, top-aligned
ws["P2"].font = copy(ws["P2"].font)
ws["P2"].font = ws["P2"].font.copy(bold=True) if hasattr(ws["P2"].font, "copy") else copy(ws["P2"].font)
if not hasattr(ws["P2"].font, "copy"):
    ws["P2"].font = copy(ws["P2"].font)
    ws["P2"].font = Font(
        name=ws["P2"].font.name,
        sz=ws["P2"].font.sz,
        b=True,
        i=ws["P2"].font.i,
        charset=ws["P2"].font.charset,
        u=ws["P2"].font.u,
        strike=ws["P2"].font.strike,
        color=ws["P2"].font.color,
        vertAlign=ws["P2"].font.vertAlign,
        outline=ws["P2"].font.outline,
        shadow=ws["P2"].font.shadow,
        condense=ws["P2"].font.condense,
        extend=ws["P2"].font.extend,
        scheme=ws["P2"].font.scheme,
        family=ws["P2"].font.family,
    )
ws["P2"].alignment = Alignment(horizontal="center", vertical="top")

# Fill formulas and styling for data rows
for r in range(3, ws.max_row + 1):
    # Fill Expected Result column E dynamically from age(year) in O using lookup table H:I
    ws.cell(r, 5).value = f'=IFERROR(VLOOKUP(O{r},$H$3:$I$11,2,FALSE),"")'
    
    # Actual Age (whole years based on report date in B1 and DOB in C)
    # Use a LibreOffice/Excel-compatible age calculation without DATEDIF dependency
    ws.cell(r, 16).value = f'=YEAR($B$1)-YEAR(C{r})-IF(DATE(YEAR($B$1),MONTH(C{r}),DAY(C{r}))>$B$1,1,0)'
    
    # Match fill color to preceding column O, preserve nearby look/feel
    ws.cell(r, 16).fill = copy(ws.cell(r, 15).fill)
    ws.cell(r, 16).border = copy(ws.cell(r, 15).border)
    ws.cell(r, 16).protection = copy(ws.cell(r, 15).protection)
    
    # Requested formatting for new column values
    ws.cell(r, 16).font = copy(ws.cell(r, 15).font)
    # Force bold
    base_font = ws.cell(r, 16).font
    try:
        ws.cell(r, 16).font = base_font.copy(bold=True)
    except Exception:
        ws.cell(r, 16).font = Font(
            name=base_font.name,
            sz=base_font.sz,
            b=True,
            i=base_font.i,
            charset=base_font.charset,
            u=base_font.u,
            strike=base_font.strike,
            color=base_font.color,
            vertAlign=base_font.vertAlign,
            outline=base_font.outline,
            shadow=base_font.shadow,
            condense=base_font.condense,
            extend=base_font.extend,
            scheme=base_font.scheme,
            family=base_font.family,
        )
    ws.cell(r, 16).alignment = Alignment(horizontal="center", vertical="top")
    ws.cell(r, 16).number_format = "0"

# Save, recalc, and inspect
wb.save(outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
wsf = wb_check["Sheet1"]
wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals["Sheet1"]

print("Saved to:", outfile)
print("Dimensions after edit:", wsf.max_row, wsf.max_column)
print("E formulas / values and P formulas / values:")
for r in range(3, wsf.max_row + 1):
