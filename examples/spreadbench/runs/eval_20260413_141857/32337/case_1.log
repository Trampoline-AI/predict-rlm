from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment
from copy import copy
import os

infile = input_spreadsheet
outfile_live = os.path.join("/sandbox/output/output_spreadsheet", "live_" + os.path.basename(input_spreadsheet))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Insert new column after O
ws.insert_cols(16, 1)

# Match width from O to P
ws.column_dimensions["P"].width = ws.column_dimensions["O"].width

# Header
ws["P2"] = "Actual Age"
ws["P2"].fill = copy(ws["O2"].fill)
ws["P2"].border = copy(ws["O2"].border)
ws["P2"].protection = copy(ws["O2"].protection)
ws["P2"].number_format = ws["O2"].number_format
ws["P2"].font = copy(ws["O2"].font)
ws["P2"].font = copy(ws["P2"].font)
try:
    ws["P2"].font = ws["P2"].font.copy(bold=True)
except Exception:
    f = ws["P2"].font
    ws["P2"].font = Font(
        name=f.name, sz=f.sz, b=True, i=f.i, charset=f.charset, u=f.u,
        strike=f.strike, color=f.color, vertAlign=f.vertAlign,
        outline=f.outline, shadow=f.shadow, condense=f.condense,
        extend=f.extend, scheme=f.scheme, family=f.family
    )
ws["P2"].alignment = Alignment(horizontal="center", vertical="top")

for r in range(3, ws.max_row + 1):
    # Column E formula: lookup category by age(year) in O against H:I table
    ws[f"E{r}"] = f'=IFERROR(VLOOKUP(O{r},$H$3:$I$11,2,FALSE),"")'
    
    # New actual age whole years
    ws[f"P{r}"] = f'=YEAR($B$1)-YEAR(C{r})-IF(DATE(YEAR($B$1),MONTH(C{r}),DAY(C{r}))>$B$1,1,0)'
    
    # Match preceding column style/fill, then apply requested formatting
    ws[f"P{r}"].fill = copy(ws[f"O{r}"].fill)
    ws[f"P{r}"].border = copy(ws[f"O{r}"].border)
    ws[f"P{r}"].protection = copy(ws[f"O{r}"].protection)
    ws[f"P{r}"].font = copy(ws[f"O{r}"].font)
    try:
        ws[f"P{r}"].font = ws[f"P{r}"].font.copy(bold=True)
    except Exception:
        f = ws[f"P{r}"].font
        ws[f"P{r}"].font = Font(
            name=f.name, sz=f.sz, b=True, i=f.i, charset=f.charset, u=f.u,
            strike=f.strike, color=f.color, vertAlign=f.vertAlign,
            outline=f.outline, shadow=f.shadow, condense=f.condense,
            extend=f.extend, scheme=f.scheme, family=f.family
        )
    ws[f"P{r}"].alignment = Alignment(horizontal="center", vertical="top")
    ws[f"P{r}"].number_format = "0"

wb.save(outfile_live)

# Verify formulas are preserved
wb_verify = load_workbook(outfile_live, data_only=False)
wsv = wb_verify["Sheet1"]

print("outfile_live:", outfile_live)
print("Dims:", wsv.max_row, wsv.max_column)
for coord in ["E3", "E12", "O3", "O12", "P3", "P12", "P2"]:
    c = wsv[coord]
    print(coord, "=>", c.value)

print("P2 align:", wsv["P2"].alignment.horizontal, wsv["P2"].alignment.vertical, "bold:", wsv["P2"].font.bold)
print("P3 style:", "fill", wsv["P3"].fill.fill_type, "bold", wsv["P3"].font.bold, "align", (wsv["P3"].alignment.horizontal, wsv["P3"].alignment.vertical), "numfmt", wsv["P3"].number_format)
```
