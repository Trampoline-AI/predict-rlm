headers = {ws.cell(1, c).value: c for c in range(1, ws.max_column + 1)}
print("Headers:", headers)

proc_col = headers["Procedure Category ID"]
new_col = proc_col + 1

# Create new header/value column
ws.cell(1, new_col).value = "Test"

# Copy formatting from prior column (Procedure Category ID) to new column
for r in range(1, ws.max_row + 1):
    src = ws.cell(r, proc_col)
