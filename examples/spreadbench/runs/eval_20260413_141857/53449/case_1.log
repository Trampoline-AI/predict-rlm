import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

headers = {ws.cell(1, c).value: c for c in range(1, ws.max_column + 1)}
proc_col = headers["Procedure Category ID"]
new_col = proc_col + 1

# Header
ws.cell(1, new_col).value = "Test"

# Copy cell formatting from prior column and populate values
for r in range(1, ws.max_row + 1):
    src = ws.cell(r, proc_col)
    dst = ws.cell(r, new_col)

    if r >= 2:
        dst.value = "X" if src.value == "Covid Test" else ""

    if src.has_style:
        dst.font = copy(src.font)
        dst.fill = copy(src.fill)
        dst.border = copy(src.border)
        dst.alignment = copy(src.alignment)
        dst.number_format = src.number_format
        dst.protection = copy(src.protection)
    if src._style is not None:
        dst._style = copy(src._style)

# Copy safe column dimension properties
src_letter = get_column_letter(proc_col)
dst_letter = get_column_letter(new_col)
ws.column_dimensions[dst_letter].width = ws.column_dimensions[src_letter].width
ws.column_dimensions[dst_letter].hidden = ws.column_dimensions[src_letter].hidden
ws.column_dimensions[dst_letter].bestFit = ws.column_dimensions[src_letter].bestFit

wb.save(outfile)

# Verify
check_wb = load_workbook(outfile)
check_ws = check_wb["Sheet1"]

print("Saved:", outfile)
print("Dims:", check_ws.max_row, "x", check_ws.max_column)
for r in range(1, check_ws.max_row + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, check_ws.max_column + 1)])

# Basic style verification on header and first data rows
for r in [1, 2, 7, 8]:
    if r <= check_ws.max_row:
        src = check_ws.cell(r, proc_col)
        dst = check_ws.cell(r, new_col)
        print(
            "row", r,
            "src/dst values:", src.value, dst.value,
            "font_same:", src.font == dst.font,
            "fill_same:", src.fill == dst.fill,
            "border_same:", src.border == dst.border,
            "align_same:", src.alignment == dst.alignment,
            "numfmt_same:", src.number_format == dst.number_format
        )

output_spreadsheet = outfile
