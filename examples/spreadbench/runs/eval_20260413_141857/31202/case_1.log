Code:
```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import range_boundaries

wb = load_workbook(input_spreadsheet)
ws = wb["NOMINA"]
tbl = ws.tables["tblNomina"]
print("tblNomina ref:", tbl.ref)

min_col, min_row, max_col, max_row = range_boundaries(tbl.ref)
print("Bounds:", (min_col, min_row, max_col, max_row))

# Inspect the last several rows to see whether the table has a totals row at the end
for r in range(max(min_row, max_row - 6), max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(min_col, max_col + 1)])

# Decide data row end: if totalsRowCount=1, last row is totals row
totals_count = getattr(tbl, "totalsRowCount", None)
print("totalsRowCount:", totals_count)
data_start = min_row + 1
data_end = max_row - 1 if totals_count == 1 else max_row
print("Data rows to fill:", data_start, "to", data_end)

# Write the DEBT formula in column J for each data row
# Logic: previous debt for same worker on latest earlier date + current deductions - current additions
for r in range(data_start, data_end + 1):
    ws.cell(r, 10).value = (
        '=IFERROR('
        'LOOKUP(2,1/(($D$2:INDEX($D:$D,ROW()-1)=D{r})*($A$2:INDEX($A:$A,ROW()-1)<A{r})),$J$2:INDEX($J:$J,ROW()-1))'
        ',0)+G{r}-H{r}'
    ).format(r=r)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate formulas for verification
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Verify formulas and cached results
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["NOMINA"]
print("\nSample DEBT formulas:")
for r in [2, 3, 12, 13, data_end]:
    if data_start <= r <= data_end:
        print(r, wsf[f"J{r}"].value)

wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values["NOMINA"]
print("\nSample cached DEBT values:")
for r in [2, 3, 12, 13, data_end]:
    if data_start <= r <= data_end:
        print(r, "worker=", wsv[f"D{r}"].value, "date=", wsv[f"A{r}"].value, "debt=", wsv[f"J{r}"].value)

output_spreadsheet = out_path
```
