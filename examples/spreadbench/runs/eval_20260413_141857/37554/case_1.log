import os
from openpyxl import load_workbook

# Load workbook normally for editing
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Replace SEARCH-based array formulas with exact-match SUMIF formulas
for r in range(2, 18):  # F2:F17
    ws[f"F{r}"] = f'=SUMIF($A$2:$A$17,D{r},$B$2:$B$17)'

# Keep existing totals/percent formulas as-is
wb.save(outfile)
print("Saved:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Formula samples:", ws_check["F2"].value, ws_check["F11"].value, ws_check["F16"].value, ws_check["F18"].value)

wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals[wb_vals.sheetnames[0]]

checks = {
    "Travel Agency (F16)": ws_vals["F16"].value,
    "Online Travel Agency (F11)": ws_vals["F11"].value,
    "Airline (F2)": ws_vals["F2"].value,
    "Total F18": ws_vals["F18"].value,
    "Total B18": ws_vals["B18"].value,
    "Control F19": ws_vals["F19"].value,
}
print(checks)

output_spreadsheet = outfile
```
