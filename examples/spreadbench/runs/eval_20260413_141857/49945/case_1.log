Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Write the requested formula in G4 and fill down for the listed models in F4:F6.
for row in range(4, 7):
    ws[f"G{row}"] = f"=SUMIF($C$4:$C$11,F{row},$D$4:$D$11)"

wb.save(outfile)

# Verify formulas were saved
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb["Sheet1"]
print("Saved to:", outfile)
for row in range(3, 7):
    print(row, [check_ws.cell(row, col).value for col in range(6, 8)])
```
