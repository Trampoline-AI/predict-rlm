import os
import re
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

wb = load_workbook(input_path)
ws = wb["Sheet1"]

target_cells = ["A1","B1","C1","D1","E1","F1","G1","H1"]
before = {cell: ws[cell].value for cell in target_cells}

for cell in target_cells:
    c = ws[cell]
    v = c.value
    if isinstance(v, str):
        c.value = re.sub(r"[^0-9.]", "", v)

after_in_memory = {cell: ws[cell].value for cell in target_cells}

wb.save(output_path)

# verify by reopening
wb_check = load_workbook(output_path)
ws_check = wb_check["Sheet1"]
after_reopen = {cell: ws_check[cell].value for cell in target_cells}

print("Output path:", output_path)
print("Before:", before)
print("After in memory:", after_in_memory)
print("After reopen:", after_reopen)
print("File exists:", os.path.exists(output_path), "Size:", os.path.getsize(output_path))
```
