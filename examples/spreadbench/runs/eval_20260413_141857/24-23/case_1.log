Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

targets = {"@9T", "SAL", "T9A"}

wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Read all rows and filter in Python for performance
rows = list(ws.iter_rows(values_only=True))
header = rows[0]
data_rows = rows[1:]

match_count = 0
kept_rows = [header]
for row in data_rows:
    if row and row[0] in targets:
        match_count += 1
    else:
        kept_rows.append(row)

print("Original rows:", len(rows))
print("Matched rows to delete:", match_count)
print("Rows to keep incl header:", len(kept_rows))

# Clear existing sheet contents by overwriting cells in place
# Since dimensions shrink automatically on save poorly, recreate the sheet contents cleanly.
wb2 = load_workbook(input_path)
ws2 = wb2["Sheet1"]

# Remove all rows except keep sheet object; easiest reliable approach: blank old cells then write kept rows
for row in ws2.iter_rows():
    for cell in row:
        cell.value = None

for r_idx, row in enumerate(kept_rows, start=1):
    for c_idx, value in enumerate(row, start=1):
        ws2.cell(row=r_idx, column=c_idx, value=value)

wb2.save(output_path)

# Verify output
verify_wb = load_workbook(output_path, read_only=True)
verify_ws = verify_wb["Sheet1"]
remaining_bad = {}
for t in targets:
    remaining_bad[t] = 0

row_count = 0
for row in verify_ws.iter_rows(values_only=True):
    row_count += 1
    if row and row[0] in targets:
        remaining_bad[row[0]] += 1

print("Verified output path:", output_path)
print("Verified row count:", row_count)
print("Remaining banned labels:", remaining_bad)
```
