Code:
```repl
import os
from openpyxl import load_workbook, Workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

targets = {"@9T", "SAL", "T9A"}

# Read source
src_wb = load_workbook(input_path, read_only=True, data_only=False)
src_ws = src_wb[src_wb.sheetnames[0]]

rows = list(src_ws.iter_rows(values_only=True))
header = rows[0]
data_rows = rows[1:]

kept_rows = [header]
match_count = 0
for row in data_rows:
    if row and row[0] in targets:
        match_count += 1
    else:
        kept_rows.append(row)

print("Original total rows:", len(rows))
print("Rows deleted:", match_count)
print("Expected output rows:", len(kept_rows))

# Build a fresh workbook so deleted rows are truly gone
out_wb = Workbook()
out_ws = out_wb.active
out_ws.title = src_ws.title

for r_idx, row in enumerate(kept_rows, start=1):
    for c_idx, value in enumerate(row, start=1):
        out_ws.cell(row=r_idx, column=c_idx, value=value)

out_wb.save(output_path)

# Verify output structure and banned labels removal
verify_wb = load_workbook(output_path, read_only=True)
verify_ws = verify_wb[verify_wb.sheetnames[0]]

verified_rows = list(verify_ws.iter_rows(values_only=True))
remaining_bad = {"@9T": 0, "SAL": 0, "T9A": 0}
for row in verified_rows[1:]:
    if row and row[0] in remaining_bad:
        remaining_bad[row[0]] += 1

print("Saved:", output_path)
print("Verified max_row via data length:", len(verified_rows))
print("Header:", verified_rows[0])
print("Remaining banned labels:", remaining_bad)

final_output_path = output_path
```
