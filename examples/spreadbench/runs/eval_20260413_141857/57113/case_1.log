Code:
```repl
import os, re
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Regex for hashtags: capture text after # without the # symbol
hashtag_pattern = re.compile(r'#([A-Za-z0-9_]+)')

# Determine hashtags per row from column A (Tweet)
row_hashtags = {}
max_tags = 0
for r in range(2, ws.max_row + 1):  # preserve header row
    tweet = ws.cell(r, 1).value
    tweet = "" if tweet is None else str(tweet)
    tags = hashtag_pattern.findall(tweet)
    row_hashtags[r] = tags
    max_tags = max(max_tags, len(tags))

# Existing hashtag area starts at column B
start_col = 2
existing_max_col = ws.max_column
target_max_col = max(existing_max_col, start_col + max_tags - 1 if max_tags > 0 else start_col - 1)

# Write hashtags and clear remaining cells in the hashtag output area
for r in range(2, ws.max_row + 1):
    tags = row_hashtags[r]
    # Fill extracted hashtags
    for i, tag in enumerate(tags, start=0):
        ws.cell(r, start_col + i).value = tag
    # Clear leftover cells in the hashtag area
    for c in range(start_col + len(tags), target_max_col + 1):
        ws.cell(r, c).value = None

# Save output
wb.save(output_path)

# Verify by reloading
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]

print("Saved to:", output_path)
print("Sheet:", check_ws.title)
print("Dimensions:", check_ws.max_row, "rows x", check_ws.max_column, "cols")
for r in range(1, check_ws.max_row + 1):
    vals = [check_ws.cell(r, c).value for c in range(1, max(check_ws.max_column, 4) + 1)]
    print(f"Row {r}:", vals)
```
