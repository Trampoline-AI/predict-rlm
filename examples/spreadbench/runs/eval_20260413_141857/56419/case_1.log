Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os

# Load source workbook
src_path = input_spreadsheet
filename = os.path.basename(src_path)
out_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(src_path)
ws = wb["Sheet1"]

# Determine last data row from columns A/B
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_data_row = r
        break

# Green fill requested: #92D050 -> FF92D050 in ARGB
green_fill = PatternFill(fill_type="solid", fgColor="FF92D050")

# Replace only the output formulas in column H
for r in range(2, last_data_row + 1):
    formula = (
        f'=IFERROR(INDEX($A$2:$A${last_data_row},'
        f'SMALL(IF($B$2:$B${last_data_row}<>0,ROW($B$2:$B${last_data_row})-ROW($B$2)+1),ROWS($H$2:H{r}))),"")'
    )
    ws.cell(r, 8).value = formula
    ws.cell(r, 8).fill = green_fill

# Keep header as-is, but ensure matching background color request does not alter text
# (header already filled in source; leave unchanged)

wb.save(out_path)

# Verify saved workbook
check_wb = load_workbook(out_path)
check_ws = check_wb["Sheet1"]

print("Saved to:", out_path)
print("Last data row:", last_data_row)
for r in range(2, min(last_data_row, 8) + 1):
    c = check_ws.cell(r, 8)
    print(r, c.value, c.fill.fill_type, c.fill.fgColor.rgb)

output_spreadsheet = out_path
```
