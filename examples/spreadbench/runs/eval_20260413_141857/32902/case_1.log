from openpyxl import load_workbook
from pathlib import Path
import os

# Load workbook
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Inspect current numeric examples for consistency
print("Existing sample row 6:", ws["B6"].value, ws["C6"].value, ws["D6"].value, ws["E6"].value)
print("Existing sample row 7:", ws["B7"].value, ws["C7"].value, ws["D7"].value, ws["E7"].value)

# Fill Tier formulas for quarterly rows 6:9 so sheet is consistent.
# Tier 1: $0.15 for dollars over 60000 up to 90000
# Tier 2: $0.25 for dollars over 90000 up to 120000
# Tier 3: $0.35 for dollars over 120000
for r in range(6, 10):
    ws[f"C{r}"] = f'=IF(B{r}<=60000,0,MIN(B{r},90000)-60000)*0.15'
    ws[f"D{r}"] = f'=IF(B{r}<=90000,0,MIN(B{r},120000)-90000)*0.25'
    ws[f"E{r}"] = f'=IF(B{r}<=120000,0,B{r}-120000)*0.35'

# Save
Path(outdir).mkdir(parents=True, exist_ok=True)
wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb2 = load_workbook(outfile, data_only=False)
ws2 = wb2["Sheet1"]
print("Formulas row 8:", ws2["C8"].value, ws2["D8"].value, ws2["E8"].value, ws2["F8"].value)

wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]
for r in range(6, 11):
    print(
        r,
        wsv[f"A{r}"].value,
        wsv[f"B{r}"].value,
        wsv[f"C{r}"].value,
        wsv[f"D{r}"].value,
        wsv[f"E{r}"].value,
        wsv[f"F{r}"].value,
    )

output_spreadsheet = outfile
