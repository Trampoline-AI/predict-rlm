```repl
from openpyxl import load_workbook
from pathlib import Path
from copy import copy
import os

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
ws = wb["Sheet1"]

start_row = 4
end_row = ws.max_row

# Copy style from an existing data cell in column C
template_cell = ws.cell(start_row, 3)

for r in range(start_row, end_row + 1):
    cell = ws.cell(r, 3)
    cell.value = (
        f'=IF(A{r}<$A${start_row}+6,"n/a",'
        f'SUMIFS($B${start_row}:$B${end_row},'
        f'$A${start_row}:$A${end_row},">="&A{r}-6,'
        f'$A${start_row}:$A${end_row},"<="&A{r}))'
    )
    cell.font = copy(template_cell.font)
    cell.fill = copy(template_cell.fill)
    cell.border = copy(template_cell.border)
    cell.alignment = copy(template_cell.alignment)
    cell.protection = copy(template_cell.protection)
    cell.number_format = template_cell.number_format

wb.save(output_path)
print("Saved:", output_path, os.path.exists(output_path))

recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]

check_rows = []
for r in range(4, end_row + 1):
    check_rows.append((r, ws_check.cell(r, 1).value, ws_check.cell(r, 2).value, ws_check.cell(r, 3).value))

print("Verified rows 4-19:")
for row in check_rows:
    print(row)
```
