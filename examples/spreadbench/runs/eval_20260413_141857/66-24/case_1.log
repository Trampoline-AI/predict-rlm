import os, shutil
from copy import copy
from datetime import timedelta
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy2(infile, outfile)

wb = load_workbook(outfile)
src = wb["Imported Data"]
tgt = wb["Items Older than 30 days"]

# Determine cutoff from max date in column E
date_cells = []
for r in range(2, src.max_row + 1):
    v = src.cell(r, 5).value
    if v is not None:
        date_cells.append((r, v))

max_date = max(v for _, v in date_cells)
cutoff = max_date - timedelta(days=30)
qualifying_rows = [r for r, v in date_cells if v < cutoff]

print("Max date:", max_date)
print("Cutoff (<):", cutoff)
print("Qualifying rows:", qualifying_rows)

# Clear target sheet contents by blanking existing cells
for row in tgt.iter_rows():
    for cell in row:
        cell.value = None
        cell._style = copy(src["A1"]._style) if False else cell._style  # no-op, keep structure simple

# Copy header + qualifying rows from source to target
rows_to_copy = [1] + qualifying_rows

for out_r, src_r in enumerate(rows_to_copy, start=1):
    for c in range(1, src.max_column + 1):
        s = src.cell(src_r, c)
        d = tgt.cell(out_r, c)
        d.value = s.value
        if s.has_style:
            d._style = copy(s._style)
        if s.number_format:
            d.number_format = s.number_format
        if s.font:
            d.font = copy(s.font)
        if s.fill:
            d.fill = copy(s.fill)
        if s.border:
            d.border = copy(s.border)
        if s.alignment:
            d.alignment = copy(s.alignment)
        if s.protection:
            d.protection = copy(s.protection)

# Copy column widths for visible source columns
for col_idx in range(1, src.max_column + 1):
    col_letter = src.cell(1, col_idx).column_letter
    if col_letter in src.column_dimensions:
        tgt.column_dimensions[col_letter].width = src.column_dimensions[col_letter].width

# Delete column Z in sheet 2 after copying
tgt.delete_cols(26, 1)

wb.save(outfile)

# Verify
check_wb = load_workbook(outfile)
check_tgt = check_wb["Items Older than 30 days"]

print("Output saved:", outfile)
print("Target size after:", check_tgt.max_row, check_tgt.max_column)
print("Target row 1 first 8 cells:", [check_tgt.cell(1, c).value for c in range(1, 9)])
for r in range(1, check_tgt.max_row + 1):
    print("Row", r, [check_tgt.cell(r, c).value for c in range(1, min(check_tgt.max_column, 8) + 1)], 
          "E format:", check_tgt.cell(r, 5).number_format)

print("Column count after deleting Z:", check_tgt.max_column)
print("Last column letter now should be Y; Y1:", check_tgt["Y1"].value)
