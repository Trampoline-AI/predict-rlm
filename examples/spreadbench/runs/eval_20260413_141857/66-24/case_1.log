```repl
import os, shutil
from copy import copy
from datetime import timedelta
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy2(infile, outfile)

wb = load_workbook(outfile)
src = wb["Imported Data"]
tgt = wb["Items Older than 30 days"]

# Find max date in column E and qualifying rows (>30 days older than max date)
date_rows = []
for r in range(2, src.max_row + 1):
    v = src.cell(r, 5).value
    if v is not None:
        date_rows.append((r, v))

max_date = max(v for _, v in date_rows)
cutoff = max_date - timedelta(days=30)
qualifying_rows = [r for r, v in date_rows if v < cutoff]

print("Max date:", max_date)
print("Cutoff:", cutoff)
print("Qualifying rows:", qualifying_rows)

# Clear target sheet completely
if tgt.max_row > 0:
    tgt.delete_rows(1, tgt.max_row)

# Copy header + qualifying rows
rows_to_copy = [1] + qualifying_rows
for out_r, src_r in enumerate(rows_to_copy, start=1):
    for c in range(1, src.max_column + 1):
        s = src.cell(src_r, c)
        d = tgt.cell(out_r, c)
        d.value = s.value
        if s.has_style:
            d._style = copy(s._style)
        d.number_format = s.number_format
        d.font = copy(s.font)
        d.fill = copy(s.fill)
        d.border = copy(s.border)
        d.alignment = copy(s.alignment)
        d.protection = copy(s.protection)

# Copy source column widths to target for A:T
for col_idx in range(1, src.max_column + 1):
    col_letter = src.cell(1, col_idx).column_letter
    tgt.column_dimensions[col_letter].width = src.column_dimensions[col_letter].width

# Delete column Z in sheet 2 (target sheet)
tgt.delete_cols(26, 1)

wb.save(outfile)

# Verify
check = load_workbook(outfile)
ws = check["Items Older than 30 days"]

nonempty_rows = []
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v is not None for v in vals):
        nonempty_rows.append((r, vals[:8], ws.cell(r, 5).number_format))

print("Verified output:", outfile)
print("Sheet names:", check.sheetnames)
print("Target max_row/max_col:", ws.max_row, ws.max_column)
print("Non-empty rows found:", len(nonempty_rows))
for item in nonempty_rows:
    print(item)
print("Z exists after deletion?", ws.max_column >= 26)
```
