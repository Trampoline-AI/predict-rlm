Code:
```repl
from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Replace broken formulas in F6:H6 with a cross-compatible formula.
# Logic:
# - amount in D6:D13
# - dates in B6:B13 within the month whose first day is in F5/G5/H5
# - categories in C6:C13 must appear in criteria list F10:F14
for col in ["F", "G", "H"]:
    month_cell = f"{col}5"
    target_cell = f"{col}6"
    ws[target_cell] = (
        f'=SUMPRODUCT('
        f'($D$6:$D$13)*'
        f'($B$6:$B$13>=DATE(YEAR({month_cell}),MONTH({month_cell}),1))*'
        f'($B$6:$B$13<DATE(YEAR({month_cell}),MONTH({month_cell})+1,1))*'
        f'(COUNTIF($F$10:$F$14,$C$6:$C$13)>0)'
        f')'
    )

wb.save(outfile)
print("Saved:", outfile)

# Recalculate cached formula results
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas and values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formulas now:")
for col in ["F", "G", "H"]:
    print(col, wsf[f"{col}6"].value)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
verified = {col: wsv[f"{col}6"].value for col in ["F", "G", "H"]}
print("Verified cached values:", verified)

output_spreadsheet = outfile
```
