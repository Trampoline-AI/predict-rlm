```repl
import os, shutil
from openpyxl import load_workbook

# Inspect current formulas/styles in the target area and source area
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("A2:C11 current contents:")
for r in range(2, 12):
    vals = [ws.cell(r, c).value for c in range(1, 4)]
    nfs = [ws.cell(r, c).number_format for c in range(1, 4)]
    print(r, vals, nfs)

print("\nE1:F6 source contents:")
for r in range(1, 7):
    print(r, [ws.cell(r, c).value for c in range(5, 7)])

# Build output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Reload fresh workbook and write formulas to align source dates/values to timeline
wb2 = load_workbook(input_spreadsheet)
ws2 = wb2["Sheet1"]

# Fill B2:C11 using lookup against source data in E:F
for r in range(2, 12):
    ws2.cell(r, 2).value = f'=IFERROR(INDEX($E$2:$E$6,MATCH(A{r},$E$2:$E$6,0)),"")'
    ws2.cell(r, 3).value = f'=IFERROR(INDEX($F$2:$F$6,MATCH(A{r},$E$2:$E$6,0)),"")'

# Save
wb2.save(out_path)
print("\nSaved to:", out_path)

# Quick verify by reopening formula workbook (formula text) and data-only workbook (cached may be None before recalc)
check = load_workbook(out_path, data_only=False)
wsc = check["Sheet1"]
print("\nWritten formulas B2:C11:")
for r in range(2, 12):
    print(r, wsc.cell(r,2).value, "|", wsc.cell(r,3).value)
```
