from openpyxl.utils import column_index_from_string, get_column_letter
from pathlib import Path
import shutil, os

ws = wb["Sheet1"]

# Inspect data rows and current BE formulas/values
for r in range(1, ws.max_row + 1):
    c_val = ws[f"C{r}"].value
    be_val = ws[f"BE{r}"].value
    d_val = ws[f"D{r}"].value
    bc_val = ws[f"BC{r}"].value
    print(f"Row {r}: C={c_val!r}, D={d_val!r}, BC={bc_val!r}, BE={be_val!r}")

# Check formulas vs values by reloading with formulas visible
wb_formula = load_workbook(input_spreadsheet, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nBE formulas/contents:")
for r in range(1, ws.max_row + 1):
    print(r, repr(wsf[f"BE{r}"].value))

# Prepare output path
input_path = Path(input_spreadsheet)
output_path = Path("/sandbox/output/output_spreadsheet") / input_path.name

# Copy workbook structure by saving modified workbook
for r in range(3, ws.max_row + 1):
    if ws[f"C{r}"].value is not None:
        ws[f"BE{r}"] = f"=SUMPRODUCT(($D$2:$BC$2>=$B$2)*(D{r}:BC{r}))"

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(output_path, data_only=False)
wscf = wb_check_formula["Sheet1"]
wb_check_values = load_workbook(output_path, data_only=True)
wscv = wb_check_values["Sheet1"]

print("\nVerification rows:")
for r in range(3, ws.max_row + 1):
    if wscf[f"C{r}"].value is not None:
        print(
            r,
            "label=", wscf[f"C{r}"].value,
            "formula=", wscf[f"BE{r}"].value,
            "value=", wscv[f"BE{r}"].value,
        )

final_output_path = str(output_path)
```
