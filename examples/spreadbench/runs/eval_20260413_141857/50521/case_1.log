Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Determine data region: labels in col A, month columns from B to current max_column, customer rows start at 4
first_data_row = 4
start_col = 2  # B
end_col = ws.max_column  # currently M
start_col_letter = get_column_letter(start_col)
end_col_letter = get_column_letter(end_col)

# Add output header in N3 as indicated by the user's example in N4
output_col = end_col + 1  # N
ws.cell(row=3, column=output_col).value = "Count"

for r in range(first_data_row, ws.max_row + 1):
    row_range = f"{start_col_letter}{r}:{end_col_letter}{r}"
    formula = (
        f'=IFERROR('
        f'IF(INDEX({row_range},1,MATCH(TRUE,INDEX({row_range}<>"",0),0))>1,'
        f'1,'
        f'MATCH(TRUE,INDEX(INDEX({row_range},1,MATCH(TRUE,INDEX({row_range}<>"",0),0)+1):{end_col_letter}{r}<>"",0),0)'
        f'),'
        f'""'
        f')'
    )
    ws.cell(row=r, column=output_col).value = formula

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formula text and calculated values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

for r in range(3, wsf.max_row + 1):
    print(
        r,
        "N formula/value:",
        wsf.cell(r, output_col).value,
        "=>",
        wsv.cell(r, output_col).value
    )
```
