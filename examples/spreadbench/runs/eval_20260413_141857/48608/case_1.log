from openpyxl import load_workbook
from pathlib import Path
import os

# Reload clean workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Determine source data range from columns A:C
data_start = 2
data_end = 8  # based on inspected populated data rows

# Replace formulas in column F with a working INDEX/MATCH
for r in range(2, ws.max_row + 1):
    ws[f"F{r}"] = f'=IFERROR(INDEX($A${data_start}:$A${data_end},MATCH(G{r},$B${data_start}:$B${data_end},0)),"")'

# Save to output directory with same filename
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb.save(out_path)

print("Saved to:", out_path)

# Recalculate and verify
recalc_result = await recalculate(str(out_path))
print("Recalculate:", recalc_result)

# Verify formulas
wb_verify = load_workbook(out_path, data_only=False)
wsv = wb_verify["Sheet1"]
print("\nVerified formulas in F2:F8:")
for r in range(2, 9):
    print(r, wsv[f"F{r}"].value)

# Verify computed values
wb_values = load_workbook(out_path, data_only=True)
wsv2 = wb_values["Sheet1"]
print("\nComputed values in F2:G8:")
for r in range(2, 9):
    print(r, "F=", wsv2[f"F{r}"].value, "G=", wsv2[f"G{r}"].value)

output_spreadsheet = str(out_path)
