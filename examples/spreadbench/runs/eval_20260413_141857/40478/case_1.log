I’ll write a LibreOffice-compatible formula using `MID`, `FIND`, and `TRIM`, fill it down for all used rows, save the workbook to the output directory with the same filename, recalculate it, and verify both the formulas and the resulting values.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Apply formula to column B for all existing rows
for r in range(1, ws.max_row + 1):
    formula = f'=TRIM(MID(A{r},FIND(" ",A{r},FIND(" ",A{r})+1)+1,FIND("-",A{r})-FIND(" ",A{r},FIND(" ",A{r})+1)-1))'
    ws[f"B{r}"] = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify results
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[wb_formula.sheetnames[0]]
print("Formulas in B:")
for r in range(1, ws_formula.max_row + 1):
    print(r, ws_formula[f"A{r}"].value, "=>", ws_formula[f"B{r}"].value)

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[wb_values.sheetnames[0]]
print("Calculated values in B:")
for r in range(1, ws_values.max_row + 1):
    print(r, ws_values[f"B{r}"].value)
```
