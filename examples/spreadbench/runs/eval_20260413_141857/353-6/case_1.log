import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook normally for editing
wb2 = load_workbook(infile)
ws = wb2["Data"]

# Inspect matches in column I (excluding header)
matches = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=9).value
    if val == "Hub Notes":
        matches.append(r)

print("Original row count:", ws.max_row)
print("Matching rows to delete:", matches)
print("Match count:", len(matches))

# Delete from bottom to top
for r in reversed(matches):
    ws.delete_rows(r, 1)

# Save output
wb2.save(outfile)
print("Saved to:", outfile)

# Verify by reopening
verify_wb = load_workbook(outfile)
verify_ws = verify_wb["Data"]
remaining_matches = []
for r in range(2, verify_ws.max_row + 1):
    if verify_ws.cell(row=r, column=9).value == "Hub Notes":
        remaining_matches.append(r)

print("Verified row count:", verify_ws.max_row)
print("Remaining 'Hub Notes' rows:", remaining_matches)
print("Header preserved:", verify_ws.cell(row=1, column=9).value)
output_spreadsheet = outfile
