import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Alignment

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Folha1"]

# Define source and destination ranges
src_start, src_end = 5, 21
dst_start, dst_end = 5, 21

# Map destination columns to source columns
col_map = {
    "L": "C",  # CODE PRODUCT
    "M": "D",  # PRODUCT
    "N": "E",  # TAX
    "O": "F",  # UNIT PRICE
    "P": "G",  # PRICE TABLE
    "Q": "H",  # COMMERCIAL DISCOUNT
    "R": "I",  # QUANTITY UNITS
}

# Formula to get nth matching row where source I is non-empty.
# We use ROWS($L$5:L5) so each next row retrieves the next qualifying source record.
for r in range(dst_start, dst_end + 1):
    nth_expr = f"ROWS($L${dst_start}:L{r})"
    pos_expr = (
        f'SMALL(INDEX(($I${src_start}:$I${src_end}<>"")*'
        f'ROW($I${src_start}:$I${src_end})-{src_start-1},0),{nth_expr})'
    )
    for dst_col, src_col in col_map.items():
        ws[f"{dst_col}{r}"] = f'=IFERROR(INDEX(${src_col}${src_start}:${src_col}${src_end},{pos_expr}),"")'

# Apply formatting/alignment consistently across the whole output area
for r in range(dst_start, dst_end + 1):
    # L = code centered
    ws[f"L{r}"].alignment = Alignment(horizontal="center", vertical="center")
    # M = product left aligned
    ws[f"M{r}"].alignment = Alignment(horizontal="left", vertical="center")
    # N = tax centered (matches existing pattern)
    ws[f"N{r}"].alignment = Alignment(horizontal="center", vertical="center")
    # O:R = requested right alignment
    for col in ["O", "P", "Q", "R"]:
        ws[f"{col}{r}"].alignment = Alignment(horizontal="right", vertical="center")

    # Number formats to match existing output pattern
    ws[f"N{r}"].number_format = '0%'
    ws[f"O{r}"].number_format = '#,##0.00\\ "€"'
    ws[f"P{r}"].number_format = '#,##0.00\\ "€"'
    ws[f"Q{r}"].number_format = '0.00%'
    ws[f"R{r}"].number_format = 'General'

wb.save(output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
wsf = wb_check["Folha1"]
print("Sample formulas:")
for r in range(5, 9):
    print(r, [wsf[f"{c}{r}"].value for c in "LMNOPQR"])

wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals["Folha1"]
print("\nCached output values rows 5:10:")
for r in range(5, 11):
    print(r, [wsv[f"{c}{r}"].value for c in "LMNOPQR"])

# Count non-empty quantity rows in source to confirm expected filtered output count
qualifying = []
wb_src = load_workbook(input_path, data_only=True)
wss = wb_src["Folha1"]
for r in range(src_start, src_end + 1):
    if wss[f"I{r}"].value not in (None, ""):
        qualifying.append(r)
print("\nQualifying source rows:", qualifying, "count=", len(qualifying))

# Verify alignments requested
print("\nAlignment checks:")
for addr in ["M5", "M6", "O5", "P5", "Q5", "R5"]:
    cell = wsf[addr]
    print(addr, "alignment=", cell.alignment.horizontal, "format=", cell.number_format)
