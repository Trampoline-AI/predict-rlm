import os, shutil
from openpyxl import load_workbook

# Inspect nearby cells/styles and prepare output path
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Current A1:", ws["A1"].value)
for coord in ["A1", "A2", "B1", "B2", "C2"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

# Build output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Write LibreOffice-compatible formula to B2
ws["B2"] = '=IF(ISNUMBER(SEARCH("4Ozark",A1)),1,IF(ISNUMBER(SEARCH("3Tall",A1)),2,IF(ISNUMBER(SEARCH("1Jasper",A1)),3,IF(ISNUMBER(SEARCH("2GWood",A1)),4,IF(ISNUMBER(SEARCH("5Dawson",A1)),5,IF(ISNUMBER(SEARCH("8CPark",A1)),6,""))))))'

wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify cached result
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(out_path, data_only=False)
print("Stored formula in B2:", wb_check_formula["Sheet1"]["B2"].value)

wb_check_value = load_workbook(out_path, data_only=True)
print("Calculated B2 value:", wb_check_value["Sheet1"]["B2"].value)
output_spreadsheet = out_path
```
