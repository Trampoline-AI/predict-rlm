import os, shutil
from openpyxl import load_workbook

# Re-open workbook and inspect earlier numbering pattern in Sheet1
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Row 7:20 A/B")
for r in range(7, 21):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

print("\nNon-empty B cells near end:")
for r in range(300, 326):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    if a is not None or b not in (None, ""):
        print(r, "A=", a, "B=", b)

# Fix formula in B323: exclude B323 itself from the MAX range
old_formula = ws["B323"].value
new_formula = '=IF(A323="E","",MAX(B$7:B322)+1)'
ws["B323"] = new_formula

# Save to output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)

# Verify saved formula
wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("\nOld formula:", old_formula)
print("New formula:", ws_check["B323"].value)
print("A323:", ws_check["A323"].value)
print("B322:", ws_check["B322"].value, "B323 formula type:", ws_check["B323"].data_type)
print("Output saved:", out_path)
```
