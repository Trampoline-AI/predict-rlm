# Step 1: clear F where E is empty
cleared_f_rows = []
for r in range(1, ws.max_row + 1):
    e = ws.cell(r, 5).value
    f = ws.cell(r, 6).value
    if (e is None or e == "") and (f is not None and f != ""):
