Code:
```repl
import os
from collections import OrderedDict
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Read source data from columns A:B, rows 2..max_row
groups = OrderedDict()
for r in range(2, ws.max_row + 1):
    first = ws.cell(r, 1).value
    second = ws.cell(r, 2).value
    if first is None and second is None:
        continue
    if first not in groups:
        groups[first] = []
    groups[first].append(second)

print("Parsed groups:", groups)

# Preserve existing headers if present; otherwise set them
ws["G1"] = ws["G1"].value or "1st"
ws["H1"] = ws["H1"].value or "Occurances"
ws["I1"] = ws["I1"].value or "2nd ->"

# Clear old output region G: last needed column for all existing rows below header
max_second_count = max((len(v) for v in groups.values()), default=0)
clear_end_col = max(ws.max_column, 8 + max_second_count)  # G=7, H=8, values start I=9
for r in range(2, ws.max_row + 1):
    for c in range(7, clear_end_col + 1):
        ws.cell(r, c).value = None

# Write grouped output starting at row 3 to match demonstrated layout
start_row = 3
for idx, (first, seconds) in enumerate(groups.items(), start=start_row):
    ws.cell(idx, 7).value = first         # G
    ws.cell(idx, 8).value = len(seconds)  # H
    for j, val in enumerate(seconds, start=9):  # I onward
        ws.cell(idx, j).value = val

# Save
wb.save(outfile)

# Verify by reopening
check_wb = load_workbook(outfile)
check_ws = check_wb[check_wb.sheetnames[0]]

print("Saved to:", outfile)
print("Verification rows G:N")
for r in range(1, min(check_ws.max_row, start_row + len(groups) + 1)):
    vals = [check_ws.cell(r, c).value for c in range(7, 15)]
    print(r, vals)

output_spreadsheet = outfile
```
