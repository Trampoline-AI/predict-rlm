import os

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Populate B14:B17 with INDEX/MATCH formulas based on the value in each A-row
for row in range(14, 18):
    ws[f"B{row}"] = f"=INDEX($B$1:$B$4,MATCH(A{row},$A$1:$A$4,0))"

# Save to output path with same filename
