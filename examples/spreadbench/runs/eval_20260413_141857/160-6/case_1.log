import os, json, textwrap
from openpyxl import load_workbook

print("Input:", input_spreadsheet)
wb = load_workbook(input_spreadsheet)
print("Sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\nSheet: {ws.title}")
    print("  max_row:", ws.max_row, "max_col:", ws.max_column)
    # Find used rows/cols roughly
    nonempty_rows = []
    for r in range(1, min(ws.max_row, 30) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
        nonempty_rows.append(vals)
    print("  Sample first rows:")
    for i, vals in enumerate(nonempty_rows[:12], start=1):
        print("   ", i, vals)

# Also inspect for VBA-related text strings anywhere in workbook
hits = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                low = v.lower()
                if any(k in low for k in ["sub ", "end sub", "rows(", "entirerow", "macro", "delete", "blank rows", "sh", "cp"]):
                    hits.append((ws.title, cell.coordinate, v[:200]))
print("\nPotential code/text hits:", len(hits))
for hit in hits[:20]:
    print(hit)
