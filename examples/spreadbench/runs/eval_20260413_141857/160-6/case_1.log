Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook normally
wb = load_workbook(infile)
ws = wb["SH"]

# Read all rows, keep non-blank rows only
all_rows = list(ws.iter_rows())
nonblank_rows = []
for row in all_rows:
    values = [cell.value for cell in row]
    if any(v is not None and v != "" for v in values):
        nonblank_rows.append(values)

print("Original rows:", ws.max_row)
print("Nonblank rows kept:", len(nonblank_rows))

# Rewrite the sheet contents compactly without gaps.
# Preserve existing cell styles/formatting by only clearing and rewriting values.
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

for r_idx, rowvals in enumerate(nonblank_rows, start=1):
    for c_idx, val in enumerate(rowvals, start=1):
        ws.cell(r_idx, c_idx).value = val

wb.save(outfile)

# Verify output
wb2 = load_workbook(outfile)
ws2 = wb2["SH"]
sample = []
for r in range(1, min(ws2.max_row, 12) + 1):
    sample.append([ws2.cell(r, c).value for c in range(1, min(ws2.max_column, 8) + 1)])

# Find blank rows within the used range up to last nonblank row
last_nonblank = 0
for r in range(1, ws2.max_row + 1):
    vals = [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)]
    if any(v is not None and v != "" for v in vals):
        last_nonblank = r

internal_blank_rows = []
for r in range(1, last_nonblank + 1):
    vals = [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)]
    if not any(v is not None and v != "" for v in vals):
        internal_blank_rows.append(r)

print("Saved to:", outfile)
print("Last nonblank row after cleanup:", last_nonblank)
print("Internal blank rows remaining:", internal_blank_rows)
print("Sample rows after cleanup:")
for i, row in enumerate(sample, start=1):
    print(i, row)
```
