from openpyxl import load_workbook
from copy import copy
import os

# Re-open workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect header row and styles around target column
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
for coord in ["E1", "F1", "H1", "E2", "F2", "H2", "H3", "H4"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

# Fill Total ability formulas in column H for all data rows below header through max_row
for r in range(2, ws.max_row + 1):
    if r == 2:
        ws.cell(r, 8).value = f'=IF(OR(B{r}="",C{r}=""),"",B{r}*(1+C{r}))'
    else:
        ws.cell(r, 8).value = f'=IF(OR(B{r}="",C{r}=""),"", (H{r-1}+B{r})*(1+C{r}))'
    # Copy style from F column to H if H is blank-style/inconsistent
    src = ws.cell(r, 6)
    dst = ws.cell(r, 8)
    dst.number_format = src.number_format
    dst.font = copy(src.font)
    dst.fill = copy(src.fill)
    dst.border = copy(src.border)
    dst.alignment = copy(src.alignment)
    dst.protection = copy(src.protection)

# Save to output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
result = await recalculate(out_path)
print("Recalc:", result)

wb2 = load_workbook(out_path, data_only=False)
ws2 = wb2["Sheet1"]
print("Formulas in H2:H6:")
for r in range(2, 7):
    print(r, ws2.cell(r, 8).value)

wb3 = load_workbook(out_path, data_only=True)
ws3 = wb3["Sheet1"]
print("Computed H2:H5:", [ws3.cell(r, 8).value for r in range(2, 6)])
