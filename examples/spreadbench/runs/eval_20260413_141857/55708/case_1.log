Code:
```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Build averages from source table above the "Calculations" section.
allowed_statuses = {"In Progress", "In Review"}
dept_values = defaultdict(list)

for r in range(2, 9):  # source data rows
    dept = ws.cell(r, 1).value
    status = ws.cell(r, 2).value
    tat = ws.cell(r, 3).value
    if dept is None:
        continue
    if status in allowed_statuses and isinstance(tat, (int, float)) and tat >= 6:
        dept_values[dept].append(tat)

# Fill existing calculations table
for r in range(11, ws.max_row + 1):
    dept = ws.cell(r, 1).value
    target = ws.cell(r, 2)
    vals = dept_values.get(dept, [])
    if vals:
        target.value = sum(vals) / len(vals)
    else:
        target.value = None
    target.number_format = "General"

wb.save(output_path)

# Verify saved output
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Saved:", output_path, os.path.exists(output_path))
for r in range(9, 14):
    print(r, [check_ws.cell(r, c).value for c in range(1, 4)])
```
