import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws = wb["Test"]

# Update formulas in G3:G58
for r in range(3, 59):
    ws[f"G{r}"] = f'=IF(E{r}=D{r},M{r},IFERROR(VLOOKUP(C{r},DATA!$A:$E,5,0),""))'

wb.save(output_path)

# Re-open and verify formulas
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb["Test"]

print("Saved to:", output_path)
for r in [3, 4, 5, 58]:
    print(r, check_ws[f"G{r}"].value)

# Also inspect neighboring cells for example row 5
