from openpyxl import load_workbook
import os

# Paths
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook
wb = load_workbook(infile)
ws_in = wb["INPUT"]
ws_out = wb["OUPUT"]  # sheet name as it exists in workbook

# Mapping for ORIGIN values
origin_map = {
    "UNATIDE STATES AMERICAN": "USA",
    "FRANCE": "FRA",
    "KOREA": "KOR",
    "GERMANY": "GR",
    "ITALY": "IT",
}

# Ensure header remains as-is in output, then populate rows from INPUT
for r in range(2, ws_in.max_row + 1):
    item = ws_in.cell(r, 1).value      # ITEM
    brands = ws_in.cell(r, 3).value    # BRANDS
    typ = ws_in.cell(r, 5).value       # TYPE
    origin = ws_in.cell(r, 6).value    # ORIGIN
    
    ws_out.cell(r, 1).value = item
    ws_out.cell(r, 2).value = brands
    ws_out.cell(r, 3).value = typ
    ws_out.cell(r, 4).value = origin_map.get(origin, origin)

# Save output
wb.save(outfile)

# Verify saved workbook
check_wb = load_workbook(outfile)
check_ws = check_wb["OUPUT"]
print("Saved to:", outfile)
print("Output sheet dimensions:", check_ws.max_row, "rows x", check_ws.max_column, "cols")
for row in check_ws.iter_rows(min_row=1, max_row=check_ws.max_row, min_col=1, max_col=4, values_only=True):
    print(row)
```
