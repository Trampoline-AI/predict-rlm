import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))
shutil.copy2(input_path, output_path)

wb = load_workbook(output_path)
ws = wb["Sheet1"]

# Fill rows 2-6 with working formulas.
# C: convert last 6 chars like "Oct 21" into a real date (1st of that month),
# add one month, then display as "MMM YY"
for r in range(2, 7):
    ws[f"C{r}"] = (
        f'=TEXT(EDATE(DATE(2000+RIGHT(A{r},2),'
        f'MATCH(LEFT(RIGHT(A{r},6),3),{{"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"}},0),'
        f'1),1),"MMM YY")'
    )
    # D: extract the 2-digit year from the final 6 characters
    ws[f"D{r}"] = f'=RIGHT(A{r},2)'
    # E: extract the month abbreviation from the final 6 characters
    ws[f"E{r}"] = f'=LEFT(RIGHT(A{r},6),3)'

wb.save(output_path)
print("Saved:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
wsf = wb_check["Sheet1"]
print("Formulas C2:E6")
for r in range(2, 7):
    print(r, wsf[f"C{r}"].value, wsf[f"D{r}"].value, wsf[f"E{r}"].value)

wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals["Sheet1"]
print("Cached values C2:E6")
for r in range(2, 7):
    print(r, wsv[f"C{r}"].value, wsv[f"D{r}"].value, wsv[f"E{r}"].value)

final_output_path = output_path
```
