import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load fresh workbook
wb2 = load_workbook(input_path)
ws = wb2["Sheet1"]

# Find last used row in column A
last_row = 0
for r in range(ws.max_row, 0, -1):
    if ws.cell(r, 1).value not in (None, ""):
        last_row = r
        break

# Apply the intended corrected logic:
# starting at row 4 (below header), delete rows whose Column A is blank
rows_to_delete = []
for r in range(4, last_row + 1):
    if ws.cell(r, 1).value in (None, ""):
        rows_to_delete.append(r)

print("Last used row in A:", last_row)
print("Rows to delete:", rows_to_delete[:10], "...", rows_to_delete[-3:] if rows_to_delete else [])

for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

wb2.save(output_path)
print("Saved to:", output_path)

# Verify output
check_wb = load_workbook(output_path)
check_ws = check_wb["Sheet1"]
print("Output max_row:", check_ws.max_row)
for r in range(1, check_ws.max_row + 1):
    vals = [check_ws.cell(r, c).value for c in range(1, 8)]
    print(r, vals)
