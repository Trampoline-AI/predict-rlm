```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
collection_name = "COLLECTION"
src_sheet_names = [s for s in wb.sheetnames if s != collection_name]

# ---------- helpers ----------
def norm_num(v):
    if v is None or v == "":
        return None
    if isinstance(v, str):
        t = v.strip()
        if t in {"-", ""}:
            return None
        try:
            return float(t)
        except:
            return None
    if isinstance(v, (int, float)):
        return float(v)
    return None

def apply_common_font(cell, color=None):
    cell.font = Font(
        name="Calibri",
        size=11,
        bold=False,
        italic=cell.font.italic,
        vertAlign=cell.font.vertAlign,
        underline=cell.font.underline,
        strike=cell.font.strike,
        color=color
    )

def set_alignment_by_col(cell, col_idx, is_header=False):
    if is_header:
        cell.alignment = copy(cell.alignment)
        cell.alignment = Alignment(
            horizontal="left",
            vertical=cell.alignment.vertical if cell.alignment and cell.alignment.vertical else "bottom",
            text_rotation=cell.alignment.textRotation if cell.alignment else 0,
            wrap_text=cell.alignment.wrapText if cell.alignment else None,
            shrink_to_fit=cell.alignment.shrinkToFit if cell.alignment else None,
            indent=cell.alignment.indent if cell.alignment else 0,
        )
    else:
        horiz = "right" if col_idx in [1, 5, 6, 7] else "left"
        cell.alignment = copy(cell.alignment)
        cell.alignment = Alignment(
            horizontal=horiz,
            vertical=cell.alignment.vertical if cell.alignment and cell.alignment.vertical else "bottom",
            text_rotation=cell.alignment.textRotation if cell.alignment else 0,
            wrap_text=cell.alignment.wrapText if cell.alignment else None,
            shrink_to_fit=cell.alignment.shrinkToFit if cell.alignment else None,
            indent=cell.alignment.indent if cell.alignment else 0,
        )

# ---------- aggregate source data by (TY, OR) ----------
agg = {}
order_seen = []

for sname in src_sheet_names:
    ws = wb[sname]
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    hmap = {str(h).strip().upper(): i+1 for i, h in enumerate(headers) if h is not None}

    required = ["BR", "TY", "OR"]
    if not all(k in hmap for k in required):
        continue

    for r in range(2, ws.max_row + 1):
        br = ws.cell(r, hmap["BR"]).value
        ty = ws.cell(r, hmap["TY"]).value
        orv = ws.cell(r, hmap["OR"]).value
        if ty is None or orv is None:
            continue
        key = (str(ty), str(orv))
        if key not in agg:
            agg[key] = {
                "BR": br,
                "TY": ty,
                "OR": orv,
                "sale_sum": 0.0,
                "ret_sum": 0.0,
                "sale_count": 0,
                "ret_count": 0,
            }
            order_seen.append(key)

        if "SALE" in hmap:
            v = norm_num(ws.cell(r, hmap["SALE"]).value)
            if v is not None:
                agg[key]["sale_sum"] += v
                agg[key]["sale_count"] += 1

        if "RET" in hmap:
            v = norm_num(ws.cell(r, hmap["RET"]).value)
            if v is not None:
                agg[key]["ret_sum"] += v
                agg[key]["ret_count"] += 1

# ---------- update collection ----------
ws = wb[collection_name]
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
cmap = {str(h).strip().upper(): i+1 for i, h in enumerate(headers) if h is not None}

# ensure BALANCE header exists in col 7 or append if needed
if "BALANCE" not in cmap:
    bal_col = ws.max_column + 1
    ws.cell(1, bal_col).value = "BALANCE"
    cmap["BALANCE"] = bal_col
else:
    bal_col = cmap["BALANCE"]

# existing collection keys in order
existing_keys = []
key_to_row = {}
for r in range(2, ws.max_row + 1):
    ty = ws.cell(r, cmap["TY"]).value
    orv = ws.cell(r, cmap["OR"]).value
    if ty is None or orv is None:
        continue
    key = (str(ty), str(orv))
    existing_keys.append(key)
    key_to_row[key] = r

# update existing rows from aggregates
for key in existing_keys:
    r = key_to_row[key]
    data = agg.get(key, None)

    sale_present = data is not None and data["sale_count"] > 0
    ret_present = data is not None and data["ret_count"] > 0
    sale_sum = data["sale_sum"] if data is not None else 0.0
    ret_sum = data["ret_sum"] if data is not None else 0.0

    ws.cell(r, cmap["SALE"]).value = sale_sum if sale_present else "-"
    ws.cell(r, cmap["RET"]).value = ret_sum if ret_present else "-"
    balance_val = sale_sum - ret_sum
    ws.cell(r, bal_col).value = balance_val

# append missing keys in source order
existing_key_set = set(existing_keys)
next_item = 1
# base next item from collection col A numeric max
item_vals = []
for r in range(2, ws.max_row + 1):
    v = norm_num(ws.cell(r, cmap["ITEM"]).value)
    if v is not None:
        item_vals.append(int(v))
next_item = (max(item_vals) + 1) if item_vals else 1

template_row = ws.max_row  # use current last row style as template

for key in order_seen:
    if key in existing_key_set:
        continue
    data = agg[key]
    new_r = ws.max_row + 1

    # copy style from template row across used columns
    for c in range(1, max(ws.max_column, bal_col) + 1):
        src = ws.cell(template_row, c)
        dst = ws.cell(new_r, c)
        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.protection:
            dst.protection = copy(src.protection)
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.font:
            dst.font = copy(src.font)
        if src.fill:
            dst.fill = copy(src.fill)
        if src.border:
            dst.border = copy(src.border)

    ws.cell(new_r, cmap["ITEM"]).value = next_item
    ws.cell(new_r, cmap["BR"]).value = data["BR"]
    ws.cell(new_r, cmap["TY"]).value = data["TY"]
    ws.cell(new_r, cmap["OR"]).value = data["OR"]
    ws.cell(new_r, cmap["SALE"]).value = data["sale_sum"] if data["sale_count"] > 0 else "-"
    ws.cell(new_r, cmap["RET"]).value = data["ret_sum"] if data["ret_count"] > 0 else "-"
    ws.cell(new_r, bal_col).value = data["sale_sum"] - data["ret_sum"]

    next_item += 1

# ---------- formatting ----------
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)

        # unbold + Calibri 11 + red if negative numeric
        color = None
        if r > 1 and isinstance(cell.value, (int, float)) and cell.value < 0:
            color = "FF0000"
        apply_common_font(cell, color=color)

        # alignment
        set_alignment_by_col(cell, c, is_header=(r == 1))

# keep headers text exactly and ensure not bold
for c in range(1, ws.max_column + 1):
    ws.cell(1, c).font = Font(
        name="Calibri",
        size=11,
        bold=False,
        color=ws.cell(1, c).font.color.rgb if ws.cell(1, c).font.color and ws.cell(1, c).font.color.type == "rgb" else None
    )

# save
wb.save(outfile)

# ---------- verify ----------
check_wb = load_workbook(outfile)
cws = check_wb[collection_name]

print("Saved:", outfile)
print("Rows/Cols:", cws.max_row, cws.max_column)
for r in range(1, cws.max_row + 1):
    vals = [cws.cell(r, c).value for c in range(1, cws.max_column + 1)]
    print(r, vals)

# style/value checks
print("Header alignments:", [cws.cell(1, c).alignment.horizontal for c in range(1, cws.max_column + 1)])
print("Header bold:", [cws.cell(1, c).font.bold for c in range(1, cws.max_column + 1)])
print("Row2 aligns:", [cws.cell(2, c).alignment.horizontal for c in range(1, cws.max_column + 1)])
# find negative cells
neg_cells = []
for r in range(2, cws.max_row + 1):
    for c in range(1, cws.max_column + 1):
        v = cws.cell(r, c).value
        if isinstance(v, (int, float)) and v < 0:
            neg_cells.append((cws.cell(r, c).coordinate, v, cws.cell(r, c).font.color.type if cws.cell(r, c).font.color else None, cws.cell(r, c).font.color.rgb if cws.cell(r, c).font.color and cws.cell(r, c).font.color.type == "rgb" else None))
print("Negative cells:", neg_cells)
```
