Code:
```repl
import os, calendar, math
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Inspect relevant cells/styles
for coord in ["B3", "B8", "B9", "B11", "M11", "A11"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

year = ws["B3"].value
months = [ws.cell(row=8, column=c).value for c in range(2, 14)]
counts = [ws.cell(row=9, column=c).value for c in range(2, 14)]

print("Year:", year)
print("Months:", months)
print("Counts:", counts)

month_abbr_to_num = {calendar.month_abbr[i]: i for i in range(1, 13)}

results = []
for idx, month_name in enumerate(months, start=2):
    mnum = month_abbr_to_num[month_name]
    days = calendar.monthrange(int(year), mnum)[1]
    count = ws.cell(row=9, column=idx).value or 0
    val = count / days

    # Decide display format
    if val == 0:
        numfmt = "0"
    else:
        # If value has exactly one decimal place and that digit is non-zero
        one_dec = round(val, 1)
        if abs(val - one_dec) < 1e-12 and int(round(abs(val) * 10)) % 10 != 0:
            numfmt = "0.0"
        else:
            numfmt = "0.000000000"

    cell = ws.cell(row=11, column=idx)
    cell.value = val
    cell.number_format = numfmt
    results.append((month_name, count, days, val, numfmt))

# Preserve filename, save to output
wb.save(outfile)

print("Saved to:", outfile)
for item in results:
    print(item)

# Verify by reopening
wb2 = load_workbook(outfile)
ws2 = wb2["Sheet1"]
verify = []
for c in range(2, 14):
    cell = ws2.cell(row=11, column=c)
    verify.append((cell.coordinate, cell.value, cell.number_format))
print("Verification:")
for row in verify:
    print(row)
```
