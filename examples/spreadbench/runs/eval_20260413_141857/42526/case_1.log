Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from pathlib import Path

# Re-open workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect all data values
values = [ws[f"A{r}"].value for r in range(2, 17)]
print("Values:", values)

pos_max = 41
neg_min = -18  # smallest value
neg_abs = abs(neg_min)

def score_value(v):
    if v is None:
        return None
    if v > 0:
        return v / pos_max * 5
    elif v < 0:
        return v / neg_abs * 5
    else:
        return 0

scores = [score_value(v) for v in values]
print("Scores:", scores)

# Ranking: highest score gets rank 1
sorted_scores_desc = sorted(scores, reverse=True)
rank_map = {}
rank = 1
for s in sorted_scores_desc:
    if s not in rank_map:
        rank_map[s] = rank
    rank += 1

ranks = [rank_map[s] for s in scores]
print("Ranks:", ranks)

# Fill color for B2:B16
fill = PatternFill(fill_type="solid", start_color="A6A6A6", end_color="A6A6A6")

def choose_number_format(x):
    # whole number
    if abs(x - round(x)) < 1e-12:
        return "0;-0;0"
    # exactly one decimal place needed
    if abs(x * 10 - round(x * 10)) < 1e-10:
        return "0.0;-0.0;0.0"
    # otherwise 11 decimals
    return "0.00000000000;-0.00000000000;0.00000000000"

for idx, row in enumerate(range(2, 17)):
    s = scores[idx]
    rnk = ranks[idx]
    bcell = ws.cell(row=row, column=2)
    ccell = ws.cell(row=row, column=3)
    bcell.value = s
    bcell.fill = fill
    bcell.number_format = choose_number_format(s)
    ccell.value = rnk
    ccell.number_format = "0"

# Save output
out_path = Path("/sandbox/output/output_spreadsheet") / Path(input_spreadsheet).name
wb.save(out_path)

print("Saved to:", out_path)

# Verify written values and formats
wb2 = load_workbook(out_path)
ws2 = wb2["Sheet1"]
for r in range(2, 17):
    print(
        r,
        ws2[f"A{r}"].value,
        ws2[f"B{r}"].value,
        ws2[f"B{r}"].number_format,
        ws2[f"C{r}"].value,
        ws2[f"B{r}"].fill.start_color.rgb
    )
```
