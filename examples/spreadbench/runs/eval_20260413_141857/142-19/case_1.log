Code:
```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# detect contiguous non-blank blocks using columns A:B, starting after row 1
blocks = []
start = None
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    nonblank = (a is not None and str(a) != "") or (b is not None and str(b) != "")
    if nonblank and start is None:
        start = r
    elif not nonblank and start is not None:
        blocks.append((start, r - 1))
        start = None
if start is not None:
    blocks.append((start, ws.max_row))

def is_header_row(val_a, val_b):
    return str(val_a).strip().lower() == "number" and str(val_b).strip().lower() == "name"

for start, end in blocks:
    rows = []
    for r in range(start, end + 1):
        # preserve all columns in the row, not just A:B
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        rows.append(row_vals)
    
    header = None
    data_rows = rows
    if rows and is_header_row(rows[0][0], rows[0][1]):
        header = rows[0]
        data_rows = rows[1:]
    
    # sort by column A text A->Z; keep full row intact
    data_rows_sorted = sorted(
        data_rows,
        key=lambda row: ("" if row[0] is None else str(row[0]))
    )
    
    new_rows = ([header] if header is not None else []) + data_rows_sorted
    
    # write back
    for i, row_vals in enumerate(new_rows, start=start):
        for c, val in enumerate(row_vals, start=1):
            ws.cell(i, c).value = val

wb.save(outfile)

# verify output
wb2 = load_workbook(outfile)
ws2 = wb2[wb2.sheetnames[0]]

verification = []
for start, end in blocks:
    block_rows = []
    for r in range(start, min(end, start + 6) + 1):
        block_rows.append((r, ws2.cell(r,1).value, ws2.cell(r,2).value))
    verification.append((start, end, block_rows))

print("Saved:", outfile)
for item in verification:
    print(item)
```
