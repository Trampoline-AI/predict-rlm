from openpyxl import load_workbook
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Identify contiguous non-blank blocks based on columns A and B
blocks = []
start = None
for r in range(2, ws.max_row + 1):  # assume row 1 is header
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    nonblank = (a is not None and str(a) != "") or (b is not None and str(b) != "")
    if nonblank and start is None:
        start = r
    elif not nonblank and start is not None:
        blocks.append((start, r - 1))
        start = None
if start is not None:
    blocks.append((start, ws.max_row))

print("Detected blocks:", blocks)
for start, end in blocks:
    sample = []
    for r in range(start, min(end, start + 5) + 1):
        sample.append((r, ws.cell(r,1).value, ws.cell(r,2).value))
    print(f"Block {start}-{end}, rows={end-start+1}, sample={sample}")
