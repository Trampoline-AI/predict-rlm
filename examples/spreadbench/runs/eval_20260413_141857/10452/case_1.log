Plan:
1. Load the workbook.
2. Write helper formulas in F4:F15 that number only the rows in B that start with `PK`.
3. Write result formulas in E4:E15 that return the 1st, 2nd, 3rd, etc. PK entry by matching that helper number.
4. Hide the helper column F so the visible layout remains clean.
5. Save to the output directory with the same filename.
6. Recalculate and verify the resulting values in column E.
Code:
```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws = wb["Sheet1"]

start_row = 4
end_row = ws.max_row  # 15 based on inspection

# Put helper formulas in column F to create a running sequence for PK-only rows.
# F4 should be 1 if B4 starts with PK, else blank.
# Subsequent rows increment only when the B cell starts with PK.
for r in range(start_row, end_row + 1):
    if r == start_row:
        ws[f"F{r}"] = '=IF(LEFT(B4,2)="PK",1,"")'
    else:
        ws[f"F{r}"] = f'=IF(LEFT(B{r},2)="PK",COUNTIF($B$4:B{r},"PK*"),"")'

# Fill result formulas in column E.
# This returns the nth PK entry from column B, where n is the row count in E starting at E4.
for r in range(start_row, end_row + 1):
    ws[f"E{r}"] = f'=IFERROR(INDEX($B$4:$B${end_row},MATCH(ROWS($E$4:E{r}),$F$4:$F${end_row},0)),"")'

# Keep helper column out of sight
ws.column_dimensions["F"].hidden = True

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("Formulas E4:E15:")
for r in range(4, end_row + 1):
    print(r, ws_check[f"E{r}"].value)

wb_vals = load_workbook(output_path, data_only=True)
ws_vals = wb_vals["Sheet1"]
print("\nCalculated values E4:E15:")
for r in range(4, end_row + 1):
    print(r, ws_vals[f"E{r}"].value)

output_spreadsheet = output_path
```
