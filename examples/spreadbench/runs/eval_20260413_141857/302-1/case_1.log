Code:
```repl
import os
from openpyxl import load_workbook

# Load workbook
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)

items_ws = wb["ITEMS"]
sheet1_ws = wb["SHEET1"]
sheet2_ws = wb["SHEET2"]

# Replace column B in SHEET1 and SHEET2 with ITEMS column B, row by row, starting at row 2
for target_ws in [sheet1_ws, sheet2_ws]:
    max_common_row = min(items_ws.max_row, target_ws.max_row)
    for r in range(2, max_common_row + 1):
        target_ws.cell(row=r, column=2).value = items_ws.cell(row=r, column=2).value

# Save output
wb.save(outfile)

# Verify against provided result sheets
verify_wb = load_workbook(outfile, data_only=False)
v_sheet1 = verify_wb["SHEET1"]
v_sheet2 = verify_wb["SHEET2"]
res1 = verify_wb["result sheet1"]
res2 = verify_wb["result sheet2"]

sheet1_matches = []
for r in range(1, min(v_sheet1.max_row, res1.max_row) + 1):
    sheet1_matches.append(v_sheet1.cell(r, 2).value == res1.cell(r, 2).value)

sheet2_matches = []
for r in range(1, min(v_sheet2.max_row, res2.max_row) + 1):
    sheet2_matches.append(v_sheet2.cell(r, 2).value == res2.cell(r, 2).value)

print("Saved to:", outfile)
print("SHEET1 column B matches result sheet1:", all(sheet1_matches), sheet1_matches)
print("SHEET2 column B matches result sheet2:", all(sheet2_matches), sheet2_matches)

output_spreadsheet = outfile
```
