Code:
```repl
from openpyxl import load_workbook
import os
from copy import copy

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
combined = wb["combined"]

source_sheets = [name for name in wb.sheetnames if name != "combined"]
combined_headers = [combined.cell(1, c).value for c in range(1, combined.max_column + 1)]

print("Source sheets:", source_sheets)
print("Combined headers:", combined_headers)

# Ensure headers align; if not, map by name from source header to combined header.
# Clear any existing data rows below header.
if combined.max_row > 1:
    for r in range(2, combined.max_row + 1):
        for c in range(1, combined.max_column + 1):
            combined.cell(r, c).value = None

out_row = 2
written_counts = {}

for sname in source_sheets:
    ws = wb[sname]
    src_headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    header_to_src_col = {h: i+1 for i, h in enumerate(src_headers)}
    count = 0
    
    for r in range(2, ws.max_row + 1):
        # copy values by matching combined headers
        for out_col, header in enumerate(combined_headers, start=1):
            src_col = header_to_src_col.get(header)
            val = ws.cell(r, src_col).value if src_col else None
            combined.cell(out_row, out_col).value = val
            
            # preserve basic number/date formatting from source where possible
            if src_col:
                src_cell = ws.cell(r, src_col)
                dst_cell = combined.cell(out_row, out_col)
                if src_cell.has_style:
                    dst_cell._style = copy(src_cell._style)
                if src_cell.number_format:
                    dst_cell.number_format = src_cell.number_format
                if src_cell.font:
                    dst_cell.font = copy(src_cell.font)
                if src_cell.fill:
                    dst_cell.fill = copy(src_cell.fill)
                if src_cell.border:
                    dst_cell.border = copy(src_cell.border)
                if src_cell.alignment:
                    dst_cell.alignment = copy(src_cell.alignment)
                if src_cell.protection:
                    dst_cell.protection = copy(src_cell.protection)
        out_row += 1
        count += 1
    written_counts[sname] = count

wb.save(output_path)

# Verify output
wb2 = load_workbook(output_path, data_only=False)
combined2 = wb2["combined"]
total_expected = sum(written_counts.values())

print("Written counts by sheet:", written_counts)
print("Expected total data rows:", total_expected)
print("Combined max_row:", combined2.max_row)
print("Combined max_col:", combined2.max_column)

for r in range(1, min(combined2.max_row, 6) + 1):
    print(f"Combined row {r}:", [combined2.cell(r, c).value for c in range(1, min(combined2.max_column, 10) + 1)])

final_output_path = output_path
```
