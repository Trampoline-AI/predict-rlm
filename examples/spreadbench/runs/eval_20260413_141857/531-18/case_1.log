```repl
import os, shutil
from copy import copy
from openpyxl import load_workbook
from datetime import datetime

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
ws_data = wb["Data"]
ws_t = wb["Transpose"]

# Read source structure
headers = [ws_data.cell(6, c).value for c in range(1, ws_data.max_column + 1)]
date_cols = [(c, v) for c, v in enumerate(headers, start=1) if isinstance(v, datetime)]
item_rows = [r for r in range(7, ws_data.max_row + 1) if ws_data.cell(r, 1).value is not None]

# Capture simple style references from existing transpose sheet if present
header_styles = {}
data_styles = {}
for c in range(1, 4):
    cell = ws_t.cell(2, c)
    header_styles[c] = {
        "font": copy(cell.font),
        "fill": copy(cell.fill),
        "border": copy(cell.border),
        "alignment": copy(cell.alignment),
        "number_format": cell.number_format,
        "protection": copy(cell.protection),
    }

for c in range(1, 4):
    sample_row = 3 if ws_t.max_row >= 3 else 2
    cell = ws_t.cell(sample_row, c)
    data_styles[c] = {
        "font": copy(cell.font),
        "fill": copy(cell.fill),
        "border": copy(cell.border),
        "alignment": copy(cell.alignment),
        "number_format": cell.number_format,
        "protection": copy(cell.protection),
    }

# Clear existing transpose values (all cells)
for row in ws_t.iter_rows():
    for cell in row:
        cell.value = None

# Restore header area to match template layout
ws_t["A2"] = "ITEM"
ws_t["B2"] = "Date"
ws_t["C2"] = "Qty's"

for c in range(1, 4):
    cell = ws_t.cell(2, c)
    st = header_styles[c]
    cell.font = copy(st["font"])
    cell.fill = copy(st["fill"])
    cell.border = copy(st["border"])
    cell.alignment = copy(st["alignment"])
    cell.number_format = st["number_format"]
    cell.protection = copy(st["protection"])

# Write transposed data
out_row = 3
for r in item_rows:
    item = ws_data.cell(r, 1).value
    for c, dt in date_cols:
        qty = ws_data.cell(r, c).value
        ws_t.cell(out_row, 1).value = item
        ws_t.cell(out_row, 2).value = dt
        ws_t.cell(out_row, 3).value = qty

        # Apply basic styles from template/sample row
        for col in range(1, 4):
            target = ws_t.cell(out_row, col)
            st = data_styles[col]
            target.font = copy(st["font"])
            target.fill = copy(st["fill"])
            target.border = copy(st["border"])
            target.alignment = copy(st["alignment"])
            target.protection = copy(st["protection"])
            # Keep sensible number formats
            if col == 2:
                target.number_format = data_styles[col]["number_format"] or "m/d/yyyy"
            elif col == 3:
                target.number_format = data_styles[col]["number_format"] or "0"
            else:
                target.number_format = data_styles[col]["number_format"]
        out_row += 1

# Save workbook
wb.save(output_path)

# Verify output
check_wb = load_workbook(output_path)
check_t = check_wb["Transpose"]

nonblank_rows = []
for r in range(1, check_t.max_row + 1):
    vals = [check_t.cell(r, c).value for c in range(1, 4)]
    if any(v is not None for v in vals):
        nonblank_rows.append((r, vals))

print("Saved to:", output_path)
print("Transpose dimensions:", check_t.max_row, "rows x", check_t.max_column, "cols")
print("Expected data rows:", len(item_rows) * len(date_cols))
print("Nonblank row count:", len(nonblank_rows))
print("First 8 nonblank rows:")
for x in nonblank_rows[:8]:
    print(x)
print("Last 5 nonblank rows:")
for x in nonblank_rows[-5:]:
    print(x)

output_spreadsheet = output_path
```
