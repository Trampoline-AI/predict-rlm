I should fill `Foglio1!G:P` for every populated row based on the ID in column `E`. To handle rows with fewer than 10 matches robustly, I’ll right-align the available results so the most recent value lands under header `1` in column `P`, leaving earlier slots blank. For rows with 10+ matches, this produces the same layout as the examples. Then I’ll save to the required output path and verify several rows.
Code:
```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws_data = wb["DATI"]
ws = wb["Foglio1"]

# Build lookup: ID in K -> list of TOT values from J, in source row order
lookup = defaultdict(list)
for r in range(2, ws_data.max_row + 1):
    tot = ws_data.cell(r, 10).value  # J
    ig = ws_data.cell(r, 11).value   # K
    if ig is not None:
        lookup[ig].append(tot)

# Fill G:P based on ID in E
for r in range(2, ws.max_row + 1):
    ig = ws.cell(r, 5).value  # E
    vals = lookup.get(ig, [])
    last10 = vals[-10:]  # keep source order
    
    # Clear existing contents in G:P first
    for c in range(7, 17):
        ws.cell(r, c).value = None
    
    # Right-align if fewer than 10, so most recent lands in P (header 1)
    start_col = 17 - len(last10)  # if 10 items => 7; if 3 items => 14
    for i, v in enumerate(last10):
        ws.cell(r, start_col + i).value = v

wb.save(outfile)
print("Saved:", outfile)

# Verify key rows
wb2 = load_workbook(outfile, data_only=True)
ws2 = wb2["Foglio1"]
for r in range(2, min(ws2.max_row, 10) + 1):
    print("row", r, "ID", ws2.cell(r, 5).value, "G:P", [ws2.cell(r, c).value for c in range(7, 17)])
```
