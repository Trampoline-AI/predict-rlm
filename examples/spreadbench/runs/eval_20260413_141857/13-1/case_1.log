```repl
from openpyxl import load_workbook
from copy import copy
from datetime import datetime
from collections import OrderedDict
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
wsr = wb["RANGES"]
wsl = wb["LISTS"]

def is_blank_row(ws, r, max_col=6):
    return all(ws.cell(r, c).value is None for c in range(1, max_col + 1))

def get_blocks(ws, title_col=3, header_row_offset=1):
    blocks = OrderedDict()
    for r in range(1, ws.max_row + 1):
        title = ws.cell(r, title_col).value
        if isinstance(title, str) and title.strip() and title.strip().upper() not in ("REF", "DATE", "AMOUNTS", "BATCH", "SN", "S.N"):
            # identify title rows by requiring next row to look like a header
            next_vals = [ws.cell(r + 1, c).value for c in range(1, min(ws.max_column, 5) + 1)] if r + 1 <= ws.max_row else []
            next_vals_norm = [str(v).strip().upper() if v is not None else None for v in next_vals]
            if "DATE" in next_vals_norm and ("REF" in next_vals_norm) and ("AMOUNTS" in next_vals_norm):
                blocks[title.strip()] = {"title_row": r, "header_row": r + header_row_offset}
    return blocks

ranges_blocks = get_blocks(wsr)
lists_blocks = get_blocks(wsl)

print("RANGES blocks:", ranges_blocks)
print("LISTS blocks:", lists_blocks)

def normalize_date(v):
    if v is None:
        return None
    if isinstance(v, datetime):
        return datetime(v.year, v.month, v.day)
    if isinstance(v, str):
        s = v.strip()
        for fmt in ("%m/%d/%Y", "%m/%d/%y", "%Y-%m-%d", "%d/%m/%Y", "%d-%m-%Y"):
            try:
                d = datetime.strptime(s, fmt)
                return datetime(d.year, d.month, d.day)
            except:
                pass
    return v

def parse_source_block(ws, block_name, title_row, header_row):
    # data starts after header until two consecutive blank rows or next title/header area
    start = header_row + 1
    rows = []
    r = start
    while r <= ws.max_row:
        # stop if next title row encountered at col C with following header
        val_c = ws.cell(r, 3).value
        next_vals = [ws.cell(r + 1, c).value for c in range(1, min(ws.max_column, 5) + 1)] if r + 1 <= ws.max_row else []
        next_vals_norm = [str(v).strip().upper() if v is not None else None for v in next_vals]
        if isinstance(val_c, str) and val_c.strip() and ("DATE" in next_vals_norm and "REF" in next_vals_norm and "AMOUNTS" in next_vals_norm):
            break
        if is_blank_row(ws, r):
            # if blank row, stop once next nonblank seems like another title or after blank gap
            # since source blocks are contiguous in this file, we can end at first blank
            break
        date_val = ws.cell(r, 2).value
        ref_val = ws.cell(r, 4).value
        amt_val = ws.cell(r, 5).value
        if date_val is not None and ref_val is not None and amt_val is not None:
            rows.append((normalize_date(date_val), ref_val, amt_val))
        r += 1
    return rows

def group_rows(rows):
    grouped = OrderedDict()
    for date_val, ref_val, amt_val in rows:
        key = (date_val, ref_val)
        if key not in grouped:
            grouped[key] = 0
        grouped[key] += amt_val
    result = []
    sn = 1
    for (date_val, ref_val), total_amt in grouped.items():
        result.append((sn, date_val, ref_val, total_amt))
        sn += 1
    return result

# Build summaries from RANGES
summaries = {}
for name, info in ranges_blocks.items():
    src_rows = parse_source_block(wsr, name, info["title_row"], info["header_row"])
    summaries[name] = group_rows(src_rows)
    print(f"{name}: source_rows={len(src_rows)} grouped_rows={len(summaries[name])} sample={summaries[name][:5]}")

# destination block boundaries in LISTS
list_names = list(lists_blocks.keys())
for i, name in enumerate(list_names):
    start_row = lists_blocks[name]["header_row"] + 1
    end_row = (lists_blocks[list_names[i + 1]]["title_row"] - 1) if i + 1 < len(list_names) else wsl.max_row
    lists_blocks[name]["data_start"] = start_row
    lists_blocks[name]["data_end"] = end_row

# capture basic styles/number formats from stage rows to reuse
date_fmt = wsl["B3"].number_format
amt_fmt = wsl["D3"].number_format
sn_style = copy(wsl["A3"]._style)
date_style = copy(wsl["B3"]._style)
ref_style = copy(wsl["C3"]._style)
amt_style = copy(wsl["D3"]._style)
total_style = copy(wsl["A10"]._style)

# clear and write each matching block in LISTS
for name, info in lists_blocks.items():
    rows = summaries.get(name, [])
    start_row = info["data_start"]
    end_row = info["data_end"]
    
    # clear old area
    for r in range(start_row, end_row + 1):
        for c in range(1, 5):
            wsl.cell(r, c).value = None
    
    # write grouped data
    current = start_row
    for sn, date_val, ref_val, amt in rows:
        wsl.cell(current, 1).value = sn
        wsl.cell(current, 2).value = date_val
        wsl.cell(current, 3).value = ref_val
        wsl.cell(current, 4).value = amt
        
        wsl.cell(current, 1)._style = copy(sn_style)
        wsl.cell(current, 2)._style = copy(date_style)
        wsl.cell(current, 3)._style = copy(ref_style)
        wsl.cell(current, 4)._style = copy(amt_style)
        wsl.cell(current, 2).number_format = date_fmt
        wsl.cell(current, 4).number_format = amt_fmt
        current += 1
    
    # write TOTAL row
    wsl.cell(current, 1).value = "TOTAL"
    wsl.cell(current, 1)._style = copy(total_style)
    if rows:
        wsl.cell(current, 4).value = f"=SUM(D{start_row}:D{current-1})"
    else:
        wsl.cell(current, 4).value = 0
    wsl.cell(current, 4)._style = copy(amt_style)
    wsl.cell(current, 4).number_format = amt_fmt
    
    print(f"Wrote block {name}: rows {len(rows)}, total row at {current}")

wb.save(outfile)

# recalc and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb2 = load_workbook(outfile, data_only=False)
wb2v = load_workbook(outfile, data_only=True)
wsv = wb2v["LISTS"]
wsf = wb2["LISTS"]

print("\nVerification LISTS rows:")
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 5)]
    if any(v is not None for v in vals):
        print(r, vals)

print("\nFormula cells check:")
for r in range(1, wsf.max_row + 1):
    if wsf.cell(r, 1).value == "TOTAL":
        print("Row", r, "formula:", wsf.cell(r, 4).value, "cached:", wsv.cell(r, 4).value)

output_spreadsheet = outfile
```
