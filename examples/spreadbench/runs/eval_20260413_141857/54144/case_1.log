import os, shutil
from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet)
data_ws = wb["Data"]
report_ws = wb["Report"]

# Inspect exact report rows with coordinates
for r in range(1, report_ws.max_row + 1):
    vals = [report_ws.cell(r, c).value for c in range(1, report_ws.max_column + 1)]
    print(r, vals)

# Build output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Write a LibreOffice-compatible formula into Report column D for each data row
# Match whole truck IDs inside a comma-separated string in C, ignoring spaces.
for r in range(3, report_ws.max_row + 1):
    formula = (
        f'=SUMPRODUCT((Data!$A$3:$A$17=A{r})*(Data!$B$3:$B$17=B{r})*'
        f'ISNUMBER(SEARCH(","&Data!$C$3:$C$17&",", ","&SUBSTITUTE(C{r}," ","")&",")),'
        f'Data!$D$3:$D$17)'
    )
    report_ws.cell(r, 4).value = formula

wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
recalc_status = await recalculate(out_path)
print("Recalc:", recalc_status)

wb_check_formula = load_workbook(out_path, data_only=False)
wb_check_values = load_workbook(out_path, data_only=True)

print("Formulas in Report D3:D10:")
for r in range(3, wb_check_formula["Report"].max_row + 1):
    print(r, wb_check_formula["Report"].cell(r, 4).value)

print("Cached values in Report D3:D10:")
for r in range(3, wb_check_values["Report"].max_row + 1):
    print(r, wb_check_values["Report"].cell(r, 4).value)

output_spreadsheet = out_path
