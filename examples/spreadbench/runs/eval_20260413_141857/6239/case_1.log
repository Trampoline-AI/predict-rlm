import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Sheet1"]

# Populate formulas for dynamic setup
for r in range(2, 24):  # employee rows
    # Variance to Goal
    ws[f"E{r}"] = f'=1-(C{r}/D{r})'
    
    # Eligibility
    ws[f"B{r}"] = f'=IF(E{r}<0,"Not Eligible","Eligible")'
    
    # Incentive lookup
    ws[f"G{r}"] = (
        f'=IF(B{r}="Not Eligible",0,'
        f'INDEX($P$3:$T$6,'
        f'MATCH(E{r},INDEX($J$3:$M$6,0,MATCH(MAX(MIN(D{r},$M$2),$J$2),$J$2:$M$2,1)),1),'
        f'MATCH(MAX(F{r},$P$2),$P$2:$T$2,1)'
        f'))'
    )

# Match percentage formatting from neighboring cells
for r in range(2, 24):
    ws[f"E{r}"].number_format = ws[f"D{r}"].number_format
    ws[f"G{r}"].number_format = ws["P3"].number_format if ws["P3"].number_format != "General" else "0%"

wb.save(outfile)
print("Saved:", outfile)

# Recalculate to populate cached values
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify values from recalculated workbook
wbv = load_workbook(outfile, data_only=False)
wsv = wbv["Sheet1"]
wbvals = load_workbook(outfile, data_only=True)
wsv2 = wbvals["Sheet1"]

print("Verification sample:")
for r in range(2, 12):
    print(
        r,
        {
            "Employee": wsv2[f"A{r}"].value,
            "Achieved": wsv2[f"C{r}"].value,
            "Goal": wsv2[f"D{r}"].value,
            "Variance_formula": wsv[f"E{r}"].value,
            "Variance_value": wsv2[f"E{r}"].value,
            "Eligibility": wsv2[f"B{r}"].value,
            "Metric2": wsv2[f"F{r}"].value,
            "Incentive_formula": wsv[f"G{r}"].value,
            "Incentive_value": wsv2[f"G{r}"].value,
        }
    )
