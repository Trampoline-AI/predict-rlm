Code:
```repl
import os
from openpyxl import load_workbook

print("FULL INSTRUCTION:")
print(instruction)

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Formula:
# - if more than one of C:D:E is filled, flag as ERROR
# - else pick first nonblank among C, D, E
# - else fall back to B
for r in range(2, ws.max_row + 1):
    formula = f'=IF(COUNTIF(C{r}:E{r},"<>")>1,"ERROR",IF(C{r}<>"",C{r},IF(D{r}<>"",D{r},IF(E{r}<>"",E{r},B{r}))))'
    ws[f"F{r}"] = formula

wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[wb_formula.sheetnames[0]]
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[wb_values.sheetnames[0]]

print("\nVerification rows 2-15: B:H with F formula/result")
for r in range(2, ws_formula.max_row + 1):
    print({
        "row": r,
        "B": ws_formula[f"B{r}"].value,
        "C": ws_formula[f"C{r}"].value,
        "D": ws_formula[f"D{r}"].value,
        "E": ws_formula[f"E{r}"].value,
        "F_formula": ws_formula[f"F{r}"].value,
        "F_value": ws_values[f"F{r}"].value,
        "H": ws_formula[f"H{r}"].value,
    })
```
