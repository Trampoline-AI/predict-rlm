from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)

for ws in wb.worksheets:
    print(f"--- {ws.title} ---")
    print("Dimensions:", ws.max_row, ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    for i, h in enumerate(headers, start=1):
        print(i, get_column_letter(i), repr(h))
    # inspect non-empty cells in first few rows/cols
    nonempty = []
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                nonempty.append((cell.coordinate, cell.value))
    print("Non-empty count:", len(nonempty))
    print("First 20 non-empty:", nonempty[:20])
    print()

# Compare sheets header equality
s1 = wb[wb.sheetnames[0]]
s2 = wb[wb.sheetnames[1]]
print("Headers identical:", [s1.cell(1,c).value for c in range(1,s1.max_column+1)] == [s2.cell(1,c).value for c in range(1,s2.max_column+1)])
