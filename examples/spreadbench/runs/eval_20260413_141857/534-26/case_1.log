Code:
```repl
from openpyxl import load_workbook
from copy import copy
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

wb = load_workbook(input_path)
ws_src = wb["Sheet1"]
ws_result = wb["Result"]

# Build list of headers from Result sheet; use these as the kept columns/order.
result_headers = [ws_result.cell(1, c).value for c in range(1, ws_result.max_column + 1)]
sheet1_headers = [ws_src.cell(1, c).value for c in range(1, ws_src.max_column + 1)]

header_to_col = {sheet1_headers[c-1]: c for c in range(1, ws_src.max_column + 1)}
keep_cols = [header_to_col[h] for h in result_headers if h in header_to_col]

print("Sheet1 cols before:", ws_src.max_column)
print("Result cols:", ws_result.max_column)
print("Keep cols count:", len(keep_cols))
print("First few kept headers:", result_headers[:10])

# Snapshot source data/styles for kept columns
max_row = ws_src.max_row
kept_cells = {}
for new_c_idx, old_c_idx in enumerate(keep_cols, start=1):
    for r in range(1, max_row + 1):
        old_cell = ws_src.cell(r, old_c_idx)
        kept_cells[(r, new_c_idx)] = {
            "value": old_cell.value,
            "has_style": old_cell.has_style,
            "font": copy(old_cell.font),
            "fill": copy(old_cell.fill),
            "border": copy(old_cell.border),
            "alignment": copy(old_cell.alignment),
            "number_format": old_cell.number_format,
            "protection": copy(old_cell.protection),
        }

# Clear existing cells in Sheet1
for row in ws_src.iter_rows():
    for cell in row:
        cell.value = None
        cell._style = copy(cell._style)

# Write back only kept columns
for (r, c), payload in kept_cells.items():
    cell = ws_src.cell(r, c)
    cell.value = payload["value"]
    if payload["has_style"]:
        cell.font = payload["font"]
        cell.fill = payload["fill"]
        cell.border = payload["border"]
        cell.alignment = payload["alignment"]
        cell.number_format = payload["number_format"]
        cell.protection = payload["protection"]

# Delete extra columns at the end
if ws_src.max_column > len(keep_cols):
    ws_src.delete_cols(len(keep_cols) + 1, ws_src.max_column - len(keep_cols))

# Copy column widths for visible kept columns based on original positions
for new_c_idx, old_c_idx in enumerate(keep_cols, start=1):
    old_letter = ws_src.cell(1, old_c_idx).column_letter if old_c_idx <= ws_src.max_column else None

# Since deleting columns changes letters, reload widths from original workbook instead
wb_orig = load_workbook(input_path)
ws_orig = wb_orig["Sheet1"]
for new_c_idx, old_c_idx in enumerate(keep_cols, start=1):
    new_letter = ws_src.cell(1, new_c_idx).column_letter
    old_letter = ws_orig.cell(1, old_c_idx).column_letter
    if old_letter in ws_orig.column_dimensions:
        ws_src.column_dimensions[new_letter].width = ws_orig.column_dimensions[old_letter].width

wb.save(output_path)

# Verify
check = load_workbook(output_path)
s1 = check["Sheet1"]
sr = check["Result"]
s1_headers_after = [s1.cell(1, c).value for c in range(1, s1.max_column + 1)]
sr_headers = [sr.cell(1, c).value for c in range(1, sr.max_column + 1)]

print("Saved:", output_path)
print("Sheet1 cols after:", s1.max_column)
print("Headers match Result:", s1_headers_after == sr_headers)

output_spreadsheet = str(output_path)
```
