I'll use `SUMPRODUCT` with `ISNUMBER(SEARCH(...))`, which is LibreOffice-compatible and handles substring matching in comma-separated tags.
Code:
```repl
import os
from openpyxl import load_workbook

# Re-open and inspect full relevant region
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 10)]
    print(r, vals)

# Apply formula to all search terms in column H, writing results in column I
# Date bounds are in E4:F4, and source data is A3:C15 (bounded to actual data rows)
start_data_row = 3
end_data_row = ws.max_row

for r in range(4, ws.max_row + 1):
    term = ws[f"H{r}"].value
    if term not in (None, ""):
        ws[f"I{r}"] = (
            f'=SUMPRODUCT(($A${start_data_row}:$A${end_data_row}>=$E$4)*'
            f'($A${start_data_row}:$A${end_data_row}<=$F$4)*'
            f'(ISNUMBER(SEARCH(H{r},$B${start_data_row}:$B${end_data_row})))*'
            f'($C${start_data_row}:$C${end_data_row}))'
        )

out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check["Sheet1"]
for r in range(4, ws_check.max_row + 1):
    if ws_check[f"H{r}"].value not in (None, ""):
        print(r, ws_check[f"H{r}"].value, ws_check[f"I{r}"].value)

wb_vals = load_workbook(out_path, data_only=True)
ws_vals = wb_vals["Sheet1"]
print("Computed values:")
for r in range(4, ws_vals.max_row + 1):
    if ws_vals[f"H{r}"].value not in (None, ""):
        print(r, ws_vals[f"H{r}"].value, ws_vals[f"I{r}"].value)

output_spreadsheet = out_path
```
