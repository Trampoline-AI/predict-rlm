import os
from openpyxl import load_workbook

# Load fresh workbook for editing
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb_edit = load_workbook(input_path)
ws = wb_edit[wb_edit.sheetnames[0]]

current_company = None
for r in range(1, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    if a_val not in (None, ""):
        current_company = a_val
    ws.cell(r, 3).value = current_company

wb_edit.save(output_path)

# Verify saved output
wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Saved to:", output_path)
print("Dimensions after save:", ws_check.max_row, "rows x", ws_check.max_column, "cols")
for r in range(1, ws_check.max_row + 1):
    if r <= 15 or r >= 50:
        print(r, [ws_check.cell(r, c).value for c in range(1, 4)])

# Quick block checks
checks = {
    "C1:C10": [ws_check.cell(r, 3).value for r in range(1, 11)],
    "C11:C19": [ws_check.cell(r, 3).value for r in range(11, 20)],
    "C20:C31": [ws_check.cell(r, 3).value for r in range(20, 32)],
    "C32:C43": [ws_check.cell(r, 3).value for r in range(32, 44)],
    "C44:C55": [ws_check.cell(r, 3).value for r in range(44, 56)],
}
for k, v in checks.items():
    print(k, "unique values:", sorted(set(v)))
```
