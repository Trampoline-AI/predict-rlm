Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load and modify
wb2 = load_workbook(input_path)
ws = wb2[wb2.sheetnames[0]]  # Sheet1

deleted_rows = []
for r in range(ws.max_row, 1, -1):  # keep row 1 blank
    cell = ws.cell(r, 3)
    if not (cell.data_type == 'e' and cell.value == '#N/A'):
        ws.delete_rows(r, 1)
        deleted_rows.append(r)

wb2.save(output_path)

# Verify output
wb_check = load_workbook(output_path)
ws_check = wb_check[wb_check.sheetnames[0]]
remaining_c = [(r, ws_check.cell(r, 3).value, ws_check.cell(r, 3).data_type) for r in range(1, ws_check.max_row + 1)]

print("Saved to:", output_path)
print("Deleted count:", len(deleted_rows))
print("Output Sheet1 rows:", ws_check.max_row, "cols:", ws_check.max_column)
print("Remaining column C values/types:", remaining_c)

# Compare to reference sheet values for confidence
ref = wb_check["Desired Sheet1 after delrow2"]
same_rows = ws_check.max_row == ref.max_row
same_cols = ws_check.max_column == ref.max_column
same_all = True
for r in range(1, max(ws_check.max_row, ref.max_row) + 1):
    for c in range(1, max(ws_check.max_column, ref.max_column) + 1):
        if ws_check.cell(r, c).value != ref.cell(r, c).value:
            same_all = False
            print("First value mismatch at", r, c, ws_check.cell(r, c).value, ref.cell(r, c).value)
            raise SystemExit
print("Reference match:", same_rows, same_cols, same_all)

output_spreadsheet = output_path
```
