```repl
from openpyxl import load_workbook
from copy import copy
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws_prob = wb["problem"]
ws_res = wb["result"]

# Build transformed rows
out_rows = []
for r in range(1, ws_prob.max_row + 1):
    label = ws_prob.cell(r, 1).value
    raw = ws_prob.cell(r, 2).value
    if label is None:
        continue
    if raw is None or str(raw).strip() == "":
        out_rows.append((label, None))
    else:
        parts = [p.strip() for p in str(raw).splitlines()]
        parts = [p for p in parts if p != ""]
        if parts:
            for p in parts:
                out_rows.append((label, p))
        else:
            out_rows.append((label, None))

print("Transformed row count:", len(out_rows))
print("Preview first 10:", out_rows[:10])
print("Preview last 10:", out_rows[-10:])

# Capture template formatting from existing result sheet
style_a = copy(ws_res["A1"]._style)
style_b = copy(ws_res["B1"]._style)
font_a = copy(ws_res["A1"].font)
font_b = copy(ws_res["B1"].font)
fill_a = copy(ws_res["A1"].fill)
fill_b = copy(ws_res["B1"].fill)
border_a = copy(ws_res["A1"].border)
border_b = copy(ws_res["B1"].border)
align_a = copy(ws_res["A1"].alignment)
align_b = copy(ws_res["B1"].alignment)
numfmt_a = ws_res["A1"].number_format
numfmt_b = ws_res["B1"].number_format
prot_a = copy(ws_res["A1"].protection)
prot_b = copy(ws_res["B1"].protection)

# Clear existing cells in used area generously
max_clear_rows = max(ws_res.max_row, len(out_rows)) + 20
for r in range(1, max_clear_rows + 1):
    for c in range(1, 3):
        ws_res.cell(r, c).value = None
        # apply baseline style so cleared/written area stays consistent
        if c == 1:
            ws_res.cell(r, c)._style = copy(style_a)
            ws_res.cell(r, c).font = copy(font_a)
            ws_res.cell(r, c).fill = copy(fill_a)
            ws_res.cell(r, c).border = copy(border_a)
            ws_res.cell(r, c).alignment = copy(align_a)
            ws_res.cell(r, c).number_format = numfmt_a
            ws_res.cell(r, c).protection = copy(prot_a)
        else:
            ws_res.cell(r, c)._style = copy(style_b)
            ws_res.cell(r, c).font = copy(font_b)
            ws_res.cell(r, c).fill = copy(fill_b)
            ws_res.cell(r, c).border = copy(border_b)
            ws_res.cell(r, c).alignment = copy(align_b)
            ws_res.cell(r, c).number_format = numfmt_b
            ws_res.cell(r, c).protection = copy(prot_b)

# Write transformed output into result sheet in-place
for i, (label, value) in enumerate(out_rows, start=1):
    ws_res.cell(i, 1).value = label
    ws_res.cell(i, 2).value = value

# Preserve row height pattern
template_height = ws_res.row_dimensions[1].height
for i in range(1, len(out_rows) + 1):
    ws_res.row_dimensions[i].height = template_height

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Verify by reopening
wb_check = load_workbook(output_path)
ws_check = wb_check["result"]
print("Verified dimensions:", ws_check.max_row, ws_check.max_column)
for r in range(1, ws_check.max_row + 1):
    print(r, [ws_check.cell(r, c).value for c in range(1, 3)])

final_output_path = output_path
```
