from openpyxl import load_workbook
from copy import copy
import os

input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))

# Reload original workbook cleanly
wb = load_workbook(input_path)
ws_prob = wb["problem"]
ws_res = wb["result"]

# Build transformed rows from problem sheet
out_rows = []
for r in range(1, ws_prob.max_row + 1):
    label = ws_prob.cell(r, 1).value
    raw = ws_prob.cell(r, 2).value
    if label is None:
        continue
    if raw is None or str(raw).strip() == "":
        out_rows.append((label, None))
    else:
        parts = [p.strip() for p in str(raw).splitlines() if p.strip() != ""]
        if parts:
            for p in parts:
                out_rows.append((label, p))
        else:
            out_rows.append((label, None))

# Template styles from existing result cells
style_a = copy(ws_res["A1"]._style)
style_b = copy(ws_res["B1"]._style)
height_1 = ws_res.row_dimensions[1].height
width_a = ws_res.column_dimensions["A"].width
width_b = ws_res.column_dimensions["B"].width

# Clear just existing used values (avoid creating extra styled rows)
for r in range(1, ws_res.max_row + 1):
    for c in range(1, ws_res.max_column + 1):
        ws_res.cell(r, c).value = None

# Write exact output
