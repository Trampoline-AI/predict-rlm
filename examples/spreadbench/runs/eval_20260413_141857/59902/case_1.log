Code:
```repl
from openpyxl import load_workbook
from pathlib import Path

outfile = Path("/sandbox/output/output_spreadsheet") / Path(input_spreadsheet).name

wb = load_workbook(outfile)
ws = wb["Sheet1"]

# Explicitly fix first ascending-row edge case
ws["C5"] = ""

# Use a guarded ascending-order formula for remaining rows
for r in range(6, ws.max_row + 1):
    prev = r - 1
    ws[f"C{r}"] = (
        f'=IF(COUNTIF($B$5:B{prev},B{r})=0,"",'
        f'A{r}-LOOKUP(2,1/($B$5:B{prev}=B{r}),$A$5:A{prev}))'
    )

wb.save(outfile)
print("Resaved", outfile)

rc = await recalculate(str(outfile))
print("Recalc:", rc)

# Verify again
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["Sheet1"]
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]

last_seen = {}
mismatches = []
for r in range(5, wsv.max_row + 1):
    dt = wsv[f"A{r}"].value
    name = wsv[f"B{r}"].value
    exp = None if name not in last_seen else (dt - last_seen[name]).days
    calc = wsv[f"C{r}"].value
    if calc != exp and not ((calc is None or calc == "") and exp is None):
        mismatches.append((r, name, calc, exp))
    last_seen[name] = dt

print("C5 formula/value:", wsf["C5"].value, wsv["C5"].value)
print("Sample formulas C6:C10:")
for r in range(6, 11):
    print(r, wsf[f"C{r}"].value)

print("Mismatch count:", len(mismatches))
print("Mismatches:", mismatches[:10])

output_spreadsheet = str(outfile)
```
