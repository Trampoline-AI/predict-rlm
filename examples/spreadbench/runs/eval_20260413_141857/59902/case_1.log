outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / filename

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Inspect actual data rows on ascending side
rows = []
for r in range(5, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    rows.append((r, a, b))
print("Ascending data rows:", len(rows))
print("First 8 rows:", rows[:8])
print("Last 5 rows:", rows[-5:])

# Replace formulas in C5:Cmax with ascending-compatible formula
for r in range(5, ws.max_row + 1):
    prior_end = r - 1
    ws[f"C{r}"] = f'=IFERROR(A{r}-LOOKUP(2,1/($B$5:B{prior_end}=B{r}),$A$5:A{prior_end}),"")'

