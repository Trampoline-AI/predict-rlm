from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
print("Sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\nSheet: {ws.title}")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Print first 10 rows and up to first 8 columns
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
        print(r, vals)
        
    # Print row 1 headers with column letters for wider inspection
    headers = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(1, c).value
        if v is not None:
            headers.append((get_column_letter(c), v))
    print("Headers row1:", headers[:20])
