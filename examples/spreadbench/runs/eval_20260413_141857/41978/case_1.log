from openpyxl import load_workbook
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Cumulative"]

# Put open-case count formulas in column I for each year listed in column G
for row in range(2, 12):  # G2:G11 contains years 2013-2022
    ws.cell(row=row, column=9).value = f'=COUNTIFS($G$14:$G$185,G{row},$J$14:$J$185,"Open")'

# Save with same filename in output directory
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

print("Saved to:", output_path)

# Recalculate formulas and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Cumulative"]
print("Formulas in I2:I11:")
for row in range(2, 12):
    print(row, ws_check[f"I{row}"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Cumulative"]
print("Cached values in I2:I11:")
for row in range(2, 12):
    print(row, ws_values[f"G{row}"].value, ws_values[f"I{row}"].value)

output_spreadsheet = output_path
