from openpyxl import load_workbook
from pathlib import Path
import os, shutil

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Put priority-extraction formula into Column C for data rows
for row in range(3, ws.max_row + 1):
    ws.cell(row=row, column=3).value = f'=IFERROR(MID(B{row},SEARCH("955",B{row}),10),IFERROR(MID(B{row},SEARCH("CHK",B{row}),10),""))'

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas and verify
recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Sheet1"]

verification = []
for row in range(2, wsf.max_row + 1):
    verification.append({
        "row": row,
        "description": wsf.cell(row=row, column=2).value,
        "formula_or_value_C": wsf.cell(row=row, column=3).value,
        "cached_C": wsv.cell(row=row, column=3).value,
    })

print("Verification:")
for item in verification:
    print(item)

final_output_path = str(output_path)
```
