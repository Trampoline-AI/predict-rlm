import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook and target sheet
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Populate requested table Log Value column using matches from the basic table
# Requested: A=Stock, B=Year
# Basic:     H=Stock, G=Year, I=Log Value
for r in range(3, ws.max_row + 1):
    if ws[f"A{r}"].value is not None and ws[f"B{r}"].value is not None:
        ws[f"C{r}"] = f'=SUMIFS($I$3:$I$18,$H$3:$H$18,A{r},$G$3:$G$18,B{r})'

wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas and verify results
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

