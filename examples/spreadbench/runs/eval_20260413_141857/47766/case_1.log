from openpyxl.utils import get_column_letter
from datetime import datetime

ws = wb[wb.sheetnames[0]]

print("Rentals source rows 8:37 (A:H):")
for r in range(8, 38):
    vals = [ws.cell(r, c).value for c in range(1, 9)]
    print(r, vals)

print("\nNearby yearly tables / formulas around J6:O18 for pattern:")
for r in range(6, 19):
    vals = []
    for c in range(10, 16):
        vals.append(f"{get_column_letter(c)}{r}={ws.cell(r,c).value}")
    print(" | ".join(vals))

# Build formulas for yearly totals table J39:O53
# Using year boundaries in K:O rows 43,48,53
# Fill K:N with interval sums [K,L), [L,M), [M,N), [N,O)
# Leave O blank on data rows because it is the upper boundary, not a full interval.

sections = [
    # title row start, data rows, boundary row, agent code
    (39, [40, 41, 42], 43, "PE"),
    (44, [45, 46, 47], 48, "GS"),
    (49, [50, 51, 52], 53, "CC"),
]

# Mapping data row -> source row range
source_ranges = {
    40: (8, 37),   45: (8, 37),   50: (8, 37),   # Rentals
    41: (41, 58),  46: (41, 58),  51: (41, 58),  # Sales
    42: (62, 74),  47: (62, 74),  52: (62, 74),  # Commercial
}

# Clear/fill formulas
for _, data_rows, boundary_row, agent in sections:
    for row in data_rows:
        start_src, end_src = source_ranges[row]
        for c in range(11, 15):  # K:N
            start_col = get_column_letter(c)
            end_col = get_column_letter(c + 1)
            formula = (
                f'=SUMIFS($C${start_src}:$C${end_src},'
                f'$H${start_src}:$H${end_src},"*{agent}*",'
                f'$F${start_src}:$F${end_src},">="&{start_col}${boundary_row},'
                f'$F${start_src}:$F${end_src},"<"&{end_col}${boundary_row})'
            )
            ws.cell(row, c).value = formula
        ws.cell(row, 15).value = None  # O column blank for data rows

print("\nUpdated target area J39:O53 formulas:")
for r in range(39, 54):
    vals = []
    for c in range(10, 16):
        vals.append(f"{get_column_letter(c)}{r}={ws.cell(r,c).value}")
    print(" | ".join(vals))

