from openpyxl import load_workbook
from copy import copy
import os
from collections import Counter

input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))

wb = load_workbook(input_path)
cons = wb["Consolidate_ALL"]

# Source yellow-highlighted columns mapped to Consolidate_ALL A:K
source_cols = [1, 3, 4, 5, 6, 7, 14, 15, 16, 17, 18]  # A,C,D,E,F,G,N,O,P,Q,R

def mapped_values(ws, r):
    return tuple(ws.cell(r, c).value for c in source_cols)

def cons_values(ws, r):
    return tuple(ws.cell(r, c).value for c in range(1, 12))  # A:K

def is_blank_row(ws, r, start_col=1, end_col=12):
    return all(ws.cell(r, c).value in (None, "") for c in range(start_col, end_col + 1))

# Existing consolidated data by sheet name
existing_by_sheet = {"Jack": set(), "Henry": set(), "Richard": set()}
for r in range(2, cons.max_row + 1):
    row_vals = [cons.cell(r, c).value for c in range(1, 13)]
    if any(v not in (None, "") for v in row_vals):
        sheet_name = cons.cell(r, 12).value
        if sheet_name in existing_by_sheet:
            existing_by_sheet[sheet_name].add(tuple(row_vals[:11]))

# Determine missing rows from each sheet
missing_rows = []
for sheet_name in ["Jack", "Henry", "Richard"]:
    ws = wb[sheet_name]
    for r in range(2, ws.max_row + 1):
        vals = mapped_values(ws, r)
        if vals not in existing_by_sheet[sheet_name]:
            missing_rows.append((sheet_name, r, vals))

print("Missing rows by source sheet:", Counter(x[0] for x in missing_rows))
print("First few missing row refs:", [(x[0], x[1]) for x in missing_rows[:10]])

# Find first blank row in Consolidate_ALL A:L
target_row = None
for r in range(1, cons.max_row + 5000):
    if is_blank_row(cons, r, 1, 12):
        target_row = r
        break
print("First blank target row:", target_row)

# Use row 2 as formatting template for data rows
template_row = 2

# Append missing rows
start_row = target_row
for sheet_name, src_row, vals in missing_rows:
    # Write A:K values
    for out_c, value in enumerate(vals, start=1):
        cell = cons.cell(target_row, out_c)
        cell.value = value
        tmpl = cons.cell(template_row, out_c)
        cell.font = copy(tmpl.font)
        cell.border = copy(tmpl.border)
        cell.fill = copy(tmpl.fill)      # keeps consolidated data-row no-fill style
        cell.number_format = tmpl.number_format
        cell.protection = copy(tmpl.protection)
        cell.alignment = copy(tmpl.alignment)

    # Write L sheet name
    cell = cons.cell(target_row, 12)
    cell.value = sheet_name
    tmpl = cons.cell(template_row, 12)
    cell.font = copy(tmpl.font)
    cell.border = copy(tmpl.border)
    cell.fill = copy(tmpl.fill)
    cell.number_format = tmpl.number_format
    cell.protection = copy(tmpl.protection)
    cell.alignment = copy(tmpl.alignment)

    # Match row height from template data row
    if cons.row_dimensions[template_row].height is not None:
        cons.row_dimensions[target_row].height = cons.row_dimensions[template_row].height

    target_row += 1

# Preserve column widths already present; no need to change

wb.save(output_path)
print("Saved to:", output_path)
print("Rows appended:", len(missing_rows), "from row", start_row, "to", target_row - 1)

# Verify by reopening
wb2 = load_workbook(output_path)
cons2 = wb2["Consolidate_ALL"]

counts = Counter()
