Code:
```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws_sh1 = wb["SH1"]
ws_rp1 = wb["RP1"]
ws_merge = wb["merging"]

def build_lookup(ws):
    lookup = {}
    for r in range(2, ws.max_row + 1):
        item_id = ws.cell(r, 2).value
        qty = ws.cell(r, 3).value
        if item_id is None:
            continue
        if qty is None or (isinstance(qty, str) and qty.strip() == ""):
            lookup[item_id] = "-"
        else:
            lookup[item_id] = qty
    return lookup

sh1_lookup = build_lookup(ws_sh1)
rp1_lookup = build_lookup(ws_rp1)

for r in range(2, ws_merge.max_row + 1):
    item_id = ws_merge.cell(r, 2).value
    c_val = sh1_lookup.get(item_id, "-")
    d_val = rp1_lookup.get(item_id, "-")
    ws_merge.cell(r, 3).value = c_val
    ws_merge.cell(r, 4).value = d_val

wb.save(outfile)

# verify
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb["merging"]
print("Saved to:", outfile)
print("Verification rows:")
for r in range(1, check_ws.max_row + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, 5)])
```
