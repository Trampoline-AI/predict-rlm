import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Reopen original workbook so we don't carry forward the bad cached result file
wb = load_workbook(infile)
ws = wb["Sheet1"]

# Use a LibreOffice-friendly formula
formula = '=COUNTIF(OFFSET($A$2,0,MATCH(I1,$A$1:$D$1,0)-1,14,1),I2)'
ws["I3"] = formula

wb.save(outfile)
print("Saved:", outfile)
print("Formula now in I3:", ws["I3"].value)

status = await recalculate(outfile)
print("Recalc status:", status)

# Verify formula text
