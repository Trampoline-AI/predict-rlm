import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws = wb["Summary"]

# Populate H6:P9 with combined actual-or-forecast formulas
for row in range(6, 10):
    gl_ref = f"$C{row}"
    forecast_ref = f"SUM($E{row}:$G{row})/(12-$D$3)"
    for col in range(8, 17):  # H:P
        col_letter = get_column_letter(col)
        month_ref = f"{col_letter}$5"
        sumifs = f"SUMIFS(Data!$C$2:$C$13,Data!$A$2:$A$13,Summary!{gl_ref},Data!$D$2:$D$13,Summary!{month_ref})"
        formula = f"=IF({sumifs}<>0,{sumifs},{forecast_ref})"
        ws.cell(row=row, column=col).value = formula

# Save workbook
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate so cached values are available for verification
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Verify formulas
