5. Returns blank if the date/agent combination does not exist.

Because agent order can change and some agents may be missing, I should not rely on fixed row offsets. I’ll use a `SUMPRODUCT`-based formula with a `LOOKUP` expression to identify which date block each `Data` row belongs to. I’ll write the formulas, save to the output path with the same filename, recalculate, and verify a few cells.
Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os

# Reload workbook cleanly
wb = load_workbook(input_spreadsheet)
ws_front = wb["Front"]
ws_data = wb["Data"]

# Build output path
input_name = Path(input_spreadsheet).name
output_path = f"/sandbox/output/output_spreadsheet/{input_name}"

# Use a bounded future-proof range large enough for added data, but not full-column
max_range = 1000

# Formula logic:
# - count matching rows for this agent within the date block; if none, return blank
# - otherwise sum the value(s) from Data column F for that agent in that date block
for r in range(2, ws_front.max_row + 1):
    for c in range(2, ws_front.max_column + 1):
        cell = ws_front.cell(r, c)
        col_letter = cell.column_letter
        formula = (
            f'=IF('
            f'SUMPRODUCT(('
            f'Data!$A$1:$A${max_range}=$A{r})*'
            f'(--(LOOKUP(ROW(Data!$A$1:$A${max_range}),'
            f'ROW(Data!$A$1:$A${max_range})/(ISNUMBER(Data!$A$1:$A${max_range})),'
            f'Data!$A$1:$A${max_range})={col_letter}$1)))=0,'
            f'"",'
            f'SUMPRODUCT(('
            f'Data!$A$1:$A${max_range}=$A{r})*'
            f'(--(LOOKUP(ROW(Data!$A$1:$A${max_range}),'
            f'ROW(Data!$A$1:$A${max_range})/(ISNUMBER(Data!$A$1:$A${max_range})),'
            f'Data!$A$1:$A${max_range})={col_letter}$1))*'
            f'Data!$F$1:$F${max_range}))'
            f')'
        )
        cell.value = formula

wb.save(output_path)
print("Saved:", output_path)

# Recalculate formulas and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(output_path, data_only=False)
wb_check_values = load_workbook(output_path, data_only=True)

wsf_formula = wb_check_formula["Front"]
wsf_values = wb_check_values["Front"]

print("Sample formulas:")
for coord in ["B2", "C2", "B3", "C4"]:
    print(coord, "=>", wsf_formula[coord].value)

print("\nSample calculated values:")
for coord in ["B2", "C2", "B3", "C4", "N2"]:
    print(coord, "=>", wsf_values[coord].value)

# Keep for next turn / submit
final_output_path = output_path
