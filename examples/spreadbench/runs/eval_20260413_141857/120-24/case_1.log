verified_updates = []
verified_fill_ok = []
for r in range(2, verify_ws.max_row + 1):
    bn = verify_ws[f"BN{r}"].value
    bl = verify_ws[f"BL{r}"].value
    ay = verify_ws[f"AY{r}"].value
