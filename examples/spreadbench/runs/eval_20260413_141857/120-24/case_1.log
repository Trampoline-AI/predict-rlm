            ws[f"BN{r}"] = ocogs_value
        else:
            ws[f"BN{r}"] = ofss_value
        updated_rows.append((r, ay, bg, bl, ws[f"BN{r}"].value))
    
    if ws[f"BL{r}"].value == "LAG" and ws[f"BN{r}"].value not in (None, ""):
        ws[f"BL{r}"].fill = blue_fill
        fill_rows.append(r)

# Save output
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb2.save(out_path)

# Verify by reopening
