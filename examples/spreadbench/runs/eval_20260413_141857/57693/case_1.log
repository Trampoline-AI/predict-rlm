import os, shutil
from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect relevant area and existing formulas/values
for r in range(5, 33):
    print(r, ws[f"D{r}"].value, ws[f"E{r}"].value)

# Apply formulas in E7:E32 based on the letter in column D and source text in D5
for r in range(7, 33):
    ws[f"E{r}"] = f'=LEN($D$5)-LEN(SUBSTITUTE($D$5,D{r},""))'

# Save to output path with same filename
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Sheet1"]
for r in range(7, 15):
    print("formula", r, ws_check[f"E{r}"].value)

wb_vals = load_workbook(output_path, data_only=True)
ws_vals = wb_vals["Sheet1"]
for r in range(7, 15):
    print("value", r, ws_vals[f"D{r}"].value, ws_vals[f"E{r}"].value)

output_spreadsheet = output_path
