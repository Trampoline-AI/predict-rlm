A good non-array formula for earliest non-zero value across `E:AN` is:
`=IFERROR(INDEX(E9:AN9, MATCH(TRUE, INDEX(E9:AN9<>0,0), 0)), "")`
This avoids CSE array-entry while still locating the first non-zero entry in the row. I’ll preserve the AO number format/style pattern and verify several rows after saving.
Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Data rows:", ws.max_row, "Columns:", ws.max_column)

# Inspect AO formatting around first data row
for r in range(8, 13):
    cell = ws[f"AO{r}"]
    print(
        f"AO{r}: value={cell.value!r}, numfmt={cell.number_format!r}, "
        f"style={cell.style_id}, fill={cell.fill.fill_type!r}"
    )

start_row = 9
end_row = ws.max_row

# Write non-array formula down AO
for r in range(start_row, end_row + 1):
    ws[f"AO{r}"] = f'=IFERROR(INDEX(E{r}:AN{r},MATCH(TRUE,INDEX(E{r}:AN{r}<>0,0),0)),"")'

# Copy number format from AO9 if present; otherwise set percent-ish display
source_fmt = ws["AO9"].number_format
for r in range(start_row, end_row + 1):
    ws[f"AO{r}"].number_format = source_fmt if source_fmt else '0.00%'

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

print("Saved to:", output_path)

# Verify by reopening normally (formula text)
wb2 = load_workbook(output_path, data_only=False)
ws2 = wb2["Sheet1"]
for r in range(9, 16):
    print(r, ws2[f"B{r}"].value, "AO formula:", ws2[f"AO{r}"].value, "numfmt:", ws2[f"AO{r}"].number_format)

output_spreadsheet = output_path
```
