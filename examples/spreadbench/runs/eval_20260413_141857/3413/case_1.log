Code:
```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

formula_template = '=IF(COUNTIFS($A$3:$A$7,E{r},$B$3:$B$7,F{r})>0,SUMIFS($C$3:$C$7,$A$3:$A$7,E{r},$B$3:$B$7,F{r}),SUMIFS($C$3:$C$7,$A$3:$A$7,E{r}))'

for r in range(3, 7):
    ws[f"G{r}"] = formula_template.format(r=r)

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Formulas written:")
for r in range(3, 7):
    print(f"G{r}:", ws_check[f'G{r}'].value)

wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals[wb_vals.sheetnames[0]]
print("Cached values after recalc:")
for r in range(3, 7):
    print(f"G{r}:", ws_vals[f'G{r}'].value)

output_spreadsheet = outfile
```
