from openpyxl import load_workbook
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Fill Result column with the appropriate formula for all data rows
for row in range(2, ws.max_row + 1):
    ws.cell(row=row, column=1).value = f'=VALUE(SUBSTITUTE(B{row},"400","",1))'

# Save to output with same filename
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved:", output_path)

# Recalculate and verify
recalc_status = await recalculate(output_path)
print("Recalc:", recalc_status)

# Reload to inspect cached values
