```repl
import os, re, shutil
from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet)
ws = wb["BZTB"]

prefixes = ("COS Pass", "COS Comm", "COS W/S")
matches = []

for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    a, b, c, d = vals
    b_str = "" if b is None else str(b)
    a_str = "" if a is None else str(a)
    if any(b_str.startswith(p) for p in prefixes) and ("Used" in b_str) and a_str != "398726":
        matches.append((r, a, b, c, d))

print("Match count:", len(matches))
for item in matches[:50]:
    print(item)

# Inspect target sheet dimensions and any existing cells in first few rows/cols
target = wb["Tema UV COS"]
print("Target sheet dimensions:", target.max_row, target.max_column)
for r in range(1, min(target.max_row, 10) + 1):
    print("target row", r, [target.cell(r, c).value for c in range(1, 5)])

# Save manipulated workbook
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# reload fresh workbook for writing
wb2 = load_workbook(infile)
src = wb2["BZTB"]
dst = wb2["Tema UV COS"]

# Clear existing content in destination sheet
for row in dst.iter_rows():
    for cell in row:
        cell.value = None

out_row = 1
for r in range(1, src.max_row + 1):
    a = src.cell(r, 1).value
    b = src.cell(r, 2).value
    c = src.cell(r, 3).value
    d = src.cell(r, 4).value
    a_str = "" if a is None else str(a)
    b_str = "" if b is None else str(b)
    if any(b_str.startswith(p) for p in prefixes) and ("Used" in b_str) and a_str != "398726":
        for col, val in enumerate([a, b, c, d], start=1):
            dst.cell(out_row, col).value = val
        out_row += 1

wb2.save(outfile)
print("Saved to:", outfile, "rows written:", out_row - 1)

# Verify saved output
check = load_workbook(outfile, data_only=True)
chk = check["Tema UV COS"]
print("Verified target dimensions:", chk.max_row, chk.max_column)
for r in range(1, min(chk.max_row, 10) + 1):
    print("out row", r, [chk.cell(r, c).value for c in range(1, 5)])

output_path = outfile
```
