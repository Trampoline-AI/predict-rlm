Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import shutil, os

# Inspect target cells / formulas first
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

for coord in ["D1","E1","F1","G1","D2","E2","F2","G2","D3","E3","F3","G3"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

# Write formulas into the summary output cells.
# Use COUNTIFS on Date column A and response column B, matching the date header row and Yes/No label row.
for date_col, yes_col, no_col in [(4, 4, 5), (6, 6, 7)]:  # D/E and F/G groups
    date_cell = ws.cell(row=1, column=date_col).coordinate
    yes_label = ws.cell(row=2, column=yes_col).coordinate
    no_label = ws.cell(row=2, column=no_col).coordinate
    ws.cell(row=3, column=yes_col).value = f'=COUNTIFS($A$2:$A$11,{date_cell},$B$2:$B$11,{yes_label})'
    ws.cell(row=3, column=no_col).value = f'=COUNTIFS($A$2:$A$11,{date_cell},$B$2:$B$11,{no_label})'

# Save with same filename in output directory
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb.save(out_path)

print("Saved to", out_path)

# Recalculate and verify cached results
recalc_result = await recalculate(str(out_path))
print("Recalc:", recalc_result)

wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formulas:", wsf["D3"].value, wsf["E3"].value, wsf["F3"].value, wsf["G3"].value)

wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values["Sheet1"]
print("Cached values:", wsv["D3"].value, wsv["E3"].value, wsv["F3"].value, wsv["G3"].value)

output_spreadsheet = str(out_path)
```
