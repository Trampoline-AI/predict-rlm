from openpyxl import load_workbook
import os

wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Inspect rows with columns A-C and especially rows where B==1
rows_data = []
b1_rows = []
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
