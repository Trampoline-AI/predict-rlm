Code:
```repl
from openpyxl import load_workbook
import os

# Load workbook and target sheet
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Clear/fill Column C based on counts between consecutive rows where B == 1
prev_one_row = None

for r in range(1, ws.max_row + 1):
    b_val = ws.cell(r, 2).value
    
    if b_val == 1:
        if prev_one_row is None:
            ws.cell(r, 3).value = None
        else:
            count_gt_zero = 0
            for rr in range(prev_one_row + 1, r):
                a_val = ws.cell(rr, 1).value
                try:
                    if a_val is not None and float(a_val) > 0:
                        count_gt_zero += 1
                except Exception:
                    pass
            ws.cell(r, 3).value = count_gt_zero
        prev_one_row = r
    else:
        ws.cell(r, 3).value = None

# Save
os.makedirs("/sandbox/output/output_spreadsheet", exist_ok=True)
wb.save(output_path)

# Verify by reloading
check_wb = load_workbook(output_path, data_only=True)
check_ws = check_wb["Sheet1"]

verification = []
for r in range(1, check_ws.max_row + 1):
    if check_ws.cell(r, 2).value == 1:
        verification.append((r, check_ws.cell(r, 1).value, check_ws.cell(r, 2).value, check_ws.cell(r, 3).value))

print("Saved to:", output_path)
print("Rows where B == 1 after update:")
for row in verification:
    print(row)
```
