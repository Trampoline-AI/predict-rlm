Code:
```repl
import os, shutil
from openpyxl import load_workbook

# Reload fresh workbook from input
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb2 = load_workbook(infile)
ws = wb2["Sheet1"]

# Read and sort column A words
words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

sorted_words = sorted(words)

# Overwrite column A with sorted words
for i, w in enumerate(sorted_words, start=1):
    ws.cell(i, 1).value = w

# If there were extra old values below, clear them
for r in range(len(sorted_words) + 1, ws.max_row + 1):
    ws.cell(r, 1).value = None

# Build matches from sorted words
word_set = set(sorted_words)

def transform_word(w):
    if len(w) < 5:
        return None
    return w[4] + w[:4] + w[5:]

pairs = []
for w in sorted_words:
    t = transform_word(w)
    if t in word_set and w[-3:] == t[-3:]:
        pairs.append((w[-3:], t, w))  # suffix, transformed->col C, original->col D

requested_order = ["ING", "ERS", "ATE", "EST", "ONE", "IER", "ILY"]

grouped = {s: [] for s in requested_order}
for suffix, transformed, original in pairs:
    if suffix in grouped:
        grouped[suffix].append((transformed, original))

for s in requested_order:
    grouped[s] = sorted(grouped[s], key=lambda x: (x[1], x[0]))

# Clear existing columns C and D
for r in range(1, ws.max_row + 1):
    ws.cell(r, 3).value = None
    ws.cell(r, 4).value = None

# Write grouped results to columns C and D, no headers
out_row = 1
for suffix in requested_order:
    for transformed, original in grouped[suffix]:
        ws.cell(out_row, 3).value = transformed
        ws.cell(out_row, 4).value = original
        out_row += 1

# Save output
wb2.save(outfile)

# Verify by reopening
check = load_workbook(outfile, data_only=False)
cws = check["Sheet1"]

print("Saved to:", outfile)
print("Column A first 15 sorted words:", [cws.cell(r, 1).value for r in range(1, 16)])
print("Results in C:D:")
for r in range(1, out_row):
    print(r, cws.cell(r, 3).value, cws.cell(r, 4).value)
```
