from collections import defaultdict, Counter

ws = wb["Sheet1"]

# Read column A words
words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

word_set = set(words)
print("Total nonblank words in A:", len(words))
print("First 20 words currently:", words[:20])

def transform_word(w):
    # "fifth letter should become the first letter"
    # Example EARTHPEA -> HEARTPEA : E A R T H P E A -> H E A R T P E A
    # so result = w[4] + w[0:4] + w[5:]
    if len(w) < 5:
        return None
    return w[4] + w[:4] + w[5:]

pairs = []
for w in words:
    t = transform_word(w)
    if t in word_set and len(w) >= 3 and t[-3:] == w[-3:]:
        pairs.append((w, t, w[-3:], w[-4:], len(w)))

print("Total candidate pairs:", len(pairs))
print("First 30 pairs:", pairs[:30])

suffix_counts = Counter([p[2] for p in pairs])
print("Candidate counts by last-3 suffix, top 20:", suffix_counts.most_common(20))

requested = ["ING", "ERS", "ATE", "EST", "ONE", "IER", "ILY"]
req_matches = {s: [(w,t) for (w,t,last3,last4,l) in pairs if last3 == s] for s in requested}
for s in requested:
    print(s, len(req_matches[s]), req_matches[s][:10])

# Also inspect if there are matches by last 4 for IERS/INGS/etc in case instruction means group labels only
last4_counts = Counter([p[3] for p in pairs])
print("Top last-4 suffix counts:", last4_counts.most_common(20))
```
