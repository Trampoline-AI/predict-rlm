from openpyxl import load_workbook
from pathlib import Path
import os

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
ws = wb["HR "]

old_formula = ws["GK29"].value
new_formula = '=SUMIFS(GK3:GK21,GK3:GK21,"<>#N/A",$GO$3:$GO$21,"yes")+SUMIFS(GR3:GR21,$GO$3:$GO$21,"Yes")'
ws["GK29"] = new_formula

wb.save(output_path)

# Verify saved result
check_wb = load_workbook(output_path)
check_ws = check_wb["HR "]
print("Output saved:", output_path)
print("Old formula:", old_formula)
print("New formula:", check_ws["GK29"].value)
print("Sheet names:", check_wb.sheetnames)
print("Dimensions:", check_ws.max_row, check_ws.max_column)
```
