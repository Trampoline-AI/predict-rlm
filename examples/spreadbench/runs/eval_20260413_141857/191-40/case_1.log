```repl
import os, shutil, copy
from openpyxl import load_workbook
from openpyxl.formula.translate import Translator
from openpyxl.styles import Font, Alignment, PatternFill, Border, Side, Protection

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook twice: formulas view and cached-values view
wb = load_workbook(input_path)
ws = wb["Sheet1"]
wb_vals = load_workbook(input_path, data_only=True)
ws_vals = wb_vals["Sheet1"]

def row_is_blank(sheet, r, max_col=None):
    if max_col is None:
        max_col = sheet.max_column
    for c in range(1, max_col + 1):
        v = sheet.cell(r, c).value
        if v is not None and v != "":
            return False
    return True

def detect_blocks(sheet):
    blocks = []
    r = 1
    while r <= sheet.max_row:
        while r <= sheet.max_row and row_is_blank(sheet, r):
            r += 1
        if r > sheet.max_row:
            break
        start = r
        while r <= sheet.max_row and not row_is_blank(sheet, r):
            r += 1
        end = r - 1
        blocks.append((start, end))
    return blocks

def numeric_sort_key(v):
    try:
        if v is None or v == "":
            return float("-inf")
        return float(v)
    except Exception:
        return float("-inf")

blocks = detect_blocks(ws)

# Capture each block's rows, sort by evaluated D from data_only workbook
for start, end in blocks:
    rows_data = []
    for r in range(start, end + 1):
        row_cells = []
        for c in range(1, ws.max_column + 1):
            cell = ws.cell(r, c)
            row_cells.append({
                "value": cell.value,
                "has_style": cell.has_style,
                "font": copy.copy(cell.font),
                "fill": copy.copy(cell.fill),
                "border": copy.copy(cell.border),
                "alignment": copy.copy(cell.alignment),
                "number_format": cell.number_format,
                "protection": copy.copy(cell.protection),
            })
        d_cached = ws_vals.cell(r, 4).value
        rows_data.append({"source_row": r, "sort_d": numeric_sort_key(d_cached), "cells": row_cells})

    rows_data.sort(key=lambda x: x["sort_d"], reverse=True)

    # Write sorted rows back into the same block positions
    for dest_r, row_info in enumerate(rows_data, start=start):
        src_r = row_info["source_row"]
        for c, cell_info in enumerate(row_info["cells"], start=1):
            dest_cell = ws.cell(dest_r, c)
            val = cell_info["value"]

            # Preserve formulas as formulas, translated to new row if moved
            if isinstance(val, str) and val.startswith("="):
                try:
                    val = Translator(val, origin=f"{dest_cell.column_letter}{src_r}").translate_formula(
                        f"{dest_cell.column_letter}{dest_r}"
                    )
                except Exception:
                    # Fallback for simple same-row formulas in D:F if translation fails
                    val = val.replace(str(src_r), str(dest_r))

            dest_cell.value = val

            if cell_info["has_style"]:
                dest_cell.font = copy.copy(cell_info["font"])
                dest_cell.fill = copy.copy(cell_info["fill"])
                dest_cell.border = copy.copy(cell_info["border"])
                dest_cell.alignment = copy.copy(cell_info["alignment"])
                dest_cell.number_format = cell_info["number_format"]
                dest_cell.protection = copy.copy(cell_info["protection"])

# Keep exactly one blank row between blocks: already preserved by in-place block sorting.
# Ensure D:F are bold, centered, and number format rounds display to one decimal
# while whole numbers can display without decimal.
num_fmt = "0.#"
for start, end in blocks:
    for r in range(start, end + 1):
        for c in (4, 5, 6):
            cell = ws.cell(r, c)
            cell.font = copy.copy(cell.font)
            cell.font = cell.font.copy(bold=True)
            cell.alignment = copy.copy(cell.alignment)
            cell.alignment = cell.alignment.copy(horizontal="center")
            cell.number_format = num_fmt

# Ensure workbook calculation is automatic
calc_props = getattr(wb, "calculation", None)
if calc_props is not None:
    try:
        calc_props.calcMode = "auto"
        calc_props.fullCalcOnLoad = True
        calc_props.forceFullCalc = True
    except Exception:
        pass

wb.save(output_path)

# Recalculate to update cached values
recalc_result = await recalculate(output_path)

# Verify
wb_check = load_workbook(output_path)
ws_check = wb_check["Sheet1"]
wb_check_vals = load_workbook(output_path, data_only=True)
ws_check_vals = wb_check_vals["Sheet1"]
check_blocks = detect_blocks(ws_check)

verification = []
all_sorted = True
for start, end in check_blocks:
    vals = []
    for r in range(start, end + 1):
        vals.append(numeric_sort_key(ws_check_vals.cell(r, 4).value))
    ok = all(vals[i] >= vals[i+1] for i in range(len(vals)-1))
    verification.append((start, end, ok, vals[:5]))
    if not ok:
        all_sorted = False

# Check blank rows between blocks
one_blank_between = True
for i in range(len(check_blocks) - 1):
    if check_blocks[i+1][0] - check_blocks[i][1] != 2:
        one_blank_between = False
        break

# Sample style/formula checks
sample_checks = []
for r in [blocks[0][0], blocks[1][0], blocks[-1][0]]:
    sample_checks.append({
        "row": r,
        "D_formula": ws_check.cell(r, 4).value,
        "E_value": ws_check.cell(r, 5).value,
        "F_formula": ws_check.cell(r, 6).value,
        "D_cached": ws_check_vals.cell(r, 4).value,
        "D_bold": ws_check.cell(r, 4).font.bold,
        "E_bold": ws_check.cell(r, 5).font.bold,
        "F_bold": ws_check.cell(r, 6).font.bold,
        "D_align": ws_check.cell(r, 4).alignment.horizontal,
        "E_align": ws_check.cell(r, 5).alignment.horizontal,
        "F_align": ws_check.cell(r, 6).alignment.horizontal,
        "D_fmt": ws_check.cell(r, 4).number_format,
        "E_fmt": ws_check.cell(r, 5).number_format,
        "F_fmt": ws_check.cell(r, 6).number_format,
    })

print("Saved:", output_path)
print("Recalc:", recalc_result)
print("Detected blocks:", check_blocks)
print("All blocks sorted descending by evaluated D:", all_sorted)
print("Exactly one blank row between blocks:", one_blank_between)
print("Verification sample:", verification[:3])
print("Style/formula samples:", sample_checks)
