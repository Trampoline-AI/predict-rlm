import os, copy
from openpyxl import load_workbook
from openpyxl.formula.translate import Translator

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh from original input
wb = load_workbook(input_path)
ws = wb["Sheet1"]
wb_vals = load_workbook(input_path, data_only=True)
ws_vals = wb_vals["Sheet1"]

def row_is_blank(sheet, r, max_col=None):
    max_col = max_col or sheet.max_column
    for c in range(1, max_col + 1):
        v = sheet.cell(r, c).value
        if v not in (None, ""):
            return False
    return True

def detect_blocks(sheet):
    blocks = []
    r = 1
    while r <= sheet.max_row:
        while r <= sheet.max_row and row_is_blank(sheet, r):
            r += 1
        if r > sheet.max_row:
            break
        start = r
        while r <= sheet.max_row and not row_is_blank(sheet, r):
            r += 1
        blocks.append((start, r - 1))
    return blocks

def numeric_sort_key(v):
    try:
        return float(v)
    except Exception:
        return float("-inf")

blocks = detect_blocks(ws)

# Sort each block by cached/evaluated D descending, preserving styles and formulas
for start, end in blocks:
    block_rows = []
    for r in range(start, end + 1):
        row_payload = []
        for c in range(1, ws.max_column + 1):
            cell = ws.cell(r, c)
            row_payload.append({
                "value": cell.value,
                "font": copy.copy(cell.font),
                "fill": copy.copy(cell.fill),
                "border": copy.copy(cell.border),
                "alignment": copy.copy(cell.alignment),
                "number_format": cell.number_format,
                "protection": copy.copy(cell.protection),
                "has_style": cell.has_style,
            })
        block_rows.append({
            "src_row": r,
            "sort_val": numeric_sort_key(ws_vals.cell(r, 4).value),
            "cells": row_payload,
        })

    block_rows.sort(key=lambda x: x["sort_val"], reverse=True)

    for dest_r, row_info in enumerate(block_rows, start=start):
        src_r = row_info["src_row"]
        for c, cell_info in enumerate(row_info["cells"], start=1):
            dest = ws.cell(dest_r, c)
            val = cell_info["value"]

            if isinstance(val, str) and val.startswith("="):
                val = Translator(val, origin=dest.coordinate.replace(str(dest_r), str(src_r))).translate_formula(dest.coordinate)

            dest.value = val
            if cell_info["has_style"]:
                dest.font = copy.copy(cell_info["font"])
                dest.fill = copy.copy(cell_info["fill"])
                dest.border = copy.copy(cell_info["border"])
                dest.alignment = copy.copy(cell_info["alignment"])
                dest.number_format = cell_info["number_format"]
                dest.protection = copy.copy(cell_info["protection"])

# Ensure D:E:F bold + center + requested numeric display
num_fmt = "0.#"
for start, end in blocks:
    for r in range(start, end + 1):
        for c in (4, 5, 6):
            cell = ws.cell(r, c)
            cell.font = copy.copy(cell.font)
            cell.font = cell.font.copy(bold=True)
            cell.alignment = copy.copy(cell.alignment)
            cell.alignment = cell.alignment.copy(horizontal="center")
            cell.number_format = num_fmt

# Automatic calculation settings
try:
    wb.calculation.calcMode = "auto"
    wb.calculation.fullCalcOnLoad = True
    wb.calculation.forceFullCalc = True
except Exception:
    pass

wb.save(output_path)

# Verify formulas preserved and blocks sorted using formula strings + translated references
wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Sheet1"]
check_blocks = detect_blocks(ws_check)

# verify formulas exist in D and F for some rows in each block
formula_samples = []
for start, end in check_blocks:
