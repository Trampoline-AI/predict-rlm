import os
from datetime import datetime
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

def month_key(dt):
    return dt.year * 12 + dt.month

# Build lookup: for each employee, map month_key -> hours
emp_month_hours = {}
data_rows = []

for r in range(2, ws.max_row + 1):
    emp = ws.cell(r, 1).value
    dt = ws.cell(r, 3).value
    hours = ws.cell(r, 4).value
    if emp is None and dt is None and hours is None:
        continue
    data_rows.append(r)
    if emp is not None and dt is not None and hours is not None:
        emp_month_hours.setdefault(emp, {})[month_key(dt)] = hours

# Recompute columns E and F for all data rows
for r in data_rows:
    emp = ws.cell(r, 1).value
    dt = ws.cell(r, 3).value
    hours = ws.cell(r, 4).value
    
    ecell = ws.cell(r, 5)
    fcell = ws.cell(r, 6)
    
    if emp is None or dt is None or hours is None:
        ecell.value = None
        fcell.value = None
        continue
    
    current_mk = month_key(dt)
    window_keys = [current_mk - i for i in range(3, -1, -1)]  # prior 3 months + current
    month_map = emp_month_hours.get(emp, {})
    window_vals = [month_map[k] for k in window_keys if k in month_map]
    
    if len(window_vals) < 4:
        ecell.value = "n/a"
        fcell.value = "n/a - less that 4 weeks"
    else:
        avg = sum(window_vals) / 4
        if float(avg).is_integer():
            ecell.value = int(avg)
        else:
            ecell.value = avg
        fcell.value = "More than 48" if avg > 48 else "Less that 48"
        ecell.number_format = "General"

wb.save(outfile)

# Verify by reopening
vwb = load_workbook(outfile, data_only=False)
vws = vwb[vwb.sheetnames[0]]

print("Saved to:", outfile)
for r in range(2, 26):
    print(r, [vws.cell(r, c).value for c in range(1, 7)])
```
