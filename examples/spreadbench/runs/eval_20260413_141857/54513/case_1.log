from openpyxl import load_workbook
from copy import copy
import os

# Reload workbook for editing
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect the target area in more detail
for r in range(7, 10):
    vals = []
    for c in range(2, 7):  # B:F
        cell = ws.cell(r, c)
        vals.append(f"{cell.coordinate}={cell.value!r}")
    print("Row", r, vals)

# Check existing number formats/styles around the price row
for coord in ["C8", "E8", "F8"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

# Put the discounted wholesale price formula into F8.
# Wholesale price = MSRP * (1 - Wholesale markdown)
ws["F8"] = "=C8*(1-E8)"

# Copy currency/number format from C8 if present
ws["F8"].number_format = ws["C8"].number_format
# Try to preserve style alignment/border/fill/font from neighboring cell if useful
ws["F8"].font = copy(ws["C8"].font)
ws["F8"].fill = copy(ws["C8"].fill)
ws["F8"].border = copy(ws["C8"].border)
ws["F8"].alignment = copy(ws["C8"].alignment)
ws["F8"].protection = copy(ws["C8"].protection)

# Save to output path with same filename
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb.save(out_path)
print("Saved to", out_path)

# Recalculate formulas and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("Written formula F8:", ws_check["F8"].value, "numfmt:", ws_check["F8"].number_format)

wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Cached values C8/E8/F8:", ws_values["C8"].value, ws_values["E8"].value, ws_values["F8"].value)

output_path = out_path
```
