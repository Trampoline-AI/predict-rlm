3. Clear any pre-existing values in the used range of the summary sheet first.
4. Save and verify the output by reopening and printing the summary sheet contents.
Code:
```repl
import os, shutil
from openpyxl import load_workbook

# Prepare paths
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)
shutil.copy2(infile, outfile)

# Load copied workbook for editing
wb = load_workbook(outfile)
src = wb["imported Data"]
dst = wb["summary Limits"]

# Clear existing content in destination used range
for row in dst.iter_rows():
    for cell in row:
        cell.value = None

# Helper to get last non-empty column in a row
def last_nonempty_col(ws, row_idx):
    last = 0
    for c in range(1, ws.max_column + 1):
        v = ws.cell(row_idx, c).value
        if v is not None and v != "":
            last = c
    return last

# Build rows to copy: header + rows where col A starts with **
rows_to_copy = [1]
for r in range(2, src.max_row + 1):
    val = src.cell(r, 1).value
    if isinstance(val, str) and val.startswith("**"):
        rows_to_copy.append(r)

# Copy values row-by-row from column A to last used cell in that row
out_r = 1
for r in rows_to_copy:
    last_col = last_nonempty_col(src, r)
    for c in range(1, last_col + 1):
        dst.cell(out_r, c).value = src.cell(r, c).value
    out_r += 1

wb.save(outfile)

# Verify
check = load_workbook(outfile, data_only=False)
vws = check["summary Limits"]
print("Output file:", outfile)
print("Rows copied from source:", rows_to_copy)
print("Summary sheet dimensions:", vws.max_row, vws.max_column)
for r in range(1, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, vws.max_column + 1)]
    print(f"Row {r}:", vals)

output_spreadsheet = outfile
```
