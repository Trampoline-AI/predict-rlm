import os
from copy import copy
from datetime import datetime, date, time
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
wsd = wb["data"]
wsm = wb["mechanic"]

def parse_date(v):
    if isinstance(v, datetime):
        return v
    if isinstance(v, date):
        return datetime.combine(v, datetime.min.time())
    if isinstance(v, str):
        s = v.strip()
        for fmt in ("%m-%d-%y", "%m/%d/%y", "%Y-%m-%d", "%m-%d-%Y", "%m/%d/%Y"):
            try:
                return datetime.strptime(s, fmt)
            except Exception:
                pass
    return None

# Determine last used data row (ignore trailing blank row)
data_last_row = 1
for r in range(wsd.max_row, 1, -1):
    if any(wsd.cell(r, c).value is not None for c in range(1, wsd.max_column + 1)):
        data_last_row = r
        break

# Normalize dates in data!A so SUMIFS date matching works
for r in range(2, data_last_row + 1):
    cell = wsd.cell(r, 1)
    dt = parse_date(cell.value)
    if dt is not None:
        cell.value = dt
        cell.number_format = "m-d-yy"

# Fill helper formulas in G:H:I:K for rows with both time in/out
# Copy number formats from an existing populated row pattern where useful
for r in range(2, data_last_row + 1):
    e = wsd.cell(r, 5).value
    f = wsd.cell(r, 6).value
    has_times = isinstance(e, time) and isinstance(f, time)

    if has_times:
        wsd.cell(r, 7).value = f'=TEXT(F{r}-E{r},"h:mm:ss")'
        wsd.cell(r, 8).value = f"=HOUR(E{r})+MINUTE(E{r})/60+SECOND(E{r})/3600"
        wsd.cell(r, 9).value = f"=HOUR(F{r})+MINUTE(F{r})/60+SECOND(F{r})/3600"
        wsd.cell(r, 11).value = f"=SUM(I{r}-H{r})"
        wsd.cell(r, 7).number_format = "h:mm:ss"
        wsd.cell(r, 8).number_format = "0.00"
        wsd.cell(r, 9).number_format = "0.00"
        wsd.cell(r, 11).number_format = "0.00"
    else:
        # Leave existing values alone if row isn't usable; don't force formulas into incomplete rows
        pass

# Fill mechanic summary table: date in col A, mechanic headers in row 1
mech_last_row = wsm.max_row
mech_last_col = wsm.max_column

for r in range(2, mech_last_row + 1):
    # keep dates as dates/formatted
    if parse_date(wsm.cell(r, 1).value):
        wsm.cell(r, 1).number_format = "mm-dd-yy"
    for c in range(2, mech_last_col + 1):
        header_ref = f"{chr(64+c)}$1"  # B$1, C$1, ...
        formula = (
            f'=SUMIFS(data!$K$2:$K${data_last_row},'
            f'data!$C$2:$C${data_last_row},"*"&{header_ref}&"*",'
            f'data!$A$2:$A${data_last_row},$A{r})'
        )
        wsm.cell(r, c).value = formula
        wsm.cell(r, c).number_format = "0.00"

# Fix example formula on data sheet: sum K where name matches M3 and date equals N5
wsd["O3"] = (
    f'=SUMIFS($K$2:$K${data_last_row},'
    f'$C$2:$C${data_last_row},"*"&$M$3&"*",'
    f'$A$2:$A${data_last_row},$N$5)'
)
wsd["O3"].number_format = "0.00"

# Keep the example date cells formatted as dates
if parse_date(wsd["N5"].value):
    wsd["N5"].number_format = "m-d-yy"
if parse_date(wsd["N6"].value):
    wsd["N6"].number_format = "m-d-yy"

wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify output
check = load_workbook(outfile, data_only=True)
check_data = check["data"]
check_mech = check["mechanic"]

print("Verification:")
print("data!M3 =", check_data["M3"].value)
print("data!N5 =", check_data["N5"].value)
print("data!O3 =", check_data["O3"].value)

for cell in ["B2", "C2", "D2", "B3", "C3", "D3", "B4", "C4", "D4"]:
    print(f"mechanic!{cell} =", check_mech[cell].value)

output_spreadsheet = outfile
