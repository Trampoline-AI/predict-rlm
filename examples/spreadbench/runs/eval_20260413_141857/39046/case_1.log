Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Determine actual data rows from column B (REF)
data_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 2).value is not None:
        data_rows.append(r)

first_data_row = min(data_rows) if data_rows else 2
last_data_row = max(data_rows) if data_rows else 2

# Use bounded ranges for compatibility/performance
d_range = f"$D${first_data_row}:$D${last_data_row}"

for r in data_rows:
    # Count subrefs in D that contain the REF from B
    ws[f"F{r}"] = f'=COUNTIF({d_range},"*"&B{r}&"*")'
    # Only evaluate Yes/No for CANCELLED rows; otherwise blank
    ws[f"E{r}"] = f'=IF(B{r}="","",IF(C{r}="CANCELLED",IF(F{r}>=1,"Yes","No"),""))'

wb.save(outfile)

# Recalculate so cached values are available
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify output
wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Saved file:", outfile)
for r in data_rows:
    print(
        r,
        "B=", ws_check[f"B{r}"].value,
        "C=", ws_check[f"C{r}"].value,
        "D=", ws_check[f"D{r}"].value,
        "E_formula=", ws_check[f"E{r}"].value,
        "F_formula=", ws_check[f"F{r}"].value,
    )

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[wb_values.sheetnames[0]]
print("Cached values after recalc:")
for r in data_rows:
    print(r, ws_values[f"E{r}"].value, ws_values[f"F{r}"].value)
```
