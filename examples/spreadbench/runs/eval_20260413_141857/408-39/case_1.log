Reasoning: I know the workbook has a pivot-style sheet (`Sheet1`) where the header row is row 5 and the `'0-15'` column is currently in column I. The instruction is to move that whole column to column B while preserving formatting, so that the sheet order changes and `Grand Total` remains in column L. I should implement this robustly by searching for the `'0-15'` header dynamically, inserting a new column at B, copying the entire source column’s values and formatting into B, then deleting the original source column (adjusted for the insertion). I also want to preserve width and verify that B5 is `'0-15'`, B contains the expected values, and `Grand Total` is still in column L after saving.
Code:
```repl
import os, shutil
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Start from original file to preserve everything possible
shutil.copy2(input_path, output_path)

wb = load_workbook(output_path)
ws = wb["Sheet1"]

# Find the header cell containing '0-15'
target_text = "0-15"
found = None
for row in ws.iter_rows():
    for cell in row:
        if cell.value == target_text:
            found = cell
            break
    if found:
        break

print("Found target:", found.coordinate if found else None)

if not found:
    raise ValueError("Could not find header '0-15' in workbook.")

src_col = found.column
dest_col = 2  # Column B

# Save source column width before structure changes
src_letter = get_column_letter(src_col)
src_width = ws.column_dimensions[src_letter].width

# Insert new column B
ws.insert_cols(dest_col, 1)

# After insertion, original source column shifts right by 1 if it was at/after B
shifted_src_col = src_col + 1 if src_col >= dest_col else src_col

# Copy entire shifted source column into new column B, including formatting
for r in range(1, ws.max_row + 1):
    src_cell = ws.cell(r, shifted_src_col)
    dst_cell = ws.cell(r, dest_col)
    dst_cell.value = src_cell.value
    if src_cell.has_style:
        dst_cell._style = copy(src_cell._style)
    if src_cell.number_format:
        dst_cell.number_format = copy(src_cell.number_format)
    if src_cell.font:
        dst_cell.font = copy(src_cell.font)
    if src_cell.fill:
        dst_cell.fill = copy(src_cell.fill)
    if src_cell.border:
        dst_cell.border = copy(src_cell.border)
    if src_cell.alignment:
        dst_cell.alignment = copy(src_cell.alignment)
    if src_cell.protection:
        dst_cell.protection = copy(src_cell.protection)

# Copy width to column B
ws.column_dimensions[get_column_letter(dest_col)].width = src_width

# Delete original shifted source column
ws.delete_cols(shifted_src_col, 1)

wb.save(output_path)

# Verify
wb2 = load_workbook(output_path)
ws2 = wb2["Sheet1"]

header_row = None
header_positions = {}
for r in range(1, ws2.max_row + 1):
    vals = [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)]
    if target_text in vals:
        header_row = r
        for c, v in enumerate(vals, start=1):
            header_positions[v] = c
        break

print("Verification:")
print("header_row:", header_row)
print("B5:", ws2["B5"].value)
print("Row 6-11 col B values:", [ws2.cell(r, 2).value for r in range(6, 12)])
print("Grand Total column index:", header_positions.get("Grand Total"))
print("Header row values:", [ws2.cell(header_row, c).value for c in range(1, ws2.max_column + 1)])
print("Saved to:", output_path)
```
