from openpyxl import load_workbook
from pathlib import Path

infile = input_spreadsheet
wb = load_workbook(infile)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Build correct lookup from Sheet2 keyed by (date, meet, race)
lookup = {}
for r in range(2, ws2.max_row + 1):
    key = (ws2.cell(r, 2).value, ws2.cell(r, 4).value, ws2.cell(r, 8).value)
    top = ws2.cell(r, 9).value
    picks = []
    for c in range(10, ws2.max_column + 1):
        v = ws2.cell(r, c).value
        if v not in (None, ""):
            picks.append(v)
    lookup[key] = {"top": top, "picks": picks, "src_row": r}

print("Lookup size:", len(lookup))

# Fill Sheet1 H and I using (date, meet, race)
changed_h = changed_i = 0
missing = []
for r in range(2, ws1.max_row + 1):
    key = (ws1.cell(r, 2).value, ws1.cell(r, 4).value, ws1.cell(r, 7).value)
    info = lookup.get(key)
    if info is None:
        missing.append((r, key))
        continue

    # Column H from Sheet2 col I
    new_top = info["top"]
    if ws1.cell(r, 8).value != new_top:
        ws1.cell(r, 8).value = new_top
        changed_h += 1
    else:
        ws1.cell(r, 8).value = new_top  # ensure consistent

    # Column I = position of Sheet1 Tab value within Sheet2 picks J:...
    tab_val = ws1.cell(r, 10).value
    rank = None
    for idx, pick in enumerate(info["picks"], start=1):
        if tab_val == pick:
            rank = idx
            break
    if ws1.cell(r, 9).value != rank:
        ws1.cell(r, 9).value = rank
        changed_i += 1
    else:
        ws1.cell(r, 9).value = rank  # ensure consistent

print("Changed H:", changed_h, "Changed I:", changed_i, "Missing:", len(missing))
if missing:
    print("Missing sample:", missing[:10])

# Save corrected output
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / Path(infile).name
wb.save(outfile)
print("Saved corrected file:", outfile)

# Verify against the known completed sample and a few later rows
