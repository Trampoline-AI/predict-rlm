from openpyxl import load_workbook
from pathlib import Path
import os
from collections import defaultdict

# Load workbook
infile = input_spreadsheet
wb = load_workbook(infile)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Inspect current blank counts for target columns H and I
blank_h = 0
blank_i = 0
for r in range(2, ws1.max_row + 1):
    if ws1.cell(r, 8).value in (None, ""):
        blank_h += 1
    if ws1.cell(r, 9).value in (None, ""):
        blank_i += 1
print("Before fill:", {"blank_H": blank_h, "blank_I": blank_i, "rows": ws1.max_row - 1})

# Build lookup from Sheet2 keyed by (meet, race)
# Top is in col I (9), rankings begin at col J (10) and continue to the sheet's max_col
lookup = {}
dupes = []
for r in range(2, ws2.max_row + 1):
    meet = ws2.cell(r, 4).value
    race = ws2.cell(r, 8).value
    top = ws2.cell(r, 9).value
    picks = []
    for c in range(10, ws2.max_column + 1):
        v = ws2.cell(r, c).value
        if v not in (None, ""):
            picks.append(v)
    key = (meet, race)
    if key in lookup:
        dupes.append((r, key))
    lookup[key] = {"top": top, "picks": picks}

print("Sheet2 lookup entries:", len(lookup), "duplicates:", len(dupes), "Sheet2 max_col:", ws2.max_column)
print("Sample lookup PORT MACQUARIE race1:", lookup.get(("PORT MACQUARIE ", 1)))

# Fill Sheet1 columns H and I
filled_h = 0
filled_i = 0
unchanged_h = 0
unchanged_i = 0
missing_keys = set()

for r in range(2, ws1.max_row + 1):
    meet = ws1.cell(r, 4).value
    race = ws1.cell(r, 7).value
    tab = ws1.cell(r, 10).value
    key = (meet, race)
    info = lookup.get(key)
    if info is None:
        missing_keys.add(key)
        continue

    # Fill/update H
    new_top = info["top"]
    old_top = ws1.cell(r, 8).value
    if old_top != new_top:
        ws1.cell(r, 8).value = new_top
        filled_h += 1
    else:
        unchanged_h += 1

    # Fill/update I from Tab matching ranked picks
    rank_val = None
    for idx, pick in enumerate(info["picks"], start=1):
        if tab == pick:
            rank_val = idx
            break

    old_rank = ws1.cell(r, 9).value
    if old_rank != rank_val:
        ws1.cell(r, 9).value = rank_val
        filled_i += 1
    else:
        unchanged_i += 1

print("Updated counts:", {
    "H_changed": filled_h, "H_unchanged": unchanged_h,
    "I_changed": filled_i, "I_unchanged": unchanged_i,
    "missing_match_keys": len(missing_keys)
})
print("Missing key samples:", list(missing_keys)[:10])

# Save output
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / Path(infile).name
wb.save(outfile)
print("Saved to:", outfile)

# Verify by reopening and checking representative rows
wbv = load_workbook(outfile, data_only=True)
v1 = wbv["Sheet1"]

print("\nVerification samples:")
for r in list(range(2, 10)) + list(range(16, 23)) + [100, 150, 200, 250, 300, 350]:
    if r <= v1.max_row:
        vals = [v1.cell(r, c).value for c in range(4, 11)]  # D:J
        print(r, vals)

# Post-fill blank counts
after_blank_h = 0
after_blank_i = 0
for r in range(2, v1.max_row + 1):
    if v1.cell(r, 8).value in (None, ""):
        after_blank_h += 1
    if v1.cell(r, 9).value in (None, ""):
        after_blank_i += 1
print("\nAfter fill:", {"blank_H": after_blank_h, "blank_I": after_blank_i})

output_spreadsheet = str(outfile)
