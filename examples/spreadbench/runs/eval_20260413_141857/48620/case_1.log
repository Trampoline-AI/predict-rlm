from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
import os, shutil

# Load workbook and inspect a bit more
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Existing sheet_view.showZeros:", getattr(ws.sheet_view, "showZeros", None))
for cell_ref in ["D2", "E2", "D6", "E6"]:
    cell = ws[cell_ref]
    print(cell_ref, "value=", cell.value, "font=", cell.font.name, cell.font.sz, "fill=", cell.fill.fill_type, cell.fill.fgColor.rgb)

# Apply duplicate-aware lookup formula in E2:E7
for r in range(2, 8):
    formula = f'=INDEX($B$2:$B$7,AGGREGATE(15,6,(ROW($A$2:$A$7)-ROW($A$2)+1)/($A$2:$A$7=D{r}),COUNTIF($D$2:D{r},D{r})))'
    ws[f"E{r}"] = formula

# Shade E2:E9 with #FCE4D6 and apply Calibri font
fill = PatternFill(fill_type="solid", fgColor="FCE4D6")
font = Font(name="Calibri")
for r in range(2, 10):
    cell = ws[f"E{r}"]
    cell.fill = fill
    # preserve size/bold/italic if present where possible, but force Calibri
    cell.font = Font(
        name="Calibri",
        size=cell.font.sz if cell.font and cell.font.sz else 11,
        bold=cell.font.bold if cell.font else False,
        italic=cell.font.italic if cell.font else False,
        underline=cell.font.underline if cell.font else None,
        strike=cell.font.strike if cell.font else False,
        color=cell.font.color.rgb if (cell.font and cell.font.color and cell.font.color.type == "rgb") else None,
    )

# Show zero values as blanks at worksheet view level
ws.sheet_view.showZeros = False

# Save output
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb2 = load_workbook(out_path, data_only=False)
ws2 = wb2["Sheet1"]
print("Post-save formulas:")
for r in range(2, 8):
    print(r, ws2[f"D{r}"].value, ws2[f"E{r}"].value)

wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
print("Cached values in E2:E7 after recalc:")
for r in range(2, 8):
    print(r, wsv[f"D{r}"].value, wsv[f"E{r}"].value)

print("showZeros now:", ws2.sheet_view.showZeros)
print("E2 fill/font:", ws2["E2"].fill.fgColor.rgb, ws2["E2"].font.name)
print("E8/E9 styled exists:", ws2["E8"].fill.fgColor.rgb, ws2["E8"].font.name, ws2["E9"].fill.fgColor.rgb, ws2["E9"].font.name)

output_spreadsheet = out_path
