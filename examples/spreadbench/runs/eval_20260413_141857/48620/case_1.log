import os

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

wb = load_workbook(out_path)
ws = wb["Sheet1"]

for r in range(2, 8):
    ws[f"E{r}"] = f'=INDEX($B$2:$B$7,_xlfn.AGGREGATE(15,6,(ROW($A$2:$A$7)-ROW($A$2)+1)/($A$2:$A$7=D{r}),COUNTIF($D$2:D{r},D{r})))'

