import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

start_row = 2
end_row = ws.max_row

for row in range(start_row, end_row + 1):
    formula = (
        f'=IF(AND(COUNTIFS($A${start_row}:$A${end_row},A{row},$D${start_row}:$D${end_row},"Sch")>0,'
        f'COUNTIFS($A${start_row}:$A${end_row},A{row},$D${start_row}:$D${end_row},"No Show")>0),'
        f'"NS/SCHED",'
        f'IF(AND(COUNTIFS($A${start_row}:$A${end_row},A{row},$D${start_row}:$D${end_row},"Sch")>0,'
        f'COUNTIFS($A${start_row}:$A${end_row},A{row},$D${start_row}:$D${end_row},"No Show")=0),'
        f'"FUTURE",'
        f'IF(AND(D{row}="No Show",E{row}<>""),"NO ACTION NEEDED",'
        f'IF(AND(D{row}="No Show",E{row}=""),"CALL PT",""))))'
    )
    ws.cell(row=row, column=6).value = formula

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[wb_formula.sheetnames[0]]
print("\nFormula samples:")
for r in range(2, min(8, ws_formula.max_row) + 1):
    print(r, ws_formula[f"F{r}"].value)

# Verify cached values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[wb_values.sheetnames[0]]
print("\nValue samples:")
for r in range(2, min(12, ws_values.max_row) + 1):
    print(r, ws_values[f"A{r}"].value, ws_values[f"D{r}"].value, ws_values[f"E{r}"].value, "->", ws_values[f"F{r}"].value)
```
