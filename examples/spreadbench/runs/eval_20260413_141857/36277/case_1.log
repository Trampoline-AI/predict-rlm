from openpyxl import load_workbook
from pathlib import Path
import os, json

input_path = input_spreadsheet
print("Input path:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
print("Sheets:", wb.sheetnames)

summary = {}
for ws in wb.worksheets:
    dims = ws.calculate_dimension()
    merged = len(ws.merged_cells.ranges)
    max_row = ws.max_row
    max_col = ws.max_column
    rows = list(ws.iter_rows(min_row=1, max_row=min(max_row, 8), values_only=False))
    sample = []
    for r in rows:
        vals = []
        for c in r[:min(max_col, 8)]:
            vals.append(c.value)
        sample.append(vals)
    formulas = []
    for row in ws.iter_rows(min_row=1, max_row=min(max_row, 20), min_col=1, max_col=min(max_col, 12)):
        for c in row:
            if isinstance(c.value, str) and c.value.startswith("="):
                formulas.append((c.coordinate, c.value))
    summary[ws.title] = {
        "dimensions": dims,
        "max_row": max_row,
        "max_col": max_col,
        "merged_ranges": merged,
        "sample_top_rows": sample,
        "sample_formulas": formulas[:20],
    }

for name, info in summary.items():
