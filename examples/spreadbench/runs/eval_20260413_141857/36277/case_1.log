from openpyxl import load_workbook
from pathlib import Path
import os

input_path = Path(input_spreadsheet)
output_path = Path("/sandbox/output/output_spreadsheet") / input_path.name

wb = load_workbook(input_path)
ws = wb["Sheet2"]

formula = '=INDEX($A$2:$E$25,MATCH($I$1,$B$2:$B$25,0),MATCH(H2,$A$1:$E$1,0))'

for row in range(2, 6):
    ws[f"I{row}"] = formula.replace("H2", f"H{row}")

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate so cached values are available for verification
recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

# Verify formulas and values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet2"]
for r in range(2, 6):
    print(f"I{r} formula:", ws_formula[f'I{r}'].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet2"]
verified = {f"I{r}": ws_values[f"I{r}"].value for r in range(2, 6)}
print("Verified cached values:", verified)

output_spreadsheet = str(output_path)
```
