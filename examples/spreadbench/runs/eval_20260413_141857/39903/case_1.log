Code:
```repl
import os, re
from openpyxl import load_workbook
from openpyxl.styles import Font, Border, Side

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb2 = load_workbook(infile)
ws = wb2["SKUs as Bins"]

def count_non_xz_locations(cell_value):
    if cell_value is None:
        return None
    text = str(cell_value).strip()
    if not text:
        return 0
    parts = [p.strip() for p in text.split(",") if p and str(p).strip()]
    count = 0
    kept = []
    for part in parts:
        loc = part.split(":", 1)[0].strip()
        if not loc:
            continue
        if loc.startswith(("X", "Z")):
            continue
        count += 1
        kept.append(loc)
    return count, kept

counts_info = {}
for r in range(2, 7):
    val = ws[f"B{r}"].value
    result = count_non_xz_locations(val)
    count = result[0] if result is not None else None
    kept = result[1] if result is not None else []
    ws[f"C{r}"] = count
    counts_info[r] = {"source": val, "count": count, "kept": kept}

thin = Side(style="thin", color="000000")
full_border = Border(left=thin, right=thin, top=thin, bottom=thin)
courier9 = Font(name="Courier New", size=9)

for r in range(2, 7):
    cell = ws[f"C{r}"]
    cell.border = full_border
    cell.font = courier9

wb2.save(outfile)

# Verify saved results
check = load_workbook(outfile)
cws = check["SKUs as Bins"]

print("Saved to:", outfile)
for r in range(2, 7):
    cell = cws[f"C{r}"]
    print(
        f"Row {r}: B={cws[f'B{r}'].value!r} -> C={cell.value}, "
        f"font=({cell.font.name}, {cell.font.sz}), "
        f"borders=({cell.border.left.style}, {cell.border.right.style}, {cell.border.top.style}, {cell.border.bottom.style}), "
        f"kept={counts_info[r]['kept']}"
    )

output_spreadsheet = outfile
```
