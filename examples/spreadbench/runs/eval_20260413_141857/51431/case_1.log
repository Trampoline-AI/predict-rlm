import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Write formula to extract the first full name before the first semicolon
ws["B2"] = '=TRIM(IFERROR(LEFT(A2,FIND(";",A2)-1),A2))'

# Save to output path with same filename
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)

# Verify saved formula
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb["Sheet1"]
print("Saved formula in B2:", check_ws["B2"].value)

# Recalculate and verify cached value if possible
