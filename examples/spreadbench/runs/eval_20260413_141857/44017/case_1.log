Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Data"]

target_cols = list(range(30, 42))  # AD:AO
start_row = 14
end_row = ws.max_row

no_fill = PatternFill(fill_type=None)

for r in range(start_row, end_row + 1):
    row_numfmt = ws[f"W{r}"].number_format
    for c in target_cols:
        col = get_column_letter(c)
        formula = (
            f'=IF(OR(${col}$9="",$L{r}="",{col}$9<$L{r}),"",'
            f'$W{r}'
            f'*(1+IF($M{r}="",0,$M{r}))'
            f'*(1+IF(AND(ISNUMBER($J{r}),{col}$9>=EDATE($L{r},$J{r}),$N{r}<>""),$N{r},0))'
            f'*(1+IF(AND(ISNUMBER($J{r}),{col}$9>=EDATE($L{r},$J{r}*2),$O{r}<>""),$O{r},0))'
            f'*(1+IF(AND(ISNUMBER($J{r}),{col}$9>=EDATE($L{r},$J{r}*3),$P{r}<>""),$P{r},0)))'
        )
        cell = ws.cell(r, c)
        cell.value = formula
        cell.fill = copy(no_fill)
        if row_numfmt:
            cell.number_format = row_numfmt

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Data"]

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Data"]

print("\nVerification samples:")
for r in [14, 15, 17, 18]:
    print(f"Row {r}")
    for col in ["AD", "AE", "AF", "AG", "AH", "AI"]:
        print(
            col,
            "formula=", wsf[f"{col}{r}"].value,
            "value=", wsv[f"{col}{r}"].value,
            "fill_type=", wsf[f"{col}{r}"].fill.fill_type,
            "fill_rgb=", wsf[f"{col}{r}"].fill.fgColor.rgb,
        )
    print("---")

output_spreadsheet = outfile
```
