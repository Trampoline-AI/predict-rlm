import os
from openpyxl import load_workbook

# Prepare output path
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and perform the requested deletion
wb2 = load_workbook(input_path)
for ws in wb2.worksheets:
    first_match_row = None
    for r in range(1, ws.max_row + 1):
        val = ws.cell(r, 1).value
        if isinstance(val, str) and "invoice no." in val.lower():
            first_match_row = r
            break
    if first_match_row and first_match_row > 1:
        ws.delete_rows(1, first_match_row - 1)

wb2.save(output_path)

# Verify output
verify_wb = load_workbook(output_path)
for ws in verify_wb.worksheets:
    print("Verified sheet:", ws.title)
    print("New dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    first_vals = [(r, ws.cell(r, 1).value) for r in range(1, min(ws.max_row, 5) + 1)]
    print("Top rows after deletion:", first_vals)
    first_match_after = None
    for r in range(1, ws.max_row + 1):
        val = ws.cell(r, 1).value
        if isinstance(val, str) and "invoice no." in val.lower():
            first_match_after = r
            break
    print("First match row after deletion:", first_match_after)

final_output_path = output_path
