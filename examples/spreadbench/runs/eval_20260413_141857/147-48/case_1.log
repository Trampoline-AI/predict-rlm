Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Build groups from contiguous nonblank cells in column A, separated by blanks
groups = []
current = []
for r in range(1, ws.max_row + 1):
    val = ws.cell(r, 1).value
    if val is None or (isinstance(val, str) and val == ""):
        if current:
            groups.append(current)
            current = []
    else:
        current.append(val)
if current:
    groups.append(current)

print("Groups found:", len(groups))
print("Group lengths:", [len(g) for g in groups])
print("First groups:", groups[:3])

# Clear existing output area from column C onward over the used rows/cols
start_col = 3
clear_to_col = max(ws.max_column, start_col + max((len(g) for g in groups), default=0) - 1)
clear_to_row = max(ws.max_row, len(groups))
for r in range(1, clear_to_row + 1):
    for c in range(start_col, clear_to_col + 1):
        ws.cell(r, c).value = None

# Write groups horizontally starting at C1
for out_row, group in enumerate(groups, start=1):
    for offset, val in enumerate(group):
        ws.cell(out_row, start_col + offset).value = val

wb.save(output_path)
print("Saved:", output_path, os.path.exists(output_path))

# Verify by reloading
check_wb = load_workbook(output_path)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Verification rows in columns C onward:")
for r in range(1, len(groups) + 2):
    vals = [check_ws.cell(r, c).value for c in range(3, clear_to_col + 1)]
    print(r, vals)
```
