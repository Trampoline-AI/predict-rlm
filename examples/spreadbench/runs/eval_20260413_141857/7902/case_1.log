Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Formula Required"]

# Fill D:J for rows 3:6 with a single reusable formula:
# - If Material exists, try material-specific lookup from Grouping!B:I
# - Otherwise (or on lookup failure), fall back to main-group lookup from Grouping!A:I
for r in range(3, 7):
    for c in range(4, 11):  # D:J
        cell = ws.cell(r, c)
        cell.value = (
            f'=IF($B{r}<>"",'
            f'IFERROR(VLOOKUP($B{r},Grouping!$B$2:$I$7,MATCH({get_column_letter(c)}$2,Grouping!$B$1:$I$1,0),FALSE),'
            f'VLOOKUP($C{r},Grouping!$A$2:$I$7,MATCH({get_column_letter(c)}$2,Grouping!$A$1:$I$1,0),FALSE)),'
            f'VLOOKUP($C{r},Grouping!$A$2:$I$7,MATCH({get_column_letter(c)}$2,Grouping!$A$1:$I$1,0),FALSE))'
        )

wb.save(output_path)
print("Saved:", output_path)

# Recalculate to populate cached formula values
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Verify formulas and values
wb_check = load_workbook(output_path, data_only=False)
wsf = wb_check["Formula Required"]
print("\nFormulas D3:J6:")
for r in range(3, 7):
    print(r, [wsf.cell(r, c).value for c in range(4, 11)])

wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals["Formula Required"]
print("\nCalculated values D3:J6:")
for r in range(3, 7):
    print(r, [wsv.cell(r, c).value for c in range(4, 11)])

print("\nSample T values:")
for r in range(3, 7):
    print(f"T{r} formula/value:", wsf[f"T{r}"].value, "/", wsv[f"T{r}"].value)
```
