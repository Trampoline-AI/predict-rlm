6. Delete all remaining rows below the rewritten data.
7. Save and verify that:
   - no blank rows remain
   - no zero rows remain except BR1 Sales
   - BR1 Sales has the computed total.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Read rows
rows = [[ws.cell(r, c).value for c in range(1, ws.max_column + 1)] for r in range(1, ws.max_row + 1)]
header = rows[0]
data_rows = rows[1:]

def is_blank_row(row):
    return all(v is None or (isinstance(v, str) and v.strip() == "") for v in row)

def is_zero(val):
    return val == 0

# Sum D for rows where E == 0
sum_d_where_e_zero = 0
for row in data_rows:
    if len(row) >= 5 and is_zero(row[4]) and isinstance(row[3], (int, float)):
        sum_d_where_e_zero += row[3]

# Update BR1 Sales amount, then filter kept rows
kept_rows = []
br1_count = 0
for row in data_rows:
    new_row = list(row)
    ref = new_row[2] if len(new_row) >= 3 else None
    e_val = new_row[4] if len(new_row) >= 5 else None
    is_br1 = ref is not None and "BR1 Sales" in str(ref)

    if is_br1:
        new_row[3] = round(sum_d_where_e_zero, 2)
        br1_count += 1

    if is_blank_row(new_row):
        continue
    if is_zero(e_val) and not is_br1:
        continue
    kept_rows.append(new_row)

# Rewrite header + kept rows
for c, val in enumerate(header, start=1):
    ws.cell(1, c).value = val

for r_idx, row in enumerate(kept_rows, start=2):
    for c_idx in range(1, ws.max_column + 1):
        ws.cell(r_idx, c_idx).value = row[c_idx - 1] if c_idx - 1 < len(row) else None

# Delete all extra rows below the kept data
last_needed_row = 1 + len(kept_rows)
if ws.max_row > last_needed_row:
    ws.delete_rows(last_needed_row + 1, ws.max_row - last_needed_row)

wb.save(outfile)

# Verify
vwb = load_workbook(outfile)
vws = vwb[vwb.sheetnames[0]]

nonblank_rows = []
remaining_zero_non_br1 = []
remaining_blank = []
br1_after = []

for r in range(2, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, min(5, vws.max_column) + 1)]
    if is_blank_row(vals):
        remaining_blank.append(r)
        continue
    nonblank_rows.append((r, vals))
    ref = vals[2] if len(vals) >= 3 else None
    e_val = vals[4] if len(vals) >= 5 else None
    if ref is not None and "BR1 Sales" in str(ref):
        br1_after.append((r, vals))
    if e_val == 0 and not (ref is not None and "BR1 Sales" in str(ref)):
        remaining_zero_non_br1.append((r, vals))

print("Sum D where E==0:", round(sum_d_where_e_zero, 2))
print("BR1 rows updated:", br1_count)
print("Final max_row/max_col:", vws.max_row, vws.max_column)
print("Nonblank data rows:", len(nonblank_rows))
print("BR1 row after:", br1_after)
print("Remaining zero non-BR1 rows:", len(remaining_zero_non_br1))
print("Remaining blank rows:", remaining_blank)
print("All remaining data rows:")
for item in nonblank_rows:
    print(item)
```
