import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Read all rows
all_rows = []
for r in range(1, ws.max_row + 1):
    all_rows.append([ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

header = all_rows[0]
data_rows = all_rows[1:]

def is_blank_row(row):
    return all(v is None or (isinstance(v, str) and v.strip() == "") for v in row)

def is_zero(val):
    return val == 0

# 1) Sum Column D where Column E is zero
sum_d_where_e_zero = 0
for row in data_rows:
    e_val = row[4] if len(row) >= 5 else None
    d_val = row[3] if len(row) >= 4 else None
    if is_zero(e_val) and isinstance(d_val, (int, float)):
        sum_d_where_e_zero += d_val

# 2) Update BR1 Sales row in memory
br1_found = 0
updated_rows = []
for row in data_rows:
    new_row = list(row)
    ref = new_row[2] if len(new_row) >= 3 else None
    if ref is not None and "BR1 Sales" in str(ref):
        new_row[3] = sum_d_where_e_zero
        br1_found += 1
    updated_rows.append(new_row)

# 3) Keep rows that are not blank and not (E==0 unless BR1 Sales)
kept_rows = []
removed_zero_non_br1 = 0
removed_blank = 0

for row in updated_rows:
    if is_blank_row(row):
        removed_blank += 1
        continue
    ref = row[2] if len(row) >= 3 else None
    e_val = row[4] if len(row) >= 5 else None
    is_br1 = ref is not None and "BR1 Sales" in str(ref)
    if is_zero(e_val) and not is_br1:
        removed_zero_non_br1 += 1
        continue
    kept_rows.append(row)

# Preserve original styles for header row, then rewrite values
max_col = ws.max_column
original_max_row = ws.max_row

# Clear existing data area values first
for r in range(2, original_max_row + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = None

# Write back header + kept rows
for c, val in enumerate(header, start=1):
    ws.cell(1, c).value = val

for out_r, row in enumerate(kept_rows, start=2):
    for c in range(1, max_col + 1):
        ws.cell(out_r, c).value = row[c-1] if c-1 < len(row) else None

# Save
wb.save(outfile)

# Verify by reloading
vwb = load_workbook(outfile)
vws = vwb[vwb.sheetnames[0]]

remaining_zero_non_br1 = []
remaining_blank_rows = []
br1_rows_after = []

for r in range(2, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, 6)]
    if all(v is None or (isinstance(v, str) and v.strip() == "") for v in vals):
        remaining_blank_rows.append(r)
        continue
    ref = vals[2]
    amt = vals[3]
    e_val = vals[4]
    if ref is not None and "BR1 Sales" in str(ref):
        br1_rows_after.append((r, vals))
    if e_val == 0 and not (ref is not None and "BR1 Sales" in str(ref)):
        remaining_zero_non_br1.append((r, vals))

print("Computed sum D where E==0:", sum_d_where_e_zero)
print("BR1 rows found before update:", br1_found)
print("Rows kept:", len(kept_rows))
print("Removed zero non-BR1 rows:", removed_zero_non_br1)
print("Removed blank rows:", removed_blank)
print("Output file:", outfile)
print("Verification - BR1 rows after:", br1_rows_after)
print("Verification - remaining zero non-BR1 rows:", len(remaining_zero_non_br1))
print("Verification - remaining blank rows:", remaining_blank_rows[:20])
print("Verification - max_row/max_col:", vws.max_row, vws.max_column)
