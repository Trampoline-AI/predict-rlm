- For each `Mat Doc`, check how many distinct `Doc No` values exist.
- If a `Mat Doc` has more than one distinct `Doc No`, mark all its rows as `"Multiple"`.
- Otherwise mark all its rows as `"Single"`.

Then I need to:
1. Remove all color/fill formatting and all borders, while preserving other formatting.
2. Re-apply a thin border to every populated cell, except cells whose value is `"Multiple"` or `"Single"`.

I’ll implement this directly with openpyxl, save to the required output folder with the same filename, and print a concise verification summary.
Code:
```repl
import os
from copy import copy
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Border, Side

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Identify data rows from row 5 onward using columns E (Mat Doc) and F (Doc No)
start_row = 5
matdoc_col = 5  # E
docno_col = 6   # F
remark_col = 7  # G

# Build mapping Mat Doc -> set of Doc No
matdoc_to_docnos = defaultdict(set)
for r in range(start_row, ws.max_row + 1):
    mat_doc = ws.cell(r, matdoc_col).value
    doc_no = ws.cell(r, docno_col).value
    if mat_doc is not None and doc_no is not None:
        matdoc_to_docnos[mat_doc].add(doc_no)

# Update Remark values
for r in range(start_row, ws.max_row + 1):
    mat_doc = ws.cell(r, matdoc_col).value
    if mat_doc is not None:
        remark = "Multiple" if len(matdoc_to_docnos.get(mat_doc, set())) > 1 else "Single"
        ws.cell(r, remark_col).value = remark

# Remove all color/fill formatting and all borders, keep other formatting
no_fill = PatternFill(fill_type=None)
no_border = Border()

for row in ws.iter_rows():
    for cell in row:
        cell.fill = copy(no_fill)
        cell.border = copy(no_border)

# Re-apply thin borders to all populated cells except those that say Multiple or Single
thin = Side(style="thin", color="000000")
thin_border = Border(left=thin, right=thin, top=thin, bottom=thin)

for row in ws.iter_rows():
    for cell in row:
        if cell.value is not None and cell.value not in ("Multiple", "Single"):
            cell.border = copy(thin_border)

wb.save(output_path)

# Verify
wb2 = load_workbook(output_path)
ws2 = wb2[wb2.sheetnames[0]]

print("Saved:", output_path)
print("Remark results:")
for r in range(5, ws2.max_row + 1):
    print(r, ws2[f"E{r}"].value, ws2[f"F{r}"].value, ws2[f"G{r}"].value)

print("Border/fill verification sample:")
for coord in ["E4", "F4", "G4", "E5", "F5", "G5", "E8", "F8", "G8", "E11", "F11", "G11"]:
    c = ws2[coord]
    print(coord, c.value, c.fill.fill_type, c.border.left.style, c.border.right.style, c.border.top.style, c.border.bottom.style)

final_output_path = output_path
```
