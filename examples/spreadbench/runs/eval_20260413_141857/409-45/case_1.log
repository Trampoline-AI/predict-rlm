- if `I2` is blank: compact every block
- if `I2` has a value: compact only blocks containing that ID in column B
- for compacted blocks, keep non-empty rows only
- insert one blank row between blocks, but none after the last block
- write the result back to `DATA`, preserve `I1:I2`, save to output, and verify the final row layout.
Code:
```repl
import os
import shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb[wb.sheetnames[0]]  # first sheet must hold the result

max_row, max_col = ws.max_row, ws.max_column
i2_value = ws["I2"].value

# Capture all row values first
rows = [[ws.cell(r, c).value for c in range(1, max_col + 1)] for r in range(1, max_row + 1)]

def is_empty_row(vals):
    return all(v in (None, "") for v in vals)

# Detect block header rows based on column B == 'id'
header_rows = [r for r in range(1, max_row + 1) if ws.cell(r, 2).value == "id"]
print("Header rows:", header_rows, "I2:", i2_value)

blocks = []
for idx, start in enumerate(header_rows):
    end = header_rows[idx + 1] - 1 if idx + 1 < len(header_rows) else max_row
    block_rows = rows[start - 1:end]
    # determine whether this block matches I2
    block_ids = [rv[1] for rv in block_rows[1:] if len(rv) >= 2 and rv[1] not in (None, "", "id")]
    matches = (i2_value in (None, "")) or (i2_value in block_ids)
    blocks.append({
        "start": start,
        "end": end,
        "rows": block_rows,
        "block_ids": block_ids,
        "matches": matches,
    })

for b in blocks:
    print(f"Block {b['start']}-{b['end']} ids={b['block_ids']} matches={b['matches']}")

# Build new sheet contents
new_rows = []
for bi, block in enumerate(blocks):
    block_rows = block["rows"]
    if block["matches"]:
        # keep header + non-empty data rows only
        compacted = [block_rows[0]] + [rv for rv in block_rows[1:] if not is_empty_row(rv)]
    else:
        # leave the block as-is
        compacted = block_rows[:]
    new_rows.extend(compacted)
    # add exactly one blank separator between blocks, but not after the last one
    if bi < len(blocks) - 1:
        new_rows.append([None] * max_col)

# Clear existing cells on the first sheet
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Write back compacted result to first sheet
for r_idx, vals in enumerate(new_rows, start=1):
    for c_idx, val in enumerate(vals, start=1):
        ws.cell(r_idx, c_idx).value = val

# Preserve the input selector area in column I
ws["I1"] = "id"
ws["I2"] = i2_value

wb.save(outfile)

# Verify by reloading
check_wb = load_workbook(outfile)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Saved:", outfile)
print("First sheet rows after rewrite:", check_ws.max_row, "cols:", check_ws.max_column)
for r in range(1, check_ws.max_row + 1):
    vals = [check_ws.cell(r, c).value for c in range(1, min(check_ws.max_column, 9) + 1)]
    print(r, vals)

output_spreadsheet = outfile
```
