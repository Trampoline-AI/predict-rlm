from openpyxl import load_workbook
import os

outfile = output_spreadsheet
wb = load_workbook(outfile)
ws = wb[wb.sheetnames[0]]

max_row, max_col = ws.max_row, ws.max_column
i2_value = ws["I2"].value
rows = [[ws.cell(r, c).value for c in range(1, max_col + 1)] for r in range(1, max_row + 1)]

def is_empty_row(vals):
    return all(v in (None, "") for v in vals)

header_rows = [r for r in range(1, max_row + 1) if ws.cell(r, 2).value == "id"]
blocks = []
for idx, start in enumerate(header_rows):
    end = header_rows[idx + 1] - 1 if idx + 1 < len(header_rows) else max_row
    block_rows = rows[start - 1:end]
    block_ids = [rv[1] for rv in block_rows[1:] if rv[1] not in (None, "", "id")]
    matches = (i2_value in (None, "")) or (i2_value in block_ids)
    blocks.append((block_rows, matches))

new_rows = []
for bi, (block_rows, matches) in enumerate(blocks):
    if matches:
        compacted = [block_rows[0]] + [rv for rv in block_rows[1:] if not is_empty_row(rv)]
    else:
        compacted = block_rows[:]
    new_rows.extend(compacted)
    if bi < len(blocks) - 1:
        new_rows.append([None] * max_col)

# overwrite needed region
for r in range(1, len(new_rows) + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = new_rows[r - 1][c - 1]

# delete any remaining rows below final output
if ws.max_row > len(new_rows):
    ws.delete_rows(len(new_rows) + 1, ws.max_row - len(new_rows))

# ensure selector cells remain as intended
ws["I1"] = "id"
ws["I2"] = i2_value

wb.save(outfile)

# verify
check_wb = load_workbook(outfile)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Verified max_row:", check_ws.max_row, "max_col:", check_ws.max_column)
for r in range(1, check_ws.max_row + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, 10)])

output_spreadsheet = outfile
