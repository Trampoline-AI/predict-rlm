from openpyxl import load_workbook
from pathlib import Path
import os, shutil

wb = load_workbook(input_spreadsheet)
ws_r = wb["RateHurdles"]
ws_d = wb["Deposits"]

print("RateHurdles headers:", [ws_r.cell(1,c).value for c in range(1, ws_r.max_column+1)])
print("Deposits headers:", [ws_d.cell(1,c).value for c in range(1, ws_d.max_column+1)])

for cell_ref in ["A1","A2","B2","C2","D2","A3","B3","C3","D3"]:
    cell = ws_d[cell_ref]
    print(cell_ref, "value=", cell.value, "numfmt=", cell.number_format)

for cell_ref in ["A1","A2","B2","C2","D2","E2"]:
    cell = ws_r[cell_ref]
    print("RH", cell_ref, "value=", cell.value, "numfmt=", cell.number_format)

# Write formulas in Deposits column A for each data row
for row in range(2, ws_d.max_row + 1):
    formula = (
        "=INDEX(RateHurdles!$E$2:$E$18,"
        "MATCH(1,"
        "(RateHurdles!$C$2:$C$18=B{r})*"
        "(RateHurdles!$D$2:$D$18=C{r})*"
        "(D{r}>=RateHurdles!$A$2:$A$18)*"
        "(D{r}<=RateHurdles!$B$2:$B$18),"
        "0))"
    ).format(r=row)
    ws_d.cell(row=row, column=1).value = formula

# Save output
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb.save(out_path)

print("Saved to:", out_path)
print("Written formulas:", ws_d["A2"].value, ws_d["A3"].value)
