from openpyxl import load_workbook
from pathlib import Path
import os

infile = Path(input_spreadsheet)
outfile = Path("/sandbox/output/output_spreadsheet") / infile.name

wb = load_workbook(infile)
ws = wb["TEST_SHEET"]

# Fill yellow summary cells C10:D12 with the correct SUMPRODUCT formula.
# Use absolute references for source ranges and mixed references for summary headers/labels.
for r in range(10, 13):   # rows for M1:M3
    for c in range(3, 5): # cols C:D for SETUP/RUN
        coord = ws.cell(r, c).coordinate
        formula = (
            f"=SUMPRODUCT(($I$17:$I$28>={getattr(ws.cell(4, c), 'coordinate')})*"
            f"($J$17:$J$28<={getattr(ws.cell(5, c), 'coordinate')})*"
            f"($L$16:$W$16={ws.cell(9, c).coordinate})*"
            f"($L$17:$W$28=$B{r})*"
            f"($L$19:$W$30))"
        )
        ws[coord] = formula

wb.save(outfile)
print("Saved to", outfile)

# Recalculate workbook formulas
recalc_result = await recalculate(str(outfile))
print("Recalc:", recalc_result)

# Verify by reopening data_only and comparing with Python-computed expected totals
wb_val = load_workbook(outfile, data_only=True)
wsv = wb_val["TEST_SHEET"]

# Build expected values directly from the table
