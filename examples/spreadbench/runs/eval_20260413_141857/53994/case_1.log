For each summary cell, the formula should:
- check the date range using the block’s date cells in columns I:J
- match the phase header in row 16 against the summary phase header in row 9
- match the machine row values against the machine in column B
- multiply by the corresponding time row values

I’ll overwrite `C10:D12` with that corrected formula pattern, save, recalculate, and verify the results numerically.
Code:
```repl
from openpyxl import load_workbook
from pathlib import Path

infile = Path(input_spreadsheet)
outfile = Path("/sandbox/output/output_spreadsheet") / infile.name

wb = load_workbook(infile)
ws = wb["TEST_SHEET"]

def make_formula(summary_row, summary_col):
    phase_ref = f"{ws.cell(9, summary_col).coordinate}"   # C9 / D9
    machine_ref = f"$B{summary_row}"                      # machine label in col B
    start_ref = "$C$4"
    end_ref = "$C$5"
    parts = []
    for machine_row, time_row in [(17, 19), (20, 22), (23, 25), (26, 28)]:
        parts.append(
            f"SUMPRODUCT(($I${machine_row}>={start_ref})*"
            f"($J${machine_row}<={end_ref})*"
            f"($L$16:$W$16={phase_ref})*"
            f"($L${machine_row}:$W${machine_row}={machine_ref})*"
            f"($L${time_row}:$W${time_row}))"
        )
    return "=" + "+".join(parts)

for r in range(10, 13):
    for c in range(3, 5):
        ws.cell(r, c).value = make_formula(r, c)

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(str(outfile))
print("Recalc:", recalc_result)

# Verify results
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["TEST_SHEET"]

for r in range(10, 13):
    print(
        f"Row {r}",
        wsv.cell(r, 2).value,
        "SETUP=", wsv.cell(r, 3).value,
        "RUN=", wsv.cell(r, 4).value
    )

final_output_spreadsheet = str(outfile)
```
