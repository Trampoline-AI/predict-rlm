        end_date = wsv.cell(5, c).value
        total = 0
        # machine rows are 17,20,23,26 and corresponding time rows are +2
        for machine_row in range(17, 29, 3):
            time_row = machine_row + 2
            recv = wsv.cell(machine_row, 9).value
            delivery = wsv.cell(machine_row, 10).value
            if recv is not None and delivery is not None and start_date is not None and end_date is not None:
                if recv >= start_date and delivery <= end_date:
                    for data_col in range(12, 24):  # L:W
                        if wsv.cell(16, data_col).value == phase and wsv.cell(machine_row, data_col).value == machine:
                            val = wsv.cell(time_row, data_col).value
                            if isinstance(val, (int, float)):
                                total += val
        expected[(r, c)] = total

actual = {}
for r in range(10, 13):
