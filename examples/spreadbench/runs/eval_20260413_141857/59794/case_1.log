Code:
```repl
import os, shutil
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

# Paths
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy2(infile, outfile)

# Load workbook for editing
wb = load_workbook(outfile)
ws = wb["SOURCE"]

# Gather source rows and split parts
data_rows = []
for r in range(3, ws.max_row + 1):
    val = ws.cell(r, 1).value
    if isinstance(val, str) and val.strip():
        parts = val.split("/")
        data_rows.append((r, parts))

max_parts = max((len(parts) for _, parts in data_rows), default=0)
start_col = 3  # column C
existing_output_cols = ws.max_column - start_col + 1
needed_last_col = start_col + max_parts - 1

# Create any missing columns by copying formatting from the column to the left
if ws.max_column < needed_last_col:
    for col in range(ws.max_column + 1, needed_last_col + 1):
        left_col = col - 1
        col_letter = get_column_letter(col)
        left_letter = get_column_letter(left_col)

        # Copy column width/hidden settings if present
        ws.column_dimensions[col_letter].width = ws.column_dimensions[left_letter].width
        ws.column_dimensions[col_letter].hidden = ws.column_dimensions[left_letter].hidden

        # Copy cell styles for existing rows
        for r in range(1, ws.max_row + 1):
            src = ws.cell(r, left_col)
            dst = ws.cell(r, col)
            if src.has_style:
                dst._style = copy(src._style)
            if src.font:
                dst.font = copy(src.font)
            if src.fill:
                dst.fill = copy(src.fill)
            if src.border:
                dst.border = copy(src.border)
            if src.alignment:
                dst.alignment = copy(src.alignment)
            if src.number_format:
                dst.number_format = src.number_format
            if src.protection:
                dst.protection = copy(src.protection)

# Update merged header in row 1 to span all output columns
merged_to_remove = []
for m in ws.merged_cells.ranges:
    if str(m) == "C1:K1":
        merged_to_remove.append(str(m))
for m in merged_to_remove:
    ws.unmerge_cells(m)
ws.merge_cells(start_row=1, start_column=3, end_row=1, end_column=needed_last_col)

# Populate row 2 headers for output columns
for i in range(max_parts):
    ws.cell(2, start_col + i).value = f"Column{i+1}"

# Fill output cells and shade them
green_fill = PatternFill(fill_type="solid", fgColor="E2EFDA", start_color="E2EFDA", end_color="E2EFDA")

for r, parts in data_rows:
    for i in range(max_parts):
        cell = ws.cell(r, start_col + i)
        cell.value = parts[i] if i < len(parts) else None
        cell.fill = copy(green_fill)

# Also shade blank target cells within the used output range for populated data rows
# (already handled above by setting fill on every target cell in range)

wb.save(outfile)

# Verify saved workbook
check = load_workbook(outfile)
cws = check["SOURCE"]
print("Saved to:", outfile)
print("New max_column:", cws.max_column, "expected last col:", needed_last_col, get_column_letter(needed_last_col))
print("Merged ranges:", list(cws.merged_cells.ranges))
print("Headers row 2:", [cws.cell(2, c).value for c in range(3, needed_last_col + 1)])
for r in range(3, 6):
    print("Row", r, [cws.cell(r, c).value for c in range(1, needed_last_col + 1)])
print("Sample fills row 3:", [cws.cell(3, c).fill.fgColor.rgb for c in range(3, needed_last_col + 1)])
output_spreadsheet = outfile
```
