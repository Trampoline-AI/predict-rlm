```repl
from openpyxl import load_workbook
from copy import copy
import os

# Load workbook
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Criteria
start_date = ws["I2"].value
end_date = ws["J2"].value

# Source and target ranges
src_start_row, src_end_row = 6, 315
src_start_col, src_end_col = 1, 5   # A:E
tgt_start_row, tgt_start_col = 6, 9 # I

# Collect matching source rows by date in column A
matching_rows = []
for r in range(src_start_row, src_end_row + 1):
    dt = ws.cell(r, 1).value
    if dt is not None and start_date <= dt <= end_date:
        matching_rows.append(r)

print("Matches found:", len(matching_rows))

# Clear existing output area I6:M315 (values + styles/formatting reset to blank/default-ish)
for r in range(tgt_start_row, src_end_row + 1):
    for c in range(tgt_start_col, tgt_start_col + 5):
        cell = ws.cell(r, c)
        cell.value = None
        cell._style = copy(ws.cell(6, 9)._style)  # current blank target style
        if cell.has_style:
            pass
        cell.number_format = "General"
        cell.font = copy(ws.cell(6, 9).font)
        cell.fill = copy(ws.cell(6, 9).fill)
        cell.border = copy(ws.cell(6, 9).border)
        cell.alignment = copy(ws.cell(6, 9).alignment)
        cell.protection = copy(ws.cell(6, 9).protection)

# Copy matching rows from A:E to I:M preserving formatting
for idx, src_r in enumerate(matching_rows):
    tgt_r = tgt_start_row + idx

    # Copy row dimensions traits that matter
    ws.row_dimensions[tgt_r].height = ws.row_dimensions[src_r].height
    ws.row_dimensions[tgt_r].hidden = ws.row_dimensions[src_r].hidden

    for offset in range(5):
        src_cell = ws.cell(src_r, src_start_col + offset)
        tgt_cell = ws.cell(tgt_r, tgt_start_col + offset)

        tgt_cell.value = src_cell.value
        tgt_cell.font = copy(src_cell.font)
        tgt_cell.fill = copy(src_cell.fill)
        tgt_cell.border = copy(src_cell.border)
        tgt_cell.alignment = copy(src_cell.alignment)
        tgt_cell.number_format = src_cell.number_format
        tgt_cell.protection = copy(src_cell.protection)
        tgt_cell._style = copy(src_cell._style)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Verify by reopening
vwb = load_workbook(outfile)
vws = vwb[vwb.sheetnames[0]]

# Recompute expected count from saved workbook source
v_matches = []
for r in range(src_start_row, src_end_row + 1):
    dt = vws.cell(r, 1).value
    if dt is not None and vws["I2"].value <= dt <= vws["J2"].value:
        v_matches.append(r)

# Count nonblank output rows in I column
output_rows = []
for r in range(tgt_start_row, src_end_row + 1):
    if vws.cell(r, tgt_start_col).value is not None:
        output_rows.append(r)

print("Verified expected matches:", len(v_matches))
print("Verified output rows:", len(output_rows))
print("First output row values I:M:", [vws.cell(6, c).value for c in range(9, 14)])
if len(output_rows) >= 2:
    print("Second output row values I:M:", [vws.cell(7, c).value for c in range(9, 14)])

# Compare style/format with first matched source row
if matching_rows:
    src_r = matching_rows[0]
    print("Source first matched A:E style ids:", [vws.cell(src_r, c).style_id for c in range(1, 6)])
    print("Target first output I:M style ids:", [vws.cell(6, c).style_id for c in range(9, 14)])
    print("Source first matched A:E formats:", [vws.cell(src_r, c).number_format for c in range(1, 6)])
    print("Target first output I:M formats:", [vws.cell(6, c).number_format for c in range(9, 14)])

output_spreadsheet = outfile
```
