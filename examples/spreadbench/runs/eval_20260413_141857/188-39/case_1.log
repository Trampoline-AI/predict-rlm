Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import Alignment
from pathlib import Path
import os

# Reload fresh workbook from input
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
main_ws = wb["main sheet"]
result_ws = wb["result"]

# Build lookup from main sheet by location
lookup = {}
for r in range(2, main_ws.max_row + 1):
    location = main_ws.cell(r, 1).value
    name = main_ws.cell(r, 2).value
    contact = main_ws.cell(r, 3).value
    mail = main_ws.cell(r, 4).value
    designation = main_ws.cell(r, 5).value
    lookup[location] = {
        "name": name,
        "contact": contact,
        "mail": mail,
        "designation": designation,
    }

allowed = {"Branch Manager", "Branch Credit Manager"}
left_align = Alignment(horizontal="left")

# Update result sheet
for r in range(2, result_ws.max_row + 1):
    location = result_ws.cell(r, 1).value
    rec = lookup.get(location)
    if rec and rec["designation"] in allowed:
        result_ws.cell(r, 2).value = rec["designation"]
        result_ws.cell(r, 3).value = str(rec["contact"]) if rec["contact"] is not None else ""
        result_ws.cell(r, 4).value = rec["mail"]
    else:
        result_ws.cell(r, 2).value = "N/A"
        result_ws.cell(r, 3).value = "N/A"
        result_ws.cell(r, 4).value = "N/A"
    
    # Left align all output entries in the row
    for c in range(1, 5):
        result_ws.cell(r, c).alignment = left_align

# Optional: left align headers too? instruction says all outputed entries, so keep data rows only changed.
wb.save(output_path)

# Verify saved file
check_wb = load_workbook(output_path)
check_ws = check_wb["result"]

print("Saved to:", output_path)
for r in range(1, check_ws.max_row + 1):
    vals = [check_ws.cell(r, c).value for c in range(1, 5)]
    aligns = [check_ws.cell(r, c).alignment.horizontal for c in range(1, 5)]
    print(r, vals, aligns)
```
