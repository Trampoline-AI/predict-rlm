Code:
```repl
import os, shutil
from openpyxl import load_workbook

# Helper to normalize cell values for matching the deletion criteria
PLACEHOLDERS = {"", "-", "0", "$", "$0", "$0.0"}

def is_target_value(val):
    if val is None:
        return True
    s = str(val).strip()
    return s in PLACEHOLDERS

# Re-open clean workbook from input
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

rows_to_delete = []
row_diagnostics = []

for r in range(2, ws.max_row + 1):  # keep header row
    j_val = ws.cell(r, 10).value
    k_val = ws.cell(r, 11).value
    j_match = is_target_value(j_val)
    k_match = is_target_value(k_val)
    if j_match and k_match:
        rows_to_delete.append(r)
    if r <= ws.max_row:
        row_diagnostics.append((r, j_val, k_val, j_match, k_match, j_match and k_match))

print("Rows marked for deletion:", rows_to_delete)
print("Total rows to delete:", len(rows_to_delete))
print("First 20 row diagnostics:", row_diagnostics[:20])

# Delete from bottom to top so indices stay valid
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)

# Verify by reopening
verify_wb = load_workbook(out_path)
verify_ws = verify_wb[verify_wb.sheetnames[0]]

remaining_jk = [(r, verify_ws.cell(r,10).value, verify_ws.cell(r,11).value) for r in range(1, verify_ws.max_row + 1)]
remaining_bad = []
for r in range(2, verify_ws.max_row + 1):
    j_val = verify_ws.cell(r, 10).value
    k_val = verify_ws.cell(r, 11).value
    if is_target_value(j_val) and is_target_value(k_val):
        remaining_bad.append(r)

print("Output path:", out_path)
print("Original row count:", ws.max_row + len(rows_to_delete), "Final row count:", verify_ws.max_row)
print("Remaining rows violating rule:", remaining_bad)
print("First 20 remaining J/K rows:", remaining_jk[:20])

output_spreadsheet = out_path
```
