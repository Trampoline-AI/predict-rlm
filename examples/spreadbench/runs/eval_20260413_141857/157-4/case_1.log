Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Identify rows in 14:83 where all F:L are blank
rows_to_delete = []
for r in range(14, min(83, ws.max_row) + 1):
    vals = [ws.cell(r, c).value for c in range(6, 13)]  # F:L
    if all(v is None or (isinstance(v, str) and v == "") for v in vals):
        rows_to_delete.append((r, vals, ws.cell(r, 13).value))  # include weeknumber for inspection

print("Rows to delete count:", len(rows_to_delete))
print("First 20 rows to delete:", rows_to_delete[:20])

# Delete bottom-up
for r, _, _ in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

wb.save(outfile)
print("Saved to:", outfile)

# Verify by reopening
vwb = load_workbook(outfile)
vws = vwb[vwb.sheetnames[0]]
print("Output max_row:", vws.max_row, "max_col:", vws.max_column)

# Show rows 13:35 after deletion
for r in range(13, min(35, vws.max_row) + 1):
    vals = [vws.cell(r, c).value for c in range(5, 14)]  # E:M
    print(r, vals)

# Confirm no rows remain in the resulting data block where F:L are all blank
remaining_blank_rows = []
for r in range(14, min(83, vws.max_row) + 1):
    vals = [vws.cell(r, c).value for c in range(6, 13)]
    if all(v is None or (isinstance(v, str) and v == "") for v in vals):
        remaining_blank_rows.append(r)
print("Remaining blank rows in F:L within 14:83:", remaining_blank_rows)
output_spreadsheet = outfile
```
