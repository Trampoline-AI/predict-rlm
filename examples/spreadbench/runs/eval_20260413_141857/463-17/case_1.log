Code:
```repl
import os
from collections import Counter
from openpyxl import load_workbook

# Re-open fresh workbook for editing
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Inspect source rows and existing column D
source = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    d = ws.cell(r, 4).value
    print(f"row {r}: A={a!r}, B={b!r}, D={d!r}")
    if a is not None and b is not None:
        source.append((a, b))

# Build repeated list
repeated = []
for company, count in source:
    count_int = int(count)
    repeated.extend([company] * count_int)

print("Source pairs:", source)
print("Total repeated entries:", len(repeated))
print("Counts check:", Counter(repeated))

# Clear existing output area in column D from row 2 downward, then write full result
for r in range(2, ws.max_row + 1):
    ws.cell(r, 4).value = None

for idx, company in enumerate(repeated, start=2):
    ws.cell(idx, 4).value = company

wb.save(output_path)
print("Saved to:", output_path)

# Verify saved workbook contents
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb[verify_wb.sheetnames[0]]
d_vals = [verify_ws.cell(r, 4).value for r in range(2, 2 + len(repeated))]
print("First 15 D values:", d_vals[:15])
print("Last 10 D values:", d_vals[-10:])
print("Non-empty D count in written range:", sum(v is not None for v in d_vals))
```
