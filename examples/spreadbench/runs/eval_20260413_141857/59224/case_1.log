import os
from copy import copy
from openpyxl import load_workbook

# Re-open and inspect relevant rows fully
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Relevant rows 3-14:")
for r in range(3, 15):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Prepare output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Update formulas in E4:E14
start_row = 4
end_row = 14
for r in range(start_row, end_row + 1):
    ws[f"E{r}"] = f'=IF(COUNTIFS($C{r}:$C${end_row},"<"&$B$2,$D{r}:$D${end_row},">"&$B$2)>0,"Select Period","Do Not Select")'

wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(out_path, data_only=False)
wsf = wb_check_formula["Sheet1"]
print("Formulas E4:E14:")
for r in range(4, 15):
    print(r, wsf[f"E{r}"].value)

wb_check_values = load_workbook(out_path, data_only=True)
wsv = wb_check_values["Sheet1"]
print("Computed values for current B2 =", wsv["B2"].value)
for r in range(4, 15):
    print(r, wsv[f"E{r}"].value)
