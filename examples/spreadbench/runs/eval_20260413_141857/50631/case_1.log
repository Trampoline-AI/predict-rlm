```repl
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill
from copy import copy
from pathlib import Path
import os

infile = input_spreadsheet
outfile = str(Path("/sandbox/output/output_spreadsheet") / Path(infile).name)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Explicitly hide gridlines
ws.sheet_view.showGridLines = False

# Set Calibri font throughout while preserving other font properties
for row in ws.iter_rows():
    for cell in row:
        f = copy(cell.font)
        f.name = "Calibri"
        cell.font = f

yellow = "FFFFFF00"

def is_yellow(cell):
    return getattr(cell.fill.fgColor, "rgb", None) in ("FFFFFF00", "00FFFF00")

# Keep / normalize yellow fill where already used in key areas
for col in ["B", "D", "F", "H"]:
    for r in range(7, ws.max_row + 1):
        if is_yellow(ws[f"{col}{r}"]):
            ws[f"{col}{r}"].fill = PatternFill(fill_type="solid", fgColor=yellow)

# Preserve styles by copying from first formatted cells in each column
style_B = copy(ws["B7"]._style)
style_D = copy(ws["D7"]._style)
style_F = copy(ws["F7"]._style)
style_H = copy(ws["H7"]._style)

# Column B: dates only through 9/30/2021, with one empty formatted cell after last date
for r in range(7, 38):  # B7:B37
    c = ws[f"B{r}"]
    c._style = copy(style_B)
    if r <= 36:
        c.value = f'=IF($B$3+ROWS($B$7:$B{r})-1<=DATE(2021,9,30),$B$3+ROWS($B$7:$B{r})-1,"")'
    else:
        c.value = ""

# Column D: sequential dates through 11/2/2021 (32 rows => start 10/2/2021)
for r in range(7, 39):  # D7:D38
    c = ws[f"D{r}"]
    c._style = copy(style_D)
    c.value = f'=IF(DATE(2021,10,2)+ROWS($D$7:$D{r})-1<=DATE(2021,11,2),DATE(2021,10,2)+ROWS($D$7:$D{r})-1,"")'

# Column F: sequential dates through 11/2/2021
for r in range(7, 39):  # F7:F38
    c = ws[f"F{r}"]
    c._style = copy(style_F)
    c.value = f'=IF(DATE(2021,10,2)+ROWS($F$7:$F{r})-1<=DATE(2021,11,2),DATE(2021,10,2)+ROWS($F$7:$F{r})-1,"")'

# Column H: corrected WORKDAY formula excluding holidays in J5:J7
# Use B3-1 plus row count so first result can be the first workday on/after B3.
for r in range(7, 39):  # H7:H38, every colored cell should have a date
    c = ws[f"H{r}"]
    c._style = copy(style_H)
    c.value = f'=WORKDAY($B$3-1,ROWS($H$7:$H{r}),$J$5:$J$7)'

wb.save(outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify key output
wbv = load_workbook(outfile, data_only=False)
wsv = wbv["Sheet1"]
wbvd = load_workbook(outfile, data_only=True)
wsvd = wbvd["Sheet1"]

print("Gridlines hidden:", wsv.sheet_view.showGridLines)
print("Fonts:", wsv["B2"].font.name, wsv["H7"].font.name)
print("B formulas/values:")
for coord in ["B7", "B36", "B37"]:
    print(coord, "formula=", wsv[coord].value, "cached=", wsvd[coord].value, "fill=", wsv[coord].fill.fgColor.rgb)

print("D formulas/values:")
for coord in ["D7", "D38"]:
    print(coord, "formula=", wsv[coord].value, "cached=", wsvd[coord].value, "fill=", wsv[coord].fill.fgColor.rgb)

print("F formulas/values:")
for coord in ["F7", "F38"]:
    print(coord, "formula=", wsv[coord].value, "cached=", wsvd[coord].value, "fill=", wsv[coord].fill.fgColor.rgb)

print("H formulas/values:")
for coord in ["H7", "H8", "H38"]:
    print(coord, "formula=", wsv[coord].value, "cached=", wsvd[coord].value, "fill=", wsv[coord].fill.fgColor.rgb)

output_spreadsheet = outfile
