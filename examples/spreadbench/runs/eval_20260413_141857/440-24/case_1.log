Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os, shutil

# Inspect all rows for columns B and H
wb2 = load_workbook(input_spreadsheet)
ws = wb2[wb2.sheetnames[0]]

pairs = []
for r in range(1, ws.max_row + 1):
    b = ws.cell(r, 2).value
    h = ws.cell(r, 8).value
    if b is not None or h is not None:
        pairs.append((r, b, h))

print("Non-empty B/H rows:")
for rownum, b, h in pairs:
    print(rownum, "| B:", b, "| H:", h)

# Apply transformation: overwrite column B with corresponding column H where H has a value
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name

wb_out = load_workbook(input_spreadsheet)
ws_out = wb_out[wb_out.sheetnames[0]]

changed = 0
for r in range(1, ws_out.max_row + 1):
    h_val = ws_out.cell(r, 8).value
    if h_val is not None:
        ws_out.cell(r, 2).value = h_val
        changed += 1

wb_out.save(out_path)
print("Saved to:", out_path, "changed rows:", changed)

# Verify output
wb_verify = load_workbook(out_path, data_only=False)
wsv = wb_verify[wb_verify.sheetnames[0]]
print("Verification sample:")
for r in range(1, wsv.max_row + 1):
    b = wsv.cell(r, 2).value
    h = wsv.cell(r, 8).value
    if h is not None:
        print(r, "| B:", b, "| H:", h, "| match:", b == h)

output_spreadsheet = str(out_path)
print("output_spreadsheet:", output_spreadsheet)
```
