Plan:
1. Build a set of nonblank values from column F (excluding header).
2. Collect rows from columns A:C where column A matches a value in column F.
3. Rewrite only columns A:C:
   - keep header row 1 as-is
   - place matched rows consecutively starting at row 2
   - clear any remaining cells in A:C below them through the original used range
4. Leave column F and all rows intact.
5. Save to the output directory with the same filename.
6. Reopen and print the result to verify that A:C were compacted upward and autofilter remained.
Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Gather filter values from column F, excluding header and blanks
filter_values = set()
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 6).value
    if v is not None and str(v).strip() != "":
        filter_values.add(str(v).strip())

# Collect matching rows from A:C based on column A matching column F list
matched_rows = []
for r in range(2, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    if a_val is not None and str(a_val).strip() in filter_values:
        matched_rows.append([ws.cell(r, c).value for c in range(1, 4)])

print("Filter values:", filter_values)
print("Matched rows:", matched_rows)

# Rewrite only columns A:C
# Keep header row intact, write matches upward starting row 2
write_row = 2
for row_vals in matched_rows:
    for c, val in enumerate(row_vals, start=1):
        ws.cell(write_row, c).value = val
    write_row += 1

# Clear remaining A:C cells down to original max_row
for r in range(write_row, ws.max_row + 1):
    for c in range(1, 4):
        ws.cell(r, c).value = None

# Ensure autofilter remains on A:C range
ws.auto_filter.ref = f"A1:C{ws.max_row}"

wb.save(output_path)
print("Saved to", output_path)

# Verify by reopening
wb2 = load_workbook(output_path)
ws2 = wb2["Sheet1"]
print("Verified auto_filter:", ws2.auto_filter.ref)
for r in range(1, ws2.max_row + 1):
    print(r, [ws2.cell(r, c).value for c in range(1, 7)])

final_output_path = str(output_path)
```
