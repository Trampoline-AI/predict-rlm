Next I’ll implement the updates in a copy saved to the output directory, using openpyxl only, then verify E2:E15 values and the fill colors.
Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from copy import copy
from datetime import time
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

threshold = time(9, 45)
target_fill = PatternFill(fill_type="solid", fgColor="FFC000")

# Update E2:E14 based on time rule; preserve row 15 total formula
for r in range(2, 15):
    t = ws[f"A{r}"].value
    chosen = None
    if isinstance(t, time):
        chosen = ws[f"B{r}"].value if t < threshold else ws[f"C{r}"].value
    # If chosen value is 0, leave blank
    ws[f"E{r}"] = None if chosen in (0, 0.0) else chosen

# Apply requested fill to E2:E15 while keeping all other formatting intact
for r in range(2, 16):
    cell = ws[f"E{r}"]
    # keep existing style except fill
    cell.fill = copy(target_fill)

wb.save(outfile)

# Verify by reopening
check_wb = load_workbook(outfile)
check_ws = check_wb[check_wb.sheetnames[0]]

verification = []
for r in range(2, 16):
    cell = check_ws[f"E{r}"]
    verification.append({
        "row": r,
        "A": check_ws[f"A{r}"].value,
        "B": check_ws[f"B{r}"].value,
        "C": check_ws[f"C{r}"].value,
        "E": cell.value,
        "fill_type": cell.fill.fill_type,
        "fgColor": cell.fill.fgColor.rgb,
    })

print("Saved to:", outfile)
for item in verification:
    print(item)
```
