Code:
```repl
import os, re
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

pat = re.compile(r'^([A-Z]{2,3})\s?(\d+)$')

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

changes = []
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 2)  # column B
    v = cell.value
    if isinstance(v, str):
        m = pat.fullmatch(v)
        if m:
            new_v = m.group(2)
            if new_v != v:
                changes.append((r, v, new_v))
                cell.value = new_v

wb.save(output_path)

print("Saved to:", output_path)
print("Number of changed cells in column B:", len(changes))
print("Changes:", changes)

# Verify by reloading
vwb = load_workbook(output_path)
vws = vwb[vwb.sheetnames[0]]

rows_to_check = [14,16,20,26,28,39,80,82,91,98,103,114,128,130,135]
verification = []
for r in rows_to_check:
    verification.append((r, vws.cell(r, 2).value, type(vws.cell(r, 2).value).__name__, vws.cell(r, 2).number_format))

print("Verification sample:")
for item in verification:
    print(item)

# Extra sanity checks
remaining_matches = []
for r in range(1, vws.max_row + 1):
    v = vws.cell(r, 2).value
    if isinstance(v, str) and pat.fullmatch(v):
        remaining_matches.append((r, v))

print("Remaining matching strings in col B after edit:", remaining_matches)
print("Output exists:", os.path.exists(output_path), "size:", os.path.getsize(output_path))
```
