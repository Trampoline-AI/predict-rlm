```repl
import os, re
from collections import Counter
from openpyxl import load_workbook
from openpyxl.styles.numbers import is_date_format

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect non-empty values in column B with row numbers and types
nonempty_b = []
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 2)
    if cell.value is not None:
        nonempty_b.append((r, cell.value, type(cell.value).__name__, cell.number_format))

print("Non-empty count in col B:", len(nonempty_b))
print("First 80 non-empty col B entries:")
for item in nonempty_b[:80]:
    print(item)

# Summaries
type_counts = Counter(t for _, _, t, _ in nonempty_b)
print("Type counts:", type_counts)

# Show candidates matching intended pattern
pat = re.compile(r'^[A-Z]{2,3}\s?\d+$')
candidates = [(r, v) for r, v, t, nf in nonempty_b if isinstance(v, str) and pat.fullmatch(v)]
print("Candidate count:", len(candidates))
print("First 40 candidates:", candidates[:40])

# Show string non-candidates to understand exceptions
string_non_candidates = [(r, v) for r, v, t, nf in nonempty_b if isinstance(v, str) and not pat.fullmatch(v)]
print("String non-candidate count:", len(string_non_candidates))
print("First 40 string non-candidates:", string_non_candidates[:40])
```
