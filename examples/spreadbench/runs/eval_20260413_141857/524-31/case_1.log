from openpyxl import load_workbook
import os

# Load workbook
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Build mapping list from A:B, preserving row order
mapping = []
for r in range(1, ws.max_row + 1):
    key = ws.cell(r, 1).value
    cat = ws.cell(r, 2).value
    if key is not None and cat is not None:
        mapping.append((str(key), str(cat), r))

print("Mapping entries:", len(mapping))
print("First 5 mapping entries:", mapping[:5])

def categorize(desc, mapping_rows):
    if desc is None:
        return None, None
    desc_str = str(desc).upper()
    for key, cat, source_row in mapping_rows:
        if key.upper() in desc_str:
            return cat, key
    return "", ""

# Fill columns E, F, G with working results
results_preview = []
for r in range(1, ws.max_row + 1):
    desc = ws.cell(r, 4).value
    category, matched_key = categorize(desc, mapping)
    ws.cell(r, 5).value = category       # existing result column
    ws.cell(r, 6).value = matched_key    # helpful matched shortened version
    ws.cell(r, 7).value = category       # replace alternate broken formula too
    if r <= 15 or r >= 45:
        results_preview.append((r, desc, matched_key, category))

# Save
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Verify by reopening
check_wb = load_workbook(outfile, data_only=True)
check_ws = check_wb[check_wb.sheetnames[0]]

print("\nVerification sample (row, description, matched key, category in E, category in G):")
for r in [1,2,4,5,6,14,16,19,31,36,40,43,47,49,53]:
    print(
        r,
        "| D:", check_ws.cell(r,4).value,
        "| F:", check_ws.cell(r,6).value,
        "| E:", check_ws.cell(r,5).value,
        "| G:", check_ws.cell(r,7).value,
    )

# keep path in variable for submission
output_path = outfile
```
