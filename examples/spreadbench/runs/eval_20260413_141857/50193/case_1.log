import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally so formulas are preserved/edited
wb = load_workbook(input_path)
ws = wb["RS.Food"]

start_row = 6
end_row = ws.max_row  # 607

# Replace Category Rank formulas in column K with sequential tie-breaking formulas.
# Logic:
# - Count same-class rows with higher sales
# - Add count of same-class rows with equal sales up to current row (row-order tie breaker)
for r in range(start_row, end_row + 1):
    ws[f"K{r}"] = (
        f'=IF(J{r}="","",'
        f'SUMPRODUCT(($I${start_row}:$I${end_row}=I{r})*($B${start_row}:$B${end_row}>B{r}))'
        f'+SUMPRODUCT(($I${start_row}:I{r}=I{r})*($B${start_row}:B{r}=B{r})))'
    )

wb.save(output_path)
print("Saved:", output_path)

# Recalculate workbook to update cached formula results
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Verify results from cached values
wbd = load_workbook(output_path, data_only=True)
wsd = wbd["RS.Food"]

rows = []
for r in range(start_row, wsd.max_row + 1):
    a = wsd.cell(r, 1).value
    b = wsd.cell(r, 2).value
    i = wsd.cell(r, 9).value
    j = wsd.cell(r, 10).value
    k = wsd.cell(r, 11).value
    rows.append((r, a, b, i, j, k))

populated = [x for x in rows if x[3] not in (None, "") and x[4] not in (None, "") and isinstance(x[5], (int, float))]

# Check remaining duplicate ranks for same class + same sales
same_sales_groups = defaultdict(list)
for r, a, b, i, j, k in populated:
    if isinstance(b, (int, float)):
        same_sales_groups[(i, b)].append((r, a, k))
same_sales_dups = {k:v for k, v in same_sales_groups.items() if len(v) > 1}

remaining_bad = []
for (klass, sales), vals in same_sales_dups.items():
    ranks = [x[2] for x in vals]
    if len(set(ranks)) != len(ranks):
        remaining_bad.append(((klass, sales), vals))

print("Tied-sales groups checked:", len(same_sales_dups))
print("Remaining tied-sales groups with duplicate ranks:", len(remaining_bad))
for item in remaining_bad[:10]:
    print(item)

# Show some formerly problematic groups
targets = [
    ("Speciality", 112),
    ("Dessert", 45),
    ("Dessert", 12),
    ("Sides", 56),
    ("Sides", 7),
    ("Kids", 210),
    ("Main", 24),
]
for target in targets:
    vals = same_sales_groups.get(target, [])
    if vals:
        print(target, vals)

# Check category ranks are sequential within each class when sorted by rank
by_class = defaultdict(list)
for r, a, b, i, j, k in populated:
    by_class[i].append((r, a, b, int(k)))

class_gaps = {}
for klass, vals in by_class.items():
    ranks = sorted(v[3] for v in vals)
    expected = list(range(1, len(ranks) + 1))
    if ranks != expected:
        class_gaps[klass] = (ranks[:20], expected[:20], len(ranks))

print("Classes with non-sequential ranks:", len(class_gaps))
