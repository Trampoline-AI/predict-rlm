from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Sheet1"]

print("Sheet dimensions:", ws.max_row, ws.max_column)

# Inspect table metadata and rows involved
print("Tables:", list(ws.tables.keys()))
for name, tbl in ws.tables.items():
    print("Table", name, "ref:", tbl.ref)

for r in range(5, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 11)]
    print(f"Row {r} values/formulas:", vals)

# Update Remarks formula in column J for all data rows (below header row 5)
new_formula = '=IF(Table2[[#This Row],[Amount Outstanding]]<0,"Prepaid",IF(Table2[[#This Row],[Over Due Days]]="","",IF(Table2[[#This Row],[Over Due Days]]<90,"Call Customer","Bad Debts")))'

