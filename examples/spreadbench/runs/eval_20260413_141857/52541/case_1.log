```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Sheet1"]

print("Dimensions:", ws.max_row, ws.max_column)
print("Tables object type:", type(ws.tables))
print("Table keys:", list(ws.tables.keys()))
for name in ws.tables.keys():
    tbl_obj = ws.tables[name]
    print("Table entry:", name, "type:", type(tbl_obj), "repr:", repr(tbl_obj)[:300])

# Confirm rows to update
for r in range(5, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, 11)]
    print(f"Row {r}:", row_vals)

new_formula = '=IF(Table2[[#This Row],[Amount Outstanding]]<0,"Prepaid",IF(Table2[[#This Row],[Over Due Days]]="","",IF(Table2[[#This Row],[Over Due Days]]<90,"Call Customer","Bad Debts")))'

updated_rows = []
for r in range(6, ws.max_row + 1):
    if ws.cell(r, 1).value not in (None, ""):
        ws.cell(r, 10).value = new_formula
        updated_rows.append(r)

wb.save(output_path)
print("Saved:", output_path)
print("Updated rows:", updated_rows)

# Verify saved formulas
wb2 = load_workbook(output_path, data_only=False)
ws2 = wb2["Sheet1"]
for r in updated_rows:
    print(f"Verify J{r}:", ws2[f'J{r}'].value)
```
