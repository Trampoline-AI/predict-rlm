import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Load workbook
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Requested fill color: RGB 226-239-218
fill = PatternFill(fill_type="solid", start_color="E2EFDA", end_color="E2EFDA")

# Put formula in each D cell where the cell in column C says "Result:"
target_rows = []
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 3).value == "Result:":
        target_rows.append(r)
        formula = (
            f'=IF(AND(B{r}="Description A",B{r+1}="Description B"),"Multiple",'
            f'IF(AND(B{r}="Description A",B{r+1}=""),"Single A",'
            f'IF(AND(B{r}="Description B",B{r+1}=""),"Single B","")))'
        )
        ws.cell(r, 4).value = formula
        ws.cell(r, 4).fill = fill

wb.save(outfile)
print("Saved to:", outfile)
print("Target rows:", target_rows)

# Recalculate and verify cached values
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_check_formula = load_workbook(outfile, data_only=False)
wsf = wb_check_formula["Sheet1"]
wb_check_values = load_workbook(outfile, data_only=True)
wsv = wb_check_values["Sheet1"]

for r in target_rows:
    formula_val = wsf.cell(r, 4).value
    cached_val = wsv.cell(r, 4).value
    fill_color = wsf.cell(r, 4).fill.start_color.rgb
    print(f"Row {r}: formula={formula_val}, cached={cached_val}, fill={fill_color}")

output_spreadsheet = outfile
```
