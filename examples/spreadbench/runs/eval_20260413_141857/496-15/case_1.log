Code:
```repl
import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Identify target rows in column E containing "Check" and at least one digit
matches = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(r, 5).value
    if isinstance(val, str) and "check" in val.lower():
        nums = re.findall(r"\d+", val)
        if nums:
            matches.append((r, val, nums))

print("Matching rows found:", len(matches))
print("Matches preview:", matches[:20])

# Apply transformation: put extracted number in D, set E to "Check Paid"
for r, val, nums in matches:
    extracted = "".join(nums)  # all numeric groups combined in order
    ws.cell(r, 4).value = extracted
    ws.cell(r, 5).value = "Check Paid"

wb.save(output_path)
print("Saved to:", output_path)

# Verify by reopening
wb2 = load_workbook(output_path, data_only=False)
ws2 = wb2[wb2.sheetnames[0]]
verification = []
for r, old_val, nums in matches:
    verification.append((r, ws2.cell(r, 4).value, ws2.cell(r, 5).value))
print("Verification:", verification)
```
