from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb["Data"]

# Find non-empty cells
nonempty = []
for row in ws.iter_rows():
    for cell in row:
        if cell.value is not None:
            nonempty.append((cell.coordinate, cell.value))

print("Non-empty cell count:", len(nonempty))
print("First 80 non-empty cells:")
for coord, val in nonempty[:80]:
    print(coord, repr(val))

# Bounding box of non-empty cells
rows = [ws[c].row for c, _ in nonempty]
cols = [ws[c].column for c, _ in nonempty]
print("Bounds:",
      f"rows {min(rows)}-{max(rows)}, cols {min(cols)}-{max(cols)}",
      f"({get_column_letter(min(cols))}:{get_column_letter(max(cols))})")

# Print populated area row by row across bounding box
min_r, max_r = min(rows), max(rows)
min_c, max_c = min(cols), max(cols)
print("\nPopulated area preview:")
for r in range(min_r, max_r + 1):
    vals = [ws.cell(r, c).value for c in range(min_c, max_c + 1)]
    print(r, vals)
```
