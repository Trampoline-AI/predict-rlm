Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os, re

infile = Path(input_spreadsheet)
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / infile.name

wb = load_workbook(infile)
ws = wb["Data"]

digit_only = re.compile(r"^\d+$")

changed = 0
kept_numeric = 0
kept_digit_strings = 0
range_coords = []

for row in range(3, 21):          # rows 3-20 inclusive
    for col in range(21, 36):     # cols U-AI inclusive
        cell = ws.cell(row=row, column=col)
        val = cell.value
        keep = False
        
        if isinstance(val, (int, float)) and not isinstance(val, bool):
            keep = True
            kept_numeric += 1
        elif isinstance(val, str) and digit_only.fullmatch(val):
            keep = True
            kept_digit_strings += 1
        
        if not keep:
            if val != 0:
                changed += 1
            cell.value = 0
            range_coords.append(cell.coordinate)

wb.save(outfile)

# Verify by reopening
wb2 = load_workbook(outfile)
ws2 = wb2["Data"]

# Count remaining non-pure-numeric strings in cleaned area
remaining_bad = []
remaining_good_strings = []
for row in range(3, 21):
    for col in range(21, 36):
        cell = ws2.cell(row=row, column=col)
        val = cell.value
        if isinstance(val, str):
            if digit_only.fullmatch(val):
                remaining_good_strings.append((cell.coordinate, val))
            else:
                remaining_bad.append((cell.coordinate, val))

print("Saved:", outfile)
print("Changed cells to 0:", changed)
print("Kept numeric values:", kept_numeric)
print("Kept digit-only strings:", kept_digit_strings)
print("Remaining bad strings:", len(remaining_bad))
print("Sample changed coords:", range_coords[:20])

print("\nVerification preview rows 3-7, cols U:AI")
for r in range(3, 8):
    vals = [ws2.cell(r, c).value for c in range(21, 36)]
    print(r, vals)
```
