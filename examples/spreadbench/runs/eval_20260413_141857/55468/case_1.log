# Try to introspect array formula object
arr = cell.value
for attr in ["text", "ref"]:
    print(attr, getattr(arr, attr, None))

# Build corrected formula:
# row match on both Grade (AE4 vs A5:A10) and Flute (AD4 vs B5:B10)
# column match on both Prefix (AC4 vs C3:Z3) and Qty (AB4 vs C4:Z4)
new_formula = "=INDEX(C5:Z10,MATCH(1,INDEX((AE4=A5:A10)*(AD4=B5:B10),0),0),MATCH(1,INDEX((AC4=C3:Z3)*(AB4=C4:Z4),0),0))"
print("New formula:", new_formula)

ws["AE5"] = new_formula

# Save to output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
