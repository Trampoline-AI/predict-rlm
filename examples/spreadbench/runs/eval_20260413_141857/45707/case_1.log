ws = wb[wb.sheetnames[0]]

for r in range(2, 69):
    ws[f"D{r}"] = (
        f'=IF(AND(A{r+1}<>"",DAY(A{r+1})=1,OR(MONTH(A{r+1})<>MONTH(A{r}),YEAR(A{r+1})<>YEAR(A{r}))),'
        f'COUNTIFS($C$2:$C$69,1,$A$2:$A$69,">="&DATE(YEAR(A{r+1}),MONTH(A{r+1}),1),'
        f'$A$2:$A$69,"<"&DATE(YEAR(A{r+1}),MONTH(A{r+1})+1,1)),"")'
