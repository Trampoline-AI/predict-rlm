    print(r, vals)

# Build output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Reload for writing formulas
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Put formulas in D2:D69. Use bounded ranges and LibreOffice-safe functions.
# Logic:
# if next day's day=1 and next row month/year differ from current row,
# count how many 1s are in column C for rows whose dates in column A
# fall in the same month/year as the next row's date.
for r in range(2, 70):
    if r < 69:
        formula = (
            f'=IF(AND(A{r+1}<>"",DAY(A{r+1})=1,MONTH(A{r+1})<>MONTH(A{r})+0'
            f'+0*(YEAR(A{r+1})<>YEAR(A{r}))'
            f'),COUNTIFS($C$2:$C$69,1,$A$2:$A$69,">="&DATE(YEAR(A{r+1}),MONTH(A{r+1}),1),'
            f'$A$2:$A$69,"<"&DATE(YEAR(A{r+1}),MONTH(A{r+1})+1,1)),"")'
        )
        # Simplify the month/year change check to avoid edge cases:
        formula = (
            f'=IF(AND(A{r+1}<>"",DAY(A{r+1})=1,OR(MONTH(A{r+1})<>MONTH(A{r}),YEAR(A{r+1})<>YEAR(A{r}))),'
            f'COUNTIFS($C$2:$C$69,1,$A$2:$A$69,">="&DATE(YEAR(A{r+1}),MONTH(A{r+1}),1),'
            f'$A$2:$A$69,"<"&DATE(YEAR(A{r+1}),MONTH(A{r+1})+1,1)),"")'
        )
    else:
        formula = '=IF(A70<>"",IF(AND(DAY(A70)=1,OR(MONTH(A70)<>MONTH(A69),YEAR(A70)<>YEAR(A69))),COUNTIFS($C$2:$C$69,1,$A$2:$A$69,">="&DATE(YEAR(A70),MONTH(A70),1),$A$2:$A$69,"<"&DATE(YEAR(A70),MONTH(A70)+1,1)),""),"")'
    ws[f"D{r}"] = formula

wb.save(out_path)
print("Saved to:", out_path)
print("D2 formula:", ws["D2"].value)
print("D30 formula:", ws["D30"].value)
print("D69 formula:", ws["D69"].value)
