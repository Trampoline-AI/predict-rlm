from openpyxl import load_workbook
from datetime import datetime
import os, re

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

iso_pat = re.compile(r"^(\d{4}-\d{2}-\d{2})T.{12}Z$")

changed_rows = []
for r in range(2, ws.max_row + 1):
    cell = ws.cell(r, 1)
    v = cell.value
    
    if isinstance(v, datetime):
        cell.number_format = "m/dd/yyyy"
        changed_rows.append((r, "format_only", v))
    elif isinstance(v, str):
        s = v.strip()
        # Prefer literal instruction pattern: time portion starts with T, ends with Z, 14 chars
        if "T" in s and s.endswith("Z"):
            date_part = s.split("T", 1)[0]
            try:
                dt = datetime.strptime(date_part, "%Y-%m-%d")
                cell.value = dt
                cell.number_format = "m/dd/yyyy"
                changed_rows.append((r, "converted", s, dt))
            except ValueError:
                pass

wb.save(outfile)

# Verify by reopening
wb2 = load_workbook(outfile)
ws2 = wb2[wb2.sheetnames[0]]

verification = []
for r in range(1, ws2.max_row + 1):
    c = ws2.cell(r, 1)
    verification.append((r, c.value, type(c.value).__name__, c.number_format))

print("Saved to:", outfile)
print("Changed rows count:", len(changed_rows))
print("Changed rows sample:", changed_rows[:10])
print("Verification rows:")
for row in verification:
    print(row)

output_spreadsheet = outfile
```
