Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Identify synthesis table dimensions from existing content
# Source data block: headers in row 1, drivers in rows 3:21, day columns B:U
source_header_start_col = 2   # B
source_header_end_col = 21    # U
source_driver_start_row = 3
source_driver_end_row = 21

# Synthesis table: weekday headers in row 24, drivers in rows 25:43, weekdays in B:H
synth_header_row = 24
synth_driver_start_row = 25
synth_driver_end_row = 43
synth_start_col = 2  # B
synth_end_col = 8    # H

# Replace formulas in synthesis cells
for r in range(synth_driver_start_row, synth_driver_end_row + 1):
    for c in range(synth_start_col, synth_end_col + 1):
        coord_driver = f"$A{r}"
        coord_day = f"{ws.cell(synth_header_row, c).coordinate}"
        formula = (
            f'=SUMPRODUCT(($B$1:$U$1={coord_day})*'
            f'(OFFSET($B$3,MATCH({coord_driver},$A$3:$A$21,0)-1,0,1,COLUMNS($B$1:$U$1))<>""))'
        )
        ws.cell(r, c).value = formula

wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas and inspect results
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload both formula view and cached values for verification
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]

# Print a compact verification of formulas and values
checks = [("B25", "Friday"), ("D25", "Sunday"), ("E25", "Monday"), ("D26", "Sunday"), ("H43", "Thursday")]
for cell, label in checks:
    print(cell, "formula:", wsf[cell].value)
    print(cell, "value:", wsv[cell].value)

# Print first few synthesis rows values
for r in range(24, 30):
    vals = [wsv.cell(r, c).value for c in range(1, 9)]
    print(r, vals)

output_spreadsheet = outfile
```
