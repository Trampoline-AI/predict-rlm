import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["whole date"]

# Capture existing number format/style from an already-correct date cell if available
template_cell = ws["J2"]
template_number_format = template_cell.number_format
template_style = template_cell._style

# Fill column J with formulas based on A=Day, B=Month, C=Year
for r in range(2, ws.max_row + 1):
    ws.cell(r, 10).value = f"=DATE(C{r},B{r},A{r})"
    ws.cell(r, 10)._style = template_style
    ws.cell(r, 10).number_format = template_number_format

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate to populate cached formula results, then verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(output_path, data_only=False)
wsf = wb_check_formula["whole date"]
print("Formulas in J2:J9:", [wsf[f"J{r}"].value for r in range(2, ws.max_row + 1)])

wb_check_values = load_workbook(output_path, data_only=True)
wsv = wb_check_values["whole date"]
print("Computed values J2:J9:", [wsv[f"J{r}"].value for r in range(2, ws.max_row + 1)])

final_output_path = output_path
```
