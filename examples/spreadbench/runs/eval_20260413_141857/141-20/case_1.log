```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb2 = load_workbook(infile)
pl = wb2["PL Recon Items"]
st = wb2["Statement Recon Items"]

def is_yellow_row(ws, row_num):
    # Treat row as highlighted if any populated cell in the used range has solid yellow fill
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(row_num, c)
        fill = cell.fill
        rgb = getattr(fill.fgColor, "rgb", None)
        if fill.fill_type == "solid" and rgb in ("FFFFFF00", "FFFF00"):
            return True
    return False

def norm_num(x):
    if x is None:
        return None
    if isinstance(x, float):
        return round(x, 2)
    try:
        return round(float(x), 2)
    except Exception:
        return str(x).strip()

# Find matching yellow rows
pl_matches = []
st_matches = []

for r_pl in range(2, pl.max_row + 1):
    if not is_yellow_row(pl, r_pl):
        continue
    pl_inv = pl.cell(r_pl, 3).value  # col C
    pl_amt = pl.cell(r_pl, 4).value  # col D
    for r_st in range(2, st.max_row + 1):
        if not is_yellow_row(st, r_st):
            continue
        st_ref = st.cell(r_st, 6).value  # col F
        st_amt = st.cell(r_st, 9).value  # col I
        if str(pl_inv).strip() == str(st_ref).strip() and norm_num(pl_amt) == norm_num(st_amt):
            pl_matches.append(r_pl)
            st_matches.append(r_st)

pl_matches = sorted(set(pl_matches), reverse=True)
st_matches = sorted(set(st_matches), reverse=True)

print("PL rows to delete:", pl_matches)
print("Statement rows to delete:", st_matches)

for r in pl_matches:
    pl.delete_rows(r, 1)
for r in st_matches:
    st.delete_rows(r, 1)

wb2.save(outfile)
print("Saved:", outfile)

# Verify output
check = load_workbook(outfile)
for s in ["PL Recon Items", "Statement Recon Items"]:
    ws = check[s]
    print(f"\n{s}: rows={ws.max_row}, cols={ws.max_column}")
    for r in range(1, ws.max_row + 1):
        print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
```
