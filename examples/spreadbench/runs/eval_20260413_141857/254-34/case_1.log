from openpyxl.styles import PatternFill
import os

# Reload fresh workbook from input to avoid accidental in-memory drift
wb2 = load_workbook(input_spreadsheet)

before_ws = wb2["Before"]

# Delete Sheet3 if present
if "Sheet3" in wb2.sheetnames:
    del wb2["Sheet3"]

# Unique valid combination rows determined earlier
target_rows = [1, 2, 4, 7, 9, 14, 16]
