print("sum highlighted:", sum(highlighted_vals))

# brute force search all subsets for sums in range
target_low, target_high = 994108, 994112
solutions = []
n = len(vals)
for mask in range(1, 1 << n):
    s = 0.0
    rows = []
    for i in range(n):
        if mask & (1 << i):
            s += vals[i]
            rows.append(i + 1)
    if target_low <= s <= target_high:
        solutions.append((s, rows))

print("solutions count:", len(solutions))
print("first 20 solutions:", solutions[:20])
