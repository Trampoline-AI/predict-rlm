    # print a compact preview of first 15 rows x first 8 cols
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
        print(r, vals)
    # inspect fills/colors in used range
