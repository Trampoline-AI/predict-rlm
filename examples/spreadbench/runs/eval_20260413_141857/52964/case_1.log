```repl
import os
from openpyxl import load_workbook
from openpyxl.comments import Comment

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Determine the target rows based on populated MRNs in column A
target_rows = []
for r in range(2, ws.max_row + 1):
    if ws[f"A{r}"].value is not None:
        target_rows.append(r)

print("Target rows in A:", target_rows[:20], "count=", len(target_rows))

# Based on inspection, formula source table is Q2:Y124
# Use the requested VLOOKUP + SUMPRODUCT pattern:
# VLOOKUP(...,{5,9},FALSE) returns [U, Y]
# SUMPRODUCT(...,{-1,1}) computes (-U) + (Y) = Y-U
for r in target_rows:
    ws[f"C{r}"] = f'=IFERROR(SUMPRODUCT(VLOOKUP($A{r},$Q$2:$Y$124,{{5,9}},FALSE),{{-1,1}}),"")'

# Add an explanation comment to C2
comment_text = (
    "Formula explanation:\n"
    "=IFERROR(SUMPRODUCT(VLOOKUP($A2,$Q$2:$Y$124,{5,9},FALSE),{-1,1}),\"\")\n\n"
    "How it works:\n"
    "1) VLOOKUP($A2,$Q$2:$Y$124,{5,9},FALSE) finds the MRN from A2 in column Q.\n"
    "2) The array constant {5,9} tells VLOOKUP to return two columns from Q:Y at once:\n"
    "   - 5 = column U\n"
    "   - 9 = column Y\n"
    "3) The array constant {-1,1} supplies multipliers for those two returned values:\n"
    "   - first value (U) is multiplied by -1\n"
    "   - second value (Y) is multiplied by 1\n"
    "4) SUMPRODUCT adds the results, so the calculation becomes Y-U.\n"
    "5) IFERROR returns a blank if no match is found or if one of the values is unavailable."
)
ws["C2"].comment = Comment(comment_text, "OpenAI")

# Save workbook
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload once for formulas, once for cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

# Verify formulas are present
for r in range(2, min(8, len(target_rows) + 2)):
    print(f"C{r} formula:", ws_formula[f'C{r}'].value)

# Verify cached values
for r in range(2, min(8, len(target_rows) + 2)):
    print(f"C{r} value:", ws_values[f'C{r}'].value)

output_spreadsheet = outfile
```
