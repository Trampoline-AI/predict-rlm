```repl
import os, re, shutil
from openpyxl import load_workbook

# Inspect all rows in the used range, especially column A pattern locations
ws = wb["Sheet1"]
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 5) + 1)]
    print(r, vals)

pattern_any = re.compile(r"^400-.*")
pattern_a = re.compile(r"^400-.*-A$")

matches_any = []
matches_a = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and pattern_any.match(v):
        matches_any.append((r, v))
    if isinstance(v, str) and pattern_a.match(v):
        matches_a.append((r, v))

print("matches_any:", matches_any)
print("matches_a:", matches_a)

# Find deletion ranges in column A:
# from each -A row through the row before the next later 400-* row
deletion_ranges = []
for r, v in matches_a:
    next_row = None
    for r2, v2 in matches_any:
        if r2 > r:
            next_row = r2
            break
    if next_row is not None:
        deletion_ranges.append((r, next_row - 1, v))
print("deletion_ranges:", deletion_ranges)

# Apply transformation by copying workbook and rewriting rows except deletions
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy2(infile, outfile)

out_wb = load_workbook(outfile)
out_ws = out_wb["Sheet1"]

# Read all rows first
all_rows = [[out_ws.cell(r, c).value for c in range(1, out_ws.max_column + 1)] for r in range(1, out_ws.max_row + 1)]

delete_rows = set()
for start, end, _ in deletion_ranges:
    delete_rows.update(range(start, end + 1))

kept_rows = [row for idx, row in enumerate(all_rows, start=1) if idx not in delete_rows]

# Clear existing cells
for r in range(1, out_ws.max_row + 1):
    for c in range(1, out_ws.max_column + 1):
        out_ws.cell(r, c).value = None

# Write kept rows back from top
for r_idx, row in enumerate(kept_rows, start=1):
    for c_idx, val in enumerate(row, start=1):
        out_ws.cell(r_idx, c_idx).value = val

out_wb.save(outfile)

# Verify output
check_wb = load_workbook(outfile)
check_ws = check_wb["Sheet1"]
print("Output path:", outfile)
print("Output max_row:", check_ws.max_row, "max_col:", check_ws.max_column)
for r in range(1, check_ws.max_row + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, min(check_ws.max_column, 5) + 1)])

output_path = outfile
