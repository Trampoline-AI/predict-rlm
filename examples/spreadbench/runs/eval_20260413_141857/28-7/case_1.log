Code:
```repl
import os, re, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Reload fresh from input
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)
print("Merged ranges:", [str(rng) for rng in ws.merged_cells.ranges])

pattern_any = re.compile(r"^400-.*")
pattern_a = re.compile(r"^400-.*-A$")

matches_any = []
matches_a = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and pattern_any.match(v):
        matches_any.append((r, v))
    if isinstance(v, str) and pattern_a.match(v):
        matches_a.append((r, v))

print("matches_any:", matches_any)
print("matches_a:", matches_a)

deletion_ranges = []
for r, v in matches_a:
    next_row = None
    for r2, v2 in matches_any:
        if r2 > r:
            next_row = r2
            break
    if next_row is not None:
        deletion_ranges.append((r, next_row - 1, v, ws.cell(next_row, 1).value))

print("deletion_ranges:", deletion_ranges)

# Copy original and delete rows bottom-up
shutil.copy2(infile, outfile)
out_wb = load_workbook(outfile)
out_ws = out_wb[out_wb.sheetnames[0]]

for start, end, start_val, next_val in sorted(deletion_ranges, reverse=True):
    count = end - start + 1
    print(f"Deleting rows {start}:{end} ({count} rows) from {start_val} up to before {next_val}")
    out_ws.delete_rows(start, count)

out_wb.save(outfile)

# Verify output
check_wb = load_workbook(outfile)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Verified output path:", outfile)
print("Verified rows:", check_ws.max_row, "cols:", check_ws.max_column)
for r in range(1, check_ws.max_row + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, min(5, check_ws.max_column) + 1)])

output_path = outfile
```
