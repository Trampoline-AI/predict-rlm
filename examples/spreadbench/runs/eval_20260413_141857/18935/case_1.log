import os
from openpyxl import load_workbook

outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

wb = load_workbook(outfile)
ws = wb["Sheet1"]

for row in range(17, 23):
    ws[f"D{row}"] = (
        f'=IF(B{row}="Category 1",'
        f'SUMPRODUCT(($A$5:$A$10=A{row})*($B$5:$B$10=C{row})*($C$5:$C$10)),'
        f'IF(B{row}="Category 2",'
        f'SUMPRODUCT(($A$5:$A$10=A{row})*($B$5:$B$10=C{row})*($D$5:$D$10)),'
        f'SUMPRODUCT(($A$5:$A$10=A{row})*($B$5:$B$10=C{row})*($E$5:$E$10))))'
    )

wb.save(outfile)
print("Saved revised formulas to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas are present
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["Sheet1"]
formula_texts = [wsf[f"D{r}"].value for r in range(17, 23)]
print("Formula sample D17:", formula_texts[0])
print("All D17:D22 types:", [type(v).__name__ for v in formula_texts])

# Verify computed values
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]
vals = [wsv[f"D{r}"].value for r in range(17, 23)]
print("Calculated values D17:D22:", vals)

# Python expected values from the source table
expected = []
for r in range(17, 23):
    work = wsv[f"A{r}"].value
    cat = wsv[f"B{r}"].value
    mat = wsv[f"C{r}"].value
    total = 0
    for sr in range(5, 11):
        if wsv[f"A{sr}"].value == work and wsv[f"B{sr}"].value == mat:
            if cat == "Category 1":
                total += wsv[f"C{sr}"].value or 0
            elif cat == "Category 2":
                total += wsv[f"D{sr}"].value or 0
            elif cat == "Category 3":
                total += wsv[f"E{sr}"].value or 0
    expected.append(total)
print("Expected by Python:", expected)
print("Match?", vals == expected)
```
