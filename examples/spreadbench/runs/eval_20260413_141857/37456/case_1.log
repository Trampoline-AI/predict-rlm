from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sample Data"]

# Currency format (non-accounting)
currency_fmt = '$#,##0.00'

# Fill formulas for rows where a next date exists: 12:15
for r in range(12, 16):
    next_row = r + 1
    for c in range(7, 11):  # G:J
        col_letter = get_column_letter(c)
        formula = (
            f'=IF($F{next_row}="","",'
            f'SUMPRODUCT((($A$4:$A$32+$B$4:$B$32)>=$F{r}+$F$1)*(($C$4:$C$32={col_letter}$11))*$D$4:$D$32)'
            f'-SUMPRODUCT((($A$4:$A$32+$B$4:$B$32)>$F{next_row}+$F$2)*(($C$4:$C$32={col_letter}$11))*$D$4:$D$32)'
            f')'
        )
        ws.cell(r, c).value = formula
        ws.cell(r, c).number_format = currency_fmt

# Ensure last date row does not calculate
for c in range(7, 11):
    ws.cell(16, c).value = None

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate workbook for cached formula values
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas and cached values
