```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Determine bounded ranges from actual used data
sheet1_last = ws1.max_row
sheet2_last = ws2.max_row
while sheet2_last > 1 and all(ws2.cell(sheet2_last, c).value is None for c in range(1, 5)):
    sheet2_last -= 1

# Populate formulas in Expected outcome (column H)
for r in range(2, sheet1_last + 1):
    formula = (
        f'=MAX(MIN(G{r},'
        f'SUMIFS(Sheet2!$D$2:$D${sheet2_last},Sheet2!$A$2:$A${sheet2_last},A{r},Sheet2!$B$2:$B${sheet2_last},D{r})'
        f'-SUMIFS($G$2:G{r-1},$A$2:A{r-1},A{r},$D$2:D{r-1},D{r})'
        f'),0)'
    )
    ws1[f"H{r}"] = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(outfile, data_only=False)
wb_check_values = load_workbook(outfile, data_only=True)
wsf = wb_check_formula["Sheet1"]
wsv = wb_check_values["Sheet1"]

print("Sample formulas and cached values:")
for r in range(2, 19):
    print(r, wsf[f"H{r}"].value, "=>", wsv[f"H{r}"].value)
```
