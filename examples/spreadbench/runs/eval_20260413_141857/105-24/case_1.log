import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws_open = wb["Open"]
ws_prod = wb["Productivity"]

# Build lookup from Productivity columns A:B, starting below header row 3
lookup = {}
for r in range(4, ws_prod.max_row + 1):
    mud_id = ws_prod.cell(r, 1).value
    name = ws_prod.cell(r, 2).value
    if mud_id not in (None, ""):
        lookup[str(mud_id)] = name

# Replace IDs with names in Open columns C and K
replaced = []
for r in range(4, ws_open.max_row + 1):
    for col in (3, 11):  # C and K
        cell = ws_open.cell(r, col)
        val = cell.value
        key = str(val) if val not in (None, "") else None
        if key and key in lookup:
            old = cell.value
            cell.value = lookup[key]
            replaced.append((r, col, old, cell.value))

wb.save(outfile)

# Verify saved output
wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check["Open"]

print("Saved to:", outfile)
print("Total replacements:", len(replaced))
print("First 10 replacements:")
for item in replaced[:10]:
    print(item)

print("Verification rows 4-8:")
for r in range(4, 9):
    print(
        r,
        "C=", ws_check.cell(r, 3).value,
        "K=", ws_check.cell(r, 11).value
    )

# Confirm no remaining original IDs from lookup keys in C/K
remaining_ids = []
for r in range(4, ws_check.max_row + 1):
    for col in (3, 11):
        v = ws_check.cell(r, col).value
        if str(v) in lookup:
            remaining_ids.append((r, col, v))
print("Remaining ID-like values in C/K that still match lookup keys:", remaining_ids[:20], "count=", len(remaining_ids))
```
