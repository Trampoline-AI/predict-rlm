import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws_data = wb["Data"]
ws_lookup = wb["Lookup"]

# Write INDEX/MATCH formulas in Lookup column B for each year in column A
for r in range(2, ws_lookup.max_row + 1):
    ws_lookup.cell(r, 2).value = f'=IFERROR(INDEX(Data!$14:$14,1,MATCH(A{r},Data!$4:$4,0)+1),"")'

wb.save(output_path)
print("Saved:", output_path)

# Recalculate to populate cached formula values
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
lf = wb_formula["Lookup"]
lv = wb_values["Lookup"]

for r in range(1, lf.max_row + 1):
    print(
        r,
        "A=", lf.cell(r, 1).value,
        "B_formula=", lf.cell(r, 2).value,
        "B_value=", lv.cell(r, 2).value
    )

output_spreadsheet = output_path
```
