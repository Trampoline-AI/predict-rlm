import zipfile, os, re, xml.etree.ElementTree as ET
from pprint import pprint

xlsx_path = input_spreadsheet
zf = zipfile.ZipFile(xlsx_path)

print("ZIP contents sample:")
names = zf.namelist()
print([n for n in names if "shared" in n or "sheet" in n or "styles" in n][:20])

# Inspect workbook relationships quickly
for name in ["xl/sharedStrings.xml", "xl/worksheets/sheet1.xml", "xl/styles.xml"]:
    print("\n---", name, "---", "exists" if name in names else "missing")
    if name in names:
        data = zf.read(name)
        print(data[:1200].decode("utf-8", errors="ignore"))

# Parse shared strings for rich text runs if present
ns = {
    "a": "http://schemas.openxmlformats.org/spreadsheetml/2006/main"
}
if "xl/sharedStrings.xml" in names:
    root = ET.fromstring(zf.read("xl/sharedStrings.xml"))
    sis = root.findall("a:si", ns)
    print("\nsharedStrings count:", len(sis))
    rich_examples = []
    for i, si in enumerate(sis):
        runs = si.findall("a:r", ns)
        if runs:
            parts = []
            for r in runs:
                text = "".join(t.text or "" for t in r.findall("a:t", ns))
                rpr = r.find("a:rPr", ns)
                color = None
                bold = False
                if rpr is not None:
                    bold = rpr.find("a:b", ns) is not None
                    c = rpr.find("a:color", ns)
                    if c is not None:
                        color = c.attrib
                parts.append((text, bold, color))
            rich_examples.append((i, parts))
            if len(rich_examples) >= 20:
                break
    print("sharedStrings with rich text (first 20):")
    pprint(rich_examples[:20])
else:
    print("No sharedStrings.xml present")

# Parse sheet1 cells in BD rows 1:40 to see storage type / style ids
sheet_root = ET.fromstring(zf.read("xl/worksheets/sheet1.xml"))
cells = []
for c in sheet_root.findall(".//a:c", ns):
    ref = c.attrib.get("r", "")
    if ref.startswith("BD"):
        row_num = int(re.sub(r"\D", "", ref))
        if 1 <= row_num <= 40:
            t = c.attrib.get("t")
            s = c.attrib.get("s")
            v = c.find("a:v", ns)
            is_el = c.find("a:is", ns)
            cells.append((ref, t, s, v.text if v is not None else None, ET.tostring(is_el, encoding="unicode")[:300] if is_el is not None else None))
print("\nBD1:BD40 raw cell storage:")
for item in cells:
