```repl
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill
import os, re, shutil

# Check rich text writing support
from openpyxl.cell.rich_text import CellRichText, TextBlock
from openpyxl.cell.text import InlineFont

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Create/update editable pattern sheet
helper_name = "PatternList"
if helper_name in wb.sheetnames:
    hp = wb[helper_name]
    # clear existing content conservatively
    for row in hp.iter_rows():
        for cell in row:
            cell.value = None
else:
    hp = wb.create_sheet(helper_name)

hp["A1"] = "Pattern"
hp["B1"] = "WholeWordOnly"
hp["C1"] = "Active"
hp["D1"] = "Notes"

header_fill = PatternFill(fill_type="solid", fgColor="D9EAF7")
for c in "ABCD":
    hp[f"{c}1"].font = Font(bold=True)
    hp[f"{c}1"].fill = header_fill

# Starter list: editable by user. Includes whole-word example "too".
starter_patterns = [
    ("too", True, True, "Example of whole-word-only matching"),
    ("led", False, True, "Substring match"),
    ("jumped", False, True, ""),
    ("imp", False, True, ""),
    ("game", False, True, ""),
    ("strong", False, True, ""),
    ("tried hard", False, True, ""),
    ("ran away", False, True, ""),
    ("no finish", False, True, ""),
    ("no danger", False, True, ""),
    ("closed well", False, True, ""),
    ("faded", False, True, ""),
    ("tough", False, True, ""),
    ("battled", False, True, ""),
]
for i, row in enumerate(starter_patterns, start=2):
    for j, val in enumerate(row, start=1):
        hp.cell(i, j).value = val

hp.column_dimensions["A"].width = 22
hp.column_dimensions["B"].width = 16
hp.column_dimensions["C"].width = 10
hp.column_dimensions["D"].width = 42
hp.freeze_panes = "A2"

# Rich text styles
default_font = InlineFont(rFont="Calibri", sz=11, b=True, color="FF000000")
highlight_font = InlineFont(rFont="Calibri", sz=11, b=True, color="FFFF0000")

def load_patterns(sheet):
    patterns = []
    r = 2
    while r <= sheet.max_row:
        pat = sheet.cell(r, 1).value
        whole = sheet.cell(r, 2).value
        active = sheet.cell(r, 3).value
        if pat not in (None, "") and active not in (False, "False", "FALSE", 0, "0", None, ""):
            patterns.append((str(pat), bool(whole)))
        r += 1
    return patterns

patterns = load_patterns(hp)
print("Patterns loaded:", patterns[:10], "count=", len(patterns))

def find_matches(text, patterns):
    matches = []
    for pat, whole_word in patterns:
        if not pat:
            continue
        if whole_word:
            # whole word/term only: must not be embedded in letters/digits/underscore
            rx = re.compile(rf'(?<![A-Za-z0-9_]){re.escape(pat)}(?![A-Za-z0-9_])', re.IGNORECASE)
        else:
            rx = re.compile(re.escape(pat), re.IGNORECASE)
        for m in rx.finditer(text):
            matches.append((m.start(), m.end()))
    if not matches:
        return []

    # merge overlaps
    matches.sort()
    merged = [list(matches[0])]
    for s, e in matches[1:]:
        if s <= merged[-1][1]:
            merged[-1][1] = max(merged[-1][1], e)
        else:
            merged.append([s, e])
    return [(s, e) for s, e in merged]

bd_col = 56
changed = 0
sample_changes = []

for r in range(2, ws.max_row + 1):  # skip header
    cell = ws.cell(r, bd_col)
    val = cell.value
    if val in (None, ""):
        continue
    text = str(val)
    spans = find_matches(text, patterns)
    if not spans:
        continue

    rt = CellRichText()
    pos = 0
    for s, e in spans:
        if s > pos:
            rt.append(TextBlock(default_font, text[pos:s]))
        rt.append(TextBlock(highlight_font, text[s:e]))
        pos = e
    if pos < len(text):
        rt.append(TextBlock(default_font, text[pos:]))

    cell.value = rt
    changed += 1
    if len(sample_changes) < 8:
        sample_changes.append((r, text, spans))

# Keep column/header formatting intact; just ensure BD cells use wrapped alignment if already typical
print("Changed BD cells:", changed)
print("Sample changes:", sample_changes)

wb.save(outfile)

# Verify reopen
wb2 = load_workbook(outfile, rich_text=True)
ws2 = wb2[wb2.sheetnames[0]]
hp2 = wb2[helper_name]
print("Output saved:", outfile)
print("Sheets:", wb2.sheetnames)
print("PatternList rows:", hp2.max_row, "BD2 type:", type(ws2["BD2"].value).__name__, "BD2 repr:", repr(ws2["BD2"].value)[:300])
```
