from openpyxl import load_workbook
from datetime import datetime, date
import os

output_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

def normalize_to_date(v):
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    return None

vwb = load_workbook(output_path, data_only=True)
vws = vwb["Sheet1"]

# Rebuild holiday map from the saved workbook
holiday_map = {}
for r in range(2, vws.max_row + 1):
    hd = normalize_to_date(vws.cell(r, 9).value)
    ht = vws.cell(r, 10).value
    if hd and ht:
        holiday_map[hd] = ht

main_dates = []
missing_workday = []
overlap = []

for r in range(2, vws.max_row + 1):
    d = normalize_to_date(vws.cell(r, 1).value)
    workday_val = vws.cell(r, 5).value
    if d:
        main_dates.append(d)
        if workday_val is None:
            missing_workday.append((r, d.isoformat()))
        if d in holiday_map:
            overlap.append((r, d.isoformat(), workday_val, holiday_map[d]))

print("Total main date rows:", len(main_dates))
print("Rows missing WORKDAY after fill:", len(missing_workday), missing_workday[:10])
print("Holiday dates that actually occur in main table:", len(overlap))
print("Overlap rows:", overlap)

# Show a few normal rows and confirm abbreviations
for r in [2,3,4,5,12,13,14,47,48,49]:
    if r <= vws.max_row:
        print(r, normalize_to_date(vws.cell(r,1).value), "->", vws.cell(r,5).value)
