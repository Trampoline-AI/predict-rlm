```repl
import os, shutil
from openpyxl import load_workbook

# Load workbook fresh
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Collect dictionary words from column A
words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

word_set = set(words)

# Build unique pairs as (vowel_word, s_word)
pairs = set()
for s_word in word_set:
    if "S" not in s_word:
        continue
    for vowel in "AEIOU":
        vowel_word = "".join(vowel if ch == "S" else ch for ch in s_word)
        if vowel_word in word_set:
            pairs.add((vowel_word, s_word))

# Sort case-insensitively by both columns
pairs_sorted = sorted(pairs, key=lambda p: (p[0].upper(), p[1].upper()))

# Clear existing G:H contents
for r in range(1, ws.max_row + 1):
    ws.cell(r, 7).value = None
    ws.cell(r, 8).value = None

# Write pairs starting at G1:H1 (after sorting whole result range, first pair should be at row 1)
for i, (gval, hval) in enumerate(pairs_sorted, start=1):
    ws.cell(i, 7).value = gval
    ws.cell(i, 8).value = hval

# Save to output path with same filename
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

# Verify saved output
wb2 = load_workbook(output_path, data_only=False)
ws2 = wb2[wb2.sheetnames[0]]

written = []
for r in range(1, ws2.max_row + 1):
    g = ws2.cell(r, 7).value
    h = ws2.cell(r, 8).value
    if g is None and h is None:
        continue
    written.append((g, h))

print("Output path:", output_path)
print("Written pair count:", len(written))
print("First 15 written pairs:", written[:15])
print("Last 10 written pairs:", written[-10:])

# Check a few rows below written area are blank in G:H
start_check = len(written) + 1
end_check = min(len(written) + 5, ws2.max_row)
tail_check = [(r, ws2.cell(r, 7).value, ws2.cell(r, 8).value) for r in range(start_check, end_check + 1)]
print("Rows after output:", tail_check)

final_output_path = output_path
```
