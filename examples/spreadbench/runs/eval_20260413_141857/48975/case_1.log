import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Inspect calculated values from the source workbook
wb_formula = load_workbook(input_path, data_only=False)
wb_values = load_workbook(input_path, data_only=True)

ws_in_f = wb_formula["Input"]
ws_in_v = wb_values["Input"]

check_rows = [9, 10, 11, 12, 18, 23, 33]
print("Input formula/value comparison:")
for r in check_rows:
    print(
        r,
        "A_formula=", ws_in_f.cell(r, 1).value,
        "A_value=", ws_in_v.cell(r, 1).value,
        "B_value=", ws_in_v.cell(r, 2).value,
        "E_value=", ws_in_v.cell(r, 5).value,
    )

# Rebuild output using literal values where available
wb_out = load_workbook(input_path)
ws_in_src = wb_out["Input"]
ws_out = wb_out["Output"]
wb_src_vals = load_workbook(input_path, data_only=True)
ws_in_vals = wb_src_vals["Input"]

ws_out["A10"] = ws_in_vals["A7"].value if ws_in_vals["A7"].value is not None else ws_in_src["A7"].value
ws_out["B10"] = ws_in_vals["B7"].value if ws_in_vals["B7"].value is not None else ws_in_src["B7"].value

for r in range(11, ws_out.max_row + 1):
    ws_out.cell(r, 1).value = None
    ws_out.cell(r, 2).value = None

filtered_rows_values = []
for r in range(1, ws_in_src.max_row + 1):
    e_val = ws_in_src.cell(r, 5).value
    if isinstance(e_val, str) and e_val.strip().lower() == "yes":
        a_val = ws_in_vals.cell(r, 1).value
        b_val = ws_in_vals.cell(r, 2).value
        if a_val not in (None, "") and b_val not in (None, ""):
            filtered_rows_values.append((a_val, b_val))

for out_r, (a_val, b_val) in enumerate(filtered_rows_values, start=11):
    ws_out.cell(out_r, 1).value = a_val
    ws_out.cell(out_r, 2).value = b_val

wb_out.save(output_path)

# Verify final saved output
verify = load_workbook(output_path, data_only=False)
vout = verify["Output"]
print("\nFinal output rows 10-20:")
for r in range(10, 21):
    print(r, [vout.cell(r, c).value for c in range(1, 3)])

print("\nRows written:", filtered_rows_values)
