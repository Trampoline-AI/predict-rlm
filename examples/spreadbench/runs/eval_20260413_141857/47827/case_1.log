Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)

main_ws = wb["3 straights to 3 boxed"]
ref_ws = wb["boxed"]

# Target fill color
boxed_fill = PatternFill(fill_type="solid", fgColor="EBF1DE")

# Complete column G in main sheet based on columns B:D sorted ascending
for r in range(2, main_ws.max_row + 1):
    b = main_ws[f"B{r}"].value
    c = main_ws[f"C{r}"].value
    d = main_ws[f"D{r}"].value
    if b is None and c is None and d is None:
        continue
    digits = [int(b), int(c), int(d)]
    boxed_text = "".join(str(x) for x in sorted(digits))
    main_ws[f"G{r}"] = boxed_text
    main_ws[f"G{r}"].number_format = "@"

# Style all boxed values in main sheet column G that are part of the used table
for r in range(1, 17):  # rows actually used in the main table
    cell = main_ws[f"G{r}"]
    cell.fill = boxed_fill
    cell.font = cell.font.copy(bold=True)

# Style all boxed values in reference sheet column E
for r in range(1, ref_ws.max_row + 1):
    cell = ref_ws[f"E{r}"]
    if cell.value is not None:
        cell.fill = boxed_fill
        cell.font = cell.font.copy(bold=True)

wb.save(output_path)

# Verify by reloading
verify_wb = load_workbook(output_path)
v_main = verify_wb["3 straights to 3 boxed"]
v_ref = verify_wb["boxed"]

print("Saved:", output_path, os.path.exists(output_path))
print("Completed main sheet G2:G16:")
for r in range(2, 17):
    c = v_main[f"G{r}"]
    print(r, c.value, c.font.bold, c.fill.fgColor.rgb)

print("Reference sheet E1:E5 styles:")
for r in range(1, 6):
    c = v_ref[f"E{r}"]
    print(r, c.value, c.font.bold, c.fill.fgColor.rgb)

final_output_path = output_path
```
