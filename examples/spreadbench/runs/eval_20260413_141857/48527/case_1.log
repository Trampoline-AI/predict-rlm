Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Ensure header for column 4 remains present
if ws.cell(1, 4).value is None:
    ws.cell(1, 4).value = "Column 4"

# Fill column 4 with the unique value among columns 1-3 when two values match
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value

    unique_val = None
    if a == b and a != c:
        unique_val = c
    elif a == c and a != b:
        unique_val = b
    elif b == c and b != a:
        unique_val = a
    elif a != b and b != c and a != c:
        unique_val = None
    else:
        # all same or ambiguous
        unique_val = None

    if unique_val is not None:
        ws.cell(r, 4).value = unique_val

wb.save(output_path)

# Verify saved output
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]
verification = []
for r in range(1, check_ws.max_row + 1):
    verification.append([check_ws.cell(r, c).value for c in range(1, 5)])

print("Saved to:", output_path)
for row in verification:
    print(row)
```
