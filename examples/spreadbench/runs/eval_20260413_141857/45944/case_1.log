import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Fill formulas for Table2 rows
for r in range(11, 14):
    ws[f"G{r}"] = '=IFERROR(IF(Table2[[#This Row],[START_DATE]]>=INDEX($E$11:$E$13,MATCH(Table2[[#This Row],[PARTICIPANT_NAME]],$D$11:$D$13,0)),TRUE(),FALSE()),FALSE())'

# Fill formulas for Table3 rows
for r in range(20, 23):
    ws[f"G{r}"] = '=IFERROR(IF(Table3[[#This Row],[START_DATE]]>=INDEX($E$20:$E$22,MATCH(Table3[[#This Row],[PARTICIPANT_NAME]],$D$20:$D$22,0)),TRUE(),FALSE()),FALSE())'

wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formulas G11:G13:", [wsf[f"G{r}"].value for r in range(11, 14)])
print("Formulas G20:G22:", [wsf[f"G{r}"].value for r in range(20, 23)])

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
print("Values G11:G13:", [wsv[f"G{r}"].value for r in range(11, 14)])
print("Values G20:G22:", [wsv[f"G{r}"].value for r in range(20, 23)])

output_spreadsheet = outfile
```
