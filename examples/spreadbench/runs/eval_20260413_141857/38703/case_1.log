```repl
from openpyxl import load_workbook
import os, shutil
from copy import copy

# Re-open fresh workbook for inspection and editing
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Rows 16-24, cols A-J:")
for r in range(16, 25):
    vals = [ws.cell(r, c).value for c in range(1, 11)]
    print(r, vals)

print("\nCurrent target/output-region cells before unmerge:")
for coord in ["H2", "H10", "H11", "H20", "H21", "H24"]:
    cell = ws[coord]
    print(coord, "value=", cell.value)

# Compute requested unique counts from column E ranges
def unique_nonblank_count(cell_range):
    vals = []
    for row in ws[cell_range]:
        for cell in row:
            if cell.value is not None and str(cell.value).strip() != "":
                vals.append(str(cell.value).strip())
    return len(set(vals))

counts = {
    "H10": unique_nonblank_count("E2:E10"),
    "H20": unique_nonblank_count("E11:E20"),
    "H24": unique_nonblank_count("E21:E24"),
}
print("\nComputed counts:", counts)

# Preserve top-left cell styles/values of merged regions if helpful
merged_ranges = list(ws.merged_cells.ranges)
print("Merged ranges to unmerge:", merged_ranges)

# Unmerge all merged cells
for mr in merged_ranges:
    ws.unmerge_cells(str(mr))

print("Merged ranges after unmerge:", list(ws.merged_cells.ranges))

# Write counts to requested cells
for coord, val in counts.items():
    ws[coord] = val

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)

# Verify
wb2 = load_workbook(out_path)
ws2 = wb2["Sheet1"]
print("\nVerification:")
print("Merged ranges count after save:", len(list(ws2.merged_cells.ranges)))
for coord in ["H10", "H20", "H24"]:
    print(coord, ws2[coord].value)
```
