Code:
```repl
from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb[wb.sheetnames[0]]

# Fill I2:L13 with formulas that return:
# - header rows where col A = "Power (kW)"
# - data rows where col A = selected power in F2
#
# Formula logic:
#   AGGREGATE(...) finds the nth matching row number among A2:A15
#   INDEX($A$2:$D$15, that_row, current_output_column)
#   IFERROR returns blank once matches are exhausted
for r in range(2, 14):      # I2:L13
    for c in range(9, 13):
        cell = ws.cell(r, c)
        col_offset = c - 8  # I=1, J=2, K=3, L=4
        row_num = r - 1     # I2 uses 1st match, I3 uses 2nd, etc.
        formula = (
            '=IFERROR('
            'INDEX($A$2:$D$15,'
            f'_xlfn.AGGREGATE(15,6,(ROW($A$2:$A$15)-ROW($A$2)+1)/(($A$2:$A$15=$F$2)+($A$2:$A$15="Power (kW)")),{row_num}),'
            f'{col_offset}'
            '),"")'
        )
        cell.value = formula

wb.save(outfile)

# Recalculate formulas and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Reload with formulas and with cached values for verification
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[wb_formula.sheetnames[0]]

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[wb_values.sheetnames[0]]

print("Written formulas in I2:L5:")
for r in range(2, 6):
    print([wsf.cell(r, c).value for c in range(9, 13)])

print("\nCached values in I2:L13:")
for r in range(2, 14):
    print(r, [wsv.cell(r, c).value for c in range(9, 13)])

output_spreadsheet = outfile
print("\nOutput file:", output_spreadsheet)
```
