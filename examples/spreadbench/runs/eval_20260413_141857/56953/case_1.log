from openpyxl.styles import PatternFill, Font, Border, Alignment
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

def cell_info(addr):
    c = ws[addr]
    fill = c.fill.fill_type, c.fill.fgColor.rgb, c.fill.fgColor.indexed, c.fill.fgColor.type
    return {
        "addr": addr,
        "value": c.value,
        "data_type": c.data_type,
        "fill": fill,
        "numfmt": c.number_format,
        "font_bold": c.font.bold,
    }

