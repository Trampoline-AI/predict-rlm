Code:
```repl
from openpyxl import load_workbook
import os

outfile = output_spreadsheet
wb = load_workbook(outfile)
ws = wb[wb.sheetnames[0]]

# Match rows where:
# 1) current row power equals F2
# OR
# 2) current row is a header "Power (kW)" and the next row's power equals F2
#
# This avoids including unrelated header rows from other power groups.
condition = (
    '(($A$2:$A$15=$F$2)'
    '+(('
    '$A$2:$A$15="Power (kW)")*'
    '(IFERROR(INDEX($A$2:$A$15,ROW($A$2:$A$15)-ROW($A$2)+2),"")=$F$2)'
    '))'
)

for r in range(2, 14):
    for c in range(9, 13):
        row_num = r - 1      # nth match
        col_offset = c - 8   # I=1..L=4
        ws.cell(r, c).value = (
            '=IFERROR('
            'INDEX($A$2:$D$15,'
            f'_xlfn.AGGREGATE(15,6,(ROW($A$2:$A$15)-ROW($A$2)+1)/{condition},{row_num}),'
            f'{col_offset}'
            '),"")'
        )

wb.save(outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify cached results
wbv = load_workbook(outfile, data_only=True)
wsv = wbv[wbv.sheetnames[0]]

print("Cached values I2:L13 after fix:")
for r in range(2, 14):
    print(r, [wsv.cell(r, c).value for c in range(9, 13)])
```
