            v = cell.value
            if hasattr(v, "text"):
                v = f"ArrayFormula(text={v.text}, ref={v.ref})"
            row.append(f"{get_column_letter(c)}{r}={v}")
        print(" | ".join(row))

print("\nDetailed target area styles/formulas:")
