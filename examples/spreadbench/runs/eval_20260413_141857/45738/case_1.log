Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect styles / formats in target area before editing
print("Sample styles/formats before editing:")
for coord in ["E5", "E6", "L6", "P9", "AB25"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format, 
          "align=", (cell.alignment.horizontal, cell.alignment.vertical))

# Write "-" in row 5 across E:AB
for col in range(5, 29):
    ws.cell(5, col).value = "-"

# Write formulas in E6:AB25
# Logic uses month difference between header date and maturity date.
# diff = months from header month to maturity month
# if diff < 0 => header after maturity month => "-"
# if diff = 0 => maturity month => principal + interest
# else if diff is a payment interval multiple => interest
# else "-"
for row in range(6, 26):
    for col in range(5, 29):
        col_letter = get_column_letter(col)
        formula = (
            f'=IF(OR($A{row}="",$B{row}="",$C{row}="",$D{row}=""),"",'
            f'IF((((YEAR($D{row})-YEAR({col_letter}$4))*12)+MONTH($D{row})-MONTH({col_letter}$4))<0,"-",'
            f'IF((((YEAR($D{row})-YEAR({col_letter}$4))*12)+MONTH($D{row})-MONTH({col_letter}$4))=0,$A{row}+$B{row},'
            f'IF(MOD((((YEAR($D{row})-YEAR({col_letter}$4))*12)+MONTH($D{row})-MONTH({col_letter}$4)),12/$C{row})=0,$B{row},"-")))'
        )
        ws.cell(row, col).value = formula
        # Center align while preserving number format and other formatting
        current_alignment = ws.cell(row, col).alignment
        ws.cell(row, col).alignment = Alignment(
            horizontal="center",
            vertical="center",
            text_rotation=current_alignment.textRotation,
            wrap_text=current_alignment.wrap_text,
            shrink_to_fit=current_alignment.shrink_to_fit,
            indent=current_alignment.indent
        )

output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Reopen and inspect formulas
wb2 = load_workbook(output_path, data_only=False)
ws2 = wb2[wb2.sheetnames[0]]
print("\nVerification of written cells:")
for coord in ["E5", "E6", "L6", "X6", "Q9", "R9", "U10", "E6", "AB25"]:
    cell = ws2[coord]
    print(coord, "=", cell.value, "align=", (cell.alignment.horizontal, cell.alignment.vertical), "numfmt=", cell.number_format)

# Keep path in variable for next step
final_output_path = output_path
```
