out_ws = out_wb["final Recon Items"]

if candidate_rows and abs(candidate_sum) <= tol_sum:
    for r in sorted(candidate_rows, reverse=True):
        out_ws.delete_rows(r, 1)
    action = f"Deleted rows {candidate_rows}"
