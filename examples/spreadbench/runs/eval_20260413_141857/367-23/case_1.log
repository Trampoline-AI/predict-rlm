from openpyxl import load_workbook

# Re-open fresh workbook and inspect exact numeric behavior
wb = load_workbook(input_spreadsheet)
ws = wb["final Recon Items"]

amounts = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 4).value
    amounts.append((r, float(v) if isinstance(v, (int, float)) else v))

print("Amounts:", amounts)
numeric_amounts = [v for _, v in amounts if isinstance(v, float)]
total = sum(numeric_amounts)
print("Total sum repr:", repr(total))
print("Total abs:", abs(total))

# Candidate rows: values approximately +/-0.01
tol_value = 1e-6
tol_sum = 1e-6
candidate_rows = [r for r, v in amounts if isinstance(v, float) and abs(abs(v) - 0.01) <= tol_value]
candidate_sum = sum(ws.cell(r, 4).value for r in candidate_rows)
print("Candidate rows:", candidate_rows)
print("Candidate sum repr:", repr(candidate_sum))
print("Candidate abs sum:", abs(candidate_sum))

# Copy input to output path
