import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load, modify, save
wb = load_workbook(infile)
ws = wb["Sheet1"]

new_formula = '=COUNTIFS(B:B,"*Gary Stoddard*",A:A,"4")'
ws["F3"] = new_formula
wb.save(outfile)

# Verify saved formula
wb_check = load_workbook(outfile)
ws_check = wb_check["Sheet1"]
print("Saved to:", outfile)
print("F3 formula after save:", ws_check["F3"].value)

# Verify expected count in Python
count_contains = 0
count_exact = 0
for row in range(2, ws_check.max_row + 1):
    a = ws_check.cell(row=row, column=1).value
    b = ws_check.cell(row=row, column=2).value
    a_str = "" if a is None else str(a).strip()
    b_str = "" if b is None else str(b)
    if a_str == "4":
        if b_str == "Gary Stoddard":
            count_exact += 1
        if "Gary Stoddard" in b_str:
            count_contains += 1

print("Python exact-match count:", count_exact)
print("Python contains-match count:", count_contains)

output_spreadsheet = outfile
```
