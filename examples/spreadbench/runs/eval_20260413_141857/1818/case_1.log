Code:
```repl
import os, shutil
from openpyxl import load_workbook

# Paths
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

# Load copied workbook for editing
wb_out = load_workbook(outfile)
data_ws = wb_out["Data"]
summary_ws = wb_out["Summary"]

# Determine data bounds from Data sheet
start_row = 2
end_row = data_ws.max_row

# Write Excel 2013-compatible formulas using INDEX + AGGREGATE
# Fill enough rows to cover all students; extra rows will stay blank via IFERROR
for r in range(3, end_row + 2):  # rows on Summary
    k_expr = f"ROWS(B$3:B{r})"
    pos_expr = (
        f'AGGREGATE(15,6,'
        f'(ROW(Data!$D${start_row}:$D${end_row})-ROW(Data!$D${start_row})+1)/'
        f'(Data!$D${start_row}:$D${end_row}="Lowest Performing"),'
        f'{k_expr})'
    )
    summary_ws[f"B{r}"] = f'=IFERROR(INDEX(Data!$B${start_row}:$B${end_row},{pos_expr}),"")'
    summary_ws[f"C{r}"] = f'=IFERROR(INDEX(Data!$C${start_row}:$C${end_row},{pos_expr}),"")'

wb_out.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=True)
sum_check = wb_check["Summary"]

# Inspect first 10 output rows and count nonblank student numbers
preview = []
nonblank = 0
for r in range(3, end_row + 2):
    b = sum_check[f"B{r}"].value
    c = sum_check[f"C{r}"].value
    if b not in (None, ""):
        nonblank += 1
    if r <= 12:
        preview.append((r, b, c))

print("Preview rows 3:12:", preview)
print("Nonblank extracted students:", nonblank)

output_spreadsheet = outfile
```
