ws2 = wb2[wb2.sheetnames[0]]
print("\nAfter:")
for r in range(1, ws2.max_row + 1):
    row_vals = [ws2.cell(r, c).value for c in range(1, ws2.max_column + 1)]
    print(r, row_vals)

output_spreadsheet = out_path
print("Saved to:", output_spreadsheet)
