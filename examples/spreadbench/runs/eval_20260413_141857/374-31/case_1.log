import os, shutil
from openpyxl import load_workbook

# Re-inspect all used rows clearly
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Before:")
for r in range(1, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(r, row_vals)

# Find first row in column A containing "Code"
code_row = None
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 1).value == "Code":
        code_row = r
        break

print("code_row:", code_row)

# Identify rows above code_row where column A is blank
rows_to_delete = []
if code_row:
    for r in range(1, code_row):
        if ws.cell(r, 1).value in (None, ""):
            rows_to_delete.append(r)

print("rows_to_delete:", rows_to_delete)

# Delete from bottom to top to preserve indices
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

# Save output
