```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for editing
wb2 = load_workbook(input_path)
ws_main = wb2["Main unique ID"]
ws_get = wb2["Result what i am getting"]
ws_exp = wb2["Result what i am expecting "]

# Quick style inspection from expected sheet
for r in [3, 4, 10, 14, 18]:
    print("Expected row", r, "values:", [ws_exp.cell(r, c).value for c in range(1, 6)])
    print(" style_ids:", [ws_exp.cell(r, c).style_id for c in range(1, 6)])
    print(" fills:", [(ws_exp.cell(r, c).fill.fill_type, ws_exp.cell(r, c).fill.fgColor.rgb) for c in range(1, 6)])

header = [ws_get.cell(1, c).value for c in range(1, ws_get.max_column + 1)]
main_ids = [ws_main.cell(r, 1).value for r in range(1, ws_main.max_row + 1) if ws_main.cell(r, 1).value is not None]

# Capture existing rows from "getting"
existing_rows = {}
for r in range(2, ws_get.max_row + 1):
    uid = ws_get.cell(r, 1).value
    if uid is not None:
        existing_rows[uid] = {
            "values": [ws_get.cell(r, c).value for c in range(1, ws_get.max_column + 1)],
            "cells": [ws_get.cell(r, c) for c in range(1, ws_get.max_column + 1)],
            "row_height": ws_get.row_dimensions[r].height,
        }

# Clear existing data area
for r in range(2, ws_get.max_row + 1):
    for c in range(1, ws_get.max_column + 1):
        cell = ws_get.cell(r, c)
        cell.value = None
        cell._style = copy(ws_get.cell(2, c)._style) if ws_get.max_row >= 2 else copy(cell._style)
        cell.number_format = 'General'
        cell.fill = PatternFill(fill_type=None)
        cell.border = copy(cell.border)
        cell.font = copy(cell.font)
        cell.alignment = copy(cell.alignment)
        cell.protection = copy(cell.protection)

# Use a yellow fill matching expected
yellow_fill = PatternFill(fill_type="solid", fgColor="FFFFFF00")

# Find a normal style template row from original getting row 2
normal_template_cells = [existing_rows[next(iter(existing_rows))]["cells"][c-1] for c in range(1, ws_get.max_column + 1)]

# Write rows in main-ID order
out_row = 2
for uid in main_ids:
    if uid in existing_rows:
        row_info = existing_rows[uid]
        values = row_info["values"]
        for c in range(1, ws_get.max_column + 1):
            target = ws_get.cell(out_row, c)
            source = row_info["cells"][c-1]
            target.value = values[c-1]
            target._style = copy(source._style)
            if source.has_style:
                target.font = copy(source.font)
                target.fill = copy(source.fill)
                target.border = copy(source.border)
                target.alignment = copy(source.alignment)
                target.number_format = source.number_format
                target.protection = copy(source.protection)
        if row_info["row_height"] is not None:
            ws_get.row_dimensions[out_row].height = row_info["row_height"]
    else:
        # Insert blank yellow-highlighted row with only Unique ID populated
        for c in range(1, ws_get.max_column + 1):
            target = ws_get.cell(out_row, c)
            template = normal_template_cells[c-1]
            target._style = copy(template._style)
            target.font = copy(template.font)
            target.border = copy(template.border)
            target.alignment = copy(template.alignment)
            target.number_format = template.number_format
            target.protection = copy(template.protection)
            target.fill = copy(yellow_fill)
            target.value = uid if c == 1 else None
    out_row += 1

# Remove any leftover trailing rows' values/styles beyond the new data length
for r in range(out_row, ws_get.max_row + 1):
    for c in range(1, ws_get.max_column + 1):
        cell = ws_get.cell(r, c)
        cell.value = None
        cell.fill = PatternFill(fill_type=None)

wb2.save(output_path)

# Verify output
check = load_workbook(output_path)
ws_check = check["Result what i am getting"]
ids_after = [ws_check.cell(r, 1).value for r in range(2, ws_check.max_row + 1) if ws_check.cell(r, 1).value is not None]
print("Output saved:", output_path)
print("IDs after:", ids_after)
print("Matches main IDs:", ids_after == main_ids)
for uid in [8, 9, 47, 99, 500]:
    row = ids_after.index(uid) + 2
    print(
        "UID", uid, "row", row,
        "first 5 values:", [ws_check.cell(row, c).value for c in range(1, 6)],
        "fills:", [ws_check.cell(row, c).fill.fgColor.rgb for c in range(1, 6)],
        "fill_types:", [ws_check.cell(row, c).fill.fill_type for c in range(1, 6)]
    )

final_output_path = output_path
```
