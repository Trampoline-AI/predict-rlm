from openpyxl import load_workbook
from pathlib import Path
import os, shutil

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
src = wb["cdnr"]
dest = wb["b2b, sez, de"]
exp = wb["Expected"]

def row_values(ws, r, c1=1, c2=None):
    c2 = c2 or ws.max_column
    return [ws.cell(r, c).value for c in range(c1, c2 + 1)]

def is_empty_row(ws, r, c1=1, c2=None):
    vals = row_values(ws, r, c1, c2 or ws.max_column)
    return all(v is None for v in vals)

# Find first empty destination row, starting from row 5
start_row = None
for r in range(5, dest.max_row + 1):
    if is_empty_row(dest, r, 1, dest.max_column):
        start_row = r
        break
if start_row is None:
    start_row = dest.max_row + 1

# Collect non-empty source data rows from row 5 downward
src_rows = []
for r in range(5, src.max_row + 1):
    if not is_empty_row(src, r, 1, src.max_column):
        src_rows.append(r)

print("start_row:", start_row)
print("source rows:", src_rows)

# Append transformed rows without overwriting existing data
for idx, sr in enumerate(src_rows):
    dr = start_row + idx

    # preserve row height pattern if desired/available
    if dest.row_dimensions[5].height is not None:
        dest.row_dimensions[dr].height = dest.row_dimensions[5].height

    # Read source row values
    s = {c: src.cell(sr, c).value for c in range(1, src.max_column + 1)}

    # Write destination values based on the required semantic alignment
    mapping_values = {
        1: s.get(1),    # A <- A
        2: s.get(2),    # B <- B
        3: s.get(3),    # C <- C
        4: s.get(4),    # D <- D
        5: s.get(9),    # E <- I
        6: s.get(6),    # F <- F
        7: s.get(7),    # G <- G
        8: None,        # H blank
        9: "Credit Note", # I constant
        10: s.get(10),  # J <- J
        11: s.get(11),  # K <- K
        12: -s.get(12) if s.get(12) is not None else None,  # L negative
        13: -s.get(13) if s.get(13) is not None else None,  # M negative
        14: s.get(14),  # N <- N
        15: s.get(15),  # O <- O
        16: s.get(16),  # P <- P
        17: s.get(17),  # Q <- Q
        18: s.get(18),  # R <- R
        19: s.get(19),  # S <- S
        20: s.get(20),  # T <- T
        21: s.get(21),  # U <- U
        22: s.get(22),  # V <- V
    }

    for c, val in mapping_values.items():
        dest.cell(dr, c).value = val

wb.save(output_path)
print("Saved to:", output_path)

# Verify output by reloading and comparing key appended rows to Expected
wb2 = load_workbook(output_path)
dest2 = wb2["b2b, sez, de"]

checks = []
for i, sr in enumerate(src_rows):
    dr = start_row + i
    out_vals = row_values(dest2, dr, 1, 22)
    exp_vals = row_values(exp, dr, 1, 22)
    same = out_vals == exp_vals
    checks.append((dr, same, out_vals, exp_vals))

print("Verification summary:")
for dr, same, out_vals, exp_vals in checks:
    print("row", dr, "match_expected=", same)

output_spreadsheet = str(output_path)
```
