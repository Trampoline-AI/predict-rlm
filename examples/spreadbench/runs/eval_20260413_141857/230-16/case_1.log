```repl
import os, re, shutil
from copy import copy
from openpyxl import load_workbook

def split_from_first_letter(val):
    if val is None:
        return None, None
    s = str(val)
    m = re.search(r"[A-Za-z]", s)
    if not m:
        return s, None
    idx = m.start()
    return s[:idx], s[idx:]

# Paths
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Copy original file first
shutil.copy2(input_spreadsheet, out_path)

# Load source and output workbooks
src_wb = load_workbook(input_spreadsheet)
src_before = src_wb["Before"]
src_after = src_wb["After"]

wb = load_workbook(out_path)
ws_before = wb["Before"]
ws_after = wb["After"]

# Clear existing used cells in After
for row in ws_after.iter_rows(min_row=1, max_row=ws_after.max_row, min_col=1, max_col=ws_after.max_column):
    for cell in row:
        cell.value = None

# Preserve dimensions from existing After sheet
for col_letter, dim in src_after.column_dimensions.items():
    ws_after.column_dimensions[col_letter].width = dim.width
for r_idx, dim in src_after.row_dimensions.items():
    ws_after.row_dimensions[r_idx].height = dim.height

# Template styles from original After if available
def clone_style(src_cell, dst_cell):
    dst_cell._style = copy(src_cell._style)
    dst_cell.font = copy(src_cell.font)
    dst_cell.fill = copy(src_cell.fill)
    dst_cell.border = copy(src_cell.border)
    dst_cell.alignment = copy(src_cell.alignment)
    dst_cell.number_format = src_cell.number_format
    dst_cell.protection = copy(src_cell.protection)

# Keep row 1 blank, put header on row 2
header_row = 2
ws_after.cell(header_row, 1).value = "data"
ws_after.cell(header_row, 2).value = "string1"

if src_after.max_row >= 2:
    clone_style(src_after.cell(2, 1), ws_after.cell(2, 1))
    clone_style(src_after.cell(2, 2), ws_after.cell(2, 2))

out_r = 3
processed = 0

# Transform rows from Before, skipping header row and blank rows
for r in range(2, ws_before.max_row + 1):
    a = ws_before.cell(r, 1).value
    b = ws_before.cell(r, 2).value
    if a is None and b is None:
        continue

    left, right = split_from_first_letter(a)

    ws_after.cell(out_r, 1).value = left
    ws_after.cell(out_r, 2).value = right if right is not None else b

    # apply data row style from row 3 of original After if it exists
    if src_after.max_row >= 3:
        clone_style(src_after.cell(3, 1), ws_after.cell(out_r, 1))
        clone_style(src_after.cell(3, 2), ws_after.cell(out_r, 2))

    processed += 1
    out_r += 1

wb.save(out_path)

# Verify output
check_wb = load_workbook(out_path, data_only=False)
check_after = check_wb["After"]
print("Saved:", out_path)
print("Processed rows:", processed)
print("After sheet dimensions:", check_after.max_row, "x", check_after.max_column)
for r in range(1, check_after.max_row + 1):
    print(r, [check_after.cell(r, c).value for c in range(1, 3)])

output_spreadsheet = out_path
```
