2. Group IDs by `(impact, likelihood)`.
3. Clear the matrix body `F12:H14`.
4. Fill each matrix cell with comma-separated IDs matching that row/column label pair.
5. Save to the required output directory with the same filename.
6. Reload and print the filled matrix to verify correctness.
Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
from collections import defaultdict
import os

# Load source workbook
infile = Path(input_spreadsheet)
outfile = Path("/sandbox/output/output_spreadsheet") / infile.name

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Read risk table from A:C starting below header row 3
grouped = defaultdict(list)
row = 4
while True:
    risk_id = ws.cell(row=row, column=1).value
    impact = ws.cell(row=row, column=2).value
    likelihood = ws.cell(row=row, column=3).value
    
    if risk_id is None and impact is None and likelihood is None:
        break
    
    if risk_id is not None and impact is not None and likelihood is not None:
        grouped[(int(impact), int(likelihood))].append(str(risk_id))
    row += 1

print("Grouped risks:", dict(grouped))

# Matrix body is F12:H14; clear existing contents first
for r in range(12, 15):
    for c in range(6, 9):  # F:H
        ws.cell(r, c).value = None

# Fill matrix based on row/column labels
for r in range(12, 15):
    impact_label = ws.cell(r, 5).value  # E column
    if impact_label is None:
        continue
    impact_val = int(impact_label)
    
    for c in range(6, 9):  # F:H
        likelihood_label = ws.cell(15, c).value
        if likelihood_label is None:
            continue
        likelihood_val = int(likelihood_label)
        
        ids = grouped.get((impact_val, likelihood_val), [])
        ws.cell(r, c).value = ", ".join(ids) if ids else None

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Verify by reloading and printing matrix area
check_wb = load_workbook(outfile)
check_ws = check_wb["Sheet1"]

print("Verified matrix F12:H14:")
for r in range(12, 15):
    print(r, [check_ws.cell(r, c).value for c in range(6, 9)])

output_spreadsheet = str(outfile)
```
