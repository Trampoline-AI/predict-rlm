```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Daily Numbers"]

# Determine data rows: rows with WHS in col A and Date in col L
data_rows = []
for r in range(3, ws.max_row + 1):
    if ws[f"A{r}"].value is not None and ws[f"L{r}"].value is not None:
        data_rows.append(r)

# Add/label difference column in S to reflect "cartons received - errors"
ws["S2"] = "Difference"

# Copy a nearby style for the new header and data cells if available
if ws["R2"].has_style:
    ws["S2"]._style = copy(ws["R2"]._style)
if ws["R3"].has_style:
    for r in data_rows:
        ws[f"S{r}"]._style = copy(ws["R3"]._style)

# Build corrected formulas.
# N:R correspond to codes in B:F
# User names are in G:J, and must be treated as OR by summing separate SUMIFS.
for r in data_rows:
    # II in N from code B
    ws[f"N{r}"] = (
        f'=SUM('
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$B{r},Errors!$AB:$AB,$G{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$B{r},Errors!$AB:$AB,$H{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$B{r},Errors!$AB:$AB,$I{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$B{r},Errors!$AB:$AB,$J{r})'
        f')'
    )

    # IR in O from code C, only positive quantities from Errors!M:M
    ws[f"O{r}"] = (
        f'=SUM('
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$C{r},Errors!$AB:$AB,$G{r},Errors!$M:$M,">0"),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$C{r},Errors!$AB:$AB,$H{r},Errors!$M:$M,">0"),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$C{r},Errors!$AB:$AB,$I{r},Errors!$M:$M,">0"),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$C{r},Errors!$AB:$AB,$J{r},Errors!$M:$M,">0")'
        f')'
    )

    # IT in P from code D
    ws[f"P{r}"] = (
        f'=SUM('
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$D{r},Errors!$AB:$AB,$G{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$D{r},Errors!$AB:$AB,$H{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$D{r},Errors!$AB:$AB,$I{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$D{r},Errors!$AB:$AB,$J{r})'
        f')'
    )

    # OV in Q from code E
    ws[f"Q{r}"] = (
        f'=SUM('
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$E{r},Errors!$AB:$AB,$G{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$E{r},Errors!$AB:$AB,$H{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$E{r},Errors!$AB:$AB,$I{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$E{r},Errors!$AB:$AB,$J{r})'
        f')'
    )

    # PI in R from code F
    ws[f"R{r}"] = (
        f'=SUM('
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$F{r},Errors!$AB:$AB,$G{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$F{r},Errors!$AB:$AB,$H{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$F{r},Errors!$AB:$AB,$I{r}),'
        f'SUMIFS(Errors!$M:$M,Errors!$I:$I,$A{r},Errors!$Q:$Q,$L{r},Errors!$B:$B,$F{r},Errors!$AB:$AB,$J{r})'
        f')'
    )

    # Difference: inbound receipts - total errors
    ws[f"S{r}"] = f"=M{r}-SUM(N{r}:R{r})"

# Save workbook
wb.save(outfile)
print("Saved:", outfile)
print("Rows updated:", data_rows)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas and cached values
wb_check = load_workbook(outfile, data_only=False)
wsf = wb_check["Daily Numbers"]
