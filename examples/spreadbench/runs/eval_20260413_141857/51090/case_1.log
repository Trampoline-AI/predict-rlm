wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals["Daily Numbers"]
print("Sample recalculated values:")
for r in data_rows[:5]:
    print(r, {c: wsv[f"{c}{r}"].value for c in ["M","N","O","P","Q","R","S"]})

output_spreadsheet = outfile
