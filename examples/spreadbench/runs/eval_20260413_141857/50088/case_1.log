import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Sheet1"]

# Determine data range from the visible sample list in columns A and B.
data_start = 2
data_end = 11

# Fill formulas for each item listed under the Item header.
for row in range(6, ws.max_row + 1):
    item = ws[f"E{row}"].value
    if item is None:
        continue
    formula = f'=SUMPRODUCT(($B${data_start}:$B${data_end}=E{row})+(($B${data_start}:$B${data_end}="")*($A${data_start}:$A${data_end}=E{row})))'
    ws[f"F{row}"] = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(outfile, data_only=False)
wsf = wb_check_formula["Sheet1"]
print("Formulas written:", {f"F{r}": wsf[f"F{r}"].value for r in range(6, 9)})

wb_check_values = load_workbook(outfile, data_only=True)
wsv = wb_check_values["Sheet1"]
print("Computed values:", {f"F{r}": wsv[f"F{r}"].value for r in range(6, 9)})

output_spreadsheet = outfile
```
