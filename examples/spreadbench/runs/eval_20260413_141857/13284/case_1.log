Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os

# Reload clean workbook
wb = load_workbook(input_spreadsheet)
base = wb["Base"]
streets = wb["Streets"]

def norm_text(x):
    return "" if x is None else str(x).strip().casefold()

def safe_num(x):
    try:
        return float(x)
    except Exception:
        return None

def lookup(base_street, base_num, mode="strict"):
    num = safe_num(base_num)
    if num is None:
        return ""
    for r in range(2, streets.max_row + 1):
        street = streets.cell(r, 2).value
        start = streets.cell(r, 3).value
        end = streets.cell(r, 4).value
        assistant = streets.cell(r, 6).value

        # Only consider rows where both start and end are populated
        if start in (None, "") or end in (None, ""):
            continue

        lo = safe_num(start)
        hi = safe_num(end)
        if lo is None or hi is None:
            continue

        if mode == "strict":
            street_ok = (base_street == street)
        else:
            street_ok = (norm_text(base_street) == norm_text(street))

        if street_ok and lo <= num <= hi:
            return "" if assistant is None else assistant
    return ""

# Compare strict vs case-insensitive against expected results in Base!F
strict_matches = 0
ci_matches = 0
comparison_rows = []
for r in range(2, base.max_row + 1):
    expected = base.cell(r, 6).value
    expected_norm = "" if expected is None else str(expected)
    strict = lookup(base.cell(r, 3).value, base.cell(r, 4).value, "strict")
    ci = lookup(base.cell(r, 3).value, base.cell(r, 4).value, "ci")
    if strict == expected_norm:
        strict_matches += 1
    if ci == expected_norm:
        ci_matches += 1
    comparison_rows.append((r, expected_norm, strict, ci))

print("Rows in Base data:", base.max_row - 1)
print("Strict matches expected:", strict_matches)
print("Case-insensitive matches expected:", ci_matches)

# Show only mismatches for the better strategy
best_mode = "ci" if ci_matches >= strict_matches else "strict"
print("Chosen mode:", best_mode)
mismatches = []
for r, expected, strict, ci in comparison_rows:
    got = ci if best_mode == "ci" else strict
    if got != expected:
        mismatches.append((r, expected, got, base.cell(r, 3).value, base.cell(r, 4).value))
print("Mismatch count for chosen mode:", len(mismatches))
print("Mismatch sample:", mismatches[:10])

# Apply chosen lookup results into Base column E
for r in range(2, base.max_row + 1):
    result = lookup(base.cell(r, 3).value, base.cell(r, 4).value, best_mode)
    base.cell(r, 5).value = result

# Save output
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb.save(out_path)

# Verify saved values
wb_check = load_workbook(out_path, data_only=False)
base_check = wb_check["Base"]
written = [base_check.cell(r, 5).value for r in range(2, base_check.max_row + 1)]
expected_vals = [base_check.cell(r, 6).value for r in range(2, base_check.max_row + 1)]

verify_matches = 0
verify_mismatches = []
for idx, (w, e) in enumerate(zip(written, expected_vals), start=2):
    e_norm = "" if e is None else str(e)
    w_norm = "" if w is None else str(w)
    if w_norm == e_norm:
        verify_matches += 1
    else:
        verify_mismatches.append((idx, w_norm, e_norm))

print("Saved to:", out_path)
print("Verification matches vs Base!F:", verify_matches, "of", len(written))
print("Verification mismatch sample:", verify_mismatches[:10])

output_file = str(out_path)
```
