# Count rows where O has green-ish fill or existing value in original workbook
orig = load_workbook(input_spreadsheet)
ows = orig[orig.sheetnames[0]]
green_rows = []
for r in range(4, ows.max_row + 1):
    o = ows[f"O{r}"]
    if o.value not in (None, "") or fill_rgb(o) is not None:
        green_rows.append((r, o.value, fill_rgb(o)))
print("Sample O rows in original:", green_rows[:20])
print("Count O rows with value/fill in original:", len(green_rows))

# Fix point IF formulas to return numeric values instead of quoted text
# Only for first section points columns F,H,J,L,N where formulas exist
point_cols = ["F", "H", "J", "L", "N"]
changed = 0
for col in point_cols:
    for r in range(4, wsf.max_row + 1):
        cell = wsf[f"{col}{r}"]
        v = cell.value
        if isinstance(v, str) and v.startswith("=IF("):
            new_v = v.replace('"3"', '3').replace('"2"', '2').replace('"1"', '1').replace('"5"', '5').replace('"4"', '4')
            if new_v != v:
