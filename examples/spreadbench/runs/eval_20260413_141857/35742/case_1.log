from openpyxl import load_workbook

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

# Inspect current output after prior edit
wbf = load_workbook(out_path, data_only=False)
wsv = load_workbook(out_path, data_only=True)
wsf = wbf[wbf.sheetnames[0]]
wsvs = wsv[wsv.sheetnames[0]]

def fill_rgb(cell):
    f = cell.fill
    if not f or f.fill_type is None:
        return None
    return f.fgColor.rgb or f.fgColor.indexed

print("Inspect rows 4-10 before any further fix:")
for r in range(4, 11):
    vals = {}
    for col in ["E","F","G","H","I","J","K","L","M","N","O"]:
        vals[col] = {
            "formula": wsf[f"{col}{r}"].value,
            "cached": wsvs[f"{col}{r}"].value,
            "fill": fill_rgb(wsf[f"{col}{r}"]),
