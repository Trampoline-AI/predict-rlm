Code:
```repl
import os
from openpyxl import load_workbook

src = input_spreadsheet
filename = os.path.basename(src)
out_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Start from the original workbook to avoid carrying forward any unnecessary edits
wb = load_workbook(src)
ws = wb[wb.sheetnames[0]]

# Determine target rows: rows where O already had a manual total/value
# or rows with section-1 content in E:N (participant rows for that section)
target_rows = []
for r in range(4, ws.max_row + 1):
    has_section_data = any(ws[f"{c}{r}"].value not in (None, "") for c in ["E","G","I","K","M","F","H","J","L","N"])
    has_total_cell_activity = ws[f"O{r}"].value not in (None, "")
    if has_section_data or has_total_cell_activity:
        target_rows.append(r)

# Write a formula that coerces text numbers to numeric values before summing.
# Leave O blank when all five point cells are blank.
for r in target_rows:
    ws[f"O{r}"] = (
        f'=IF(COUNTA(F{r},H{r},J{r},L{r},N{r})=0,"",'
        f'SUM(IFERROR(VALUE(F{r}),0),IFERROR(VALUE(H{r}),0),'
        f'IFERROR(VALUE(J{r}),0),IFERROR(VALUE(L{r}),0),IFERROR(VALUE(N{r}),0)))'
    )

wb.save(out_path)
print("Saved:", out_path)
print("Target row count:", len(target_rows), "sample:", target_rows[:15], "...", target_rows[-10:])

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Verify formulas and cached values
wbf = load_workbook(out_path, data_only=False)
wbv = load_workbook(out_path, data_only=True)
wsf = wbf[wbf.sheetnames[0]]
wsv = wbv[wbv.sheetnames[0]]

sample_rows = [4, 5, 6, 7, 8, 9, 10]
print("\nVerification samples:")
for r in sample_rows:
    points = [wsv[f"{c}{r}"].value for c in ["F","H","J","L","N"]]
    total = wsv[f"O{r}"].value
    print(r, "points=", points, "O_formula=", wsf[f"O{r}"].value, "O_value=", total)

# Compare expected totals by coercing cached text values in Python
def to_num(x):
    if x in (None, ""):
        return 0
    try:
        return float(x)
    except:
        return 0

print("\nExpected vs cached:")
for r in [4,5,6,7]:
    pts = [wsv[f"{c}{r}"].value for c in ["F","H","J","L","N"]]
    expected = sum(to_num(x) for x in pts)
    print("Row", r, "expected", expected, "cached O", wsv[f"O{r}"].value)
```
