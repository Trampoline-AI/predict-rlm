import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def color_of(cell):
    fill = cell.fill
    if fill and fill.fill_type:
        return {
            "fill_type": fill.fill_type,
            "fgColor": fill.fgColor.rgb or fill.fgColor.indexed or fill.fgColor.type,
            "bgColor": fill.bgColor.rgb or fill.bgColor.indexed or fill.bgColor.type,
        }
    return None

for ws in wb.worksheets:
    print("\n--- Sheet:", ws.title, "---")
    print("Size:", ws.max_row, "rows x", ws.max_column, "cols")
    # Print first 15 rows x 12 cols values
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)]
        print(r, vals)
    # Inspect colored cells in used range
    colored = []
    for row in ws.iter_rows():
        for cell in row:
            col = color_of(cell)
            if col:
                colored.append((cell.coordinate, cell.value, col))
    print("Colored cells count:", len(colored))
    print("First 30 colored cells:", colored[:30])
