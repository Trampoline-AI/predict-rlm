Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sub CO's"]

start_row, end_row = 4, 10

# Write formulas in column G
ws[f"G{start_row}"] = f'=IF(F{start_row}="Yes",1,0)'
for r in range(start_row + 1, end_row + 1):
    ws[f"G{r}"] = f'=IF(F{r}="Yes",MAX($G${start_row}:G{r-1})+1,0)'

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate workbook so cached formula results are available
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sub CO's"]
formula_check = [(r, ws_formula[f"F{r}"].value, ws_formula[f"G{r}"].value) for r in range(start_row, end_row + 1)]
print("Formulas in F/G rows 4-10:")
for row in formula_check:
    print(row)

# Verify calculated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sub CO's"]
value_check = [(r, ws_values[f"F{r}"].value, ws_values[f"G{r}"].value) for r in range(start_row, end_row + 1)]
print("Calculated values in F/G rows 4-10:")
for row in value_check:
    print(row)

output_spreadsheet = outfile
```
