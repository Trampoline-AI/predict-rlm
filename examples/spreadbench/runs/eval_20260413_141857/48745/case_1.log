Code:
```repl
from openpyxl import load_workbook
from copy import copy
import os

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect output column formatting/formulas for rows 5:10
for r in range(5, 11):
    c = ws.cell(r, 4)  # column D
    print(r, "C=", ws.cell(r, 3).value, "D=", c.value, "data_type=", c.data_type)

# Build lookup from G:H
lookup = {}
for r in range(5, ws.max_row + 1):
    key = ws.cell(r, 7).value
    val = ws.cell(r, 8).value
    if key is not None and val is not None:
        lookup[str(key).strip()] = str(val).strip()

print("lookup:", lookup)

def classify(cell_value):
    parts = [p.strip() for p in str(cell_value).split(";") if p and str(p).strip()]
    groups = []
    for p in parts:
        g = lookup.get(p)
        if g and g not in groups:
            groups.append(g)
    # sort ascending by group number if possible
    def sort_key(g):
        import re
        m = re.search(r"(\d+)", g)
        return int(m.group(1)) if m else 10**9
    groups = sorted(groups, key=sort_key)
    if not groups:
        return None
    return ", ".join(groups)

computed = {}
for r in range(5, 11):
    computed[r] = classify(ws.cell(r, 3).value)
print("computed:", computed)

# Preserve style from D5 when filling D column
style_source = ws["D5"]
for r in range(5, 11):
    target = ws.cell(r, 4)
    target.value = computed[r]
    if r != 5:
        target._style = copy(style_source._style)
        target.number_format = style_source.number_format
        target.font = copy(style_source.font)
        target.fill = copy(style_source.fill)
        target.border = copy(style_source.border)
        target.alignment = copy(style_source.alignment)
        target.protection = copy(style_source.protection)

out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("saved:", out_path)

# Verify output values
wb2 = load_workbook(out_path, data_only=False)
ws2 = wb2["Sheet1"]
for r in range(5, 11):
    print("Row", r, "C=", ws2.cell(r,3).value, "D=", ws2.cell(r,4).value)
```
