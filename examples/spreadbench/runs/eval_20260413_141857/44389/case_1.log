import os
from copy import copy
from openpyxl import load_workbook

# Reload workbook normally to inspect formulas/styles
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect column O formulas and style references around target cells
for r in range(2, ws.max_row + 1):
    o = ws[f"O{r}"]
    p = ws[f"P{r}"]
    print(
        r,
        "O.value type:", type(o.value).__name__,
        "O.value:", getattr(o.value, "text", o.value),
        "P.value:", p.value,
        "O.style:", o.style_id,
        "P.style:", p.style_id,
    )

# Build seller formulas in P based on B:N matching O
header_range = "$B$1:$N$1"
for r in range(2, ws.max_row + 1):
    data_range = f"B{r}:N{r}"
    min_cell = f"O{r}"
    # concatenate matching headers with trailing commas, then remove final comma
    concat_expr = (
        f'IF(B{r}={min_cell},B$1&",","")&'
        f'IF(C{r}={min_cell},C$1&",","")&'
        f'IF(D{r}={min_cell},D$1&",","")&'
        f'IF(E{r}={min_cell},E$1&",","")&'
        f'IF(F{r}={min_cell},F$1&",","")&'
        f'IF(G{r}={min_cell},G$1&",","")&'
        f'IF(H{r}={min_cell},H$1&",","")&'
        f'IF(I{r}={min_cell},I$1&",","")&'
        f'IF(J{r}={min_cell},J$1&",","")&'
        f'IF(K{r}={min_cell},K$1&",","")&'
        f'IF(L{r}={min_cell},L$1&",","")&'
        f'IF(M{r}={min_cell},M$1&",","")&'
        f'IF(N{r}={min_cell},N$1&",","")'
    )
    formula = f'=IFERROR(LEFT({concat_expr},LEN({concat_expr})-1),"")'
    ws[f"P{r}"] = formula
    # copy style from O to P if P blank/default to preserve appearance
    ws[f"P{r}"]._style = copy(ws[f"O{r}"]._style)

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb.save(out_path)
print("Saved to", out_path)

# Recalculate and verify
res = await recalculate(out_path)
print("Recalc:", res)

wbv = load_workbook(out_path, data_only=False)
wsv = wbv[wbv.sheetnames[0]]
print("Formulas in P:")
for r in range(2, wsv.max_row + 1):
    print(r, wsv[f"P{r}"].value)

wbv2 = load_workbook(out_path, data_only=True)
wsv2 = wbv2[wbv2.sheetnames[0]]
print("Computed O/P values:")
for r in range(2, wsv2.max_row + 1):
    print(r, "Min>", wsv2[f"O{r}"].value, "Seller", wsv2[f"P{r}"].value)

output_spreadsheet = out_path
```
