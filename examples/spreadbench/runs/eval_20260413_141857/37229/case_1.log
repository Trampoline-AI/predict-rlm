import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook normally to write formulas
wb = load_workbook(infile)
ws = wb["Sheet1"]

# Write formulas in C3:G14
for r in range(3, 15):      # rows for Jan-Dec
    for c in range(3, 8):   # cols C:G
        col_letter = ws.cell(1, c).column_letter
        formula = (
            f'=IF('
            f'SUMPRODUCT((MONTH($B$17:$B$24)=MONTH($B{r}))*(YEAR($B$17:$B$24)=YEAR($B{r}))*{col_letter}$17:{col_letter}$24)=0,'
            f'"",'
            f'SUMPRODUCT((MONTH($B$17:$B$24)=MONTH($B{r}))*(YEAR($B$17:$B$24)=YEAR($B{r}))*{col_letter}$17:{col_letter}$24)'
            f')'
        )
        ws.cell(r, c).value = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify cached values
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check["Sheet1"]
print("Formula samples:")
for r in range(3, 6):
    print(r, [ws_check.cell(r, c).value for c in range(3, 8)])

wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Sheet1"]
print("Calculated values C3:G14:")
for r in range(3, 15):
    print(r, [ws_vals.cell(r, c).value for c in range(3, 8)])

output_spreadsheet = outfile
