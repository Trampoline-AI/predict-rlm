Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

for r in range(3, 15):  # months Jan-Dec
    for c in range(3, 8):  # C:G
        col = get_column_letter(c)
        sumifs_expr = (
            f'SUMIFS({col}$17:{col}$24,'
            f'$B$17:$B$24,">="&$B{r},'
            f'$B$17:$B$24,"<"&DATE(YEAR($B{r}),MONTH($B{r})+1,1))'
        )
        ws.cell(r, c).value = f'=IF({sumifs_expr}=0,"",{sumifs_expr})'

wb.save(outfile)
print("Saved:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify a few formulas
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["Sheet1"]
print("Formula rows 3-5:")
for r in range(3, 6):
    print(r, [wsf.cell(r, c).value for c in range(3, 8)])

# Verify cached values
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]
print("Values C3:G14:")
for r in range(3, 15):
    print(r, [wsv.cell(r, c).value for c in range(3, 8)])

output_spreadsheet = outfile
```
