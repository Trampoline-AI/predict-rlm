from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook normally so formulas are preserved
wb = load_workbook(infile)
ws = wb["Sheet3"]

# Write the formula requested into B3
formula = "=INDEX(month,MATCH(MID(A3,6,2),codes2,0))"
ws["B3"] = formula

# Save output
wb.save(outfile)
print("Saved to:", outfile)
print("Written formula in B3:", ws["B3"].value)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(outfile, data_only=False)
wsf = wb_check_formula["Sheet3"]
