wb_check_values = load_workbook(outfile, data_only=True)
wsv = wb_check_values["Sheet3"]
print("Data-only check A3:", wsv["A3"].value)
print("Data-only check B3:", wsv["B3"].value)

output_spreadsheet = outfile
