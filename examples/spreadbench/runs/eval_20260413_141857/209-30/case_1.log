Next action:
1. Load the workbook.
2. Find the last used row in column C.
3. Replace each non-empty string in column C with `value[:-3]`.
4. Save to the output directory with the same filename.
5. Reopen and verify a few sample rows plus summary counts.
Code:
```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Data to Import"]

# Find last used row in column C
last_row = ws.max_row
while last_row > 1 and ws.cell(last_row, 3).value in (None, ""):
    last_row -= 1

changed = 0
unchanged = 0
too_short = 0
samples_before_after = []

for r in range(2, last_row + 1):
    cell = ws.cell(r, 3)
    val = cell.value
    if isinstance(val, str) and val != "":
        new_val = val[:-3] if len(val) >= 3 else ""
        if len(samples_before_after) < 10:
            samples_before_after.append((r, val, new_val))
        if new_val != val:
            cell.value = new_val
            changed += 1
        else:
            unchanged += 1
        if len(val) < 3:
            too_short += 1

wb.save(outfile)

# Verify by reopening
wb2 = load_workbook(outfile, data_only=False)
ws2 = wb2["Data to Import"]

verify_samples = []
for r in range(2, min(last_row, 12) + 1):
    verify_samples.append((r, ws2.cell(r, 3).value))

print("Output saved to:", outfile)
print("Last used row in column C:", last_row)
print("Changed cells:", changed)
print("Unchanged string cells:", unchanged)
print("Too short (<3 chars):", too_short)
print("Sample before/after:", samples_before_after[:10])
print("Verified rows 2-12 col C:", verify_samples)
```
