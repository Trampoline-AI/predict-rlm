from copy import copy
import os

# Inspect all rows fully
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 8)])

# Build expected joined text for each data row
headers = [str(ws.cell(1, c).value).strip() if ws.cell(1, c).value is not None else "" for c in range(1, 7)]
print("Headers used:", headers)

expected = {}
for r in range(2, ws.max_row + 1):
    parts = []
    for c in range(1, 7):
        val = ws.cell(r, c).value
        if isinstance(val, str) and val.strip().upper() == "Y":
            parts.append(headers[c-1])
    expected[r] = ", ".join(parts)

print("Expected G values:")
for r in range(2, ws.max_row + 1):
    print(r, "current=", ws.cell(r, 7).value, "| expected=", expected[r])

# Fill/fix all G cells and copy formatting pattern from an existing data cell in G if available
for r in range(2, ws.max_row + 1):
    ws.cell(r, 7).value = expected[r]

# Keep formatting in G consistent with existing column G data cells / row style
# Copy style from G2 to all G data cells
source_style_cell = ws["G2"]
for r in range(2, ws.max_row + 1):
    target = ws.cell(r, 7)
    target.font = copy(source_style_cell.font)
    target.fill = copy(source_style_cell.fill)
    target.border = copy(source_style_cell.border)
    target.alignment = copy(source_style_cell.alignment)
    target.number_format = source_style_cell.number_format
    target.protection = copy(source_style_cell.protection)

# Save output
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Verify by reopening
wb_check = load_workbook(out_path)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification:")
for r in range(1, ws_check.max_row + 1):
    print(r, [ws_check.cell(r, c).value for c in range(1, 8)])
```
