from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_path)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Inspect non-empty counts and a few matching examples
nonempty_B = sum(1 for r in range(2, ws1.max_row + 1) if ws1.cell(r, 2).value not in (None, ""))
nonempty_C = sum(1 for r in range(2, ws1.max_row + 1) if ws1.cell(r, 3).value not in (None, ""))
print("Sheet1 non-empty counts:", {"B": nonempty_B, "C": nonempty_C})

# Show first few products and whether they exist on Sheet2
sheet2_products = {ws2.cell(r, 1).value: ws2.cell(r, 2).value for r in range(2, ws2.max_row + 1)}
for r in range(2, 12):
    prod = ws1.cell(r, 1).value
    print(r, prod, "Need=", ws1.cell(r,2).value, "SoldMatch=", sheet2_products.get(prod))

# If column C is empty, use it to preserve existing "Need" data.
target_col = 3
header = "Sold"
ws1.cell(1, target_col).value = header

for r in range(2, ws1.max_row + 1):
    # Return empty string when no match or blank product
    ws1.cell(r, target_col).value = f'=IF(A{r}="","",IFERROR(VLOOKUP(A{r},Sheet2!$A$2:$B$6,2,FALSE),""))'

wb.save(output_path)
print("Saved to", output_path)
print("Header row after edit:", [ws1.cell(1,c).value for c in range(1, ws1.max_column+1)])
```
