```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Replace month-over-month headcount formulas in E2:P2
# Logic:
# - Hire date must be on or before the month in row 1
# - Term date must be blank or greater than the month in row 1
for col in range(5, 17):  # E:P
    col_letter = get_column_letter(col)
    ws[f"{col_letter}2"] = (
        f'=SUMPRODUCT(--($A$2:$A$22<={col_letter}$1),'
        f'--((($B$2:$B$22="")+($B$2:$B$22>{col_letter}$1))>0))'
    )

wb.save(output_path)
print("Saved:", output_path)

# Recalculate formulas and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("Updated formulas E2:P2:")
for col in range(5, 17):
    col_letter = get_column_letter(col)
    print(col_letter, ws_check[f"{col_letter}2"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Calculated values E2:P2:")
vals = {}
for col in range(5, 17):
    col_letter = get_column_letter(col)
    vals[f"{col_letter}2"] = ws_values[f"{col_letter}2"].value
print(vals)

output_spreadsheet = output_path
```
