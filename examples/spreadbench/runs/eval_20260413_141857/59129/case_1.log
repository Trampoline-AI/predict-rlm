import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Rebuild output cleanly from original input
wb = load_workbook(input_path)
ws = wb["Sheet1"]

new_formulas = {}
for col in range(5, 17):  # E:P
    col_letter = get_column_letter(col)
    formula = f'=SUMPRODUCT(($A$2:$A$22<={col_letter}$1)*(($B$2:$B$22="")+($B$2:$B$22>={col_letter}$1)))'
    ws[f"{col_letter}2"] = formula
    new_formulas[f"{col_letter}2"] = formula

wb.save(output_path)
print("Saved clean workbook:", output_path)

# Verify formulas immediately after save (before recalc)
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("Formulas after save:")
for cell in ["E2","F2","G2","P2"]:
    print(cell, ws_formula[cell].value)

# Optionally inspect existing termination count row references as context
for cell in ["E3","F3","E5","F5"]:
    print(cell, ws_formula[cell].value)

# Calculate expected row-2 values in Python for verification
# month date in row 1, hire dates in A2:A22, term dates in B2:B22
py_vals = {}
for col in range(5, 17):
    month_dt = ws_formula.cell(1, col).value
    count = 0
    for r in range(2, 23):
        hire = ws_formula.cell(r, 1).value
        term = ws_formula.cell(r, 2).value
        if hire is not None and hire <= month_dt and (term is None or term >= month_dt):
            count += 1
    py_vals[f"{get_column_letter(col)}2"] = count
print("Expected Python counts E2:P2:", py_vals)

output_spreadsheet = output_path
```
