```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook for editing
wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

start_row = 2
end_row = ws.max_row

# Ensure D1 has no header/value
ws["D1"] = None

# Write formulas in column D using MAX (not MAXIFS)
for r in range(start_row, end_row + 1):
    formula = f'=IF(B{r}=MAX(IF($A${start_row}:$A${end_row}=A{r},$B${start_row}:$B${end_row})),B{r},"")'
    ws.cell(r, 4).value = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas and verify
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Sample formulas in D:")
for r in range(2, min(end_row, 8) + 1):
    print(r, check_ws.cell(r, 4).value)

check_vals_wb = load_workbook(outfile, data_only=True)
check_vals_ws = check_vals_wb[check_vals_wb.sheetnames[0]]
print("Cached values A-D:")
for r in range(1, end_row + 1):
    vals = [check_vals_ws.cell(r, c).value for c in range(1, 5)]
    print(r, vals)
