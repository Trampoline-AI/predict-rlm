```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws = wb["sheet1"]

# 1) Read source rows from A:C, skipping blanks and repeated headers
source_rows = []
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value

    if a in (None, "") and b in (None, "") and c in (None, ""):
        continue

    a_str = str(a).strip().upper() if a is not None else ""
    b_str = str(b).strip().upper() if b is not None else ""
    c_str = str(c).strip().upper() if c is not None else ""
    if a_str == "ITEM" and b_str == "NAME" and c_str == "REF":
        continue

    if b in (None, "") or c in (None, ""):
        continue

    source_rows.append((r, a, b, c))

# 2) Deduplicate by (B, C), preserving first occurrence
seen = set()
deduped = []
for row in source_rows:
    _, a, b, c = row
    key = (b, c)
    if key in seen:
        continue
    seen.add(key)
    deduped.append(row)

# 3) Read helper names from J, skipping header/blanks/duplicates
helper_names = []
helper_seen = set()
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 10).value
    if v in (None, ""):
        continue
    s = str(v).strip()
    if not s or s.upper() == "LIST":
        continue
    if s in helper_seen:
        continue
    helper_seen.add(s)
    helper_names.append(s)

# 4) Build final ordered rows
ordered = []
used = set()

if helper_names:
    for helper_name in helper_names:
        for row in deduped:
            _, a, b, c = row
            key = (b, c)
            if b == helper_name and key not in used:
                ordered.append(row)
                used.add(key)

    for row in deduped:
        _, a, b, c = row
        key = (b, c)
        if key not in used:
            ordered.append(row)
            used.add(key)
else:
    ordered = sorted(deduped, key=lambda x: str(x[2]).strip().upper())

# 5) Clear old output area in F:H below header
for r in range(2, ws.max_row + 1):
    for col in range(6, 9):
        ws.cell(r, col).value = None

# Ensure header remains as template indicates
ws["F1"] = "ITEM"
ws["G1"] = "NAME"
ws["H1"] = "REF"

# 6) Write output to F:H
out_row = 2
for idx, (_, a, b, c) in enumerate(ordered, start=1):
    ws.cell(out_row, 6).value = idx
    ws.cell(out_row, 7).value = b
    ws.cell(out_row, 8).value = c
    out_row += 1

wb.save(output_path)

# 7) Verify
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb["sheet1"]

preview = []
for r in range(1, min(out_row + 2, check_ws.max_row) + 1):
    preview.append((r, check_ws.cell(r, 6).value, check_ws.cell(r, 7).value, check_ws.cell(r, 8).value))

print("Saved to:", output_path)
print("Helper names:", helper_names)
print("Output row count:", len(ordered))
print("Preview F:H:")
for row in preview[:20]:
    print(row)

output_spreadsheet = output_path
```
