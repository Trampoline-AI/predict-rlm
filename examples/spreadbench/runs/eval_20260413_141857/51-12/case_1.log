from pathlib import Path
import os

# Load workbook
infile = Path(input_spreadsheet)
outfile = Path("/sandbox/output/output_spreadsheet") / infile.name

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Compute the count using the described logic across row 1
