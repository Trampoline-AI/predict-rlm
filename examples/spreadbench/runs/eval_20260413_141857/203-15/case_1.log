    }
    return mapping.get(d, None)

staff_rows = OrderedDict()
skipped_blank = 0

for r in range(2, main.max_row + 1):
    base = tuple(main.cell(r, c).value for c in range(1, 8))  # A:G
    if all(v is None or str(v).strip() == "" for v in base):
        skipped_blank += 1
