wb = load_workbook(input_spreadsheet)
main = wb["Main"]

# Inspect tail rows to confirm blank/trailing row behavior
for r in range(max(2, main.max_row - 5), main.max_row + 1):
    print("Main row", r, [main.cell(r, c).value for c in range(1, 11)])

allowance_headers = [
    "Basic",
    "Housing Allowance",
    "Transport Allowance",
    "Other Allowance",
    "Social Allowance",
]

def normalize_desc(desc):
    if desc is None:
        return None
    d = str(desc).strip().lower()
    mapping = {
        "basic": "Basic",
        "housing allowance": "Housing Allowance",
