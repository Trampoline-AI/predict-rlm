    idx = wb.sheetnames.index("Output Required")
    del wb["Output Required"]
    out = wb.create_sheet("Output Required", idx)
else:
    out = wb.create_sheet("Output Required")

# Write headers
for c in range(1, 8):
    out.cell(1, c).value = main.cell(1, c).value
for i, h in enumerate(allowance_headers, start=8):
    out.cell(1, i).value = h
out.cell(1, 13).value = "Total"

