import os, shutil
from collections import OrderedDict
from openpyxl import load_workbook

# Re-open fresh workbook
wb = load_workbook(input_spreadsheet)
main = wb["Main"]

# Inspect distinct descriptions and row data summary
descriptions = []
for r in range(2, main.max_row + 1):
    descriptions.append(main.cell(r, 8).value)
print("Distinct descriptions:", sorted(set(descriptions)))

# Build normalized pivot data by staff no. (assuming one row-group per staff)
allowance_headers = [
    "Basic",
    "Housing Allowance",
    "Transport Allowance",
    "Other Allowance",
    "Social Allowance",
]

def normalize_desc(desc):
    if desc is None:
        return None
    d = str(desc).strip().lower()
    mapping = {
        "basic": "Basic",
        "housing allowance": "Housing Allowance",
        "housing allowances": "Housing Allowance",
        "transport allowance": "Transport Allowance",
        "transport allowances": "Transport Allowance",
        "other allowance": "Other Allowance",
        "other allowances": "Other Allowance",
        "social allowance": "Social Allowance",
        "social allowances": "Social Allowance",
    }
    return mapping.get(d, str(desc).strip())

staff_rows = OrderedDict()

for r in range(2, main.max_row + 1):
    base = [main.cell(r, c).value for c in range(1, 8)]  # A:G
    desc = normalize_desc(main.cell(r, 8).value)         # H
    amount = main.cell(r, 9).value                       # I
    # currency = main.cell(r, 10).value                  # J, not requested in final layout
    
    staff_key = tuple(base)  # robust grouping by full identity across A:G
    if staff_key not in staff_rows:
        staff_rows[staff_key] = {h: 0 for h in allowance_headers}
    if desc in staff_rows[staff_key]:
        staff_rows[staff_key][desc] = amount if amount is not None else 0

print("Grouped staff count:", len(staff_rows))
print("First grouped item:", list(staff_rows.items())[:1])

# Remove existing Output Required and recreate it cleanly
if "Output Required" in wb.sheetnames:
    idx = wb.sheetnames.index("Output Required")
    del wb["Output Required"]
    out = wb.create_sheet("Output Required", idx)
else:
    out = wb.create_sheet("Output Required")

# Write headers
for c in range(1, 8):
    out.cell(1, c).value = main.cell(1, c).value
for i, h in enumerate(allowance_headers, start=8):
    out.cell(1, i).value = h
out.cell(1, 13).value = "Total"

# Write data rows
out_row = 2
for base_key, allowances in staff_rows.items():
    for c, val in enumerate(base_key, start=1):
        out.cell(out_row, c).value = val
    total = 0
    for i, h in enumerate(allowance_headers, start=8):
        val = allowances.get(h, 0)
        out.cell(out_row, i).value = val
        if isinstance(val, (int, float)):
            total += val
        elif val is None:
            total += 0
    out.cell(out_row, 13).value = total
    out_row += 1

# Save to output path with same filename
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)

# Verify saved workbook contents
check_wb = load_workbook(output_path, data_only=True)
check = check_wb["Output Required"]
print("Saved to:", output_path)
print("Output sheet size:", check.max_row, check.max_column)
for r in range(1, check.max_row + 1):
    vals = [check.cell(r, c).value for c in range(1, 14)]
    print(f"out row {r}:", vals)
```
