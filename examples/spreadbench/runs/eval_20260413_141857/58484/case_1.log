```repl
from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment, Border, Side
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

thin = Side(style="thin", color="000000")
header_border = Border(bottom=thin)
no_border = Border()

# Enforce row 4 wrap text
for c in range(1, ws.max_column + 1):
    cell = ws.cell(4, c)
    cell.alignment = Alignment(
        horizontal=cell.alignment.horizontal,
        vertical=cell.alignment.vertical,
        text_rotation=cell.alignment.textRotation if cell.alignment else 0,
        wrap_text=True,
        shrink_to_fit=cell.alignment.shrinkToFit if cell.alignment else None,
        indent=cell.alignment.indent if cell.alignment else 0,
    )

# Enforce header formatting on actual header cells, but not G4
for coord in ["D4", "E4", "F4", "H4"]:
    cell = ws[coord]
    cell.font = Font(
        name=cell.font.name,
        size=cell.font.sz,
        bold=True,
        italic=cell.font.italic,
        vertAlign=cell.font.vertAlign,
        underline=cell.font.underline,
        strike=cell.font.strike,
        color=cell.font.color.type == "rgb" and cell.font.color.rgb or None if cell.font.color else None,
    )
    cell.border = header_border

# Ensure column G has no values and no borders
for r in range(1, ws.max_row + 1):
    g = ws.cell(r, 7)
    g.value = None
    g.border = no_border

# Insert formula in H5:Hmax_row
# Logic:
# - if current row is not a transfer row (D<>5551234): blank
# - if next row is also a transfer row: blank
# - else count consecutive transfer rows from last non-transfer row + 1 to current row
for r in range(5, ws.max_row + 1):
    next_r = r + 1
    if r < ws.max_row:
        next_ref = f"D{next_r}"
        end_check = f"{next_ref}<>5551234"
    else:
        end_check = "TRUE"
    formula = (
        f'=IF(D{r}<>5551234,"",'
        f'IF({end_check},COUNTIF(INDEX($D$5:D{r},MATCH(1,INDEX(($D$5:D{r}<>5551234)*1,0),0)):D{r},5551234),""))'
    )
    ws[f"H{r}"] = formula

# Save before recalculation
wb.save(outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Verify output
wb2 = load_workbook(outfile, data_only=False)
ws2 = wb2["Sheet1"]
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]

print("Saved to:", outfile)
print("Column G check:", all(ws2.cell(r, 7).value is None for r in range(1, ws2.max_row + 1)))
print("Header checks:")
for coord in ["D4", "E4", "F4", "H4", "G4"]:
    c = ws2[coord]
    print(coord, c.value, c.font.bold, c.border.bottom.style, c.alignment.wrap_text)

print("H formulas and cached values:")
for r in range(5, ws2.max_row + 1):
    print(r, ws2[f"H{r}"].value, "=>", wsv[f"H{r}"].value)
