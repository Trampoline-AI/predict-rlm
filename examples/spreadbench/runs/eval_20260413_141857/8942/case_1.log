from openpyxl import load_workbook
import os

out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

# Re-open output workbook and patch B2/C2 so month text in A2 doesn't create hard errors.
wb = load_workbook(out_path)
ws = wb["Overview"]
pay = wb["Pay Dates"]

last_row = pay.max_row

# Keep month dropdown + B5 monthly total; guard old exact-date formulas.
ws["B2"] = '=IFERROR(INDEX(\'Pay Dates\'!$B:$B,MATCH(Overview!$A2,\'Pay Dates\'!$A:$A,0)),"")'
ws["C2"] = '=IFERROR(INDEX(\'Pay Dates\'!$C:$C,MATCH(Overview!$A2,\'Pay Dates\'!$A:$A,0)),"")'

# Ensure B5 formula is present
ws["B5"] = (
    f'=SUMPRODUCT((MONTH(\'Pay Dates\'!$A$2:$A${last_row})='
    f'MATCH($A$2,$F$1:$F$12,0))*('
    f'\'Pay Dates\'!$B$2:$B${last_row}+\'Pay Dates\'!$C$2:$C${last_row}))'
)

wb.save(out_path)
print("Patched and saved:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_formula = load_workbook(out_path, data_only=False)
wb_values = load_workbook(out_path, data_only=True)
wsf = wb_formula["Overview"]
wsv = wb_values["Overview"]

print("A2:", wsf["A2"].value)
print("B2 formula:", wsf["B2"].value)
print("C2 formula:", wsf["C2"].value)
print("B5 formula:", wsf["B5"].value)
print("B5 cached value:", wsv["B5"].value)

# Compute expected January total directly in Python for verification
months = ["January","February","March","April","May","June","July","August","September","October","November","December"]
selected_month = wsf["A2"].value
month_num = months.index(selected_month) + 1
expected = 0
for r in range(2, pay.max_row + 1):
    d = pay.cell(r, 1).value
    if d and hasattr(d, "month") and d.month == month_num:
        expected += (pay.cell(r, 2).value or 0) + (pay.cell(r, 3).value or 0)
print("Expected total for", selected_month, "=", expected)
