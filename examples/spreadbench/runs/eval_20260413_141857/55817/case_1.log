```repl
import os
from openpyxl import load_workbook

# Load source workbook
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Read non-empty source data from column A starting at row 2
source_vals = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None:
        source_vals.append(v)

# Group into blocks of 7 and write starting at B2
blocks = [source_vals[i:i+7] for i in range(0, len(source_vals), 7)]
print("Total source values:", len(source_vals))
print("Total blocks:", len(blocks))
print("Block lengths:", [len(b) for b in blocks])

start_row = 2
start_col = 2  # column B

for i, block in enumerate(blocks):
    row = start_row + i
    for j, value in enumerate(block):
        ws.cell(row=row, column=start_col + j).value = value

# Save output
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Verify by reopening and printing target area
check_wb = load_workbook(outfile)
check_ws = check_wb["Sheet1"]
print("\nVerified B1:H6")
for r in range(1, 7):
    print(r, [check_ws.cell(r, c).value for c in range(2, 9)])

output_spreadsheet = outfile
```
