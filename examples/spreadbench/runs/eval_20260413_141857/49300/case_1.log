from openpyxl import load_workbook
from pathlib import Path
import os

# Re-open fresh workbook for editing
wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]
wsd = wb["Data"]

# Inspect full month headers and row labels relevant to the lookup table
headers = [wsd.cell(row=2, column=c).value for c in range(1, wsd.max_column + 1)]
row_labels = [wsd.cell(row=r, column=2).value for r in range(1, wsd.max_row + 1)]
print("Data row 2 headers (first 20 cols):", headers[:20])
print("Data sheet row labels in col B:", row_labels)

# Build lookup maps from Data sheet
col_map = {}  # month -> column index
for c in range(3, wsd.max_column + 1):
    key = wsd.cell(row=2, column=c).value
    if key is not None:
        col_map[key] = c

row_map = {}  # job title -> row index
for r in range(3, wsd.max_row + 1):
    key = wsd.cell(row=r, column=2).value
    if key is not None:
        row_map[key] = r

print("Row map:", row_map)
print("Sample col map:", {k: col_map[k] for k in list(col_map)[:15]})

# Fill Sheet1 column C with numeric values
filled = []
for r in range(2, ws1.max_row + 1):
    job = ws1.cell(row=r, column=1).value
    month = ws1.cell(row=r, column=2).value
    data_row = row_map.get(job)
    data_col = col_map.get(month)
    value = None
    if data_row is not None and data_col is not None:
        value = wsd.cell(row=data_row, column=data_col).value
    ws1.cell(row=r, column=3).value = value
    filled.append((r, job, month, value))

print("Filled values:", filled)

# Save to output path with same filename
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_spreadsheet).name
wb.save(output_path)

# Verify by reopening
verify_wb = load_workbook(output_path, data_only=True)
verify_ws1 = verify_wb["Sheet1"]
verified = [verify_ws1.cell(row=r, column=3).value for r in range(2, verify_ws1.max_row + 1)]
print("Verified Sheet1!C values:", verified)
print("Output path:", str(output_path))
```
