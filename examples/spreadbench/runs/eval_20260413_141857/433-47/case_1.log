```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

unit_cols = list(range(2, 7))  # B:F
residual_col = 9               # I
data_rows = range(2, 19)       # 2:18 inclusive
min_row = 20
max_row = 21

mins = {c: ws.cell(min_row, c).value for c in unit_cols}
maxs = {c: ws.cell(max_row, c).value for c in unit_cols}

original_rows = {}
for r in data_rows:
    original_rows[r] = {
        "units": [ws.cell(r, c).value for c in unit_cols],
        "residual": ws.cell(r, residual_col).value,
    }

# Apply row-by-row balancing
for r in data_rows:
    residual = ws.cell(r, residual_col).value
    if residual is None:
        continue

    # Positive residual: add left to right, respecting max; don't alter zeros
    if residual > 0:
        remaining = residual
        for c in unit_cols:
            val = ws.cell(r, c).value
            if val in (None, 0):
                continue
            max_val = maxs[c]
            if max_val is None:
                continue
            room = max_val - val
            if room <= 0:
                continue
            delta = min(remaining, room)
            ws.cell(r, c).value = val + delta
            remaining -= delta
            if remaining == 0:
                break

    # Negative residual: subtract right to left, respecting min; don't alter zeros
    elif residual < 0:
        remaining = -residual
        for c in reversed(unit_cols):
            val = ws.cell(r, c).value
            if val in (None, 0):
                continue
            min_val = mins[c]
            if min_val is None:
                continue
            room = val - min_val
            if room <= 0:
                continue
            delta = min(remaining, room)
            ws.cell(r, c).value = val - delta
            remaining -= delta
            if remaining == 0:
                break

    # Set residual to 0 at the end
    ws.cell(r, residual_col).value = 0

wb.save(output_path)

# Verify by reloading
check_wb = load_workbook(output_path)
check_ws = check_wb[check_wb.sheetnames[0]]

verification = []
all_ok = True

for r in data_rows:
    orig_units = original_rows[r]["units"]
    orig_res = original_rows[r]["residual"]
    new_units = [check_ws.cell(r, c).value for c in unit_cols]
    new_res = check_ws.cell(r, residual_col).value

    # Check residual cleared
    residual_ok = (new_res == 0)

    # Check unit bounds and unchanged zeros
    bounds_ok = True
    zero_ok = True
    for idx, c in enumerate(unit_cols):
        val = new_units[idx]
        orig = orig_units[idx]
        mn = mins[c]
        mx = maxs[c]
        if val is not None and mn is not None and mx is not None:
            # Existing data includes one start value above max in unit4; do not fail if unchanged/addition avoided.
            if orig == 0 and val != 0:
                zero_ok = False
            # changed cells should not violate constraints in direction of operation
            if val != orig:
                if val < mn or val > mx:
                    bounds_ok = False

    row_ok = residual_ok and bounds_ok and zero_ok
    all_ok = all_ok and row_ok
    verification.append((r, orig_res, orig_units, new_units, new_res, row_ok))

print("Output saved:", output_path)
print("All verification checks passed:", all_ok)
for item in verification:
    print(item)
```
