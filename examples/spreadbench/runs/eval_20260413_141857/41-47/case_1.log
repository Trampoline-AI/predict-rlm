from openpyxl import load_workbook
from pathlib import Path
from collections import defaultdict
import re
import shutil

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook
wb = load_workbook(input_path)
out_ws = wb["OUT CAS"]

# Detect blocks dynamically from OUT CAS header row
blocks = []
c = 1
while c <= out_ws.max_column:
    if out_ws.cell(1, c).value == "ITEM" and c + 2 <= out_ws.max_column:
        acct = out_ws.cell(1, c + 1).value
        amt_header = out_ws.cell(1, c + 2).value
        if acct and amt_header == "AMOUNT":
            blocks.append({
                "start_col": c,
                "item_col": c,
                "ref_col": c + 1,
                "amt_col": c + 2,
                "account_type": str(acct),
            })
            c += 4
            continue
    c += 1

account_types = [b["account_type"] for b in blocks]
print("Detected blocks/account types:", account_types)

# Sort key based on trailing numeric code; handles EX009 etc.
def sort_key(ref):
    s = str(ref or "").strip()
    m = re.search(r'([A-Za-z]*)(\d+)\s*$', s)
    if m:
        prefix, num = m.groups()
        return (0, int(num), s)
    m2 = re.search(r'(\d+)', s)
    if m2:
        return (1, int(m2.group(1)), s)
    return (2, s)

# Aggregate rows from every source sheet except OUT CAS
bucket_items = defaultdict(list)

for ws in wb.worksheets:
    if ws.title == "OUT CAS":
        continue
    for r in range(2, ws.max_row + 1):
        ref = ws.cell(r, 2).value
        if ref in (None, ""):
            continue
        ref = str(ref).strip()
        debit = ws.cell(r, 3).value
        credit = ws.cell(r, 4).value
        amt = credit if credit not in (None, "") else debit
        if amt in (None, ""):
            continue

        matched = False
        for acct in account_types:
            if ref.startswith(acct):
                bucket_items[acct].append((ref, amt))
                matched = True
                break
        if not matched:
            # ignore unrecognized rows; instruction says use OUT CAS headers as buckets
            pass

# Sort bucket contents
for acct in account_types:
    bucket_items[acct] = sorted(bucket_items[acct], key=lambda x: sort_key(x[0]))

# Clear existing OUT CAS data rows, leaving headers intact
for row in range(2, out_ws.max_row + 1):
    for col in range(1, out_ws.max_column + 1):
        out_ws.cell(row, col).value = None

# Repopulate each block
for block in blocks:
    acct = block["account_type"]
    item_col = block["item_col"]
    ref_col = block["ref_col"]
    amt_col = block["amt_col"]
    items = bucket_items.get(acct, [])

    # data rows
    for idx, (ref, amt) in enumerate(items, start=1):
        row = idx + 1
        out_ws.cell(row, item_col).value = idx
        out_ws.cell(row, ref_col).value = ref
        out_ws.cell(row, amt_col).value = amt
        out_ws.cell(row, amt_col).number_format = "#,##0.00"

    # total row
    total_row = len(items) + 2
    out_ws.cell(total_row, item_col).value = "TOTAL"
    if items:
        col_letter = out_ws.cell(1, amt_col).column_letter
        out_ws.cell(total_row, amt_col).value = f"=SUM({col_letter}2:{col_letter}{len(items)+1})"
        out_ws.cell(total_row, amt_col).number_format = "#,##0.00"
    else:
        out_ws.cell(total_row, amt_col).value = 0
        out_ws.cell(total_row, amt_col).number_format = "#,##0.00"

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas and verify
recalc_result = await recalculate(str(output_path))
print("Recalculate:", recalc_result)

verify_wb = load_workbook(output_path, data_only=False)
verify_ws = verify_wb["OUT CAS"]

print("\nVerification summary:")
for block in blocks:
    acct = block["account_type"]
    item_col = block["item_col"]
    ref_col = block["ref_col"]
    amt_col = block["amt_col"]
    items = bucket_items.get(acct, [])
    total_row = len(items) + 2
    sample_first = [(verify_ws.cell(r, ref_col).value, verify_ws.cell(r, amt_col).value) for r in range(2, min(len(items)+2, 7))]
    print({
        "account_type": acct,
        "count": len(items),
        "total_row": total_row,
        "total_label": verify_ws.cell(total_row, item_col).value,
        "total_formula": verify_ws.cell(total_row, amt_col).value,
        "first_rows": sample_first,
    })

output_spreadsheet = str(output_path)
print("\nPrepared output_spreadsheet:", output_spreadsheet)
