from openpyxl.utils import get_column_letter

for ws in wb.worksheets:
    print(f"\n=== Deep inspection: {ws.title} ===")
    print("Auto filter:", ws.auto_filter.ref)
    print("Tables:", list(ws.tables.keys()) if hasattr(ws, "tables") else [])
    
    # Non-empty cells
    nonempty = []
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                nonempty.append((cell.coordinate, cell.value, cell.data_type, cell.number_format, cell.style_id))
    print("Non-empty cell count:", len(nonempty))
    print("First 30 non-empty:", nonempty[:30])
    
    # Comments / hyperlinks
    comments = []
    links = []
    for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=max(ws.max_column, 8)):
        for cell in row:
            if cell.comment:
                comments.append((cell.coordinate, cell.comment.text))
            if cell.hyperlink:
                links.append((cell.coordinate, cell.hyperlink.target))
    print("Comments:", comments if comments else "None")
    print("Hyperlinks:", links if links else "None")
    
    # Hidden rows/cols used area-ish
    hidden_rows = [r for r in range(1, ws.max_row + 1) if ws.row_dimensions[r].hidden]
    hidden_cols = [get_column_letter(c) for c in range(1, 15) if ws.column_dimensions[get_column_letter(c)].hidden]
    print("Hidden rows:", hidden_rows if hidden_rows else "None")
    print("Hidden cols A:N:", hidden_cols if hidden_cols else "None")
    
    # Show row 1-5, cols A:H with coordinates
    for r in range(1, min(6, ws.max_row + 1)):
        vals = []
