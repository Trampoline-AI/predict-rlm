```repl
import os
from copy import copy
from openpyxl import load_workbook

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Determine lookup range on Sheet2 based on existing data in col A
last_row_sheet2 = ws2.max_row
last_row_sheet1 = ws1.max_row

# Add headers on Sheet1 for the two returned fields
ws1["E1"] = "Sheet2 Column B"
ws1["F1"] = "Sheet2 Column C"

# Copy header style from D1 if present
for target in ["E1", "F1"]:
    ws1[target]._style = copy(ws1["D1"]._style)
    ws1[target].font = copy(ws1["D1"].font)
    ws1[target].fill = copy(ws1["D1"].fill)
    ws1[target].border = copy(ws1["D1"].border)
    ws1[target].alignment = copy(ws1["D1"].alignment)
    ws1[target].number_format = ws1["D1"].number_format
    ws1[target].protection = copy(ws1["D1"].protection)

# Fill formulas down
for r in range(2, last_row_sheet1 + 1):
    # Return Sheet2 column B
    ws1.cell(r, 5).value = f'=IFERROR(INDEX(Sheet2!$B$2:$B${last_row_sheet2},MATCH($D{r},Sheet2!$A$2:$A${last_row_sheet2},0)),"")'
    # Return Sheet2 column C
    ws1.cell(r, 6).value = f'=IFERROR(INDEX(Sheet2!$C$2:$C${last_row_sheet2},MATCH($D{r},Sheet2!$A$2:$A${last_row_sheet2},0)),"")'
    
    # Copy data style from D column cells to keep workbook appearance consistent
    for c in [5, 6]:
        ws1.cell(r, c)._style = copy(ws1.cell(r, 4)._style)
        ws1.cell(r, c).font = copy(ws1.cell(r, 4).font)
        ws1.cell(r, c).fill = copy(ws1.cell(r, 4).fill)
        ws1.cell(r, c).border = copy(ws1.cell(r, 4).border)
        ws1.cell(r, c).alignment = copy(ws1.cell(r, 4).alignment)
        ws1.cell(r, c).number_format = ws1.cell(r, 4).number_format
        ws1.cell(r, c).protection = copy(ws1.cell(r, 4).protection)

# Adjust widths a bit
ws1.column_dimensions["E"].width = 18
ws1.column_dimensions["F"].width = 18

# Save output
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)

# Verify by reopening normally and checking formulas
check_wb = load_workbook(output_path, data_only=False)
check_ws1 = check_wb["Sheet1"]

print("Saved to:", output_path)
print("Headers:", check_ws1["E1"].value, "|", check_ws1["F1"].value)
for r in range(2, min(7, check_ws1.max_row + 1)):
    print(r, check_ws1.cell(r, 4).value, "=>", check_ws1.cell(r, 5).value, "|", check_ws1.cell(r, 6).value)

final_output_path = output_path
```
