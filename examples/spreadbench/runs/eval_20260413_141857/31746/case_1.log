from openpyxl import load_workbook
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Month columns D:P with their contract-duration multipliers for 81 months total
multipliers = {
    4: 70,  # D Month 12
    5: 69,  # E Month 13
    6: 64,  # F Month 18
    7: 61,  # G Month 21
    8: 58,  # H Month 24
    9: 57,  # I Month 25
    10: 52, # J Month 30
    11: 46, # K Month 36
    12: 45, # L Month 37
    13: 34, # M Month 48
    14: 22, # N Month 60
    15: 10, # O Month 72
    16: 4,  # P Month 78
}

# Use row 3's Q style as template for detail rows
template_q = ws["Q3"]
total_template_q = ws["Q38"]

# Fill Q3:Q37
for r in range(3, 38):
    parts = [f"({ws.cell(r, c).coordinate}*{mult})" for c, mult in multipliers.items()]
    ws.cell(r, 17).value = "=" + "+".join(parts)

    # preserve/standardize formatting
    ws.cell(r, 17).number_format = template_q.number_format
    ws.cell(r, 17).fill = copy(template_q.fill)
    ws.cell(r, 17).border = copy(template_q.border)
    ws.cell(r, 17).alignment = copy(template_q.alignment)
    ws.cell(r, 17).protection = copy(template_q.protection)
    ws.cell(r, 17).font = copy(template_q.font)
    ws.cell(r, 17).font = copy(ws.cell(r, 17).font)
    ws.cell(r, 17).font = ws.cell(r, 17).font.copy(bold=False)

# Grand total in Q38
ws["Q38"] = "=SUM(Q3:Q37)"
ws["Q38"].number_format = total_template_q.number_format
ws["Q38"].fill = copy(total_template_q.fill)
ws["Q38"].border = copy(total_template_q.border)
ws["Q38"].alignment = copy(total_template_q.alignment)
ws["Q38"].protection = copy(total_template_q.protection)
ws["Q38"].font = copy(total_template_q.font)
ws["Q38"].font = ws["Q38"].font.copy(bold=False)

wb.save(outfile)
print("Saved:", outfile)

# Recalculate to cache formula values
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify output
wb2 = load_workbook(outfile, data_only=False)
ws2 = wb2["Sheet1"]
print("Q35 formula:", ws2["Q35"].value)
print("Q36 formula:", ws2["Q36"].value)
print("Q37 formula:", ws2["Q37"].value)
print("Q38 formula:", ws2["Q38"].value)
print("Bold flags Q35-Q38:", [ws2[f'Q{i}'].font.bold for i in range(35, 39)])

wb3 = load_workbook(outfile, data_only=True)
ws3 = wb3["Sheet1"]
print("Cached values Q35:Q38:", [ws3[f"Q{i}"].value for i in range(35, 39)])

output_spreadsheet = outfile
```
