Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Update column J formulas and formatting to show only time from datetime in column I
for r in range(2, ws.max_row + 1):
    source = ws.cell(r, 9).value  # column I
    target = ws.cell(r, 10)       # column J
    if source is not None:
        target.value = f"=MOD(I{r},1)"
        target.number_format = "hh:mm:ss AM/PM"

wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]
wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals[wb_vals.sheetnames[0]]

for r in range(1, ws_check.max_row + 1):
    print(
        r,
        "I=", ws_check.cell(r, 9).value,
        "J_formula=", ws_check.cell(r, 10).value,
        "J_format=", ws_check.cell(r, 10).number_format,
        "J_value=", ws_vals.cell(r, 10).value,
    )

output_spreadsheet = outfile
```
