Code:
```repl
import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Build and write formulas into Sheet2 column D
for r in range(3, ws2.max_row + 1):
    ws2.cell(r, 4).value = (
        f'=INDEX(Sheet1!$L$3:$R$53,'
        f'MATCH(A{r},Sheet1!$B$3:$B$53,0),'
        f'MATCH(B{r},Sheet1!$L$1:$R$1,0))'
    )

# Save output with same filename
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Verify by reopening with cached values
wb_check = load_workbook(output_path, data_only=False)
wb_vals = load_workbook(output_path, data_only=True)
ws2f = wb_check["Sheet2"]
ws2v = wb_vals["Sheet2"]

print("Header row Sheet2:", [ws2f.cell(2, c).value for c in range(1, 5)])

# Show formulas and calculated values for sample rows
sample_rows = [3, 4, 10, 53, 54, 55, 104]
for r in sample_rows:
    print(
        "Row", r,
        "state/year=", ws2f.cell(r,1).value, ws2f.cell(r,2).value,
        "formula=", ws2f.cell(r,4).value,
        "value=", ws2v.cell(r,4).value
    )

# Cross-check against source values for a few rows
def expected_value(state, year):
    # find source row
    source_row = None
    for rr in range(3, ws1.max_row + 1):
        if ws1.cell(rr, 2).value == state:
            source_row = rr
            break
    source_col = None
    for cc in range(12, 19):
        if ws1.cell(1, cc).value == year:
            source_col = cc
            break
    if source_row and source_col:
        return ws1.cell(source_row, source_col).value
    return None

for r in [3, 4, 54, 55]:
    st = ws2f.cell(r, 1).value
    yr = ws2f.cell(r, 2).value
    print("Check", r, "expected:", expected_value(st, yr), "got:", ws2v.cell(r, 4).value)

final_output_path = output_path
```
