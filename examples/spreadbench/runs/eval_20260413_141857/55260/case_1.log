Code:
```repl
import os
from openpyxl import load_workbook
from copy import copy

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Inspect styles/number formats for row 1-2, cols A-C
for r in range(1, 3):
    row_info = []
    for c in range(1, 4):
        cell = ws.cell(r, c)
        row_info.append({
            "coord": cell.coordinate,
            "value": cell.value,
            "numfmt": cell.number_format,
        })
    print(row_info)

# Write formulas to column C: nearest $5, ties exactly at midpoint round down
for r in range(1, ws.max_row + 1):
    target = ws.cell(r, 3)
    source = ws.cell(r, 2)
    target.value = f'=IF(MOD(B{r},5)=2.5,FLOOR(B{r},5),ROUND(B{r}/5,0)*5)'
    # Copy number format/style from column B when available
    target.number_format = source.number_format
    if source.has_style:
        target.font = copy(source.font)
        target.fill = copy(source.fill)
        target.border = copy(source.border)
        target.alignment = copy(source.alignment)
        target.protection = copy(source.protection)

wb.save(output_path)
print("Saved:", output_path, os.path.exists(output_path))

recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Verify formulas and values
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[wb_formula.sheetnames[0]]
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values[wb_values.sheetnames[0]]

for r in range(1, wsf.max_row + 1):
    print(
        r,
        "B_formula=", wsf.cell(r, 2).value,
        "C_formula=", wsf.cell(r, 3).value,
        "C_value=", wsv.cell(r, 3).value
    )
```
