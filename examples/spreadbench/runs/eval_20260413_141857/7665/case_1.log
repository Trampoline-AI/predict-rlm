from openpyxl import load_workbook
from pathlib import Path
import os

# Load workbook
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Read source values from column H, rows 2:max_row
source_vals = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 8).value
    if v is not None and v != "":
        source_vals.append(v)

unique_sorted = sorted(set(source_vals))
print("unique_sorted:", unique_sorted)

# Write formulas in Q2:V2
start_col = 17  # Q
target_len = 6  # Q:V
for i in range(target_len):
    cell = ws.cell(2, start_col + i)
    if i < len(unique_sorted):
        # formula cell, per instruction "by formula"
        cell.value = f"={unique_sorted[i]}"
    else:
        cell.value = ""

# Save
wb.save(output_path)
print("saved to", output_path)

# Recalculate and verify
recalc_result = await recalculate(str(output_path))
print("recalc:", recalc_result)

wb_check_formula = load_workbook(output_path, data_only=False)
wsf = wb_check_formula[wb_check_formula.sheetnames[0]]
formula_cells = [wsf.cell(2, c).value for c in range(17, 23)]
print("formulas Q2:V2:", formula_cells)

wb_check_values = load_workbook(output_path, data_only=True)
wsv = wb_check_values[wb_check_values.sheetnames[0]]
value_cells = [wsv.cell(2, c).value for c in range(17, 23)]
print("values Q2:V2:", value_cells)

final_output_spreadsheet = str(output_path)
