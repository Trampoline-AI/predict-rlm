from openpyxl import load_workbook
from pathlib import Path
import os

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load and modify
wb = load_workbook(input_path)
ws = wb["Sheet1"]

for r in range(2, 14):
    ws[f"D{r}"] = f'=IF(A{r}="","",IF(A{r}=0,1,0))'

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nUpdated D formulas:")
for r in range(2, 14):
    print(f"D{r}:", wsf[f"D{r}"].value)

# Verify cached values
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Sheet1"]
print("\nCached values D8:D13:")
for r in range(8, 14):
    print(f"D{r}:", wsv[f"D{r}"].value)

print("\nKey totals:")
for cell in ["I4", "I5", "I6", "I7", "I8"]:
    print(cell, "formula=", wsf[cell].value, "cached=", wsv[cell].value)

final_output_path = str(output_path)
```
