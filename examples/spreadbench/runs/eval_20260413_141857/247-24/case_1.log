```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

wb2 = load_workbook(infile)
main_ws = wb2["Main"]
lookup_ws = wb2["Lookup"]

# Build lookup map from Lookup sheet
lookup_map = {}
for r in lookup_ws.iter_rows(min_row=2, values_only=True):
    emp_id, weeks = r[0], r[1]
    if emp_id is not None:
        lookup_map[emp_id] = weeks

# Read original main data
orig_rows = list(main_ws.iter_rows(values_only=True))
header = list(orig_rows[0])
data_rows = [list(r) for r in orig_rows[1:]]

# Keep original row styles as templates by row index
style_templates = {}
for r in range(2, main_ws.max_row + 1):
    style_templates[r] = [copy(main_ws.cell(r, c)._style) for c in range(1, main_ws.max_column + 1)]

# Choose a blank-row style template from first Ahmed Sons row if possible, else row 2
blank_style_source_row = 2
for r in range(2, main_ws.max_row + 1):
    if main_ws.cell(r, 1).value == "Ahmed Sons":
        blank_style_source_row = r
        break
blank_style_template = [copy(main_ws.cell(blank_style_source_row, c)._style) for c in range(1, main_ws.max_column + 1)]

rebuilt = []
deleted_count = 0
updated_rate_count = 0
inserted_blank_rows = 0

for row in data_rows:
    company = row[0]
    location = row[1]
    emp_id = row[2]

    # Delete conditions
    if company == "Motorcycle":
        deleted_count += 1
        continue
    if company == "Ahmed Sons" and location == "Canada":
        deleted_count += 1
        continue

    # Update bill rate
    if company == "National TV" and location == "India":
        row[6] = 180
        updated_rate_count += 1

    # Populate lookup column M
    row[12] = lookup_map.get(emp_id)

    # Existing row
    rebuilt.append(("data", row))

    # Insert two blank rows after each remaining Ahmed Sons row
    if company == "Ahmed Sons":
        rebuilt.append(("blank", [None] * len(header)))
        rebuilt.append(("blank", [None] * len(header)))
        inserted_blank_rows += 2

# Clear old body contents thoroughly so no stale values remain
max_existing_rows = main_ws.max_row
max_cols = main_ws.max_column
target_total_rows = 1 + len(rebuilt)
clear_to_row = max(max_existing_rows, target_total_rows)

for r in range(2, clear_to_row + 1):
    for c in range(1, max_cols + 1):
        cell = main_ws.cell(r, c)
        cell.value = None

# Rewrite rows
source_data_row_ptr = 2  # used for style inheritance from original rows
for out_row_idx, (kind, rowvals) in enumerate(rebuilt, start=2):
    if kind == "data":
        # Find next original non-deleted source row style by advancing pointer until matching actual source row content roughly.
        # Simpler: use current pointer if available; fallback to blank template.
        row_style = style_templates.get(source_data_row_ptr, blank_style_template)
        source_data_row_ptr += 1

        # Write A:H, M as values and I:L as formulas
        for c in range(1, 14):
            cell = main_ws.cell(out_row_idx, c)
            cell._style = copy(row_style[c - 1])

            if c == 9:
                cell.value = f"=G{out_row_idx}*H{out_row_idx}"
            elif c == 10:
                cell.value = f"=G{out_row_idx}-30"
            elif c == 11:
                cell.value = f"=J{out_row_idx}*H{out_row_idx}"
            elif c == 12:
                cell.value = f"=I{out_row_idx}-K{out_row_idx}"
            else:
                cell.value = rowvals[c - 1]
    else:
        # Blank inserted row
        for c in range(1, 14):
            cell = main_ws.cell(out_row_idx, c)
            cell._style = copy(blank_style_template[c - 1])
            cell.value = None

# If output has fewer rows than original, clear remaining rows/styles values
for r in range(target_total_rows + 1, max_existing_rows + 1):
    for c in range(1, max_cols + 1):
        main_ws.cell(r, c).value = None

wb2.save(outfile)

# Verify
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb["Main"]
check_rows = list(check_ws.iter_rows(values_only=True))
check_data = check_rows[1:]

count_ahmed = sum(1 for r in check_data if r[0] == "Ahmed Sons")
count_ahmed_canada = sum(1 for r in check_data if r[0] == "Ahmed Sons" and r[1] == "Canada")
count_motorcycle = sum(1 for r in check_data if r[0] == "Motorcycle")
count_ntv_india_180 = sum(1 for r in check_data if r[0] == "National TV" and r[1] == "India" and r[6] == 180)
blank_rows_after_ahmed = 0
for i in range(len(check_data) - 2):
    if check_data[i][0] == "Ahmed Sons":
        if all(v is None for v in check_data[i+1]) and all(v is None for v in check_data[i+2]):
            blank_rows_after_ahmed += 2

print("Saved:", outfile)
print("Final rows including header:", check_ws.max_row)
print("Deleted count:", deleted_count)
print("Updated National TV India rows to 180:", count_ntv_india_180)
print("Ahmed Sons rows kept:", count_ahmed)
print("Inserted blank rows confirmed:", blank_rows_after_ahmed)
print("Remaining Ahmed Sons Canada rows:", count_ahmed_canada)
print("Remaining Motorcycle rows:", count_motorcycle)

# Show a small sample around the top and around National TV India section
for r in range(1, min(check_ws.max_row, 16) + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, 14)])

print("Last 8 rows:")
for r in range(max(1, check_ws.max_row - 7), check_ws.max_row + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, 14)])
