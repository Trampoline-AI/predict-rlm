from openpyxl.styles import PatternFill, Font, Border, Alignment
from copy import copy

ws = wb["Sheet1"]

# Inspect the target/result area and any possible Category 9 row
for r in range(21, 32):
    vals = [ws.cell(r, c).value for c in range(5, 32)]
    print(r, vals)

# Build structures from source tables
# Categories table: E3:N9 => agent in col E, categories in F:N, headers row 3
cat_headers = [ws.cell(3, c).value for c in range(6, 15)]
agents = []
agent_cat_weights = {}
for r in range(4, 10):
    agent = ws.cell(r, 5).value
    if agent:
        agents.append(agent)
        agent_cat_weights[agent] = {}
        for c, cat in enumerate(cat_headers, start=6):
            val = ws.cell(r, c).value
            agent_cat_weights[agent][cat] = 0 if val in (None, "") else val

# Schedule table: row 12 headers F:AE, agents rows 13:18
time_headers = [ws.cell(12, c).value for c in range(6, 32)]
agent_schedule = {}
for r in range(13, 19):
    agent = ws.cell(r, 5).value
    if agent:
        agent_schedule[agent] = {}
        for c, tm in enumerate(time_headers, start=6):
            val = ws.cell(r, c).value
            agent_schedule[agent][tm] = 0 if val in (None, "") else val

# Compute totals: for each category and each time, sum over scheduled agents * category assignment
computed = {}
for cat in cat_headers:
    computed[cat] = []
    for tm in time_headers:
        total = 0
        for agent in agents:
            total += (agent_schedule.get(agent, {}).get(tm, 0) or 0) * (agent_cat_weights.get(agent, {}).get(cat, 0) or 0)
        computed[cat].append(total)

print("Computed categories:", cat_headers)
for cat in cat_headers[:3]:
    print(cat, computed[cat][:10])

# Compare to example table for categories 1-8 at rows 36:43
mismatches = []
for i, cat in enumerate(cat_headers[:8], start=36):
    example_vals = [ws.cell(i, c).value for c in range(6, 32)]
    if example_vals != computed[cat]:
        mismatches.append((cat, example_vals, computed[cat]))
print("Mismatch count vs example:", len(mismatches))
if mismatches:
    print("First mismatch:", mismatches[0][0], mismatches[0][1][:10], mismatches[0][2][:10])

