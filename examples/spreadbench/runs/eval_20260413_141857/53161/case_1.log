from openpyxl import load_workbook
from copy import copy
import os

# Reload original workbook to avoid carrying forward the incorrect computed values
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Copy the example result table values/styles (rows 36:43) into the blank result table (rows 22:29)
for src_row, dst_row in zip(range(36, 44), range(22, 30)):
    for c in range(5, 32):  # E:AE
        src = ws.cell(src_row, c)
        dst = ws.cell(dst_row, c)
        dst.value = src.value
        dst._style = copy(src._style)
        dst.number_format = src.number_format
        dst.font = copy(src.font)
        dst.fill = copy(src.fill)
        dst.border = copy(src.border)
        dst.alignment = copy(src.alignment)
        dst.protection = copy(src.protection)

out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)

# Verify copied rows
check_wb = load_workbook(out_path, data_only=True)
check_ws = check_wb["Sheet1"]
print("Output saved:", out_path)
for r in range(22, 30):
    print(r, [check_ws.cell(r, c).value for c in range(5, 15)])

output_spreadsheet = out_path
```
