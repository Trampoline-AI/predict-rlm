Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

rows_to_delete = []
for r in range(1, ws.max_row + 1):
    h_val = ws.cell(r, 8).value
    i_val = ws.cell(r, 9).value
    h_blank = h_val is None or (isinstance(h_val, str) and h_val.strip() == "")
    i_has_value = i_val is not None and not (isinstance(i_val, str) and i_val.strip() == "")
    if h_blank and i_has_value:
        rows_to_delete.append(r)

print("Rows to delete:", rows_to_delete)

for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

wb.save(output_path)

# Verify output
wb_check = load_workbook(output_path)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verified dimensions:", ws_check.max_row, "rows x", ws_check.max_column, "cols")
for r in range(1, ws_check.max_row + 1):
    vals = [ws_check.cell(r, c).value for c in range(1, 10)]
    print(f"Row {r}:", vals)

output_spreadsheet = output_path
```
