Reasoning: I know the workbook has one sheet with source data in A:E (`date, brand, batch, origin, quantity`) and an output area already set up in H:L with the same headers. The task is to populate H2 onward using the latest date per brand, while combining duplicate rows on that latest date by summing quantity.

Plan:
1. Load the workbook with openpyxl.
2. Read rows A2:E, skipping blanks.
3. For each brand, determine its latest date.
4. Keep only rows for that brand on that latest date.
5. Aggregate duplicate latest-date rows by `(date, brand, batch, origin)` and sum `quantity`.
6. Clear existing output values in H2:L and write the aggregated results there.
7. Save to `/sandbox/output/output_spreadsheet/` using the same filename.
8. Reopen and print the output region to verify.
Code:
```repl
import os
from collections import defaultdict, OrderedDict
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Read source data from A:E starting at row 2
rows = []
for r in range(2, ws.max_row + 1):
    date_val = ws.cell(r, 1).value
    brand = ws.cell(r, 2).value
    batch = ws.cell(r, 3).value
    origin = ws.cell(r, 4).value
    qty = ws.cell(r, 5).value
    if date_val is None and brand is None and batch is None and origin is None and qty is None:
        continue
    rows.append({
        "date": date_val,
        "brand": brand,
        "batch": batch,
        "origin": origin,
        "quantity": qty,
        "source_row": r,
    })

print("Source row count:", len(rows))

# Latest date per brand
latest_by_brand = {}
for row in rows:
    brand = row["brand"]
    date_val = row["date"]
    if brand is None or date_val is None:
        continue
    if brand not in latest_by_brand or date_val > latest_by_brand[brand]:
        latest_by_brand[brand] = date_val

print("Latest date per brand:", latest_by_brand)

# Aggregate only rows on each brand's latest date
agg = OrderedDict()
for row in rows:
    brand = row["brand"]
    if brand is None or row["date"] != latest_by_brand.get(brand):
        continue
    key = (row["date"], row["brand"], row["batch"], row["origin"])
    if key not in agg:
        agg[key] = 0
    agg[key] += row["quantity"] if row["quantity"] is not None else 0

result_rows = [
    [k[0], k[1], k[2], k[3], qty]
    for k, qty in agg.items()
]

# Sort by date then brand for stable output
result_rows.sort(key=lambda x: (x[0], str(x[1])))

print("Result rows:", len(result_rows))
for rr in result_rows:
    print(rr)

# Clear existing output area H2:L down through existing used rows and needed result rows
clear_to = max(ws.max_row, 1 + len(result_rows) + 5)
for r in range(2, clear_to + 1):
    for c in range(8, 13):
        ws.cell(r, c).value = None

# Ensure headers in H1:L1
headers = [ws.cell(1, c).value for c in range(1, 6)]
for idx, val in enumerate(headers, start=8):
    ws.cell(1, idx).value = val

# Write results to H:L starting row 2
for out_r, data in enumerate(result_rows, start=2):
    for offset, val in enumerate(data):
        ws.cell(out_r, 8 + offset).value = val

# Preserve date formatting in output date column if source has one
src_date_fmt = ws["A2"].number_format
for r in range(2, 2 + len(result_rows)):
    ws.cell(r, 8).number_format = src_date_fmt

wb.save(outfile)
print("Saved:", outfile)

# Verify by reopening
check_wb = load_workbook(outfile)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Verified output region H:L")
for r in range(1, max(2, len(result_rows) + 1) + 1):
    vals = [check_ws.cell(r, c).value for c in range(8, 13)]
    print(r, vals)
```
