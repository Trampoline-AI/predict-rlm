To avoid compatibility problems with array-style formulas in LibreOffice/Excel, I’ll build a robust formula for each `Q` cell by explicitly summing/counting matching columns using `SUMIF`/`COUNTIFS`, wrapped in `IFERROR(...,"")`. Then I’ll change the fill of `Q2:Q6` from green to yellow, save the workbook to the output directory, and print the formulas plus fill colors for verification.
Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Inspect existing target cells/fills
for r in range(2, 7):
    cell = ws[f"Q{r}"]
    print(f"Before Q{r}: value={cell.value!r}, fill_type={cell.fill.fill_type}, fgColor={cell.fill.fgColor.rgb}, startColor={cell.fill.start_color.rgb}")

# Build a LibreOffice/Excel-compatible formula by explicitly handling each candidate column.
# Average values in B3:L8 where:
# - header in row 2 equals P[row]
# - rating in M3:M8 equals $S$2
# - value cell is nonblank (for denominator)
cols = [chr(ord('B') + i) for i in range(11)]  # B:L

for r in range(2, 7):
    size_ref = f"P{r}"
    rating_ref = "$S$2"
    sum_parts = []
    count_parts = []
    for col in cols:
        header_ref = f"${col}$2"
        data_range = f"${col}$3:${col}$8"
        rating_range = "$M$3:$M$8"
        sum_parts.append(f'IF({header_ref}={size_ref},SUMIF({rating_range},{rating_ref},{data_range}),0)')
        count_parts.append(f'IF({header_ref}={size_ref},COUNTIFS({rating_range},{rating_ref},{data_range},"<>"),0)')
    formula = f'=IFERROR(({" + ".join(sum_parts)})/({" + ".join(count_parts)}),"")'
    ws[f"Q{r}"] = formula

# Change target cells to yellow fill
yellow_fill = PatternFill(fill_type="solid", fgColor="FFFF00")
for r in range(2, 7):
    ws[f"Q{r}"].fill = yellow_fill

wb.save(outfile)
print("Saved to:", outfile)

# Verify formulas and fills after save/reload
wb2 = load_workbook(outfile)
ws2 = wb2["Sheet1"]
for r in range(2, 7):
    cell = ws2[f"Q{r}"]
    print(f"After Q{r}: formula={cell.value}")
    print(f"  fill_type={cell.fill.fill_type}, fgColor={cell.fill.fgColor.rgb}, startColor={cell.fill.start_color.rgb}")
```
