from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os

infile = input_spreadsheet
outfile = "/sandbox/output/output_spreadsheet/" + os.path.basename(infile)

# Rebuild from original input to avoid any corruption/loss of formulas
wb = load_workbook(infile)
ws = wb["Sheet1"]

yellow_fill = PatternFill(fill_type="solid", fgColor="FFFF00")

for r in range(2, 7):
    # SUMPRODUCT across B3:L8 with row-rating and column-size criteria
    formula = (
        f'=IFERROR('
        f'SUMPRODUCT(($M$3:$M$8=$S$2)*($B$2:$L$2=P{r})*($B$3:$L$8))/'
        f'SUMPRODUCT(($M$3:$M$8=$S$2)*($B$2:$L$2=P{r})*($B$3:$L$8<>""))'
        f',"")'
    )
    ws[f"Q{r}"] = formula
    ws[f"Q{r}"].fill = yellow_fill

wb.save(outfile)

# Verify formulas persisted and fills changed
wbf = load_workbook(outfile, data_only=False)
wsf = wbf["Sheet1"]

print("Post-save formula check:")
for r in range(2, 7):
    print(r, type(wsf[f"Q{r}"].value).__name__, str(wsf[f"Q{r}"].value), wsf[f"Q{r}"].fill.fgColor.rgb)

# Compute expected results in Python from source data
headers = [wsf.cell(2, c).value for c in range(2, 13)]  # B:L row 2
subject_rating = wsf["S2"].value
expected = {}

for tr in range(2, 7):
    target_size = wsf[f"P{tr}"].value
    vals = []
    for c in range(2, 13):
        if wsf.cell(2, c).value == target_size:
            for rr in range(3, 9):
                v = wsf.cell(rr, c).value
                rating = wsf.cell(rr, 13).value
                if rating == subject_rating and v not in (None, ""):
                    vals.append(v)
    expected[tr] = "" if not vals else sum(vals) / len(vals)

print("Expected by Python:")
for tr in range(2, 7):
    print(tr, "size", wsf[f"P{tr}"].value, "expected", expected[tr])
```
