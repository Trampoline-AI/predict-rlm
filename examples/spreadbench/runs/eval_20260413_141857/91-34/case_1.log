Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
from collections import defaultdict
import os

# Reload clean workbook from input
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", Path(input_spreadsheet).name)

wb = load_workbook(infile)
ws = wb["SwiftMD"]

headers = {ws.cell(2, c).value: c for c in range(1, ws.max_column + 1)}

# Build groups by person
groups = defaultdict(list)
for r in range(3, ws.max_row + 1):
    last = ws.cell(r, headers["Last Name"]).value
    first = ws.cell(r, headers["First Name"]).value
    dob = ws.cell(r, headers["Date Of Birth"]).value
    dup = ws.cell(r, headers["Duplicate?"]).value
    rel = ws.cell(r, headers["Relationship"]).value
    groups[(last, first, dob)].append({"row": r, "dup": dup, "rel": rel})

# Determine qualifying groups:
# - more than one row
# - all rows marked Yes in Duplicate?
# - none of the rows has Relationship == Employee
qualifying = {}
for person, items in groups.items():
    if len(items) > 1:
        all_yes = all(str(x["dup"]).strip().lower() == "yes" for x in items)
        any_employee = any(str(x["rel"]).strip().lower() == "employee" for x in items)
        if all_yes and not any_employee:
            qualifying[person] = items

print("Qualifying groups to delete one entry from:")
for person, items in qualifying.items():
    print(person, [(x["row"], x["rel"], x["dup"]) for x in items])

# Delete one entry from each qualifying group: remove the later row, keep the first
rows_to_delete = sorted([items[-1]["row"] for items in qualifying.values()], reverse=True)
print("Rows to delete:", rows_to_delete)

for r in rows_to_delete:
    ws.delete_rows(r, 1)

wb.save(outfile)
print("Saved to:", outfile)

# Verify output
wb2 = load_workbook(outfile)
ws2 = wb2["SwiftMD"]
headers2 = {ws2.cell(2, c).value: c for c in range(1, ws2.max_column + 1)}

groups2 = defaultdict(list)
for r in range(3, ws2.max_row + 1):
    last = ws2.cell(r, headers2["Last Name"]).value
    first = ws2.cell(r, headers2["First Name"]).value
    dob = ws2.cell(r, headers2["Date Of Birth"]).value
    dup = ws2.cell(r, headers2["Duplicate?"]).value
    rel = ws2.cell(r, headers2["Relationship"]).value
    groups2[(last, first, dob)].append((r, dup, rel))

# Print verification for targeted examples and any remaining all-nonemployee duplicate groups
targets = [
    ("Doees", "Emily"),
    ("Doees", "Ryan"),
    ("Doees", "Lisa"),
    ("Smith", "Antoinette"),
]
print("\nVerification samples:")
for person, items in groups2.items():
    if person[0] in [t[0] for t in targets] and person[1] in [t[1] for t in targets]:
        print(person, items)

remaining_nonemployee_dupes = []
for person, items in groups2.items():
    if len(items) > 1:
        all_yes = all(str(x[1]).strip().lower() == "yes" for x in items)
        any_employee = any(str(x[2]).strip().lower() == "employee" for x in items)
        if all_yes and not any_employee:
            remaining_nonemployee_dupes.append((person, items))
print("\nRemaining duplicate groups with all non-employees:", remaining_nonemployee_dupes)
print("Final row count:", ws2.max_row)
```
