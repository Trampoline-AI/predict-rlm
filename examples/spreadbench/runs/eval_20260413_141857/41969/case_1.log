import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Apply the formulas to A6:C6
formulas = [
    "=COUNTBLANK(A3:C3)",
    "=COUNTBLANK(D3:F3)",
    "=COUNTBLANK(G3:I3)",
]
for col_idx, formula in enumerate(formulas, start=1):
    ws.cell(row=6, column=col_idx).value = formula

# Save to output path with same filename
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

# Verify saved formulas
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Saved to:", output_path)
print("A6:C6 formulas:", [check_ws.cell(6, c).value for c in range(1, 4)])

output_spreadsheet = output_path
```
