import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load fresh workbook
wb = load_workbook(input_path)
sh1 = wb["SH1"]
data = wb["DATA"]

# Extract SH1 invoice numbers in appearance order
sh1_invoices = []
for row in range(1, sh1.max_row):
    for col in range(1, sh1.max_column + 1):
        v = sh1.cell(row, col).value
        if isinstance(v, str) and v.strip().upper() == "INVOICE NO":
            sh1_invoices.append(sh1.cell(row + 1, col).value)

# Find DATA groups ending at TOTAL rows in col A
groups = []
start = 2
for r in range(2, data.max_row + 1):
    if data.cell(r, 1).value == "TOTAL":
        groups.append({
            "start": start,
            "end": r,
            "sheet_name": data.cell(start, 5).value
        })
        start = r + 1

# Update only groups whose sheet_name matches SH1, up to available invoice count
match_idx = 0
updated_groups = []
for g in groups:
    if g["sheet_name"] == "SH1" and match_idx < len(sh1_invoices):
        inv = sh1_invoices[match_idx]
        for rr in range(g["start"], g["end"] + 1):
            data.cell(rr, 4).value = inv
        updated_groups.append((g["start"], g["end"], g["sheet_name"], inv))
        match_idx += 1

# Save
wb.save(output_path)

# Verify by reopening and printing DATA rows 2-17 cols A-E
check_wb = load_workbook(output_path)
check_data = check_wb["DATA"]

print("Output saved:", output_path)
print("Invoices from SH1:", sh1_invoices)
print("Updated groups:", updated_groups)
for r in range(2, check_data.max_row + 1):
    vals = [check_data.cell(r, c).value for c in range(1, 6)]
    print(r, vals)

final_output_path = output_path
```
