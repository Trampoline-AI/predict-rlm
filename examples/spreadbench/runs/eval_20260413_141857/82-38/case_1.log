from openpyxl import load_workbook
import os, shutil

wb = load_workbook(input_spreadsheet)
sh1 = wb["SH1"]
data = wb["DATA"]

# Extract invoice numbers from SH1 by finding "INVOICE NO" and taking the value below
sh1_invoices = []
sh1_positions = []
for row in range(1, sh1.max_row):
    for col in range(1, sh1.max_column + 1):
        v = sh1.cell(row, col).value
        if isinstance(v, str) and v.strip().upper() == "INVOICE NO":
            below = sh1.cell(row + 1, col).value
            sh1_invoices.append(below)
            sh1_positions.append((row, col, below))

print("SH1 invoice markers found:", len(sh1_invoices))
print("SH1 invoice details:", sh1_positions)

# Inspect DATA groups: contiguous sections ending with TOTAL in col A
groups = []
start = 2
r = 2
while r <= data.max_row:
    a = data.cell(r, 1).value
    e = data.cell(r, 5).value
    d = data.cell(r, 4).value
    if a == "TOTAL":
        groups.append({
            "start": start,
            "end": r,
            "sheet_name": e,
            "orig_invoice": data.cell(start, 4).value if start <= r else None,
            "rows": [(rr, data.cell(rr,1).value, data.cell(rr,4).value, data.cell(rr,5).value) for rr in range(start, r+1)]
        })
        start = r + 1
    r += 1

print("DATA groups found:", len(groups))
for i, g in enumerate(groups, 1):
    print(f"Group {i}: rows {g['start']}-{g['end']}, sheet_name={g['sheet_name']}, orig_invoice={g['orig_invoice']}, nrows={len(g['rows'])}")
    print("  sample rows:", g["rows"][:3])

# Show unique sheet names in DATA groups
print("Unique sheet_name values in DATA groups:", sorted(set(g["sheet_name"] for g in groups)))
