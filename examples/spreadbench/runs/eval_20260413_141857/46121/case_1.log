Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import numbers
from pathlib import Path
import os

# Re-open workbook and inspect wider area of the 2022 sheet
wb = load_workbook(input_spreadsheet)
ws2022 = wb["2022"]
wst = wb["Transactions"]

print("2022 dimensions:", ws2022.max_row, ws2022.max_column)

# Show rows 1-15 and cols A-M
for r in range(1, 16):
    vals = [ws2022.cell(r, c).value for c in range(1, 14)]
    print(r, vals)

# Determine income section rows: from row after "Income" until row before "Total"
income_label_row = None
income_total_row = None
for r in range(1, ws2022.max_row + 1):
    a = ws2022.cell(r, 1).value
    if a == "Income":
        income_label_row = r
    elif income_label_row and a == "Total":
        income_total_row = r
        break

print("Income section starts at row", income_label_row, "ends before total row", income_total_row)

# Show month headers row 3 across A:N
headers = [ws2022.cell(3, c).value for c in range(1, 15)]
print("Row 3 headers A:N:", headers)

# Show transaction income columns A:D rows 1:15
for r in range(1, 16):
    print("T", r, [wst.cell(r, c).value for c in range(1, 5)])

# Fill formulas in income section across month columns B:M (based on visible headers in row 3)
start_row = income_label_row + 1
end_row = income_total_row - 1

for r in range(start_row, end_row + 1):
    category_cell = f"$A{r}"
    for c in range(2, 14):  # B:M
        header_ref = f"{ws2022.cell(3, c).coordinate}"
        cell = ws2022.cell(r, c)
        # Sum income amounts in Transactions!C:C where Month matches header row 3 and Category matches column A
        cell.value = f'=SUMIFS(Transactions!$C$3:$C$22,Transactions!$A$3:$A$22,{header_ref},Transactions!$D$3:$D$22,{category_cell})'
        cell.number_format = numbers.FORMAT_CURRENCY_USD_SIMPLE

# Also apply currency format to income total row across months if formulas already exist
for c in range(2, 14):
    ws2022.cell(income_total_row, c).number_format = numbers.FORMAT_CURRENCY_USD_SIMPLE

# Save output
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb.save(out_path)

print("Saved to", out_path)

# Verify formulas written to first few cells
wb2 = load_workbook(out_path, data_only=False)
wsv = wb2["2022"]
for r in range(start_row, min(end_row, start_row + 3) + 1):
    print("Row", r, [wsv.cell(r, c).value for c in range(1, 7)])
    print("Formats", [wsv.cell(r, c).number_format for c in range(2, 7)])
```
