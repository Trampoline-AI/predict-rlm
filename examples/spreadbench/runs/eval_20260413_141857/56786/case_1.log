Code:
```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.utils.cell import range_boundaries, get_column_letter

# Inspect actual used rows and sample lower part of sheet
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]
print("max_row/max_col:", ws.max_row, ws.max_column)
for r in [190, 195, 200, 201, 205, 210, 300, 400, 500, 515]:
    vals = [ws.cell(r, c).value for c in range(1, 4)]
    print(r, vals)

# find last row with data in col A or B
last_data_row = 0
for r in range(ws.max_row, 0, -1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_data_row = r
        break
print("last_data_row:", last_data_row)

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

wb2 = load_workbook(out_path)
ws2 = wb2["Sheet1"]
table2 = ws2.tables["Table1"]
print("old table ref:", table2.ref)

# Expand table to actual data rows if needed
min_col, min_row, max_col, max_row = range_boundaries(table2.ref)
new_ref = f"{get_column_letter(min_col)}{min_row}:{get_column_letter(max_col)}{last_data_row}"
table2.ref = new_ref
print("new table ref:", table2.ref)

# Write LibreOffice-safe bounded formulas in column C for all data rows
# Header row is row 3; data starts row 4
for r in range(4, last_data_row + 1):
    ws2.cell(r, 3).value = f'=AVERAGEIFS($B$4:$B${last_data_row},$A$4:$A${last_data_row},">"&A{r}-365,$A$4:$A${last_data_row},"<="&A{r})'

wb2.save(out_path)
print("saved", out_path)

recalc_result = await recalculate(out_path)
print("recalc:", recalc_result)

# Verify formulas and cached values
wbf = load_workbook(out_path, data_only=False)
wsf = wbf["Sheet1"]
print("formula samples:", [wsf[f"C{i}"].value for i in [4,5,10,200,last_data_row]])

wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
print("value samples:", {i: wsv[f"C{i}"].value for i in [4,5,10,200,last_data_row]})
output_spreadsheet = out_path
```
