import os, shutil
from openpyxl import load_workbook

# Load workbook and inspect table details
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]
table = ws.tables["Table1"]

print("Table ref:", table.ref)
print("Headers:", [ws.cell(3, c).value for c in range(1, 5)])

# Copy input to output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

# Re-open copied workbook for editing
wb2 = load_workbook(out_path)
ws2 = wb2["Sheet1"]
table2 = ws2.tables["Table1"]

# Determine table bounds
from openpyxl.utils.cell import range_boundaries
min_col, min_row, max_col, max_row = range_boundaries(table2.ref)
print("Table bounds:", (min_col, min_row, max_col, max_row))

# Fill the "12 month rolling average" column with a structured-reference formula
# Previous 365 days inclusive of current row's date
formula = '=AVERAGEIFS(Table1[Beans Counted],Table1[Date],">"&[@Date]-365,Table1[Date],"<="&[@Date])'

for r in range(min_row + 1, max_row + 1):  # data rows only
    ws2.cell(r, 3).value = formula

wb2.save(out_path)
print("Saved:", out_path)

# Recalculate formulas and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("Sample formulas C4:C8:", [ws_check[f"C{i}"].value for i in range(4, 9)])

wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Sample cached values C4:C10:", [ws_values[f"C{i}"].value for i in range(4, 11)])

output_spreadsheet = out_path
