import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Implement formulas using the existing criterion/input cell B12 (=0)
ws["A13"] = '=IFERROR(INDEX($B$3:$F$3,MATCH($B$12,$B$1:$F$1,0)),"")'
ws["A14"] = '=IFERROR(INDEX($B$3:$F$3,MATCH($B$12,INDEX($B$1:$F$1,MATCH($B$12,$B$1:$F$1,0)+1):$F$1,0)+MATCH($B$12,$B$1:$F$1,0)),"")'

wb.save(outfile)
print("Saved:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check["Sheet1"]
print("Formulas:", ws_check["A13"].value, " | ", ws_check["A14"].value)

wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Sheet1"]
print("Values:", ws_vals["A13"].value, ws_vals["A14"].value)
print("B12 criterion:", ws_vals["B12"].value)
```
