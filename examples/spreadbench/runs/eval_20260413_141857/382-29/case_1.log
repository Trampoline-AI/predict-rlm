Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os, shutil

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
totals = wb["Totals"]
data_sheet_names = [name for name in wb.sheetnames if name != "Totals"]

# Fill Totals!B2:B26 with formulas summing AB5:AB29 across all data sheets
for totals_row in range(2, 27):  # B2 through B26
    source_row = totals_row + 3   # maps 2->5, 26->29
    refs = [f"'{sheet}'!AB{source_row}" for sheet in data_sheet_names]
    formula = "=" + "+".join(refs)
    totals.cell(row=totals_row, column=2).value = formula

wb.save(output_path)

# Recalculate formulas for cached values
recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

# Verify formulas and resulting values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
tf = wb_formula["Totals"]
tv = wb_values["Totals"]

print("Verification of Totals!A1:B26")
for r in range(1, 27):
    print(r, tf[f"A{r}"].value, tf[f"B{r}"].value, "=>", tv[f"B{r}"].value)

output_spreadsheet = str(output_path)
```
