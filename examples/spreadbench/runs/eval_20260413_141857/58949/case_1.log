from openpyxl import load_workbook
from pathlib import Path
import os

# Load workbook
infile = Path(input_spreadsheet)
outfile = Path("/sandbox/output/output_spreadsheet") / infile.name

wb = load_workbook(infile)
ws_extract = wb["Extract"]
ws_desired = wb["Desired Result"]

# Read headers from Desired Result
desired_headers = [ws_desired.cell(1, c).value for c in range(1, ws_desired.max_column + 1)]
person_header = desired_headers[0]
car_headers = desired_headers[1:]

# Build mapping from Extract: person -> {car: value}
person_order = []
data = {}

for r in range(2, ws_extract.max_row + 1):
    person = ws_extract.cell(r, 1).value
    car = ws_extract.cell(r, 2).value
    value = ws_extract.cell(r, 3).value
    
    if person not in data:
        data[person] = {}
        person_order.append(person)
    data[person][car] = value

# Fill Desired Result rows using predefined headers
# Keep existing row count/layout; extend if necessary
for idx, person in enumerate(person_order, start=2):
    ws_desired.cell(idx, 1).value = person
    for c, car in enumerate(car_headers, start=2):
        value = data.get(person, {}).get(car, "")
        ws_desired.cell(idx, c).value = value

# If there are leftover rows beyond populated persons, blank them out
for r in range(2 + len(person_order), ws_desired.max_row + 1):
    for c in range(1, ws_desired.max_column + 1):
        ws_desired.cell(r, c).value = ""

# Save
wb.save(outfile)

# Verify saved output
check_wb = load_workbook(outfile)
check_ws = check_wb["Desired Result"]
print("Saved to:", outfile)
for r in range(1, check_ws.max_row + 1):
    print(r, [check_ws.cell(r, c).value for c in range(1, check_ws.max_column + 1)])

output_spreadsheet = str(outfile)
```
