import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Sheet1"]

for row in range(6, 14):
    ws[f"E{row}"] = f'=IF(ISNUMBER(SEARCH("deposit",B{row})),"Revenue",IF(ISNUMBER(SEARCH("withdrawal",B{row})),"Expenses",""))'

wb.save(output_path)

# Verify formulas were written correctly
verify_wb = load_workbook(output_path, data_only=False)
verify_ws = verify_wb["Sheet1"]
print("Saved to:", output_path)
for row in range(5, 14):
    print(row, [verify_ws[f"{col}{row}"].value for col in ["B", "E"]])

output_spreadsheet = output_path
```
