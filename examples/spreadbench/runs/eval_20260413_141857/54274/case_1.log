Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os

infile = Path(input_spreadsheet)
outfile = Path("/sandbox/output/output_spreadsheet") / infile.name

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Nested IF formula per instruction:
# If total <= target: total/target
# If target < total < stretch: min(total/target, 1.09)
# If total = stretch: min(total/target, 1.1)
# If stretch < total < overstretch: min(total/target, 1.19)
# If total >= overstretch: min(total/target, 1.2)
formula = (
    '=IF(F4<=B4,F4/B4,'
    'IF(F4<C4,MIN(F4/B4,1.09),'
    'IF(F4=C4,MIN(F4/B4,1.1),'
    'IF(F4<D4,MIN(F4/B4,1.19),'
    'MIN(F4/B4,1.2)))))'
)

ws["G4"] = formula

wb.save(outfile)
print("Saved to", outfile)
print("Formula written to G4:", ws["G4"].value)

# Recalculate and verify
recalc_result = await recalculate(str(outfile))
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=True)
ws_check = wb_check["Sheet1"]
print("Verified cached G4 value:", ws_check["G4"].value)
print("Reference values B4,C4,D4,F4:", ws_check["B4"].value, ws_check["C4"].value, ws_check["D4"].value, ws_check["F4"].value)

output_spreadsheet = str(outfile)
```
