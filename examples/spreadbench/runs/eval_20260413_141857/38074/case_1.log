To treat blanks as zeros, I’ll wrap the numeric columns with `N(...)`, which converts blanks to `0` and keeps numbers numeric. I’ll write the formulas for each row in `K2:K5`, format them without decimals using number format `0`, save to the output directory with the same filename, recalculate, and verify both formulas and computed values.
Code:
```repl
import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook normally to preserve formulas/styles
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Build case-sensitive vectorized formula for K2:K5
# Profit = B - C - E - G, matched where A equals J(row) with case sensitivity
data_start = 2
data_end = ws.max_row

for row in range(2, 6):
    formula = (
        f'=SUMPRODUCT(--EXACT($A${data_start}:$A${data_end},J{row}),'
        f'(N($B${data_start}:$B${data_end})-N($C${data_start}:$C${data_end})'
        f'-N($E${data_start}:$E${data_end})-N($G${data_start}:$G${data_end})))'
    )
    ws[f"K{row}"] = formula
    ws[f"K{row}"].number_format = "0"

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Verify formulas and values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]

for row in range(2, 6):
    print(
        f"K{row}",
        "label=", ws_formula[f"J{row}"].value,
        "formula=", ws_formula[f'K{row}'].value,
        "value=", ws_values[f'K{row}'].value,
        "numfmt=", ws_formula[f'K{row}'].number_format
    )

# keep for submit
final_output_path = output_path
```
