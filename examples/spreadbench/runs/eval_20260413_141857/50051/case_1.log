Code:
```repl
import os, shutil
from collections import defaultdict, Counter
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

# Copy original file first to preserve workbook structure/styles
shutil.copy2(input_path, output_path)

# Load writable workbook and data-only workbook for cached formula results
wb = load_workbook(output_path)
ws = wb["Sheet1"]

wb_vals = load_workbook(input_path, data_only=True)
wsv = wb_vals["Sheet1"]

# Build score -> source row list from actual values in T2:T600
score_to_rows = defaultdict(list)
for r in range(2, 601):
    v = wsv[f"T{r}"].value
    if v not in (None, "", " "):
        score_to_rows[v].append(r)

# Build position -> full name lookup from actual AF/AG values
pos_to_name = {}
for r in range(2, wsv.max_row + 1):
    pos = wsv[f"AG{r}"].value
    name = wsv[f"AF{r}"].value
    if pos not in (None, "", " ") and name not in (None, "", " ") and pos not in pos_to_name:
        pos_to_name[pos] = name

# Compute corrected rows for Triple Score block
seen = Counter()
written = []
for r in range(2, wsv.max_row + 1):
    score = wsv[f"CB{r}"].value
    if score in (None, "", " "):
        # keep the decorative label in CA/blank score rows, but clear outputs
        ws[f"CC{r}"] = None
        ws[f"CD{r}"] = None
        ws[f"CE{r}"] = None
        continue

    seen[score] += 1
    idx = seen[score] - 1
    matches = score_to_rows.get(score, [])
    src_row = matches[idx] if idx < len(matches) else None
    pos = ((src_row - 2) // 21 + 1) if src_row is not None else None
    name = pos_to_name.get(pos, None)

    ws[f"CC{r}"] = src_row
    ws[f"CD{r}"] = pos
    ws[f"CE{r}"] = name
    written.append((r, score, src_row, pos, name))

# Save workbook
wb.save(output_path)

# Verify by reopening
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb["Sheet1"]

print("Output saved to:", output_path)
print("Rows written:", len(written))
print("First 15 corrected rows:")
for item in written[:15]:
    r = item[0]
    print(
        r,
        "CB=", verify_ws[f"CB{r}"].value,
        "CC=", verify_ws[f"CC{r}"].value,
        "CD=", verify_ws[f"CD{r}"].value,
        "CE=", verify_ws[f"CE{r}"].value,
    )

print("Last 5 corrected rows:")
for item in written[-5:]:
    r = item[0]
    print(
        r,
        "CB=", verify_ws[f"CB{r}"].value,
        "CC=", verify_ws[f"CC{r}"].value,
        "CD=", verify_ws[f"CD{r}"].value,
        "CE=", verify_ws[f"CE{r}"].value,
    )

output_spreadsheet = output_path
```
