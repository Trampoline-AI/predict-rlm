5. Re-open and verify that `Numbers` matches `Manual Result` in the meaningful output range.
Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import math, os

input_path = Path(input_spreadsheet)
output_path = Path("/sandbox/output/output_spreadsheet") / input_path.name

wb = load_workbook(input_path)
raw = wb["Raw Data"]
numbers = wb["Numbers"]
manual = wb["Manual Result"]

# Collect whole numbers in column-major order from A:F
whole_numbers_col_major = []
for c in range(1, 7):  # A to F
    for r in range(1, raw.max_row + 1):
        v = raw.cell(r, c).value
        if isinstance(v, int):
            whole_numbers_col_major.append(int(v))
        elif isinstance(v, float) and v.is_integer():
            whole_numbers_col_major.append(int(v))

print("Whole numbers count (column-major):", len(whole_numbers_col_major))
print("First 20:", whole_numbers_col_major[:20])

# Clear Numbers sheet contents
for row in numbers.iter_rows():
    for cell in row:
        cell.value = None

# Write max 6 numbers per row
for idx, val in enumerate(whole_numbers_col_major):
    out_row = idx // 6 + 1
    out_col = idx % 6 + 1
    numbers.cell(row=out_row, column=out_col).value = val

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Verify by re-opening
check_wb = load_workbook(output_path, data_only=True)
check_numbers = check_wb["Numbers"]
check_manual = check_wb["Manual Result"]

# Determine expected rows based on count
expected_rows = math.ceil(len(whole_numbers_col_major) / 6)

# Compare Numbers to Manual Result in first 6 columns / expected rows
mismatches = []
for r in range(1, expected_rows + 1):
    for c in range(1, 7):
        num_v = check_numbers.cell(r, c).value
        man_v = check_manual.cell(r, c).value
        if num_v != man_v:
            mismatches.append((r, c, num_v, man_v))

print("Expected rows:", expected_rows)
print("Numbers preview:")
for r in range(1, expected_rows + 1):
    print([check_numbers.cell(r, c).value for c in range(1, 7)])

print("Mismatch count vs Manual Result (first 6 cols):", len(mismatches))
if mismatches[:10]:
    print("First mismatches:", mismatches[:10])

final_output_path = str(output_path)
```
