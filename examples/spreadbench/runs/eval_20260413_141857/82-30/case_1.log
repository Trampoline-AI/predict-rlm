from openpyxl import load_workbook
from pathlib import Path
import math, os

# Re-open / use existing workbook
wb = load_workbook(input_spreadsheet)
raw = wb["Raw Data"]
manual = wb["Manual Result"]
numbers = wb["Numbers"]

# Collect raw A:F values and keep only whole numbers, preserving scan order row-wise
vals = []
for r in range(1, raw.max_row + 1):
    for c in range(1, 7):
        v = raw.cell(r, c).value
        is_whole = False
        if isinstance(v, int):
            is_whole = True
        elif isinstance(v, float) and v.is_integer():
            is_whole = True
        vals.append((r, c, v, is_whole))

whole_numbers = [int(v) for (r, c, v, is_whole) in vals if is_whole]

print("Total scanned cells A:F:", len(vals))
print("Whole number count:", len(whole_numbers))
print("First 30 whole numbers:", whole_numbers[:30])

# Inspect Manual Result used range more carefully
nonempty = []
for r in range(1, manual.max_row + 1):
    row_nonempty = []
    for c in range(1, manual.max_column + 1):
        v = manual.cell(r, c).value
        if v is not None:
            row_nonempty.append((c, v))
    if row_nonempty:
        nonempty.append((r, row_nonempty))

print("Manual nonempty rows count:", len(nonempty))
for r, row_nonempty in nonempty[:12]:
    print("Row", r, "count", len(row_nonempty), "first entries", row_nonempty[:15], "last entries", row_nonempty[-5:])

# Build two candidate layouts for first few values
# Candidate 1: 6 per row across columns
cand1 = []
for i in range(0, len(whole_numbers), 6):
    cand1.append(whole_numbers[i:i+6])

# Candidate 2: 6 per column down rows (transpose-like chunks)
cand2 = []
chunk_size = math.ceil(len(whole_numbers)/6)
for i in range(chunk_size):
    row = []
    for j in range(6):
        idx = j*chunk_size + i
        row.append(whole_numbers[idx] if idx < len(whole_numbers) else None)
    cand2.append(row)

print("Candidate 1 first 6 rows:", cand1[:6])
print("Candidate 2 first 6 rows:", cand2[:6])

# Inspect first 15 columns x 9 rows of Manual Result as plain grid
grid = []
for r in range(1, min(9, manual.max_row) + 1):
    row = []
    for c in range(1, min(18, manual.max_column) + 1):
        row.append(manual.cell(r, c).value)
    grid.append(row)
print("Manual 9x18 grid:")
