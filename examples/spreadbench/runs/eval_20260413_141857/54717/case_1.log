import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Validate expected result using the interpreted logic:
# column from S4 matched in row 2, rows from levels in S6:S8 matched in column A
target_header = ws["S4"].value
start_level = ws["S6"].value
end_level = ws["S8"].value

target_col = None
for c in range(1, ws.max_column + 1):
    if ws.cell(2, c).value == target_header:
        target_col = c
        break

start_row = end_row = None
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 1).value == start_level:
        start_row = r
    if ws.cell(r, 1).value == end_level:
        end_row = r

expected_sum = sum(ws.cell(r, target_col).value for r in range(start_row, end_row + 1))
print("Interpreted target column:", target_col, get_column_letter(target_col), "header:", target_header)
print("Matched rows:", start_row, end_row, "for levels", start_level, end_level)
print("Expected sum:", expected_sum)

# Write dynamic formula to S10
formula = '=SUM(INDEX($A:$P,MATCH($S$6,$A:$A,0),MATCH($S$4,$2:$2,0)):INDEX($A:$P,MATCH($S$8,$A:$A,0),MATCH($S$4,$2:$2,0)))'
ws["S10"] = formula

# Preserve nearby numeric/general styling pattern from input cells in column S
ws["S10"].number_format = '#,##0'

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
recalc_status = await recalculate(out_path)
print("Recalc:", recalc_status)

wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Formula in S10:", ws_check["S10"].value)

wb_vals = load_workbook(out_path, data_only=True)
ws_vals = wb_vals[wb_vals.sheetnames[0]]
print("Cached value S10:", ws_vals["S10"].value)

output_spreadsheet = out_path
