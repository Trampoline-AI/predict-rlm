Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Border, Side

# Re-open fresh workbook for modification
wb2 = load_workbook(input_spreadsheet)
test_ws = wb2["Test"]
master_ws = wb2["master"]

def is_yellow(cell):
    fill = cell.fill
    if fill is None or fill.fill_type != "solid":
        return False
    rgb_candidates = [
        fill.fgColor.rgb if getattr(fill.fgColor, "type", None) == "rgb" else None,
        fill.start_color.rgb if getattr(fill.start_color, "type", None) == "rgb" else None,
    ]
    return any(rgb == "FFFFFF00" for rgb in rgb_candidates)

yellow_cells = []
for r in range(1, test_ws.max_row + 1):
    cell = test_ws.cell(r, 1)
    if is_yellow(cell):
        yellow_cells.append((r, cell.value))

print("Yellow cells in Test!A:", yellow_cells)

# Remove blanks
transposed_values = [val for _, val in yellow_cells if val not in (None, "")]
print("Nonblank transposed values:", transposed_values)
print("Count:", len(transposed_values))

# Clear existing row 1 content/styles in master across currently used range and target range
clear_to = max(master_ws.max_column, len(transposed_values))
for c in range(1, clear_to + 1):
    cell = master_ws.cell(1, c)
    cell.value = None
    cell.fill = PatternFill(fill_type=None)
    cell.border = Border()

# Apply requested formatting
yellow_fill = PatternFill(fill_type="solid", fgColor="FFFFFF00")
thin = Side(style="thin", color="000000")
border = Border(left=thin, right=thin, top=thin, bottom=thin)

# Write transposed values into row 1
for idx, val in enumerate(transposed_values, start=1):
    cell = master_ws.cell(1, idx)
    cell.value = val
    cell.fill = yellow_fill
    cell.border = border

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb2.save(output_path)

# Verify by reopening
check_wb = load_workbook(output_path)
check_master = check_wb["master"]
verified_vals = [check_master.cell(1, c).value for c in range(1, len(transposed_values) + 3)]
verified_fills = [check_master.cell(1, c).fill.fgColor.rgb for c in range(1, len(transposed_values) + 1)]
print("Saved to:", output_path)
print("Verified master row1 values:", verified_vals)
print("Verified fill colors:", verified_fills)
print("Verified dimensions:", check_master.max_row, check_master.max_column)

output_spreadsheet = output_path
```
