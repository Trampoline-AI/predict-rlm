from openpyxl import load_workbook
import os, json, math

print("input_spreadsheet:", input_spreadsheet)
print("instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\nSheet: {ws.title}")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # Print a compact view of the used range
    for r in range(1, min(ws.max_row, 20) + 1):
        vals = []
        for c in range(1, min(ws.max_column, 8) + 1):
            vals.append(ws.cell(r, c).value)
        print(r, vals)
    # Find formulas
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print("Formulas found:", formulas[:20], "count:", len(formulas))
