import os, shutil, re
from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\nSheet: {ws.title!r}, rows={ws.max_row}, cols={ws.max_column}")
    sample = []
    for row in ws.iter_rows(min_row=1, max_row=min(12, ws.max_row), min_col=1, max_col=min(8, ws.max_column)):
        for cell in row:
            if cell.value is not None:
                sample.append(f"{cell.coordinate}={cell.value!r}")
    print("Top sample:", sample[:25])

# Try to find likely dashboard sheet by normalized title
norm_map = {re.sub(r'[^a-z0-9]+', '', ws.title.lower()): ws.title for ws in wb.worksheets}
print("\nNormalized sheet map:", norm_map)

candidate = None
for key, title in norm_map.items():
    if "dashboard" in key or "dash" in key:
        candidate = title
        break

print("Candidate dashboard sheet:", candidate)
if candidate:
    ws = wb[candidate]
    for coord in ["B5", "B6", "B8", "A5", "A6", "A8", "C5", "C6", "C8"]:
        c = ws[coord]
        print(coord, "value=", c.value, "numfmt=", c.number_format, "datatype=", c.data_type)
