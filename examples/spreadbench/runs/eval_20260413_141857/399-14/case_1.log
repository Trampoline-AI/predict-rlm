Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import Font
from copy import copy
import os, math

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb2 = load_workbook(infile)
ws = wb2[wb2.sheetnames[0]]

def is_number(x):
    return isinstance(x, (int, float)) and not isinstance(x, bool)

def is_whole_number(x):
    if not is_number(x):
        return False
    return abs(float(x) - round(float(x))) < 1e-9

# Apply 等线 font throughout used range, preserving other font attributes.
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        existing = cell.font if cell.font is not None else Font()
        cell.font = copy(existing)
        cell.font = cell.font.copy(name="等线")

# Split REG/OT hours in columns N/O for rows below header
changes = []
for r in range(7, ws.max_row + 1):
    ncell = ws[f"N{r}"]
    ocell = ws[f"O{r}"]
    val = ncell.value
    if is_number(val):
        fv = float(val)
        if fv > 40:
            overtime = fv - 40
            ncell.value = 40 if abs(40 - round(40)) < 1e-9 else 40.0
            ocell.value = overtime
            changes.append((r, val, ncell.value, ocell.value))

# Apply requested number formatting to N, O, P
for col in ["N", "O", "P"]:
    for r in range(1, ws.max_row + 1):
        cell = ws[f"{col}{r}"]
        v = cell.value
        if is_number(v):
            if is_whole_number(v):
                cell.number_format = "General"
            else:
                cell.number_format = "#,##0.##"

wb2.save(outfile)

# Verify by reopening
verify_wb = load_workbook(outfile)
verify_ws = verify_wb[verify_wb.sheetnames[0]]

print("Saved to:", outfile)
print("Changes made:", len(changes))
print("First few changes:", changes[:10])

for r in [7, 12, 15, 16, 17, 18, 19, 20, 21, 22, 23]:
    print(
        r,
        "N=", verify_ws[f"N{r}"].value,
        "O=", verify_ws[f"O{r}"].value,
        "P=", verify_ws[f"P{r}"].value,
        "fmtN=", verify_ws[f"N{r}"].number_format,
        "fmtO=", verify_ws[f"O{r}"].number_format,
        "fmtP=", verify_ws[f"P{r}"].number_format,
        "font=", verify_ws[f"N{r}"].font.name
    )

output_spreadsheet = outfile
```
