So the task appears to be filling in the missing/needed values in `WHP` from `WHP DATA`. I’ll build a lookup from the data sheet, populate rows in `WHP` where a site name exists in column C, save to the output path with the same filename, recalculate, and verify the results by reopening the file.
Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
ws_whp = wb["WHP"]
ws_data = wb["WHP DATA"]

# Build lookup from WHP DATA using headers on row 3 / row 21-like section starts.
# In practice, site rows are those with a name in col B and numeric/text values in C:E,
# excluding rows labeled Total or header rows.
lookup = {}
for r in range(1, ws_data.max_row + 1):
    site = ws_data.cell(r, 2).value
    eeg = ws_data.cell(r, 3).value
    dis = ws_data.cell(r, 4).value
    ltu = ws_data.cell(r, 5).value
    if site and site != "Total" and site not in ("Go Live 1/3/18", "Local London Partnership", "Central London Forward"):
        # Only accept rows that look like site data rows
        if eeg is not None or dis is not None or ltu is not None:
            lookup[str(site).strip()] = {"EEG": eeg, "Dis": dis, "LTU": ltu}

print("Lookup:", lookup)

# Populate WHP rows based on site names in column C
updated_rows = []
for r in range(7, ws_whp.max_row + 1):
    site = ws_whp.cell(r, 3).value
    if site is None:
        continue
    site_key = str(site).strip()
    if site_key in lookup:
        ws_whp.cell(r, 5).value = lookup[site_key]["EEG"]
        ws_whp.cell(r, 6).value = lookup[site_key]["Dis"]
        ws_whp.cell(r, 7).value = lookup[site_key]["LTU"]
        updated_rows.append((r, site_key, lookup[site_key]))

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas and verify output
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_verify = load_workbook(outfile, data_only=False)
ws_verify = wb_verify["WHP"]
print("Updated rows in formula view:")
for r, site, vals in updated_rows:
    print(r, site, [ws_verify.cell(r, c).value for c in range(3, 9)])

wb_verify_vals = load_workbook(outfile, data_only=True)
ws_verify_vals = wb_verify_vals["WHP"]
print("Updated rows in data_only view:")
for r, site, vals in updated_rows:
    print(r, site, [ws_verify_vals.cell(r, c).value for c in range(3, 9)])
```
