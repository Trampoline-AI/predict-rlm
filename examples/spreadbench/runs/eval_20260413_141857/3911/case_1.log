from openpyxl import load_workbook
from pathlib import Path
from functools import lru_cache

wb = load_workbook(input_spreadsheet)
ws = wb["denomination"]

employee_rows = list(range(2, 9))
salaries = [ws[f"E{r}"].value for r in employee_rows]
emp_names = [ws[f"C{r}"].value for r in employee_rows]

denoms = [ws.cell(1, c).value for c in range(8, 17)]  # H:P
avail = []
for r in range(13, 22):
    cnt = ws[f"D{r}"].value
    avail.append(0 if cnt is None else int(cnt))

print("Employees:", list(zip(employee_rows, emp_names, salaries)))
print("Denoms:", denoms)
print("Avail:", avail, "total notes", sum(avail), "total amount", sum(d*c for d,c in zip(denoms, avail)))
print("Total salaries:", sum(salaries))

# sort employees by salary descending to make search easier, but map back later
order = sorted(range(len(salaries)), key=lambda i: salaries[i], reverse=True)
ordered_salaries = [salaries[i] for i in order]
ordered_names = [emp_names[i] for i in order]
print("Search order:", list(zip(ordered_names, ordered_salaries)))

# Precompute possible allocations for a target given upper bounds, using DFS with pruning
def find_employee_allocations(target, counts):
    den = tuple(denoms)
    counts = tuple(counts)
    out = []

    def dfs(i, rem, cur):
        if i == len(den):
            if rem == 0:
                out.append(tuple(cur))
            return
        d = den[i]
        max_use = min(counts[i], rem // d)
        for x in range(max_use, -1, -1):
            # lower denominations max possible pruning
            new_rem = rem - x * d
            max_possible = sum(den[j] * counts[j] for j in range(i + 1, len(den)))
            if new_rem > max_possible:
                continue
            cur.append(x)
            dfs(i + 1, new_rem, cur)
            cur.pop()

    dfs(0, target, [])
    # Prefer solutions using larger notes
    return out

# memoized backtracking over employees
from functools import lru_cache

@lru_cache(None)
def solve(idx, counts):
    counts = tuple(counts)
    if idx == len(ordered_salaries):
        return () if all(c == 0 for c in counts) else None

    target = ordered_salaries[idx]
    sols = find_employee_allocations(target, counts)
    # try more "greedy" larger-note allocations first
    sols.sort(reverse=True)
    for alloc in sols:
        new_counts = tuple(counts[i] - alloc[i] for i in range(len(counts)))
        res = solve(idx + 1, new_counts)
        if res is not None:
            return (alloc,) + res
    return None

solution = solve(0, tuple(avail))
print("Found solution?", solution is not None)
if solution:
    for name, sal, alloc in zip(ordered_names, ordered_salaries, solution):
        print(name, sal, alloc, sum(a*d for a,d in zip(alloc, denoms)))
