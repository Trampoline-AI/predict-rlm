import os
import copy
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Sheet1"]

max_row = ws.max_row
max_col = ws.max_column
count_col = 33  # AG
key_col = 1     # A

# Find last row with data in column A
last_data_row = 1
for r in range(2, max_row + 1):
    if ws.cell(r, key_col).value not in (None, ""):
        last_data_row = r

print("Original rows/cols:", max_row, max_col)
print("Last data row in col A:", last_data_row)

# Snapshot source rows (values + formatting)
source_rows = []
for r in range(1, last_data_row + 1):
    row_cells = []
    for c in range(1, max_col + 1):
        cell = ws.cell(r, c)
        row_cells.append({
            "value": cell.value,
            "font": copy.copy(cell.font),
            "fill": copy.copy(cell.fill),
            "border": copy.copy(cell.border),
            "alignment": copy.copy(cell.alignment),
            "number_format": cell.number_format,
            "protection": copy.copy(cell.protection),
            "has_style": cell.has_style,
        })
    source_rows.append(row_cells)

# Create output rows: header once, then each data row repeated AG times
expanded_rows = [source_rows[0]]

repeat_debug = []
for r in range(2, last_data_row + 1):
    row_data = source_rows[r - 1]
    raw_count = row_data[count_col - 1]["value"]
    try:
        repeat_n = int(raw_count) if raw_count not in (None, "") else 1
    except Exception:
        repeat_n = 1
    if repeat_n < 1:
        repeat_n = 1
    repeat_debug.append((r, row_data[0]["value"], raw_count, repeat_n))
    for _ in range(repeat_n):
        expanded_rows.append(row_data)

print("Sample repeat decisions:", repeat_debug[:10])
print("Expanded total rows including header:", len(expanded_rows))

# Write back in place
for r_idx, row_data in enumerate(expanded_rows, start=1):
    for c_idx, cell_data in enumerate(row_data, start=1):
        out_cell = ws.cell(r_idx, c_idx)
        out_cell.value = cell_data["value"]
        if cell_data["has_style"]:
            out_cell.font = copy.copy(cell_data["font"])
            out_cell.fill = copy.copy(cell_data["fill"])
            out_cell.border = copy.copy(cell_data["border"])
            out_cell.alignment = copy.copy(cell_data["alignment"])
            out_cell.number_format = cell_data["number_format"]
            out_cell.protection = copy.copy(cell_data["protection"])

# Clear any leftover old rows below the new dataset
for r in range(len(expanded_rows) + 1, max_row + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = None

# Preserve column widths
for key, dim in ws.column_dimensions.items():
    pass  # existing dimensions remain on worksheet

wb.save(output_path)
print("Saved to:", output_path)

# Verify by reopening and checking counts / sample AG results
wb2 = load_workbook(output_path)
ws2 = wb2["Sheet1"]
print("Verified rows/cols:", ws2.max_row, ws2.max_column)
for r in range(1, min(ws2.max_row, 15) + 1):
    print(r, ws2.cell(r, 1).value, ws2.cell(r, count_col).value)
