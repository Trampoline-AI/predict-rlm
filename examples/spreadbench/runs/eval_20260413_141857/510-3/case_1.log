from openpyxl import load_workbook
from copy import copy
from pathlib import Path
import os, re

infile = input_spreadsheet
outfile = str(Path("/sandbox/output/output_spreadsheet") / Path(infile).name)

wb = load_workbook(infile)
old_ws = wb["Data"]
sheet_index = wb.sheetnames.index("Data")

# Snapshot all cell content/style data before removing the sheet
cell_data = {}
for row in old_ws.iter_rows():
    for cell in row:
        cell_data[(cell.row, cell.column)] = {
            "value": cell.value,
            "style": copy(cell._style),
            "number_format": cell.number_format,
            "font": copy(cell.font),
            "fill": copy(cell.fill),
            "border": copy(cell.border),
            "alignment": copy(cell.alignment),
            "protection": copy(cell.protection),
        }

# Snapshot dimensions and sheet properties
col_dims = {}
for key, dim in old_ws.column_dimensions.items():
    col_dims[key] = {
        "width": dim.width,
        "hidden": dim.hidden,
        "bestFit": dim.bestFit,
        "min": dim.min,
        "max": dim.max,
        "style": dim.style,
    }

row_dims = {}
for key, dim in old_ws.row_dimensions.items():
    row_dims[key] = {
        "height": dim.height,
        "hidden": dim.hidden,
        "outlineLevel": dim.outlineLevel,
        "collapsed": dim.collapsed,
        "style": dim.style,
    }

max_row, max_col = old_ws.max_row, old_ws.max_column
sheet_view = copy(old_ws.sheet_view)
sheet_format = copy(old_ws.sheet_format)
page_margins = copy(old_ws.page_margins)
page_setup = copy(old_ws.page_setup)
print_options = copy(old_ws.print_options)

# Remove and recreate sheet
wb.remove(old_ws)
new_ws = wb.create_sheet("Data", sheet_index)

# Restore sheet-level settings
new_ws.sheet_view = sheet_view
new_ws.sheet_format = sheet_format
new_ws.page_margins = page_margins
new_ws.page_setup = page_setup
new_ws.print_options = print_options

# Restore dimensions
for key, info in col_dims.items():
    d = new_ws.column_dimensions[key]
    d.width = info["width"]
    d.hidden = info["hidden"]
    d.bestFit = info["bestFit"]
    d.min = info["min"]
    d.max = info["max"]
    d.style = info["style"]

for key, info in row_dims.items():
    d = new_ws.row_dimensions[key]
    d.height = info["height"]
    d.hidden = info["hidden"]
    d.outlineLevel = info["outlineLevel"]
    d.collapsed = info["collapsed"]
    d.style = info["style"]

def parse_ymd(val):
    s = "" if val is None else str(val)
    nums = re.findall(r"\d+", s)
    if len(nums) >= 3:
        return int(nums[0]), int(nums[1]), int(nums[2])
    return None, None, None

# Rewrite cells, fixing E:H
for r in range(1, max_row + 1):
    for c in range(1, max_col + 1):
        src = cell_data[(r, c)]
        cell = new_ws.cell(r, c)
        cell._style = copy(src["style"])
        
        # Copy all original values first
        cell.value = src["value"]
        
        # Explicitly preserve exact number formatting in D:G
        if 4 <= c <= 7:
            cell.number_format = src["number_format"]

    # Header row: ensure not bold
    if r == 1:
        for c in range(4, 9):
            new_ws.cell(r, c).font = copy(new_ws.cell(r, c).font.copy(bold=False) if hasattr(new_ws.cell(r, c).font, "copy") else new_ws.cell(r, c).font)

    # Data rows: parse D and hardcode numeric Year/Month/Day/Sum
    if r >= 2:
        y, m, d = parse_ymd(cell_data[(r, 4)]["value"])
        if y is not None:
            new_ws.cell(r, 5).value = y
            new_ws.cell(r, 6).value = m
            new_ws.cell(r, 7).value = d
            new_ws.cell(r, 8).value = y * 365 + m * 12 + d

            # Preserve exact number formatting for D:G from original cells
            for c in range(4, 8):
                new_ws.cell(r, c).number_format = cell_data[(r, c)]["number_format"]

# Ensure header row D:H are not bold
for c in range(4, 9):
    hdr = new_ws.cell(1, c)
    hdr.font = copy(hdr.font)
    hdr.font = hdr.font.copy(bold=False)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Verify output
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb["Data"]
print("Verify rows 1-8, cols D:H")
for r in range(1, 9):
    print(r, [check_ws.cell(r, c).value for c in range(4, 9)])

print("Header bold states D:H:", [check_ws.cell(1, c).font.bold for c in range(4, 9)])
print("Number formats D:G row2:", [check_ws.cell(2, c).number_format for c in range(4, 8)])
print("Types row2 E:H:", [check_ws.cell(2, c).data_type for c in range(5, 9)])
print("Last rows 72-78 D:H")
for r in range(72, 79):
    print(r, [check_ws.cell(r, c).value for c in range(4, 9)])
