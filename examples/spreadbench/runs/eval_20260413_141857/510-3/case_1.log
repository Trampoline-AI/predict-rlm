outfile = str(Path("/sandbox/output/output_spreadsheet") / Path(infile).name)

wb = load_workbook(infile)
ws = wb["Data"]
sheet_index = wb.sheetnames.index("Data")

# Snapshot cells
cell_data = {}
for row in ws.iter_rows():
    for cell in row:
        cell_data[(cell.row, cell.column)] = {
            "value": cell.value,
            "style": copy(cell._style),
            "numfmt": cell.number_format,
        }

max_row, max_col = ws.max_row, ws.max_column

# Snapshot dimensions
col_info = {}
for col in range(1, max_col + 1):
    letter = ws.cell(1, col).column_letter
    dim = ws.column_dimensions[letter]
    col_info[letter] = {"width": dim.width, "hidden": dim.hidden}

row_info = {}
for r in range(1, max_row + 1):
    dim = ws.row_dimensions[r]
    row_info[r] = {"height": dim.height, "hidden": dim.hidden}

def parse_ymd(val):
    s = "" if val is None else str(val)
    nums = re.findall(r"\d+", s)
    if len(nums) >= 3:
        return int(nums[0]), int(nums[1]), int(nums[2])
    return None, None, None

# Recreate sheet
wb.remove(ws)
new_ws = wb.create_sheet("Data", sheet_index)

# Restore dimensions
for letter, info in col_info.items():
    new_ws.column_dimensions[letter].width = info["width"]
    new_ws.column_dimensions[letter].hidden = info["hidden"]

for r, info in row_info.items():
    new_ws.row_dimensions[r].height = info["height"]
    new_ws.row_dimensions[r].hidden = info["hidden"]

# Restore cells and apply fixes
for r in range(1, max_row + 1):
    for c in range(1, max_col + 1):
        src = cell_data[(r, c)]
        cell = new_ws.cell(r, c)
        cell._style = copy(src["style"])
        cell.value = src["value"]
        if 4 <= c <= 7:
            cell.number_format = src["numfmt"]

# Fix header font boldness D:H
for c in range(4, 9):
    cell = new_ws.cell(1, c)
    f = copy(cell.font)
    f.bold = False
    cell.font = f

# Parse D and hardcode E:F:G:H
