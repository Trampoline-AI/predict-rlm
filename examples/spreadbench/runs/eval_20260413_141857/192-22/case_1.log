Code:
```repl
from openpyxl import load_workbook
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

keywords = [
    "Core Activation",
    "Core Design",
    "Mobile Terminology",
    "Mobile Design",
    "Mobile Integration",
    "Testing Layer",
    "Testing Offshore",
    "Carrier",
    "Barrier",
]
keywords_lower = [k.lower() for k in keywords]

wb = load_workbook(input_path)
ws = wb["Sheet1"]

match_rows = []
nonblank_d_rows = 0

for r in range(2, ws.max_row + 1):  # keep header row as-is
    d_val = ws.cell(r, 4).value
    f_cell = ws.cell(r, 6)
    if d_val not in (None, ""):
        nonblank_d_rows += 1
        text = str(d_val).lower()
        matched = any(k in text for k in keywords_lower)
        if matched:
            f_cell.value = "Billing PO"
            match_rows.append((r, d_val))
        else:
            f_cell.value = None
    else:
        f_cell.value = None

wb.save(output_path)

# Verify by reopening
wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Sheet1"]

verified_matches = []
for r in range(2, ws_check.max_row + 1):
    d_val = ws_check.cell(r, 4).value
    f_val = ws_check.cell(r, 6).value
    if f_val == "Billing PO":
        verified_matches.append((r, d_val, f_val))

print("Saved to:", output_path)
print("Nonblank D rows scanned:", nonblank_d_rows)
print("Billing PO rows:", len(verified_matches))
print("First 20 matches:")
for row in verified_matches[:20]:
    print(row)

print("Sample rows 2-20, D/F after update:")
for r in range(2, min(20, ws_check.max_row) + 1):
    print(r, ws_check.cell(r,4).value, "=>", ws_check.cell(r,6).value)
```
