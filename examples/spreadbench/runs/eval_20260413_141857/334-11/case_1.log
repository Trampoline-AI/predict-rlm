from openpyxl import Workbook, load_workbook
from pathlib import Path

input_path = Path(input_spreadsheet)
output_path = Path("/sandbox/output/output_spreadsheet") / input_path.name

# Read source workbook and gather filtered rows
src_wb = load_workbook(input_path)
src_ws = src_wb["imported Data"]
original_rows = [[cell.value for cell in row] for row in src_ws.iter_rows()]

kept_values = []
for i, vals in enumerate(original_rows, start=1):
    if i == 1:
        kept_values.append(vals)
        continue
    c_val = vals[2] if len(vals) >= 3 else None
    if c_val is None or (isinstance(c_val, str) and c_val.strip() == ""):
        continue
    if isinstance(c_val, (int, float)) and -1 <= c_val <= 1:
        continue
    kept_values.append(vals)

# Create a fresh workbook to avoid trailing blank rows
out_wb = Workbook()
out_ws = out_wb.active
out_ws.title = "imported Data"

for r_idx, vals in enumerate(kept_values, start=1):
    for c_idx, val in enumerate(vals, start=1):
        out_ws.cell(row=r_idx, column=c_idx, value=val)

out_wb.save(output_path)

# Verify
check_wb = load_workbook(output_path)
check_ws = check_wb["imported Data"]
verified_rows = list(check_ws.iter_rows(values_only=True))

print("Saved to:", output_path)
print("Dimensions:", check_ws.max_row, check_ws.max_column)
for r in verified_rows:
