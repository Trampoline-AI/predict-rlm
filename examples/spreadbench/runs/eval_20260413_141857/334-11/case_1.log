# Read all rows
rows = list(ws.iter_rows(values_only=False))

# Keep header row, then filter data rows by Column C
kept_values = []
for i, row in enumerate(rows, start=1):
    vals = [cell.value for cell in row]
    if i == 1:
        kept_values.append(vals)
        continue

    c_val = vals[2] if len(vals) >= 3 else None

    # Delete if Column C is blank
    if c_val is None or (isinstance(c_val, str) and c_val.strip() == ""):
        continue

    # Delete if numeric and between -1 and 1 inclusive
    if isinstance(c_val, (int, float)) and -1 <= c_val <= 1:
        continue

    kept_values.append(vals)

# Clear existing sheet contents
for row in ws.iter_rows():
    for cell in row:
        cell.value = None

# Write filtered values back
for r_idx, vals in enumerate(kept_values, start=1):
    for c_idx, val in enumerate(vals, start=1):
        ws.cell(r=r_idx, column=c_idx, value=val)

# Save
wb.save(output_path)

# Verify
check_wb = load_workbook(output_path)
check_ws = check_wb["imported Data"]
result_rows = list(check_ws.iter_rows(values_only=True))

print("Saved to:", output_path)
