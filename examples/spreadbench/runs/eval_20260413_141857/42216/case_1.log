```repl
import os
from copy import copy
from datetime import date, datetime, timedelta
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb2 = load_workbook(infile)
ws = wb2["Sheet1"]

# Helper to copy row styles from a source row to a destination row for relevant columns
def copy_row_style(ws, src_row, dst_row, max_col):
    for c in range(1, max_col + 1):
        src = ws.cell(src_row, c)
        dst = ws.cell(dst_row, c)
        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.font:
            dst.font = copy(src.font)
        if src.fill:
            dst.fill = copy(src.fill)
        if src.border:
            dst.border = copy(src.border)
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.protection:
            dst.protection = copy(src.protection)

# 1) Insert April row in Group A between 1951-03 and 1951-05
month_labels = {ws.cell(r, 1).value: r for r in range(1, ws.max_row + 1)}
if "1951-04" not in month_labels:
    insert_at = month_labels["1951-05"]  # insert before May
    ws.insert_rows(insert_at, 1)
    # copy style from March row (now still above insert location)
    copy_row_style(ws, insert_at - 1, insert_at, ws.max_column)
    ws.cell(insert_at, 1).value = "1951-04"
    # Only for April row, zeros should remain blank in Group A: use blanks for all days
    for c in range(2, 33):
        ws.cell(insert_at, c).value = None

# Recompute month row lookup after insertion
month_row = {ws.cell(r, 1).value: r for r in range(1, ws.max_row + 1) if ws.cell(r, 1).value}

# Build a lookup from YYYY-MM to list of day values (1..31)
group_a = {}
for ym, r in month_row.items():
    if isinstance(ym, str) and ym.startswith("1951-") and len(ym) == 7:
        group_a[ym] = [ws.cell(r, c).value for c in range(2, 33)]

def group_b_value(raw):
    # Irrelevant / excluded values -> blank
    if raw is None:
        return 0
    if isinstance(raw, str):
        t = raw.strip()
        if t in {"M", "NA", ""}:
            return None if t == "NA" else None if t == "M" else 0
        # numeric sentinels stored as text
        if t.startswith("-9999"):
            return None
        return raw
    if isinstance(raw, (int, float)):
        if raw <= -9999:
            return None
        return raw
    return raw

# 2) Rebuild Group B dates/data from 1951-01-01 to 1951-11-16 inclusive
start_row = 19
start_date = date(1951, 1, 1)
end_date = date(1951, 11, 16)

# Reference styles from existing first Group B data row
ref_row = 19
date_style = copy(ws.cell(ref_row, 1)._style)
data_style = copy(ws.cell(ref_row, 2)._style)
date_numfmt = ws.cell(ref_row, 1).number_format
data_numfmt = ws.cell(ref_row, 2).number_format

cur = start_date
row = start_row
written = []

while cur <= end_date:
    ym = cur.strftime("%Y-%m")
    day = cur.day
    raw = None
    if ym in group_a:
        raw = group_a[ym][day - 1]
    val = group_b_value(raw)

    # write date
    ws.cell(row, 1).value = datetime(cur.year, cur.month, cur.day)
    ws.cell(row, 1)._style = copy(date_style)
    ws.cell(row, 1).number_format = date_numfmt or "mm-dd-yy"

    # write data
    ws.cell(row, 2).value = val
    ws.cell(row, 2)._style = copy(data_style)
    if data_numfmt:
        ws.cell(row, 2).number_format = data_numfmt

    # clear extra columns in the used area for these output rows
    for c in range(3, min(ws.max_column, 8) + 1):
        ws.cell(row, c).value = None

    written.append((row, cur, raw, val))
    cur += timedelta(days=1)
    row += 1

# Clear any leftover old Group B rows below the new end, within current used range
for r in range(row, ws.max_row + 1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        ws.cell(r, 1).value = None
        ws.cell(r, 2).value = None

wb2.save(outfile)

# Verification
check = load_workbook(outfile)
cws = check["Sheet1"]

# find April row
april_row = None
for r in range(1, cws.max_row + 1):
    if cws.cell(r, 1).value == "1951-04":
        april_row = r
        break

april_vals = [cws.cell(april_row, c).value for c in range(2, 33)] if april_row else None
group_b_last_nonempty = max(r for r in range(1, cws.max_row + 1) if cws.cell(r, 1).value is not None)
print("Saved to:", outfile)
print("April row:", april_row)
print("April nonblank count in B:AF:", sum(v is not None for v in april_vals) if april_vals is not None else None)
print("Group B first rows:", [(r, cws.cell(r,1).value, cws.cell(r,2).value) for r in range(19, 25)])
print("Group B sample around Apr 1:", [(r, cws.cell(r,1).value, cws.cell(r,2).value) for r in range(109, 114)])
print("Group B sample around Jul 12 / Sep 5 / Oct 15:", [(r, cws.cell(r,1).value, cws.cell(r,2).value) for r in [210, 265, 305]])
print("Group B last nonempty row/date/data:", group_b_last_nonempty, cws.cell(group_b_last_nonempty,1).value, cws.cell(group_b_last_nonempty,2).value)
```
