from openpyxl import load_workbook
from openpyxl.utils.datetime import from_excel
from datetime import datetime

verify_wb = load_workbook(outfile, data_only=False)
vws = verify_wb["Sheet1"]

def display_date(val):
    if isinstance(val, datetime):
        return val.date().isoformat()
    if isinstance(val, (int, float)):
        try:
            return from_excel(val).date().isoformat()
        except Exception:
            return f"nondate:{val}"
    return str(val)

checks = {
    "Apr_1": 19 + (datetime(1951,4,1) - datetime(1951,1,1)).days,
    "Jul_12": 19 + (datetime(1951,7,12) - datetime(1951,1,1)).days,
    "Sep_5": 19 + (datetime(1951,9,5) - datetime(1951,1,1)).days,
    "Oct_15": 19 + (datetime(1951,10,15) - datetime(1951,1,1)).days,
    "Nov_16": 19 + (datetime(1951,11,16) - datetime(1951,1,1)).days,
    "Feb_28": 19 + (datetime(1951,2,28) - datetime(1951,1,1)).days,
    "Mar_1": 19 + (datetime(1951,3,1) - datetime(1951,1,1)).days,
}

print("Verification rows:")
for name, r in checks.items():
    dv = vws.cell(r,1).value
    xv = vws.cell(r,2).value
    print(name, r, display_date(dv), xv, "numfmt:", vws.cell(r,1).number_format)

# Verify specific Group A row content for April
april_row = next(r for r in range(1, vws.max_row + 1) if vws.cell(r,1).value == "1951-04")
print("April row index:", april_row)
print("April row all blank B:AF?", all(vws.cell(april_row,c).value is None for c in range(2,33)))

# Verify last nonempty Group B row
last_nonempty = max(r for r in range(1, vws.max_row + 1) if vws.cell(r,1).value is not None)
print("Last nonempty row:", last_nonempty, display_date(vws.cell(last_nonempty,1).value), vws.cell(last_nonempty,2).value)

# Show saved file exists and size
import os
print("Exists:", os.path.exists(outfile), "size:", os.path.getsize(outfile))
