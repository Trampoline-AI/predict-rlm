```repl
import os, shutil
from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet)
ws_op = wb["Opportunities"]
ws_data = wb["Data"]

print("Defined names:")
try:
    for name, defn in wb.defined_names.items():
        try:
            target = defn.attr_text
        except Exception:
            target = str(defn)
        print(" -", name, "=>", target)
except Exception as e:
    print("Could not iterate defined names:", e)

print("\nTarget cell formats:")
for coord in ["D2", "E2", "F2", "G2", "D3", "E3", "F3", "G3"]:
    cell = ws_op[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

# Determine mapping extent on Data sheet
mapping_last_row = 0
for r in range(1, ws_data.max_row + 1):
    a = ws_data.cell(r, 1).value
    b = ws_data.cell(r, 2).value
    if a is not None and b is not None:
        mapping_last_row = r
print("\nMapping last row:", mapping_last_row)

# Determine last meaningful row in Opportunities
last_used = 1
for r in range(1, ws_op.max_row + 1):
    if any(ws_op.cell(r, c).value is not None for c in range(1, 8)):
        last_used = r
print("Last used row in Opportunities:", last_used)

# Fill formulas from row 2 through 1000 so future entries also work
for r in range(2, ws_op.max_row + 1):
    ws_op.cell(r, 6).value = f'=IFERROR(VLOOKUP(D{r},Data!$A$1:$B${mapping_last_row},2,FALSE),"")'
    ws_op.cell(r, 7).value = f'=IF(OR(E{r}="",F{r}=""),"",E{r}*F{r})'

# Apply sensible number formats matching purpose
for r in range(2, ws_op.max_row + 1):
    ws_op.cell(r, 6).number_format = '0%'
    ws_op.cell(r, 7).number_format = '£#,##0.00'

# Save output
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Opportunities"]
print("Formulas F2:G3:", ws_check["F2"].value, ws_check["G2"].value, ws_check["F3"].value, ws_check["G3"].value)

wb_vals = load_workbook(output_path, data_only=True)
ws_vals = wb_vals["Opportunities"]
print("Values F2:G3:", ws_vals["F2"].value, ws_vals["G2"].value, ws_vals["F3"].value, ws_vals["G3"].value)

output_spreadsheet = output_path
```
