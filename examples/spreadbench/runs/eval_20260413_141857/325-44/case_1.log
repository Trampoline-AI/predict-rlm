Code:
```repl
import os, re, shutil
from itertools import product
from openpyxl import load_workbook

# Re-open fresh workbook
wb = load_workbook(input_spreadsheet)
ws_in = wb["Input"]
ws_out = wb["Output"]

# Inspect all current output rows for pattern confirmation
existing_output = []
for r in range(1, ws_out.max_row + 1):
    existing_output.append([ws_out.cell(r, c).value for c in range(1, ws_out.max_column + 1)])
print("Existing Output rows:")
for i, row in enumerate(existing_output, start=1):
    print(i, row)

def normalize_token(token):
    token = str(token).strip().strip('"').strip("'")
    if token == "":
        return None
    # Omit leading zeros for purely numeric tokens
    if re.fullmatch(r"\d+", token):
        return int(token)
    return token

def parse_filter(filter_text):
    result = {}
    if not filter_text:
        return result
    
    # Matches ("field" = "value")
    for field, value in re.findall(r'\("([^"]+)"\s*=\s*"([^"]*)"\)', filter_text):
        result[field] = normalize_token(value)
    
    # Matches ("field" IN LIST 1,2,03)
    for field, values in re.findall(r'\("([^"]+)"\s+IN\s+LIST\s+([^)]+)\)', filter_text):
        parts = [normalize_token(x) for x in values.split(",")]
        parts = [p for p in parts if p is not None]
        result[field] = parts
    return result

headers = [ws_out.cell(1, c).value for c in range(1, ws_out.max_column + 1)]
print("Output headers:", headers)

# Build transformed rows from Input
new_rows = []
for r in range(2, ws_in.max_row + 1):
    wtype_id = ws_in.cell(r, 1).value
    name = ws_in.cell(r, 2).value
    status = ws_in.cell(r, 3).value
    filter_text = ws_in.cell(r, 4).value
    
    parsed = parse_filter(filter_text)
    orgId = parsed.get("orgId")
    careType = parsed.get("careType")
    specialty_vals = parsed.get("specialtyId", [None])
    context_vals = parsed.get("contextId", [None])
    
    # ensure list form for expansion
    if not isinstance(specialty_vals, list):
        specialty_vals = [specialty_vals]
    if not isinstance(context_vals, list):
        context_vals = [context_vals]
    
    for spec, ctx in product(specialty_vals, context_vals):
        new_rows.append([wtype_id, name, status, orgId, careType, spec, ctx])

print("Generated rows:")
for row in new_rows:
    print(row)

# Clear output sheet data rows
for r in range(2, ws_out.max_row + 1):
    for c in range(1, ws_out.max_column + 1):
        ws_out.cell(r, c).value = None

# Write new rows
for r_idx, row in enumerate(new_rows, start=2):
    for c_idx, val in enumerate(row, start=1):
        ws_out.cell(r_idx, c_idx).value = val

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)

# Verify by reopening
wb_verify = load_workbook(out_path)
ws_verify = wb_verify["Output"]
verified = []
for r in range(1, ws_verify.max_row + 1):
    verified.append([ws_verify.cell(r, c).value for c in range(1, ws_verify.max_column + 1)])
print("Verified output rows:")
for i, row in enumerate(verified, start=1):
    print(i, row)

output_path = out_path
print("Saved to:", output_path)
```
