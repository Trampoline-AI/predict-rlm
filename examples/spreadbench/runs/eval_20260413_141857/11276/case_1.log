Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["ATTENDENCE"]

# Apply weekday formula across F3:AJ3, each referencing the date in row 4 below it.
for col in range(6, 37):  # F to AJ
    col_letter = get_column_letter(col)
    ws.cell(row=3, column=col).value = f'=TEXT({col_letter}4,"DDD")'

wb.save(outfile)

# Verify by reopening and checking formulas
wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check["ATTENDENCE"]

formulas = {f"{get_column_letter(c)}3": ws_check.cell(row=3, column=c).value for c in range(6, 37)}
print("Saved to:", outfile)
print("Verified formula samples:")
for key in ["F3", "G3", "H3", "AI3", "AJ3"]:
    print(key, "->", formulas[key])

# Also confirm row/column metadata briefly
print("Sheet:", ws_check.title, "rows:", ws_check.max_row, "cols:", ws_check.max_column)
```
