from openpyxl import load_workbook
from pathlib import Path
import os

# Load workbook normally so formulas are preserved
infile = Path(input_spreadsheet)
outfile = Path("/sandbox/output/output_spreadsheet") / infile.name

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Write formulas to total cells, including row 4 mapping values as instructed
for col in "FGHI":
    ws[f"{col}25"] = f'=SUMPRODUCT(COUNTIFS($A$5:$A$84,{col}$4:{col}$23,$C$5:$C$84,"x"))'

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate so cached values are available for verification
recalc_result = await recalculate(str(outfile))
print("Recalculate:", recalc_result)

# Verify formulas and values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[wb_formula.sheetnames[0]]
print("Formulas in F25:I25:", [ws_formula[f"{c}25"].value for c in "FGHI"])

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[wb_values.sheetnames[0]]
print("Cached values in F25:I25:", [ws_values[f"{c}25"].value for c in "FGHI"])

output_spreadsheet = str(outfile)
```
