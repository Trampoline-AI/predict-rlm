```repl
from openpyxl import load_workbook
from pathlib import Path
import os

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Determine bounds of the lookup table in columns A:B
start_row = 2
end_row = ws.max_row

# Write formulas into column G for rows having both parameters in E and F
for r in range(start_row, end_row + 1):
    p1 = ws[f"E{r}"].value
    p2 = ws[f"F{r}"].value
    if p1 not in (None, "") and p2 not in (None, ""):
        formula = (
            f'=IFERROR('
            f'INDEX($A$2:$A${end_row},'
            f'MATCH(1,INDEX((ISNUMBER(SEARCH(E{r},$B$2:$B${end_row})))*(ISNUMBER(SEARCH(F{r},$B$2:$B${end_row})),0),0)),'
            f'"")'
        )
        # Corrected formula with properly placed INDEX wrapper
        formula = (
            f'=IFERROR('
            f'INDEX($A$2:$A${end_row},'
            f'MATCH(1,INDEX((ISNUMBER(SEARCH(E{r},$B$2:$B${end_row})))*(ISNUMBER(SEARCH(F{r},$B$2:$B${end_row})),0),0)),'
            f'""'
            f')'
        )
        # Build clean final formula explicitly
        formula = (
            f'=IFERROR(INDEX($A$2:$A${end_row},'
            f'MATCH(1,INDEX((ISNUMBER(SEARCH(E{r},$B$2:$B${end_row})))*'
            f'(ISNUMBER(SEARCH(F{r},$B$2:$B${end_row})),0),0)),"")'
        )
        # Fix parenthesis issue by replacing with the intended standard non-CSE pattern
        formula = (
            f'=IFERROR(INDEX($A$2:$A${end_row},'
            f'MATCH(1,INDEX((ISNUMBER(SEARCH(E{r},$B$2:$B${end_row})))*'
            f'(ISNUMBER(SEARCH(F{r},$B$2:$B${end_row})),0),0)),"")'
        )
        # Final reliable formula:
        formula = (
            f'=IFERROR(INDEX($A$2:$A${end_row},'
            f'MATCH(1,INDEX((ISNUMBER(SEARCH(E{r},$B$2:$B${end_row})))*'
            f'(ISNUMBER(SEARCH(F{r},$B$2:$B${end_row})),0),0)),"")'
        )
        ws[f"G{r}"] = formula
    else:
        ws[f"G{r}"] = None

wb.save(output_path)

# Re-open and correct formulas with a safer construction after save-time syntax review
wb = load_workbook(output_path)
ws = wb[wb.sheetnames[0]]
for r in range(start_row, end_row + 1):
    p1 = ws[f"E{r}"].value
    p2 = ws[f"F{r}"].value
    if p1 not in (None, "") and p2 not in (None, ""):
        ws[f"G{r}"] = (
            f'=IFERROR(INDEX($A$2:$A${end_row},MATCH(1,INDEX('
            f'(ISNUMBER(SEARCH(E{r},$B$2:$B${end_row})))*'
            f'(ISNUMBER(SEARCH(F{r},$B$2:$B${end_row}))),0),0)),"")'
        )
wb.save(output_path)

recalc_result = await recalculate(str(output_path))
print("Recalc:", recalc_result)

# Verify cached results
