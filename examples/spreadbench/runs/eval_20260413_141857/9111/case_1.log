To match the sample, lookup should be case-insensitive (`bob` should match `Bob`). The literal logic is:

1. If B and C are both blank → D blank.
2. Else if B exists in list1 → D = list1 ID.
3. Else if C exists in list2 → D = list2 ID.
4. Else if either there is some input (B or C) but no applicable match → D = 2500.

I’ll implement this with openpyxl, save to the output path with the same filename, reopen to verify key rows, and inspect D values for the target range.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Build lookup dictionaries from list1 (G:H) and list2 (J:K), case-insensitive
list1 = {}
for r in range(2, ws.max_row + 1):
    name = ws.cell(r, 7).value
    idv = ws.cell(r, 8).value
    if isinstance(name, str) and name.strip() != "" and idv is not None:
        list1[name.strip().lower()] = idv

list2 = {}
for r in range(2, ws.max_row + 1):
    name = ws.cell(r, 10).value
    idv = ws.cell(r, 11).value
    if isinstance(name, str) and name.strip() != "" and idv is not None:
        # Skip the stray label row like "List2"
        if str(idv).strip() != "":
            list2[name.strip().lower()] = idv

print("List1:", list1)
print("List2:", list2)

# Fill D for rows in the main table where A has a record number
changes = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    if a is None:
        continue

    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value

    b_key = b.strip().lower() if isinstance(b, str) and b.strip() != "" else None
    c_key = c.strip().lower() if isinstance(c, str) and c.strip() != "" else None

    if b_key is None and c_key is None:
        new_val = ""
    elif b_key is not None and b_key in list1:
        new_val = list1[b_key]
    elif c_key is not None and c_key in list2:
        new_val = list2[c_key]
    else:
        new_val = 2500

    old_val = ws.cell(r, 4).value
    ws.cell(r, 4).value = new_val
    changes.append((r, b, c, old_val, new_val))

wb.save(outfile)

# Verify by reopening
vwb = load_workbook(outfile, data_only=False)
vws = vwb["Sheet1"]

print("Saved to:", outfile)
print("Verification rows A:D (2:20):")
for r in range(2, 21):
    vals = [vws.cell(r, c).value for c in range(1, 5)]
    print(r, vals)
```
