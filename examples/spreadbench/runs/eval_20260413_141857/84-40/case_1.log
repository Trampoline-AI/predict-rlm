Code:
```repl
from openpyxl import load_workbook
from copy import copy
import os

# Re-open workbook
wb = load_workbook(input_spreadsheet)
list_ws = wb["LIST"]

# Identify source sheets: all sheets before LIST
list_index = wb.sheetnames.index("LIST")
source_sheet_names = wb.sheetnames[:list_index]

# Compute sums for C and D
sheet_sums = []
for name in source_sheet_names:
    ws = wb[name]
    sum_c = 0
    sum_d = 0
    for row in range(2, ws.max_row + 1):
        c_val = ws.cell(row=row, column=3).value
        d_val = ws.cell(row=row, column=4).value
        if isinstance(c_val, (int, float)):
            sum_c += c_val
        if isinstance(d_val, (int, float)):
            sum_d += d_val
    sheet_sums.append((name, sum_c, sum_d, sum_c - sum_d))

print("Computed sums:", sheet_sums)

# Inspect list sheet styles/format of first few rows/cells
for r in range(1, min(list_ws.max_row, 6) + 1):
    vals = [list_ws.cell(r, c).value for c in range(1, 6)]
    print("LIST row", r, vals)

# Preserve basic styles from existing rows if present
template_data_row = 2 if list_ws.max_row >= 2 else None
template_total_row = list_ws.max_row if list_ws.max_row >= 2 else None

# Clear existing body rows under header in columns A:E
for r in range(2, list_ws.max_row + 1):
    for c in range(1, 6):
        list_ws.cell(r, c).value = None

# Write refreshed data rows
for idx, (name, sum_c, sum_d, bal) in enumerate(sheet_sums, start=1):
    r = idx + 1
    list_ws.cell(r, 1).value = idx
    list_ws.cell(r, 2).value = name
    list_ws.cell(r, 3).value = sum_c
    list_ws.cell(r, 4).value = sum_d
    list_ws.cell(r, 5).value = f"=C{r}-D{r}"

# Write total row
total_row = len(sheet_sums) + 2
list_ws.cell(total_row, 2).value = "TOTAL"
list_ws.cell(total_row, 3).value = f"=SUM(C2:C{total_row-1})"
list_ws.cell(total_row, 4).value = f"=SUM(D2:D{total_row-1})"
list_ws.cell(total_row, 5).value = f"=C{total_row}-D{total_row}"

# Copy styles from original template rows if available
def copy_row_style(src_row, dst_row, cols=5):
    for c in range(1, cols + 1):
        src = list_ws.cell(src_row, c)
        dst = list_ws.cell(dst_row, c)
        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.font:
            dst.font = copy(src.font)
        if src.fill:
            dst.fill = copy(src.fill)
        if src.border:
            dst.border = copy(src.border)
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.protection:
            dst.protection = copy(src.protection)

if template_data_row:
    for r in range(2, total_row):
        copy_row_style(template_data_row, r, cols=5)

if template_total_row:
    copy_row_style(template_total_row, total_row, cols=5)

# Save output
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)

print("Saved to:", output_path)
print("Total row:", total_row)

# Quick verification by reopening (formula strings visible)
wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["LIST"]
for r in range(1, total_row + 1):
    print("OUT row", r, [ws_check.cell(r, c).value for c in range(1, 6)])
