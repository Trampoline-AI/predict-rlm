Code:
```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Fill destination matrix M6:S19 using INDEX/MATCH from source table
for r in range(6, 20):          # rows 6:19
    for c in range(13, 20):     # cols M:S
        col_letter = ws.cell(5, c).column_letter
        formula = (
            f'=IF(OR($L{r}="",{col_letter}$5=""),"",'
            f'IFERROR(INDEX($C$6:$I$19,'
            f'MATCH($L{r},$B$6:$B$19,0),'
            f'MATCH({col_letter}$5,$C$5:$I$5,0)),""))'
        )
        ws.cell(r, c).value = formula

wb.save(outfile)
print("Saved:", outfile)

# Recalculate workbook so cached values are available for verification
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas and a few computed results
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[wb_formula.sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[wb_values.sheetnames[0]]

checks = ["M6", "S6", "N7", "Q8", "R9", "M10", "M11"]
for cell in checks:
    print(cell, "formula:", wsf[cell].value, "value:", wsv[cell].value)
```
