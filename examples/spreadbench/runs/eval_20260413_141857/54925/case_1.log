from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb["Support"]

# Read criteria from sheet
target_h = ws["M3"].value
target_k1 = ws["N3"].value
target_k2 = ws["N4"].value

# Collect matches from rows 2:40 in original order
matches = []
for r in range(2, 41):
    h = ws[f"H{r}"].value
    k = ws[f"K{r}"].value
    b = ws[f"B{r}"].value
    if h == target_h and k in (target_k1, target_k2):
        matches.append((b, k, r))

print("Criteria:", target_h, target_k1, target_k2)
print("Match count:", len(matches))
print("First matches:", matches[:10])

# Clear Q column existing contents/fills
for r in range(1, ws.max_row + 1):
    cell = ws[f"Q{r}"]
    cell.value = None
    cell.fill = PatternFill(fill_type=None)

# Write header and results
ws["Q1"] = "Emp"
yellow_fill = PatternFill(fill_type="solid", fgColor="FFFF00")
green_fill = PatternFill(fill_type="solid", fgColor="92D050")

out_row = 2
for b_value, k_value, src_row in matches:
    cell = ws[f"Q{out_row}"]
    cell.value = b_value
    cell.fill = yellow_fill if k_value == target_k1 else green_fill
    out_row += 1

wb.save(output_path)

# Verify output
check_wb = load_workbook(output_path)
check_ws = check_wb["Support"]

written = []
for r in range(1, check_ws.max_row + 1):
    val = check_ws[f"Q{r}"].value
    if val is not None:
        fill = check_ws[f"Q{r}"].fill.fgColor.rgb
        written.append((r, val, fill))

print("Saved to:", output_path)
print("Written Q cells:", written[:20])

final_output_spreadsheet = output_path
```
