To satisfy the instruction literally, I’ll write a drag-down formula into `B9` that returns the nth header whose value in the matched row is greater than 0. I’ll then copy it down a few rows so the workbook demonstrates the setup, save it to the output directory with the same filename, recalculate, and verify the displayed results for the current lookup value `A`.
Code:
```repl
import os
from openpyxl import load_workbook

# Load workbook
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Formula for B9, designed to be dragged down
# Returns headers from B1:G1 where the matched row for B6 in A2:A3 has values > 0
formula_b9 = '=IFERROR(INDEX($B$1:$G$1,SMALL(IF(INDEX($B$2:$G$3,MATCH($B$6,$A$2:$A$3,0),0)>0,COLUMN($B$1:$G$1)-COLUMN($B$1)+1),ROWS(B$9:B9))),"")'

# Put formula in B9 and copy downward to provide enough output rows
for r in range(9, 15):
    ws.cell(r, 2).value = formula_b9.replace("B$9:B9", f"B$9:B{r}")

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_status = await recalculate(outfile)
print("Recalc:", recalc_status)

# Verify output values
wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check["Sheet1"]
print("Stored formulas B9:B14:")
for r in range(9, 15):
    print(r, ws_check.cell(r, 2).value)

wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Sheet1"]
print("Calculated values for current lookup in B6 =", ws_vals["B6"].value)
for r in range(9, 15):
    print(r, ws_vals.cell(r, 2).value)

output_spreadsheet = outfile
```
