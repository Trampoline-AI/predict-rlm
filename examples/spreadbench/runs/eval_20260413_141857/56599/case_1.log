import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Simpler LibreOffice-friendly formula
ws["B2"] = '=IF(OR(M5="",M5<$G$6,M5>$H$30),"not found - please re-enter",LOOKUP(M5,$G$6:$G$30,$J$6:$J$30))'

wb.save(outfile)
print("Saved:", outfile)
print("B2 formula now:", ws["B2"].value)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify with sample values
test_values = [None, 5871001, 5871005, 5871010, 5871011, 5871249, 5871250, 5871251, 1234567]
verification = []

for test_val in test_values:
    twb = load_workbook(outfile)
    tws = twb["Sheet1"]
    tws["M5"] = test_val
    test_path = os.path.join("/sandbox/output/output_spreadsheet", f"verify_{'blank' if test_val is None else test_val}_{filename}")
    twb.save(test_path)
    await recalculate(test_path)
    cwb = load_workbook(test_path, data_only=True)
    cws = cwb["Sheet1"]
    verification.append((test_val, cws["B2"].value))

print("Verification:")
for row in verification:
    print(row)

output_spreadsheet = outfile
