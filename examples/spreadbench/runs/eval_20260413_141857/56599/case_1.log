import os
from copy import copy
from openpyxl import load_workbook

# Load workbook
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Put the requested formula in B2 using lookup value in M5.
# If M5 is blank or no matching range is found, return the required message.
formula = '=IF(M5="","not found - please re-enter",IF(COUNTIFS($G$6:$G$30,"<="&M5,$H$6:$H$30,">="&M5)=0,"not found - please re-enter",INDEX($J$6:$J$30,MATCH(1,INDEX(($G$6:$G$30<=M5)*($H$6:$H$30>=M5),0),0))))'
ws["B2"] = formula

# Save output
wb.save(outfile)
print("Saved to:", outfile)
print("B2 formula:", ws["B2"].value)

# Recalculate workbook so cached formula results are available
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify by trying a few inputs in temporary workbooks derived from the output file
test_values = [None, 5871001, 5871005, 5871010, 5871011, 5871250, 1234567]
verification = []

for test_val in test_values:
    twb = load_workbook(outfile)
    tws = twb["Sheet1"]
    tws["M5"] = test_val
    test_path = os.path.join(outdir, f"test_{'blank' if test_val is None else test_val}_{filename}")
    twb.save(test_path)
    await recalculate(test_path)
    check_wb = load_workbook(test_path, data_only=True)
    check_ws = check_wb["Sheet1"]
    verification.append((test_val, check_ws["B2"].value))

print("Verification results:")
for item in verification:
    print(item)

output_spreadsheet = outfile
