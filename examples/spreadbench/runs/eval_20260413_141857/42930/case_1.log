Code:
```repl
import os
from openpyxl import load_workbook

# Load workbook fresh
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb2 = load_workbook(infile)
ws = wb2["Sheet1"]

# Identify house-data rows from columns A:B (starting after header)
data_rows = []
for r in range(2, ws.max_row + 1):
    year = ws.cell(r, 1).value
    subdiv = ws.cell(r, 2).value
    if year is not None and subdiv is not None:
        data_rows.append((r, year, subdiv))

print("House rows found:", len(data_rows))

# Compute earliest year per subdivision
earliest = {}
for r, year, subdiv in data_rows:
    if subdiv not in earliest or year < earliest[subdiv]:
        earliest[subdiv] = year

print("Earliest year per subdivision:", earliest)

# Sort subdivisions by earliest year, then by subdivision name for ties
ordered_subdivs = sorted(earliest.items(), key=lambda x: (x[1], str(x[0])))
mapping = {subdiv: i + 1 for i, (subdiv, _) in enumerate(ordered_subdivs)}
print("Assigned mapping:", mapping)

# Fill column C for each house row
for r, year, subdiv in data_rows:
    ws.cell(r, 3).value = mapping[subdiv]

# Refresh helper table in columns E:F
# Clear existing helper values below headers first
for r in range(2, ws.max_row + 1):
    ws.cell(r, 5).value = None
    ws.cell(r, 6).value = None

for i, (subdiv, yr) in enumerate(ordered_subdivs, start=2):
    ws.cell(i, 5).value = subdiv
    ws.cell(i, 6).value = mapping[subdiv]

# Save
wb2.save(outfile)
print("Saved to:", outfile)

# Verify by reopening
check = load_workbook(outfile, data_only=False)
cws = check["Sheet1"]
preview = []
for r in range(1, cws.max_row + 1):
    preview.append([cws.cell(r, c).value for c in range(1, 7)])

for row in preview[:12]:
    print(row)

output_spreadsheet = outfile
```
