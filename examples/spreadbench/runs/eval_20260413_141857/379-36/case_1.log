Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

changed_rows = []

def is_whole_number(val):
    if val is None:
        return False
    try:
        return float(val).is_integer()
    except Exception:
        return False

# Update column E based on column F where E contains the target text
for r in range(2, ws.max_row + 1):
    e_val = ws.cell(r, 5).value
    f_val = ws.cell(r, 6).value
    if isinstance(e_val, str) and "Georgia Its Tax" in e_val:
        new_text = "Georgia WH Tax" if is_whole_number(f_val) else "Georgia Sales Tax"
        ws.cell(r, 5).value = new_text
        changed_rows.append((r, e_val, f_val, new_text))

# Clear all of column H values and remove background color
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 8)
    cell.value = None
    cell.fill = PatternFill(fill_type=None)

wb.save(output_path)

# Verify by reloading
vwb = load_workbook(output_path)
vws = vwb[vwb.sheetnames[0]]

verification = []
for r in range(1, vws.max_row + 1):
    verification.append((
        r,
        vws.cell(r, 5).value,
        vws.cell(r, 6).value,
        vws.cell(r, 8).value,
        vws.cell(r, 8).fill.fill_type
    ))

print("Saved to:", output_path)
print("Changed rows:", changed_rows)
print("Verification rows 9-11:")
for row in verification[8:11]:
    print(row)

all_h_empty = all(vws.cell(r, 8).value is None for r in range(1, vws.max_row + 1))
all_h_nofill = all(vws.cell(r, 8).fill.fill_type is None for r in range(1, vws.max_row + 1))
print("All H empty:", all_h_empty)
print("All H no fill:", all_h_nofill)
```
