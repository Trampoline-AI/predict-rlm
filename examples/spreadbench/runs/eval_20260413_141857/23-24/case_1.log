import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row

# Build set of words from column I
col_i_words = set()
for r in range(1, max_row + 1):
    v = ws.cell(r, 9).value
    if v is not None and str(v).strip() != "":
        col_i_words.add(str(v).strip())

# Keep only A:E rows where A is blank or not present in column I
kept_ae = []
removed_count = 0
for r in range(1, max_row + 1):
    a = ws.cell(r, 1).value
    a_str = None if a is None else str(a).strip()
    row_ae = [ws.cell(r, c).value for c in range(1, 6)]
    if a_str and a_str in col_i_words:
        removed_count += 1
    else:
        kept_ae.append(row_ae)

# Write compacted A:E back to the sheet
for out_r, row_vals in enumerate(kept_ae, start=1):
    for c, val in enumerate(row_vals, start=1):
        ws.cell(out_r, c).value = val

# Clear remaining A:E cells below compacted data
for r in range(len(kept_ae) + 1, max_row + 1):
    for c in range(1, 6):
        ws.cell(r, c).value = None

wb.save(output_path)

# Verify by reloading
wb2 = load_workbook(output_path)
ws2 = wb2[wb2.sheetnames[0]]

# Recompute remaining matches
col_i_words_after = set()
for r in range(1, ws2.max_row + 1):
    v = ws2.cell(r, 9).value
    if v is not None and str(v).strip() != "":
        col_i_words_after.add(str(v).strip())

remaining_matches = []
for r in range(1, ws2.max_row + 1):
    a = ws2.cell(r, 1).value
    a_str = None if a is None else str(a).strip()
    if a_str and a_str in col_i_words_after:
        remaining_matches.append(r)

# Sample-check F:I unchanged by comparing input and output for selected rows
wb_orig = load_workbook(input_path, read_only=True)
ws_orig = wb_orig[wb_orig.sheetnames[0]]
sample_rows = [1, 2, 10, 100, 1000, max_row]
fi_same = {}
for r in sample_rows:
    orig = [ws_orig.cell(r, c).value for c in range(6, 10)]
    new = [ws2.cell(r, c).value for c in range(6, 10)]
    fi_same[r] = (orig == new, orig, new)

print("Saved to:", output_path)
print("Original rows:", max_row)
print("Removed A:E rows:", removed_count)
print("Kept A:E rows:", len(kept_ae))
print("Remaining A-vs-I matches:", len(remaining_matches))
print("First 5 rows after compaction (A:I):")
for r in range(1, 6):
    print(r, [ws2.cell(r, c).value for c in range(1, 10)])
print("F:I sample unchanged checks:")
for r, info in fi_same.items():
    print(r, info[0])
```
