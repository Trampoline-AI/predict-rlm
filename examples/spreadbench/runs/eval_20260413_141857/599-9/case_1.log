Code:
```repl
import os
import copy
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)

update_summary = {}

for ws in wb.worksheets:
    # Ensure column K exists conceptually; openpyxl can write there even if max_column < 11
    updates = 0
    unchanged_due_blank_g = 0
    
    for r in range(2, ws.max_row + 1):  # skip header
        g_cell = ws.cell(r, 7)   # G
        k_cell = ws.cell(r, 11)  # K
        
        if g_cell.value is not None:
            old_k = k_cell.value
            k_cell.value = g_cell.value
            # copy number format from G to K so dates display consistently
            if g_cell.number_format:
                k_cell.number_format = g_cell.number_format
            updates += 1
        else:
            unchanged_due_blank_g += 1
    
    update_summary[ws.title] = {
        "rows": ws.max_row,
        "updates": updates,
        "blank_g_left_k_unchanged": unchanged_due_blank_g,
    }

wb.save(output_path)

# Verify by reopening
check_wb = load_workbook(output_path)
verification = {}

for ws in check_wb.worksheets:
    mismatches = []
    for r in range(2, ws.max_row + 1):
        g = ws.cell(r, 7).value
        k = ws.cell(r, 11).value
        if g is not None and g != k:
            mismatches.append(r)
    verification[ws.title] = {
        "mismatch_rows_where_g_present_but_k_differs": mismatches[:10],
        "mismatch_count": len(mismatches),
        "sample_GK": [(r, ws.cell(r, 7).value, ws.cell(r, 11).value) for r in range(2, min(ws.max_row, 8) + 1)]
    }

print("Saved to:", output_path)
print("Update summary:", update_summary)
print("Verification:", verification)

output_spreadsheet = output_path
```
