Then populate `F4:H6` with `INDEX` formulas based on those helper positions. This stays formula-driven and uses standard compatible functions. I’ll save, inspect formulas, and also compute the expected extracted values in Python to verify they correspond to the three lighting rows.
Code:
```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Clear previous attempted formulas in output/helper area
for cell in ["E4","E5","E6"] + [f"{col}{row}" for row in range(4,7) for col in "FGH"]:
    ws[cell] = None

# Helper formulas: positions of the 1st, 2nd, and 3rd "Lighting" entries in B4:B22
ws["E4"] = '=MATCH($F$3,$B$4:$B$22,0)'
ws["E5"] = '=MATCH($F$3,INDEX($B$4:$B$22,$E4+1):$B$22,0)+$E4'
ws["E6"] = '=MATCH($F$3,INDEX($B$4:$B$22,$E5+1):$B$22,0)+$E5'

# Populate extracted table with INDEX formulas
for r in range(4, 7):
    ws[f"F{r}"] = f'=IFERROR(INDEX($B$4:$B$22,$E{r}),"")'
    ws[f"G{r}"] = f'=IFERROR(INDEX($C$4:$C$22,$E{r}),"")'
    ws[f"H{r}"] = f'=IFERROR(INDEX($D$4:$D$22,$E{r}),"")'

# Hide helper column E to preserve layout
ws.column_dimensions["E"].hidden = True

wb.save(outfile)
print("Saved:", outfile)

# Re-open and inspect formulas
wb2 = load_workbook(outfile, data_only=False)
ws2 = wb2["Sheet1"]
print("Helper formulas E4:E6:")
for r in range(4, 7):
    print(r, ws2[f"E{r}"].value)

print("Output formulas F4:H6:")
for r in range(4, 7):
    print(r, [ws2[f"{c}{r}"].value for c in "FGH"])

# Verify expected extracted values from source data in Python
expected = []
for r in range(4, 23):
    if ws2[f"B{r}"].value == "Lighting":
        expected.append([ws2[f"B{r}"].value, ws2[f"C{r}"].value, ws2[f"D{r}"].value])
print("Expected lighting rows from source:", expected)
print("Target size:", len(expected), "rows into F4:H6")
```
