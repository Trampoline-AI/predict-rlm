- Work within each stock name separately, in the existing row order.
- Consecutive rows with `Change < 0` are merged into one output row.
- A non-negative `Change` row stays as its own output row.
- For a merged negative run:
  - `DATE` = the first row’s date in the input order (latest date at the top of that run)
  - `OPENP*` = opening price from the last row in the run (earliest date in that run)
  - `CLOSEP*` = closing price from the first row in the run
  - `HIGH` = max high across the run
  - `LOW` = min low across the run
  - `VOLUME` = sum volume across the run

Next I should compute this for all stocks, write it into the `output` sheet while preserving the existing header/style pattern, save the workbook to the required output path, and print the resulting rows for verification before submitting.
Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws_in = wb["input"]
ws_out = wb["output"]

# Read input rows
rows = []
for r in range(2, ws_in.max_row + 1):
    vals = [ws_in.cell(r, c).value for c in range(1, 9)]
    if all(v is None for v in vals):
        continue
    rows.append({
        "date": vals[0],
        "stock": vals[1],
        "open": vals[2],
        "high": vals[3],
        "low": vals[4],
        "close": vals[5],
        "volume": vals[6],
        "change": vals[7],
    })

# Group by contiguous stock blocks, then summarize consecutive negative-change runs
summary_rows = []
i = 0
n = len(rows)

while i < n:
    stock = rows[i]["stock"]
    block = []
    while i < n and rows[i]["stock"] == stock:
        block.append(rows[i])
        i += 1

    j = 0
    while j < len(block):
        row = block[j]
        ch = row["change"]
        is_negative = (ch is not None and ch < 0)

        if is_negative:
            run = [row]
            j += 1
            while j < len(block):
                ch2 = block[j]["change"]
                if ch2 is not None and ch2 < 0:
                    run.append(block[j])
                    j += 1
                else:
                    break

            summary_rows.append([
                run[0]["date"],                      # first row date in displayed order
                stock,
                run[-1]["open"],                     # open from earliest date in the run
                max(x["high"] for x in run if x["high"] is not None),
                min(x["low"] for x in run if x["low"] is not None),
                run[0]["close"],                    # close from latest date in the run
                sum((x["volume"] or 0) for x in run),
            ])
        else:
            summary_rows.append([
                row["date"],
                stock,
                row["open"],
                row["high"],
                row["low"],
                row["close"],
                row["volume"],
            ])
            j += 1

# Clear existing output data rows
for r in range(2, ws_out.max_row + 1):
    for c in range(1, 8):
        ws_out.cell(r, c).value = None
        # keep styles untouched for now

# Ensure header matches first 7 relevant columns from input
for c in range(1, 8):
    ws_out.cell(1, c).value = ws_in.cell(1, c).value
    ws_out.cell(1, c)._style = copy(ws_out.cell(1, c)._style)
    ws_out.cell(1, c).number_format = ws_in.cell(1, c).number_format

# Use existing output row 2 as a style template if present, otherwise input row 2
template_row = 2 if ws_out.max_row >= 2 else 2
style_source_ws = ws_out if ws_out.max_row >= 2 else ws_in

for out_r, out_vals in enumerate(summary_rows, start=2):
    for c, v in enumerate(out_vals, start=1):
        cell = ws_out.cell(out_r, c)
        cell.value = v

        src = style_source_ws.cell(template_row, c)
        cell._style = copy(src._style)
        cell.number_format = src.number_format
        cell.font = copy(src.font)
        cell.fill = copy(src.fill)
        cell.border = copy(src.border)
        cell.alignment = copy(src.alignment)
        cell.protection = copy(src.protection)

# Save output
wb.save(outfile)

# Verify by reopening and printing output rows
wb_check = load_workbook(outfile)
ws_check = wb_check["output"]

print("Saved to:", outfile)
print("Summary row count:", len(summary_rows))
for r in range(1, ws_check.max_row + 1):
    print(r, [ws_check.cell(r, c).value for c in range(1, 8)])
```
