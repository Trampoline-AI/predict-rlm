Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)

changed = []
total_replacements = 0

for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and '"' in cell.value:
                old = cell.value
                new = old.replace('"', '')
                total_replacements += old.count('"')
                cell.value = new
                changed.append((ws.title, cell.coordinate, old, new))

wb.save(outfile)

# Verify
vwb = load_workbook(outfile)
remaining = []
for ws in vwb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and '"' in cell.value:
                remaining.append((ws.title, cell.coordinate, cell.value))

print("Saved to:", outfile)
print("Changed cells:", changed)
print("Total quote characters removed:", total_replacements)
print("Remaining quoted cells:", remaining)

# keep output path in variable for submission
output_path = outfile
```
