Code:
```repl
import os
from openpyxl import load_workbook

# Load fresh workbook
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb2 = load_workbook(infile)
ws = wb2[wb2.sheetnames[0]]

cleared_rows = []
kept_rows = []

for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 1)
    v = cell.value
    keep = isinstance(v, str) and v.strip().lower() == "comments"
    if keep:
        kept_rows.append(r)
    else:
        if v is not None:
            cleared_rows.append((r, v))
        cell.value = None  # clear only the value; formatting remains

wb2.save(outfile)

# Verify saved output
check_wb = load_workbook(outfile)
check_ws = check_wb[check_wb.sheetnames[0]]
result_vals = [(r, check_ws.cell(r, 1).value) for r in range(1, check_ws.max_row + 1)]

print("Saved to:", outfile)
print("Kept rows:", kept_rows)
print("Cleared rows:", cleared_rows)
print("Final column A:", result_vals)

output_spreadsheet = outfile
```
