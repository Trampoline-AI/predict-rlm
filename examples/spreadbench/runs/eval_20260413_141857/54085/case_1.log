Code:
```repl
from openpyxl import load_workbook
import os
from shutil import copy2

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
copy2(infile, outfile)

wb = load_workbook(outfile)
ws = wb["Sheet1"]

# Write formulas to C2:C4 to list items from B excluding A2, preserving order.
formula_template = '=IFERROR(INDEX($B$2:$B$5,MATCH(0,INDEX(($B$2:$B$5=$A$2)+COUNTIF($C$1:C{prev_row},$B$2:$B$5),0),0)),"")'
for row in range(2, 5):
    ws[f"C{row}"] = formula_template.format(prev_row=row-1)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Verify formulas and computed values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]

print("Formulas in C2:C4:", [wsf[f"C{r}"].value for r in range(2,5)])
print("Values in C2:C4:", [wsv[f"C{r}"].value for r in range(2,5)])

output_spreadsheet = outfile
```
