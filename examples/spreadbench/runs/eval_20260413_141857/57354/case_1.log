import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and target sheet
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Determine dynamic detail range: starts at F and extends to the sheet's last used column
start_col = 6  # F
end_col = ws.max_column
start_letter = get_column_letter(start_col)
end_letter = get_column_letter(end_col)

header_range = f"{start_letter}2:{end_letter}2"
value_range = f"{start_letter}3:{end_letter}3"

# Write automated formulas for total revenue and total GP
ws["D3"] = f'=SUMIF({header_range},"REVENUE",{value_range})'
ws["E3"] = f'=SUMIF({header_range},"GP",{value_range})'

# Preserve number formats/styles already present; just save
wb.save(output_path)
print("Saved to:", output_path)
print("D3 formula:", ws["D3"].value)
print("E3 formula:", ws["E3"].value)

# Recalculate formulas and verify cached results
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

wb_check_formula = load_workbook(output_path, data_only=False)
wsf = wb_check_formula["Sheet1"]
print("Stored formulas:", wsf["D3"].value, "|", wsf["E3"].value)

wb_check_values = load_workbook(output_path, data_only=True)
wsv = wb_check_values["Sheet1"]
print("Cached values D3/E3:", wsv["D3"].value, wsv["E3"].value)

# Keep path for submission
final_output_path = output_path
```
