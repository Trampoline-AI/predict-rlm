import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet2"]

def count_ones_in_runs_at_least_2(values):
    total = 0
    run = 0
    for v in values:
        if v == 1:
            run += 1
        else:
            if run >= 2:
                total += run
            run = 0
    if run >= 2:
        total += run
    return total

# Data appears in rows 3:14 for columns B:E
data_rows = range(3, 15)
results = {}

for col in range(2, 6):  # B:E
    vals = [ws.cell(r, col).value for r in data_rows]
    results[get_column_letter(col)] = count_ones_in_runs_at_least_2(vals)
    ws.cell(15, col).value = results[get_column_letter(col)]

# Ensure label remains
ws["A15"] = "Ans"

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

print("Computed results:", results)
print("Saved to:", output_path)

# Verify by reopening
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb["Sheet2"]
print("Verification row 15:", [check_ws.cell(15, c).value for c in range(1, 6)])
```
