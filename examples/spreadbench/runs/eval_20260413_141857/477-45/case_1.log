4. Clear any existing output under G:J if needed.
5. Write the grouped result starting at `G2`, preserving the headers in row 1.
6. Save to the output directory with the same filename.
7. Reopen and verify a sample of the output.
Code:
```repl
from openpyxl import load_workbook
from collections import OrderedDict
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["merge"]

# Aggregate by columns A, B, and C; sum column D
agg = OrderedDict()
for row in range(2, ws.max_row + 1):
    a = ws.cell(row=row, column=1).value
    b = ws.cell(row=row, column=2).value
    c = ws.cell(row=row, column=3).value
    d = ws.cell(row=row, column=4).value
    
    if a is None and b is None and c is None and d is None:
        continue
    
    key = (a, b, c)
    val = d if isinstance(d, (int, float)) else (float(d) if d not in (None, "") else 0)
    
    if key not in agg:
        agg[key] = 0
    agg[key] += val

# Clear old output area below headers in G:J
for row in range(2, ws.max_row + 1):
    for col in range(7, 11):
        ws.cell(row=row, column=col).value = None

# Ensure headers remain as in the workbook
# Write output starting at G2
out_row = 2
for (a, b, c), total in agg.items():
    ws.cell(row=out_row, column=7).value = a
    ws.cell(row=out_row, column=8).value = b
    ws.cell(row=out_row, column=9).value = c
    # keep integer totals as integers if possible
    if isinstance(total, float) and total.is_integer():
        total = int(total)
    ws.cell(row=out_row, column=10).value = total
    out_row += 1

wb.save(outfile)

# Verify
check_wb = load_workbook(outfile, data_only=True)
check_ws = check_wb["merge"]
print("Saved to:", outfile)
print("Unique groups written:", len(agg))
for r in range(1, min(out_row, 8)):
    print([check_ws.cell(row=r, column=c).value for c in range(7, 11)])

output_path = outfile
```
