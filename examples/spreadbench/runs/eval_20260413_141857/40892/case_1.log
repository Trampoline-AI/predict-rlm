from openpyxl import load_workbook
import os

# Re-open and inspect all relevant rows
wb = load_workbook(input_path)
ws = wb["Sheet1"]

print("All rows A:D:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])

# Build formulas in column B for data rows using the allowed list in D3:D17
# Return the last matching item from the list (typical LOOKUP(2,1/SEARCH()) pattern),
# or empty string if no allowed color is found in the text.
list_start = 3
list_end = ws.max_row

for r in range(2, ws.max_row + 1):
    formula = f'=IFERROR(LOOKUP(2,1/(ISNUMBER(SEARCH($D${list_start}:$D${list_end},A{r}))),$D${list_start}:$D${list_end}),"")'
    ws.cell(r, 2).value = formula

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("Formulas in B2:B17:")
for r in range(2, ws_check.max_row + 1):
    print(r, ws_check.cell(r, 1).value, "=>", ws_check.cell(r, 2).value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("\nComputed values in B2:B17:")
for r in range(2, ws_values.max_row + 1):
    print(r, ws_values.cell(r, 1).value, "=>", ws_values.cell(r, 2).value)
