Code:
```repl
from openpyxl import load_workbook
import os

# Load workbook again
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Extract allowed colors from column D, excluding headers/blank cells, preserving order and de-duping
allowed_colors = []
seen = set()
for r in range(3, ws.max_row + 1):
    val = ws.cell(r, 4).value
    if isinstance(val, str):
        v = val.strip()
        if v and v.lower() not in seen:
            allowed_colors.append((r, v))
            seen.add(v.lower())

print("Allowed colors:", allowed_colors)

# Build nested IF/COUNTIF formula for each row in column B
for r in range(2, ws.max_row + 1):
    formula = '""'
    for color_row, color_val in reversed(allowed_colors):
        formula = f'IF(COUNTIF(A{r},"*"&$D${color_row}&"*")>0,$D${color_row},{formula})'
    ws.cell(r, 2).value = f"={formula}"

# Save
wb.save(output_path)
print("Saved:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("\nFormulas preview:")
for r in range(2, min(ws_formula.max_row, 8) + 1):
    print(r, ws_formula.cell(r, 2).value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("\nComputed values:")
for r in range(2, ws_values.max_row + 1):
    print(r, ws_values.cell(r, 1).value, "=>", ws_values.cell(r, 2).value)
```
