from openpyxl import load_workbook
from collections import defaultdict

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("max_row,max_col:", ws.max_row, ws.max_column)

# Print all rows concisely
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(r, vals)

# Summarize employee/week groups
groups = defaultdict(lambda: {"rows": [], "sick": 0, "ot": 0})
for r in range(2, ws.max_row + 1):
    emp = ws.cell(r, 2).value
    week = ws.cell(r, 5).value
    abs_name = ws.cell(r, 3).value
    att_name = ws.cell(r, 4).value
    g = groups[(emp, week)]
    g["rows"].append(r)
    if abs_name == "Sick Day":
        g["sick"] += 1
    if att_name == "Overtime":
        g["ot"] += 1

print("\nGroup summary:")
for k, v in sorted(groups.items(), key=lambda kv: (kv[0][0], kv[0][1])):
    print(k, v)
