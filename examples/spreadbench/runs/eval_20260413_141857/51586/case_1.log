Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
import os

# Load source workbook
src_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src_path))

wb = load_workbook(src_path)
ws = wb["Sheet1"]

# Green fill for column C data cells
green_fill = PatternFill(fill_type="solid", fgColor="FF00B050")

# Preserve dimensions if present
col_dims = {}
for key, dim in ws.column_dimensions.items():
    col_dims[key] = {
        "width": dim.width,
        "hidden": dim.hidden,
        "bestFit": dim.bestFit,
    }

row_dims = {}
for key, dim in ws.row_dimensions.items():
    row_dims[key] = {
        "height": dim.height,
        "hidden": dim.hidden,
    }

# Apply Calibri font throughout, preserving size/bold/italic/etc as much as possible
for row in ws.iter_rows():
    for cell in row:
        cell.font = cell.font.copy(name="Calibri")

# Put formulas in column C for data rows and recolor C2:Cend green
for r in range(2, ws.max_row + 1):
    ws.cell(r, 3).value = f'=RIGHT(TRIM(A{r}),LEN(TRIM(B{r})))=TRIM(B{r})'
    ws.cell(r, 3).fill = green_fill
    ws.cell(r, 3).font = ws.cell(r, 3).font.copy(name="Calibri")

# Ensure header font also Calibri (and all cells already handled)
for c in range(1, ws.max_column + 1):
    ws.cell(1, c).font = ws.cell(1, c).font.copy(name="Calibri")

# Reapply dimensions just to preserve them
for key, props in col_dims.items():
    ws.column_dimensions[key].width = props["width"]
    ws.column_dimensions[key].hidden = props["hidden"]
    ws.column_dimensions[key].bestFit = props["bestFit"]

for key, props in row_dims.items():
    ws.row_dimensions[key].height = props["height"]
    ws.row_dimensions[key].hidden = props["hidden"]

wb.save(out_path)

# Verify saved workbook contents/styles
check = load_workbook(out_path, data_only=False)
cws = check["Sheet1"]

print("Saved to:", out_path)
print("Rows x Cols:", cws.max_row, "x", cws.max_column)
for r in range(1, cws.max_row + 1):
    vals = [cws.cell(r, c).value for c in range(1, 4)]
    print(r, vals)

print("Column C formulas and fills:")
for r in range(2, cws.max_row + 1):
    cell = cws.cell(r, 3)
    print(r, cell.value, cell.fill.fgColor.rgb, cell.font.name)

output_spreadsheet = out_path
```
