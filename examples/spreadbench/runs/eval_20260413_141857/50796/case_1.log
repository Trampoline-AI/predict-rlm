from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Write the requested formula pattern in the result area
for row in range(2, 6):
    ws.cell(row=row, column=2).value = f'=SUMIF($B$12:$B$22,A{row},$C$12:$C$22)'

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check["Sheet1"]
print("Formulas B2:B5:", [ws_check[f"B{i}"].value for i in range(2, 6)])

wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Sheet1"]
print("Values A1:B5:")
for r in range(1, 6):
    print(r, [ws_vals.cell(r, c).value for c in range(1, 3)])

output_spreadsheet = outfile
