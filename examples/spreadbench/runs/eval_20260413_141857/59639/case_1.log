Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Find rows with source strings in column A and determine max length
source_rows = []
max_len = 0
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v != "":
        source_rows.append(r)
        max_len = max(max_len, len(v))

start_col = 4  # column D, based on sample layout

# Write formulas across D onward for each source row
for r in source_rows:
    for idx in range(1, max_len + 1):
        c = start_col + idx - 1
        ws.cell(r, c).value = f'=IF(COLUMN()-3<=LEN($A{r}),MID($A{r},COLUMN()-3,1),"")'

wb.save(output_path)
print("Saved:", output_path)

# Verify formulas written
check_wb = load_workbook(output_path)
check_ws = check_wb[check_wb.sheetnames[0]]
for r in source_rows:
    formulas = [check_ws.cell(r, c).value for c in range(start_col, start_col + max_len)]
    print(f"Row {r} formulas:", formulas[:4], "...", formulas[-2:])

# Recalculate and verify cached values
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

value_wb = load_workbook(output_path, data_only=True)
value_ws = value_wb[value_wb.sheetnames[0]]
for r in source_rows:
    vals = [value_ws.cell(r, c).value for c in range(start_col, start_col + max_len)]
    print(f"Row {r} values:", vals)
```
