from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, textwrap

print("Input:", input_spreadsheet)
print("Instruction preview:", instruction[:500])

wb = load_workbook(input_spreadsheet)
print("Sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # Find a tighter used range by checking non-empty cells
    nonempty = []
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                nonempty.append((cell.row, cell.column, cell.value))
    print("nonempty cells:", len(nonempty))
    if nonempty:
        min_row = min(r for r,c,v in nonempty)
        max_row = max(r for r,c,v in nonempty)
        min_col = min(c for r,c,v in nonempty)
        max_col = max(c for r,c,v in nonempty)
        print("used range:", f"{get_column_letter(min_col)}{min_row}:{get_column_letter(max_col)}{max_row}")
        # print first several rows in used range
        for r in range(min_row, min(max_row, min_row + 12) + 1):
            vals = [ws.cell(r, c).value for c in range(min_col, max_col + 1)]
            print(r, vals)
    # merged cells
    if ws.merged_cells.ranges:
        print("merged ranges:", list(ws.merged_cells.ranges)[:10])

for ws in wb.worksheets:
    sheet_summary(ws)
```
