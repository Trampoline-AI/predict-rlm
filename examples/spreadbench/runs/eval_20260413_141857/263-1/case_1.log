```repl
from openpyxl import load_workbook
from collections import defaultdict
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Compute totals from source data A:C
totals = defaultdict(float)
source_material_order = []
seen = set()
for r in range(2, ws.max_row + 1):
    m = ws.cell(r, 1).value
    w = ws.cell(r, 2).value
    h = ws.cell(r, 3).value
    if m is None and w is None and h is None:
        continue
    if m is not None and m not in seen:
        seen.add(m)
        source_material_order.append(m)
    if m is not None and w is not None and h is not None:
        totals[str(m)] += float(w) * float(h)

# Preserve existing output order in G starting at row 2
existing_output_materials = []
r = 2
while r <= ws.max_row:
    val = ws.cell(r, 7).value
    if val is None:
        break
    if isinstance(val, str) and val != "":
        existing_output_materials.append(val)
    r += 1

# Final order: existing listed order first, then any unseen materials from source
final_materials = []
seen_out = set()
for m in existing_output_materials + source_material_order:
    m = str(m)
    if m in totals and m not in seen_out:
        seen_out.add(m)
        final_materials.append(m)

# Template style from row 2, G:I
template = {}
for c in range(7, 10):
    cell = ws.cell(2, c)
    template[c] = {
        "_style": copy(cell._style),
        "font": copy(cell.font),
        "fill": copy(cell.fill),
        "border": copy(cell.border),
        "alignment": copy(cell.alignment),
        "number_format": cell.number_format,
    }

# Clear a reasonable output area and apply template style
for rr in range(2, max(ws.max_row, 2 + len(final_materials) + 5) + 1):
    for c in range(7, 10):
        cell = ws.cell(rr, c)
        cell.value = None
        cell._style = copy(template[c]["_style"])
        cell.font = copy(template[c]["font"])
        cell.fill = copy(template[c]["fill"])
        cell.border = copy(template[c]["border"])
        cell.alignment = copy(template[c]["alignment"])
        cell.number_format = template[c]["number_format"]

ws["G1"] = "This is what I need:"

for i, material in enumerate(final_materials, start=2):
    ws.cell(i, 7).value = material
    total = totals[material]
    ws.cell(i, 8).value = int(round(total)) if abs(total - round(total)) < 1e-9 else total
    ws.cell(i, 9).value = "sqf"

wb.save(outfile)

# Verify
check = load_workbook(outfile, data_only=True)
cws = check["Sheet1"]
print("Verified output:", outfile)
for rr in range(1, 8):
    print(rr, [cws.cell(rr, cc).value for cc in range(7, 10)])
```
