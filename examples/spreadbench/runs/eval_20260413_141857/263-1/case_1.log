```repl
from openpyxl import load_workbook
from collections import defaultdict
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Compute totals by material from source list in A:C
totals = defaultdict(float)
material_order = []
seen = set()

for r in range(2, ws.max_row + 1):
    m = ws.cell(r, 1).value
    w = ws.cell(r, 2).value
    h = ws.cell(r, 3).value
    if m is None and w is None and h is None:
        continue
    if m is not None and m not in seen:
        seen.add(m)
        material_order.append(m)
    if m is not None and w is not None and h is not None:
        totals[m] += float(w) * float(h)

# Use existing example style pattern from row 2 if present
template_cells = {col: copy(ws.cell(2, col)._style) for col in range(7, 10)}
template_numfmts = {col: ws.cell(2, col).number_format for col in range(7, 10)}
template_align = {col: copy(ws.cell(2, col).alignment) for col in range(7, 10)}
template_font = {col: copy(ws.cell(2, col).font) for col in range(7, 10)}
template_fill = {col: copy(ws.cell(2, col).fill) for col in range(7, 10)}
template_border = {col: copy(ws.cell(2, col).border) for col in range(7, 10)}

# Clear existing output area under the header enough to handle all materials
start_row = 2
end_row = max(ws.max_row, start_row + len(material_order) + 10)
for r in range(start_row, end_row + 1):
    for c in range(7, 10):
        ws.cell(r, c).value = None
        ws.cell(r, c)._style = copy(template_cells[c])
        ws.cell(r, c).number_format = template_numfmts[c]
        ws.cell(r, c).alignment = copy(template_align[c])
        ws.cell(r, c).font = copy(template_font[c])
        ws.cell(r, c).fill = copy(template_fill[c])
        ws.cell(r, c).border = copy(template_border[c])

# Preserve / set header
ws["G1"] = "This is what I need:"

# Write summary rows in source appearance order
for idx, material in enumerate(material_order, start=start_row):
    ws.cell(idx, 7).value = material
    total = totals[material]
    if abs(total - round(total)) < 1e-9:
        total = int(round(total))
    ws.cell(idx, 8).value = total
    ws.cell(idx, 9).value = "sqf"

wb.save(outfile)

# Verify
check_wb = load_workbook(outfile, data_only=True)
check_ws = check_wb["Sheet1"]
written = []
for r in range(1, 10):
    written.append([check_ws.cell(r, c).value for c in range(7, 10)])
print("Saved to:", outfile)
print("Summary preview G1:I9:")
for row in written:
    print(row)
print("Expected totals:", {k: totals[k] for k in material_order})
```
