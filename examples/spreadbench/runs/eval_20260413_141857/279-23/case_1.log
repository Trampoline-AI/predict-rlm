Code:
```repl
import os
import re
import shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Copy first, then edit the copy
shutil.copy2(input_path, output_path)

wb = load_workbook(output_path)
ws = wb[wb.sheetnames[0]]

pattern = re.compile(r"\(([^()]*)\)")

changed = []
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 2)  # column B
    v = cell.value
    
    if v is None or v == "":
        continue  # leave blanks blank
    
    if isinstance(v, str):
        m = pattern.search(v)
        if m:
            new_v = m.group(1)
            if new_v != v:
                changed.append((r, v, new_v))
                cell.value = new_v
        # if no parentheses, leave as is

wb.save(output_path)

# Verify
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]

print("Saved:", output_path, os.path.exists(output_path))
print("Changed rows:", len(changed))
print("First few changes:", changed[:10])
print("Column B after save:")
for r in range(1, check_ws.max_row + 1):
    print(r, repr(check_ws.cell(r, 2).value))
```
