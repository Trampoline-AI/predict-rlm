import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Load workbook
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
ws = wb[wb.sheetnames[0]]

# Build formula for M2 from repeated PN/Qty column pairs starting at O
max_row = ws.max_row
terms = []
for part_col in range(15, ws.max_column + 1, 2):  # O, Q, S, U, W, ...
    qty_col = part_col + 1
    if qty_col <= ws.max_column:
        part_letter = get_column_letter(part_col)
        qty_letter = get_column_letter(qty_col)
        terms.append(f"SUMIF(${part_letter}$2:${part_letter}${max_row},$A2,${qty_letter}$2:${qty_letter}${max_row})")

formula = "=" + "+".join(terms)
ws["M2"] = formula

# Save output
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)

print("Written formula to M2:", ws["M2"].value)
print("Saved to:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check_formula = load_workbook(outfile, data_only=False)
wsf = wb_check_formula[wb_check_formula.sheetnames[0]]
print("Verified formula in M2:", wsf["M2"].value)

wb_check_value = load_workbook(outfile, data_only=True)
wsv = wb_check_value[wb_check_value.sheetnames[0]]
print("Cached value in M2:", wsv["M2"].value)
