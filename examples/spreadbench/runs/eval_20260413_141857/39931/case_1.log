Code:
```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook and target sheet
wb = load_workbook(infile)
ws = wb["Sheet1"]

# Determine table bounds from the example layout
header_row = 3          # C3:F3 contain A-D
row_label_col = 2       # B4:B7 contain x-z
table_start_row = 4
table_end_row = 7
table_start_col = 3     # C
table_end_col = 6       # F

# Write two-criteria lookup formula into the table area
for r in range(table_start_row, table_end_row + 1):
    row_key = ws.cell(r, row_label_col).value
    if row_key is None:
        continue
    for c in range(table_start_col, table_end_col + 1):
        col_key = ws.cell(header_row, c).value
        if col_key is None:
            continue
        formula = f'=SUMIFS($K$3:$K$22,$I$3:$I$22,$B{r},$J$3:$J$22,{ws.cell(header_row, c).coordinate})'
        ws.cell(r, c).value = formula

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas and verify results
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

wb_check = load_workbook(outfile, data_only=True)
ws_check = wb_check["Sheet1"]

# Print the filled table for verification
print("Verified table values:")
headers = [ws_check.cell(header_row, c).value for c in range(table_start_col, table_end_col + 1)]
print("Headers:", headers)
for r in range(table_start_row, table_end_row + 1):
    row_label = ws_check.cell(r, row_label_col).value
    row_vals = [ws_check.cell(r, c).value for c in range(table_start_col, table_end_col + 1)]
    print(row_label, row_vals)

output_spreadsheet = outfile
```
