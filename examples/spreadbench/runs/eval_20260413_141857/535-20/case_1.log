Code:
```repl
import os
from openpyxl import load_workbook

# Load fresh workbook for editing
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)

deletion_summary = {}

for ws in wb.worksheets:
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    cols_to_delete = [
        c for c in range(1, ws.max_column + 1)
        if isinstance(headers[c-1], str) and "/description" in headers[c-1]
    ]
    deletion_summary[ws.title] = {
        "before_cols": ws.max_column,
        "delete_count": len(cols_to_delete),
    }
    
    # Delete from right to left so column indices remain valid
    for c in reversed(cols_to_delete):
        ws.delete_cols(c, 1)
    
    deletion_summary[ws.title]["after_cols"] = ws.max_column

wb.save(output_path)
print("Saved:", output_path)
print("Deletion summary:", deletion_summary)

# Verify by reopening
verify_wb = load_workbook(output_path)
verification = {}
for ws in verify_wb.worksheets:
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    remaining = [
        (c, headers[c-1]) for c in range(1, ws.max_column + 1)
        if isinstance(headers[c-1], str) and "/description" in headers[c-1]
    ]
    verification[ws.title] = {
        "rows": ws.max_row,
        "cols": ws.max_column,
        "remaining_matches": len(remaining),
        "sample_headers": headers[:15],
    }

print("Verification:", verification)

output_spreadsheet = output_path
```
