from openpyxl import load_workbook
from pathlib import Path

output_path = Path("/sandbox/output/output_spreadsheet") / Path(input_spreadsheet).name

wb = load_workbook(output_path)
ws = wb["Sheet1"]

# Identify retained/nonblank ID rows after consolidation
id_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, 1).value is not None]
first_id_row = id_rows[0] if id_rows else None
last_id_row = id_rows[-1] if id_rows else None

# Collect the two original F-column values from rows that contain values
f_values = []
for r in range(1, ws.max_row + 1):
    val = ws.cell(r, 6).value
    if val is not None:
        f_values.append(val)

# Clear existing F values, then place them on first and last ID rows respectively
for r in range(1, ws.max_row + 1):
    ws.cell(r, 6).value = None

if len(f_values) >= 1 and first_id_row is not None:
    ws.cell(first_id_row, 6).value = f_values[0]
if len(f_values) >= 2 and last_id_row is not None:
    ws.cell(last_id_row, 6).value = f_values[1]

# Set exact requested date display format on populated cells in column C
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 3).value is not None:
        ws.cell(r, 3).number_format = "m/dd/yyyy hh:ss"

wb.save(output_path)

# Verify key results
check = load_workbook(output_path)
cws = check["Sheet1"]

print("retained ID rows:", [r for r in range(2, cws.max_row + 1) if cws.cell(r, 1).value is not None])
for r in range(1, cws.max_row + 1):
    print(r, [cws.cell(r, c).value for c in range(1, 9)])

for coord in ["C2", "C4", "C6", "C8", "F2", "F6", "F8"]:
    cell = cws[coord]
    print(coord, "value=", cell.value, "fmt=", cell.number_format)

final_output_path = str(output_path)
```
