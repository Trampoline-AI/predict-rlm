from openpyxl import load_workbook
from openpyxl.styles import Font
from pathlib import Path
import os, shutil

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Capture original date number formats from existing date cells in column C
date_formats = {}
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 3).value is not None:
        date_formats[r] = ws.cell(r, 3).number_format

# Unmerge all merged cells in worksheet
merged_ranges = [str(rng) for rng in ws.merged_cells.ranges]
for rng in merged_ranges:
    ws.unmerge_cells(rng)

# Consolidate duplicates in A:D while keeping row structure unchanged
first_row_by_id = {}
sum_by_id = {}

for r in range(2, ws.max_row + 1):
    id_val = ws.cell(r, 1).value
    amt_val = ws.cell(r, 4).value
    if id_val is None:
        continue
    if id_val not in first_row_by_id:
        first_row_by_id[id_val] = r
        sum_by_id[id_val] = 0
    # sum amounts as integers, rounding if needed
    if amt_val is not None:
        sum_by_id[id_val] += int(round(float(amt_val)))

# Write summed amount to first occurrence row; clear duplicate rows A:D
seen = set()
for r in range(2, ws.max_row + 1):
    id_val = ws.cell(r, 1).value
    if id_val is None:
        continue
    if id_val not in seen:
        seen.add(id_val)
        ws.cell(r, 4).value = int(sum_by_id[id_val])
    else:
        for c in range(1, 5):
            ws.cell(r, c).value = None

# Apply formatting rules only to A:D table area
for r in range(1, ws.max_row + 1):
    for c in range(1, 5):
        cell = ws.cell(r, c)
        # non-bold, black
        existing_font = cell.font
        cell.font = existing_font.copy(bold=False, color="000000")
        # Amount as integer/no decimals
        if c == 4 and cell.value is not None:
            cell.number_format = "0"

# Keep date formatting the same on retained date cells in column C
for r in range(2, ws.max_row + 1):
    cell = ws.cell(r, 3)
    if cell.value is not None:
        # use original format from that row if available; otherwise preserve current/default
        fmt = date_formats.get(r, cell.number_format)
        cell.number_format = fmt

wb.save(output_path)

# Verify
check_wb = load_workbook(output_path)
check_ws = check_wb["Sheet1"]

print("Saved to:", output_path)
print("Merged ranges after save:", list(check_ws.merged_cells.ranges))
for r in range(1, check_ws.max_row + 1):
    vals = [check_ws.cell(r, c).value for c in range(1, 9)]
    print(r, vals)

# Print some formatting checks for A:D
for coord in ["A1", "A2", "D2", "C2", "A3", "D6", "F2", "F6"]:
