    print(coord, "value=", cell.value, "bold=", cell.font.bold, "color=", cell.font.color.type if cell.font.color else None, cell.font.color.rgb if cell.font.color and cell.font.color.type=="rgb" else None, "fmt=", cell.number_format)

final_output_path = str(output_path)
