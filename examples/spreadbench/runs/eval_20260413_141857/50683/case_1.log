Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Re-open cleanly
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Safe table inspection:")
print("ws.tables type:", type(ws.tables))
print("table names:", list(ws.tables.keys()))
for name in ws.tables.keys():
    tbl = ws.tables[name]
    print("name:", name, "type:", type(tbl), "repr:", tbl)

# Compute latest 4 nonblank scores from columns B:N for each golfer
results = {}
for r in range(2, ws.max_row + 1):
    scores = [ws.cell(r, c).value for c in range(2, 15)]  # B:N
    nonblank = [v for v in scores if v is not None and v != ""]
    last4 = nonblank[-4:]
    avg_last4 = sum(last4) / len(last4) if last4 else None
    results[r] = {
        "scores": scores,
        "nonblank": nonblank,
        "last4": last4,
        "avg_last4": avg_last4
    }

print("\nComputed last-4 averages:")
for r, info in results.items():
    print(r, "last4 =", info["last4"], "avg =", info["avg_last4"])

# Write results to output workbook
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

for r, info in results.items():
    ws.cell(r, 17).value = info["avg_last4"]  # column Q, "last 4 trend"
    ws.cell(r, 17).number_format = "0.00"

wb.save(out_path)
print("\nSaved to:", out_path)

# Verify saved values
wb_check = load_workbook(out_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("\nVerification of Q column:")
for r in range(1, ws_check.max_row + 1):
    print(r, ws_check.cell(r, 17).value)
```
