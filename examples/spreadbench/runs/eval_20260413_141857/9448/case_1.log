Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Re-open workbook for editing
wb = load_workbook(input_spreadsheet)
ws = wb["Data"]

# Inspect relevant area more closely
print("Relevant rows/cols preview:")
for r in range(6, 19):
    vals = [ws.cell(r, c).value for c in range(7, 22)]  # G:U
    print(r, vals)

print("\nCurrent U column styles/formats before change:")
for r in range(8, 19):
    cell = ws[f"U{r}"]
    print(r, "value=", cell.value, "numfmt=", cell.number_format)

# Excel-2010-compatible formula:
# - Find last nonblank sale in I:T
# - Determine matching month from row 7
# - Determine year by taking the last numeric header in row 6 up to that column
# - Return DATE(year, month_num, 1)
month_array = '{"January","February","March","April","May","June","July","August","September","October","November","December"}'

for r in range(9, 19):
    lastcol_expr = f'LOOKUP(2,1/($I{r}:$T{r}<>""),COLUMN($I{r}:$T{r}))'
    month_expr = f'INDEX($I$7:$T$7,1,{lastcol_expr}-COLUMN($I$7)+1)'
    year_range_expr = f'$I$6:INDEX($6:$6,{lastcol_expr})'
    year_expr = f'LOOKUP(2,1/(ISNUMBER({year_range_expr})),{year_range_expr})'
    formula = f'=IF(COUNT($I{r}:$T{r})=0,"",DATE({year_expr},MATCH({month_expr},{month_array},0),1))'
    ws[f"U{r}"] = formula
    ws[f"U{r}"].number_format = "DD/MM/YYYY"

# Save to output
output_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb.save(output_path)

print("\nWritten formulas in U9:U18:")
for r in range(9, 19):
    print(r, ws[f"U{r}"].value, ws[f"U{r}"].number_format)

print("\nSaved to:", output_path)
```
