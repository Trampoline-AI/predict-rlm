Code:
```repl
import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Write formulas for each month in the result section.
# Compare month names from dates in A3:A6 to the label in column A, then sum matching amounts.
for row in range(10, 12):
    ws.cell(row=row, column=2).value = f'=SUMPRODUCT((TEXT($A$3:$A$6,"MMMM")=A{row})*($B$3:$B$6))'

# Save with same filename in output directory
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

print("Saved to:", output_path)

# Recalculate and verify
recalc_status = await recalculate(output_path)
print("Recalc:", recalc_status)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("Formulas:", ws_check["B10"].value, ws_check["B11"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Values:", ws_values["B10"].value, ws_values["B11"].value)

output_spreadsheet = output_path
```
