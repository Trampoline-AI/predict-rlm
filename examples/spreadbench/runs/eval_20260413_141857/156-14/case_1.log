Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)

target_sheets = ["99250", "99251", "99252"]
deletion_summary = {}

for sheet_name in target_sheets:
    ws = wb[sheet_name]
    rows_to_delete = []
    for r in range(6, ws.max_row + 1):
        val = ws.cell(r, 6).value
        if isinstance(val, str) and "to be processed" in val.lower():
            rows_to_delete.append(r)
    deletion_summary[sheet_name] = rows_to_delete[:]
    for r in reversed(rows_to_delete):
        ws.delete_rows(r, 1)

wb.save(outfile)

# Verify by reopening
vwb = load_workbook(outfile)
verification = {}
for sheet_name in target_sheets:
    ws = vwb[sheet_name]
    remaining_matches = []
    rows_snapshot = []
    for r in range(1, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        rows_snapshot.append(row_vals)
        val = ws.cell(r, 6).value
        if r >= 6 and isinstance(val, str) and "to be processed" in val.lower():
            remaining_matches.append(r)
    verification[sheet_name] = {
        "max_row": ws.max_row,
        "remaining_matches": remaining_matches,
        "rows_1_to_end": rows_snapshot,
    }

print("Saved to:", outfile)
print("Deletion summary:", deletion_summary)
for k, v in verification.items():
    print("\nSheet:", k)
    print("max_row:", v["max_row"])
    print("remaining matches:", v["remaining_matches"])
    for i, row in enumerate(v["rows_1_to_end"], start=1):
        print(i, row)
```
