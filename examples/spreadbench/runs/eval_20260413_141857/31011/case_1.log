import os, shutil
from openpyxl import load_workbook

# Reload workbook normally (with formulas)
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect nearby cells/styles to mirror conventions if useful
for coord in ["P3","Q3","R3","P4","Q4","R4","P5","Q5","R5","P6","Q6","R6"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

# Build a LibreOffice-safe SUMPRODUCT formula:
# rows: (A2:A20>=P6)*(A2:A20<=Q6)
# cols: (B1:M1>=R3)*(B1:M1<=R4)
# data: B2:M20
formula = "=SUMPRODUCT(($A$2:$A$20>=$P$6)*($A$2:$A$20<=$Q$6)*($B$1:$M$1>=$R$3)*($B$1:$M$1<=$R$4)*$B$2:$M$20)"
ws["R6"] = formula

print("Set R6 formula to:", ws["R6"].value)

# Save to output path with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(out_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("Stored formula in R6:", ws_check["R6"].value)

wb_val = load_workbook(out_path, data_only=True)
ws_val = wb_val["Sheet1"]
print("Cached value R6:", ws_val["R6"].value)

output_spreadsheet = out_path
```
