So the most literal and reliable solution is to place formulas in `Result!G10:L10` that:
1. Match the item in row 2 against `Master-RM!A12:A20`
2. Use row 3 to choose the correct source amount column:
   - `I` for `Shrawan`
   - `K` for `Bhadra`

I’ll write these formulas, save to the output path with the same filename, recalculate, and verify the resulting values.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws_r = wb["Result"]

# Write lookup formulas in G10:L10 based on item in row 2 and month in row 3.
# Shrawan -> Master-RM column I
# Bhadra  -> Master-RM column K
for col in range(7, 13):  # G:L
    cell = ws_r.cell(10, col)
    col_letter = cell.column_letter
    formula = (
        f'=IF({col_letter}$3="Shrawan",'
        f'INDEX(\'Master-RM\'!$I$12:$I$20, MATCH({col_letter}$2, \'Master-RM\'!$A$12:$A$20, 0)),'
        f'IF({col_letter}$3="Bhadra",'
        f'INDEX(\'Master-RM\'!$K$12:$K$20, MATCH({col_letter}$2, \'Master-RM\'!$A$12:$A$20, 0)),'
        f'""'
        f'))'
    )
    cell.value = formula

wb.save(outfile)
print("Saved:", outfile)

# Recalculate formulas and verify
recalc_status = await recalculate(outfile)
print("Recalc:", recalc_status)

wb_check = load_workbook(outfile, data_only=False)
ws_check = wb_check["Result"]
print("Formulas G10:L10:", [ws_check.cell(10, c).value for c in range(7, 13)])

wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Result"]
print("Values G10:L10:", [ws_vals.cell(10, c).value for c in range(7, 13)])

output_spreadsheet = outfile
```
