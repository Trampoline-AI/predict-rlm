Next I’ll perform the modification, save to the required output path with the same filename, and print verification of the resulting rows and retained important rows.
Code:
```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)

changes = {}

for ws in wb.worksheets:
    pairs_to_delete = []
    for r in range(1, ws.max_row):
        cur = ws.cell(r, 1).value
        below = ws.cell(r + 1, 1).value
        if isinstance(cur, str) and "Line No" in cur and (below is None or str(below).strip() == ""):
            pairs_to_delete.append((r, r + 1))
    changes[ws.title] = pairs_to_delete

    # delete bottom-up so row shifting does not affect earlier targets
    for r1, r2 in reversed(pairs_to_delete):
        ws.delete_rows(r1, 2)

wb.save(outfile)

print("Saved to:", outfile)
print("Planned deletions:", changes)

# verification
vwb = load_workbook(outfile)
for ws in vwb.worksheets:
    print(f"\nVerified sheet {ws.title}: rows={ws.max_row}, cols={ws.max_column}")
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(6, ws.max_column + 1))]
        print(r, vals)
```
