Code:
```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

changed_rows = []

def is_whole_number_amount(val):
    if val is None:
        return False
    if isinstance(val, bool):
        return False
    if isinstance(val, int):
        return True
    if isinstance(val, float):
        return float(val).is_integer()
    return False

for r in range(1, ws.max_row + 1):
    f_val = ws.cell(r, 6).value  # Column F
    j_val = ws.cell(r, 10).value # Column J
    if f_val == "Marble Slab Creamery" and is_whole_number_amount(j_val):
        ws.cell(r, 6).value = "Georgia State WH"
        changed_rows.append((r, f_val, j_val, ws.cell(r, 6).value))

wb.save(output_path)

# Verify by reopening
wb_verify = load_workbook(output_path, data_only=False)
wsv = wb_verify[wb_verify.sheetnames[0]]
verification = [(r, wsv.cell(r, 6).value, wsv.cell(r, 10).value) for r, *_ in changed_rows]

print("Output saved:", output_path, os.path.exists(output_path))
print("Changed rows:", changed_rows)
print("Verification:", verification)
print("All rows 1-15 F/J after update:", [(r, wsv.cell(r, 6).value, wsv.cell(r, 10).value) for r in range(1, min(15, wsv.max_row)+1)])
```
