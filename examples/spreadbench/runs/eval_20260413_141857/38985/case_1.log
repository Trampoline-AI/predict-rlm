import os
from collections import defaultdict
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet1"]

# Build lookup from Table 2 (columns L:N), stopping before placeholder rows like … / …..
lookup = defaultdict(list)
for r in range(7, ws.max_row + 1):
    name = ws[f"L{r}"].value
    v1 = ws[f"M{r}"].value
    v2 = ws[f"N{r}"].value
    if name is None:
        continue
    if str(name).strip() in {"…", "….."}:
        continue
    lookup[name].append((v1, v2))

print("Lookup built:", dict(lookup))

# Fill Table 1 rows (starting row 7, key in column C, outputs across D onward)
for r in range(7, ws.max_row + 1):
    key = ws[f"C{r}"].value
    if key is None:
        continue
    matches = lookup.get(key, [])
    # Clear target area D:I to avoid stale values, but preserve headers/other layout
    for c in range(4, 10):  # D:I
        ws.cell(r, c).value = None
    # Write matches across row as (val1,val2), (val1,val2), ...
    out_col = 4
    for pair in matches:
        if out_col + 1 > 9:  # stay within D:I in this template
            break
        ws.cell(r, out_col).value = pair[0]
        ws.cell(r, out_col + 1).value = pair[1]
        out_col += 2

wb.save(outfile)

# Verify output
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb["Sheet1"]
for r in range(7, 12):
    vals = [check_ws.cell(r, c).value for c in range(3, 10)]  # C:I
    print(r, vals)

output_spreadsheet = outfile
```
