from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Header row:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Inspect relevant columns C, I, M across all populated rows
sample = []
for r in range(1, ws.max_row + 1):
    sample.append((r, ws[f"C{r}"].value, ws[f"I{r}"].value, ws[f"M{r}"].value))
print("Row, C(A_Name), I(Entry Time), M(Max) samples:")
for row in sample[:20]:
    print(row)

print("Last few rows:")
for row in sample[-10:]:
    print(row)

# Apply formula to Max column (M), keeping header
last_row = ws.max_row
if ws["M1"].value is None:
    ws["M1"] = "Max"

for r in range(2, last_row + 1):
    ws[f"M{r}"] = f'=IF(COUNTIFS($C$2:$C${last_row},C{r},$I$2:$I${last_row},">"&I{r})>0,"Not Latest","Latest")'

# Save output
import os
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Re-open and verify formulas were written
check_wb = load_workbook(output_path, data_only=False)
check_ws = check_wb[check_wb.sheetnames[0]]
print("Verification of formulas in M2:M12:")
for r in range(2, min(12, check_ws.max_row) + 1):
    print(r, check_ws[f"C{r}"].value, check_ws[f"I{r}"].value, check_ws[f"M{r}"].value)

output_spreadsheet = output_path
