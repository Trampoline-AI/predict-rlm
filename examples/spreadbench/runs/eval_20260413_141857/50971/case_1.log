from openpyxl import load_workbook
import os

out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

# Load current output and replace UNIQUE spill with literal unique values from column A
wb = load_workbook(out_path)
ws = wb["Sheet1"]

# Compute unique values from source A2:A19 in first-seen order
seen = []
for r in range(2, 20):
    v = ws[f"A{r}"].value
    if v not in seen:
        seen.append(v)

print("Unique values:", seen)

# Clear F3:F13 and write literal unique list
for r in range(3, 14):
    ws[f"F{r}"] = None
for i, v in enumerate(seen, start=3):
    ws[f"F{i}"] = v

# Ensure E formulas exist for all unique rows
for r in range(3, 3 + len(seen)):
    ws[f"E{r}"] = f"=COUNTIF($A$2:$A$19,F{r})"

wb.save(out_path)
print("Saved revised workbook:", out_path)

# Recalculate and inspect cached results
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

check = load_workbook(out_path, data_only=True)
cws = check["Sheet1"]

for r in range(3, 14):
    row = [cws.cell(r, c).value for c in range(5, 12)]  # E:K
    print(r, row)
```
