Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Inspect array formula metadata in F3
f3 = ws["F3"]
print("F3 object:", f3.value)
for attr in ["text", "ref"]:
    try:
        print(attr, "=", getattr(f3.value, attr))
    except Exception as e:
        print(attr, "ERR", e)

# Determine bounds from existing unique list
start_row = 3
end_row = 13   # based on inspected sheet; rows with unique items
start_col = 7  # G
end_col = 11   # K

# Write formulas in G:K to fetch nth matching B value for duplicate A key in F-row.
# Formula logic:
# if count in E row > 1, return nth match from B where A == F-row, else blank.
# nth is based on output column position (G=1, H=2, ...).
for r in range(start_row, end_row + 1):
    for c in range(start_col, end_col + 1):
        n = c - start_col + 1
        formula = (
            f'=IF($E{r}>1,IFERROR(INDEX($B$2:$B$19,'
            f'SMALL(IF($A$2:$A$19=$F{r},ROW($A$2:$A$19)-ROW($A$2)+1),{n})),""),"")'
        )
        ws.cell(r, c).value = formula

# Save output
out_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Reload normally and inspect stored formulas
check_wb = load_workbook(out_path, data_only=False)
check_ws = check_wb["Sheet1"]
for r in range(3, 8):
    print(r, [check_ws.cell(r, c).value for c in range(5, 12)])
```
