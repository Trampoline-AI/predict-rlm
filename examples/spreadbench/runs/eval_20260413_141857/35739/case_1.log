Next I’ll apply this in `C2`, fill it down through the used rows in column C, preserve the time format, save to the output directory with the same filename, recalculate, and verify a few key rows including one after midnight.
Code:
```repl
import os, shutil
from openpyxl import load_workbook

# Load source workbook
src_path = input_spreadsheet
filename = os.path.basename(src_path)
out_dir = "/sandbox/output/output_spreadsheet"
out_path = os.path.join(out_dir, filename)

wb = load_workbook(src_path)
ws = wb["Sheet1"]

# Apply corrected formula from C2 down the used rows
for r in range(2, ws.max_row + 1):
    ws[f"C{r}"] = f'=IF(COUNTA(A{r}:B{r})=0,"",MOD(B{r}-TIME(0,30,0),1))'
    ws[f"C{r}"].number_format = ws[f"B{r}"].number_format or "h:mm"

# Save output
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate cached formula values
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Verify formulas and displayed values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula["Sheet1"]

wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values["Sheet1"]

print("C2 formula:", ws_formula["C2"].value)
print("C9 formula:", ws_formula["C9"].value)   # midnight-crossing example expected from 00:15 -> 23:45
print("Sample outputs:")
for r in [2, 4, 8, 9, 10, 99, 100]:
    print(
        r,
        "A=", ws_values[f"A{r}"].value,
        "B=", ws_values[f"B{r}"].value,
        "C=", ws_values[f"C{r}"].value
    )

output_spreadsheet = out_path
