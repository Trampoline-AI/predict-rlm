To avoid unsupported dynamic-array functions, I’ll write standard LibreOffice-compatible formulas. I’ll use:
- `COUNTIF($Arow,"*digit*")` to detect whether each digit 0–9 appears anywhere in the source text
- `MIN(...)` over candidate digits, with `99` as a sentinel for “not available”
- each next cell will reference the previous output cell to return the next larger present digit
- `IF(...=99,"",...)` to leave unused cells blank

Then I’ll save the workbook to the output directory, recalculate it, and verify the resulting values in `C2:G8`.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws = wb["Sheet2"]

def first_digit_formula(row):
    candidates = [f'IF(COUNTIF($A{row},"*{d}*"),{d},99)' for d in range(10)]
    min_expr = f"MIN({','.join(candidates)})"
    return f'=IF({min_expr}=99,"",{min_expr})'

def next_digit_formula(row, prev_col_letter):
    candidates = [f'IF(AND(COUNTIF($A{row},"*{d}*"),{d}>{prev_col_letter}{row}),{d},99)' for d in range(10)]
    min_expr = f"MIN({','.join(candidates)})"
    return f'=IF({prev_col_letter}{row}="","",IF({min_expr}=99,"",{min_expr}))'

# Fill formulas in C:G for rows 2:8
for row in range(2, 9):
    ws[f"C{row}"] = first_digit_formula(row)
    ws[f"D{row}"] = next_digit_formula(row, "C")
    ws[f"E{row}"] = next_digit_formula(row, "D")
    ws[f"F{row}"] = next_digit_formula(row, "E")
    ws[f"G{row}"] = next_digit_formula(row, "F")

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and verify
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

wb_check = load_workbook(outfile, data_only=False)
wsf = wb_check["Sheet2"]
print("Formulas C2:G8:")
for r in range(2, 9):
    print(r, [wsf[f"{col}{r}"].value for col in "CDEFG"])

wb_vals = load_workbook(outfile, data_only=True)
wsv = wb_vals["Sheet2"]
print("Values C2:G8:")
for r in range(2, 9):
    print(r, [wsv[f"{col}{r}"].value for col in "CDEFG"])
```
