from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Alignment
from openpyxl.utils import get_column_letter
import os, shutil

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect full header row / used columns
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("max_row, max_col:", ws.max_row, ws.max_column)
print("last 15 headers:", [(get_column_letter(c), headers[c-1]) for c in range(max(1, ws.max_column-14), ws.max_column+1)])

# Build output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Styles
green_fill = PatternFill(fill_type="solid", fgColor="E2EFDA")
center_align = Alignment(horizontal="center", vertical="center")
num_fmt = "0.###############"  # whole nums show no decimals; decimals preserved

# Fill formulas for all cells right of column G
# Formula logic for each target cell:
# - if current row is not a race-start row (B<>1), blank
# - if offset exceeds runner count C, blank
# - else fetch G from current row + offset
# - preserve blank source as blank
# - convert text numbers to numeric values
for r in range(2, ws.max_row + 1):
    for c in range(8, ws.max_column + 1):  # H to end
        col_letter = get_column_letter(c)
        offset = c - 8  # H=0, I=1, ...
        formula = (
            f'=IF($B{r}<>1,"",'
            f'IF({offset+1}>$C{r},"",'
            f'IF(INDEX($G$2:$G${ws.max_row},ROW()-1+{offset+1})="","",'
            f'VALUE(INDEX($G$2:$G${ws.max_row},ROW()-1+{offset+1}))))'
            f')'
        )
        ws.cell(r, c).value = formula
        ws.cell(r, c).alignment = center_align
        ws.cell(r, c).number_format = num_fmt

# Shade H2:S28 only
for r in range(2, min(28, ws.max_row) + 1):
    for c in range(8, min(19, ws.max_column) + 1):  # H:S
        ws.cell(r, c).fill = green_fill

# Also center align any existing cells to the right of G including header row
for r in range(1, ws.max_row + 1):
    for c in range(8, ws.max_column + 1):
        ws.cell(r, c).alignment = center_align

wb.save(out_path)
print("saved:", out_path)

# Recalculate and verify
rc = await recalculate(out_path)
print("recalculate:", rc)

wbv = load_workbook(out_path, data_only=False)
wsv = wbv[wbv.sheetnames[0]]
wbvd = load_workbook(out_path, data_only=True)
wsvd = wbvd[wbvd.sheetnames[0]]

# Print a few formulas and calculated values for race-start rows
for r in range(2, ws.max_row + 1):
    if wsv.cell(r, 2).value == 1:
        vals = [wsvd.cell(r, c).value for c in range(8, min(ws.max_column, 20) + 1)]
        formulas = [wsv.cell(r, c).value for c in range(8, min(ws.max_column, 12) + 1)]
        print("row", r, "C=", wsv.cell(r, 3).value, "sample vals H:T=", vals)
