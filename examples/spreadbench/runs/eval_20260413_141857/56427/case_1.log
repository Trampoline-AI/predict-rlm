from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Alignment
from openpyxl.utils import get_column_letter
import os

# Reload original workbook to avoid carrying forward wrong formulas
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

green_fill = PatternFill(fill_type="solid", fgColor="E2EFDA")
center_align = Alignment(horizontal="center", vertical="center")
num_fmt = "0.###############"

max_row = ws.max_row
max_col = ws.max_column

# Correct formulas: H should pull current row's G, then next consecutive rows.
for r in range(2, max_row + 1):
    for c in range(8, max_col + 1):
        offset = c - 8  # H=0, I=1, ...
        formula = (
            f'=IF($B{r}<>1,"",'
            f'IF({offset+1}>$C{r},"",'
            f'IF(INDEX($G$2:$G${max_row},ROW()-1+{offset})="","",'
            f'VALUE(INDEX($G$2:$G${max_row},ROW()-1+{offset}))))'
            f')'
        )
        cell = ws.cell(r, c)
        cell.value = formula
        cell.alignment = center_align
        cell.number_format = num_fmt

# Shade H2:S28
for r in range(2, min(28, max_row) + 1):
    for c in range(8, min(19, max_col) + 1):
        ws.cell(r, c).fill = green_fill

# Center align all cells to the right of G, including header row
for r in range(1, max_row + 1):
    for c in range(8, max_col + 1):
        ws.cell(r, c).alignment = center_align

wb.save(out_path)
print("saved corrected file:", out_path)

rc = await recalculate(out_path)
print("recalculate:", rc)

# Verify
wbf = load_workbook(out_path, data_only=False)
wsf = wbf[wbf.sheetnames[0]]
wbd = load_workbook(out_path, data_only=True)
wsd = wbd[wbd.sheetnames[0]]

for r in [2, 7, 15]:
    vals = [wsd.cell(r, c).value for c in range(8, 20)]  # H:S
    print("row", r, "B=", wsf.cell(r, 2).value, "C=", wsf.cell(r, 3).value, "H:S=", vals)

print("H2 formula:", wsf["H2"].value, "value:", wsd["H2"].value)
print("I2 formula:", wsf["I2"].value, "value:", wsd["I2"].value)
print("O7 value:", wsd["O7"].value, "P7 value:", wsd["P7"].value)
print("H2 fill:", wsf["H2"].fill.fgColor.rgb or wsf["H2"].fill.fgColor.value)
print("H2 numfmt:", wsf["H2"].number_format)
print("BE2 alignment:", wsf["BE2"].alignment.horizontal)
