import os, json, math, statistics
from collections import Counter, defaultdict
from openpyxl import load_workbook

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheets:", wb.sheetnames)

sheet_info = {}
for ws in wb.worksheets:
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    sheet_info[ws.title] = {
        "rows": max_row,
        "cols": max_col,
        "headers": headers[:10],
    }
    print(f"\nSheet: {ws.title} rows={max_row} cols={max_col}")
    print("First 10 headers:", headers[:10])
    
    # show first few rows
    for r in range(1, min(max_row, 8) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(max_col, 8) + 1)]
        print(f"Row {r} first 8 cells:", vals)
    
    # inspect duplicate counts by column
    dup_summaries = []
    for c in range(1, max_col + 1):
        vals = [ws.cell(r, c).value for r in range(2, max_row + 1)]
        nonempty = [v for v in vals if v not in (None, "")]
        if not nonempty:
            continue
        ctr = Counter(nonempty)
        dup_values = sum(1 for v, n in ctr.items() if n > 1)
        total_dupe_rows = sum(n for v, n in ctr.items() if n > 1)
        if dup_values > 0:
            dup_summaries.append((c, ws.cell(1, c).value, len(nonempty), dup_values, total_dupe_rows, ctr.most_common(5)))
    dup_summaries = sorted(dup_summaries, key=lambda x: (-x[4], x[0]))
    print("Top duplicate-heavy columns:")
    for item in dup_summaries[:10]:
        print(item)

