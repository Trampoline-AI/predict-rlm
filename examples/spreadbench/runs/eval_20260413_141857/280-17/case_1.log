import os
from openpyxl import load_workbook

# Inspect all rows fully
wb2 = load_workbook(input_spreadsheet)
ws = wb2[wb2.sheetnames[0]]

all_rows = []
for r in range(1, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    all_rows.append(row_vals)
    print(r, row_vals)

# Determine last occurrence rows based on column 2
target_col = 2
last_row_for_value = {}
for r in range(1, ws.max_row + 1):
    val = ws.cell(r, target_col).value
    last_row_for_value[val] = r

keep_rows = sorted(last_row_for_value.values())
print("Last row for each value:", last_row_for_value)
print("Rows to keep:", keep_rows)

# Remove rows not in keep_rows, deleting bottom-up
keep_set = set(keep_rows)
for r in range(ws.max_row, 0, -1):
    if r not in keep_set:
        ws.delete_rows(r, 1)

# Save output
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb2.save(output_path)
print("Saved to:", output_path)

# Verify output
verify_wb = load_workbook(output_path)
verify_ws = verify_wb[verify_wb.sheetnames[0]]
print("Verified rows after filtering:")
for r in range(1, verify_ws.max_row + 1):
    print(r, [verify_ws.cell(r, c).value for c in range(1, verify_ws.max_column + 1)])

final_output_path = output_path
