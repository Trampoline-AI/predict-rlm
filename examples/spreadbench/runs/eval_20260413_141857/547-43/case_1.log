Code:
```repl
import os
from openpyxl import load_workbook

# Load source workbook
src_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src_path))

wb = load_workbook(src_path)
ws_emp = wb["Emp"]
ws_lookup = wb["Lookup"]
ws_target = wb["Expected"]

# Read headers
emp_headers = [ws_emp.cell(1, c).value for c in range(1, ws_emp.max_column + 1)]
id_headers = emp_headers[:4]
variable_headers = emp_headers[4:]

# Build lookup mapping
lookup_map = {}
for r in range(2, ws_lookup.max_row + 1):
    variable = ws_lookup.cell(r, 1).value
    category = ws_lookup.cell(r, 2).value
    subcategory = ws_lookup.cell(r, 3).value
    lookup_map[variable] = (category, subcategory)

# Build transformed rows
output_rows = [["seqno", "Empno", "ename", "Jobid", "Variable", "Category", "Subcategory", "Value"]]
for r in range(2, ws_emp.max_row + 1):
    base = [ws_emp.cell(r, c).value for c in range(1, 5)]
    for idx, var in enumerate(variable_headers, start=5):
        value = ws_emp.cell(r, idx).value
        category, subcategory = lookup_map.get(var, (None, None))
        output_rows.append(base + [var, category, subcategory, value])

# Clear existing target area contents
for row in ws_target.iter_rows():
    for cell in row:
        cell.value = None

# Write transformed data into Expected sheet
for r_idx, row_vals in enumerate(output_rows, start=1):
    for c_idx, val in enumerate(row_vals, start=1):
        ws_target.cell(r_idx, c_idx).value = val

# Save output
wb.save(out_path)

# Verify by reopening
verify_wb = load_workbook(out_path, data_only=True)
verify_ws = verify_wb["Expected"]
verified = []
for r in range(1, len(output_rows) + 1):
    verified.append([verify_ws.cell(r, c).value for c in range(1, 9)])

print("Saved to:", out_path)
print("Rows written:", len(output_rows))
print("First 10 verified rows:")
for row in verified[:10]:
    print(row)
print("Verification match:", verified == output_rows)
```
