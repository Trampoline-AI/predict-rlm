import os
from openpyxl import load_workbook

# Re-open workbook and inspect remaining rows in C:D
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Rows 4 to", ws.max_row, "C and D:")
for r in range(4, ws.max_row + 1):
    print(r, ws[f"C{r}"].value, ws[f"D{r}"].value)

# Update formulas in column D for all rows with values in column C
for r in range(4, ws.max_row + 1):
    if ws[f"C{r}"].value is not None:
        ws[f"D{r}"] = f'=IF(AND(C{r}>=5,C{r}<=6),5,IF(AND(C{r}>=3,C{r}<=4),3.75,IF(AND(C{r}>=1,C{r}<=2),1,0)))'

# Save to output path with same filename
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["Sheet1"]
print("Updated formulas sample:")
for r in range(4, min(ws_check.max_row, 10) + 1):
    print(r, ws_check[f"D{r}"].value)

wb_vals = load_workbook(output_path, data_only=True)
ws_vals = wb_vals["Sheet1"]
print("Computed values rows 4 to", ws_vals.max_row)
for r in range(4, ws_vals.max_row + 1):
    print(r, ws_vals[f"C{r}"].value, ws_vals[f"D{r}"].value)

final_output_path = output_path
```
