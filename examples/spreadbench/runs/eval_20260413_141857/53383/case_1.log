Because `worksheet 1` includes a trailing space in one status (`closed `), I should use `TRIM` in the formula so the comparison behaves as intended. I’ll write the formula into the populated rows of column C in `worksheet2`, save the workbook to the output directory, recalculate it, and verify the results with a data-only reload.
Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally to write formulas
wb = load_workbook(input_path)
ws1 = wb["worksheet 1"]
ws2 = wb["worksheet2"]

# Write formulas in worksheet2 column C for data rows
for row in range(3, ws2.max_row + 1):
    name_val = ws2.cell(row=row, column=1).value
    status_val = ws2.cell(row=row, column=2).value
    if name_val is not None and status_val is not None:
        ws2.cell(row=row, column=3).value = (
            f'=IFERROR(IF(TRIM(B{row})=TRIM(VLOOKUP(A{row},\'worksheet 1\'!A:B,2,FALSE)),"Matched","Not Matched"),"Not Matched")'
        )

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate and verify
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

wb_check = load_workbook(output_path, data_only=False)
ws2_check = wb_check["worksheet2"]
print("Formulas in C3:C6:")
for row in range(3, 7):
    print(row, ws2_check[f"C{row}"].value)

wb_values = load_workbook(output_path, data_only=True)
ws2_values = wb_values["worksheet2"]
print("Calculated values in C3:C6:")
for row in range(3, 7):
    print(row, ws2_values[f"C{row}"].value)
```
