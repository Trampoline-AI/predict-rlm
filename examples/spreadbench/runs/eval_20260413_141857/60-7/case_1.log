1. Extract records from "Existing Task", "Additions", and "Retired" using the same 5 columns.
2. Compute the net records literally as Existing + Additions - Retired, treating rows as full-row records and removing retired matches once per occurrence.
3. Write the resulting rows into "Consolidated Tracker" starting at row 3, columns A:E.
4. Clear any leftover old content below the written rows.
5. Save to the output directory with the same filename and verify by reopening and printing the written rows.
Code:
```repl
import os
from collections import Counter
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
ws_cons = wb["Consolidated Tracker"]
ws_exist = wb["Existing Task"]
ws_add = wb["Additions"]
ws_ret = wb["Retired"]

def extract_rows(ws, start_row=3, cols=5):
    rows = []
    for r in range(start_row, ws.max_row + 1):
        vals = tuple(ws.cell(r, c).value for c in range(1, cols + 1))
        if any(v is not None for v in vals):
            rows.append(vals)
    return rows

existing_rows = extract_rows(ws_exist)
addition_rows = extract_rows(ws_add)
retired_rows = extract_rows(ws_ret)

# Compute Existing + Additions - Retired, removing exact row matches once per occurrence.
combined_rows = list(existing_rows) + list(addition_rows)
retired_counter = Counter(retired_rows)

final_rows = []
for row in combined_rows:
    if retired_counter[row] > 0:
        retired_counter[row] -= 1
    else:
        final_rows.append(row)

print("Existing:", len(existing_rows))
print("Additions:", len(addition_rows))
print("Retired:", len(retired_rows))
print("Final:", len(final_rows))
print("Final rows preview:", final_rows)

# Write to Consolidated Tracker starting at row 3, columns A:E
start_row = 3
max_write_cols = 5

# Clear a reasonable output area first (existing sheet is small, so clear all rows below header across existing used width)
for r in range(3, max(ws_cons.max_row, start_row + len(final_rows) + 20) + 1):
    for c in range(1, max_write_cols + 1):
        ws_cons.cell(r, c).value = None

for i, row in enumerate(final_rows, start=start_row):
    for c, val in enumerate(row, start=1):
        ws_cons.cell(i, c).value = val

wb.save(outfile)
print("Saved to:", outfile)

# Verify
check_wb = load_workbook(outfile, data_only=False)
check_ws = check_wb["Consolidated Tracker"]
written = []
for r in range(1, check_ws.max_row + 1):
    vals = [check_ws.cell(r, c).value for c in range(1, 6)]
    if any(v is not None for v in vals):
        written.append((r, vals))
print("Non-empty rows in Consolidated Tracker (A:E):")
for item in written:
    print(item)

output_spreadsheet = outfile
```
