Code:
```repl
import os
import copy
from collections import Counter
from datetime import datetime
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
src = wb["Imported Data"]
dst = wb["Duplicates"]

def parse_sort_date(v):
    if v is None:
        return datetime.max
    if isinstance(v, datetime):
        return v
    if isinstance(v, str):
        s = v.strip()
        for fmt in ("%d/%m/%Y", "%m/%d/%Y", "%Y-%m-%d"):
            try:
                return datetime.strptime(s, fmt)
            except ValueError:
                pass
    return datetime.max

# Read source rows, skipping completely blank rows
source_rows = []
for r in range(2, src.max_row + 1):
    vals = [src.cell(r, c).value for c in range(1, src.max_column + 1)]
    if all(v is None for v in vals):
        continue
    source_rows.append({
        "rownum": r,
        "values": vals,
        "ref": vals[2],
        "date": vals[3],
        "balance": vals[4],
    })

ref_counts = Counter(row["ref"] for row in source_rows if row["ref"] is not None)
duplicate_rows = [row for row in source_rows if ref_counts[row["ref"]] > 1]

duplicate_rows.sort(key=lambda x: (
    float(x["balance"]) if x["balance"] is not None else float("inf"),
    parse_sort_date(x["date"])
))

# Clear destination sheet contents
for row in dst.iter_rows():
    for cell in row:
        cell.value = None
        cell._style = copy.copy(src.cell(1, min(cell.column, src.max_column))._style) if cell.row == 1 else copy.copy(cell._style)

# Copy header from source row 1
for c in range(1, src.max_column + 1):
    s = src.cell(1, c)
    d = dst.cell(1, c)
    d.value = s.value
    d._style = copy.copy(s._style)
    if s.has_style:
        d.font = copy.copy(s.font)
        d.fill = copy.copy(s.fill)
        d.border = copy.copy(s.border)
        d.alignment = copy.copy(s.alignment)
        d.number_format = s.number_format
        d.protection = copy.copy(s.protection)
    if src.column_dimensions[s.column_letter].width is not None:
        dst.column_dimensions[s.column_letter].width = src.column_dimensions[s.column_letter].width

# Copy duplicate rows with values + styles from source
out_row = 2
for item in duplicate_rows:
    r = item["rownum"]
    for c in range(1, src.max_column + 1):
        s = src.cell(r, c)
        d = dst.cell(out_row, c)
        d.value = s.value
        d._style = copy.copy(s._style)
        if s.has_style:
            d.font = copy.copy(s.font)
            d.fill = copy.copy(s.fill)
            d.border = copy.copy(s.border)
            d.alignment = copy.copy(s.alignment)
            d.number_format = s.number_format
            d.protection = copy.copy(s.protection)
    out_row += 1

# Remove any leftover old rows beneath output area by blanking them
for r in range(out_row, dst.max_row + 1):
    for c in range(1, dst.max_column + 1):
        dst.cell(r, c).value = None

wb.save(outfile)

# Verify
check = load_workbook(outfile)
vsrc = check["Imported Data"]
vdst = check["Duplicates"]

print("Saved:", outfile)
print("Duplicate references:", sorted(set(row["ref"] for row in duplicate_rows)))
print("Rows written (excluding header):", len(duplicate_rows))
for r in range(1, min(vdst.max_row, 8) + 1):
    print("Duplicates row", r, [vdst.cell(r, c).value for c in range(1, vdst.max_column + 1)])

print("Date alignments in output D column:")
for r in range(2, 2 + len(duplicate_rows)):
    print(
        r,
        "value=", vdst.cell(r, 4).value,
        "alignment=", (vdst.cell(r, 4).alignment.horizontal, vdst.cell(r, 4).alignment.vertical),
        "numfmt=", vdst.cell(r, 4).number_format
    )

output_spreadsheet = outfile
```
