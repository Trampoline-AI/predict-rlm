from openpyxl import load_workbook
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["INPUTS"]
s2 = wb["Sheet2"]

# Print the relevant INPUTS rows/cols including formulas in the expense section
for r in range(14, 21):
    vals = [ws.cell(r, c).value for c in range(1, 9)]
    print("INPUTS", r, vals)

print("\nSheet2 relevant rows:")
for r in range(1, 13):
    vals = [s2.cell(r, c).value for c in range(1, 8)]
    print("Sheet2", r, vals)

# Show exact formulas C:G for rows 15:17
for r in [15, 16, 17]:
    print(f"\nRow {r} formulas/values C:G")
    for c in range(3, 8):
        cell = ws.cell(r, c)
        print(cell.coordinate, cell.value)

# Prepare output path and apply fix to Electricity row only (first 5 years = C:G)
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb2 = load_workbook(outfile)
wsi = wb2["INPUTS"]

# Formula that matches both region (A14) and expense name (column A of current row), 
# and year header from row 3. Use SUMPRODUCT-based row locator to avoid array-entered formulas.
for c in range(3, 8):  # C:G
    coord_year = wsi.cell(3, c).coordinate
    row_num = wsi.cell(16, 1).row
    formula = (
        "=_xlfn.IFNA(INDEX(Sheet2!$C$3:$G$20,"
        f"SUMPRODUCT((Sheet2!$A$3:$A$20=INPUTS!$A$14)*(Sheet2!$B$3:$B$20=INPUTS!$A${row_num})*(ROW(Sheet2!$A$3:$A$20)-ROW(Sheet2!$A$3)+1)),"
        f"MATCH(INPUTS!{coord_year},Sheet2!$C$1:$G$1,0)),0)"
    )
    wsi.cell(16, c).value = formula

wb2.save(outfile)
print("\nSaved to", outfile)

# Verify formulas written
wb_check = load_workbook(outfile)
wsc = wb_check["INPUTS"]
print("Written formulas C16:G16:")
for c in range(3, 8):
    print(wsc.cell(16, c).coordinate, wsc.cell(16, c).value)
