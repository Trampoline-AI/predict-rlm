import os, shutil
from openpyxl import load_workbook
from collections import Counter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Copy original file first, then edit in place
shutil.copy2(input_path, output_path)

wb_out = load_workbook(output_path)
ws = wb_out["Sheet1"]

# Identify duplicate rows based only on Column A, among data rows starting at row 3
seen = set()
rows_to_delete = []
for r in range(3, ws.max_row + 1):
    val = ws.cell(r, 1).value
    if val is None:
        continue
    if val in seen:
        rows_to_delete.append(r)
    else:
        seen.add(val)

print("Rows to delete:", rows_to_delete)

# Delete from bottom to top
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

wb_out.save(output_path)
print("Saved to:", output_path)

# Verify output
wb_check = load_workbook(output_path)
ws_check = wb_check["Sheet1"]
rows_after = [[ws_check.cell(r, c).value for c in range(1, ws_check.max_column + 1)] for r in range(1, ws_check.max_row + 1)]
colA_after = [ws_check.cell(r, 1).value for r in range(3, ws_check.max_row + 1) if ws_check.cell(r, 1).value is not None]
counts_after = Counter(colA_after)

print("Dimensions after:", ws_check.max_row, "rows x", ws_check.max_column, "cols")
print("Column A counts after duplicates removed:", {k: v for k, v in counts_after.items() if v > 1})
print("Rows 1-16 after:")
for i, row in enumerate(rows_after[:16], start=1):
    print(i, row)

final_output_path = output_path
```
