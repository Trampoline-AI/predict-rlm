from openpyxl import load_workbook
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

header_q = ws["Q1"].value
print("Q1 header:", repr(header_q))
print("Max row/col:", ws.max_row, ws.max_column)

match_rows = []
already_vw = 0
other_q_values = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    q = ws.cell(r, 17).value
    is_match = (a == "Government" and b == "Germany" and c == "Carretera")
    if is_match:
        match_rows.append(r)
        if q == "Volkswagen":
            already_vw += 1
    elif q not in (None, ""):
        other_q_values.append((r, q))

print("Matching rows count:", len(match_rows))
print("Matching rows already Volkswagen:", already_vw)
print("First 10 matching rows:", match_rows[:10])
print("Non-matching rows with any Q value count:", len(other_q_values))
print("Sample non-matching rows with Q values:", other_q_values[:10])

# Apply transformation
for r in match_rows:
    ws.cell(r, 17).value = "Volkswagen"

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Verify saved result
wb2 = load_workbook(out_path, data_only=False)
ws2 = wb2[wb2.sheetnames[0]]

post_bad = []
post_good = 0
for r in range(2, ws2.max_row + 1):
    a = ws2.cell(r, 1).value
    b = ws2.cell(r, 2).value
    c = ws2.cell(r, 3).value
    q = ws2.cell(r, 17).value
    is_match = (a == "Government" and b == "Germany" and c == "Carretera")
    if is_match:
        if q == "Volkswagen":
            post_good += 1
        else:
            post_bad.append((r, q))

print("Verified matching rows with Volkswagen:", post_good)
print("Any matching rows not updated?:", post_bad[:10])
output_path = out_path
```
