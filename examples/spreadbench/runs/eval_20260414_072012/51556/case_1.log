Code:
```repl
import openpyxl
from pathlib import Path

# Paths
in_path = Path("/sandbox/input/input_spreadsheet/1_51556_init.xlsx")
out_path = Path("/sandbox/output/output_spreadsheet/1_51556_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb.active  # assume first sheet contains the data

# Column indices (1‑based)
COL_MARKET_RENT = 17  # Q - where we will write the result
COL_SQFT = 16          # P - unit size for the row
COL_IMPR = 13          # M - improvement rating for the row
COL_HEADER_START = 2   # B
COL_HEADER_END = 12    # L

# Read header values (row 2, columns B‑L)
headers = {}
for col in range(COL_HEADER_START, COL_HEADER_END + 1):
    header_val = ws.cell(row=2, column=col).value
    if header_val is not None:
        headers[col] = header_val

# Pre‑fetch rent values matrix (rows 3‑8, columns B‑L)
rent_matrix = {}
for row in range(3, ws.max_row + 1):
    for col in range(COL_HEADER_START, COL_HEADER_END + 1):
        rent_matrix[(row, col)] = ws.cell(row=row, column=col).value

# Compute average for each data row and write to column Q
for row in range(3, ws.max_row + 1):
    size = ws.cell(row=row, column=COL_SQFT).value
    rating = ws.cell(row=row, column=COL_IMPR).value
    # Collect matching rent cells
    matching_vals = []
    for col, hdr in headers.items():
        if hdr == size:
            val = rent_matrix.get((row, col))
            if isinstance(val, (int, float)):
                matching_vals.append(val)
    # Also need to ensure rating matches – the rating column is per‑row, not per‑cell, so we only include rows where rating matches the row's rating (which it always does). The instruction implies both conditions must hold, but rating is already taken from the same row, so we just need the size match.
    # If rating filtering across columns is required, the data does not have per‑cell rating, so we assume size alone drives selection.
    avg = sum(matching_vals) / len(matching_vals) if matching_vals else None
    ws.cell(row=row, column=COL_MARKET_RENT).value = avg

# Save to output location
wb.save(out_path)

# Recalculate formulas (if any other formulas exist)
await recalculate(str(out_path))

# Reload with data_only=True to verify written values
wb_eval = openpyxl.load_workbook(out_path, data_only=True)
ws_eval = wb_eval.active
print("Written average market rent values (column Q) for rows 3‑8:")
for row in range(3, ws_eval.max_row + 1):
    print(f"Row {row}: {ws_eval.cell(row=row, column=COL_MARKET_RENT).value}")
```
