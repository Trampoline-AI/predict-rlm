import openpyxl
from openpyxl.utils import get_column_letter
from pathlib import Path

# Load the workbook
wb_path = Path("/sandbox/input/input_spreadsheet/1_51556_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=False)

ws = wb.active  # assuming the data is on the first sheet

# Determine column indices
col_market_rent = 17  # Q
col_sqft = 16          # P
col_impr = 13          # M
col_header_start = 2   # B
col_header_end = 12    # L

# Build the fixed parts of the formula
market_range = f"${get_column_letter(col_market_rent)}$3:${get_column_letter(col_market_rent)}$8"
size_header_range = f"${get_column_letter(col_header_start)}$2:${get_column_letter(col_header_end)}$2"
impr_range = f"${get_column_letter(col_impr)}$3:${get_column_letter(col_impr)}$8"

# Write the formula for each data row
for r in range(3, ws.max_row + 1):
    size_cell = ws.cell(row=r, column=col_sqft).coordinate
    impr_cell = ws.cell(row=r, column=col_impr).coordinate
    formula = f"=AVERAGEIFS({market_range},{size_header_range},{size_cell},{impr_range},{impr_cell})"
    ws.cell(row=r, column=col_market_rent).value = formula

# Save to output location
