```repl
import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_51586_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_51586_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # Sheet1

max_row = ws.max_row

# Define fills
fill_true = PatternFill(start_color="C6EFCE", end_color="C6EFCE", fill_type="solid")   # light green
fill_false = PatternFill(start_color="FFC7CE", end_color="FFC7CE", fill_type="solid")  # light red

for r in range(2, max_row + 1):
    store_cell = ws.cell(row=r, column=1)   # A
    city_cell = ws.cell(row=r, column=2)    # B
    formula_cell = ws.cell(row=r, column=3)  # C

    # Write formula (using relative row reference)
    formula = f"""=IF(ISNUMBER(SEARCH(B{r},A{r})),IF(TRIM(SUBSTITUTE(A{r},B{r},""))="",TRUE,FALSE),FALSE)"""
    formula_cell.value = formula

    # Compute Python evaluation for fill color
    store = store_cell.value or ""
    city = city_cell.value or ""
    # Normalise to strings
    store_str = str(store)
    city_str = str(city)

    # Determine truth
    if city_str and city_str in store_str:
        # Remove city and trim
        remaining = store_str.replace(city_str, "", 1).strip()
        is_true = (remaining == "")
    else:
        is_true = False

    # Apply fill based on result
    formula_cell.fill = fill_true if is_true else fill_false

# Ensure output directory exists
import os
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload to verify a few cells (data_only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification (row, C value):")
for r in range(2, min(2+5, ws_check.max_row+1)):
    print(r, ws_check.cell(row=r, column=3).value)
