import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook("/sandbox/input/input_spreadsheet/1_49196_init.xlsx")
print("Sheets:", wb.sheetnames)

# Assume first sheet is the target
ws = wb[wb.sheetnames[0]]

# Determine max rows and columns
max_row = ws.max_row
max_col = ws.max_column
print(f"Rows: {max_row}, Columns: {max_col}")

# Print header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Headers:", headers)

# Print first 5 data rows
print("First 5 rows:")
for r in range(2, min(7, max_row+1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Print last 5 data rows
print("Last 5 rows:")
for r in range(max(max_row-4, 2), max_row+1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Inspect column C and K formulas for a few rows
print("Column C formulas (rows 2-5):")
