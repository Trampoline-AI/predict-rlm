import openpyxl
from openpyxl.utils import get_column_letter
import os

# Load the workbook (editable, not data_only)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
ws = wb.active  # only one sheet

# Determine the last row with data (ignore completely empty rows)
max_row = ws.max_row

# Write the lookup formula into column D (index 4) for each data row starting at row 5
formula = '=IFERROR(VLOOKUP(TODAY(); $A:$B; 2; FALSE); "")'
for r in range(5, max_row + 1):
    ws.cell(row=r, column=4, value=formula)  # column D

# Prepare output path
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_37900_init.xlsx")
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active
# Print a few evaluated results
print("Evaluated values in column D (rows 5-10):")
for r in range(5, min(10, ws2.max_row) + 1):
    print(r, ws2.cell(row=r, column=4).value)
