import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_6239_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# Gather sheet info
sheet_info = []
for ws in wb.worksheets:
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    # Count rows with any data beyond header
    data_rows = 0
    for r in range(2, ws.max_row+1):
        if any(ws.cell(row=r, column=c).value is not None for c in range(1, ws.max_column+1)):
            data_rows += 1
    sheet_info.append({
        "title": ws.title,
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "data_rows": data_rows,
        "headers": headers
    })

print("Sheet summary:")
print(json.dumps(sheet_info, indent=2))

# Print sample rows for each sheet (first 5 and last 5 data rows)
for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print("Headers:", headers)
    # collect all data rows indices
    data_indices = [r for r in range(2, ws.max_row+1) if any(ws.cell(row=r, column=c).value is not None for c in range(1, ws.max_column+1))]
    sample_idxs = data_indices[:5] + data_indices[-5:] if len(data_indices) > 5 else data_indices
    for r in sample_idxs:
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", row_vals)
