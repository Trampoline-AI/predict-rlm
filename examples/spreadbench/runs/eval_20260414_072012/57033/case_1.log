```repl
import openpyxl
import os
from openpyxl.utils import column_index_from_string
from openpyxl.styles import PatternFill

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_57033_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, "1_57033_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb["Sheet4"]          # target sheet
lookup_ws = wb["CBtrans"]   # lookup sheet

# Determine last row of CBtrans to bound the SUMIFS range
lookup_last = lookup_ws.max_row

# Build the SUMIFS formula string (LibreOffice syntax is same as Excel)
# Use absolute references for the lookup range, relative for the criteria cells.
formula_template = (
    "=SUMIFS(CBtrans!$I${start}:$I${end},"
    "CBtrans!$A${start}:$A${end}, B{row},"
    "CBtrans!$C${start}:$C${end}, C{row},"
    "CBtrans!$J${start}:$J${end}, J{row})"
)

start_row = 2  # data starts at row 2 in CBtrans
end_row = lookup_last

# Write formula into K2:K7
for r in range(2, 8):  # rows 2 through 7 inclusive
    cell = ws.cell(row=r, column=column_index_from_string("K"))
    cell.value = formula_template.format(start=start_row, end=end_row, row=r)

    # Apply regular casing (default font) – no change needed, just ensure no special case
    # Apply cell shading #FF66CC
    cell.fill = PatternFill(start_color="FF66CC", end_color="FF66CC", fill_type="solid")

# Save workbook to output location
wb.save(out_path)

# Recalculate formulas (LibreOffice backend)
from recalculate import recalculate  # provided by the environment
await recalculate(out_path)

# Reload with data_only to read evaluated values
wb2 = openpyxl.load_workbook(out_path, data_only=True)
ws2 = wb2["Sheet4"]
print("Evaluated values in K2:K7 after recalculation:")
for r in range(2, 8):
    print(f"K{r}:", ws2.cell(row=r, column=column_index_from_string("K")).value)

# Final save (already saved)
```
