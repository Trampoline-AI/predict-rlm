wb = openpyxl.load_workbook(in_path, data_only=False)

# Target and lookup sheets
ws = wb["Sheet4"]
lookup_ws = wb["CBtrans"]

# Determine last row of CBtrans for the range
lookup_last = lookup_ws.max_row

# SUMPRODUCT formula:
#   Company  -> CBtrans!A
#   Document -> trimmed Sheet4 C vs CBtrans!C
#   Year     -> CBtrans!E
#   Value    -> CBtrans!I
formula_template = (
    "=SUMPRODUCT((CBtrans!$A$2:$A${end}=B{row})*"
    "(CBtrans!$C$2:$C${end}=TRIM(C{row}))*"
    "(CBtrans!$E$2:$E${end}=J{row})*"
    "CBtrans!$I$2:$I${end})"
)

# Write formula into K2:K7 and apply shading #FF66CC
for r in range(2, 8):
    cell = ws.cell(row=r, column=column_index_from_string("K"))
    cell.value = formula_template.format(end=lookup_last, row=r)
    cell.fill = PatternFill(start_color="FF66CC", end_color="FF66CC", fill_type="solid")

# Save workbook to output location
wb.save(out_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(out_path)

# Reload with data_only to read evaluated values
wb2 = openpyxl.load_workbook(out_path, data_only=True)
ws2 = wb2["Sheet4"]
print("Evaluated values in K2:K7 after recalculation:")
for r in range(2, 8):
    print(f"K{r}:", ws2.cell(row=r, column=column_index_from_string("K")).value)
