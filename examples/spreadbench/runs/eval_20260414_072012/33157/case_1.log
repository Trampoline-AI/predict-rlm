Code:
```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook with formulas (for writing)
wb_formulas = openpyxl.load_workbook(input_path, data_only=False)
ws_formulas = wb_formulas[wb_formulas.sheetnames[0]]

# Recalculate formulas using LibreOffice (async)
await recalculate(output_path)  # recalc in place; we will reload data after this

# Load workbook data-only after recalculation to read computed values
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data[wb_data.sheetnames[0]]

# Column indices (1‑based)
col_desc = [2, 4, 6, 8]   # B, D, F, H (activity description columns)
col_date = [3, 5, 7, 9]   # C, E, G, I (date columns)
col_earliest_date = 10    # J (computed earliest date)
col_target = 11           # K (output column)

# Get activity headers from row 1 of description columns
activity_headers = {desc_col: ws_formulas.cell(row=1, column=desc_col).value for desc_col in col_desc}

max_row = ws_formulas.max_row

for r in range(2, max_row + 1):
    # Read the earliest date (numeric) from column J using the data‑only workbook
    earliest = ws_data.cell(row=r, column=col_earliest_date).value
    if earliest is None:
        # No earliest date – leave target blank
        continue

    matched_header = None
    # Check each date column for a match to the earliest date
    for desc_c, date_c in zip(col_desc, col_date):
        date_val = ws_data.cell(row=r, column=date_c).value
        if date_val == earliest:
            matched_header = activity_headers.get(desc_c, "")
            break  # first match wins

    # Fallback: if no exact match (possible due to rounding), pick the column with the smallest date
    if matched_header is None:
        # Gather valid numeric dates
        date_vals = [(desc_c, ws_data.cell(row=r, column=date_c).value) for desc_c, date_c in zip(col_desc, col_date)]
        # Filter out non‑numeric
        numeric_dates = [(desc, val) for desc, val in date_vals if isinstance(val, (int, float))]
        if numeric_dates:
            min_desc, _ = min(numeric_dates, key=lambda x: x[1])
            matched_header = activity_headers.get(min_desc, "")
        else:
            matched_header = ""

    # Write the header into column K of the formulas workbook
    ws_formulas.cell(row=r, column=col_target, value=matched_header)

# Save the modified workbook
wb_formulas.save(output_path)

# Verify a few rows after saving (reload data‑only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
sample_check = [ws_check.cell(row=r, column=col_target).value for r in range(2, min(7, max_row+1))]
print("Sample values in column K (rows 2‑6):", sample_check)
```
