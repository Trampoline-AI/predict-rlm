import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the one we need

# Column indices (1‑based)
col_desc = [2, 4, 6, 8]   # B, D, F, H
col_date = [3, 5, 7, 9]   # C, E, G, I
col_earliest_date = 10    # J
col_target = 11           # K

# Get activity headers from row 1 of description columns
activity_headers = {desc_col: ws.cell(row=1, column=desc_col).value for desc_col in col_desc}

max_row = ws.max_row

for r in range(2, max_row + 1):
    # Read earliest date from column J (may be a formula, but we can read its cached value)
    earliest = ws.cell(row=r, column=col_earliest_date).value
    if earliest is None:
        # No date, skip
        continue

    # Find which activity column has this date (compare numeric values)
    matched_header = None
    for desc_c, date_c in zip(col_desc, col_date):
        cell_val = ws.cell(row=r, column=date_c).value
        if cell_val == earliest:
            matched_header = activity_headers.get(desc_c, "")
            break  # first match wins

    # If not found (possible due to None), fallback to None of dates
    if matched_header is None:
        # Find min among the date columns manually
        date_vals = [ws.cell(row=r, column=dc).value for dc in col_date]
        # Filter out None
        valid = [(dc, val) for dc, val in zip(col_desc, date_vals) if isinstance(val, (int, float))]
        if valid:
            min_desc, _ = min(valid, key=lambda x: x[1])
            matched_header = activity_headers.get(min_desc, "")
        else:
            matched_header = ""

    # Write to column K
    ws.cell(row=r, column=col_target, value=matched_header)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
from asyncio import run
await recalculate(output_path)

# Verify that column K now has values (reload data_only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
sample_check = [ws_check.cell(row=r, column=col_target).value for r in range(2, min(7, max_row+1))]
print("Sample values in column K (rows 2‑6):", sample_check)
