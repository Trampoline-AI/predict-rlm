import openpyxl, os, json
from pathlib import Path

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_157-4_init.xlsx'
output_dir = Path('/sandbox/output/output_spreadsheet/')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / '1_157-4_init.xlsx'

# Load workbook (keep formulas if any)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet as inspected

# Delete rows where columns F-M are all empty, from 14 to 83
for row in range(83, 13, -1):  # descending order
    # Gather values from columns 6 to 13 (F to M)
    values = [ws.cell(row=row, column=col).value for col in range(6, 14)]
    # Treat None or empty string as empty
    if all(v is None or (isinstance(v, str) and v.strip() == '') for v in values):
        ws.delete_rows(row, 1)

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(str(output_path))

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print('After deletion, max_row =', ws_check.max_row)
# Verify that no remaining row in the original range (14‑83) has all empty F‑M
for r in range(14, 84):
    if r > ws_check.max_row:
        break
    vals = [ws_check.cell(row=r, column=c).value for c in range(6, 14)]
    if all(v is None or (isinstance(v, str) and v.strip() == '') for v in vals):
        print('Row', r, 'still empty in F‑M')
```
