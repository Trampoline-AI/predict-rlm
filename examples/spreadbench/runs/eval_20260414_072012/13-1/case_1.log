```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook(input_spreadsheet)
ws_ranges = wb["RANGES"]
ws_lists = wb["LISTS"]

# Determine data range in RANGES (skip header rows 1‑2)
start_row_ranges = 3
end_row_ranges = ws_ranges.max_row

# Clear old data in LISTS (rows 3 up to the row before TOTAL)
# Find the TOTAL row (first row where column A == 'TOTAL')
total_row = None
for r in range(3, ws_lists.max_row + 1):
    if ws_lists.cell(row=r, column=1).value == "TOTAL":
        total_row = r
        break
if total_row is None:
    # fallback: assume last row is TOTAL
    total_row = ws_lists.max_row

# Clear rows between header (row 2) and TOTAL row (exclusive)
for r in range(3, total_row):
    for c in range(1, ws_lists.max_column + 1):
        ws_lists.cell(row=r, column=c).value = None

# Copy data from RANGES to LISTS
current_row = 3
sn = 1
for r in range(start_row_ranges, end_row_ranges + 1):
    date_val = ws_ranges.cell(row=r, column=2).value   # column B
    ref_val = ws_ranges.cell(row=r, column=4).value    # column D
    amt_val = ws_ranges.cell(row=r, column=5).value    # column E

    # Write SN, DATE, REF, AMOUNTS
    ws_lists.cell(row=current_row, column=1).value = sn
    ws_lists.cell(row=current_row, column=2).value = date_val
    ws_lists.cell(row=current_row, column=3).value = ref_val
    ws_lists.cell(row=current_row, column=4).value = amt_val

    sn += 1
    current_row += 1

# Write TOTAL formula in column D of the TOTAL row
total_amount_row = total_row
first_amount_row = 3
last_amount_row = current_row - 1
if last_amount_row >= first_amount_row:
    ws_lists.cell(row=total_amount_row, column=4).value = f"=SUM(D{first_amount_row}:D{last_amount_row})"
else:
    ws_lists.cell(row=total_amount_row, column=4).value = 0

# Save to output path
output_path = "/sandbox/output/output_spreadsheet/1_13-1_init.xlsx"
wb.save(output_path)

# Recalculate formulas
recalculate(output_path)
```
