```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_path = "/sandbox/output/output_spreadsheet/1_13-1_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws_ranges = wb["RANGES"]
ws_lists = wb["LISTS"]

# Locate the TOTAL row in LISTS (column A == "TOTAL")
original_total_row = None
for r in range(3, ws_lists.max_row + 1):
    if ws_lists.cell(row=r, column=1).value == "TOTAL":
        original_total_row = r
        break
if original_total_row is None:
    # If not found, assume the last row is the TOTAL row
    original_total_row = ws_lists.max_row

# Delete the original TOTAL row so we can re‑add it after new data
ws_lists.delete_rows(original_total_row, 1)

# After deletion, the sheet now has rows 1..(original_total_row-1) as before
# Clear any existing data rows (rows 3 up to the new max row, which is original_total_row-1)
max_data_row_before = original_total_row - 1
for r in range(3, max_data_row_before + 1):
    for c in range(1, ws_lists.max_column + 1):
        ws_lists.cell(row=r, column=c).value = None

# Copy data from RANGES to LISTS
start_row_ranges = 3  # data starts at row 3 in RANGES
end_row_ranges = ws_ranges.max_row
current_row = 3
sn = 1
for r in range(start_row_ranges, end_row_ranges + 1):
    date_val = ws_ranges.cell(row=r, column=2).value   # column B
    ref_val = ws_ranges.cell(row=r, column=4).value    # column D
    amt_val = ws_ranges.cell(row=r, column=5).value    # column E
    # Write SN, DATE, REF, AMOUNTS into LISTS
    ws_lists.cell(row=current_row, column=1).value = sn
    ws_lists.cell(row=current_row, column=2).value = date_val
    ws_lists.cell(row=current_row, column=3).value = ref_val
    ws_lists.cell(row=current_row, column=4).value = amt_val
    sn += 1
    current_row += 1

# After copying, current_row is the first empty row after the data
total_row = current_row
# Write the TOTAL label
ws_lists.cell(row=total_row, column=1).value = "TOTAL"
# Write SUM formula in column D of the TOTAL row
first_amount_row = 3
last_amount_row = total_row - 1
if last_amount_row >= first_amount_row:
    ws_lists.cell(row=total_row, column=4).value = f"=SUM(D{first_amount_row}:D{last_amount_row})"
else:
    ws_lists.cell(row=total_row, column=4).value = 0

# Save the workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)
