1. Build the SUMIFS formula **without** a leading “=”.
2. Build the forecast formula **without** a leading “=”.
3. Combine them in an IF that checks if the SUMIFS result is zero (or blank) and otherwise uses the forecast.
4. Write the combined formula (with a single leading “=”) into each cell H6:P9.
5. Recalculate and verify that the cells now contain numeric results instead of errors.

We'll also ensure the denominator uses the absolute reference `$D$3` (months completed) and that the month header cells (row 5) contain the month numbers to drive the SUMIFS criteria.
Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

input_path = "/sandbox/input/input_spreadsheet/1_52807_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_52807_init.xlsx"

# Load workbook preserving formulas
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Summary"]

# Ensure denominator cell D3 exists
months_completed = ws["D3"].value
if months_completed is None:
    months_completed = 0  # fallback, though formula will use the cell reference directly

# Target rows (GL accounts) and columns (forecast months H-P)
start_row, end_row = 6, 9
start_col, end_col = 8, 16  # H=8, P=16

for row in range(start_row, end_row + 1):
    # Range of actuals for this row (E:G)
    actual_range = f"$E{row}:$G{row}"
    # Forecast formula (no leading =)
    forecast_formula = f"SUM({actual_range})/(12-$D$3)"
    # GL account reference (C column)
    gl_acct_ref = f"Summary!${get_column_letter(3)}{row}"
    for col in range(start_col, end_col + 1):
        # Month header cell (row 5, current column)
        month_header = ws.cell(row=5, column=col).value
        # Build SUMIFS only if month header is numeric (valid month)
        if isinstance(month_header, (int, float)):
            month_ref = f"Summary!${get_column_letter(col)}$5"
            sumifs = (
                f"SUMIFS(Data!$C$2:$C$13,Data!$A$2:$A$13,{gl_acct_ref},"
                f"Data!$D$2:$D$13,{month_ref})"
            )
            # Combined IF: if SUMIFS returns 0 (or blank), use forecast, else SUMIFS result
            combined = f"=IF({sumifs}=0, {forecast_formula}, {sumifs})"
        else:
            # No month header – default to forecast
            combined = f"={forecast_formula}"
        ws.cell(row=row, column=col).value = combined

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas with LibreOffice
await recalculate(output_path)

# Reload with data_only to check computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Summary"]
print("Verification of H6:P9 after recalculation:")
