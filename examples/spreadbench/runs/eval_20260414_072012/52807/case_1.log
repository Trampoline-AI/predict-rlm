import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

input_path = "/sandbox/input/input_spreadsheet/1_52807_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_52807_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Summary"]

# Determine denominator cell D3
denom_cell = ws["D3"]
# Ensure denominator is a number (months completed)
months_completed = denom_cell.value
if months_completed is None:
    # fallback to 0 if missing
    months_completed = 0

# We'll write formulas into columns H (8) to P (16) for rows 6-9
start_row = 6
end_row = 9
for row in range(start_row, end_row + 1):
    # Sum of actuals in E:G for this row
    actual_sum_range = f"$E{row}:$G{row}"
    # Denominator (12 - D3) – D3 is absolute reference
    denom_ref = "$D$3"
    forecast_formula = f"SUM({actual_sum_range})/(12-{denom_ref})"
    for col in range(8, 17):  # H=8, P=16
        # Determine month header cell for this column (row 5)
        month_header = ws.cell(row=5, column=col).value
        # Build SUMIFS for this month if month_header is a number
        if isinstance(month_header, (int, float)):
            # SUMIFS criteria: GL ACCT (C column) matches, Period (D column) equals month_header
            gl_acct = ws.cell(row=row, column=3).value  # column C
            sumifs_formula = (
                f"=SUMIFS(Data!$C$2:$C$13,Data!$A$2:$A$13,Summary!${get_column_letter(3)}{row},"
                f"Data!$D$2:$D$13,Summary!${get_column_letter(col)}$5)"
            )
            # Combine: if SUMIFS returns non‑zero, use it, else forecast
            combined = f"=IF({sumifs_formula}=0, {forecast_formula}, {sumifs_formula})"
        else:
            # No month header – just use forecast
            combined = f"={forecast_formula}"
        ws.cell(row=row, column=col).value = combined

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2["Summary"]
print("Verification of H6:P9 after recalculation:")
for r in range(start_row, end_row + 1):
    vals = [ws2.cell(row=r, column=c).value for c in range(8, 17)]
    print(f"Row {r}:", vals)
