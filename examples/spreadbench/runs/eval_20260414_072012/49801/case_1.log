import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_49801_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume single sheet

# Inspect sheet name, dimensions, and headers
print("Sheet name:", ws.title)
print("Max row:", ws.max_row, "Max column:", ws.max_column)

# Print header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
print("Headers:", headers)

# Show first 5 data rows and last 5 data rows (columns A-C)
def row_vals(r):
    return [ws.cell(row=r, column=c).value for c in range(1, min(4, ws.max_column+1))]

print("First 5 rows:")
for r in range(2, min(ws.max_row, 6)):
    print(r, row_vals(r))

print("Last 5 rows:")
for r in range(max(2, ws.max_row-4), ws.max_row+1):
    print(r, row_vals(r))

# Identify column indices for A, B, C (1‑based)
col_A = openpyxl.utils.column_index_from_string('A')
col_B = openpyxl.utils.column_index_from_string('B')
col_C = openpyxl.utils.column_index_from_string('C')
print(f"Column indices -> A:{col_A}, B:{col_B}, C:{col_C}")

# Verify existing formulas in B and C for a few rows
for r in range(2, min(ws.max_row, 5)):
    val_B = ws.cell(row=r, column=col_B).value
    val_C = ws.cell(row=r, column=col_C).value
    print(f"Row {r} B:{val_B} C:{val_C}")

# Write combined formula to column C for all rows with data in column A
for r in range(2, ws.max_row + 1):
    cell_A = ws.cell(row=r, column=col_A)
    if cell_A.value is None:
        continue  # skip empty rows
    ws.cell(row=r, column=col_C).value = f"=LEFT(A{r},2)&RIGHT(A{r},5)"

# Save workbook
wb.save(output_path)
print("Saved to", output_path)

# Recalculate formulas
from __main__ import recalculate  # the sandbox provides this async function
import asyncio
async def do_recalc():
    result = await recalculate(str(output_path))
    print("Recalculate result:", result)
    # Reload with data_only to see computed values
    wb2 = openpyxl.load_workbook(output_path, data_only=True)
    ws2 = wb2.active
    print("Sample computed values in column C:")
    for r in range(2, min(ws2.max_row, 6)):
        print(r, ws2.cell(row=r, column=col_C).value)
    # Also check last few rows
    for r in range(max(2, ws2.max_row-4), ws2.max_row+1):
        print(r, ws2.cell(row=r, column=col_C).value)

asyncio.run(do_recalc())
