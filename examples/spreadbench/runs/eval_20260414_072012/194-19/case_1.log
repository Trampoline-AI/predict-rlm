import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load the workbook (read only for inspection)
wb_path = '/sandbox/input/input_spreadsheet/1_194-19_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print('Sheets:', wb.sheetnames)

# Function to print header and sample rows for a sheet

def inspect_sheet(ws, max_rows=10):
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f'\nSheet: {ws.title}\nRows: {ws.max_row}, Columns: {ws.max_column}\nHeaders: {headers}')
    # Print first few data rows
    print('First data rows:')
    for r in range(2, min(ws.max_row, max_rows)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)
    # Print last few data rows if enough rows
    if ws.max_row > max_rows:
        print('Last data rows:')
        for r in range(ws.max_row - max_rows + 1, ws.max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
            print(r, row_vals)

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    inspect_sheet(ws, max_rows=10)
```
