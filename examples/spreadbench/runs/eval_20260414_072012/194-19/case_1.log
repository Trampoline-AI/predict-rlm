import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_194-19_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_194-19_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
ws_src = wb["Sheet2"]   # source data
ws_tgt = wb["Sheet1"]   # destination

# Build a lookup dictionary from Sheet2: (track, race#) -> (top, [1,2,3,4])
lookup = {}
for r in range(2, ws_src.max_row + 1):
    track = ws_src.cell(r, column_index_from_string("D")).value
    race = ws_src.cell(r, column_index_from_string("H")).value
    top = ws_src.cell(r, column_index_from_string("I")).value
    # columns J-M are numeric results (1,2,3,4)
    nums = [
        ws_src.cell(r, column_index_from_string("J")).value,
        ws_src.cell(r, column_index_from_string("K")).value,
        ws_src.cell(r, column_index_from_string("L")).value,
        ws_src.cell(r, column_index_from_string("M")).value,
    ]
    lookup[(track, race)] = (top, nums)

# Write to Sheet1 columns H (Top) and I (derived)
for r in range(2, ws_tgt.max_row + 1):
    meet = ws_tgt.cell(r, column_index_from_string("D")).value
    race = ws_tgt.cell(r, column_index_from_string("G")).value
    key = (meet, race)
    if key in lookup:
        top_val, nums = lookup[key]
        # Column H (Top)
        ws_tgt.cell(r, column_index_from_string("H")).value = top_val
        # Column I (derived) – join the four numbers with hyphens, ignoring None
        derived = "-".join(str(int(n)) for n in nums if n is not None)
        ws_tgt.cell(r, column_index_from_string("I")).value = derived
    else:
        # No match – leave cells blank (or could write an indicator)
        ws_tgt.cell(r, column_index_from_string("H")).value = None
        ws_tgt.cell(r, column_index_from_string("I")).value = None

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Reload with data_only to verify a few rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("Sample verification rows (Row, Meet, Race#, H, I):")
for r in range(2, min(12, ws_check.max_row + 1)):
    print(r,
          ws_check.cell(r, column_index_from_string("D")).value,
          ws_check.cell(r, column_index_from_string("G")).value,
          ws_check.cell(r, column_index_from_string("H")).value,
          ws_check.cell(r, column_index_from_string("I")).value)
