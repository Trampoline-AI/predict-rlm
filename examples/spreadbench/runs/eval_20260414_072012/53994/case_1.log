import openpyxl
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_53994_init.xlsx"

# Load workbook preserving formulas
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Write corrected formula into B30 (row 30, column 2)
# Use columns L‑W (12‑23) for machine, phase, and time values
ws.cell(row=30, column=2).value = '=SUMPRODUCT(($L$26:$W$26="M1")*($L$16:$W$16="SETUP")*($L$25:$W$25))'

# Save to output location
wb.save(output_path)

# Recalculate formulas
await recalculate(str(output_path))

# Reload with data_only to read evaluated value
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
result_val = ws2.cell(row=30, column=2).value
print("Evaluated result in B30:", result_val)
```
