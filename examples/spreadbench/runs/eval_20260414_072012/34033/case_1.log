import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
inp_path = "/sandbox/input/input_spreadsheet/1_34033_init.xlsx"
wb = openpyxl.load_workbook(inp_path, data_only=False)
ws = wb["ExcelForum help"]

# Determine the last data row (excluding possible empty trailing rows)
max_row = ws.max_row

# Column indices (1‑based)
col_date = 1   # A
col_item = 2   # B
col_param = 3  # C
col_result = 11  # K (empty column for output)

# Write formula into each data row (starting at row 2)
for r in range(2, max_row + 1):
    # Build formula string
    # MATCH finds the row number of the current date within column A
    # INDEX(..., MATCH-1) gives previous date, INDEX(..., MATCH+1) gives next date
    # The formula guards against first/last rows where previous or next may not exist
    formula = (
        f'=IF(AND('
        f'ROW()-1>1,'  # ensure there is a previous row
        f'ROW()+1<={max_row},'  # ensure there is a next row
        f'${get_column_letter(col_date)}{r}>=INDEX(${get_column_letter(col_date)}$2:${get_column_letter(col_date)}${max_row},MATCH(${get_column_letter(col_date)}{r},${get_column_letter(col_date)}$2:${get_column_letter(col_date)}${max_row},0)-1),'
        f'${get_column_letter(col_date)}{r}<=INDEX(${get_column_letter(col_date)}$2:${get_column_letter(col_date)}${max_row},MATCH(${get_column_letter(col_date)}{r},${get_column_letter(col_date)}$2:${get_column_letter(col_date)}${max_row},0)+1),'
        f'${get_column_letter(col_param)}{r}>=25),'
        f'INDEX(${get_column_letter(col_item)}$2:${get_column_letter(col_item)}${max_row},MATCH(${get_column_letter(col_date)}{r},${get_column_letter(col_date)}$2:${get_column_letter(col_date)}${max_row},0)),'
        f'""'
        f')'
    )
    ws.cell(row=r, column=col_result).value = formula

