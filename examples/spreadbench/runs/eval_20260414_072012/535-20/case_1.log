import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
ws = wb.active  # assume single worksheet

# Find columns to delete
keyword = "/description"
cols_to_delete = []
for col in range(1, ws.max_column + 1):
    cell_val = ws.cell(row=1, column=col).value
    if isinstance(cell_val, str) and keyword in cell_val:
        cols_to_delete.append(col)

# Delete from rightmost to leftmost
for col in sorted(cols_to_delete, reverse=True):
    ws.delete_cols(col, 1)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload to verify
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print(f"Columns remaining after deletion: {ws_check.max_column}")

# Submit the output spreadsheet path
SUBMIT(output_spreadsheet=output_path)
