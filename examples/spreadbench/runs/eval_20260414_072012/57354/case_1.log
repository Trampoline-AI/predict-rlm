import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active

# Determine new column indices (after existing max column)
new_col1_idx = ws.max_column + 1  # Total Revenue
new_col2_idx = ws.max_column + 2  # Total GP
col1_letter = get_column_letter(new_col1_idx)
col2_letter = get_column_letter(new_col2_idx)

# Write headers
ws[f"{col1_letter}1"] = "Total Revenue"
ws[f"{col2_letter}1"] = "Total GP"

# Write LibreOffice formulas using whole‑row references (LibreOffice compatible)
ws[f"{col1_letter}3"] = '=SUMIF($1:$1,"TOTAL",$3:$3)'
ws[f"{col2_letter}3"] = '=SUMIF($1:$1,"GP",$3:$3)'

# Save workbook
wb.save(output_path)

# Recalculate formulas using LibreOffice
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only=True to verify computed values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active
rev_val = ws2[f"{col1_letter}3"].value
gp_val = ws2[f"{col2_letter}3"].value
print(f"Verified Total Revenue ({col1_letter}3):", rev_val)
print(f"Verified Total GP ({col2_letter}3):", gp_val)
```
