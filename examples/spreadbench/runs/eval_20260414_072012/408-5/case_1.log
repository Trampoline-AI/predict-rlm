Code:
```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Load workbook (data_only=False to keep formulas for later if needed)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine column indices (1‑based)
col_D = 4
col_E = 5
col_C = 3

# Compute sum of D where E == 0 (including possible blanks)
sum_val = 0.0
for r in range(2, ws.max_row + 1):
    e_val = ws.cell(row=r, column=col_E).value
    d_val = ws.cell(row=r, column=col_D).value
    if e_val == 0 and isinstance(d_val, (int, float)):
        sum_val += d_val

# Find the row where column C contains 'BR1 Sales'
br1_row = None
for r in range(2, ws.max_row + 1):
    c_val = ws.cell(row=r, column=col_C).value
    if c_val and 'BR1 Sales' in str(c_val):
        br1_row = r
        break

if br1_row is None:
    raise ValueError("Could not locate a row with 'BR1 Sales' in column C")

# Write the computed sum into column D of that row
ws.cell(row=br1_row, column=col_D, value=sum_val)

# Delete rows where E == 0 except the BR1 row, and delete completely blank rows.
# Iterate backwards to keep indices stable.
for r in range(ws.max_row, 1, -1):
    # Check for blank row (all cells None or empty string)
    is_blank = all(
        (ws.cell(row=r, column=c).value is None) or (str(ws.cell(row=r, column=c).value).strip() == "")
        for c in range(1, ws.max_column + 1)
    )
    if is_blank:
        ws.delete_rows(r)
        continue
    e_val = ws.cell(row=r, column=col_E).value
    if e_val == 0 and r != br1_row:
        ws.delete_rows(r)

# Save to output directory preserving the original filename
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

# Recalculate formulas (if any) and verify D92 (now possibly a different row index after deletions)
await recalculate(output_path)
# Reload with data_only to read the computed value
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
# Find the BR1 row again (it may have shifted)
br1_row2 = None
for r in range(2, ws2.max_row + 1):
    c_val = ws2.cell(row=r, column=col_C).value
    if c_val and 'BR1 Sales' in str(c_val):
        br1_row2 = r
        break
print("BR1 row after deletions:", br1_row2)
print("Value in D of that row:", ws2.cell(row=br1_row2, column=col_D).value)
