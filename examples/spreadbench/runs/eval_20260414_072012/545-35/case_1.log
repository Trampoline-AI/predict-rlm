4. Save the modified workbook to the output directory with the same filename.
5. Call `recalculate()` on the saved file, reload it with `data_only=True`, and print a few sample cells to verify the replacement.
Code:
```repl
import openpyxl
from openpyxl import load_workbook
import os
import re

input_path = "/sandbox/input/input_spreadsheet/1_545-35_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_545-35_init.xlsx")

# Load workbook
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Helper to test numeric
def is_numeric(val):
    if isinstance(val, (int, float)):
        return True
    if isinstance(val, str):
        # strip whitespace
        v = val.strip()
        # allow commas as thousand separators, dot as decimal
        v = v.replace(",", "")
        # match optional sign, digits, optional decimal part
        return bool(re.fullmatch(r"[+-]?\d+(\.\d+)?", v))
    return False

# Replace non‑numeric with 0
for r in range(2, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(row=r, column=c)
        val = cell.value
        if val is None:
            continue
        if not is_numeric(val):
            cell.value = 0

# Save modified workbook
wb.save(output_path)

# Recalculate formulas (none expected, but required by workflow)
await recalculate(output_path)

# Reload with data_only to verify
wb2 = load_workbook(output_path, data_only=True)
ws2 = wb2.active

# Print a few rows to confirm
print("After cleaning – sample rows:")
for r in range(2, min(8, ws2.max_row + 1)):
    print(r, [ws2.cell(row=r, column=c).value for c in range(1, ws2.max_column + 1)])
```
