import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook("/sandbox/input/input_spreadsheet/1_58701_init.xlsx", data_only=False)
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows
def inspect_sheet(name):
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"\n=== {name} ===")
    print("Headers:", headers)
    # print first 5 data rows
    print("First 5 rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # print last 5 rows if enough rows
    if max_row > 6:
        print("Last 5 rows:")
        for r in range(max(max_row-4,2), max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(r, row_vals)

# Inspect both relevant sheets (if they exist)
for sheet in ["Entry Tab", "Table Tab"]:
    if sheet in wb.sheetnames:
        inspect_sheet(sheet)
    else:
        print(f"Sheet '{sheet}' not found.")
