```python
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_80-42_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_80-42_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path)

# Identify sheets
target_name = "Consolidate_ALL"  # exact name from the file
source_names = ["Jack", "Henry", "Richard"]

target_ws = wb[target_name]

# Determine first empty row in target (after header)
first_dest_row = target_ws.max_row + 1 if target_ws.max_row > 1 else 2

# Helper to copy style from source cell to destination cell
def copy_style(src_cell, dst_cell):
    dst_cell.font = src_cell.font
    dst_cell.fill = src_cell.fill
    dst_cell.border = src_cell.border
    dst_cell.alignment = src_cell.alignment
    dst_cell.number_format = src_cell.number_format
    dst_cell.protection = src_cell.protection

# Process each source sheet
dest_row = first_dest_row
for src_name in source_names:
    src_ws = wb[src_name]
    # Assume header is row 1, data starts at row 2
    for r in range(2, src_ws.max_row + 1):
        # Skip completely empty rows (all first 12 cells None)
        if all(src_ws.cell(row=r, column=c).value is None for c in range(1, 13)):
            continue
        # Copy columns A‑K (1‑11) values
        for c in range(1, 12):  # columns 1..11
            src_cell = src_ws.cell(row=r, column=c)
            dst_cell = target_ws.cell(row=dest_row, column=c)
            dst_cell.value = src_cell.value
            copy_style(src_cell, dst_cell)
        # Column L (12) gets the sheet name
        dst_cell_L = target_ws.cell(row=dest_row, column=12)
        dst_cell_L.value = src_name
        # Apply a simple style (optional) – copy style from column K of source
        copy_style(src_ws.cell(row=r, column=11), dst_cell_L)
        dest_row += 1

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
check_ws = wb_check[target_name]

# Print a few rows of column L to confirm sheet names were written
print("Verification of column L (origin sheet) in target:")
for r in range(first_dest_row, min(first_dest_row + 5, check_ws.max_row + 1)):
    print(f"Row {r}: {check_ws.cell(row=r, column=12).value}")

# Also print the last few rows to ensure all data was appended
print("\nLast few rows in target sheet (showing columns A‑L):")
for r in range(max(first_dest_row, check_ws.max_row - 4), check_ws.max_row + 1):
    row_vals = [check_ws.cell(row=r, column=c).value for c in range(1, 13)]
    print(f"Row {r}: {row_vals}")
```
