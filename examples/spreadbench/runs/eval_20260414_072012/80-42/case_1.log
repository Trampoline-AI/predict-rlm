    cons_ws = wb[target_name]
    cons_headers = [cons_ws.cell(row=1, column=c).value for c in range(1, cons_ws.max_column + 1)]
    print(f'\n--- Target sheet {target_name} ---')
    print('Headers:', cons_headers)
    print('Current max row:', cons_ws.max_row)
    # Show first few rows after header
    for r in range(2, min(cons_ws.max_row, 6)):
        row_vals = [cons_ws.cell(row=r, column=c).value for c in range(1, cons_ws.max_column + 1)]
        print(f'Row {r}:', row_vals)
else:
    print('No target sheet containing "consolidated" was found.')
