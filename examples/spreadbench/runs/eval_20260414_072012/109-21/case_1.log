import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Column indices (1‑based)
COL_NAME   = 1   # A, person name
COL_GROUP  = 2   # B, group identifier
COL_POINTS = 11  # K, point totals
COL_RESULT = 26  # Z, output Y/N

max_row = ws.max_row

# Build mapping: group -> list of (row, points)
group_map = {}
for r in range(2, max_row + 1):
    name = ws.cell(row=r, column=COL_NAME).value
    if not name:          # skip empty rows
        continue
    grp = ws.cell(row=r, column=COL_GROUP).value
    if grp is None:       # skip rows without a group id
        continue
    pt = ws.cell(row=r, column=COL_POINTS).value
    # Ensure numeric; treat non‑numeric as 0
    pt_val = pt if isinstance(pt, (int, float)) else 0
    group_map.setdefault(grp, []).append((r, pt_val))

# Debug: print groups and their points
print("Group details before writing Y/N:")
for grp, rows_pts in group_map.items():
    pts = [pt for _, pt in rows_pts]
    print(f"Group {grp}: rows={ [r for r,_ in rows_pts]}, points={pts}, max={max(pts) if pts else None}")

# Write Y/N
for grp, rows_pts in group_map.items():
    if not rows_pts:
        continue
    max_pt = max(pt for _, pt in rows_pts)
    single = len(rows_pts) == 1
    for r, pt in rows_pts:
        cell = ws.cell(row=r, column=COL_RESULT)
        if single:
            cell.value = "Y"
        else:
            cell.value = "Y" if pt == max_pt else "N"

# Save and recalculate
wb.save(output_path)
await recalculate(output_path)

# Verify a few rows after calculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("\nVerification of column Z (first 15 data rows):")
for r in range(2, min(17, ws_check.max_row + 1)):
    name = ws_check.cell(row=r, column=COL_NAME).value
    grp  = ws_check.cell(row=r, column=COL_GROUP).value
    pts  = ws_check.cell(row=r, column=COL_POINTS).value
    res  = ws_check.cell(row=r, column=COL_RESULT).value
    print(f"Row {r}: Name={name}, Group={grp}, Points={pts}, Result={res}")
```
