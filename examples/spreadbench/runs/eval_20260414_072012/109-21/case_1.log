```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Column indices (1‑based)
COL_GROUP = 2   # column B, assumed group identifier
COL_POINTS = 11 # column K, point totals
COL_RESULT = 26 # column Z, where Y/N will be written

max_row = ws.max_row

# Build group -> list of row numbers
group_rows = {}
for r in range(2, max_row + 1):
    group_val = ws.cell(row=r, column=COL_GROUP).value
    # Skip rows without a group identifier (could be empty rows)
    if group_val is None:
        continue
    group_rows.setdefault(group_val, []).append(r)

# Process each group
for group, rows in group_rows.items():
    # Gather point totals for the group
    points = []
    for r in rows:
        pt = ws.cell(row=r, column=COL_POINTS).value
        # Treat non‑numeric or None as 0 for comparison
        if isinstance(pt, (int, float)):
            points.append(pt)
        else:
            points.append(0)

    # Determine max points
    max_pt = max(points) if points else 0

    # Write Y/N for each member
    for r, pt in zip(rows, points):
        result_cell = ws.cell(row=r, column=COL_RESULT)
        # If the group has only one member, automatically Y
        if len(rows) == 1:
            result_cell.value = "Y"
        else:
            result_cell.value = "Y" if pt == max_pt else "N"

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify a few rows of column Z
wb_verify = openpyxl.load_workbook(output_path, data_only=True)
ws_verify = wb_verify[wb_verify.sheetnames[0]]
print("Verification of column Z (first 10 data rows):")
for r in range(2, min(12, ws_verify.max_row + 1)):
    name = ws_verify.cell(row=r, column=1).value
    group = ws_verify.cell(row=r, column=COL_GROUP).value
    pts = ws_verify.cell(row=r, column=COL_POINTS).value
    res = ws_verify.cell(row=r, column=COL_RESULT).value
    print(f"Row {r}: Name={name}, Group={group}, Points={pts}, Result={res}")
```
