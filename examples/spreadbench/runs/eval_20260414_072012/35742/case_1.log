import openpyxl, os
from openpyxl.utils import get_column_letter

input_path = "/sandbox/input/input_spreadsheet/1_35742_init.xlsx"
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Identify merged cells that involve column 15 (O)
merged_in_col15 = []
for mr in ws.merged_cells.ranges:
    # mr is a CellRange object
    if 15 in range(mr.min_col, mr.max_col + 1):
        merged_in_col15.append(mr)
print("Merged ranges that include column 15:", merged_in_col15)

# Determine data rows
first_data_row = 2
max_row = ws.max_row

# Point columns (based on earlier inspection)
point_cols = ["F", "H", "J", "L", "N", "T", "V", "X"]

# Helper to find the top‑left cell of a merged range that contains a given cell

def top_left_of_merge(row, col):
    for mr in merged_in_col15:
        if mr.min_row <= row <= mr.max_row and mr.min_col <= col <= mr.max_col:
            return mr.min_row, mr.min_col
    return row, col

# Write SUM formulas into column 15 (O)
for r in range(first_data_row, max_row + 1):
    # Determine the actual cell to write to (top‑left of any merge)
    write_row, write_col = top_left_of_merge(r, 15)
    cells_to_sum = [f"{c}{r}" for c in point_cols]
    formula = f"=SUM({','.join(cells_to_sum)})"
    ws.cell(row=write_row, column=write_col).value = formula

# Save to output directory
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_35742_init.xlsx")
wb.save(output_path)

# Recalculate formulas using the provided helper
await recalculate(output_path)

# Verify a few Section Total cells after recalculation (data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Sample Section Total values after recalculation:")
for r in range(first_data_row, min(first_data_row + 5, max_row + 1)):
    val = ws_check.cell(row=r, column=15).value
    print(r, val)
