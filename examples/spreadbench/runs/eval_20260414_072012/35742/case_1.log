import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_35742_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_35742_init.xlsx")

# Load workbook with formulas
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Column index for totals (O = 15)
total_col = 15

# Unmerge any merged cells that intersect this column
for mr in list(ws.merged_cells.ranges):
    if mr.min_col <= total_col <= mr.max_col:
        ws.unmerge_cells(str(mr))

# Determine data rows
first_data_row = 2
max_row = ws.max_row

# Point columns (as identified)
point_cols = ["F", "H", "J", "L", "N", "T", "V", "X"]

# Write SUM formulas with VALUE conversion into column 15 for each data row
for r in range(first_data_row, max_row + 1):
    # Build formula: =SUM(VALUE(Fr),VALUE(Hr),...,VALUE(Xr))
    cells = [f"VALUE({c}{r})" for c in point_cols]
    formula = f"=SUM({','.join(cells)})"
    ws.cell(row=r, column=total_col).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas using the provided helper
await recalculate(output_path)

# Verify a few totals after recalculation (data_only=True)
