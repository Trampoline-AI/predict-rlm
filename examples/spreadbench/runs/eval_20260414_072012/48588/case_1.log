1. Loads the workbook.
2. Scans column A for product codes.
3. Assigns a sequential ID to each distinct product in the order of its first appearance.
4. Writes the computed IDs into column B for every row (leaving the header row untouched).
5. Saves the workbook to the output directory, recalculates (though no formulas remain), and verifies a few sample rows.

This satisfies the instruction to generate a unique number for each product, matching the manually done results in column B, without relying on a fragile formula.
Code:
```repl
import os
import openpyxl
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_48588_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_48588_init.xlsx")

# Load workbook (keep formulas if any, but we will overwrite column B with values)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # assume the relevant sheet is the active one

# Determine the last row with data in column A (or overall max row)
max_row = ws.max_row

# Compute unique IDs
product_to_id = {}
next_id = 1

for row in range(2, max_row + 1):
    prod = ws.cell(row=row, column=1).value  # Column A
    if prod is None:
        # Leave B empty if A is empty
        ws.cell(row=row, column=2).value = None
        continue
    if prod not in product_to_id:
        product_to_id[prod] = next_id
        next_id += 1
    ws.cell(row=row, column=2).value = product_to_id[prod]

# Save workbook
wb.save(output_path)

# Recalculate (no formulas, but required by workflow)
await recalculate(output_path)

# Verify a few rows after recalculation
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active

print("Sample verification (first 10 rows of column B):")
for r in range(2, min(12, ws_check.max_row + 1)):
    print(f"Row {r}: A={ws_check.cell(r,1).value}, B={ws_check.cell(r,2).value}")

print("Sample verification (last 5 rows of column B):")
for r in range(max(2, ws_check.max_row-4), ws_check.max_row+1):
    print(f"Row {r}: A={ws_check.cell(r,1).value}, B={ws_check.cell(r,2).value}")
```
