4. If the three conditions are met, set cell BL to the literal string `"VALID"`. Otherwise leave the cell unchanged.
5. Save the workbook to the output directory, recalculate formulas, and verify that the target cells contain the expected values.
Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_120-24_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_120-24_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume single sheet

# Column indices (1‑based)
col_AY = 51   # AY
col_BG = 59   # BG
col_BL = 64   # BL

# Counters for reporting
total_rows = ws.max_row
modified = 0

for r in range(2, total_rows + 1):
    val_AY = ws.cell(row=r, column=col_AY).value
    val_BG = ws.cell(row=r, column=col_BG).value
    val_BL = ws.cell(row=r, column=col_BL).value

    # Condition checks
    cond1 = (val_BL == "LAG")
    cond2 = (val_BG in ("OCOGS - Spares - Transfer Price Overhead",
                        "OFSS - ORCL Consulting Prod Cost I/C"))
    cond3 = (val_AY in ("BOA_033E", "BOA_011G"))

    if cond1 and cond2 and cond3:
        # Write the replacement value (example: "VALID")
        ws.cell(row=r, column=col_BL).value = "VALID"
        modified += 1

print(f"Processed {total_rows-1} data rows. Modified {modified} cells in column BL.")

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(output_path)

# Verify a few rows where we expect changes
print("\nVerification of modified rows (showing columns AY, BG, BL):")
for r in range(2, total_rows + 1):
    val_BL = ws.cell(row=r, column=col_BL).value
    if val_BL == "VALID":
        print(f"Row {r}: AY={ws.cell(r, col_AY).value}, BG={ws.cell(r, col_BG).value}, BL={val_BL}")

