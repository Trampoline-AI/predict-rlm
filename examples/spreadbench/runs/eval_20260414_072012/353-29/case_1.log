Code:
```repl
import openpyxl, string, os
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_353-29_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_353-29_init.xlsx')

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row
letters = list(string.ascii_lowercase)

base_number = None          # last seen numeric URN
letter_idx = 0             # index within current blank block
in_blank_block = False     # flag indicating we are inside a consecutive blank region

for row in range(2, max_row + 1):   # start after header
    cell = ws.cell(row=row, column=1)   # column A = URN
    val = cell.value

    # If the cell already has a non‑blank value, update base_number and reset block state
    if val is not None:
        # If we were in a blank block, reset for next possible block
        in_blank_block = False
        letter_idx = 0
        # Update base_number only if the value is numeric (int/float)
        if isinstance(val, (int, float)):
            base_number = int(val)
        # If the value is already a string (e.g., already filled), we keep the current base_number unchanged
        continue

    # Cell is blank (None)
    # If we have a base_number to work with, fill it
    if base_number is not None:
        # Start a new block if we just entered blanks
        if not in_blank_block:
            in_blank_block = True
            letter_idx = 0
        # Generate new URN: base_number + letter
        new_urn = f"{base_number}{letters[letter_idx % len(letters)]}"
        cell.value = new_urn
        letter_idx += 1
    else:
        # No preceding numeric URN found – leave blank (should not happen with given data)
        pass

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and reload to verify
await recalculate(output_path)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Helper to display a range of rows for verification
def show_rows(start, end):
    rows = []
    for r in range(start, end + 1):
        rows.append((r, ws_check.cell(row=r, column=1).value))
    return rows

# Print rows around the two gaps we modified
print("Rows 66‑84 (first gap and surrounding):", show_rows(66, 84))
print("Rows 78‑90 (second gap and surrounding):", show_rows(78, 90))
```
