import openpyxl, string, os
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_353-29_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_353-29_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Find the first blank cell in column A (URN) and the preceding numeric URN
base_number = None
first_blank_row = None
for row in range(2, ws.max_row + 1):
    val = ws.cell(row=row, column=1).value
    if val is None:
        first_blank_row = row
        break
    # Keep updating base_number when we see a numeric value
    if isinstance(val, (int, float)):
        base_number = int(val)

if first_blank_row is None or base_number is None:
    raise ValueError('Could not locate a blank URN cell or preceding numeric URN.')

# Fill consecutive blanks starting at first_blank_row with base_number + letters
letters = list(string.ascii_lowercase)
letter_idx = 0
row = first_blank_row
while row <= ws.max_row:
    cell = ws.cell(row=row, column=1)
    if cell.value is None:
        # Assign base_number + letter
        new_urn = f"{base_number}{letters[letter_idx % len(letters)]}"
        cell.value = new_urn
        letter_idx += 1
        row += 1
    else:
        # Stop when we encounter a non‑blank after the blank block
        break

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and reload to verify
await recalculate(output_path)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Print the filled URNs for verification
filled = []
for r in range(first_blank_row, first_blank_row + letter_idx):
    filled.append((r, ws_check.cell(row=r, column=1).value))
print('Filled URNs:', filled)
