import openpyxl, os
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_433-47_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_433-47_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Find column I index
col_I = column_index_from_string('I')

# Determine rows that contain data (exclude header row and min/max rows)
# Header is row 1, data rows start at 2, min row is the one where column A == 'min'
# max row is the one where column A == 'max'
min_row = None
max_row = None
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=1).value
    if val == 'min':
        min_row = r
    if val == 'max':
        max_row = r
        break

# Data rows are from 2 up to (min_row-1) if min_row exists, else up to ws.max_row
end_row = min_row - 1 if min_row else ws.max_row

# Set residuals to 0 for each data row
for r in range(2, end_row + 1):
    ws.cell(row=r, column=col_I).value = 0

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload to verify
