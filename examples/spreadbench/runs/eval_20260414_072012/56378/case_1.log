import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
print("Sheets:", wb.sheetnames)

# Function to print header and sample rows
def inspect_sheet(name):
    ws = wb[name]
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f"\n--- Sheet: {name} ---")
    print("Headers:", headers)
    # Print first 5 data rows
    for r in range(2, min(ws.max_row, 6)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", row_vals)
    # Print last 5 data rows
    start = max(2, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", row_vals)

# Inspect all sheets
for sheet in wb.sheetnames:
    inspect_sheet(sheet)
```
