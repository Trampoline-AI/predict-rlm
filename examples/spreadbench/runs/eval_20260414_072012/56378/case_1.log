ws = wb["Folha1"]

# Determine the last row with data in the first frame (column C has product code)
last_row = ws.max_row

# Write formulas for rows 5..last_row (row 4 is header)
for r in range(5, last_row + 1):
    # column H is QUANTITY UNITS in frame1
    qty_cell = ws.cell(row=r, column=column_index_from_string('H')).value
    # Build formula strings (use absolute column reference for H)
    formulas = {
        'L': f"=IF(ISBLANK($H{r}),\"\",$C{r})",
        'M': f"=IF(ISBLANK($H{r}),\"\",$D{r})",
        'N': f"=IF(ISBLANK($H{r}),\"\",$E{r})",
        'O': f"=IF(ISBLANK($H{r}),\"\",$F{r})",
        'P': f"=IF(ISBLANK($H{r}),\"\",$G{r})",
        'Q': f"=IF(ISBLANK($H{r}),\"\",$H{r})",
        'R': f"=IF(ISBLANK($H{r}),\"\",$H{r})",
    }
    for col_letter, formula in formulas.items():
        ws[f"{col_letter}{r}"] = formula

# Alignment: left for columns L and M, right for O,R (and also N,P,Q for consistency)
