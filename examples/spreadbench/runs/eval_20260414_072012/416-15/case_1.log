import openpyxl
from openpyxl.utils import get_column_letter
from datetime import datetime
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_416-15_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_416-15_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Process column A (column 1)
for row in range(2, ws.max_row + 1):
    cell = ws.cell(row=row, column=1)
    val = cell.value
    if isinstance(val, str) and "T" in val and val.endswith("Z"):
        # Extract date part before 'T'
        date_str = val.split("T")[0]  # e.g., '2021-01-21'
        try:
            # Parse to datetime object
            dt = datetime.strptime(date_str, "%Y-%m-%d")
            # Write back as date (datetime works for Excel)
            cell.value = dt
        except Exception as e:
            # If parsing fails, leave original value
            print(f"Row {row}: failed to parse '{val}' -> {e}")
    # Ensure number format for dates
    # LibreOffice uses MM/DD/YYYY; we set a format that displays m/dd/yyyy
    cell.number_format = "MM/DD/YYYY"

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of column A after processing:")
for r in range(2, ws_check.max_row + 1):
    val = ws_check.cell(row=r, column=1).value
    print(r, val)
