output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_41265_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Helper to get cell value safely
def get_val(cell):
    return cell.value if cell.value is not None else ""

# Build lists of keywords and their volumes
keywords = {}
for r in range(2, 7):  # A2‑A6
    kw = ws[f"A{r}"].value
    vol = ws[f"B{r}"].value
    if kw is not None:
        keywords[r] = (str(kw).strip(), vol if isinstance(vol, (int, float)) else 0)

# Process each root word D2‑D5
for r in range(2, 6):  # D2‑D5
    root = ws[f"D{r}"].value
    if root is None:
        continue
    root_str = str(root).strip()
    total = 0
    # Scan keywords
    for _, (kw, vol) in keywords.items():
        # Split keyword into words and check for exact match
        if root_str in kw.split():
            total += vol
    # Write total into column E of same row
    ws[f"E{r}"] = total

# Save to output path
