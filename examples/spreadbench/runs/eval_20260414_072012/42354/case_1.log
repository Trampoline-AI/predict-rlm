Code:
```python
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_42354_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_42354_init.xlsx')

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is target

max_row = ws.max_row

def first_non_na(a, b, c):
    """Return the first value that is not the literal string '#N/A', or blank."""
    for v in (a, b, c):
        if v != "#N/A":
            return v
    return ""

# Write computed values into column D (index 4) for each data row
for r in range(2, max_row + 1):
    a = ws.cell(row=r, column=1).value
    b = ws.cell(row=r, column=2).value
    c = ws.cell(row=r, column=3).value
    result = first_non_na(a, b, c)
    ws.cell(row=r, column=4).value = result

# Save workbook
wb.save(output_path)

# Recalculate (LibreOffice) – will preserve the literals
recalculate(output_path)

# Verify a few rows in column D
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of column D values (first 5 data rows):")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f"Row {r} D = {ws_check.cell(row=r, column=4).value}")
```
