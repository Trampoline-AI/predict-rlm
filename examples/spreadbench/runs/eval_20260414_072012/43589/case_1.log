Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_43589_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_43589_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine last row with data in column A (skip header)
max_row = ws.max_row

# Write formula into column B for each data row
for row in range(2, max_row + 1):
    cell_a = ws.cell(row=row, column=1)
    if cell_a.value is None:
        continue  # skip empty rows
    # Formula using the current row number
    formula = f"=VALUE(MID(A{row}, FIND(\" to\",A{row})+4, 10)) - VALUE(LEFT(A{row}, FIND(\" to\",A{row})-1)) + 1"
    ws.cell(row=row, column=2).value = formula

# Ensure output directory exists
import os
os.makedirs(out_dir, exist_ok=True)

# Save workbook
wb.save(out_path)

# Recalculate formulas
from sandbox import recalculate
await recalculate(out_path)

# Verify a few cells after recalculation (data_only)
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print('Sample results:')
for r in range(2, min(max_row, 7)):
    print(r, ws_check.cell(r,1).value, ws_check.cell(r,2).value)
