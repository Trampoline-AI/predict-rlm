import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_384-4_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_384-4_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# --------------------
# 1. Extract values
# --------------------
src_ws = wb['Source']
src2_ws = wb['Source2']
result_ws = wb['Result']

# Source values are in column B (2nd column), rows starting at 2
src_vals = []
for r in range(2, src_ws.max_row + 1):
    val = src_ws.cell(row=r, column=2).value
    if val is not None:
        src_vals.append(val)

# Source2 values are in column A (1st column), rows starting at 2
src2_vals = set()
for r in range(2, src2_ws.max_row + 1):
    val = src2_ws.cell(row=r, column=1).value
    if val is not None:
        src2_vals.add(val)

# --------------------
# 2. Compute result list
# --------------------
result_vals = []
seen = set()
for val in src_vals:
    if val == 2:
        # include 2 only if it exists in both sources
        if 2 in src2_vals and 2 not in seen:
            result_vals.append(2)
            seen.add(2)
    else:
        if val not in src2_vals and val not in seen:
            result_vals.append(val)
            seen.add(val)

# --------------------
# 3. Write to Result sheet
# --------------------
# Clear any existing data below header (just in case)
for r in range(2, result_ws.max_row + 1):
    result_ws.cell(row=r, column=1).value = None

# Write results starting at row 2
for idx, val in enumerate(result_vals, start=2):
    result_ws.cell(row=idx, column=1).value = val

# --------------------
# 4. Save and recalculate
# --------------------
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Verify by reloading with data_only=True
