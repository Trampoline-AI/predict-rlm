import openpyxl
from openpyxl.utils import get_column_letter

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_146-49_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_146-49_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(in_path)
ws = wb[wb.sheetnames[0]]

# Gather all words from column A (skip header row 1)
words = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=1).value
    if isinstance(val, str):
        words.append(val.strip().upper())
words_set = set(words)

vowels = ["A", "E", "I", "O", "U"]
pairs = []

# Find matching pairs
for w in words:
    if "S" not in w:
        continue
    for v in vowels:
        cand = w.replace("S", v)
        if cand != w and cand in words_set:
            pairs.append((w, cand))

# Deduplicate while preserving order
unique_pairs = list(dict.fromkeys(pairs))

# Sort alphabetically by first then second column
unique_pairs.sort(key=lambda x: (x[0], x[1]))

# Write to columns G (7) and H (8) starting at row 2
start_row = 2
for i, (w1, w2) in enumerate(unique_pairs):
    row = start_row + i
    ws.cell(row=row, column=7, value=w1)  # G
    ws.cell(row=row, column=8, value=w2)  # H

# Save workbook
wb.save(out_path)

# Recalculate formulas (required by workflow)
await recalculate(out_path)

# Verify by reloading (data_only=True) and printing first few output rows
