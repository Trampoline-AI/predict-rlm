import openpyxl, os
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_56920_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_56920_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet1"]

# Write formula into column C for all rows with data (starting at row 2)
for r in range(2, ws.max_row + 1):
    # Build formula string with the current row number
    formula = (
        f'=IFERROR(LEFT(MID(B{r}, FIND("955", B{r}), 10),10), '
        f'IFERROR(LEFT(MID(B{r}, FIND("CHK", B{r}), 10),10), ""))'
    )
    ws.cell(row=r, column=3).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("Verification of column C values:")
for r in range(2, ws_check.max_row + 1):
    print(r, ws_check.cell(row=r, column=3).value)
