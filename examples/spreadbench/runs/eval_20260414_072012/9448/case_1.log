# Write formula into column U (21)
for r in range(start_row, end_row + 1):
    cell = ws.cell(row=r, column=21)  # column U
    # Only write if the cell is currently empty or contains an error
    if cell.value is None or (isinstance(cell.value, str) and cell.value.startswith("=") is False):
        cell.value = f'=LOOKUP(2,1/(I{r}:T{r}<>""), $I$4:$T$4)'

