import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sample rows
def print_sheet_samples(ws, max_rows=5):
    # Determine max column based on header row (assume row 1)
    max_col = ws.max_column
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"Headers (row 1): {headers}")
    # First rows
    print("First rows:")
    for r in range(2, min(ws.max_row, max_rows+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Last rows
    print("Last rows:")
    start = max(ws.max_row - max_rows + 1, 2)
    for r in range(start, ws.max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Inspect BZTB sheet
if 'BZTB' in wb.sheetnames:
    ws_bztb = wb['BZTB']
    print("\n--- BZTB sheet ---")
    print_sheet_samples(ws_bztb)
else:
    print("Sheet 'BZTB' not found.")

# Inspect Tema UV COS sheet
if 'Tema UV COS' in wb.sheetnames:
    ws_tema = wb['Tema UV COS']
    print("\n--- Tema UV COS sheet ---")
    print_sheet_samples(ws_tema)
else:
    print("Sheet 'Tema UV COS' not found.")
