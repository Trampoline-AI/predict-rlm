        ws.cell(row=r, column=target_col).value = None
        continue

    # Define window: start at 06:00 of start_date, end at 05:59:59 of end_date
    window_start = datetime.datetime.combine(start_date.date() if isinstance(start_date, datetime.datetime) else start_date,
                                            datetime.time(6, 0, 0))
    window_end = datetime.datetime.combine(end_date.date() if isinstance(end_date, datetime.datetime) else end_date,
                                          datetime.time(5, 59, 59))

    # Sum sales for same product within window
    total = 0
    for rr in range(first_data_row, max_row + 1):
        if products[rr] != products[r]:
            continue
        cur_date = dates[rr]
        if not isinstance(cur_date, (datetime.datetime, datetime.date)):
            continue
        cur_dt = datetime.datetime.combine(cur_date.date() if isinstance(cur_date, datetime.datetime) else cur_date,
                                          datetime.time(0, 0, 0))
        if window_start <= cur_dt <= window_end:
            total += sales[rr]

    ws.cell(row=r, column=target_col).value = total

# Save to output path
wb.save(out_path)
wb.close()

