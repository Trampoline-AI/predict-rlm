import os
import datetime

# Paths
in_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(in_path))

# Load workbook for editing
wb = openpyxl.load_workbook(in_path, data_only=False, read_only=False)
ws = wb[wb.sheetnames[0]]

# Locate header row (first row containing "Date")
header_row = None
for r in range(1, 10):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(row=r, column=c).value
        if isinstance(v, str) and v.strip().lower() == "date":
            header_row = r
            break
    if header_row:
        break
if header_row is None:
    raise ValueError("Header row with 'Date' not found.")

# Helper to find column index by header name (first occurrence)
def col_idx(name):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(row=header_row, column=c).value
        if isinstance(v, str) and v.strip().lower() == name.lower():
            return c
    return None

date_col = col_idx("Date")
product_col = col_idx("Product")
sales_col = col_idx("Sales")   # first "Sales" header (numeric column)

if not all([date_col, product_col, sales_col]):
    raise ValueError("Could not locate required columns (Date, Product, Sales).")

# Determine target column: first empty column after current max
target_col = ws.max_column + 1
target_letter = get_column_letter(target_col)

# Write header for daily sales
ws.cell(row=header_row, column=target_col).value = "Daily Sales"

# Data rows start after header
first_data_row = header_row + 1
max_row = ws.max_row

# Load data into Python structures for fast lookup
dates = {}
products = {}
sales = {}

for r in range(first_data_row, max_row + 1):
    d = ws.cell(row=r, column=date_col).value
    p = ws.cell(row=r, column=product_col).value
    s = ws.cell(row=r, column=sales_col).value
    dates[r] = d
    products[r] = p
    sales[r] = s if isinstance(s, (int, float)) else 0

# Compute daily sales for each row (except the last one, which lacks a next‑date)
