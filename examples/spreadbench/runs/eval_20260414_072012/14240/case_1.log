```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_14240_init.xlsx'
output_path = '/sandbox/output/output_spreadsheet/1_14240_init.xlsx'

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Determine a safe target column (first empty column after existing data)
# Existing data goes up to column 21 (U). We'll check if U4 is empty.
target_col_idx = 21  # column U
target_cell = ws.cell(row=4, column=target_col_idx)
if target_cell.value is not None:
    # Find next empty column
    col = target_col_idx + 1
    while ws.cell(row=4, column=col).value is not None:
        col += 1
    target_col_idx = col
    target_cell = ws.cell(row=4, column=target_col_idx)

# Write the LibreOffice‑compatible SUMPRODUCT formula
# Use absolute references for the ranges to avoid accidental shifts
formula = (
    "=SUMPRODUCT((A4:A75=R4)*(B4:B75=S4)*(C3:M3=T4)*(C4:M75))"
)
target_cell.value = formula

# Save to output location
wb.save(output_path)

# Recalculate (LibreOffice will compute the formula when opened)
