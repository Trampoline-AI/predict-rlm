import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = '/sandbox/input/input_spreadsheet/1_55049_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print('Sheets:', wb.sheetnames)

# Function to show header and sample rows

def show_sheet(ws, rows=5):
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print('Headers:', headers)
    # First few rows
    for r in range(2, min(ws.max_row, rows+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f'Row {r}:', row_vals)
    # Last few rows
    start = max(2, ws.max_row - rows + 1)
    for r in range(start, ws.max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f'Row {r}:', row_vals)

# Show each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print('\n--- Sheet:', name, '---')
    show_sheet(ws, rows=5)
