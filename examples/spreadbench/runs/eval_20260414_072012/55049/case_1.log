import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_55049_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_55049_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
ws1 = wb["book1"]
ws2 = wb["book2"]

# Determine last data row in book2 (skip completely empty rows at bottom)
def last_nonempty_row(ws):
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(row=r, column=c).value is not None for c in range(1, ws.max_column+1)):
            return r
    return 0

last_row_book2 = last_nonempty_row(ws2)

# Build absolute range strings for book2
col_A = "$A$2:$A${}".format(last_row_book2)
col_HJ = "$H$2:$J${}".format(last_row_book2)

# Write formula into column B of book1 for each data row (starting at row 2)
for r in range(2, ws1.max_row + 1):
    # Check if column A has an identifier; stop if empty
    id_val = ws1.cell(row=r, column=1).value
    if id_val is None:
        continue
    # Build formula using relative reference to column A of the same row
    formula = f"=SUMPRODUCT((book2!{col_A}=A{r})*book2!{col_HJ})"
    ws1.cell(row=r, column=2).value = formula  # column B

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice + formulas library)
await recalculate(output_path)

# Verify first few result cells (data_only=True after recalculation)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["book1"]
print("Verification of first 5 result cells in column B:")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f"Row {r} B{r}: {ws_check.cell(row=r, column=2).value}")

# End of script
