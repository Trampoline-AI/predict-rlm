import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_49036_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_49036_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb['Dashboard']

# Write the formula into B8
formula = '=TEXT(VALUE(LEFT(B6, FIND(" ", B6)-1)) / VALUE(LEFT(B5, FIND(" ", B5)-1)), "0.00%") & " WIN RATE"'
ws['B8'] = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas using LibreOffice (async)
await recalculate(output_path)

# Reload with data_only to see the computed value
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2['Dashboard']
print('B8 computed value:', ws2['B8'].value)
```
