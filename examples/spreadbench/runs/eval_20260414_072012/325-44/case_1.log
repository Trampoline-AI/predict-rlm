```repl
import openpyxl
import re
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_325-44_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_325-44_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws_in = wb["Input"]
ws_out = wb["Output"]

# Helper to extract list of ints from a pattern like 'IN LIST 66,77'
def extract_list(text):
    m = re.search(r'IN LIST\s+([\d,\s]+)', text)
    if not m:
        return [None]
    # split by comma, strip, convert to int (leading zeros omitted automatically)
    return [int(num.strip()) for num in m.group(1).split(',') if num.strip()]

# Helper to extract a single quoted value e.g. '"LIM"'
def extract_quoted(text, key):
    pattern = rf'{key}\s*=\s*"([^"]+)"'
    m = re.search(pattern, text)
    return m.group(1) if m else None

# Build result rows
result_rows = []  # each entry: (wtype_id, name, status, orgId, careType, specialtyId, contextId)
for r in range(2, ws_in.max_row + 1):
    wtype_id = ws_in.cell(r, 1).value
    name = ws_in.cell(r, 2).value
    status = ws_in.cell(r, 3).value
    filter_str = ws_in.cell(r, 4).value or ""
    
    orgId = extract_quoted(filter_str, "orgId")
    careType = extract_quoted(filter_str, "careType")
    specialty_ids = extract_list(filter_str) if "specialtyId" in filter_str else [None]
    context_ids = extract_list(filter_str) if "contextId" in filter_str else [None]
    
    # Produce all combinations
    for sid in specialty_ids:
        for cid in context_ids:
            result_rows.append((wtype_id, name, status, orgId, careType, sid, cid))

# Clear existing data rows in Output (keep header)
for row in ws_out.iter_rows(min_row=2, max_row=ws_out.max_row, max_col=ws_out.max_column):
    for cell in row:
        cell.value = None

# Write header (ensure correct order)
headers = ['wtype_id', 'name', 'status', 'orgId', 'careType', 'specialtyId', 'contextId']
for c, h in enumerate(headers, start=1):
    ws_out.cell(row=1, column=c).value = h

# Write result rows
for idx, row_vals in enumerate(result_rows, start=2):
    for c, val in enumerate(row_vals, start=1):
        ws_out.cell(row=idx, column=c).value = val

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(str(output_path))
```
