import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_55060_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_55060_init.xlsx")

# Load workbook
wb = load_workbook(filename=input_path)
# Assume the relevant sheet is the active one (or first sheet)
ws = wb.active

# Write the formula to J23 (column 10, row 23)
ws["J23"] = '=IF(I12="","",I12)'

# Save the workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify by reloading with data_only
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active
value_J23 = ws_check["J23"].value
value_I12 = ws_check["I12"].value
print(f"I12 value: {value_I12!r}")
print(f"J23 value after formula: {value_J23!r}")

# Submit the output spreadsheet
SUBMIT(output_spreadsheet=output_path)
