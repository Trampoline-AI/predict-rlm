```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_82-30_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_82-30_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
raw_ws = wb["Raw Data"]
numbers_ws = wb["Numbers"]

# ----------------------------------------------------------------------
# 1. Collect whole numbers from Raw Data (columns A-F)
# ----------------------------------------------------------------------
whole_numbers = []
for row in raw_ws.iter_rows(min_row=1, max_col=6, values_only=True):
    for val in row:
        if isinstance(val, int):
            whole_numbers.append(val)
        elif isinstance(val, float) and val.is_integer():
            whole_numbers.append(int(val))

# ----------------------------------------------------------------------
# 2. Write numbers to Numbers sheet, max 6 per row, columns A-F
# ----------------------------------------------------------------------
# Clear existing content (optional but safe)
for r in numbers_ws.iter_rows(min_row=1, max_row=numbers_ws.max_row,
                              min_col=1, max_col=6):
    for cell in r:
        cell.value = None

for idx, num in enumerate(whole_numbers):
    row_idx = idx // 6 + 1   # 1‑based row
    col_idx = idx % 6 + 1    # 1‑based column (A‑F)
    numbers_ws.cell(row=row_idx, column=col_idx, value=num)

# ----------------------------------------------------------------------
# 3. Save to output location
# ----------------------------------------------------------------------
wb.save(output_path)

# ----------------------------------------------------------------------
# 4. Recalculate formulas (if any) and verify target cells
# ----------------------------------------------------------------------
import asyncio
await recalculate(output_path)

# Reload with data_only to see cached values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
numbers_check = wb_check["Numbers"]

# Verify first few rows
print("First 5 rows in Numbers after write:")
for r in range(1, 6):
    row_vals = [numbers_check.cell(row=r, column=c).value for c in range(1, 7)]
    print(r, row_vals)

# Verify total count
print("Total whole numbers written:", len(whole_numbers))
print("Rows used:", (len(whole_numbers) - 1) // 6 + 1)
```
