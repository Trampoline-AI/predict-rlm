The task is to **remove all characters that are not digits or a decimal point**, preserving the numeric value and any decimal points.  
We will:

1. Load the workbook.
2. Iterate over cells A1:H1.
3. For each cell, apply a regular expression that keeps only `0‑9` and `.` characters.
4. Convert the cleaned string to a number (`float`) if possible; otherwise keep the cleaned string.
5. Write the cleaned value back into the same cell.
6. Save the modified workbook to the output directory, recalculate formulas, and verify that the cells now contain the expected cleaned numeric values.
Code:
```repl
import openpyxl
import re
from openpyxl.utils import get_column_letter
import os

# Load the input workbook
wb = openpyxl.load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Define the target range A1:H1 (columns 1 to 8, row 1)
row_idx = 1
for col_idx in range(1, 9):
    cell = ws.cell(row=row_idx, column=col_idx)
    original = str(cell.value) if cell.value is not None else ""
    # Keep only digits and decimal points
    cleaned = re.sub(r"[^0-9.]", "", original)
    # Convert to float if it looks like a number, otherwise keep as string
    if cleaned == "":
        new_val = None
    else:
        # Preserve leading zeros if needed; float conversion is safe for numeric strings
        try:
            new_val = float(cleaned)
        except ValueError:
            new_val = cleaned
    cell.value = new_val

# Prepare output path
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))

# Save the workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to inspect the cleaned values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
cleaned_vals = [ws_check.cell(row=1, column=c).value for c in range(1, 9)]
print("Cleaned A1:H1 values:", cleaned_vals)
```
