Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_188-39_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_188-39_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
main_ws = wb["main sheet"]
result_ws = wb["result"]

# Build a lookup from Location -> (Designation, Contact, Mail)
loc_lookup = {}
for row in range(2, main_ws.max_row + 1):
    loc = main_ws.cell(row=row, column=1).value
    designation = main_ws.cell(row=row, column=5).value
    contact = main_ws.cell(row=row, column=3).value
    mail = main_ws.cell(row=row, column=4).value
    # Store the first occurrence; if duplicates exist, later rows will overwrite
    loc_lookup[loc] = (designation, contact, mail)

# Define the target designations
target_designations = {"Branch Manager", "Branch Credit Manager"}

# Update result sheet
for row in range(2, result_ws.max_row + 1):
    loc = result_ws.cell(row=row, column=1).value
    # Default to N/A
    result_ws.cell(row=row, column=2).value = "N/A"
    result_ws.cell(row=row, column=3).value = "N/A"
    result_ws.cell(row=row, column=4).value = "N/A"
    if loc in loc_lookup:
        desig, contact, mail = loc_lookup[loc]
        if desig in target_designations:
            result_ws.cell(row=row, column=2).value = desig
            result_ws.cell(row=row, column=3).value = contact
            result_ws.cell(row=row, column=4).value = mail
        else:
            # Keep N/A (already set)
            pass

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and reload data_only to verify
await recalculate(output_path)
# Reload to verify target cells are populated (optional verification step)
verify_wb = openpyxl.load_workbook(output_path, data_only=True)
verify_ws = verify_wb["result"]
print("Verification of result rows (first 5):")
for r in range(2, min(7, verify_ws.max_row + 1)):
    print([verify_ws.cell(row=r, column=c).value for c in range(1, 5)])
