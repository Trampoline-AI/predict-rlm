import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_188-39_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print("Sheets:", wb.sheetnames)

# Function to print headers and sample rows for a sheet
def inspect_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # Get headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"\nSheet: {ws.title}")
    print("Headers:", headers)
    # First 5 data rows
    print("First 5 rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Last 5 data rows
    if max_row > 6:
        print("Last 5 rows:")
        start = max(2, max_row-4)
        for r in range(start, max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(r, row_vals)

# Inspect each sheet
for title in wb.sheetnames:
    ws = wb[title]
    inspect_sheet(ws)
