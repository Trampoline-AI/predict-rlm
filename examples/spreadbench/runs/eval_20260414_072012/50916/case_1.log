import openpyxl
from openpyxl.utils import get_column_letter

# Paths
in_path = '/sandbox/input/input_spreadsheet/1_50916_init.xlsx'
out_dir = '/sandbox/output/output_spreadsheet/'
out_path = out_dir + '1_50916_init.xlsx'

# Load workbook
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb['21-22 Schedule']

max_row = ws.max_row
max_col = ws.max_column

# ----------------------------------------------------------------------
# 1. Build lookup table from existing example rows (rows 2‑8)
#    We'll place it in columns I‑O (I = Day, J‑O = H1, P1‑P5)
# ----------------------------------------------------------------------
lookup_start_row = 2
lookup_end_row = 8  # based on observed example rows
day_col = 2  # column B
period_cols = [3,4,5,6,7,8]  # C‑H

# Write headers for lookup table (optional, for clarity)
lookup_headers = ['Day','H1','P1','P2','P3','P4','P5']
for idx, hdr in enumerate(lookup_headers, start=9):  # I=9
    ws.cell(row=1, column=idx).value = hdr

# Copy data into lookup table
for r in range(lookup_start_row, lookup_end_row+1):
    # Day value
    ws.cell(row=r, column=9).value = ws.cell(row=r, column=day_col).value
    # Period values
    for i, pc in enumerate(period_cols):
        ws.cell(row=r, column=10+i).value = ws.cell(row=r, column=pc).value

# ----------------------------------------------------------------------
# 2. Write formulas into columns C‑H for all rows (2‑max_row)
#    Formula: =INDEX($J$2:$O$8, MATCH($B2, $I$2:$I$8, 0), <col_index>)
#    where <col_index> = 1 for H1 (column J), 2 for P1 (K), etc.
# ----------------------------------------------------------------------
lookup_day_range = "$I$2:$I$8"
lookup_range_start = "$J$2"
lookup_range_end = "$O$8"

for r in range(2, max_row+1):
    day_cell = f"$B{r}"
    # Only write formula if the Day cell is not empty (to avoid #N/A on blank rows)
    if ws.cell(row=r, column=day_col).value is not None:
        for offset, pc in enumerate(period_cols):
            # column letter for target cell
            target_col_letter = get_column_letter(pc)
            # column index within lookup range (1‑based)
            col_index = offset + 1
            formula = f"=INDEX({lookup_range_start}:{lookup_range_end}, MATCH({day_cell}, {lookup_day_range}, 0), {col_index})"
            ws[f"{target_col_letter}{r}"] = formula
    else:
        # Ensure blank rows stay blank
        for pc in period_cols:
            ws.cell(row=r, column=pc).value = None

# ----------------------------------------------------------------------
# 3. Save workbook to output directory
# ----------------------------------------------------------------------
import os
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)

# ----------------------------------------------------------------------
# 4. Recalculate formulas
# ----------------------------------------------------------------------
await recalculate(out_path)

# ----------------------------------------------------------------------
# 5. Verify a few rows (print row 2, 5, 10)
# ----------------------------------------------------------------------
def print_row(r):
    vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(f"Row {r}:", vals)

for r in [2,5,10]:
    print_row(r)
