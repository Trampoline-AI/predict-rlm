Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.cell.cell import MergedCell
import os

in_path = '/sandbox/input/input_spreadsheet/1_50916_init.xlsx'
out_dir = '/sandbox/output/output_spreadsheet/'
out_path = os.path.join(out_dir, '1_50916_init.xlsx')

# Load workbook
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb['21-22 Schedule']

max_row = ws.max_row

# ----------------------------------------------------------------------
# 1. Build lookup table in columns I‑O (I=Day, J‑O=periods) from rows 2‑8
# ----------------------------------------------------------------------
lookup_start = 2
lookup_end = 8
day_col = 2  # B
period_cols = [3,4,5,6,7,8]  # C‑H

for r in range(lookup_start, lookup_end + 1):
    # Day value
    ws.cell(row=r, column=9).value = ws.cell(row=r, column=day_col).value  # I
    # Period values into J‑O
    for i, pc in enumerate(period_cols):
        ws.cell(row=r, column=10 + i).value = ws.cell(row=r, column=pc).value

# ----------------------------------------------------------------------
# 2. Write formulas into columns C‑H for all rows where Day is present
# ----------------------------------------------------------------------
lookup_day_range = "$I$2:$I$8"
lookup_range = "$J$2:$O$8"

for r in range(2, max_row + 1):
    day_val = ws.cell(row=r, column=day_col).value
    if day_val is None:
        continue  # skip rows without a day number
    day_ref = f"$B{r}"
    for offset, pc in enumerate(period_cols):
        target_cell = ws.cell(row=r, column=pc)
        # Skip if the target cell is part of a merged range
        if isinstance(target_cell, MergedCell):
            continue
        col_index = offset + 1  # 1‑based index within J‑O
        formula = f"=INDEX({lookup_range}, MATCH({day_ref}, {lookup_day_range}, 0), {col_index})"
        target_cell.value = formula

# ----------------------------------------------------------------------
# 3. Save and recalculate
# ----------------------------------------------------------------------
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)
await recalculate(out_path)

# ----------------------------------------------------------------------
# 4. Verify a few rows (print columns B‑H for rows 2,5,10)
# ----------------------------------------------------------------------
def print_row(r):
    vals = [ws.cell(row=r, column=c).value for c in range(2, 9)]  # B‑H
    print(f"Row {r} (B‑H):", vals)

for r in [2, 5, 10]:
    print_row(r)
