import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas, data_only=False)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Worksheets
src_name = "cdnr"
dst_name = "b2b, sez, de"
ws_src = wb[src_name]
ws_dst = wb[dst_name]

# Determine first empty row in destination (scan column A from row 5 onward)
first_empty = None
for r in range(5, ws_dst.max_row + 2):  # +2 to allow one extra check beyond current max
    if ws_dst.cell(row=r, column=1).value is None:
        first_empty = r
        break
if first_empty is None:
    # If no empty found, start after the last row
    first_empty = ws_dst.max_row + 1

# Identify max columns (both sheets have same layout)
max_col = max(ws_src.max_column, ws_dst.max_column)

# Copy rows
target_row = first_empty
for src_row in range(5, ws_src.max_row + 1):
    # Check if the entire row is empty (skip trailing blanks)
    if all(ws_src.cell(row=src_row, column=c).value is None for c in range(1, max_col + 1)):
        continue
    for col in range(1, max_col + 1):
        val = ws_src.cell(row=src_row, column=col).value
        # Negate amounts in columns L (12) and M (13) if numeric
        if col in (12, 13) and isinstance(val, (int, float)):
            val = -val
        ws_dst.cell(row=target_row, column=col).value = val
    target_row += 1

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only=True to confirm
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[dst_name]

# Print a few rows around the newly added data for verification
print("Destination sheet after copy (rows", first_empty, "to", target_row-1, "):")
for r in range(first_empty, min(first_empty + 5, target_row)):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, max_col + 1)]
    print(r, row_vals)
```
