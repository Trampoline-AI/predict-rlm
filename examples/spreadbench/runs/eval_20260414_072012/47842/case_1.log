```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_47842_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_47842_init.xlsx')

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row
# Process rows starting from 2 (skip header)
for r in range(2, max_row + 1):
    b_cell = ws.cell(row=r, column=2)  # Column B
    c_cell = ws.cell(row=r, column=3)  # Column C
    b_val = b_cell.value
    c_val = c_cell.value
    # Skip if B is empty or C is empty
    if b_val is None or c_val is None:
        continue
    # Ensure both are strings
    b_str = str(b_val)
    c_str = str(c_val)
    # Adjust case of C to match B
    if b_str.islower():
        new_c = c_str.lower()
    else:
        # Title case (first letter uppercase, rest lowercase)
        new_c = c_str.title()
    # Write back only if changed
    if new_c != c_str:
        c_cell.value = new_c

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify a few rows after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of rows 2-6 after case adjustment:")
for r in range(2, 7):
    print(r, ws_check.cell(row=r, column=2).value, "->", ws_check.cell(row=r, column=3).value)
```
