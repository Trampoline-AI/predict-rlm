import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_1925_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_1925_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Determine the data range in Sheet2 (rows 6..max_row, columns A..max_column)
max_col = ws2.max_column
max_row = ws2.max_row
col_letter_start = get_column_letter(1)   # "A"
col_letter_end   = get_column_letter(max_col)

# Build the range string for INDEX (e.g., Sheet2!$A$6:$Z$100)
data_range = f"Sheet2!${col_letter_start}$6:${col_letter_end}${max_row}"

# Build the formula string with the known data_range inserted.
# We'll later substitute the row number for the MATCH on Sheet1!B{row}.
formula_base = (
    "IFERROR("
    f"INDEX({data_range},"
    "MATCH(Sheet1!B{row},"
    f"INDEX({data_range},0,"
    "MATCH(Sheet1!C5,Sheet2!$5:$5,0)),0),"
    "MATCH(Sheet1!C5,Sheet2!$5:$5,0)),"
    "\"NEW\")"
)

# Apply formula to every cell in column C starting at row 6
first_data_row = 6
last_row = ws1.max_row
for r in range(first_data_row, last_row + 1):
    cell = ws1.cell(row=r, column=3)  # column C = 3
    # Insert the current row number into the formula
    cell.value = "=" + formula_base.format(row=r)

# Save to output path
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify a few cells after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("Verification (first 5 data rows in column C):")
for r in range(first_data_row, min(first_data_row + 5, ws_check.max_row + 1)):
    print(r, ws_check.cell(row=r, column=3).value)

# Submit the resulting spreadsheet
SUBMIT(output_spreadsheet=output_path)
