import openpyxl, os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_472-15_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_472-15_init.xlsx')

# Load workbook (preserve formulas, though we will write a value)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Read A1
a1_val = ws['A1'].value or ''
a1_str = str(a1_val).lower()

# Mapping of keywords to numbers
mapping = {
    '4ozark': 1,
    '3tall': 2,
    '1jasper': 3,
    '2gwood': 4,
    '5dawson': 5,
    '8cpark': 6,
}

# Determine the number to write
result = None
for key, num in mapping.items():
    if key in a1_str:
        result = num
        break

# Write result (or leave blank if none matched)
ws['B2'].value = result

# Save to output location
wb.save(output_path)

# Recalculate (no formulas, but call to follow workflow)
await recalculate(output_path)

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print('B2 after processing:', ws_check['B2'].value)
```
