Code:
```repl
import os, openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active

# Find the last row that has a numeric value in column A
max_row = ws.max_row
last_data_row = 1
for r in range(max_row, 0, -1):
    val = ws.cell(row=r, column=1).value
    if isinstance(val, (int, float)):
        last_data_row = r
        break

# We need to fill B12 through B{last_data_row}
start_row = 12
if last_data_row >= start_row:
    for r in range(start_row, last_data_row + 1):
        cell = ws.cell(row=r, column=2)  # column B
        # Write formula (overwrite only if empty or contains an error)
        if cell.value is None or isinstance(cell.value, str) and not cell.value.startswith("="):
            cell.value = f"=ROUND(AVERAGE($A$2:A{r}),3)"
else:
    print("No data rows to process.")

# Save workbook
wb.save(output_path)

# Recalculate formulas
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Verify a few cells (data_only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
samples = {}
for r in range(start_row, min(start_row + 5, ws_check.max_row + 1)):
    samples[f"B{r}"] = ws_check.cell(row=r, column=2).value
print("Sample computed averages:", samples)
```
