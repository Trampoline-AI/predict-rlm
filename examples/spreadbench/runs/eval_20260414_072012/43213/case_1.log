import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active

# Determine last row with data in column A (values)
max_row = ws.max_row
# Ensure we have at least row 11 as start; if not, nothing to do
start_row = 12
if max_row < start_row:
    print("No rows to process.")
else:
    # Write formula for each row from start_row to max_row
    for r in range(start_row, max_row + 1):
        cell = ws.cell(row=r, column=2)  # column B
        # Only write if cell is empty or contains an error
        if cell.value is None or isinstance(cell.value, str) and cell.value.startswith("=") is False:
            formula = f"=ROUND(AVERAGE($B$11:B{r}),3)"
            cell.value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to verify a few cells
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active
# Print sample of computed averages for rows 12-15 (if they exist)
samples = {}
for r in range(12, min(16, ws2.max_row + 1)):
    samples[f"B{r}"] = ws2.cell(row=r, column=2).value
print("Sample computed averages:", samples)
