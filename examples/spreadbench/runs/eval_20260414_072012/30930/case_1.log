for r in range(2, min(max_row, 12)):
    b = ws_check.cell(row=r, column=2).value
    c = ws_check.cell(row=r, column=3).value
    if b == 1:
        samples.append((r, b, c))
print("Sample rows where B=1 and C value:", samples)
