```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_49300_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_49300_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet1"]

# Determine last row with data (assume column A defines the extent)
max_row = ws.max_row

# Write corrected non‑array INDEX/MATCH formula into column C for each data row
for r in range(2, max_row + 1):
    job = ws.cell(row=r, column=1).value
    month = ws.cell(row=r, column=2).value
    if job is not None and month is not None:
        formula = (
            f"=INDEX(Data!C3:AY4,"
            f"MATCH(Sheet1!A{r},Data!B3:B4,0),"
            f"MATCH(Sheet1!B{r},Data!C2:AY2,0))"
