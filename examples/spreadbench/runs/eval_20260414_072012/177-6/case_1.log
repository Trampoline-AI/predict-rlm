import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.styles import PatternFill, Font, Alignment, Border, Side
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_177-6_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_177-6_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws_data = wb["DATA"]
ws_comb = wb["combined"]

# Clear combined sheet (keep header row)
for row in ws_comb.iter_rows(min_row=2, max_row=ws_comb.max_row):
    for cell in row:
        cell.value = None
        cell._style = openpyxl.styles.NamedStyle()  # reset style

# Group rows by column H (8)
from collections import defaultdict
groups = defaultdict(list)  # key -> list of row numbers

for r in range(2, ws_data.max_row + 1):
    key = ws_data.cell(row=r, column=8).value
    if key is None:
        continue
    groups[key].append(r)

# Helper to copy style from source cell to target cell
def copy_style(src, tgt):
    tgt.font = src.font
    tgt.fill = src.fill
    tgt.alignment = src.alignment
    tgt.border = src.border
    tgt.number_format = src.number_format

# Write merged rows
out_row = 2
for key, rows in groups.items():
    # Use first row for non‑numeric columns and style reference
    first = rows[0]
    # Columns A‑H (1‑8) copy values and style
    for col in range(1, 9):
        src_cell = ws_data.cell(row=first, column=col)
        tgt_cell = ws_comb.cell(row=out_row, column=col)
        tgt_cell.value = src_cell.value
        copy_style(src_cell, tgt_cell)

    # Columns I‑R (9‑18) sum numeric values
    for col in range(9, 19):
        total = 0
        has_number = False
        for r in rows:
            val = ws_data.cell(row=r, column=col).value
            if isinstance(val, (int, float)):
                total += val
                has_number = True
        tgt_cell = ws_comb.cell(row=out_row, column=col)
        if has_number:
            # Round to 2 decimals as required
            tgt_cell.value = round(total, 2)
            tgt_cell.number_format = "0.00"
        else:
            tgt_cell.value = None
        # Copy style from first row's cell (even if blank) for consistency
        src_cell = ws_data.cell(row=first, column=col)
        copy_style(src_cell, tgt_cell)

    out_row += 1

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)
# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["combined"]
print("Combined sheet after merge:")
for r in range(2, ws_check.max_row + 1):
    vals = [ws_check.cell(row=r, column=c).value for c in range(1, 19)]
    print(f"Row {r}:", vals)
