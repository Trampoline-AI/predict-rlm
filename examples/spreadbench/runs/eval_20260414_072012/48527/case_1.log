import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_48527_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_48527_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine max row
max_row = ws.max_row

# Track seen values for uniqueness
seen = set()

# Process rows
for r in range(2, max_row + 1):
    val_a = ws.cell(row=r, column=1).value
    val_b = ws.cell(row=r, column=2).value
    if val_a == val_b and val_a is not None:
        val_c = ws.cell(row=r, column=3).value
        if val_c is not None and val_c not in seen:
            ws.cell(row=r, column=4).value = val_c
            seen.add(val_c)
        else:
            # Ensure blank if duplicate or None
            ws.cell(row=r, column=4).value = None
    else:
        # Not a qualifying row – leave column D unchanged (or clear)
        ws.cell(row=r, column=4).value = None

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload with data_only to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Final column D values:")
for r in range(2, max_row + 1):
    print(r, ws_check.cell(row=r, column=4).value)
