Code:
```repl
import openpyxl
from openpyxl import load_workbook

# Load the workbook
wb = load_workbook("/sandbox/input/input_spreadsheet/1_54474_init.xlsx", data_only=False)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows for a sheet
def inspect_sheet(ws, name):
    print(f"\n--- Sheet: {name} ---")
    # Header row (assume first row)
    header = [cell.value for cell in ws[1]]
    print("Header:", header)
    max_row = ws.max_row
    max_col = ws.max_column
    # Print first 5 rows (including header)
    print("First rows:")
    for r in range(1, min(6, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(r, row_vals)
    # Print last 5 rows if more than 5 rows total
    if max_row > 5:
        print("Last rows:")
        for r in range(max_row - 4, max_row + 1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
            print(r, row_vals)

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    inspect_sheet(ws, name)
