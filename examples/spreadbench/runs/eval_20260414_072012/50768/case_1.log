import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50768_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_50768_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active

# --- Identify risk table layout ---
# Header row is 3 (found earlier)
header_row = 3
id_col = 1
impact_col = 2
likelihood_col = 3

# Gather risk entries until a blank ID cell
risk_map = {}  # (impact, likelihood) -> list of IDs
row = header_row + 1
while True:
    id_val = ws.cell(row=row, column=id_col).value
    if id_val is None:
        break
    impact_val = ws.cell(row=row, column=impact_col).value
    likelihood_val = ws.cell(row=row, column=likelihood_col).value
    # ensure numeric
    try:
        i = int(impact_val)
        l = int(likelihood_val)
    except Exception:
        row += 1
        continue
    key = (i, l)
    risk_map.setdefault(key, []).append(str(id_val))
    row += 1

# --- Write to matrix ---
# Matrix headers positions (found earlier)
impact_header_row, impact_header_col = 12, 4  # cell containing the word "Impact"
likelihood_header_row, likelihood_header_col = 16, 6  # cell containing "Liklihood"

# The matrix grid starts one row below the likelihood header and one column right of the impact header
# For each possible impact (1‑3) and likelihood (1‑3) we compute the target cell
for i in range(1, 4):
    for l in range(1, 4):
        target_row = likelihood_header_row + l  # row index for this likelihood
        target_col = impact_header_col + i       # column index for this impact
        ids = risk_map.get((i, l), [])
        cell_value = ", ".join(ids) if ids else ""
        ws.cell(row=target_row, column=target_col, value=cell_value)

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice) – using provided tool
await recalculate(output_path)

# Verify by re‑loading data‑only and printing the matrix cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Matrix content after write:")
for l in range(1, 4):
    row_vals = []
    for i in range(1, 4):
        cell = ws_check.cell(row=likelihood_header_row + l, column=impact_header_col + i)
        row_vals.append(cell.value)
    print(f"Likelihood {l}:", row_vals)
```
