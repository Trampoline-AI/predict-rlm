```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_50768_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows for a sheet
def inspect_sheet(ws, max_samples=5):
    # Determine max column based on first row
    max_col = ws.max_column
    # Header row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"\nSheet: {ws.title}")
    print("Headers:", headers)
    # First few rows
    total_rows = ws.max_row
    print(f"Total rows (including header): {total_rows}")
    print("First rows:")
    for r in range(2, min(2+max_samples, total_rows+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}: {row_vals}")
    # Last few rows
    print("Last rows:")
    start = max(2, total_rows - max_samples + 1)
    for r in range(start, total_rows+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}: {row_vals}")

# Inspect each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    inspect_sheet(ws)
```
