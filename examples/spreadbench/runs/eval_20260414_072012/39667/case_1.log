```repl
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.styles import PatternFill

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_39667_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)
print("Sheet names:", wb.sheetnames)

# We'll work with the first sheet (adjust later if needed)
ws = wb[wb.sheetnames[0]]

# Determine max rows/cols
max_row = ws.max_row
max_col = ws.max_column
print(f"Rows: {max_row}, Columns: {max_col}")

# Print header row (assume first row)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Headers:", headers)

# Print first 10 data rows (excluding header)
print("First 10 rows:")
for r in range(2, min(12, max_row+1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Print last 5 rows
print("Last 5 rows:")
for r in range(max_row-4, max_row+1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Find rows with black fill in any cell (RGB '000000')
black_rows = set()
for r in range(1, max_row+1):
    for c in range(1, max_col+1):
        cell = ws.cell(row=r, column=c)
        fill = cell.fill
        if isinstance(fill, PatternFill) and fill.fgColor and fill.fgColor.rgb == "FF000000":
            black_rows.add(r)
            break
print("Rows with black fill:", sorted(black_rows))

# Show columns A & B colors for rows 20-26
print("Colors for A20-B26:")
for r in range(20, 27):
    a_fill = ws.cell(row=r, column=1).fill.fgColor.rgb if ws.cell(row=r, column=1).fill else None
    b_fill = ws.cell(row=r, column=2).fill.fgColor.rgb if ws.cell(row=r, column=2).fill else None
    print(r, a_fill, b_fill)
