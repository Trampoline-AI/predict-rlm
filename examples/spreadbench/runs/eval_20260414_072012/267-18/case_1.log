Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Helper to get fill color RGB
def get_fill_rgb(cell):
    if cell.fill and cell.fill.start_color and cell.fill.start_color.rgb:
        return cell.fill.start_color.rgb
    return None

# Yellow RGB used by LibreOffice (may be ARGB; ignore alpha if present)
YELLOW_RGB = "FFFFF00"  # sometimes "FFFFFF00" (alpha FF + RGB FFFFFF00)
# We'll accept both with/without leading alpha
def is_yellow(cell):
    rgb = get_fill_rgb(cell)
    if not rgb:
        return False
    # Normalize to 8 chars (ARGB) if needed
    if len(rgb) == 6:
        rgb = "FF" + rgb
    return rgb.upper() in {"FFFFFFFF00", "FFFFFF00", "FFFFF00"}

# Process rows
for row in range(2, ws.max_row + 1):
    g_cell = ws.cell(row=row, column=7)  # column G
    if is_yellow(g_cell):
        orig = g_cell.value
        if isinstance(orig, str) and orig.startswith("="):
            # Strip leading '='
            inner = orig[1:]
            # Build new formula
            new_formula = f'=CONCATENATE("//",{inner})'
            g_cell.value = new_formula
            # Preserve existing fill (optional)
        else:
            # Not a formula; skip or handle as needed
            pass

# Save to output location
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify a few rows after recalculation (data_only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification (first 5 rows, column G values):")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(r, ws_check.cell(r, 7).value)
