import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_36097_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_36097_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine data rows (exclude header row 1 and total row if it contains a SUM)
max_row = ws.max_row
# Identify total row: often contains "Total" in column A
total_row = None
for r in range(2, max_row + 1):
    if ws.cell(row=r, column=1).value == "Total":
        total_row = r
        break

# Write formula to column H (index 8) for each data row
for r in range(2, max_row + 1):
    if total_row and r == total_row:
        continue  # skip total row
    # Build formula string using column letters
    col_C = get_column_letter(3)  # Cost
    col_E = get_column_letter(5)  # ITV
    col_F = get_column_letter(6)  # Profit
    formula = f"=IF({col_F}{r}<0, {col_E}{r}+{col_F}{r}, IF({col_F}{r}<{col_C}{r}, {col_F}{r}, {col_C}{r}-{col_E}{r}))"
    ws.cell(row=r, column=8).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify by reloading data_only
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification of column H values after recalculation:")
for r in range(2, max_row + 1):
    if total_row and r == total_row:
        continue
    print(r, ws_check.cell(row=r, column=8).value)
