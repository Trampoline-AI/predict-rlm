Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
from datetime import datetime, timedelta

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_66-24_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheets
print("Sheets:", wb.sheetnames)

# Inspect Imported Data sheet
ws_src = wb["Imported Data"]
print("Imported Data rows:", ws_src.max_row, "cols:", ws_src.max_column)

# Print header row
header = [ws_src.cell(row=1, column=c).value for c in range(1, ws_src.max_column+1)]
print("Header:", header)

# Print first 5 data rows
for r in range(2, min(7, ws_src.max_row+1)):
    row_vals = [ws_src.cell(row=r, column=c).value for c in range(1, ws_src.max_column+1)]
    print(f"Row {r}:", row_vals)

# Print last 5 data rows
for r in range(max(2, ws_src.max_row-4), ws_src.max_row+1):
    row_vals = [ws_src.cell(row=r, column=c).value for c in range(1, ws_src.max_column+1)]
    print(f"Row {r}:", row_vals)

# Check column E dates
col_e = column_index_from_string('E')
dates = [ws_src.cell(row=r, column=col_e).value for r in range(2, ws_src.max_row+1)]
print("Sample dates (first 5):", dates[:5])
print("Sample dates (last 5):", dates[-5:])

# Find max date
max_date = max([d for d in dates if isinstance(d, datetime)])
print("Max date:", max_date)

# Determine cutoff
cutoff = max_date - timedelta(days=30)
print("Cutoff date (max -30d):", cutoff)

# Identify target sheet, create if not exists
target_name = "Items Older than 30 days"
if target_name not in wb.sheetnames:
    ws_tgt = wb.create_sheet(title=target_name)
else:
    ws_tgt = wb[target_name]

# Clear target sheet (except header later)
ws_tgt.delete_rows(1, ws_tgt.max_row)

# Copy header
for c, val in enumerate(header, start=1):
    ws_tgt.cell(row=1, column=c).value = val

# Copy rows meeting condition
out_row = 2
for r in range(2, ws_src.max_row+1):
    cell_val = ws_src.cell(row=r, column=col_e).value
    if isinstance(cell_val, datetime) and cell_val < cutoff:
        for c in range(1, ws_src.max_column+1):
            src_cell = ws_src.cell(row=r, column=c)
            tgt_cell = ws_tgt.cell(row=out_row, column=c)
            tgt_cell.value = src_cell.value
            # copy style (number format) for dates etc.
            tgt_cell.number_format = src_cell.number_format
        out_row += 1

print("Rows copied:", out_row-2)

# Delete column Z in target sheet (column 26)
col_z = column_index_from_string('Z')
if ws_tgt.max_column >= col_z:
    ws_tgt.delete_cols(col_z)
    print("Deleted column Z in target sheet")
else:
    print("Column Z not present in target sheet")

# Save to output path
out_path = "/sandbox/output/output_spreadsheet/1_66-24_init.xlsx"
wb.save(out_path)
print("Saved to", out_path)
```
