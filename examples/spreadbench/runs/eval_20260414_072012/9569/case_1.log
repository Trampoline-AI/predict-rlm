Plan:
1. Load the input workbook.
2. Identify the target column (AO → index 41) and the data range columns (8 → 40, i.e., H → AN).
3. For each row from 2 to `max_row`:
   - Scan columns 8‑40 left‑to‑right.
   - Find the first cell with a numeric value that is not zero.
   - Write that value (or blank if none) into column 41.
4. Save the workbook to `/sandbox/output/output_spreadsheet/1_9569_init.xlsx`.
5. Call `recalculate()` on the saved file.
6. Reload the file with `data_only=True` and print a few sample results to confirm.
Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_9569_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_9569_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Column indices
first_data_col = column_index_from_string("H")   # 8
last_data_col  = column_index_from_string("AN")  # 40 (one before AO)
target_col     = column_index_from_string("AO")  # 41

max_row = ws.max_row

# Compute earliest non‑zero per row and write into column AO
for r in range(2, max_row + 1):
    earliest = None
    for c in range(first_data_col, last_data_col + 1):
        val = ws.cell(row=r, column=c).value
        # consider numeric values; ignore None / empty / text
        if isinstance(val, (int, float)) and val != 0:
            earliest = val
            break
    # Write result (blank if none)
    ws.cell(row=r, column=target_col).value = earliest

# Save workbook
wb.save(output_path)

# Recalculate formulas (even though we wrote literals, this follows the required workflow)
await recalculate(output_path)

# Reload with data_only to verify a few rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification (first 5 rows, column AO):")
for r in range(2, 7):
    print(r, ws_check.cell(row=r, column=target_col).value)
print("Verification (last 5 rows, column AO):")
for r in range(max_row-4, max_row+1):
    print(r, ws_check.cell(row=r, column=target_col).value)
```
