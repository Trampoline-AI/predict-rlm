# Load workbook
wb = openpyxl.load_workbook("/sandbox/input/input_spreadsheet/1_55965_init.xlsx")
print("Sheet names:", wb.sheetnames)

# Function to inspect a sheet
def inspect_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Sheet '{ws.title}': {max_row} rows, {max_col} columns")
    # Get headers from first row
