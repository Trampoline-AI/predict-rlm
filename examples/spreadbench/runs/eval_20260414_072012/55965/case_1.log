import openpyxl
from pathlib import Path
import os

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_55965_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_55965_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
data_ws = wb["DATI"]
target_ws = wb["Foglio1"]

# Build ID → list of result strings (column J) preserving order
id_to_results = {}
for r in range(2, data_ws.max_row + 1):
    id_val = data_ws.cell(row=r, column=11).value  # column K
    result = data_ws.cell(row=r, column=10).value  # column J
    if id_val is None:
        continue
    id_to_results.setdefault(id_val, []).append(result)

# Write last 10 results into columns G-P (7-16) of Foglio1
for r in range(2, target_ws.max_row + 1):
    id_val = target_ws.cell(row=r, column=5).value  # column E
    if id_val is None:
        continue
    results = id_to_results.get(id_val, [])
    # Take last 10 (most recent)
    last10 = results[-10:] if len(results) >= 10 else results
    # Pad to length 10 with None
    last10 = [None] * (10 - len(last10)) + last10
    # Write into G-P
    for offset, val in enumerate(last10):
        col = 7 + offset  # G=7
        cell = target_ws.cell(row=r, column=col)
        # Overwrite only if cell is empty or contains an error string
        if cell.value is None or isinstance(cell.value, str) and cell.value.startswith("#"):
            cell.value = val

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and verify
# The environment provides a recalculate tool; we call it via await
import asyncio
from pathlib import Path

# Recalculate
await recalculate(str(output_path))

# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Foglio1"]

# Print a few verification rows (e.g., rows 2-4)
