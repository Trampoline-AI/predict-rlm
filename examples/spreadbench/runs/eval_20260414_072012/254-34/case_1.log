```repl
import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.formatting.rule import CellIsRule
from openpyxl.utils import get_column_letter

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_254-34_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_254-34_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)

# Target sheet
ws = wb["Before"]

# Determine data range (column A, rows 2..max_row)
max_row = ws.max_row
col_letter = get_column_letter(1)  # "A"
data_range = f"{col_letter}2:{col_letter}{max_row}"

# Define a light‑green fill
green_fill = PatternFill(start_color="C6EFCE", end_color="C6EFCE", fill_type="solid")

# Conditional formatting: highlight cells with value between 994108 and 994112
# Use two CellIsRule objects (>= lower bound, <= upper bound) combined via AND logic.
# openpyxl does not support direct AND, so we create a rule that checks the range using a formula.
# Formula: =AND(A2>=994108, A2<=994112)
formula = f"=AND({col_letter}2>=994108,{col_letter}2<=994112)"
ws.conditional_formatting.add(data_range, CellIsRule(operator='equal', formula=[formula], fill=green_fill))

# Save workbook
wb.save(out_path)

# Recalculate formulas (if any) and verify
await recalculate(out_path)

# Reload to confirm the conditional formatting exists
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check["Before"]
print("Conditional formatting rules on 'Before':", ws_check.conditional_formatting)
