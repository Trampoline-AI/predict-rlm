Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_516-46_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_516-46_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine data range (A2:Emax)
max_row = ws.max_row
# Collect rows data
brand_data = {}  # brand -> list of (date, qty)
for r in range(2, max_row + 1):
    date = ws.cell(row=r, column=1).value  # A
    brand = ws.cell(row=r, column=2).value  # B
    qty = ws.cell(row=r, column=5).value  # E
    if brand is None:
        continue
    # Ensure qty is numeric
    try:
        qty = float(qty)
    except (TypeError, ValueError):
        qty = 0
    brand_data.setdefault(brand, []).append((date, qty))

# Compute per‑brand latest date and summed qty
results = []  # list of (date, brand, sum_qty)
for brand, entries in brand_data.items():
    # Find max date
    max_date = max(d for d, _ in entries if d is not None)
    # Sum qty for rows with that date
    total_qty = sum(q for d, q in entries if d == max_date)
    results.append((max_date, brand, total_qty))

# Sort results by date descending (optional)
results.sort(key=lambda x: x[0], reverse=True)

# Write results starting at H2 (column 8)
start_row = 2
for i, (date, brand, qty) in enumerate(results):
    row = start_row + i
    ws.cell(row=row, column=8).value = date   # H
    ws.cell(row=row, column=9).value = brand  # I
    ws.cell(row=row, column=10).value = qty   # J

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of written results:")
for i in range(len(results)):
    r = start_row + i
    print(r, ws_check.cell(row=r, column=8).value,
          ws_check.cell(row=r, column=9).value,
          ws_check.cell(row=r, column=10).value)
```
