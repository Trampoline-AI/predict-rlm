import re, os, openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_42216_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_42216_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet1"]

# ------------------------------------------------------------------
# 1. Ensure April row exists with correct label (YYYY-04)
# ------------------------------------------------------------------
# Determine year from first month row (row 2)
first_val = ws.cell(row=2, column=1).value
year_part = "1951"
if isinstance(first_val, str) and "-" in first_val:
    year_part = first_val.split("-")[0]

april_label = f"{year_part}-04"

# Find last row that matches a proper month label (YYYY-MM)
month_pat = re.compile(r"\d{4}-\d{2}$")
last_month_row = None
for r in range(2, ws.max_row + 1):
    v = ws.cell(row=r, column=1).value
    if isinstance(v, str) and month_pat.fullmatch(v):
        last_month_row = r

# Insert April row after the last proper month row (or at row 2 if none)
insert_row = (last_month_row + 1) if last_month_row else 2
current = ws.cell(row=insert_row, column=1).value
if current != april_label:
    # If a row already exists here, shift it down
    ws.insert_rows(insert_row)
    ws.cell(row=insert_row, column=1, value=april_label)

# ------------------------------------------------------------------
# 2. Clean up stray rows after the month list (remove everything
#    that is not a proper month label in column A)
# ------------------------------------------------------------------
# Scan downwards; once we hit a non‑month entry, delete that row
# (but stop before we delete rows we might need later)
r = insert_row + 1
while r <= ws.max_row:
    v = ws.cell(row=r, column=1).value
    if isinstance(v, str) and month_pat.fullmatch(v):
        r += 1
        continue
    # Delete this row (and any following non‑month rows)
    ws.delete_rows(r)
    # Do not increment r because rows shift up
# ------------------------------------------------------------------
# 3. Collect month labels and their rows (now clean)
# ------------------------------------------------------------------
months = []
month_rows = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(row=r, column=1).value
    if isinstance(v, str) and month_pat.fullmatch(v):
        months.append(v)
        month_rows.append(r)

# ------------------------------------------------------------------
# 4. Rebuild Group B sheet (only Day + month columns)
# ------------------------------------------------------------------
if "Group B" in wb.sheetnames:
    wb.remove(wb["Group B"])
ws_b = wb.create_sheet("Group B")

# Header
ws_b.cell(row=1, column=1, value="Day")
for idx, month in enumerate(months, start=2):
    ws_b.cell(row=1, column=idx, value=month)

# Fill days 1‑31
for day in range(1, 32):
    ws_b.cell(row=day+1, column=1, value=day)  # column A = day number
    for col_idx, (month, mrow) in enumerate(zip(months, month_rows), start=2):
        orig_cell = ws.cell(row=mrow, column=day+1)  # column 1 is Year‑Month
        val = orig_cell.value
        # Apply rules
        if val == -9999 or val == "M":
            out_val = None
        elif month.endswith("-04"):          # April
            out_val = 0 if val is None else val
        else:
            out_val = val
        ws_b.cell(row=day+1, column=col_idx, value=out_val)

# ------------------------------------------------------------------
# 5. Save, recalculate, and verify
# ------------------------------------------------------------------
wb.save(output_path)
await recalculate(output_path)

# Verify
check_wb = openpyxl.load_workbook(output_path, data_only=True)
check_ws = check_wb["Group B"]
header = [check_ws.cell(row=1, column=c).value for c in range(1, check_ws.max_column+1)]
