        val = orig_cell.value
        # Apply filtering rules
        if val == -9999 or val == "M":
            out_val = None
        elif month.endswith("-04"):          # April month
            out_val = 0 if val is None else val
        else:
            out_val = val
        ws_b.cell(row=day+1, column=col_idx, value=out_val)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# ---- 4. Verification ----
check_wb = openpyxl.load_workbook(output_path, data_only=True)
