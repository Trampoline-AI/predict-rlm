import openpyxl, os, re
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_42216_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_42216_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet1"]

# ---- Ensure April row exists ----
# Find first blank Year‑Month cell after existing data
insert_row = None
for r in range(2, ws.max_row + 1):
    if ws.cell(row=r, column=1).value is None:
        insert_row = r
        break
if insert_row is None:
    insert_row = ws.max_row + 1

# Insert row if needed and label it
if ws.cell(row=insert_row, column=1).value is None:
