header = [check_ws.cell(row=1, column=c).value for c in range(1, check_ws.max_column+1)]
print("Header:", header)
# Locate April column index
april_idx = None
for i, h in enumerate(header[1:], start=2):
    if isinstance(h, str) and h.endswith("-04"):
        april_idx = i
        break
print("April column index:", april_idx)
if april_idx:
