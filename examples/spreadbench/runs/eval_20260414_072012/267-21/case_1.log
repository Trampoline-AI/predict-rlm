import os, openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_267-21_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_267-21_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Build lookup dictionaries for SH1 and RP1 (ID -> QTY)
lookup_sh1 = {}
lookup_rp1 = {}

ws_sh1 = wb["SH1"]
for r in range(2, ws_sh1.max_row + 1):
    id_val = ws_sh1.cell(row=r, column=2).value  # column B = ID
    qty = ws_sh1.cell(row=r, column=3).value   # column C = QTY
    if id_val is not None:
        lookup_sh1[id_val] = qty

ws_rp1 = wb["RP1"]
for r in range(2, ws_rp1.max_row + 1):
    id_val = ws_rp1.cell(row=r, column=2).value
    qty = ws_rp1.cell(row=r, column=3).value
    if id_val is not None:
        lookup_rp1[id_val] = qty

# Populate the merging sheet (columns C and D)
ws_merge = wb["merging"]
for r in range(2, ws_merge.max_row + 1):
    id_val = ws_merge.cell(row=r, column=2).value  # column B = ID
    # MONTH1 -> column C
    ws_merge.cell(row=r, column=3).value = lookup_sh1.get(id_val)
    # MONTH2 -> column D
    ws_merge.cell(row=r, column=4).value = lookup_rp1.get(id_val)

# Save the updated workbook
wb.save(output_path)

# Recalculate formulas (if any) – required by the workflow
await recalculate(output_path)

# Verify the written values by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["merging"]
print("Verification (ID -> MONTH1, MONTH2):")
for r in range(2, ws_check.max_row + 1):
    id_val = ws_check.cell(row=r, column=2).value
    m1 = ws_check.cell(row=r, column=3).value
    m2 = ws_check.cell(row=r, column=4).value
    print(f"{id_val!r}: {m1}, {m2}")
```
