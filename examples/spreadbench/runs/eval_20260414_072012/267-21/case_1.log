ws_check = wb_check["merging"]
print("Verification of merging sheet (ID -> MONTH1, MONTH2):")
for r in range(2, ws_check.max_row + 1):
    id_val = ws_check.cell(r, 2).value
    m1 = ws_check.cell(r, 3).value
    m2 = ws_check.cell(r, 4).value
    print(f"{id_val!r}: {m1}, {m2}")
