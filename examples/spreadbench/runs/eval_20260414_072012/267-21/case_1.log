import openpyxl, os
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_267-21_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_267-21_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Build lookup dictionaries for SH1 and RP1
lookup_sh1 = {}
lookup_rp1 = {}

ws_sh1 = wb["SH1"]
ws_rp1 = wb["RP1"]
for r in range(2, ws_sh1.max_row + 1):
    id_val = ws_sh1.cell(r, 2).value
    qty = ws_sh1.cell(r, 3).value
    if id_val is not None:
        lookup_sh1[id_val] = qty

for r in range(2, ws_rp1.max_row + 1):
    id_val = ws_rp1.cell(r, 2).value
    qty = ws_rp1.cell(r, 3).value
    if id_val is not None:
        lookup_rp1[id_val] = qty

# Write into merging sheet
ws_merge = wb["merging"]
for r in range(2, ws_merge.max_row + 1):
    id_val = ws_merge.cell(r, 2).value
    # MONTH1 (column C)
    month1_val = lookup_sh1.get(id_val)
    ws_merge.cell(r, 3).value = month1_val
    # MONTH2 (column D)
    month2_val = lookup_rp1.get(id_val)
    ws_merge.cell(r, 4).value = month2_val

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
