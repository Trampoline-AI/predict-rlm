```repl
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula

# Load workbook (data_only=False to see formulas)
wb_path = "/sandbox/input/input_spreadsheet/1_55468_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume single sheet

# Scan for any cell containing INDEX/MATCH, handling both plain strings and ArrayFormula objects
found = []
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        val = cell.value
        if isinstance(val, str):
            txt = val
        elif isinstance(val, ArrayFormula):
            txt = val.text  # the actual formula string
        else:
            continue
        if "INDEX" in txt.upper() or "MATCH" in txt.upper():
            found.append((cell.coordinate, txt))

print(f"Found {len(found)} cells with INDEX/MATCH formulas.")
for coord, formula in found[:10]:
    print(f"{coord}: {formula}")

# If we found at least one, replace the first occurrence with a four‑criteria formula.
# The user’s example uses data range C5:Z10 and criteria cells:
#   vertical1 (rows)   -> AE4 matched against A5:A10
#   vertical2 (rows)   -> AD4 matched against B5:B10
#   horizontal1 (cols) -> AC4 matched against C4:Z4
#   horizontal2 (cols) -> AB4 matched against D4:AA4 (adjusted to same width as data)
# We'll build a formula that works in LibreOffice:
#   =INDEX(C5:Z10, MATCH(1, (A5:A10=AE4)*(B5:B10=AD4)*(C4:Z4=AC4)*(D4:AA4=AB4), 0))
# Note: D4:AA4 is the same width as C4:Z4 shifted one column right; adjust if needed.
if found:
    target_coord, old_formula = found[0]
    new_formula = "=INDEX(C5:Z10, MATCH(1, (A5:A10=AE4)*(B5:B10=AD4)*(C4:Z4=AC4)*(D4:AA4=AB4), 0))"
    ws[target_coord].value = new_formula
    print(f"Replaced formula in {target_coord} with new formula.")
else:
    print("No INDEX/MATCH formulas detected; nothing to replace.")

# Save to output directory
output_path = "/sandbox/output/output_spreadsheet/1_55468_init.xlsx"
wb.save(output_path)
print("Workbook saved to:", output_path)
