import openpyxl
from openpyxl.utils import get_column_letter

wb_path = "/sandbox/input/input_spreadsheet/1_55468_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume single sheet

# Find cells with INDEX or MATCH in their formula
matches = []
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        if isinstance(cell.value, str) and ("INDEX" in cell.value.upper() or "MATCH" in cell.value.upper()):
            matches.append((cell.coordinate, cell.value))

print(f"Found {len(matches)} cells with INDEX/MATCH formulas:")
for coord, formula in matches[:20]:
    print(f"{coord}: {formula}")

# If there are any, we will replace the first one with a new formula that uses four criteria.
# The new formula pattern (LibreOffice compatible) will be:
# =INDEX(data_range, MATCH(1, (vertical1_range=vertical1_criteria)*(vertical2_range=vertical2_criteria)*(horizontal1_range=horizontal1_criteria)*(horizontal2_range=horizontal2_criteria), 0))
# We'll assume the user wants to keep the same data_range (C5:Z10) and the criteria cells are AD4, AE4, AB4, AC4 as in the example.
# We'll construct the formula accordingly and write it back to the same cell.
if matches:
    target_coord, old_formula = matches[0]
    # Build new formula
    new_formula = "=INDEX(C5:Z10, MATCH(1, (A5:A10=AE4)*(B5:B10=AD4)*(C4:Z4=AC4)*(D4:AA4=AB4), 0))"
    ws[target_coord].value = new_formula
    print(f"Replaced formula in {target_coord} with: {new_formula}")
else:
    print("No INDEX/MATCH formulas found.")

# Save to output directory
output_path = "/sandbox/output/output_spreadsheet/1_55468_init.xlsx"
wb.save(output_path)
print("Saved modified workbook to", output_path)
```
