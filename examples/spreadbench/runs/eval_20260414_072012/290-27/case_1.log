# Load workbook
wb = openpyxl.load_workbook(input_spreadsheet)
print('Sheets:', wb.sheetnames)

for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Sheet '{name}': rows={max_row}, cols={max_col}")
    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print('Headers:', headers)
    # Sample first 5 data rows (excluding header)
    print('First 5 rows:')
