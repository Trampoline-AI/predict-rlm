ws_master = wb["master"]

# Helper to get fill color as hex string (ignoring alpha)
def get_fill_rgb(cell):
    fill = cell.fill
    if fill is None:
        return None
    # openpyxl stores color in fgColor.rgb (may include alpha)
    rgb = fill.fgColor.rgb
    if rgb is None:
