```repl
import openpyxl
from openpyxl.styles import PatternFill, Border, Side
from openpyxl.utils import get_column_letter
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_423-16_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_423-16_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheets
ws_test = wb["Test"]
ws_master = wb["master"]

# Helper to get fill color as 6‑digit hex string (uppercase)
def get_fill_hex(cell):
    # openpyxl may store color in start_color or fgColor
    color = None
    if hasattr(cell.fill, "start_color") and cell.fill.start_color and cell.fill.start_color.rgb:
        color = cell.fill.start_color.rgb
    elif hasattr(cell.fill, "fgColor") and cell.fill.fgColor and cell.fill.fgColor.rgb:
        color = cell.fill.fgColor.rgb
    if not color:
        return None
    # color may be a string like "FFFF00" or "FF000000" (includes alpha)
    if isinstance(color, str):
        # Take last 6 characters (ignore possible alpha)
        return color[-6:].upper()
    # Fallback: try to get .rgb attribute if it's a Color object
    try:
        return color.rgb[-6:].upper()
    except Exception:
        return None

# Collect values from Test!A that are yellow (FFFF00) and non‑blank
yellow_vals = []
for r in range(1, ws_test.max_row + 1):
    cell = ws_test.cell(row=r, column=1)  # column A
    hex_color = get_fill_hex(cell)
    if hex_color == "FFFF00" and cell.value not in (None, "", " "):
        yellow_vals.append(cell.value)

# Prepare styling for the output cells
fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
thin_side = Side(border_style="thin", color="000000")
border = Border(left=thin_side, right=thin_side, top=thin_side, bottom=thin_side)

# Write transposed values into master row 1 (starting at column A)
for idx, val in enumerate(yellow_vals, start=1):
    col_letter = get_column_letter(idx)
    target = ws_master[f"{col_letter}1"]
    target.value = val
    target.fill = fill
    target.border = border

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(str(output_path))

# Verify by reloading with data_only=True and printing first few cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["master"]
print("Master row 1 after transposition (first 15 cells):")
for c in range(1, min(16, ws_check.max_column + 1)):
    cell = ws_check.cell(row=1, column=c)
    print(f"{get_column_letter(c)}1: {cell.value}")
```
