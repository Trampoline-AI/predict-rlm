import openpyxl
import os
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_156-14_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_156-14_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)

target_sheets = ["99250", "99251", "99252"]
for name in target_sheets:
    if name not in wb.sheetnames:
        continue
    ws = wb[name]
    # Delete rows from bottom to row 6 where column F == "to be processed"
    for row in range(ws.max_row, 5, -1):  # start at max_row, stop at 6 (inclusive)
        cell_val = ws.cell(row=row, column=6).value
        if isinstance(cell_val, str) and cell_val.strip() == "to be processed":
            ws.delete_rows(row, 1)

# Save modified workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(str(output_path))

# Reload to ensure sheet names unchanged after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
# If any sheet got renamed (unlikely), rename back
for name in wb_check.sheetnames:
    if name not in target_sheets and name in wb.sheetnames:
        ws = wb_check[name]
        ws.title = name  # restore original name
wb_check.save(output_path)
