import openpyxl
from openpyxl.utils import get_column_letter
from pathlib import Path

# Paths
input_path = Path('/sandbox/input/input_spreadsheet/1_41978_init.xlsx')
output_dir = Path('/sandbox/output/output_spreadsheet/')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / '1_41978_init.xlsx'

# Load workbook (preserve formatting)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Define range limits based on instruction (G14:G185 and J14:J185)
start_row = 14
end_row = 185
year_col = 7   # G
status_col = 10  # J
output_col = 9   # I

# Formula template (relative year cell, absolute ranges)
formula_template = "=COUNTIFS($G$14:$G$185, G{row}, $J$14:$J$185, \"Open\")"

# Write formula to each cell in column I, preserving existing style
for r in range(start_row, end_row + 1):
    cell = ws.cell(row=r, column=output_col)
    # Preserve style if cell already has one
    existing_style = cell._style
    cell.value = formula_template.format(row=r)
    # Reapply style (openpyxl stores style objects; assigning back works)
    cell._style = existing_style

# Save to output location
