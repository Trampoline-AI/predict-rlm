Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_547-18_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_547-18_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)

# Access sheets (case-sensitive as listed)
ws_import = wb["imported Data"]
ws_summary = wb["summary Limits"]

# Determine the maximum column in the import sheet (overall)
overall_max_col = ws_import.max_column

# Prepare to write into summary sheet starting at row 2
summary_row = 2

for r in range(2, ws_import.max_row + 1):
    cell_a = ws_import.cell(row=r, column=1).value
    if isinstance(cell_a, str) and cell_a.startswith("**"):
        # Find last non-empty column in this row
        last_col = 0
        for c in range(1, overall_max_col + 1):
            if ws_import.cell(row=r, column=c).value is not None:
                last_col = c
        if last_col == 0:
            continue  # skip empty rows
        
        # Copy values from column 1 to last_col
        for c in range(1, last_col + 1):
            src_val = ws_import.cell(row=r, column=c).value
            ws_summary.cell(row=summary_row, column=c).value = src_val
        
        summary_row += 1

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to verify copied rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["summary Limits"]
print("Copied rows in 'summary Limits':")
for r in range(2, ws_check.max_row + 1):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, overall_max_col + 1)]
    print(r, row_vals)
```
