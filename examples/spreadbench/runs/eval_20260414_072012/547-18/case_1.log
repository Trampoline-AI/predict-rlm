```repl
import openpyxl, json
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook('/sandbox/input/input_spreadsheet/1_547-18_init.xlsx')

# List sheets
print('Sheets:', wb.sheetnames)

# Function to print sheet info

def sheet_info(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"Sheet '{ws.title}': rows={max_row}, cols={max_col}")
    print('Headers:', headers)
    # Print first 5 data rows
    print('First 5 rows:')
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last 5 rows
    print('Last 5 rows:')
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    sheet_info(ws)
