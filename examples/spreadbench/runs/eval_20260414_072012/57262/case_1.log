    g_cell = ws.cell(row=row, column=column_index_from_string('G')).coordinate
    t_cell = ws.cell(row=row, column=column_index_from_string('T')).coordinate
    formula = f"=IF(NOT(ISBLANK({f_cell})),{f_cell}*8,0)+IF(NOT(ISBLANK({g_cell})),{g_cell}*10,0)"
    ws[t_cell].value = formula

# Save workbook
wb.save(output_path)

