import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_31202_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_31202_init.xlsx")

# Load workbook (keep formulas for other cells)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming the payroll table is the active sheet

# Identify header row (assume first row)
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
# Find column indices (1‑based)
col_idx = {str(h).strip().upper(): i+1 for i,h in enumerate(headers) if h}
worker_col = col_idx.get('WORKER')
deductions_col = col_idx.get('DEDUCTIONS')
additions_col = col_idx.get('ADDITIONS')
dbt_col = col_idx.get('DEBT')
print(f"Columns: WORKER={worker_col}, DEDUCTIONS={deductions_col}, ADDITIONS={additions_col}, DEBT={debt_col}")

# Compute cumulative debt per worker
running_debt = {}
for row in range(2, ws.max_row+1):
    worker = ws.cell(row=row, column=worker_col).value
    if worker is None:
        continue
    # Ensure numeric values; treat None as 0
    deductions = ws.cell(row=row, column=deductions_col).value or 0
    additions = ws.cell(row=row, column=additions_col).value or 0
    # Convert to float if possible
    try:
        deductions = float(deductions)
    except Exception:
        deductions = 0.0
    try:
        additions = float(additions)
    except Exception:
        additions = 0.0
    prev = running_debt.get(worker, 0.0)
    new_debt = prev + additions - deductions
    # Write the new debt value (static number)
    ws.cell(row=row, column=debt_col).value = new_debt
    running_debt[worker] = new_debt

# Save to output path
wb.save(output_path)

# Recalculate formulas using the provided tool
await recalculate(output_path)

# Reload with data_only to verify DEBT values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active
print("Sample DEBT values after recalculation:")
for r in range(2, min(8, ws2.max_row+1)):
    print(r, ws2.cell(row=r, column=debt_col).value)
```
