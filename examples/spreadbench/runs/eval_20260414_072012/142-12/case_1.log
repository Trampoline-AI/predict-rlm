Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Column indices
col_f = column_index_from_string('F')
col_j = column_index_from_string('J')

# Iterate rows (assuming header is row 1)
for row in range(2, ws.max_row + 1):
    cell_f = ws.cell(row=row, column=col_f)
    cell_j = ws.cell(row=row, column=col_j)
    val_f = cell_f.value
    val_j = cell_j.value
    # Check conditions
    if isinstance(val_f, str) and val_f == "Marble Slab Creamery":
        if isinstance(val_j, (int, float)):
            if val_j == int(val_j):  # whole number (no cents)
                cell_f.value = "Georgia State WH"

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload with data_only to verify changes
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Verify rows 10 and 13
for r in [10, 13]:
    print(f"Row {r} - F: {ws2.cell(row=r, column=col_f).value}, J: {ws2.cell(row=r, column=col_j).value}")
```
