Code:
```repl
import openpyxl
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_560-12_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_560-12_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Count items in column B (index 2)
item_counts = {}
for row in range(2, ws.max_row + 1):
    item = ws.cell(row=row, column=2).value
    if item is None:
        continue
    item_counts[item] = item_counts.get(item, 0) + 1

# Desired order
order = ["A006", "A004", "A005"]

# Write headers at I3 (column 9) and J3 (column 10)
ws.cell(row=3, column=9, value="ITEM")
ws.cell(row=3, column=10, value="Qty")

# Write data
start_row = 4
for i, code in enumerate(order):
    cnt = item_counts.get(code, 0)
    ws.cell(row=start_row + i, column=9, value=code)
    ws.cell(row=start_row + i, column=10, value=cnt)

# Left align the output range (I3:J6)
align_left = Alignment(horizontal="left")
for r in range(3, start_row + len(order)):
    ws.cell(row=r, column=9).alignment = align_left
    ws.cell(row=r, column=10).alignment = align_left

# Save to output directory
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to verify written values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification:")
for r in range(3, start_row + len(order)):
    print(r, ws_check.cell(r, 9).value, ws_check.cell(r, 10).value)
```
