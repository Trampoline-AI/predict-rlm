import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_18935_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_18935_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Define data table range (rows 5‑12, columns A‑E)
data_start = 5
data_end = 12
data_row_range = f"${get_column_letter(1)}${data_start}:${get_column_letter(1)}${data_end}"
# Actually we need column ranges for Work (A) and Material (B) and categories (C‑E)
work_range = f"$A${data_start}:$A${data_end}"
material_range = f"$B${data_start}:$B${data_end}"
category_range = f"$C${data_start}:$E${data_end}"

# Write formula into report rows (starting at row 17) column D (4)
for r in range(17, ws.max_row + 1):
    target_cell = ws.cell(row=r, column=4)  # Column D = Category Value
    # Skip if already has a value
    if target_cell.value is not None:
        continue
    # Build formula string (LibreOffice syntax)
    # Note: LibreOffice supports array multiplication inside MATCH
    formula = (
        f"=INDEX({category_range},"
        f"MATCH(1,({work_range}=A{r})*({material_range}=C{r}),0),"
        f"MATCH(B{r},{{\"Category 1\",\"Category 2\",\"Category 3\"}},0))"
    )
    target_cell.value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify that the Category Value column now has values for report rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of Category Value (column D) for report rows:")
for r in range(17, ws_check.max_row + 1):
    val = ws_check.cell(row=r, column=4).value
    print(f"Row {r}: {val}")

# Submit the output file path
SUBMIT(output_spreadsheet=output_path)
