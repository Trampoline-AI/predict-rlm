Code:
```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_37378_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_37378_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine last row
last_row = ws.max_row

# Write formula in column A (column 1) from row 2 to last_row
for r in range(2, last_row + 1):
    # Formula counts non‑empty cells in column B up to this row
    formula = f"=IF(B{r}<>\"\", COUNTA($B$2:B{r}), \"\")"
    ws.cell(row=r, column=1, value=formula)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice) and reload to verify
await recalculate(output_path)
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Print a few results for verification
print("Verification of column A after recalculation:")
for r in range(2, min(last_row, 10) + 1):
    print(f"A{r} =", ws2.cell(row=r, column=1).value)
```
