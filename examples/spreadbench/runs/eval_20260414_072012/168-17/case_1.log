```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_168-17_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_168-17_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = load_workbook(filename=input_path, keep_vba=False)  # no VBA needed
# Identify the target sheet
sheet_name = "Statement"
if sheet_name not in wb.sheetnames:
    raise ValueError(f"Sheet '{sheet_name}' not found in workbook. Available: {wb.sheetnames}")

ws = wb[sheet_name]

# Find first occurrence of "Invoice No." in column A
target_text = "Invoice No."
first_row = None
for row in range(1, ws.max_row + 1):
    cell_val = ws.cell(row=row, column=1).value
    if isinstance(cell_val, str) and cell_val == target_text:
        first_row = row
        break

if first_row is None:
    raise ValueError(f"'{target_text}' not found in column A of sheet '{sheet_name}'.")

# Delete rows before the first occurrence, if any
if first_row > 1:
    ws.delete_rows(idx=1, amount=first_row - 1)
    print(f"Deleted rows 1 to {first_row - 1}.")
else:
    print("Target already at row 1; no rows deleted.")

# Save the modified workbook
wb.save(output_path)
print(f"Workbook saved to {output_path}")

# Recalculate formulas
from recalculate import recalculate  # provided async function
import asyncio

async def recalc_and_verify():
    # Recalculate
    result = await recalculate(output_path)
    print("Recalculate result:", result)

    # Reload with data_only to read cached values
    wb_check = load_workbook(output_path, data_only=True)
    ws_check = wb_check[sheet_name]
    a1_val = ws_check["A1"].value
    print(f"After recalculation, A1 = {a1_val!r}")
    if a1_val == target_text:
        print("Verification successful: A1 contains the target text.")
    else:
        print("Verification failed: A1 does not contain the target text.")

# Run the async verification
asyncio.run(recalc_and_verify())
