Reasoning: We have four source sheets (CMSN, CSTR, EXPRO) that contain rows with an ACCOUNT REF like "PUR PURCHASE INV 000011" and a numeric amount in the CREDIT column. The OUT CAS sheet already has four groups of columns:

- Group 1 (PUR PURCHASE): ITEM in column A, AMOUNT in column C  
- Group 2 (PUR PAID):    ITEM in column E, AMOUNT in column G  
- Group 3 (CASH SS):    ITEM in column I, AMOUNT in column K  
- Group 4 (EXPRR):      ITEM in column M, AMOUNT in column O  

The task is to aggregate (sum) the amounts for each item number within each group and write the results into the corresponding columns of the OUT CAS sheet, ordered by the numeric item number (e.g., 000011 before 000012). We will:

1. Load the workbook.
2. Scan the three source sheets, extract the numeric item code and amount, and accumulate sums per group.
3. For each group, sort the items by the numeric code.
4. Clear any existing data rows in OUT CAS (rows 2‑end) for the four groups.
5. Write the aggregated ITEM text and summed AMOUNT into the appropriate columns.
6. Save the workbook to the output directory, recalculate formulas, and verify a few target cells.

The code below implements these steps.
Code:
```python
```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import re
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_41-47_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_41-47_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify OUT CAS sheet
out_sheet_name = next((s for s in wb.sheetnames if "OUT" in s.upper() and "CAS" in s.upper()), None)
if not out_sheet_name:
    raise ValueError("OUT CAS sheet not found")
out_ws = wb[out_sheet_name]

# Define groups: (prefix, item_col, amount_col)
groups = {
    "PUR PURCHASE": ("PUR PURCHASE", "A", "C"),
    "PUR PAID":    ("PUR PAID",    "E", "G"),
    "CASH SS":    ("CASH SS",    "I", "K"),
    "EXPRR":      ("EXPRR",      "M", "O"),
}

# Containers for aggregated data
agg = {key: {} for key in groups}  # {group: {item_num: (desc, total)}}

# Helper to extract numeric item code (last numeric part)
def extract_item_num(ref):
    # Find the last sequence of digits in the string
    m = re.search(r"(\d{3,})\D*$", ref or "")
    return int(m.group(1)) if m else None

# Process each source sheet
source_sheets = [s for s in wb.sheetnames if s != out_sheet_name]
for sheet_name in source_sheets:
    ws = wb[sheet_name]
    # Assume columns: A=DATE, B=ACCOUNT REF, C=DEBIT, D=CREDIT (based on inspection)
    for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=2, max_col=4, values_only=True):
        acct_ref, debit, credit = row
        if not acct_ref:
            continue
        # Determine bucket by prefix
        bucket = None
        for grp_key, (prefix, _, _) in groups.items():
            if acct_ref.startswith(prefix):
                bucket = grp_key
                break
        if not bucket:
            continue  # ignore unknown rows
        # Amount is in CREDIT column (4th column), may be None
        amount = credit if credit is not None else 0
        # Extract numeric item code
        item_num = extract_item_num(acct_ref)
        if item_num is None:
            continue
        # Aggregate
        grp_dict = agg[bucket]
        if item_num in grp_dict:
            _, cur_total = grp_dict[item_num]
            grp_dict[item_num] = (acct_ref, cur_total + amount)
        else:
            grp_dict[item_num] = (acct_ref, amount)

# Function to clear existing data rows for a given column range
def clear_column_range(ws, start_row, col_letter, end_row):
    col_idx = column_index_from_string(col_letter)
    for r in range(start_row, end_row + 1):
        ws.cell(row=r, column=col_idx).value = None

# Determine max rows needed per group
max_rows = max(len(d) for d in agg.values())  # rows of data per group
data_start = 2  # row after header

# Clear existing data rows for all groups
for _, (_, item_col, amount_col) in groups.items():
    clear_column_range(out_ws, data_start, item_col, out_ws.max_row)
    clear_column_range(out_ws, data_start, amount_col, out_ws.max_row)

# Write aggregated data
for grp_key, (prefix, item_col, amount_col) in groups.items():
    grp_data = agg[grp_key]
    # Sort by numeric item code
    sorted_items = sorted(grp_data.items(), key=lambda kv: kv[0])
    for idx, (item_num, (desc, total)) in enumerate(sorted_items, start=0):
        row = data_start + idx
        out_ws[f"{item_col}{row}"] = desc
        out_ws[f"{amount_col}{row}"] = total

# Write total formulas (optional – keep existing total row)
# The original sheet has a total row at the bottom; we leave it unchanged.

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify a few cells (first row of each group)
print("Verification samples:")
for grp_key, (_, item_col, amount_col) in groups.items():
    print(f"{grp_key} -> {item_col}2: {out_ws[f'{item_col}2'].value}, {amount_col}2: {out_ws[f'{amount_col}2'].value}")

# Reload with data_only to confirm formulas evaluated
wb_check = openpyxl.load_workbook(output_path, data_only=True)
out_check = wb_check[out_sheet_name]
print("Post‑recalc sample (row 2):")
for grp_key, (_, item_col, amount_col) in groups.items():
    print(f"{grp_key}: ITEM={out_check[f'{item_col}2'].value}, AMOUNT={out_check[f'{amount_col}2'].value}")
