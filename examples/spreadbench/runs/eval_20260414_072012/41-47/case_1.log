```repl
import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = '/sandbox/input/input_spreadsheet/1_41-47_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
sheet_names = wb.sheetnames
print('Sheet names:', sheet_names)

# Function to print sheet summary
def sheet_summary(ws, max_rows=5):
    # header row assumed first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print('Headers:', headers)
    total_rows = ws.max_row
    print('Total rows (including header):', total_rows)
    # first data rows
    print('First data rows:')
    for r in range(2, min(2+max_rows, total_rows+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)
    # last data rows
    print('Last data rows:')
    start = max(2, total_rows - max_rows + 1)
    for r in range(start, total_rows+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)

# Inspect OUT CAS sheet (assuming name contains 'OUT CAS')
out_cas_name = next((s for s in sheet_names if 'OUT' in s.upper() and 'CAS' in s.upper()), None)
if out_cas_name:
    ws_out = wb[out_cas_name]
    print('\n--- OUT CAS sheet summary ---')
    sheet_summary(ws_out)
else:
    print('OUT CAS sheet not found')

# Inspect other sheets
for name in sheet_names:
    if name != out_cas_name:
        ws = wb[name]
        print(f'\n--- Sheet {name} summary ---')
        sheet_summary(ws)
