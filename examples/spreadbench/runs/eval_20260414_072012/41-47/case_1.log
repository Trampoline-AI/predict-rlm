import openpyxl
from openpyxl.utils import column_index_from_string
import re
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_41-47_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_41-47_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify OUT CAS sheet
out_sheet_name = next((s for s in wb.sheetnames if "OUT" in s.upper() and "CAS" in s.upper()), None)
if not out_sheet_name:
    raise ValueError("OUT CAS sheet not found")
out_ws = wb[out_sheet_name]

# Define groups: (prefix, item column, amount column)
groups = {
    "PUR PURCHASE": ("PUR PURCHASE", "A", "C"),
    "PUR PAID":    ("PUR PAID",    "E", "G"),
    "CASH SS":    ("CASH SS",    "I", "K"),
    "EXPRR":      ("EXPRR",      "M", "O"),
}

# Containers for aggregated data per group
agg = {g: {} for g in groups}  # {group: {item_num: (desc, total)}}

# Helper to extract the numeric item code (last sequence of digits)
def extract_item_num(ref):
    m = re.search(r"(\d{3,})\D*$", ref or "")
    return int(m.group(1)) if m else None

# Process each source sheet (all except OUT CAS)
for sheet_name in wb.sheetnames:
    if sheet_name == out_sheet_name:
        continue
    ws = wb[sheet_name]
    # Assume columns: A=DATE, B=ACCOUNT REF, C=DEBIT, D=CREDIT
    for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=2, max_col=4, values_only=True):
        acct_ref, debit, credit = row
        if not acct_ref:
            continue
        # Determine which group the row belongs to by prefix
        bucket = None
        for grp_key, (prefix, _, _) in groups.items():
            if acct_ref.startswith(prefix):
                bucket = grp_key
                break
        if not bucket:
            continue  # ignore rows that don't match any known prefix
        amount = credit if credit is not None else 0
        item_num = extract_item_num(acct_ref)
        if item_num is None:
            continue
        # Aggregate
        grp_dict = agg[bucket]
        if item_num in grp_dict:
            _, cur_total = grp_dict[item_num]
            grp_dict[item_num] = (acct_ref, cur_total + amount)
        else:
            grp_dict[item_num] = (acct_ref, amount)

# Function to clear a column range (from start_row to end_row)
def clear_column(ws, col_letter, start_row, end_row):
    col_idx = column_index_from_string(col_letter)
    for r in range(start_row, end_row + 1):
        ws.cell(row=r, column=col_idx).value = None

# Determine how many rows we need (max of any group)
max_rows_needed = max(len(d) for d in agg.values())
data_start = 2  # first data row after header
data_end = data_start + max_rows_needed - 1

# Clear existing data for all groups
for _, (_, item_col, amount_col) in groups.items():
    clear_column(out_ws, item_col, data_start, out_ws.max_row)
    clear_column(out_ws, amount_col, data_start, out_ws.max_row)

# Write aggregated,, sorted by numeric item code
for grp_key, (prefix, item_col, amount_col) in groups.items():
    grp_data = agg[grp_key]
    sorted_items = sorted(grp_data.items(), key=lambda kv: kv[0])  # sort by numeric code
    for idx, (item_num, (desc, total)) in enumerate(sorted_items):
        row = data_start + idx
        out_ws[f"{item_col}{row}"] = desc
        out_ws[f"{amount_col}{row}"] = total

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(output_path)

# Verify a few sample cells (first row of each group)
print("Verification samples after write:")
for grp_key, (_, item_col, amount_col) in groups.items():
    print(f"{grp_key}: {item_col}2 = {out_ws[f'{item_col}2'].value}, {amount_col}2 = {out_ws[f'{amount_col}2'].value}")

# Reload with data_only to confirm formulas evaluated (if any)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
out_check = wb_check[out_sheet_name]
print("Post‑recalc sample (data_only):")
for grp_key, (_, item_col, amount_col) in groups.items():
    print(f"{grp_key}: ITEM={out_check[f'{item_col}2'].value}, AMOUNT={out_check[f'{amount_col}2'].value}")
