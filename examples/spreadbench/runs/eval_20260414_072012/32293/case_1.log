import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_32293_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_32293_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming the target sheet is the active one

# Write formulas into B14‑B17
for row in range(14, 18):
    formula = f'=IF(A{row}="MNQ",B1,IF(A{row}="MES",B2,IF(A{row}="NQ",B3,IF(A{row}="ES",B4,""))))'
    ws[f'B{row}'].value = formula

# Save to output location
wb.save(output_path)

# Recalculate formulas using the provided tool
await recalculate(output_path)

# Reload with data_only to verify results
