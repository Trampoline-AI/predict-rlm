Code:
```repl
import openpyxl
from pathlib import Path
import statistics

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_55708_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_55708_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Collect turnaround times per department with the
dept_times = {}
for row in ws.iter_rows(min_row=2, max_row=9, min_col=1, max_col=3, values_only=True):
    dept, status, tt = row
    if dept is None or status is None or tt is None:
        continue
    if status in ("In Progress", "In Review") and tt >= 6:
        dept_times.setdefault(dept, []).append(tt)

# Compute averages (or None)
dept_avg = {}
for dept, times in dept_times.items():
    if times:
        dept_avg[dept] = sum(times) / len(times)
    else:
        dept_avg[dept] = None

# Departments expected in summary rows (A, B, C) based on rows 11‑13
summary_rows = {"A": 11, "B": 12, "C": 13}
for dept, row in summary_rows.items():
    avg = dept_avg.get(dept)
    cell = ws.cell(row=row, column=3)  # column C
    if avg is None:
        cell.value = None
    else:
        # Write numeric value (general formatting)
        cell.value = avg

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(str(output_path))

# Verify by reloading data_only
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of summary cells (C11‑C13):")
for dept, row in summary_rows.items():
    print(dept, ws_check.cell(row=row, column=3).value)
```
