Code:
```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
in_path = '/sandbox/input/input_spreadsheet/1_6698_init.xlsx'
out_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, '1_6698_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# 1. Add autofilter to header range A1:C1
ws.auto_filter.ref = "A1:C1"

# 2. Write new formula into G4:G8
for row in range(4, 9):
    # Build formula string for this row
    formula = (
        f"=SUM(COUNTIFS('raw 1'!A2:A100000,$F{row},'raw 1'!B2:B100000,\"<>0\"),"
        f"COUNTIFS('raw 1'!A2:A100000,$F{row},'raw 1'!C2:C100000,\"<>0\"))"
    )
    ws.cell(row=row, column=7).value = formula  # column G is 7

# Save workbook
wb.save(out_path)
print("Workbook saved to", out_path)

# Recalculate formulas (LibreOffice)
from recalculate import recalculate  # assume this tool is available
await recalculate(out_path)

# Reload with data_only to verify results
wb2 = openpyxl.load_workbook(out_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("Verification of G4:G8 after recalculation:")
for row in range(4, 9):
    val = ws2.cell(row=row, column=7).value
    print(f"G{row} = {val}")
```
