import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_165-23_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_165-23_init.xlsx")

# Load workbook (preserve formulas, formatting)
wb = openpyxl.load_workbook(input_path, data_only=False)
# Identify the primary sheet (first sheet)
ws = wb[wb.sheetnames[0]]

# Delete rows where column C (3) is not "#N/A"
# Iterate backwards to avoid index shift
for row in range(ws.max_row, 1, -1):  # start from max_row down to 2 (skip header row 1)
    cell_val = ws.cell(row=row, column=3).value
    if cell_val != "#N/A":
        ws.delete_rows(row, 1)

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Verify: reload with data_only=True and print remaining rows count and a few C values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("After deletion - max row:", ws_check.max_row)
print("Remaining column C values (rows 2-10):")
for r in range(2, min(ws_check.max_row, 12)+1):
