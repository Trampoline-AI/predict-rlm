import os
import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_3413_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_3413_init.xlsx')

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Formula to place in G3:G6
formula_template = '=IF(COUNTIFS($A$3:$A$6,$E{row},$B$3:$B$6,$F{row})>0,' \
                   'SUMIFS($C$3:$C$6,$A$3:$A$6,$E{row},$B$3:$B$6,$F{row}),' \
                   'SUMIF($A$3:$A$6,$E{row},$C$3:$C$6))'

# Apply formula to rows 3 through 6 in column G
for r in range(3, 7):
    ws[f'G{r}'] = formula_template.format(row=r)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only to read computed values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

print('Verified G3:G6 values after recalculation:')
for r in range(3, 7):
    print(f'G{r}:', ws2[f'G{r}'].value)

# Submit the output file
SUBMIT(output_spreadsheet=output_path)
