for row in range(2, ws_two.max_row + 1):
    sid_raw = ws_two.cell(row=row, column=7).value
    lead = ws_two.cell(row=row, column=3).value
    if sid_raw is None:
        continue
    # Normalize: keep only digits (strip any non‑digit characters)
    sid = ''.join(ch for ch in str(sid_raw) if ch.isdigit())
    lookup_dict[sid] = lead

