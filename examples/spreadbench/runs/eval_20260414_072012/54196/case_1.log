    sid = ''.join(ch for ch in str(sid_raw) if ch.isdigit())
    ws_one.cell(row=row, column=8).value = lookup_dict.get(sid)

# Save and recalc
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)
await recalculate(output_path)

# Verify a few rows after writing
print("\nVerification after write (row, Supplier ID, Lead Time):")
