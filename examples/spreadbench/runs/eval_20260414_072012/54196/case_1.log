wb = openpyxl.load_workbook(input_path, data_only=False)
ws_one = wb["Sheet one"]
ws_two = wb["Sheet two"]

def show_info(sheet, col, rows):
    for r in rows:
        val = sheet.cell(row=r, column=col).value
        if isinstance(val, str):
            codepoints = [hex(ord(ch)) for ch in val]
        else:
            codepoints = None
        print(f"Row {r}: repr={repr(val)} len={len(val) if isinstance(val,str) else 'N/A'} codepoints={codepoints}")

print("=== Sheet one, column F (Supplier) ===")
