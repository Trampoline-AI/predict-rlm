```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

input_path = "/sandbox/input/input_spreadsheet/1_54196_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_54196_init.xlsx")

# Load workbook (keep formulas for other cells)
wb = openpyxl.load_workbook(input_path, data_only=False)

# ---------- Build lookup dict (Sheet two) ----------
lookup_ws = wb["Sheet two"]
lookup_dict = {}
for row in range(2, lookup_ws.max_row + 1):
    # Supplier ID is column G (7)
    supplier_id_raw = lookup_ws.cell(row=row, column=7).value
    # Estimated Delivery time is column C (3)
    lead_time = lookup_ws.cell(row=row, column=3).value
    if supplier_id_raw is None:
        continue
    # Normalize key to string without surrounding whitespace
    supplier_id = str(supplier_id_raw).strip()
    lookup_dict[supplier_id] = lead_time

# ---------- Populate Sheet one column H ----------
ws = wb["Sheet one"]
for row in range(2, ws.max_row + 1):
    # Supplier ID is column F (6) in Sheet one
    supplier_id_raw = ws.cell(row=row, column=6).value
    if supplier_id_raw is None:
        ws.cell(row=row, column=8).value = None
        continue
    supplier_id = str(supplier_id_raw).strip()
    lead_time = lookup_dict.get(supplier_id)
    ws.cell(row=row, column=8).value = lead_time  # column H

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify a few rows after recalculation
print("Verification after fix (row, Supplier ID, Lead Time):")
for r in [2, 3, 4, 5, 100]:
    sid = ws.cell(row=r, column=6).value
    lt = ws.cell(row=r, column=8).value
    print(r, sid, lt)
