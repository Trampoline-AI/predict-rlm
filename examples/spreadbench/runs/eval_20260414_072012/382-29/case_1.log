import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = '/sandbox/input/input_spreadsheet/1_382-29_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# Gather sheet info
sheet_info = []
for ws in wb.worksheets:
    # Assume first row is header if exists
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    # Sample first 5 and last 5 rows of data (excluding header)
    sample_start = []
    for r in range(2, min(2+5, max_row+1)):
        sample_start.append([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    sample_end = []
    for r in range(max_row-4, max_row+1):
        if r >= 2:
            sample_end.append([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    sheet_info.append({
        'title': ws.title,
        'max_row': max_row,
        'max_col': max_col,
        'headers': headers,
        'sample_start': sample_start,
        'sample_end': sample_end,
    })

print(json.dumps(sheet_info, indent=2, default=str))
```
