import openpyxl
from openpyxl.utils import get_column_letter

# Load input workbook
in_path = "/sandbox/input/input_spreadsheet/1_42198_init.xlsx"
wb = openpyxl.load_workbook(in_path)
ws = wb[wb.sheetnames[0]]

# Write cumulative COUNTIFS formula in column C rows 2‑7
for row in range(2, 8):
    # Build range strings that expand to current row
    a_range = f"$A$2:$A{row}"
    b_range = f"$B$2:$B{row}"
    formula = (
        f"=IF(COUNTIFS({a_range},\"Potato\",{b_range},FALSE)>0,\"Worst\",
        f        "IF(COUNTIFS({a_range},\"Tomato\",{b_range},FALSE)>0,\"Ignore\",\"\"))"
    )
    ws.cell(row=row, column=3).value = formula

# Save to output directory
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_42198_init.xlsx"
wb.save(out_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(out_path)

# Reload with data_only to verify
