import openpyxl, json, os

# Load workbook
wb_path = '/sandbox/input/input_spreadsheet/initial.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print('Sheets:', wb.sheetnames)

# Function to print header and sample rows
def print_sheet_info(sheet_name, max_rows=5):
    ws = wb[sheet_name]
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f"\nSheet '{sheet_name}' header:", headers)
    total_rows = ws.max_row
    print(f"Total rows (including header): {total_rows}")
    # Print first few data rows
    print('First data rows:')
    for r in range(2, min(2+max_rows, total_rows+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)
    # Print last few data rows
    print('Last data rows:')
    start = max(2, total_rows - max_rows + 1)
    for r in range(start, total_rows+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)

# Inspect both sheets
print_sheet_info('Streets')
print_sheet_info('Base')
