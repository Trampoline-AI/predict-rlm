import openpyxl, os, shutil
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/initial.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "initial.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws_base = wb["Base"]
ws_streets = wb["Streets"]

# Determine last data row in Base (exclude header)
last_row = ws_base.max_row

# Build formula template using relative row reference
# We'll use ROW() to make it generic, but openpyxl cannot evaluate ROW()
# So we construct the formula with explicit row numbers per row.
for r in range(2, last_row + 1):
    # Cell references for this row
    col_c = f"C{r}"   # street name in Base
    col_d = f"D{r}"   # number in Base
    # Formula string
    formula = (
        f'=IFERROR('
        f'IF('
        f'AND('
        f'{col_d}>=INDEX(Streets!C:C,MATCH({col_c},Streets!B:B,0)),'
        f'{col_d}<=INDEX(Streets!D:D,MATCH({col_c},Streets!B:B,0))'
        f'),'
        f'INDEX(Streets!F:F,MATCH({col_c},Streets!B:B,0)),'
        f'""'
        f'),'
        f'""'
        f')'
    )
    ws_base.cell(row=r, column=5).value = formula  # column E is index 5

# Save to output location
wb.save(output_path)

# Recalculate formulas
recalc_result = await recalculate(str(output_path))
print("Recalculate:", recalc_result)

# Reload with data_only to verify a few target cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Base"]
print("Sample results (first 5 rows of column E):")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(r, ws_check.cell(row=r, column=5).value)
