Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_42930_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_42930_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Identify columns (by header names) to be robust
header_row = 1
headers = {}
for col in range(1, ws.max_column + 1):
    val = ws.cell(row=header_row, column=col).value
    if isinstance(val, str):
        headers[val.strip()] = col

# Expected header names (based on preview)
year_col = headers.get('Year House Built')
subdiv_col = headers.get('Subdivision Name')
assign_col = headers.get("Number I'd like to assign to each")

if not (year_col and subdiv_col and assign_col):
    raise ValueError('Could not locate required columns')

# Gather earliest year per subdivision
earliest = {}
for row in range(2, ws.max_row + 1):
    year = ws.cell(row=row, column=year_col).value
    subdiv = ws.cell(row=row, column=subdiv_col).value
    if subdiv is None:
        continue
    if year is None:
        continue
    if subdiv not in earliest or year < earliest[subdiv]:
        earliest[subdiv] = year

# Sort subdivisions by earliest year and assign rank
sorted_subdivs = sorted(earliest.items(), key=lambda x: (x[1], x[0]))
rank_map = {subdiv: idx+1 for idx, (subdiv, _) in enumerate(sorted_subdivs)}

# Write rank to every row in the assignment column
for row in range(2, ws.max_row + 1):
    subdiv = ws.cell(row=row, column=subdiv_col).value
    if subdiv in rank_map:
        ws.cell(row=row, column=assign_col).value = rank_map[subdiv]
    else:
        ws.cell(row=row, column=assign_col).value = None

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) using provided tool
await recalculate(output_path)

# Reload to verify that column F is populated (data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
missing = []
for row in range(2, ws_check.max_row + 1):
    val = ws_check.cell(row=row, column=assign_col).value
    if val is None:
        missing.append(row)
print(f"Rows with missing assignment: {missing}")
```
