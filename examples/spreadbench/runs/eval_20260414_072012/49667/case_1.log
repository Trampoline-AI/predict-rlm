import openpyxl
from openpyxl.utils import get_column_letter
from pathlib import Path

input_path = "/sandbox/input/input_spreadsheet/1_49667_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = Path(output_dir) / "1_49667_init.xlsx"

# Load workbook (original) to modify
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row
# Header times are in row 1, columns F (6) to AT (46)
header_times = [ws.cell(row=1, column=c).value for c in range(6, 47)]

# Helper: find up to two contiguous blocks of 'm' in a list of cell values
def find_blocks(row_vals):
    blocks = []
    i = 0
    n = len(row_vals)
    while i < n:
        # skip non‑'m'
        while i < n and row_vals[i] != "m":
            i += 1
        if i >= n:
            break
        start = i
        # continue while 'm'
        while i < n and row_vals[i] == "m":
            i += 1
        end = i - 1
        blocks.append((start, end))
        if len(blocks) == 2:
            break
    return blocks

# Update formulas for columns B and C (first block) with IFERROR
for r in range(2, max_row + 1):
    ws[f"B{r}"] = f"=IFERROR(INDEX($F$1:$AT$1, MATCH(\"m\", $F{r}:$AT{r}, 0)), \"\")"
    ws[f"C{r}"] = f"=IFERROR(LOOKUP(2, 1/($F{r}:$AT{r}=\"m\"), $F$1:$AT$1), \"\")"

# Compute and write second‑block start/finish (columns D and E) as literal times
for r in range(2, max_row + 1):
    # Extract the row's marker values from columns F‑AT
    row_vals = [ws.cell(row=r, column=c).value for c in range(6, 47)]
    blocks = find_blocks(row_vals)
    if len(blocks) >= 2:
        # second block indices (0‑based relative to F‑AT)
        start_idx, end_idx = blocks[1]
        start_time = header_times[start_idx]
        end_time = header_times[end_idx]
        ws[f"D{r}"] = start_time
        ws[f"E{r}"] = end_time
    else:
        ws[f"D{r}"] = None
        ws[f"E{r}"] = None

# Save workbook
wb.save(output_path)

