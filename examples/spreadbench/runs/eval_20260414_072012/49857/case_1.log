# Load workbook for editing
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Identify column indices
col_f = column_index_from_string('F')
col_g = column_index_from_string('G')

# Determine the last row with data in column F (or max_row)
max_row = ws.max_row
# Optionally refine to the last non‑empty cell in column F
for r in range(max_row, 0, -1):
    if ws.cell(row=r, column=col_f).value is not None:
        max_row = r
        break

# Write formula into column G for each data row (starting at row 4)
for r in range(4, max_row + 1):
    f_cell = ws.cell(row=r, column=col_f)
    g_cell = ws.cell(row=r, column=col_g)
    # Only write if the cell is empty or contains a formula (avoid overwriting existing correct values)
    if g_cell.value is None or isinstance(g_cell.value, str) and g_cell.value.startswith('='):
