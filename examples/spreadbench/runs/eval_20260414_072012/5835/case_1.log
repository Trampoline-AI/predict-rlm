from pathlib import Path
import asyncio

input_path = Path("/sandbox/input/input_spreadsheet/1_5835_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_5835_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row

# Copy Log Value from column I (9) to column C (3)
for r in range(2, max_row + 1):
    src_val = ws.cell(row=r, column=9).value
    # Only write if source is not None (avoid overwriting with blanks)
    if src_val is not None:
        ws.cell(row=r, column=3).value = src_val

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(str(output_path))

