import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_55817_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_55817_init.xlsx")

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Read all values from column A, starting at row 2
col_a_vals = [ws.cell(row=r, column=1).value for r in range(2, ws.max_row + 1)]

# Define block size (7 rows per question)
block_size = 7
num_blocks = len(col_a_vals) // block_size

# Write transposed data starting at B2 (row 2, column 2)
start_row = 2
start_col = 2  # Column B

for i in range(num_blocks):
    block = col_a_vals[i*block_size:(i+1)*block_size]
    target_row = start_row + i
    for j, val in enumerate(block):
        ws.cell(row=target_row, column=start_col + j, value=val)

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and ensure sheet names unchanged
# This call returns a status string; we ignore it for now
await recalculate(output_path)

