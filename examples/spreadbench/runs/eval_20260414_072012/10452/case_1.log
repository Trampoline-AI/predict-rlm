import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
input_path = "/sandbox/input/input_spreadsheet/1_10452_init.xlsx"
wb = openpyxl.load_workbook(input_path, data_only=False)

# List sheet names and basic info
print("Sheets:", wb.sheetnames)
for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Sheet '{name}': rows={max_row}, cols={max_col}")

    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Print last 5 data rows
    if max_row > 2:
        print("Last 5 data rows:")
        start = max(2, max_row-4)
        for r in range(start, max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(r, row_vals)

    print("-"*40)
