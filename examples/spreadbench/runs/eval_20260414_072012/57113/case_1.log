Code:
```repl
import re, os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas for any other cells)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row

hashtag_pattern = re.compile(r'#(\w+)')

for row in range(2, max_row + 1):
    tweet_cell = ws.cell(row=row, column=1)  # Column A
    tweet = tweet_cell.value
    if not isinstance(tweet, str):
        continue
    hashtags = hashtag_pattern.findall(tweet)
    # Write each hashtag into columns B, C, D... (starting at column 2)
    for i, tag in enumerate(hashtags):
        target_col = 2 + i
        ws.cell(row=row, column=target_col, value=tag)
    # Clear any leftover cells in the row beyond the last hashtag (up to column 10 for safety)
    for col in range(2 + len(hashtags), 12):
        ws.cell(row=row, column=col, value=None)

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

print('Processing complete. Saved to', output_path)
```
