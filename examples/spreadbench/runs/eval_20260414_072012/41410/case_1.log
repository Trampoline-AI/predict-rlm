import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_41410_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = os.path.join(out_dir, "1_41410_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Ensure target headers (row 3)
ws["F3"] = "Item"
ws["G3"] = "kW rating"
ws["H3"] = "Number"

# Gather source rows B3:D22
source_rows = []
for r in range(3, 23):  # 3 to 22 inclusive
    item = ws.cell(row=r, column=2).value  # column B
    kw = ws.cell(row=r, column=3).value    # column C
    num = ws.cell(row=r, column=4).value   # column D
    source_rows.append((item, kw, num))

# Filter lighting rows
lighting_rows = [row for row in source_rows if row[0] == "Lighting"]

# Write lighting rows into target range F4:H6 (max 3 rows)
start_row = 4
for i, row in enumerate(lighting_rows[:3]):  # only up to 3 rows as target allows
    target_row = start_row + i
    ws.cell(row=target_row, column=6).value = row[0]   # Item
    ws.cell(row=target_row, column=7).value = row[1]   # kW rating
    ws.cell(row=target_row, column=8).value = row[2]   # Number

# Ensure output directory exists
os.makedirs(out_dir, exist_ok=True)

# Save workbook
wb.save(out_path)

# Recalculate formulas (if any)
await recalculate(out_path)

# Verify target range F3:H6
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verified target values (F3:H6):")
for r in range(3, 7):
    print([ws_check.cell(row=r, column=c).value for c in range(6, 9)])
