import openpyxl
from openpyxl.utils import get_column_letter

# paths
in_path = "/sandbox/input/input_spreadsheet/1_41410_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_41410_init.xlsx"

# load workbook
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# write headers in target (row 3) if not already present
ws["F3"] = "Item"
ws["G3"] = "kW rating"
ws["H3"] = "Number"

# formulas for up to 3 lighting rows (rows 4-6)
for i in range(1, 4):  # i = 1,2,3 corresponds to target rows 4,5,6
    target_row = i + 3
    # INDEX/SMALL/IF formula for column B (Item)
    ws.cell(row=target_row, column=6).value = (
        f'=IFERROR(INDEX($B$3:$B$22,SMALL(IF($B$3:$B$22="Lighting",'
        f'ROW($B$3:$B$22)-ROW($B$3)+1),ROW({i}:{i}))),"")'
    )
    # column C (kW rating)
    ws.cell(row=target_row, column=7).value = (
        f'=IFERROR(INDEX($C$3:$C$22,SMALL(IF($B$3:$B$22="Lighting",'
        f'ROW($B$3:$B$22)-ROW($B$3)+1),ROW({i}:{i}))),"")'
    )
    # column D (Number)
    ws.cell(row=target_row, column=8).value = (
        f'=IFERROR(INDEX($D$3:$D$22,SMALL(IF($B$3:$B$22="Lighting",'
        f'ROW($B$3:$B$22)-ROW($B$3)+1),ROW({i}:{i}))),"")'
    )

# ensure output directory exists
import os
os.makedirs(out_dir, exist_ok=True)

# save workbook
wb.save(out_path)

# recalculate formulas
await recalculate(out_path)

# reload with data_only to verify
wb2 = openpyxl.load_workbook(out_path, data_only=True)
ws2 = wb2[ws2.sheetnames[0]]
print("Verified target values (F3:H6):")
for r in range(3, 7):
    print([ws2.cell(row=r, column=c).value for c in range(6, 9)])
