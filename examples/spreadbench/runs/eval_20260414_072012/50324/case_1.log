import openpyxl, json, os
from openpyxl.utils import column_index_from_string, get_column_letter

# Load workbook
wb_path = '/sandbox/input/input_spreadsheet/1_50324_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)
print('Sheets:', wb.sheetnames)

# Function to print sheet summary

def sheet_summary(ws, name):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Sheet '{name}': rows={max_row}, cols={max_col}")
    # Print header row (row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print('Header row 1:', headers)
    # Print first 5 data rows
    print('First 5 rows:')
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last 5 rows
    print('Last 5 rows:')
    for r in range(max(max_row-4,2), max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Iterate sheets
for name in wb.sheetnames:
    ws = wb[name]
    sheet_summary(ws, name)
