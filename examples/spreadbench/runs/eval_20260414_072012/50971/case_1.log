import openpyxl, os, shutil
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_50971_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Build mapping from column A to list of column B values
dup_map = {}
for r in range(2, ws.max_row + 1):
    a_val = ws.cell(row=r, column=1).value  # Column A
    b_val = ws.cell(row=r, column=2).value  # Column B
    if a_val is None:
        continue
    dup_map.setdefault(a_val, []).append(b_val)

# Filter duplicates (more than one occurrence)
duplicates = {k: v for k, v in dup_map.items() if len(v) > 1}

# Write results starting at G3 (column 7, row 3)
start_row = 3
col_g = 7  # G
col_h = 8  # H
col_i = 9  # I
col_j = 10 # J
col_k = 11 # K

for idx, (key, b_vals) in enumerate(duplicates.items()):
    row = start_row + idx
    ws.cell(row=row, column=col_g, value=key)
    ws.cell(row=row, column=col_h, value=len(b_vals))
    # Write up to three B values
    ws.cell(row=row, column=col_i, value=b_vals[0] if len(b_vals) > 0 else None)
    ws.cell(row=row, column=col_j, value=b_vals[1] if len(b_vals) > 1 else None)
    ws.cell(row=row, column=col_k, value=b_vals[2] if len(b_vals) > 2 else None)

# Save workbook
wb.save(output_path)

# Recalculate (LibreOffice will evaluate any formulas that remain)
recalculate(output_path)

# Verify that the target range G3:K14 now contains data
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification of G3:K14 (data_only):")
for r in range(3, 15):
    vals = [ws_check.cell(row=r, column=c).value for c in range(7, 12)]
    print(r, vals)
