Code:
```repl
import openpyxl, os, math
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_47933_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_47933_init.xlsx")

# Load workbook (keep all sheets)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
master_ws = wb["master"]
hrs_ws = wb["Hrs"]
amount_ws = wb["amount"]

# Build lookup for hours from Hrs sheet (employee number in column A, hours in column B)
hours_lookup = {}
for r in range(2, hrs_ws.max_row + 1):
    emp = hrs_ws.cell(row=r, column=1).value
    hrs = hrs_ws.cell(row=r, column=2).value
    if emp is not None:
        hours_lookup[emp] = hrs

# Build lookup for amount from amount sheet (employee number in column B, amount in column A)
amount_lookup = {}
for r in range(2, amount_ws.max_row + 1):
    emp = amount_ws.cell(row=r, column=2).value
    amt = amount_ws.cell(row=r, column=1).value
    if emp is not None:
        amount_lookup[emp] = amt

# Process each row in master sheet
for r in range(2, master_ws.max_row + 1):
    emp = master_ws.cell(row=r, column=1).value
    # Retrieve hours and amount using lookups (fallback to None if missing)
    hrs = hours_lookup.get(emp)
    amt = amount_lookup.get(emp)
    # Compute rate safely
    if hrs is None or amt is None or hrs == 0:
        rate = None
    else:
        rate = round(amt / (52 * hrs), 2)
    # Compute final E value according to the rule
    if rate is None or hrs is None:
        e_val = None
    else:
        e_val = rate * 2 if hrs < 37.5 else rate * 1.5
    # Write the numeric result (or leave blank if cannot compute)
    master_ws.cell(row=r, column=5).value = e_val

# Save to output location
wb.save(output_path)

# Recalculate with LibreOffice to cache any formulas (though column E now holds static numbers)
recalculate(output_path)

# Verify E2 after recalculation
check_wb = openpyxl.load_workbook(output_path, data_only=True)
check_ws = check_wb["master"]
print("E2 after recalculation:", check_ws["E2"].value)
```
