import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_48983_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_48983_init.xlsx")

# Load workbook preserving formulas
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Define source and target ranges based on observed layout
source_start_row = 6
source_end_row = 13
source_start_col = 3   # column C
source_end_col = 19    # column S

target_start_col = 13  # column M
target_end_col = 19    # column S

# Populate target cells with INDEX/MATCH formulas
for r in range(source_start_row, source_end_row + 1):
    brand_cell = ws.cell(row=r, column=12).coordinate  # column L
    for c in range(target_start_col, target_end_col + 1):
        header_cell = ws.cell(row=5, column=c).coordinate
        formula = (
            f"=INDEX($C$6:$S$13,"
            f"MATCH({brand_cell},$L$6:$L$13,0),"
            f"MATCH({header_cell},$C$5:$S$5,0))"
        )
        ws.cell(row=r, column=c).value = formula

# Save and recalculate
wb.save(output_path)
await recalculate(output_path)

# Verify a few target cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("\nSample target rows after recalculation:")
for r in range(source_start_row, source_start_row + 3):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(target_start_col, target_end_col + 1)]
    print(f"Row {r}:", row_vals)
