import openpyxl
from openpyxl.utils import get_column_letter

wb = openpyxl.load_workbook("/sandbox/input/input_spreadsheet/1_48983_init.xlsx", data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row
max_col = ws.max_column

# Collect non‑empty cells
non_empty = []
for r in range(1, max_row+1):
    for c in range(1, max_col+1):
        val = ws.cell(row=r, column=c).value
        if val is not None:
            non_empty.append((r, c, val))

# Summarize by rows
rows_summary = {}
for r, c, v in non_empty:
    rows_summary.setdefault(r, []).append((c, v))

print("Non‑empty rows and their columns (showing up to 10 rows):")
for r in sorted(rows_summary.keys())[:10]:
    cols = rows_summary[r]
    cols_str = ", ".join([f"{get_column_letter(c)}:{v}" for c, v in cols])
    print(f"Row {r}: {cols_str}")

# Find any other header containing the word "Category"
print("\nRows containing the word 'Category':")
for r, cols in rows_summary.items():
    for c, v in cols:
        if isinstance(v, str) and "Category" in v:
            print(f"Row {r}, Column {get_column_letter(c)} -> {v}")

# Show a block of rows 6‑12 (the main data area)
print("\nRows 6‑12 (full row values):")
for r in range(6, 13):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)
