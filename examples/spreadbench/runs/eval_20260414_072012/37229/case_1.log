import openpyxl
from openpyxl.utils import get_column_letter
import os
from datetime import datetime

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_37229_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_37229_init.xlsx")

# Load workbook (keep formulas, but we will replace with static values)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # Assuming single sheet

# Define data rows and header rows
data_start, data_end = 17, 24
header_start, header_end = 3, 14  # rows B3:B14

# Helper to compute sum for a given header row and data column
def compute_month_sum(header_row, data_col):
    header_date = ws.cell(row=header_row, column=2).value  # column B
    if not isinstance(header_date, datetime):
        return ""  # no valid month header
    target_year = header_date.year
    target_month = header_date.month
    total = 0
    for r in range(data_start, data_end + 1):
        d = ws.cell(row=r, column=2).value
        if isinstance(d, datetime) and d.year == target_year and d.month == target_month:
            v = ws.cell(row=r, column=data_col).value
            if isinstance(v, (int, float)):
                total += v
    return total if total != 0 else ""  # empty string for zero

# Write computed values into C3:G14
for row in range(header_start, header_end + 1):
    for col in range(3, 8):  # columns C (3) to G (7)
        val = compute_month_sum(row, col)
        ws.cell(row=row, column=col).value = val

# Save the modified workbook
