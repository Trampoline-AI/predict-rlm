import openpyxl, os
from datetime import datetime

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_37229_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_37229_init.xlsx")

# Load workbook with formulas (already saved from previous step)
wb = openpyxl.load_workbook(output_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Ensure formulas are evaluated
await recalculate(output_path)

# Reload with data_only=True to read evaluated values
wb_eval = openpyxl.load_workbook(output_path, data_only=True)
ws_eval = wb_eval[wb_eval.sheetnames[0]]

# Helper to compute expected sum for a given header row and column
def expected_sum(header_row, data_col):
    header_date = ws.cell(row=header_row, column=2).value  # B column
    if not isinstance(header_date, datetime):
        return None
    target_year = header_date.year
    target_month = header_date.month
    total = 0
    for r in range(17, 25):  # data rows 17-24
        d = ws.cell(row=r, column=2).value
        if isinstance(d, datetime) and d.year == target_year and d.month == target_month:
            v = ws.cell(row=r, column=data_col).value
            if isinstance(v, (int, float)):
                total += v
    return total if total != 0 else ""  # empty string for zero as per spec

# Print evaluated values and expected sums for rows 3-14, columns C-G
print("--- Evaluated vs Expected (C3:G14) ---")
for row in range(3, 15):
    eval_vals = []
    exp_vals = []
    for col in range(3, 8):
        eval_val = ws_eval.cell(row=row, column=col).value
        exp_val = expected_sum(row, col)
        eval_vals.append(eval_val)
        exp_vals.append(exp_val)
    print(f"Row {row}: evaluated={eval_vals} | expected={exp_vals}")

# Spot‑check a few specific cells
print("\nSpot‑check:")
for (r, c) in [(3,3), (4,5), (5,7), (14,7)]:
    print(f"Cell {ws.cell(row=r, column=c).coordinate}: evaluated={ws_eval.cell(row=r, column=c).value}, expected={expected_sum(r,c)}")
