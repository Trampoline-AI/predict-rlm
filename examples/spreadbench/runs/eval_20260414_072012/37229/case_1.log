ws_check = wb_check[wb_check.sheetnames[0]]

print("--- Verified values in C3:G14 (None = empty) ---")
for r in range(3, 15):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(3, 8)]
    print(f"Row {r}: {row_vals}")
