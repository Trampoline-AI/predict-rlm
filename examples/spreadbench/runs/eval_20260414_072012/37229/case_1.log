# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # Assuming single sheet as inspected

# Define the data range rows
data_start = 17
data_end = 24
month_header_start = 3
month_header_end = 14

# Loop over target rows and columns (C=3 to G=7)
for row in range(month_header_start, month_header_end + 1):
    month_cell = ws.cell(row=row, column=2)  # B column month start
    for col in range(3, 8):  # C to G
        # Build column letter for the data column
        col_letter = get_column_letter(col)
        # Build SUMIFS formula for this column
        sum_range = f"{col_letter}${data_start}:{col_letter}${data_end}"
        date_range = f"$B${data_start}:$B${data_end}"
        # Month boundaries using EOMONTH (LibreOffice compatible with _xlfn. prefix)
        # EOMONTH returns the end of month; we need first day of month and last day.
        # First day: =EOMONTH(B3,-1)+1
        # Last day: =EOMONTH(B3,0)
        # Wrap with IF to hide zero results.
        formula = (
            f"=IF(SUMIFS({sum_range},{date_range},">="&_xlfn.EOMONTH(B{row},-1)+1,{date_range},"<="&_xlfn.EOMONTH(B{row},0))=0,"
            f"""",SUMIFS({sum_range},{date_range},">="&_xlfn.EOMONTH(B{row},-1)+1,{date_range},"<="&_xlfn.EOMONTH(B{row},0)))"
        )
        ws.cell(row=row, column=col).value = formula

# Save to output location
wb.save(output_path)

# Recalculate formulas using the provided tool
