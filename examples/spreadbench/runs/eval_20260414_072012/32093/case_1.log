import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_32093_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_32093_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row

# Write new formula into column F (index 6) for all data rows
for r in range(2, max_row + 1):
    formula = f'=IF(C{r}<>"",C{r},IF(D{r}<>"",D{r},IF(E{r}<>"",E{r},B{r})))'
    ws.cell(row=r, column=6).value = formula

# Save to output location
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify by reloading with data_only to see cached values (or formulas if not evaluated)
wb_check = openpyxl.load_workbook(output_path, data_only=False)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Sample rows after formula insertion (column F values):")
for r in range(2, min(2+5, max_row+1)):
    val = ws_check.cell(row=r, column=6).value
    print(f"Row {r}: {val}")

# Also print a few rows where C/D/E are empty to see fallback to B
for r in range(max_row-4, max_row+1):
    val = ws_check.cell(row=r, column=6).value
    print(f"Row {r}: {val}")
