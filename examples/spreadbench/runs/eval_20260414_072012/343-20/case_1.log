import openpyxl
from openpyxl import load_workbook

# Load workbook
path = "/sandbox/input/input_spreadsheet/1_343-20_init.xlsx"
wb = load_workbook(path, data_only=False)

# List sheet names
print("Sheets:", wb.sheetnames)

# Function to print sheet info
def inspect_sheet(name, max_rows=5):
    ws = wb[name]
    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f"\n{name} headers ({len(headers)}): {headers}")
    # Print first few rows
    print("First rows:")
    for r in range(2, min(ws.max_row, max_rows+1)):
        row = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row)
    # Print last few rows
    print("Last rows:")
    start = max(2, ws.max_row - max_rows + 1)
    for r in range(start, ws.max_row+1):
        row = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row)

# Inspect relevant sheets
inspect_sheet("Import Data")
inspect_sheet("Duplicates")
```
