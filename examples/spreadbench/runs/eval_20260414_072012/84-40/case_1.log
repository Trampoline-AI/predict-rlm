import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_84-40_init.xlsx"
output_path = "/sandbox/output/output_spreadsheet/1_84-40_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify the LIST sheet (case‑insensitive)
list_sheet_name = None
for name in wb.sheetnames:
    if name.strip().lower() == "list":
        list_sheet_name = name
        break
if not list_sheet_name:
    raise ValueError("No sheet named 'LIST' found")

list_ws = wb[list_sheet_name]

# Prepare to write rows: start at row 2 (assuming header is row 1)
start_row = 2

# Iterate over sheets (excluding LIST) in the order they appear
for idx, sheet_name in enumerate([n for n in wb.sheetnames if n != list_sheet_name], start=0):
    ws = wb[sheet_name]
    import_sum = 0
    export_sum = 0
    for r in range(2, ws.max_row + 1):  # data starts at row 2
        # Column C = 3, Column D = 4
        imp_val = ws.cell(row=r, column=3).value
        exp_val = ws.cell(row=r, column=4).value
        if isinstance(imp_val, (int, float)):
            import_sum += imp_val
        if isinstance(exp_val, (int, float)):
            export_sum += exp_val

    # Determine the row in LIST where this sheet's totals go
    target_row = start_row + idx  # CA->2, MN->3, SDFRT->4, ...

    # Write sheet name (column B), import (C), export (D), balance formula (E)
    list_ws.cell(row=target_row, column=2, value=sheet_name)          # B
    list_ws.cell(row=target_row, column=3, value=import_sum)        # C
    list_ws.cell(row=target_row, column=4, value=export_sum)        # D
    # Balance formula: =C{row}-D{row}
    list_ws.cell(row=target_row, column=5, value=f"=C{target_row}-D{target_row}")  # E

# Save to output directory
wb.save(output_path)

# Recalculate formulas (LibreOffice will evaluate the balance column)
recalculate(output_path)

# Verify by re‑loading with data_only=True and printing the LIST rows
verify_wb = openpyxl.load_workbook(output_path, data_only=True)
verify_ws = verify_wb[list_sheet_name]
print("LIST verification:")
for r in range(start_row, start_row + len(wb.sheetnames) - 1):
    print([verify_ws.cell(row=r, column=c).value for c in range(1, 6)])
