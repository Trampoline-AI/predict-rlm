import openpyxl
from openpyxl import load_workbook

# Load the workbook
wb = load_workbook("/sandbox/input/input_spreadsheet/1_304-35_init.xlsx", data_only=False)
print("Sheet names:", wb.sheetnames)

# Function to print sheet info
def print_sheet_info(ws, max_rows=10):
    print(f"\n--- Sheet: {ws.title} ---")
    # Determine max column from header row (assume row 1)
    max_col = ws.max_column
    headers = [ws.cell(row=1, column=col).value for col in range(1, max_col+1)]
    print("Headers:", headers)
    total_rows = ws.max_row
    print("Total rows:", total_rows)
    # Print first few rows
    print("First rows:")
    for r in range(2, min(2+max_rows, total_rows+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last few rows
    start = max(2, total_rows - max_rows + 1)
    print("Last rows:")
    for r in range(start, total_rows+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Iterate sheets
for ws in wb.worksheets:
    print_sheet_info(ws, max_rows=10)
