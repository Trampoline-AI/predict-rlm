import openpyxl
from openpyxl import load_workbook, Workbook
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_304-35_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_304-35_init.xlsx")

# Load workbook (preserve formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb["start"]  # the only sheet

max_row = ws.max_row

# 1. Clear column F where column E is empty
for r in range(2, max_row + 1):
    e_val = ws.cell(row=r, column=5).value  # column E
    if e_val is None:
        ws.cell(row=r, column=6).value = None  # clear column F

# 2. Copy column A downwards while column F not empty,
#    stop when an empty cell in column F is encountered,
#    and skip copying if target already has the same value.
r = 2
while r <= max_row:
    f_val = ws.cell(row=r, column=6).value
    if f_val is None:
        # stop copying when column F is empty
        break
    a_val = ws.cell(row=r, column=1).value
    if a_val is not None:
        target_row = r + 1
        if target_row <= max_row:
            target_f = ws.cell(row=target_row, column=6).value
            if target_f is not None:  # only copy if target F not empty
                target_a = ws.cell(row=target_row, column=1).value
                if target_a != a_val:  # skip if identical index already present
                    ws.cell(row=target_row, column=1).value = a_val
    r += 1

# Save modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice) and verify
