# Paths
input_path = "/sandbox/input/input_spreadsheet/1_39432_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_39432_init.xlsx")

# Load workbook (keep formulas for other cells)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# Column indices (1‑based)
col_item = 1   # A
col_begin_qty = 2   # B
col_begin_cost = 3  # C
# PO pairs: D/E, F/G, H/I, J/K
po_qty_cols = [4, 6, 8, 10]
po_cost_cols = [5, 7, 9, 11]
col_current_inv = 12  # L
col_output = 13       # M

def compute_fifo_cost(row):
    """Return per‑unit cost based on FIFO for the given row."""
    layers = []
    # Beginning inventory
    beg_qty = ws.cell(row=row, column=col_begin_qty).value
    beg_cost = ws.cell(row=row, column=col_begin_cost).value
    if beg_qty is not None and beg_cost is not None:
        layers.append((float(beg_qty), float(beg_cost)))
    # Purchase orders
    for qcol, ccol in zip(po_qty_cols, po_cost_cols):
        qty = ws.cell(row=row, column=qcol).value
        cost = ws.cell(row=row, column=ccol).value
        if qty is not None and cost is not None:
            layers.append((float(qty), float(cost)))
    # Current inventory on hand
    cur_inv = ws.cell(row=row, column=col_current_inv).value
    if cur_inv is None or cur_inv == 0:
        return None
    cur_inv = float(cur_inv)
    taken = 0.0
    total_cost = 0.0
    for qty, cost in layers:
        if taken >= cur_inv:
            break
        take_qty = min(qty, cur_inv - taken)
        total_cost += take_qty * cost
        taken += take_qty
    if taken == 0:
        return None
    return total_cost / taken

# Write computed per‑unit cost into column M
for r in range(2, ws.max_row + 1):
    cost = compute_fifo_cost(r)
    cell = ws.cell(row=r, column=col_output)
    cell.value = round(cost, 4) if cost is not None else None

# Save to output location
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas (if any) and reload to verify column M values
await recalculate(output_path)

# Reload with data_only to see cached values
