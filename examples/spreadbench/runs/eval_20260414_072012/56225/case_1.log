    t_out = ws.cell(row=row, column=6).value
    sec_in = time_to_seconds(t_in)
    sec_out = time_to_seconds(t_out)
    if sec_in is None or sec_out is None:
        continue

    # Handle possible overnight shift (out < in)
    diff_sec = sec_out - sec_in
    if diff_sec < 0:
        diff_sec += 86400  # add 24 h

    # Convert seconds to fractional day (Excel time unit)
    total += diff_sec / 86400.0

# Write label and result into column O (13th column = O)
