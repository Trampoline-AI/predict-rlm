ws = wb["data"]

# Helper to convert datetime.time to seconds since midnight
def time_to_seconds(t):
    if isinstance(t, time):
        return t.hour * 3600 + t.minute * 60 + t.second + t.microsecond / 1e6
    return None

# Read target name (M3) and target date (N5)
target_name = ws["M3"].value
target_date = ws["N5"].value  # should be a datetime.date or datetime.datetime

print("Target name:", target_name)
print("Target date:", target_date)

total = 0.0  # sum in fractional days (Excel time unit)

for row in range(2, ws.max_row + 1):
