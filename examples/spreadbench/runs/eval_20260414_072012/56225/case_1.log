4. Iterate over rows, matching rows where column C contains the target name (case‑insensitive) and column A date matches the target date (after parsing).
5. Compute time difference between columns E and F, convert to fractional days, sum.
6. Write label "Total Time (days)" to O1 and the sum to O2.
7. Save to the output directory, recalculate, reload with data_only, and verify O1 and O2.

The code below follows these steps with proper indentation and no syntax errors.
Code:
```repl
import openpyxl
import os
from datetime import datetime, time

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_56225_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = os.path.join(out_dir, "1_56225_init.xlsx")

# Load workbook preserving formulas
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb["data"]

# Helper to convert datetime.time to seconds since midnight
def time_to_seconds(t):
    if isinstance(t, time):
        return t.hour * 3600 + t.minute * 60 + t.second + t.microsecond / 1e6
    return None

# Helper to parse date strings that appear in column A
def parse_date(val):
    if isinstance(val, datetime):
        return val.date()
    if isinstance(val, str):
        # Try common formats
        for fmt in ("%m-%d-%y", "%m/%d/%y", "%Y-%m-%d", "%m-%d-%Y", "%m/%d/%Y"):
            try:
                return datetime.strptime(val, fmt).date()
            except Exception:
                continue
    return None

# Read target name (M3) and target date (N5)
raw_target_name = ws["M3"].value
raw_target_date = ws["N5"].value
print("Raw target name:", raw_target_name)
print("Raw target date:", raw_target_date)

target_name = str(raw_target_name).strip() if raw_target_name else ""
# Normalize target date to a plain date object
if isinstance(raw_target_date, datetime):
    target_date = raw_target_date.date()
else:
    target_date = parse_date(raw_target_date)
print("Normalized target name:", target_name)
print("Normalized target date:", target_date)

# Accumulate total time in fractional days (Excel time unit)
total = 0.0

# Iterate over rows (skip header row)
for r in range(2, ws.max_row + 1):
    name = ws.cell(row=r, column=3).value          # column C (name)
    row_date_raw = ws.cell(row=r, column=1).value  # column A (date)

    # Name must contain target substring (case‑insensitive)
    if not name or target_name.lower() not in str(name).lower():
        continue

    # Parse row date
    row_date = parse_date(row_date_raw)
    if row_date != target_date:
        continue

    # Get time‑in (E) and time‑out (F)
    t_in = ws.cell(row=r, column=5).value
    t_out = ws.cell(row=r, column=6).value
    sec_in = time_to_seconds(t_in)
    sec_out = time_to_seconds(t_out)
    if sec_in is None or sec_out is None:
        continue

    # Compute difference, handling overnight shift
    diff_sec = sec_out - sec_in
    if diff_sec < 0:
        diff_sec += 86400  # add 24 h

    # Convert to fractional day (Excel time unit) and add to total
    total += diff_sec / 86400.0

# Write label and result into column O (15th column)
ws["O1"].value = "Total Time (days)"
ws["O2"].value = total

# Ensure output directory exists and save
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)

# Recalculate formulas using LibreOffice (async)
await recalculate(out_path)

# Reload with data_only to verify written values
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check["data"]
print("Verification - O1:", ws_check["O1"].value)
print("Verification - O2:", ws_check["O2"].value)
