import openpyxl
from openpyxl.utils import get_column_letter
import asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_37086_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_37086_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Identify column indices (1‑based)
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
col1_idx = None
col_total_idx = None
for idx, hdr in enumerate(headers, start=1):
    if isinstance(hdr, str):
        h = hdr.strip().lower()
        if h == "column1":
            col1_idx = idx
        if h == "total":
            col_total_idx = idx

assert col1_idx is not None and col_total_idx is not None, "Required columns not found"

# Update Total column formulas for each data row
for r in range(2, ws.max_row + 1):
    col1_cell = ws.cell(row=r, column=col1_idx).coordinate
    # Sum of Column2 and Column3 (columns right after Column1)
    sum_range = f"{get_column_letter(col1_idx+1)}{r}:{get_column_letter(col1_idx+2)}{r}"
    formula = f'=IF({col1_cell}="A", SUM({sum_range})+10, IF({col1_cell}="B", SUM({sum_range})-10, ""))'
    ws.cell(row=r, column=col_total_idx).value = formula

# Save modified workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify results
