Code:
```python
```repl
import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas, though we will overwrite column B with values)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active

max_row = ws.max_row

# 1. Build list of colors from column D (skip header)
colors = []
for r in range(2, max_row + 1):
    val = ws.cell(row=r, column=4).value  # column D
    if isinstance(val, str):
        colors.append(val.strip())
# Remove duplicates while preserving order
seen = set()
unique_colors = []
for c in colors:
    if c not in seen:
        seen.add(c)
        unique_colors.append(c)

# 2. Populate column B with matching color or empty string
for r in range(2, max_row + 1):
    prod_desc = ws.cell(row=r, column=1).value  # column A
    match = ""
    if isinstance(prod_desc, str):
        desc_lower = prod_desc.lower()
        for col in unique_colors:
            if col.lower() in desc_lower:
                match = col  # preserve original capitalization
                break
    ws.cell(row=r, column=2).value = match  # column B

# Save to output path
wb.save(output_path)

# Recalculate (even though we wrote static values, the workflow expects it)
await recalculate(output_path)

# Reload with evaluated values to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active

print("Resulting column B values (row: value):")
for r in range(2, max_row + 1):
    print(r, ws2.cell(row=r, column=2).value)
