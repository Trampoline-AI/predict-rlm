```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active

max_row = ws.max_row
max_col = ws.max_column

# define range for color list in column D
color_range = f"$D$2:$D${max_row}"

# write formula into column B for each data row
for r in range(2, max_row + 1):
    # formula: IFERROR(LOOKUP(2,1/(ISNUMBER(SEARCH($D$2:$D$N,$A<))),$D$2:$D$N),"")
    formula = f'=IFERROR(LOOKUP(2,1/(ISNUMBER(SEARCH({color_range},${get_column_letter(1)}{r}))),{color_range}),"")'
    ws.cell(row=r, column=2).value = formula

# save to output path
wb.save(output_path)

# recalculate formulas
from recalculate import recalculate  # assuming the tool is available
await recalculate(output_path)

# reload with data_only to verify results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active

# print resulting column B values
print("Resulting column B values:")
for r in range(2, max_row + 1):
    print(r, ws2.cell(row=r, column=2).value)
