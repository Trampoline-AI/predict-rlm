import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_41348_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_41348_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet as inspected

# Column indices (1‑based)
COL_BUDGET_ID = 10   # J
COL_BUDGET_TYPE = 12 # L
COL_LINKED = 9       # I
COL_TARGET = 17      # Q

# First pass: collect Budget IDs that have Technology
tech_budget_ids = set()
for row in ws.iter_rows(min_row=2, max_col=COL_BUDGET_ID, values_only=False):
    budget_id = row[COL_BUDGET_ID-1].value  # column J
    budget_type = row[COL_BUDGET_TYPE-1].value  # column L
    if budget_id is not None and isinstance(budget_type, str) and budget_type.strip().lower() == "technology":
        tech_budget_ids.add(budget_id)

# Second pass: write Y/N into column Q
for r in range(2, ws.max_row + 1):
    cell_budget_id = ws.cell(row=r, column=COL_BUDGET_ID).value
    cell_linked = ws.cell(row=r, column=COL_LINKED).value
    target_cell = ws.cell(row=r, column=COL_TARGET)
    # Determine value
    if cell_budget_id is not None and cell_linked == "Y" and cell_budget_id in tech_budget_ids:
        target_cell.value = "Y"
    else:
        target_cell.value = "N"

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify a few rows
