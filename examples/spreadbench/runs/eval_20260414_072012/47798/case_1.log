```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
inp_path = "/sandbox/input/input_spreadsheet/1_47798_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, "1_47798_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(inp_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine max row
max_row = ws.max_row

# Ensure header for output column C
out_col_idx = 3  # column C
ws.cell(row=1, column=out_col_idx).value = "Extracted Collection"

# Build formula string (Excel-compatible, LibreOffice-friendly)
# Explanation:
#   start = FIND("Collection-",A2) + LEN("Collection-")
#   end   = FIND(",",A2, start)  (if comma exists) else LEN(A2)+1
#   length = end - start
#   result = TRIM(MID(A2, start, length))
formula_template = (
    '=TRIM(MID(A{row}, '
    'FIND("Collection-",A{row})+LEN("Collection-"), '
    'IFERROR(FIND(",",A{row}, FIND("Collection-",A{row})+LEN("Collection-")) '
    '- (FIND("Collection-",A{row})+LEN("Collection-")), '
    'LEN(A{row})- (FIND("Collection-",A{row})+LEN("Collection-"))+1)))'
)

# Apply formula to each data row
for r in range(2, max_row + 1):
    ws.cell(row=r, column=out_col_idx).value = formula_template.format(row=r)

# Save workbook
wb.save(out_path)
print("Workbook saved to", out_path)

# Recalculate formulas
from asyncio import run
await recalculate(out_path)
print("Recalculation done")

# Verify a few rows
ws_check = openpyxl.load_workbook(out_path, data_only=True)[ws.title]
for r in range(2, min(7, max_row + 1)):
    print(f"Row {r} ->", ws_check.cell(row=r, column=out_col_idx).value)
```
