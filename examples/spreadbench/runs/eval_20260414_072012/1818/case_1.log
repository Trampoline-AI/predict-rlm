```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_1818_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_1818_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheets
ws_data = wb["Data"]
ws_sum = wb["Summary"]

# Identify data columns (based on inspection)
col_student_num = 2  # B
col_student_name = 3  # C
col_performance = 4  # D

# Collect lowest performing students
lowest_students = []
for r in range(2, ws_data.max_row + 1):
    perf = ws_data.cell(row=r, column=col_performance).value
    if perf == "Lowest Performing":
        num = ws_data.cell(row=r, column=col_student_num).value
        name = ws_data.cell(row=r, column=col_student_name).value
        lowest_students.append((num, name))

# Write to Summary starting at row 4, columns B (2) and C (3)
start_row = 4
for i, (num, name) in enumerate(lowest_students):
    row_idx = start_row + i
    ws_sum.cell(row=row_idx, column=2).value = num
    ws_sum.cell(row=row_idx, column=3).value = name

# Clear any remaining rows below the written data up to the original max row
for r in range(start_row + len(lowest_students), ws_sum.max_row + 1):
    ws_sum.cell(row=r, column=2).value = None
    ws_sum.cell(row=r, column=3).value = None

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(str(output_path))

# Reload with data_only to verify the written values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Summary"]
print("Verification of Summary rows (Student Number, Student Name):")
for r in range(start_row, start_row + len(lowest_students)):
    num = ws_check.cell(row=r, column=2).value
    name = ws_check.cell(row=r, column=3).value
    print(r, num, name)
```
