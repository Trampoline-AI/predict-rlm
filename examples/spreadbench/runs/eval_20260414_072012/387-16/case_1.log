import openpyxl
from openpyxl.utils import get_column_letter
import shutil
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_387-16_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_387-16_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Identify header row (row 2) and data start row
header_row = 2
data_start = header_row + 1

# Gather all data rows into a list of dicts for easier manipulation
data_rows = []
for r in range(data_start, ws.max_row + 1):
    row_dict = {
        "row_idx": r,
        "Value": ws.cell(row=r, column=1).value,
        "Binaries": ws.cell(row=r, column=2).value,
        "Result": ws.cell(row=r, column=4).value,
    }
    data_rows.append(row_dict)

# Extract result values from column 4, skipping header and empty cells
result_vals = [row["Result"] for row in data_rows if row["Result"] is not None]

# Keep track of which result values have already been removed
removed = set()

# Remove only one instance per result value
for val in result_vals:
    if val in removed:
        continue
    for row in data_rows:
        if row["Value"] == val:
            # Mark removal
            row["Value"] = None
            row["Binaries"] = None
            removed.add(val)
            break  # only remove first occurrence

# After removal, compact the Value and Binaries columns (shift up)
compact_values = [row["Value"] for row in data_rows if row["Value"] is not None]
compact_binaries = [row["Binaries"] for row in data_rows if row["Binaries"] is not None]

# Write back compacted lists
for i, val in enumerate(compact_values):
    ws.cell(row=data_start + i, column=1).value = val
for i, bin_val in enumerate(compact_binaries):
    ws.cell(row=data_start + i, column=2).value = bin_val

# Clear any leftover cells below the new data length (up to original max row)
new_last_row = data_start + max(len(compact_values), len(compact_binaries)) - 1
for r in range(new_last_row + 1, ws.max_row + 1):
    ws.cell(row=r, column=1).value = None
    ws.cell(row=r, column=2).value = None

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload to verify key cells (optional sanity check)
wb2 = openpyxl.load_workbook(output_path, data_only=False)
ws2 = wb2[wb2.sheetnames[0]]
print("Solver result formula (cell G2):", ws2["G2"].value)
print("Difference formula (cell K2):", ws2["K2"].value)
print("First few cleaned Value cells:", [ws2.cell(row=data_start + i, column=1).value for i in range(5)])
