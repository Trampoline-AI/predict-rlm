import openpyxl
from openpyxl.utils import get_column_letter

in_path = "/sandbox/input/input_spreadsheet/1_59639_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_59639_init.xlsx"

# Reload workbook with calculated values
wb_calc = openpyxl.load_workbook(out_path, data_only=True)
ws_calc = wb_calc[wb_calc.sheetnames[0]]

start_col = 4  # D
for r in range(2, ws_calc.max_row + 1):
    val = ws_calc.cell(row=r, column=1).value
    if isinstance(val, str):
        split_vals = [ws_calc.cell(row=r, column=start_col + i).value for i in range(len(val))]
        print(f"Row {r} original: '{val}' split: {split_vals}")

# Verify that each split value is a single character matching the original string
all_ok = True
for r in range(2, ws_calc.max_row + 1):
    val = ws_calc.cell(row=r, column=1).value
    if isinstance(val, str):
        for i, ch in enumerate(val):
            cell_val = ws_calc.cell(row=r, column=start_col + i).value
            if cell_val != ch:
                all_ok = False
                print(f"Mismatch at row {r}, col {get_column_letter(start_col + i)}: expected '{ch}', got '{cell_val}'")
print("All splits correct:", all_ok)
