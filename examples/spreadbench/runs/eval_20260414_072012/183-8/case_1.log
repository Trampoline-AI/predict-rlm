# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Define formulas for weighted averages using column C as weight
formula_J = "=SUMPRODUCT($C$2:$C$43,$D$2:$D$43)/SUM($C$2:$C$43)"
formula_K = "=SUMPRODUCT($C$2:$C$43,$E$2:$E$43)/SUM($C$2:$C$43)"
formula_L = "=SUMPRODUCT($C$2:$C$43,$F$2:$F$43)/SUM($C$2:$C$43)"

