ws_check = wb_check[wb_check.sheetnames[0]]
remaining = []
for r in range(2, ws_check.max_row + 1):
    val = ws_check.cell(row=r, column=1).value
    if isinstance(val, str) and val.strip() in targets:
        remaining.append((r, val))
print("Remaining target rows after deletion:", remaining[:10])  # should be empty
