output_path = os.path.join(output_dir, "1_24-23_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Identify rows to delete (column A)
targets = {"@9T", "SAL", "T9A"}
rows_to_delete = []
for r in range(2, ws.max_row + 1):
    cell_val = ws.cell(row=r, column=1).value
    if isinstance(cell_val, str) and cell_val.strip() in targets:
        rows_to_delete.append(r)

print(f"Found {len(rows_to_delete)} rows to delete.")

# Delete rows in reverse order to keep indices valid
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, amount=1)

# Save workbook
wb.save(output_path)

# Recalculate formulas
from predict import recalculate
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Verify removal
