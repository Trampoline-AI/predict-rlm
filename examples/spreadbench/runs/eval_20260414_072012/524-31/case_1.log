import os
import openpyxl
from openpyxl.utils import get_column_letter

# Load the input workbook
wb = openpyxl.load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]  # Assuming a single sheet

max_row = ws.max_row

# ----------------------------------------------------------------------
# 1. Build a mapping from the lookup table (rows 2‑37) : short_name -> category
#    The VLOOKUP formula uses range $A$1:$B$37, so we read columns A and B
#    within that range.
# ----------------------------------------------------------------------
lookup_start = 2
lookup_end = 37  # inclusive, based on the VLOOKUP range
lookup_dict = {}
for r in range(lookup_start, lookup_end + 1):
    key = ws.cell(row=r, column=1).value   # column A
    cat = ws.cell(row=r, column=2).value   # column B
    if key is not None:
        lookup_dict[str(key).strip()] = cat

# ----------------------------------------------------------------------
# 2. Populate column G (index 7) with the category based on the shortened
#    name in column B (index 2). If the shortened name is not found in the
#    lookup table, leave the cell blank (or you could write "UNKNOWN").
# ----------------------------------------------------------------------
for r in range(2, max_row + 1):
    short_name = ws.cell(row=r, column=2).value
    if short_name is None:
        ws.cell(row=r, column=7).value = None
        continue
    short_name_str = str(short_name).strip()
    category = lookup_dict.get(short_name_str, None)
    ws.cell(row=r, column=7).value = category

# ----------------------------------------------------------------------
# 3. Save to the output directory with the same filename
# ----------------------------------------------------------------------
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

# ----------------------------------------------------------------------
# 4. Recalculate (no formulas remain in column G, but we still call it)
# ----------------------------------------------------------------------
await recalculate(output_path)

# ----------------------------------------------------------------------
# 5. Reload with data_only=True and print a few sample category values
# ----------------------------------------------------------------------
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

print("Sample category values after processing:")
for r in range(2, min(7, max_row + 1)):
    val = ws2.cell(row=r, column=7).value
    print(f"Row {r} G:", val)
