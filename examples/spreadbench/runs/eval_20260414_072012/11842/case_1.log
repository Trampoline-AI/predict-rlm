import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load workbook (not data_only because we will write formulas)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
total_ws = wb["Total"]

# Inspect header row of Total sheet
max_col = total_ws.max_column
headers = [total_ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Total sheet headers:", headers)

# Find a column that looks like it should hold the yearly total.
# If none exists, we will append a new column after the last used column.
target_col_idx = None
for idx, header in enumerate(headers, start=1):
    if isinstance(header, str) and "TOTAL" in header.upper():
        target_col_idx = idx
        break

if target_col_idx is None:
    # No existing total column, create one after the last column
    target_col_idx = max_col + 1
    new_header = "YEARLY TOTAL"
    total_ws.cell(row=1, column=target_col_idx, value=new_header)
    print(f"Created new column {get_column_letter(target_col_idx)} with header '{new_header}'")
else:
    print(f"Using existing column {get_column_letter(target_col_idx)} for yearly total")

# Determine the column in monthly sheets that holds the per‑person total.
# From the Jan sheet we saw that column AG (31) contains a COUNTIF for a marker.
# We'll assume the same column index is used in all months.
monthly_total_col = "AG"  # column letter

# Build the formula for each person row (starting at row 2)
for row in range(2, total_ws.max_row + 1):
    # Skip rows where the name cell (column A) is empty
    name_cell = total_ws.cell(row=row, column=1)
    if not name_cell.value:
        continue

    # Build SUM across all months
    sum_parts = []
    for month in ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]:
        sum_parts.append(f"{month}!{monthly_total_col}{row}")

    formula = f"=SUM({','.join(sum_parts)})"
    total_ws.cell(row=row, column=target_col_idx, value=formula)

# Save to output directory
output_path = "/sandbox/output/output_spreadsheet/1_11842_init.xlsx"
wb.save(output_path)

# Recalculate formulas
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to verify a few results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Total"]
print("Sample yearly totals (first 5 rows):")
for r in range(2, min(7, ws_check.max_row+1)):
    print(r, ws_check.cell(row=r, column=target_col_idx).value)
