Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook (writeable)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
total_ws = wb["Total"]

# ---- Identify or create target column for yearly total ----
max_col = total_ws.max_column
headers = [total_ws.cell(row=1, column=c).value for c in range(1, max_col+1)]

target_col_idx = None
for idx, hdr in enumerate(headers, start=1):
    if isinstance(hdr, str) and "TOTAL" in hdr.upper():
        target_col_idx = idx
        break

if target_col_idx is None:
    target_col_idx = max_col + 1
    total_ws.cell(row=1, column=target_col_idx, value="YEARLY TOTAL")
    print(f"Created column {get_column_letter(target_col_idx)} for yearly total")
else:
    print(f"Using existing column {get_column_letter(target_col_idx)} for yearly total")

# ---- Build the SUMIF formula for each data row ----
months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
monthly_total_col = "AG"   # column that holds the per‑person total in each month sheet

for row in range(2, total_ws.max_row + 1):
    name_cell = total_ws.cell(row=row, column=1)   # column A holds the employee name
    if not name_cell.value:
        continue   # skip empty rows

    # Build the SUMIF parts for all months
    sumif_parts = []
    for m in months:
        sumif_parts.append(f"SUMIF({m}!$A:$A,$O$3,{m}!${monthly_total_col}:${monthly_total_col})")
    sumif_expr = "+".join(sumif_parts)

    # Full IF formula
    formula = f'=IF($A{row}=$O$3,{sumif_expr},"")'
    total_ws.cell(row=row, column=target_col_idx, value=formula)

# ---- Save to output path ----
output_path = "/sandbox/output/output_spreadsheet/1_11842_init.xlsx"
wb.save(output_path)

# ---- Recalculate formulas ----
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# ---- Verify a few rows (data_only) ----
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Total"]
print("Sample YEARLY TOTAL values (rows 2‑6):")
for r in range(2, min(7, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=target_col_idx).value
    print(f"Row {r}: {val}")
```
