- **G**: The value we need to transpose (e.g., odds)  

The task is to take, for each race, the sequential values from column G of the rows belonging to that race and write them horizontally starting at column H, stopping after the number of runners indicated in column C. Blank cells must stay blank (no zeroes). After filling, the range H2:S28 must be shaded #E2EFD and any whole‑number values should be displayed without decimals.

**Plan**
1. Load the workbook and get the active sheet.  
2. Build a mapping `race → list of G values` preserving order of rows.  
3. For each data row (starting at 2), look up its race, fetch the list of G values, and write them into columns H, I, … up to the count in column C (or the length of the list, whichever is smaller). Cells beyond that count are left blank.  
4. Apply a number format that hides decimals for whole numbers (`0`).  
5. Apply the background fill `#E2EFD` to the whole range H2:S28.  
6. Save the workbook to the output directory, recalculate formulas, and verify a few target cells.
Code:
```repl
import openpyxl
from openpyxl.styles import PatternFill, NumberFormatDescriptor
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_56427_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_56427_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# ----------------------------------------------------------------------
# 1. Build race → list of G values (preserve row order)
# ----------------------------------------------------------------------
race_to_vals = {}
max_row = ws.max_row
for r in range(2, max_row + 1):
    race = ws.cell(row=r, column=1).value   # column A
    b_val = ws.cell(row=r, column=2).value # column B (runner number)
    g_val = ws.cell(row=r, column=7).value # column G
    # Only consider rows that actually have a G value
    if race is None:
        continue
    if race not in race_to_vals:
        race_to_vals[race] = []
    # Preserve the original order (row order)
    race_to_vals[race].append(g_val)

# ----------------------------------------------------------------------
# 2. Write transposed values starting at column H (8) for each row
# ----------------------------------------------------------------------
start_col = 8   # H
end_col = 19    # S (inclusive)
for r in range(2, max_row + 1):
    race = ws.cell(row=r, column=1).value
    runners = ws.cell(row=r, column=3).value   # column C (number of runners)
    # Convert runners to int if possible, otherwise use length of list
    try:
        runners = int(runners)
    except Exception:
        runners = None

    vals = race_to_vals.get(race, [])
    # Determine how many columns we actually fill
    fill_len = min(len(vals), runners) if runners is not None else len(vals)
    # Write values
    for offset in range(0, end_col - start_col + 1):
        col_idx = start_col + offset
        cell = ws.cell(row=r, column=col_idx)
        if offset < fill_len:
            value = vals[offset]
            cell.value = value
            # If the value is a whole number, hide decimals
            if isinstance(value, (int, float)):
                if float(value).is_integer():
                    cell.number_format = "0"
                else:
                    cell.number_format = "0.00"
            else:
                cell.number_format = "General"
        else:
            # Ensure blanks stay blank (no zero)
            cell.value = None

# ----------------------------------------------------------------------
# 3. Apply shading #E2EFD to range H2:S28
# ----------------------------------------------------------------------
fill = PatternFill(start_color="E2EFD", end_color="E2EFD", fill_type="solid")
for r in range(2, 29):   # rows 2‑28 inclusive
    for c in range(start_col, end_col + 1):
        ws.cell(row=r, column=c).fill = fill

# ----------------------------------------------------------------------
# 4. Save and recalculate
# ----------------------------------------------------------------------
wb.save(output_path)

# Recalculate formulas (if any) and reload for verification
await recalculate(output_path)
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Verify a few cells (sample)
sample_rows = [2, 7, 12]  # a few different races
for r in sample_rows:
    vals = [ws2.cell(row=r, column=c).value for c in range(start_col, end_col + 1) if ws2.cell(row=r, column=c).value is not None]
    print(f"Row {r} transposed values:", vals)

# End of script
```
