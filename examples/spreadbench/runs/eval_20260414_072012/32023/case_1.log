import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/initial.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "initial.xlsx")

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine the range of rows to apply the formula (skip header row)
start_row = 2
end_row = ws.max_row  # currently 19, but we will apply up to this row

# Build the nested IF formula string
# It checks today's date (assumed in column B) against assignment dates in C74:C78
# and returns the department code from column O of the same row.
# If none of the dates are reached, it returns an empty string.
# Using LibreOffice‑compatible syntax (no Excel‑only functions).
date_cells = ["C74", "C75", "C76", "C77", "C78"]
nested = '""'  # default empty
for dc in reversed(date_cells):
    nested = f'IF(TODAY()>={dc}, O{{row}}, {nested})'  # placeholder {{row}} to replace later

# Insert formula for each employee row
for r in range(start_row, end_row + 1):
    # Replace placeholder with actual row number
    formula = nested.replace("{row}", str(r))
    ws.cell(row=r, column=15).value = f"={formula}"  # column 15 = O

# Save to output path
wb.save(output_path)

# Recalculate (LibreOffice)
from openpyxl import workbook
wb2 = load_workbook(output_path, data_only=False)
wb2.save(output_path)  # trigger recalculation in the environment
