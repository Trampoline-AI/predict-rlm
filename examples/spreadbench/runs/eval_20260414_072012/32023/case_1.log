import os
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/initial.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "initial.xlsx")

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine rows to apply formula (skip header)
start_row = 2
end_row = ws.max_row  # current last non‑empty row

# Build nested IF formula (LibreOffice compatible)
# Checks TODAY() against C74:C78 and returns the department code from O74:O78.
date_cells = ["C78", "C77", "C76", "C75", "C74"]
code_cells = ["O78", "O77", "O76", "O75", "O74"]
nested = '""'  # default empty string
for d, c in zip(date_cells, code_cells):
    nested = f'IF(TODAY()>={d}, {c}, {nested})'

# Insert formula into column P (column 16) for each employee row
for r in range(start_row, end_row + 1):
    ws.cell(row=r, column=16).value = f"={nested}"

# Save to output path
