import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_51090_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_51090_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet holds the data

# Determine column indices
col_warehouse = column_index_from_string('A')  # 1
col_user = column_index_from_string('B')       # 2 (first user column)
col_date = column_index_from_string('L')       # 12
col_total = column_index_from_string('M')      # 13
col_err_II = column_index_from_string('N')     # 14
col_err_IR = column_index_from_string('O')     # 15
col_err_IT = column_index_from_string('P')     # 16
col_err_OV = column_index_from_string('Q')     # 17
col_err_PI = column_index_from_string('R')     # 18
col_output = column_index_from_string('S')     # 19 (new column)

# Write header for output column
ws.cell(row=1, column=col_output).value = "Diff (Cartons - Errors)"

# Formula template (Excel/LibreOffice compatible)
# Note: Use absolute column references for readability, but keep relative row.
formula_template = (
    '=IF(AND(A{r}=27, '
    'OR(B{r}="CHROGIL1", B{r}="CHDSPOLJ", B{r}="CHSJEFFE", B{r}="CHBTHOMA"), '
    'ISNUMBER(L{r})), '
    'M{r} - (N{r} + IF(O{r}>0, O{r}, 0) + P{r} + Q{r} + R{r}), '
    '"" )'
)

# Apply formula to each data row
for r in range(2, ws.max_row + 1):
    ws.cell(row=r, column=col_output).value = formula_template.format(r=r)

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Verification – first 10 rows of column S (Diff):")
for r in range(2, min(12, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=col_output).value
    print(f"Row {r}: {val}")

# Also print a row that should be blank (e.g., warehouse not 27)
# Find first row where warehouse != 27 for sanity check
for r in range(2, ws_check.max_row + 1):
    if ws_check.cell(row=r, column=col_warehouse).value != 27:
        blank_val = ws_check.cell(row=r, column=col_output).value
        print(f"Row {r} (warehouse {ws_check.cell(row=r, column=col_warehouse).value}) Diff: {blank_val}")
        break
