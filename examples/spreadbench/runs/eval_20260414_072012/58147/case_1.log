Code:
```repl
import os, openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_58147_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_58147_init.xlsx')

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb['Here']

# Determine the last row with any data in column I (9)
last_row = ws.max_row

# Write formula =I{row} into column J (10) for each row starting at 2
for r in range(2, last_row + 1):
    # Write the formula regardless of current I value; Excel will show blank if I is blank
    ws.cell(row=r, column=10).value = f"=I{r}"

# Ensure output directory exists and save
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas using LibreOffice (await the async function)
await recalculate(output_path)

# Reload the workbook with data_only to see evaluated results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['Here']

# Print a few target cells in column J to verify
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f'Row {r} J (Outcome) =', ws_check.cell(row=r, column=10).value)
```
