import openpyxl, os, json
from openpyxl.utils import column_index_from_string

# Load workbook
wb_path = '/sandbox/input/input_spreadsheet/1_395-36_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)
print('Sheets:', wb.sheetnames)

# Function to print header and sample rows
def inspect_sheet(ws, name):
    print(f'--- Sheet: {name} ---')
    # Assume first row is header
    headers = [cell.value for cell in ws[1]]
    print('Headers:', headers)
    max_row = ws.max_row
    max_col = ws.max_column
    # Print first 5 data rows (if exist)
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f'Row {r}:', row_vals)
    # Print last 5 data rows
    for r in range(max(max_row-4, 2), max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f'Row {r}:', row_vals)

for name in wb.sheetnames:
    ws = wb[name]
    inspect_sheet(ws, name)
