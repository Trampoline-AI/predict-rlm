Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# 1. Write corrected formula into D4:D7
for r in range(4, 8):
    formula = (
        f"=IFERROR(INT(INDEX($BD$3:$BR$81, MATCH($A{r}, $BD$3:$BD$81, 0), "
        f"MATCH(_xlfn.CONCAT(B$2), $BD$2:$BR$2, 0))),\"-\")"
    )
    ws.cell(row=r, column=column_index_from_string('D')).value = formula

# 2. Clear any values below row 7 in columns C and D
max_row = ws.max_row
for r in range(8, max_row + 1):
    ws.cell(row=r, column=column_index_from_string('C')).value = None
    ws.cell(row=r, column=column_index_from_string('D')).value = None

# Save workbook
wb.save(output_path)

# 3. Recalculate formulas (global async function)
await recalculate(str(output_path))

# 4. Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

print("Verification after recalculation:")
for r in range(4, 8):
    print(f"D{r} formula:", ws_check.cell(row=r, column=column_index_from_string('D')).value)
print("C8 value:", ws_check.cell(row=8, column=column_index_from_string('C')).value)
print("D8 value:", ws_check.cell(row=8, column=column_index_from_string('D')).value)
```
