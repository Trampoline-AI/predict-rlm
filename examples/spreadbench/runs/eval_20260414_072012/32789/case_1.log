Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# 1. Write corrected formula into D4:D7
start_row = 4
end_row = 7
col_D = column_index_from_string('D')
for r in range(start_row, end_row + 1):
    # Build formula string
    # Use _xlfn.CONCAT for LibreOffice compatibility
    formula = f'''=IFERROR(INT(INDEX($BD$3:$BR$81, MATCH($A{r}, $BD$3:$BD$81, 0), MATCH(_xlfn.CONCAT(B$2), $BD$2:$BR$2, 0))),"-")'''
    ws.cell(row=r, column=col_D).value = formula

# 2. Clear any values below row 7 in columns C and D
col_C = column_index_from_string('C')
max_row = ws.max_row
for r in range(8, max_row + 1):
    ws.cell(row=r, column=col_C).value = None
    ws.cell(row=r, column=col_D).value = None

# Save workbook
wb.save(output_path)

# Recalculate formulas
from sandbox import recalculate
await recalculate(str(output_path))

# Verify formulas in D4:D7 and cleared cells
print("Verification after updates:")
for r in range(start_row, end_row + 1):
    print(f"D{r}:", ws.cell(row=r, column=col_D).value)
print("C8:", ws.cell(row=8, column=col_C).value)
print("D8:", ws.cell(row=8, column=col_D).value)
```
