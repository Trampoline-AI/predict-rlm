import openpyxl
from openpyxl.utils import get_column_letter

# Paths
inp_path = "/sandbox/input/input_spreadsheet/1_55976_init.xlsx"
out_path = "/sandbox/output/output_spreadsheet/1_55976_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(inp_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Write tally formulas into row 25, columns F (6) to I (9)
# Count rows where column C ("Yes") = "x" and the category column (F‑I) is not empty
for col_idx, col_letter in zip(range(6, 10), ["F", "G", "H", "I"]):
    formula = f'=COUNTIFS(C:C,"x",{col_letter}:{col_letter},"<>")'
    ws[f"{col_letter}25"] = formula

# Save to output location
wb.save(out_path)

# Recalculate (LibreOffice) – placeholder call; the environment will handle it after submission
