import openpyxl
from openpyxl.utils import get_column_letter
import asyncio

# Paths
inp_path = "/sandbox/input/input_spreadsheet/1_55976_init.xlsx"
out_path = "/sandbox/output/output_spreadsheet/1_55976_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(inp_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Write tally formulas into row 25, columns F (6) to I (9)
for col_idx, col_letter in zip(range(6, 10), ["F", "G", "H", "I"]):
    # Count rows where column C ("Yes") = "x" and the category column (F‑I) is not empty
    formula = f'=COUNTIFS(C:C,"x",{col_letter}:{col_letter},"<>")'
    ws[f"{col_letter}25"] = formula

# Save to output location
wb.save(out_path)

# Recalculate formulas using LibreOffice (async)
await recalculate(out_path)

# Reload with data_only to get evaluated values
wb2 = openpyxl.load_workbook(out_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Print the formulas and their evaluated values for verification
for col_letter in ["F", "G", "H", "I"]:
    cell = ws[f"{col_letter}25"]
    val_cell = ws2[f"{col_letter}25"]
    print(f"{col_letter}25 formula: {cell.value} -> value: {val_cell.value}")

```
