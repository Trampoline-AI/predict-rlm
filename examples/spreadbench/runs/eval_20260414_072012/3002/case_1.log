        mat_doc_col = headers.index('Mat Doc') + 1
        doc_no_col = headers.index('Doc No') + 1
        remark_col = headers.index('Remark') + 1
        print('Mat Doc column:', get_column_letter(mat_doc_col))
        print('Doc No column:', get_column_letter(doc_no_col))
        print('Remark column:', get_column_letter(remark_col))
    except ValueError as e:
