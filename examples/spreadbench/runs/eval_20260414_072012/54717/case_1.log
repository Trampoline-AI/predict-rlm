import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_54717_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_54717_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Helper to print a block of cells
def print_block(r_start, r_end, c_start, c_end):
    for r in range(r_start, r_end+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(c_start, c_end+1)]
        print(f"Row {r}: {row_vals}")

# 1. Inspect rows 3-6, cols 15-20 (possible config area)
print("Inspecting rows 3-6, cols 15-20:")
print_block(3, 6, 15, 20)

# 2. Look for a cell containing the word "Total" or "Sum"
target_cell = None
for r in range(1, ws.max_row+1):
    for c in range(1, ws.max_column+1):
        val = ws.cell(row=r, column=c).value
        if isinstance(val, str) and ("total" in val.lower() or "sum" in val.lower()):
            target_cell = (r, c)
            print(f"Found possible target cell at ({r},{c}) with value '{val}'")
            break
    if target_cell:
        break

# 3. Identify config cells: column letter, start row, end row
col_letter_cell = None
start_row_cell = None
end_row_cell = None

for r in range(1, ws.max_row+1):
    for c in range(1, ws.max_column+1):
        val = ws.cell(row=r, column=c).value
        # column letter: single alphabetic string (A-Z)
        if isinstance(val, str) and len(val) == 1 and val.isalpha():
            col_letter_cell = (r, c, val.upper())
        # start row: integer, likely smaller
        if isinstance(val, (int, float)):
            if start_row_cell is None:
                start_row_cell = (r, c, int(val))
            else:
                # assume the larger number is end row
                if int(val) > start_row_cell[2]:
                    end_row_cell = (r, c, int(val))

# Print discovered config
print("Detected config cells:")
print("Column letter cell:", col_letter_cell)
print("Start row cell:", start_row_cell)
print("End row cell:", end_row_cell)

# If any config missing, we cannot proceed
if not (col_letter_cell and start_row_cell and end_row_cell and target_cell):
    raise RuntimeError("Could not locate all required config cells.")

# Build the SUM formula
col_letter = col_letter_cell[2]
start_row = start_row_cell[2]
end_row = end_row_cell[2]
sum_range = f"{col_letter}{start_row}:{col_letter}{end_row}"
formula = f"=SUM({sum_range})"
print(f"Writing formula '{formula}' to target cell at {target_cell}")

# Write the formula
ws.cell(row=target_cell[0], column=target_cell[1], value=formula)

# Save workbook
wb.save(output_path)

# Recalculate formulas
import asyncio
await recalculate(output_path)

# Verify the result
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
result_val = ws_check.cell(row=target_cell[0], column=target_cell[1]).value
print(f"Result after recalculation at target cell: {result_val}")

# Ensure the result is numeric
if result_val is None:
    raise RuntimeError("Result cell is empty after recalculation.")

# Done
