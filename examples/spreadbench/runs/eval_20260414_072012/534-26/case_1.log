import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_534-26_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# Gather sheet info
sheet_info = []
for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    sheet_info.append({
        "title": ws.title,
        "max_row": max_row,
        "max_col": max_col,
        "headers": headers
    })

print("Sheets info:", json.dumps(sheet_info, indent=2, default=str))

# Show sample rows for each sheet (first 5 and last 5)
