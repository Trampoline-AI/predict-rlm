Assuming today is 2026‑04‑14, the cutoff date is 2026‑04‑01. All header dates in the sheets are before this cutoff, so every date column should be removed, leaving only the first eight non‑date columns.

The plan:
1. Load the workbook.
2. For each worksheet, identify columns whose header (row 1) is a datetime and whose date < 2026‑04‑01.
3. Delete those columns, iterating from right‑most to left‑most to keep indices stable.
4. Save the modified workbook to the output directory with the same filename.
5. Call `recalculate` on the saved file, then reload to verify that only the first eight columns remain.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
from datetime import datetime
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_534-26_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_534-26_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Define cutoff: first day of current month/year
today = datetime.now()
cutoff = datetime(year=today.year, month=today.month, day=1)

for ws in wb.worksheets:
    max_col = ws.max_column
    # Determine columns to delete (store indices)
    cols_to_delete = []
    for col in range(1, max_col + 1):
        header_val = ws.cell(row=1, column=col).value
        if isinstance(header_val, datetime):
            if header_val < cutoff:
                cols_to_delete.append(col)
    # Delete from right to left
    for col_idx in sorted(cols_to_delete, reverse=True):
        ws.delete_cols(col_idx)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to check result
wb_check = openpyxl.load_workbook(output_path, data_only=True)
for ws in wb_check.worksheets:
    print(f"After deletion - sheet {ws.title}: columns = {ws.max_column}")
    # Show first row headers
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print("Headers:", headers)
```
