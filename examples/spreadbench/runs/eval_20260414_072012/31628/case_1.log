import openpyxl
from openpyxl.utils.datetime import to_excel
import os
import shutil

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_31628_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_31628_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)  # keep formulas if any
ws = wb.active  # assume first sheet

# Get the last date in column A (row 11 as max_row)
last_row = ws.max_row
last_date = ws.cell(row=last_row, column=1).value  # should be datetime
print("Last date extracted:", last_date)

# Convert to Excel serial number (float)
serial = to_excel(last_date)
print("Excel serial number:", serial)

# Write static number to B1
ws["B1"] = serial

# Save to output location
wb.save(output_path)

# Recalculate (no formulas, but follow workflow)
from predict import recalculate
await recalculate(output_path)

# Verify by reloading data_only
wb_check = openpyxl.load_workbook(output_path, data_only=True)
val = wb_check.active["B1"].value
print("Verified B1 value after recalculation:", val)
