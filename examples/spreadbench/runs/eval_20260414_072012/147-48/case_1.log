import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_147-48_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_147-48_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet

# Collect non‑empty values from column A (skip header row 1)
col_a_vals = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=1).value
    if val is not None:
        col_a_vals.append(val)

# Write transposed values starting at column C (index 3) on row 2
start_row = 2
start_col = 3  # column C
for idx, val in enumerate(col_a_vals):
    col = start_col + idx
    ws.cell(row=start_row, column=col, value=val)

# Save workbook
wb.save(output_path)

# Recalculate formulas using the provided helper (async call will be made by the environment)
# The environment will later call `await recalculate(str(output_path))` automatically after submission.

print(f"Transposed {len(col_a_vals)} values into {ws.title} starting at C{start_row}.")
