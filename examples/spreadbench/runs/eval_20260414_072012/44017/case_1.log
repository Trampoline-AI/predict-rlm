import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_44017_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_44017_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row

# Column indexes
col_Q = column_index_from_string('Q')   # baseline month 1
col_AD = column_index_from_string('AD')  # new rates month 1
col_AE = column_index_from_string('AE')
col_AF = column_index_from_string('AF')
col_AG = column_index_from_string('AG')
col_C = column_index_from_string('C')   # effective start date
col_J = column_index_from_string('J')   # frequency
col_M = column_index_from_string('M')   # increase %1
col_N = column_index_from_string('N')   # increase %2
col_O = column_index_from_string('O')   # increase %3
col_P = column_index_from_string('P')   # increase %4 (may be empty)

# Helper to build the IF‑MOD formula for a given month offset (k) and index (inc_idx)
def build_formula(row, prev_col_letter, inc_idx):
    """
    row: int row number
    prev_col_letter: letter of the previous month column (e.g., 'AD' for AE)
    inc_idx: 1‑based index into the increase columns M‑P
    """
    # Absolute references for start date and frequency
    start_date = f"C{row}"
    freq = f"J{row}"
    # Increase column for this step
    inc_col = get_column_letter(col_M + inc_idx - 1)  # M,N,O,P
    inc_cell = f"{inc_col}{row}"
    # Formula:
    # IF(MOD(DATEDIF(start_date, DATE(YEAR(start_date), MONTH(start_date)+inc_idx, 1), "M"), freq)=0,
    #    prev_cell*(1+inc_cell), prev_cell)
    prev_cell = f"{prev_col_letter}{row}"
    formula = (f"=IF(MOD(DATEDIF({start_date}, DATE(YEAR({start_date}), MONTH({start_date})+{inc_idx}, 1), \"M\"), {freq})=0, "
               f"{prev_cell}*(1+{inc_cell}), {prev_cell})")
    return formula

# Write formulas from row 14 to max_row
for r in range(14, max_row + 1):
    # Skip rows without a baseline value in column Q
    if ws.cell(row=r, column=col_Q).value is None:
        continue

    # AD = baseline month 1 (column Q)
    ws.cell(row=r, column=col_AD).value = f"=Q{r}"

    # AE (month 2) uses first increase (index 1) and refers to AD
    ws.cell(row=r, column=col_AE).value = build_formula(r, 'AD', 1)

    # AF (month 3) uses second increase (index 2) and refers to AE
    ws.cell(row=r, column=col_AF).value = build_formula(r, 'AE', 2)

    # AG (month 4) uses third increase (index 3) and refers to AF
    ws.cell(row=r, column=col_AG).value = build_formula(r, 'AF', 3)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(output_path)

# Reload with data_only to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Print a few target cells for verification
print("Verification of new rate formulas (rows 14‑18):")
for r in range(14, 19):
    vals = [ws2.cell(row=r, column=c).value for c in (col_AD, col_AE, col_AF, col_AG)]
    print(f"Row {r}: AD={vals[0]}, AE={vals[1]}, AF={vals[2]}, AG={vals[3]}")
