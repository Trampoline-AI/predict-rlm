Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_45635_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_45635_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet

# Build the formula string (using column letters dynamically)
def make_formula(col_letter):
    # Build the SUM ranges for each column B-E
    cols = ["B", "C", "D", "E"]
    sums = [f"SUM({c}2:{c}4)" for c in cols]
    max_expr = "MAX(" + ",".join(sums) + ")"
    count_expr = f"COUNTIF({{" + ",".join(sums) + "}," + max_expr + ")"
    # Formula for this specific column
    col_sum = f"SUM({col_letter}2:{col_letter}4)"
    formula = f"""=IF({col_sum}={max_expr},
    IF({count_expr}=1,6,
        IF({count_expr}=2,3,2)
    ),
    0)"""
    return formula

# Write formulas into rows 5-7, columns B-E
for row in range(5, 8):
    for col_idx in range(2, 6):  # B=2, C=3, D=4, E=5
        col_letter = get_column_letter(col_idx)
        ws.cell(row=row, column=col_idx).value = make_formula(col_letter)

# Save to output location
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify target cells after recalculation (load data_only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
verified = {}
for row in range(5, 8):
    for col_idx in range(2, 6):
        cell = ws_check.cell(row=row, column=col_idx)
        verified[(row, col_idx)] = cell.value
print("Verified target cell values (row, col): value")
for k, v in verified.items():
    print(k, v)
