        # ${col_letter} should be column A (where category name lives)
        # Compute column letter for A
        col_letter = get_column_letter(1)  # "A"
        # Insert formula
        ws_out.cell(row=r, column=col_idx).value = formula

# ---- 4. Save workbook ----
wb.save(output_path)

# ---- 5. Recalculate (LibreOffice) ----
# The environment provides a `recalculate` function; call it.
