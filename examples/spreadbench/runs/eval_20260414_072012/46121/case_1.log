for r in range(start_row, ws_out.max_row + 1):
    cat = ws_out.cell(row=r, column=1).value
    if cat is None or (isinstance(cat, str) and not cat.strip()):
        # stop when first empty category cell encountered
        break
    category_rows.append(r)

# ---- 3. Write SUMIFS formulas for each month/column ----
for r in category_rows:
    cat_cell = ws_out.cell(row=r, column=1)
    cat_name = cat_cell.value
