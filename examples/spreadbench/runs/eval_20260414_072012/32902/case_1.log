Code:
```repl
import pathlib, json, openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = pathlib.Path("/sandbox/input/input_spreadsheet/1_32902_init.xlsx")
output_dir = pathlib.Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_32902_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Determine data rows (skip header row 5)
first_data_row = 6
last_data_row = ws.max_row - 1  # row before total row (row 10)

for r in range(first_data_row, last_data_row + 1):
    income_cell = ws.cell(row=r, column=2)  # column B
    # Tier 1 formula in column C
    ws.cell(row=r, column=3).value = f"=IF({income_cell.coordinate}>60000, MIN({income_cell.coordinate}-60000,30000)*0.15, 0)"
    # Tier 2 formula in column D
    ws.cell(row=r, column=4).value = f"=IF({income_cell.coordinate}>90000, MIN({income_cell.coordinate}-90000,30000)*0.25, 0)"
    # Tier 3 formula in column E
    ws.cell(row=r, column=5).value = f"=IF({income_cell.coordinate}>120000, ({income_cell.coordinate}-120000)*0.35, 0)"

# Save workbook
wb.save(output_path)

# Recalculate formulas
calc_status = await recalculate(str(output_path))
print("Recalculate status:", calc_status)

# Reload with data_only to verify values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Print formulas (data_only=False) and computed values for rows 6-9
wb_form = openpyxl.load_workbook(output_path, data_only=False)
ws_form = wb_form.active
for r in range(first_data_row, last_data_row + 1):
    tier1 = ws_form.cell(r,3).value
    tier2 = ws_form.cell(r,4).value
    tier3 = ws_form.cell(r,5).value
    val1 = ws_check.cell(r,3).value
    val2 = ws_check.cell(r,4).value
    val3 = ws_check.cell(r,5).value
    print(f"Row {r} formulas: C={tier1}, D={tier2}, E={tier3}")
    print(f"Row {r} values: C={val1}, D={val2}, E={val3}")

# Verify total column still sums correctly (row 6‑9)
for r in range(first_data_row, last_data_row + 1):
    total = ws_check.cell(r,6).value
    print(f"Row {r} Total (F): {total}")
