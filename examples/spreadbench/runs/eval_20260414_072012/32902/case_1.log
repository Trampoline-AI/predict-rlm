import openpyxl, pathlib, json
from openpyxl.utils import get_column_letter

# Load workbook
input_path = pathlib.Path("/sandbox/input/input_spreadsheet/1_32902_init.xlsx")
wb = openpyxl.load_workbook(input_path, data_only=False)

# Gather sheet info
sheet_info = []
for ws in wb.worksheets:
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    sheet_info.append({
        "title": ws.title,
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "headers": headers,
    })

print("Sheets and headers:")
print(json.dumps(sheet_info, indent=2))

# Print sample rows for each sheet (first 5 and last 5)
for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    # first 5 data rows (row 2 onward)
    for r in range(2, min(ws.max_row, 6)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}: {row_vals}")
    # last 5 rows if more than 6 rows total
    if ws.max_row > 6:
        start = max(2, ws.max_row-4)
        for r in range(start, ws.max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
            print(f"Row {r}: {row_vals}")
