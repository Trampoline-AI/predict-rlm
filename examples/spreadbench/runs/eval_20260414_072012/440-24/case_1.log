Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_440-24_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_440-24_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Column indices
col_B = column_index_from_string('B')
col_H = column_index_from_string('H')

# Copy values from H to B for all data rows (assume header at row 1)
for r in range(2, ws.max_row + 1):
    src_val = ws.cell(row=r, column=col_H).value
    ws.cell(row=r, column=col_B).value = src_val

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and reload data_only for verification
await recalculate(output_path)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Verify first and last few rows
print("Verification (row, B, H):")
for r in [2, 3, 4, 5, ws_check.max_row-4, ws_check.max_row-3, ws_check.max_row-2, ws_check.max_row-1, ws_check.max_row]:
    b = ws_check.cell(row=r, column=col_B).value
    h = ws_check.cell(row=r, column=col_H).value
    print(r, b, h)
```
