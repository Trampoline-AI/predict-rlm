import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_48365_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
import.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_48365_init.xlsx')

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb['Dashboard']

# Identify product cell (C2) and region cells start at C11
product_cell = 'C2'
region_start_col = column_index_from_string('C')
region_row = 11
# We'll write the result in column D (next column after region)
result_col = column_index_from_string('D')

# Build formula string
# If region cell is "All", sum all regions for the product; otherwise sum for that region.
# Use absolute references for product cell and data ranges.
# Formula: =IF(C11="All",SUMIFS(Data!$C:$C,Data!$A:$A,$C$2),SUMIFS(Data!$C:$C,Data!$A:$A,$C$2,Data!$B:$B,C11))
# We'll write this formula for rows 11,12,13 (up to three selections)
for r in range(region_row, region_row+3):
    region_cell = ws.cell(row=r, column=region_start_col).coordinate
    formula = f"=IF({region_cell}=\"All\",SUMIFS(Data!$C:$C,Data!$A:$A,$C$2),SUMIFS(Data!$C:$C,Data!$A:$A,$C$2,Data!$B:$B,{region_cell}))"
    ws.cell(row=r, column=result_col).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify by loading data_only version and printing the results cells
