Code:
```repl
import os
import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_48365_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_48365_init.xlsx')

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb['Dashboard']

# Identify cells
product_cell = 'C2'                     # product selector
region_start_col = column_index_from_string('C')
region_row = 11
result_col = column_index_from_string('D')  # write results in column D

# Write formula for rows 11,12,13 (up to three region selections)
for r in range(region_row, region_row + 3):
    region_cell = ws.cell(row=r, column=region_start_col).coordinate
    formula = (
        f"=IF({region_cell}=\"All\","
        f"SUMIFS(Data!$C:$C,Data!$A:$A,$C$2),"
        f"SUMIFS(Data!$C:$C,Data!$A:$A,$C$2,Data!$B:$B,{region_cell}))"
    )
    ws.cell(row=r, column=result_col).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify results (data_only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['Dashboard']
print('Verification of result cells (column D):')
for r in range(region_row, region_row + 3):
    print(f'D{r}:', ws_check.cell(row=r, column=result_col).value)
```
