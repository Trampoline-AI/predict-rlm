Code:
```repl
import openpyxl
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_170-13_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_170-13_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws1 = wb['Sheet1']
ws2 = wb['Sheet2']
ws3 = wb['Sheet3']

# Number of data rows in Sheet2 (excluding header)
num_data_rows = ws2.max_row - 1

# Gather Sheet2 headers (column index, header string)
headers = [(c, ws2.cell(row=1, column=c).value) for c in range(1, ws2.max_column + 1) if ws2.cell(row=1, column=c).value]

# Collect new output rows to add to Sheet3
new_output_rows = []

# Process each header
for col_idx, header in headers:
    # Find rows in Sheet1 where Entry contains this header
    matching = []
    for r in range(2, ws1.max_row + 1):
        entry = ws1.cell(row=r, column=1).value
        if isinstance(entry, str) and header in entry:
            matching.append((r, entry))
    if not matching:
        continue

    # Insert rows into Sheet1 after each matching row
    offset = 0
    for orig_row, entry in matching:
        insert_at = orig_row + offset + 1  # after the original row
        ws1.insert_rows(insert_at, amount=num_data_rows)
        offset += num_data_rows

        # For each data row in Sheet2, create an output entry
        for data_r in range(2, ws2.max_row + 1):
            val = ws2.cell(row=data_r, column=col_idx).value
            if val is None:
                val = ''
            new_output_rows.append([f"{entry}{val}"])

# Append new rows to Sheet3
start_row = ws3.max_row + 1
for i, row_vals in enumerate(new_output_rows):
    for col_idx, val in enumerate(row_vals, start=1):
        ws3.cell(row=start_row + i, column=col_idx).value = val

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify Sheet3 contents
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws3_check = wb_check['Sheet3']
print('Sheet3 total rows after update:', ws3_check.max_row)
# Show the newly added rows (last N rows)
for r in range(ws3_check.max_row - len(new_output_rows) + 1, ws3_check.max_row + 1):
    print(ws3_check.cell(row=r, column=1).value)
```
