import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = '/sandbox/input/input_spreadsheet/1_170-13_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)
print('Sheets:', wb.sheetnames)

# Function to print headers and sample rows for a sheet

def inspect_sheet(name):
    ws = wb[name]
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f'\n--- {name} ---')
    print('Headers:', headers)
    # Print first 5 data rows
    rows = []
    for r in range(2, min(ws.max_row, 6)):
        rows.append([ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)])
    print('First rows:', rows)
    # Print last 5 data rows
    rows_last = []
    start = max(2, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        rows_last.append([ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)])
    print('Last rows:', rows_last)

for s in wb.sheetnames:
    inspect_sheet(s)
