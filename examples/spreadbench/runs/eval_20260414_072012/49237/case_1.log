Code:
```repl
import openpyxl
from pathlib import Path
from openpyxl.utils import get_column_letter

# Paths
in_path = Path("/sandbox/input/input_spreadsheet/1_49237_init.xlsx")
out_dir = Path("/sandbox/output/output_spreadsheet/")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / "1_49237_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(in_path)
ws = wb[wb.sheetnames[0]]

# Target cell that currently holds the initial (as observed earlier)
target_cell = "G7"

# Determine the master cell of any merged range that contains the target
master_addr = target_cell  # default if not merged
for mr in ws.merged_cells.ranges:
    if target_cell in mr:
        # Build address of top‑left cell of the merged range
        master_addr = f"{get_column_letter(mr.min_col)}{mr.min_row}"
        print(f"Found merged range {mr} for {target_cell}, master cell is {master_addr}")
        break
else:
    print(f"No merged range covering {target_cell}; using {master_addr}")

# Write the conditional period‑added initial formula to the master cell
ws[master_addr] = '=IF(F10="","",LEFT(F10)&".")'

# Save the modified workbook
wb.save(out_path)

# Recalculate formulas using LibreOffice
await recalculate(str(out_path))

# Verify the result: read the master cell and F10 (proper‑case middle name)
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print(f"{master_addr} value after recalculation:", ws_check[master_addr].value)
print("F10 (middle name proper case) after recalculation:", ws_check["F10"].value)
```
