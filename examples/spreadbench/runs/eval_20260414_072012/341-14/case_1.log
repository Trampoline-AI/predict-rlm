import openpyxl, os, json
from openpyxl.utils import column_index_from_string, get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_341-14_init.xlsx"
wb = openpyxl.load_workbook(wb_path)
print("Sheets:", wb.sheetnames)

# Identify problem and result sheets
problem_ws = wb["problem"] if "problem" in wb.sheetnames else None
result_ws = wb["result"] if "result" in wb.sheetnames else None
print("Problem sheet:", problem_ws.title if problem_ws else None)
print("Result sheet:", result_ws.title if result_ws else None)

# Show headers for both sheets (first row)
def show_headers(ws):
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    return headers

print("Problem headers:", show_headers(problem_ws))
print("Result headers:", show_headers(result_ws))

# Sample rows from problem sheet
def sample_rows(ws, n=5):
    rows = []
    for r in range(2, min(ws.max_row+1, n+2)):
        rows.append([ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)])
    return rows

print("Problem first rows:", sample_rows(problem_ws, 5))
# Last rows
def last_rows(ws, n=5):
    start = max(2, ws.max_row - n + 1)
    rows = []
    for r in range(start, ws.max_row+1):
        rows.append([ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)])
    return rows

print("Problem last rows:", last_rows(problem_ws,5))

# Determine transposition: assume column A is identifier, column B is value.
# In result sheet we will write identifiers horizontally starting at A2, values below them.
# Preserve existing cells that are already filled (do not overwrite non‑empty cells).

# Gather data from problem sheet
data = []
for r in range(2, problem_ws.max_row+1):
    id_val = problem_ws.cell(row=r, column=1).value
    num_val = problem_ws.cell(row=r, column=2).value
    data.append((id_val, num_val))

# Write to result sheet: first row (row1) maybe headers, we start at row2 for identifiers.
row_start = 2
col_start = 1  # A
for idx, (id_val, num_val) in enumerate(data):
    col = col_start + idx
    # identifier cell
    id_cell = result_ws.cell(row=row_start, column=col)
    if not id_cell.value:
        id_cell.value = id_val
    # number cell (row below)
    num_cell = result_ws.cell(row=row_start+1, column=col)
    if not num_cell.value:
        num_cell.value = num_val

# Save to output path
out_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, "1_341-14_init.xlsx")
wb.save(out_path)
print("Saved to", out_path)

# Recalculate (LibreOffice)
from openpyxl import load_workbook
recalculate(out_path)
# reload to verify
