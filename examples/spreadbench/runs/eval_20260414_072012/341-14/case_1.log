Code:
```repl
import os, openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_341-14_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, "1_341-14_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(in_path)
problem_ws = wb["problem"]
result_ws = wb["result"]

# Helper to show a small region of a sheet
def show_region(ws, start_row, start_col, rows, cols):
    data = []
    for r in range(start_row, start_row + rows):
        row = []
        for c in range(start_col, start_col + cols):
            row.append(ws.cell(row=r, column=c).value)
        data.append(row)
    return data

print("Result sheet first 5 rows, 8 columns:")
print(show_region(result_ws, 1, 1, 5, 8))

# Gather data from problem sheet (skip header row)
pairs = []
for r in range(2, problem_ws.max_row + 1):
    id_val = problem_ws.cell(row=r, column=1).value
    num_val = problem_ws.cell(row=r, column=2).value
    # Only consider rows where at least one of the two cells is not None
    if id_val is not None or num_val is not None:
        pairs.append((id_val, num_val))

# Write transposed data into result sheet
# Start at row 2 for identifiers, row 3 for values
id_row = 2
val_row = 3
for idx, (id_val, num_val) in enumerate(pairs):
    col = idx + 1  # column A = 1, B = 2, etc.
    # Identifier cell
    id_cell = result_ws.cell(row=id_row, column=col)
    if id_cell.value in (None, ""):
        id_cell.value = id_val
    # Value cell (directly below)
    val_cell = result_ws.cell(row=val_row, column=col)
    if val_cell.value in (None, ""):
        val_cell.value = num_val

# Save workbook
wb.save(out_path)
print("Workbook saved to", out_path)

# Recalculate formulas (LibreOffice)
await recalculate(out_path)

# Reload with data_only to verify a few cells
wb_check = openpyxl.load_workbook(out_path, data_only=True)
res_check = wb_check["result"]
print("Result sheet after transposition (first 2 rows, 10 columns):")
print(show_region(res_check, 1, 1, 2, 10))
```
