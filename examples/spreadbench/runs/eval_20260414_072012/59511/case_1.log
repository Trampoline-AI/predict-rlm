max_col = ws.max_column

# Identify column index for B and F (B=2, F=6)
col_B = 2
col_F = 6

# Write formula into column F where empty or error
for r in range(2, max_row + 1):
    cell_F = ws.cell(row=r, column=col_F)
    # Skip if cell already has a non‑None value
    if cell_F.value is not None:
        continue
    # Write formula using relative row reference
    cell_F.value = f"=INT(B{r}/1000)"

# Ensure output directory exists
