import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_493-18_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_493-18_init.xlsx")

# Load workbook (keep all features, including autofilter)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume single sheet

# 1. Gather allowed values from column F (index 6)
allowed = set()
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=column_index_from_string('F')).value
    if val is not None:
        allowed.add(val)

# 2. Clear A‑C where A not in allowed
col_a = column_index_from_string('A')
col_b = column_index_from_string('B')
col_c = column_index_from_string('C')
for r in range(2, ws.max_row + 1):
    a_val = ws.cell(row=r, column=col_a).value
    if a_val not in allowed:
        ws.cell(row=r, column=col_a).value = None
        ws.cell(row=r, column=col_b).value = None
        ws.cell(row=r, column=col_c).value = None

# 3. Delete rows that are now completely blank in A‑C
# Iterate from bottom to top to avoid index shift when deleting
for r in range(ws.max_row, 1, -1):
    a = ws.cell(row=r, column=col_a).value
    b = ws.cell(row=r, column=col_b).value
    c = ws.cell(row=r, column=col_c).value
    if a is None and b is None and c is None:
        ws.delete_rows(r, 1)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Verify: reload with data_only to see computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("After processing:")
print("Rows:", ws_check.max_row)
for r in range(2, ws_check.max_row + 1):
    print(r, [ws_check.cell(row=r, column=c).value for c in (col_a, col_b, col_c, column_index_from_string('F'))])
