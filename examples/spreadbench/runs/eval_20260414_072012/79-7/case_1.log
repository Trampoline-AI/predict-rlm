```repl
import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_79-7_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_79-7_init.xlsx")

# Load workbook (keep formulas if any)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming the target sheet is the active one

# Iterate over all used cells and strip double quotes
for row in ws.iter_rows(min_row=1, max_row=ws.max_row,
                        min_col=1, max_col=ws.max_column):
    for cell in row:
        if isinstance(cell.value, str):
            # Replace all double‑quote characters
            new_val = cell.value.replace('"', '')
            if new_val != cell.value:
                cell.value = new_val

# Save modified workbook
wb.save(output_path)

# Recalculate formulas (if any) and ensure sheet names stay the same
from recalculate import recalculate
await recalculate(output_path)

# Reload with data_only=True to verify changes
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Verify that no cell contains a double‑quote
issues = []
for row in ws_check.iter_rows(min_row=1, max_row=ws_check.max_row,
                             min_col=1, max_col=ws_check.max_column):
    for cell in row:
        if isinstance(cell.value, str) and '"' in cell.value:
            issues.append((cell.coordinate, cell.value))

print("Verification issues (should be empty):", issues)
