import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_477-45_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_477-45_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Build aggregation dictionary
agg = {}  # key: (ID, Brand, type) -> sum of Total
for row in range(2, ws.max_row + 1):
    id_val = ws.cell(row=row, column=1).value
    brand = ws.cell(row=row, column=2).value
    typ = ws.cell(row=row, column=3).value
    total = ws.cell(row=row, column=4).value
    # Treat None as 0 for summing
    total = total if isinstance(total, (int, float)) else 0
    key = (id_val, brand, typ)
    agg[key] = agg.get(key, 0) + total

# Write headers starting at G1 (columns 7‑10)
headers = ["ID", "Brand", "type", "Sum"]
for i, hdr in enumerate(headers, start=7):  # column G is 7
    ws.cell(row=1, column=i, value=hdr)

# Write aggregated rows starting at G2
out_row = 2
for (id_val, brand, typ), sum_val in agg.items():
    ws.cell(row=out_row, column=7, value=id_val)   # G
    ws.cell(row=out_row, column=8, value=brand)    # H
    ws.cell(row=out_row, column=9, value=typ)      # I
    ws.cell(row=out_row, column=10, value=sum_val) # J
    out_row += 1

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to check a output cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification of first few result rows:")
for r in range(2, min(7, ws_check.max_row + 1)):
    print([ws_check.cell(row=r, column=c).value for c in range(7, 11)])
