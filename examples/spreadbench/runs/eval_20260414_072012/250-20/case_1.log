import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_250-20_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_250-20_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = load_workbook(input_path)
ws = wb["RNM"]

# Determine the actual data range (ignore trailing empty rows)
max_row = ws.max_row
max_col = ws.max_column

# Build groups by (NUMBER, LINE NO) -> list of row indices
from collections import defaultdict

groups = defaultdict(list)
for r in range(2, max_row + 1):
    number = ws.cell(row=r, column=2).value  # Column B
    line_no = ws.cell(row=r, column=3).value  # Column C
    # Stop if both are None (likely past data)
    if number is None and line_no is None:
        continue
    groups[(number, line_no)].append(r)

rows_to_delete = []
for key, rows in groups.items():
    if not rows:
        continue
    # Compute sum of MATCHED_QTY (column 10) for this group
    total = 0
    for r in rows:
        val = ws.cell(row=r, column=10).value
        if isinstance(val, (int, float)):
            total += val
    # Write sum into the first row's column J
    first_row = rows[0]
    ws.cell(row=first_row, column=10, value=total)
    # Mark remaining rows for deletion
    rows_to_delete.extend(rows[1:])

# Delete rows from bottom to top to keep indices stable
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload to verify that column J values are present (data_only=True)
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check["RNM"]
print("Verification sample after processing:")
for r in range(2, min(12, ws_check.max_row + 1)):
    print(r, ws_check.cell(row=r, column=2).value, ws_check.cell(row=r, column=3).value, ws_check.cell(row=r, column=10).value)
