        if name.lower() == target_sheet_name.lower():
            target_sheet_name = name
            break

ws = wb[target_sheet_name]

# Determine column index for C (should be 3)
col_c = 3

# Delete rows from bottom to top where C is blank or -1 ≤ value ≤ 1
for row in range(ws.max_row, 1, -1):  # skip header row 1
    cell = ws.cell(row=row, column=col_c)
    val = cell.value
    delete = False
    if val is None:
        delete = True
    else:
        # Try numeric comparison; ignore non‑numeric values
        try:
            if -1 <= float(val) <= 1:
                delete = True
        except (TypeError, ValueError):
            pass
    if delete:
        ws.delete_rows(row, 1)

