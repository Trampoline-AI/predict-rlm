import openpyxl
from openpyxl.utils import get_column_letter
import os

input_path = "/sandbox/input/input_spreadsheet/1_48969_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_48969_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # only one sheet

# Locate the "Result" column (header row is 1)
header_row = 1
result_col = None
for col in range(1, ws.max_column + 1):
    if ws.cell(row=header_row, column=col).value == "Result":
        result_col = col
        break
if result_col is None:
    raise ValueError("Could not find a column with header 'Result'")

# Helper to read a block of data rows and return a dict: city -> list of numeric values (cols C-G)
def read_block(start_row, end_row):
    data = {}
    for r in range(start_row, end_row + 1):
        city = ws.cell(row=r, column=2).value  # column B
        if not city:
            continue
        nums = []
        for c in range(3, 8):  # columns C to G
            val = ws.cell(row=r, column=c).value
            nums.append(val)
        data[city] = nums
    return data

# Identify the two blocks based on observed layout
# Source 1: rows 3‑5 (after header row 1 and blank row 2)
source1_start, source1_end = 3, 5
# Source 2: rows 8‑10 (after blank row 6 and header row 7)
source2_start, source2_end = 8, 10

source1_data = read_block(source1_start, source1_end)
source2_data = read_block(source2_start, source2_end)

# Write result for Source 1 rows
for r in range(source1_start, source1_end + 1):
    city = ws.cell(row=r, column=2).value
    match = False
    if city in source2_data:
        match = source1_data[city] == source2_data[city]
    # Write Boolean as Excel TRUE/FALSE (openpyxl will store Python bool)
    ws.cell(row=r, column=result_col).value = match

# Write result for Source 2 rows
for r in range(source2_start, source2_end + 1):
    city = ws.cell(row=r, column=2).value
    match = False
    if city in source1_data:
        match = source2_data[city] == source1_data[city]
    ws.cell(row=r, column=result_col).value = match

# Save to output directory
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate (no formulas, but call to satisfy workflow)
await recalculate(output_path)

# Verify results by loading with data_only
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Result values after processing:")
for r in [source1_start, source1_start+1, source1_end,
          source2_start, source2_start+1, source2_end]:
    val = ws_check.cell(row=r, column=result_col).value
    print(f"Row {r}: {val}")
