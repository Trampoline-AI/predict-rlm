import openpyxl
from openpyxl.utils import get_column_letter
import os

input_path = "/sandbox/input/input_spreadsheet/1_48969_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_48969_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # only one sheet

# Find the column index for header "Result"
header_row = 1
result_col = None
for col in range(1, ws.max_column + 1):
    if ws.cell(row=header_row, column=col).value == "Result":
        result_col = col
        break
if result_col is None:
    raise ValueError("Could not locate a 'Result' header")

# Helper to generate formula for a given row and lookup block
def formula_for_row(row, lookup_start, lookup_end):
    # City column is B (2)
    city_cell = f"B{row}"
    # Numeric columns C-G are 3-7
    # Build comparisons using INDEX/MATCH for each numeric column
    comps = []
    for offset, src_col in enumerate(range(3, 8), start=1):  # offset 1..5
        # Lookup range for numeric values
        lookup_range = f"${get_column_letter(3)}${lookup_start}:${get_column_letter(7)}${lookup_end}"
        # MATCH to find the row index of the city in the lookup block
        match_expr = f"MATCH({city_cell},${get_column_letter(2)}${lookup_start}:${get_column_letter(2)}${lookup_end},0)"
        # INDEX to fetch the value from the appropriate column (offset)
        index_expr = f"INDEX({lookup_range},{match_expr},{offset})"
        # Compare to the current row's value in the same column
        comps.append(f"{index_expr}={get_column_letter(src_col)}{row}")
    # Combine with AND and wrap with IFERROR
    return f"=IFERROR(AND({', '.join(comps)}),FALSE)"

# Source 1 rows (3-5) lookup in Source 2 block (rows 8-10)
for r in range(3, 6):
    ws.cell(row=r, column=result_col).value = formula_for_row(r, 8, 10)

# Source 2 rows (8-10) lookup in Source 1 block (rows 3-5)
for r in range(8, 11):
    ws.cell(row=r, column=result_col).value = formula_for_row(r, 3, 5)

# Ensure output directory exists and save
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

