import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_55427_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_55427_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Target sheet name (as observed)
sheet_name = "Compiled and located schools da"
ws = wb[sheet_name]

# Iterate over rows starting at 2
for row in range(2, ws.max_row + 1):
    cell_b = ws.cell(row=row, column=2)  # column B
    # Only replace if it is a formula starting with =INDEX(
    if isinstance(cell_b.value, str) and cell_b.value.lstrip().upper().startswith("=INDEX("):
        # Build new formula using the row number
        new_formula = f"=INDEX('URN lookup'!$D$2:$D$1461,MATCH(TRIM(UPPER(L{row})),TRIM(UPPER('URN lookup'!$K$2:$K$1461)),0))"
        cell_b.value = new_formula

# Save to output location
wb.save(output_path)

# Recalculate (LibreOffice compatible)
recalculate(output_path)

