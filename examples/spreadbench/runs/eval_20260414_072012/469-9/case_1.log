```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Write headers in H (8) and I (9)
ws.cell(row=1, column=8, value="Debits")
ws.cell(row=1, column=9, value="Credits")

# Process each data row
for r in range(2, ws.max_row + 1):
    amt = ws.cell(row=r, column=3).value  # column C
    # Clear any existing values in H and I first
    ws.cell(row=r, column=8, value=None)
    ws.cell(row=r, column=9, value=None)
    if isinstance(amt, (int, float)):
        if amt > 0:
            ws.cell(row=r, column=8, value=abs(amt))
        elif amt < 0:
            ws.cell(row=r, column=9, value=abs(amt))
        # amt == 0 -> leave both blank
    # else: non‑numeric or None -> leave blank

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and verify a few rows
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to see computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Headers after write:", [ws_check.cell(row=1, column=c).value for c in range(1, 10)])
print("Sample rows after processing (C, H, I):")
for r in range(2, min(7, ws_check.max_row + 1)):
    c_val = ws_check.cell(row=r, column=3).value
    h_val = ws_check.cell(row=r, column=8).value
    i_val = ws_check.cell(row=r, column=9).value
    print(r, c_val, h_val, i_val)
