import openpyxl
from openpyxl.utils import column_index_from_string
import os
import math

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50683_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_50683_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Identify header row and target column
header_row = 1
headers = [ws.cell(row=header_row, column=c).value for c in range(1, ws.max_column + 1)]
# Find column index for "last 4 trend"
target_col = None
for idx, h in enumerate(headers, start=1):
    if isinstance(h, str) and h.strip().lower() == "last 4 trend":
        target_col = idx
        break
if target_col is None:
    raise ValueError("Could not find column header 'last 4 trend'")

# Date score columns are from column 2 up to column before "Average"
# Find column of "Average" to know end of score columns
avg_col = None
for idx, h in enumerate(headers, start=1):
    if isinstance(h, str) and h.strip().lower() == "average":
        avg_col = idx
        break
if avg_col is None:
    raise ValueError("Could not find column header 'Average'")
score_start = 2
score_end = avg_col - 1  # inclusive

# Process each player row
for row in range(2, ws.max_row + 1):
    # Collect scores
    scores = []
    for col in range(score_start, score_end + 1):
        val = ws.cell(row=row, column=col).value
        if isinstance(val, (int, float)):
            scores.append(val)
    # Take last four scores
    last_four = scores[-4:] if len(scores) >= 4 else scores
    # Compute average if we have at least one score
    if last_four:
        avg_last4 = sum(last_four) / len(last_four)
        # Round to two decimals (optional)
        avg_last4 = round(avg_last4, 2)
        ws.cell(row=row, column=target_col).value = avg_last4
    else:
        ws.cell(row=row, column=target_col).value = None

# Save to output path
wb.save(output_path)

# Recalculate formulas
from __future__ import annotations
await recalculate(output_path)

# Verify by reloading data_only
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of 'last 4 trend' values:")
for row in range(2, ws_check.max_row + 1):
    val = ws_check.cell(row=row, column=target_col).value
    print(f"Row {row}: {val}")

# Done
