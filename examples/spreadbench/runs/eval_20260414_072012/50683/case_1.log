import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_50683_init.xlsx"
wb = openpyxl.load_workbook(wb_path)
print("Sheets:", wb.sheetnames)

# Assume primary sheet is the first one
