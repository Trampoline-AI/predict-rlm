import openpyxl, os, string
from openpyxl.utils import get_column_letter

# Paths
in_path = '/sandbox/input/input_spreadsheet/1_57693_init.xlsx'
out_dir = '/sandbox/output/output_spreadsheet/'
out_path = os.path.join(out_dir, '1_57693_init.xlsx')

# Load workbook
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Identify the column that holds the text strings. From inspection it's column D (4).
text_col = 4
output_col = text_col + 1  # column E

# Ensure the output column exists (openpyxl will create cells as needed)

# Helper to count letters in a string

def count_letters(s: str):
    s = s.lower()
    counts = {ch: 0 for ch in string.ascii_lowercase}
    for ch in s:
        if ch in counts:
            counts[ch] += 1
    # Build a compact representation, omitting letters with zero count
    parts = [f"{ch}:{counts[ch]}" for ch in string.ascii_lowercase if counts[ch] > 0]
    return " ".join(parts)

# Process each row with data in the text column
for r in range(2, ws.max_row + 1):
    cell = ws.cell(row=r, column=text_col)
    val = cell.value
    if isinstance(val, str) and val:
        result = count_letters(val)
        ws.cell(row=r, column=output_col, value=result)
    else:
        # leave output cell blank if no string
        ws.cell(row=r, column=output_col, value=None)

# Save to output location
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)

# Recalculate formulas (none added, but required by workflow)
await recalculate(out_path)

# Verify a few rows
print('Sample results:')
for r in range(5, 8):
    print(r, ws.cell(row=r, column=text_col).value, '->', ws.cell(row=r, column=output_col).value)
