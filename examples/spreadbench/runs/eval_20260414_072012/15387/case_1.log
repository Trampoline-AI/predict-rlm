```repl
import openpyxl
from pathlib import Path

# Paths
in_path = Path('/sandbox/input/input_spreadsheet/1_15387_init.xlsx')
out_dir = Path('/sandbox/output/output_spreadsheet/')
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / '1_15387_init.xlsx'

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Write the TEXTJOIN formula into A13
# The formula joins the headers from B3:F3 where the corresponding B1:F1 cell equals 0.
# LibreOffice needs the _xlfn. prefix for TEXTJOIN.
ws['A13'].value = "=_xlfn.TEXTJOIN(\", \", TRUE, IF(B1:F1=0, $B$3:$F$3, \"\"))"

# Save workbook to output location
wb.save(out_path)

# Recalculate formulas using the provided tool
result = await recalculate(str(out_path))
print('Recalculate result:', result)

# Reload with data_only to verify the computed value
wb2 = openpyxl.load_workbook(out_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print('A13 value after recalculation:', ws2['A13'].value)
```
