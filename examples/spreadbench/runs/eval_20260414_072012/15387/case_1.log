Code:
```repl
import openpyxl
from pathlib import Path

# Paths
in_path = Path('/sandbox/input/input_spreadsheet/1_15387_init.xlsx')
out_dir = Path('/sandbox/output/output_spreadsheet/')
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / '1_15387_init.xlsx'

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine columns B (2) to F (6)
header_vals = []
for col in range(2, 7):  # 2..6 inclusive
    input_cell = ws.cell(row=1, column=col)
    header_cell = ws.cell(row=3, column=col)
    if input_cell.value == 0:
        header_vals.append(str(header_cell.value))

# Join with comma and space
joined = ", ".join(header_vals)

# Write the literal result into A13
ws['A13'].value = joined

# Save to output location
wb.save(out_path)

# Recalculate (no formulas to evaluate for this literal, but keep workflow)
result = await recalculate(str(out_path))
print('Recalculate result:', result)

# Reload with data_only to verify
wb2 = openpyxl.load_workbook(out_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print('A13 value after recalculation:', ws2['A13'].value)
```
