import openpyxl
from openpyxl.utils import get_column_letter

# Paths
inp_path = "/sandbox/input/input_spreadsheet/1_12864_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_12864_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(inp_path, data_only=False)

# Helper to scan a wide column range for a sheet and return headers
def get_headers(ws, max_check_col=20):
    headers = []
    for col in range(1, max_check_col + 1):
        val = ws.cell(row=1, column=col).value
        if val is None:
            # stop at first empty header (common pattern)
            break
        headers.append(val)
    return headers

# Inspect Sheet2 for hidden/extra columns
ws2 = wb["Sheet2"]
headers2 = get_headers(ws2, max_check_col=20)
print("Sheet2 headers (up to col 20):", headers2)

# Add new columns to Sheet1 for results
ws1 = wb["Sheet1"]
# Determine current max column
max_col1 = ws1.max_column
# New headers
new_headers = ["Matched Date", "Matched Column B", "Matched Column C"]
for i, hdr in enumerate(new_headers, start=1):
    col_idx = max_col1 + i
    ws1.cell(row=1, column=col_idx, value=hdr)

# Write Index/Match formulas for each data row in Sheet1
for row in range(2, ws1.max_row + 1):
    # Cell in column D (Existing Data Fields) to match
    match_cell = ws1.cell(row=row, column=4).coordinate  # D{row}
    # Formulas for the three new columns
    # Matched Date -> Sheet2!B:B
    formula_date = f'=IFERROR(INDEX(Sheet2!B:B, MATCH({match_cell}, Sheet2!A:A, 0)), "")'
    # Matched Column B -> Sheet2!C:C
    formula_colB = f'=IFERROR(INDEX(Sheet2!C:C, MATCH({match_cell}, Sheet2!A:A, 0)), "")'
    # Matched Column C -> Sheet2!D:D
    formula_colC = f'=IFERROR(INDEX(Sheet2!D:D, MATCH({match_cell}, Sheet2!A:A, 0)), "")'
    ws1.cell(row=row, column=max_col1 + 1, value=formula_date)
    ws1.cell(row=row, column=max_col1 + 2, value=formula_colB)
    ws1.cell(row=row, column=max_col1 + 3, value=formula_colC)

# Ensure output directory exists
import os
os.makedirs(out_dir, exist_ok=True)

# Save workbook
wb.save(out_path)
print("Workbook saved to", out_path)

# Recalculate formulas
calc_result = await recalculate(out_path)
print("Recalculate result:", calc_result)

# Reload with data_only to verify a few rows
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("Verification (first 5 data rows, new columns):")
for r in range(2, min(7, ws_check.max_row + 1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(max_col1 + 1, max_col1 + 4)]
    print(f"Row {r}:", vals)
