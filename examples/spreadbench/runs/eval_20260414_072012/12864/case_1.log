import openpyxl
from openpyxl.utils import get_column_letter

inp_path = "/sandbox/input/input_spreadsheet/1_12864_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_12864_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(inp_path, data_only=False)

# Helper to get values from a column range for a sheet
def column_has_data(ws, col_idx, start_row=2, end_row=None):
    if end_row is None:
        end_row = ws.max_row
    for r in range(start_row, end_row + 1):
        if ws.cell(row=r, column=col_idx).value is not None:
            return True
    return False

ws2 = wb["Sheet2"]
max_row2 = ws2.max_row

# Scan columns A (Z (1‑26) for any data beyond the first two columns
found_columns = {}
for col_idx in range(1, 27):
    has_data = column_has_data(ws2, col_idx, start_row=2, end_row=max_row2)
    header = ws2.cell(row=1, column=col_idx).value
    if has_data:
        col_letter = get_column_letter(col_idx)
        found_columns[col_letter] = {"header": header, "has_data": has_data}
        # Print a few sample values from this column
        samples = [ws2.cell(row=r, column=col_idx).value for r in range(2, min(7, max_row2+1))]
        print(f"Column {col_letter}: header={header!r}, samples={samples}")

print("All discovered data columns:", found_columns)

# Determine target columns for lookup based on discovered data
# Expected: Column A = Existing Data Fields (key), Column B = Date, Column C = Data B, Column D = Data C
# If columns C/D are missing, we will still write formulas that may return blank.

# Add result columns to Sheet1 (if not already present)
ws1 = wb["Sheet1"]
max_col1 = ws1.max_column
result_headers = ["Matched Date", "Matched Col B", "Matched Col C"]
for i, hdr in enumerate(result_headers, start=1):
    col_idx = max_col1 + i
    ws1.cell(row=1, column=col_idx, value=hdr)

# Write formulas for each data row in Sheet1
for row in range(2, ws1.max_row + 1):
    match_cell = ws1.cell(row=row, column=4).coordinate  # D{row}
    # Formulas reference Sheet2 columns A (key), B (date), C, D
    formula_date = f'=IFERROR(INDEX(Sheet2!B:B, MATCH({match_cell}, Sheet2!A:A, 0)), "")'
    formula_colB = f'=IFERROR(INDEX(Sheet2!C:C, MATCH({match_cell}, Sheet2!A:A, 0)), "")'
    formula_colC = f'=IFERROR(INDEX(Sheet2!D:D, MATCH({match_cell}, Sheet2!A:A, 0)), "")'
    ws1.cell(row=row, column=max_col1 + 1, value=formula_date)
    ws1.cell(row=row, column=max_col1 + 2, value=formula_colB)
    ws1.cell(row=row, column=max_col1 + 3, value=formula_colC)

# Save to output directory
import os
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)
print("Saved workbook to", out_path)

# Recalculate formulas
calc_res = await recalculate(out_path)
print("Recalculate:", calc_res)

# Verify first few rows of the new columns (data_only)
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("Verification (first 5 rows, new columns):")
for r in range(2, min(7, ws_check.max_row + 1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(max_col1 + 1, max_col1 + 4)]
    print(f"Row {r}:", vals)
