import openpyxl
from pathlib import Path

# Load the workbook
wb_path = Path("/sandbox/input/input_spreadsheet/1_59196_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=False)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# 2. For each sheet, inspect headers and sample rows
for ws in wb.worksheets:
    print("\n=== Sheet:", ws.title, "===")
    # Assume first row is header
    headers = [cell.value for cell in ws[1]]
    print("Headers:", headers)
    
    max_row = ws.max_row
    max_col = ws.max_column
    
    # Print first 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(r, row_vals)
    
    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row - 4)
    for r in range(start, max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(r, row_vals)
