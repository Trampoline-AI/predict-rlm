Code:
```python
import openpyxl
from openpyxl.styles import Font, PatternFill
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_47827_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_47827_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Column indices
col_b = column_index_from_string('B')
col_c = column_index_from_string('C')
col_d = column_index_from_string('D')
col_g = column_index_from_string('G')

# Styles
bold_font = Font(bold=True)
fill = PatternFill(start_color="EBF1DE", end_color="EBF1DE", fill_type="solid")

# Process rows
for r in range(2, ws.max_row + 1):
    # Read three numbers; treat None as 0
    vals = []
    for col in (col_b, col_c, col_d):
        v = ws.cell(row=r, column=col).value
        if v is None:
            v = 0
        # Ensure integer
        try:
            v = int(v)
        except Exception:
            v = 0
        vals.append(v)
    # Sort and concatenate as three‑digit string
    sorted_vals = sorted(vals)
    three_digit = "".join(f"{v:01d}" for v in sorted_vals)  # each number already 0‑9 in data
    # Write to column G
    target_cell = ws.cell(row=r, column=col_g)
    target_cell.value = three_digit
    # Apply bold and fill
    target_cell.font = bold_font
    target_cell.fill = fill

# Ensure output directory exists
import os
os.makedirs(output_dir, exist_ok=True)

# Save output
wb.save(output_path)

# Recalculate (LibreOffice)
from openpyxl import load_workbook
recalculate(output_path)
```
