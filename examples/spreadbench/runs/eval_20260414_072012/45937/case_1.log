import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_45937_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_45937_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine last row with data (max_row is fine here)
last_row = ws.max_row

# Write formula into column E (5) for rows 7 to last_row
for r in range(7, last_row + 1):
    # Skip rows that are completely empty in column D (no category)
    if ws.cell(row=r, column=4).value is None:
        continue
    formula = f"=INDEX($H$20:$N$22, MATCH(D{r},$H$18:$N$18,0), MATCH(D{r},$H$18:$N$18,0))"
    ws.cell(row=r, column=5).value = formula

# Ensure output directory exists
import os
