import os
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.styles import Font, Alignment

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_53449_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = os.path.join(out_dir, "1_53449_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(in_path)
ws = wb.active  # only one sheet

# Identify the Procedure Category ID column (header contains that phrase)
proc_col = None
for col in range(1, ws.max_column + 1):
    hdr = ws.cell(row=1, column=col).value
    if isinstance(hdr, str) and "Procedure Category ID".lower() in hdr.lower():
        proc_col = col
        break
if proc_col is None:
    raise ValueError("Could not find 'Procedure Category ID' column")

# Insert new column after the Procedure Category ID column
new_col_idx = proc_col + 1
ws.insert_cols(new_col_idx)

# Set header for the new column
header_cell = ws.cell(row=1, column=new_col_idx)
header_cell.value = "Test"

# Copy column width from the previous column (proc_col) to the new column
prev_width = ws.column_dimensions[get_column_letter(proc_col)].width
if prev_width is not None:
    ws.column_dimensions[get_column_letter(new_col_idx)].width = prev_width

# Copy basic font and alignment from the previous header cell (safe to copy)
ref_header = ws.cell(row=1, column=proc_col)
if isinstance(ref_header.font, Font):
    header_cell.font = ref_header.font
if isinstance(ref_header.alignment, Alignment):
    header_cell.alignment = ref_header.alignment

# Fill the new column rows
for r in range(2, ws.max_row + 1):
    proc_cell = ws.cell(row=r, column=proc_col)
    test_cell = ws.cell(row=r, column=new_col_idx)
    # Determine if the Procedure Category ID contains "Covid"
    if isinstance(proc_cell.value, str) and "covid" in proc_cell.value.lower():
        test_cell.value = "X"
    else:
        test_cell.value = ""  # explicit blank

# Ensure output directory exists
os.makedirs(out_dir, exist_ok=True)

# Save workbook
wb.save(out_path)

# Recalculate formulas (if any) and reload for verification
await recalculate(out_path)
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check.active

# Verify header and a few rows
print("Header:", ws_check.cell(row=1, column=new_col_idx).value)
for r in range(2, min(ws_check.max_row, 7)):
