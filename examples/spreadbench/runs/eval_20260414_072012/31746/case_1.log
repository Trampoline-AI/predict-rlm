month_numbers = {}
header_row = 2  # month labels are in row 2
for col in month_cols:
    header = ws.cell(row=header_row, column=col).value
    if isinstance(header, str) and "Month" in header:
        try:
            month = int(header.split()[-1])
            month_numbers[col] = month
        except Exception:
            pass

# Verify we found month numbers
print("Month columns parsed:", {get_column_letter(c): m for c, m in month_numbers.items()})

# Data rows are 3 through 37 (row 38 holds totals)
data_start = 3
data_end = 37  # fixed based on observed layout

for r in range(data_start, data_end + 1):
    parts = []
    for col, month in month_numbers.items():
        factor = 81 - (month - 1)  # 81 - (month-1)
        cell_ref = f"{get_column_letter(col)}{r}"
        parts.append(f"{cell_ref}*{factor}")
    formula = "=" + "+".join(parts)
    ws.cell(row=r, column=17).value = formula  # column Q is 17

# Grand total in Q38
ws.cell(row=38, column=17).value = f"=SUM(Q{data_start}:Q{data_end})"

# Ensure output directory exists and save
