```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_31746_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_31746_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb.active  # Sheet1

# Identify month columns (D to P -> columns 4 to 16)
month_cols = list(range(4, 17))  # 4..16 inclusive
month_numbers = {}
for col in month_cols:
    header = ws.cell(row=1, column=col).value
    # header like "Month 12"
    if isinstance(header, str) and "Month" in header:
        try:
            month = int(header.split()[-1])
            month_numbers[col] = month
        except:
            pass

# Build formulas for each data row (rows 3 to max_row-1, assuming last row is totals)
max_row = ws.max_row
data_start = 3
data_end = max_row - 1  # row 38 is totals, so data ends at 37

for r in range(data_start, data_end + 1):
    parts = []
    for col, month in month_numbers.items():
        factor = 81 - (month - 1)  # 81 - (month-1)
        cell_ref = f"{get_column_letter(col)}{r}"
        parts.append(f"{cell_ref}*{factor}")
    formula = "=" + "+".join(parts)
    ws.cell(row=r, column=17).value = formula  # column Q is 17

# Grand total in Q38
ws.cell(row=max_row, column=17).value = f"=SUM(Q{data_start}:Q{data_end})"

# Save to output directory
import os
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)

# Recalculate formulas
await recalculate(out_path)

# Verify a few cells
print("Sample formulas written:")
for r in range(data_start, data_start+3):
    print(f"Row {r} Q{r}:", ws.cell(row=r, column=17).value)
print("Grand total formula:", ws.cell(row=max_row, column=17).value)
```
