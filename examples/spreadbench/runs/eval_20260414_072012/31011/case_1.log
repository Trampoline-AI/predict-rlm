import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_31011_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = output_dir + '1_31011_init.xlsx'

