import openpyxl
import os
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_416-27_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_416-27_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (write mode)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume single sheet

# Determine last used row in column A
last_row = ws.max_row
while last_row > 1 and ws.cell(row=last_row, column=1).value is None:
    last_row -= 1

# Starting row (user says start from the row where first value appears; first value is at row 3, so start at row 4)
start_row = 4

# Delete blank rows in column A, looping backwards
for r in range(last_row, start_row - 1, -1):
    val = ws.cell(row=r, column=1).value
    if val is None or (isinstance(val, str) and val.strip() == ""):
        ws.delete_rows(r, 1)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
recalculate(output_path)

# Reload to verify (data_only to see computed values)
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Print a few rows around where blanks used to be
print("Rows after deletion (showing rows 1‑10):")
for r in range(1, min(ws_check.max_row, 10) + 1):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column + 1)]
    print(r, row_vals)

print("Last 5 rows after deletion:")
for r in range(max(ws_check.max_row - 4, 1), ws_check.max_row + 1):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column + 1)]
    print(r, row_vals)
