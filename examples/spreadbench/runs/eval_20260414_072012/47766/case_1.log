import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_47766_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_47766_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Column indices (1‑based)
col_date = 6   # F
col_prod = 3   # C

# Define the range for production and dates (cover all data rows)
first_data_row = 8   # data starts at row 8 (row 7 is header for formulas)
last_row = ws.max_row

prod_range = f"${get_column_letter(col_prod)}${first_data_row}:${get_column_letter(col_prod)}${last_row}"
date_range = f"${get_column_letter(col_date)}${first_data_row}:${get_column_letter(col_date)}${last_row}"

# New formula for yearly total (inclusive start and end)
new_formula = f"=SUMIFS({prod_range},{date_range},\">=\"&$K$10,{date_range},\"<=\"&$L$10)"

# Write formula into K7
ws["K7"] = new_formula

# Clear adjacent period formulas (L7‑O7) to avoid confusion
for col in range(12, 16):  # L(12) to O(15)
    ws.cell(row=7, column=col).value = None

# Save workbook
wb.save(output_path)

# Recalculate formulas
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to read the computed value
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
k7_val = ws2["K7"].value
print("K7 computed value after recalculation:", k7_val)
```
