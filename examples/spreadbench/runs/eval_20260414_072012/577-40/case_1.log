1. Load the workbook.
2. Identify rows to delete by scanning from row 2 to the last row.
3. Delete rows in reverse order to avoid shifting indices.
4. Save the modified workbook to the output directory with the same filename.
5. Call `recalculate` on the saved file, then verify that the target columns no longer contain the rows that should have been removed.
Code:
```repl
import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Define the set of values that count as "blank or specified"
bad_vals = {"", "-", "0", "$", "$0", "$0.0", None}

# Collect rows to delete
rows_to_delete = []
for r in range(2, ws.max_row + 1):  # start after header
    val_j = ws.cell(row=r, column=10).value
    val_k = ws.cell(row=r, column=11).value
    # Normalize possible whitespace strings
    if isinstance(val_j, str):
        val_j = val_j.strip()
    if isinstance(val_k, str):
        val_k = val_k.strip()
    if (val_j in bad_vals) and (val_k in bad_vals):
        rows_to_delete.append(r)

# Delete rows from bottom to top
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify deletion: count remaining rows and print a few sample rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Remaining rows (including header):", ws_check.max_row)
sample = []
for r in range(2, min(2+5, ws_check.max_row+1)):
    sample.append([ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column+1)])
print("Sample rows after deletion:", sample)
```
