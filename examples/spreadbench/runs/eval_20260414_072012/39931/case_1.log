import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_39931_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_39931_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine data range (skip header rows that are empty)
# From inspection, data starts at row 3 and ends at row 22
start_row = 3
end_row = ws.max_row  # should be 22

# Write formula into column L (12) for each data row
for r in range(start_row, end_row + 1):
    col_c = ws.cell(row=r, column=3).coordinate  # e.g., C3
    col_i = ws.cell(row=r, column=9).coordinate  # e.g., I3
    formula = f"=SUMPRODUCT(($C${start_row}:$C${end_row}={col_c})*($I${start_row}:$I${end_row}={col_i})*$K${start_row}:$K${end_row})"
    ws.cell(row=r, column=12).value = formula  # column L

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to read evaluated values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Verify the new column values
print("Verified values in column L:")
for r in range(start_row, end_row + 1):
    val = ws2.cell(row=r, column=12).value
    print(f"Row {r}: {val}")

# Ensure the output file exists
print("Output saved to:", output_path)
```
