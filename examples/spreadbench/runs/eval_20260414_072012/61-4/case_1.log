```repl
import os
import openpyxl
from collections import defaultdict
from datetime import datetime

# Paths
inp_path = "/sandbox/input/input_spreadsheet/1_61-4_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = os.path.join(out_dir, "1_61-4_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(inp_path, data_only=False)
ws_in = wb["input"]
ws_out = wb["output"]

# ---- 1. Determine column indices for the first 8 columns (ignore duplicated set) ----
header_row = 1
headers = [ws_in.cell(row=header_row, column=c).value for c in range(1, ws_in.max_column + 1)]

# Map clean header names to column numbers (1‑based). Use exact text (including spaces) to avoid duplicates.
col_map = {}
for idx, h in enumerate(headers, start=1):
    if isinstance(h, str):
        clean = h.strip()
        # Only keep the first occurrence of each needed header
        if clean in {"DATE", "Stock Name", "OPENP*", "HIGH", "LOW", "CLOSEP*", "VOLUME", "Change"} and clean not in col_map:
            col_map[clean] = idx

# Verify we have all needed columns
missing = {"DATE", "Stock Name", "OPENP*", "HIGH", "LOW", "CLOSEP*", "VOLUME", "Change"} - set(col_map.keys())
if missing:
    raise RuntimeError(f"Missing columns: {missing}")

# ---- 2. Helper to read a row into a dict ----
def read_row(r):
    return {
        "DATE": ws_in.cell(row=r, column=col_map["DATE"]).value,
        "Stock Name": ws_in.cell(row=r, column=col_map["Stock Name"]).value,
        "OPENP*": ws_in.cell(row=r, column=col_map["OPENP*"]).value,
        "HIGH": ws_in.cell(row=r, column=col_map["HIGH"]).value,
        "LOW": ws_in.cell(row=r, column=col_map["LOW"]).value,
        "CLOSEP*": ws_in.cell(row=r, column=col_map["CLOSEP*"]).value,
        "VOLUME": ws_in.cell(row=r, column=col_map["VOLUME"]).value,
        "Change": ws_in.cell(row=r, column=col_map["Change"]).value,
    }

# ---- 3. Group rows by stock ----
stock_rows = defaultdict(list)
for r in range(2, ws_in.max_row + 1):
    row_data = read_row(r)
    if row_data["DATE"] is None:  # skip completely empty rows
        continue
    stock_rows[row_data["Stock Name"]].append(row_data)

# ---- 4. Detect negative‑change runs and compute aggregates ----
summaries = []

for stock, rows in stock_rows.items():
    # Sort by DATE ascending (oldest → newest)
    rows.sort(key=lambda x: x["DATE"])
    i = 0
    while i < len(rows):
        cur = rows[i]
        if cur["Change"] is not None and cur["Change"] < 0:
            # start of a negative run
            run_start = i
            i += 1
            while i < len(rows) and rows[i]["Change"] is not None and rows[i]["Change"] < 0:
                i += 1
            run_end = i - 1  # inclusive
            run = rows[run_start:run_end + 1]

            # Aggregations
            open_price = run[0]["OPENP*"]
            close_price = run[-1]["CLOSEP*"]
            high_price = max(v for v in (r["HIGH"] for r in run) if isinstance(v, (int, float)))
            low_price = min(v for v in (r["LOW"] for r in run) if isinstance(v, (int, float)))
            volume_sum = sum(v for v in (r["VOLUME"] for r in run) if isinstance(v, (int, float)))
            first_date = run[0]["DATE"]

            summaries.append({
                "DATE": first_date,
                "Stock Name": stock,
                "OPENP*": open_price,
                "HIGH": high_price,
                "LOW": low_price,
                "CLOSEP*": close_price,
                "VOLUME": volume_sum,
            })
        else:
            i += 1

# ---- 5. Debug: print the computed summaries before writing ----
print("=== Computed summary records ===")
for rec in summaries:
    print(rec)

# ---- 6. Write summaries to the output sheet (overwrite rows after header) ----
# Clear existing data rows (keep header row)
for r in range(2, ws_out.max_row + 1):
    for c in range(1, ws_out.max_column + 1):
        ws_out.cell(row=r, column=c).value = None

# Write each summary row
out_row = 2
for rec in summaries:
    ws_out.cell(row=out_row, column=1).value = rec["DATE"]
    ws_out.cell(row=out_row, column=2).value = rec["Stock Name"]
    ws_out.cell(row=out_row, column=3).value = rec["OPENP*"]
    ws_out.cell(row=out_row, column=4).value = rec["HIGH"]
    ws_out.cell(row=out_row, column=5).value = rec["LOW"]
    ws_out.cell(row=out_row, column=6).value = rec["CLOSEP*"]
    ws_out.cell(row=out_row, column=7).value = rec["VOLUME"]
    out_row += 1

# ---- 7. Save, recalculate, and verify ----
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)

# Recalculate formulas (none are added, but we follow the required step)
await recalculate(out_path)

# Reload with data_only=True to see the final values
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check["output"]
print("\n=== Final rows in output sheet ===")
for r in range(2, ws_check.max_row + 1):
    vals = [ws_check.cell(row=r, column=c).value for c in range(1, 8)]
    print(r, vals)
