The task is to find, for each stock, every **consecutive run of negative “Change” values**.  
For each run we must keep:
- the opening price from the first date of the run,
- the closing price from the last date,
- the highest “HIGH” value within the run,
- the lowest “LOW” value within the run,
- the summed “VOLUME” of the run.

These summary rows are to be written to the existing “output” sheet (over‑writing any previous content, keeping the header row).  
All calculations will be done in Python; the resulting values will be written as literals (no formulas are needed for this static summary).

The plan:
1. Load the workbook with openpyxl (data_only=False so we can read raw values).  
2. Read all rows from the “input” sheet into a list of dictionaries, converting dates to Python `datetime` objects for easy sorting.  
3. Group rows by “Stock Name”. For each stock, sort rows by DATE ascending (oldest → newest) to correctly detect consecutive negative changes.  
4. Scan the sorted list, detecting runs where `Change < 0`. When a run ends, compute the required aggregates and store a summary record.  
5. After processing all stocks, write the summary records to the “output” sheet, starting at row 2 (row 1 holds the header).  
6. Save the workbook to the required output directory and call `recalculate()` to let LibreOffice evaluate any formulas (none are added here).  
7. Reload the saved file with `data_only=True` and print the written summary rows for verification.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
from collections import defaultdict
from datetime import datetime

# Paths
inp_path = "/sandbox/input/input_spreadsheet/1_61-4_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_61-4_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(inp_path, data_only=False)
ws_in = wb["input"]
ws_out = wb["output"]

# Map column indices (1‑based) to names from header row
headers = [ws_in.cell(row=1, column=c).value for c in range(1, ws_in.max_column + 1)]
col_idx = {h.strip(): i for i, h in enumerate(headers, start=1) if isinstance(h, str)}

# Helper to read a row into a dict
def row_to_dict(r):
    return {
        "DATE": ws_in.cell(row=r, column=col_idx["DATE"]).value,
        "Stock Name": ws_in.cell(row=r, column=col_idx["Stock Name"]).value,
        "OPENP*": ws_in.cell(row=r, column=col_idx["OPENP*"]).value,
        "HIGH": ws_in.cell(row=r, column=col_idx["HIGH"]).value,
        "LOW": ws_in.cell(row=r, column=col_idx["LOW"]).value,
        "CLOSEP*": ws_in.cell(row=r, column=col_idx["CLOSEP*"]).value,
        "VOLUME": ws_in.cell(row=r, column=col_idx["VOLUME"]).value,
        "Change": ws_in.cell(row=r, column=col_idx["Change"]).value,
    }

# Collect rows per stock
stock_rows = defaultdict(list)
for r in range(2, ws_in.max_row + 1):
    d = row_to_dict(r)
    # Skip completely empty rows
    if d["DATE"] is None:
        continue
    stock_rows[d["Stock Name"]].append(d)

# Prepare summary list
summaries = []

for stock, rows in stock_rows.items():
    # Sort by DATE ascending (oldest first) to detect consecutive runs correctly
    rows.sort(key=lambda x: x["DATE"])
    i = 0
    while i < len(rows):
        # Find start of a negative‑change run
        if rows[i]["Change"] is not None and rows[i]["Change"] < 0:
            run_start = i
            # Continue while next rows also have negative Change
            i += 1
            while i < len(rows) and rows[i]["Change"] is not None and rows[i]["Change"] < 0:
                i += 1
            run_end = i - 1  # inclusive
            # Compute aggregates for the run
            run_rows = rows[run_start:run_end + 1]
            open_price = run_rows[0]["OPENP*"]
            close_price = run_rows[-1]["CLOSEP*"]
            high_price = max(r["HIGH"] for r in run_rows if isinstance(r["HIGH"], (int, float)))
            low_price = min(r["LOW"] for r in run_rows if isinstance(r["LOW"], (int, float)))
            volume_sum = sum(r["VOLUME"] for r in run_rows if isinstance(r["VOLUME"], (int, float)))
            first_date = run_rows[0]["DATE"]
            # Append summary record
            summaries.append({
                "DATE": first_date,
                "Stock Name": stock,
                "OPENP*": open_price,
                "HIGH": high_price,
                "LOW": low_price,
                "CLOSEP*": close_price,
                "VOLUME": volume_sum,
            })
        else:
            i += 1

# Write summaries to the output sheet (overwrite existing data after header)
# First clear old data rows (keep header)
for r in range(2, ws_out.max_row + 1):
    for c in range(1, ws_out.max_column + 1):
        ws_out.cell(row=r, column=c).value = None

# Write new rows
out_row = 2
for rec in summaries:
    ws_out.cell(row=out_row, column=1).value = rec["DATE"]
    ws_out.cell(row=out_row, column=2).value = rec["Stock Name"]
    ws_out.cell(row=out_row, column=3).value = rec["OPENP*"]
    ws_out.cell(row=out_row, column=4).value = rec["HIGH"]
    ws_out.cell(row=out_row, column=5).value = rec["LOW"]
    ws_out.cell(row=out_row, column=6).value = rec["CLOSEP*"]
    ws_out.cell(row=out_row, column=7).value = rec["VOLUME"]
    out_row += 1

# Ensure output directory exists
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)

# Recalculate (LibreOffice will evaluate any formulas – none present here)
recalculate(out_path)

# Verify by reloading with data_only=True and printing the written rows
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check["output"]
print("=== Written summary rows ===")
for r in range(2, ws_check.max_row + 1):
    vals = [ws_check.cell(row=r, column=c).value for c in range(1, 8)]
    print(r, vals)
