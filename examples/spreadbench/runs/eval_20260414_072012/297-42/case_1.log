import os, openpyxl
from openpyxl.utils import get_column_letter
from pathlib import Path

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_297-42_init.xlsx")
os.makedirs(output_dir, exist_ok=True)

# Load workbook
wb = openpyxl.load_workbook(input_path)
combined_ws = wb["combined"]

# Clear existing data rows in combined (keep header row 1)
if combined_ws.max_row > 1:
    combined_ws.delete_rows(2, combined_ws.max_row - 1)

# Append rows from each source sheet
for sheet_name in wb.sheetnames:
    if sheet_name == "combined":
        continue
    ws = wb[sheet_name]
    # Determine number of columns from header row
    max_col = ws.max_column
    # Iterate over data rows
    for r in range(2, ws.max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        combined_ws.append(row_vals)

# Save workbook
