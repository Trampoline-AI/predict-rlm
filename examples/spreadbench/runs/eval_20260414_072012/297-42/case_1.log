import openpyxl, os, json, textwrap
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows
def inspect_sheet(ws, name):
    max_col = ws.max_column
    max_row = ws.max_row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"\n--- {name} ---")
    print("Headers:", headers)
    # print first 5 data rows
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)
    # print last 5 data rows if enough rows
    if max_row > 7:
        print("...")
        for r in range(max(max_row-4,2), max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(f"Row {r}:", row_vals)

# Inspect all sheets
for name in wb.sheetnames:
    ws = wb[name]
    inspect_sheet(ws, name)

# Save a copy for later use
output_path = "/sandbox/output/output_spreadsheet/combined.xlsx"
os.makedirs(os.path.dirname(output_path), exist_ok=True)
wb.save(output_path)
print("Saved copy to", output_path)
```
