Code:
```repl
import openpyxl
import os
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_382-10_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume the target sheet is the active one

# Clear column A cells that are not "comments"
for r in range(2, ws.max_row + 1):
    cell = ws.cell(row=r, column=1)
    val = cell.value
    # Determine if the cell contains the word "comments"
    is_comments = isinstance(val, str) and val.strip().lower() == "comments"
    if not is_comments:
        cell.value = None

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(str(output_path))

# Verify by reloading with data_only
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification after clearing:")
for r in range(2, min(12, ws_check.max_row + 1)):
    print(f"Row {r} A =", ws_check.cell(row=r, column=1).value)
```
