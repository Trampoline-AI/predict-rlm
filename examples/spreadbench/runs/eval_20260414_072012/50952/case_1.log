import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50952_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_50952_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row

# Process each data row
for r in range(2, max_row + 1):
    comment_cell = ws.cell(row=r, column=2)   # B
    param1_cell = ws.cell(row=r, column=5)   # E
    param2_cell = ws.cell(row=r, column=6)   # F
    id_cell = ws.cell(row=r, column=1)       # A
    target_cell = ws.cell(row=r, column=7)   # G (Found ID)

    comment = comment_cell.value
    param1 = param1_cell.value
    param2 = param2_cell.value
    source_id = id_cell.value

    # Ensure we have strings for comparison
    if isinstance(comment, str) and isinstance(param1, str) and isinstance(param2, str):
        # case‑insensitive search
        comment_low = comment.lower()
        if param1.lower() in comment_low and param2.lower() in comment_low:
            target_cell.value = source_id
        else:
            target_cell.value = None
    else:
        # If any piece is missing, leave target empty
        target_cell.value = None

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of column G (Found ID):")
for r in range(2, max_row + 1):
    print(r, ws_check.cell(row=r, column=7).value)
