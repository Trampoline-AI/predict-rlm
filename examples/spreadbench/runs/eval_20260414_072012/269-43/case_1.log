import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
# Assume we work on the first sheet (or all sheets?) – instruction doesn't specify sheet, so apply to all sheets
for ws in wb.worksheets:
    max_row = ws.max_row
    # Iterate backwards to safely delete rows
    for row in range(max_row, 1, -1):  # start from max_row down to 2 (assuming header at row 1)
        cell_h = ws.cell(row=row, column=column_index_from_string('H')).value
        cell_i = ws.cell(row=row, column=column_index_from_string('I')).value
        # Define blank as None or empty string after stripping
        h_blank = cell_h is None or (isinstance(cell_h, str) and cell_h.strip() == "")
        i_has = cell_i is not None and not (isinstance(cell_i, str) and cell_i.strip() == "")
        if i_has and h_blank:
            ws.delete_rows(row)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)
# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload to verify (data_only to read cached values)
wb_check = load_workbook(output_path, data_only=True)
# Print a few rows to confirm deletion
for ws in wb_check.worksheets:
    print(f"Sheet: {ws.title}")
    # Print first 5 rows after header
    for r in range(2, min(ws.max_row, 6)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(row_vals)
    print("---")
