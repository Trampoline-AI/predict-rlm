import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))

# Reload the saved workbook (data_only=False to see any remaining formulas/values)
wb = load_workbook(output_path, data_only=False)

offending = []
for ws in wb.worksheets:
    for row in range(2, ws.max_row + 1):  # assume header at row 1
        h_val = ws.cell(row=row, column=column_index_from_string('H')).value
        i_val = ws.cell(row=row, column=column_index_from_string('I')).value
        h_blank = h_val is None or (isinstance(h_val, str) and h_val.strip() == "")
        i_has = i_val is not None and not (isinstance(i_val, str) and i_val.strip() == "")
        if i_has and h_blank:
            offending.append((ws.title, row, h_val, i_val))

print("Offending rows (should be empty):", offending)
print("Total rows after processing per sheet:")
for ws in wb.worksheets:
    print(f"{ws.title}: {ws.max_row} rows")
