```python
import re, os
import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_82-38_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = os.path.join(out_dir, "1_82-38_init.xlsx")
os.makedirs(out_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)

# ------------------------------
# 1. Extract invoice numbers from SH1
# ------------------------------
sh1 = wb["SH1"]
invoice_numbers = []
invoice_pattern = re.compile(r"^[A-Z]\d+$")  # e.g., A7179

for row in sh1.iter_rows(min_row=2, max_col=4, values_only=True):
    val = row[3]  # column D (0‑based index 3)
    if isinstance(val, str) and invoice_pattern.match(val.strip()):
        invoice_numbers.append(val.strip())

print("Extracted invoice numbers:", invoice_numbers)

# ------------------------------
# 2. Fill DATA column D
# ------------------------------
data_ws = wb["DATA"]
col_A = column_index_from_string("A")
col_D = column_index_from_string("D")
col_E = column_index_from_string("E")
target_sheet_name = "SH1"

inv_idx = 0  # index in invoice_numbers list

for row in data_ws.iter_rows(min_row=2, max_row=data_ws.max_row):
    # Process only rows where column E matches the target sheet name
    if row[col_E - 1].value != target_sheet_name:
        continue

    cell_A_val = row[col_A - 1].value
    # Determine if this row is a TOTAL row
    is_total = isinstance(cell_A_val, str) and cell_A_val.strip().upper() == "TOTAL"

    # Write current invoice number (if any)
    if inv_idx < len(invoice_numbers):
        row[col_D - 1].value = invoice_numbers[inv_idx]

    # After writing for a TOTAL row, move to the next invoice
    if is_total:
        inv_idx += 1

# ------------------------------
# 3. Save workbook
# ------------------------------
wb.save(out_path)

# ------------------------------
# 4. Recalculate formulas
# ------------------------------
await recalculate(out_path)

# ------------------------------
# 5. Verify a few rows in column D
# ------------------------------
wb_check = openpyxl.load_workbook(out_path, data_only=True)
data_check = wb_check["DATA"]
print("First 15 values in column D after update:")
for r in data_check.iter_rows(min_row=2, max_row=16, min_col=col_D, max_col=col_D, values_only=True):
    print(r[0])
