out_path = out_dir + "1_82-38_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)

# ----- 1. Extract invoice numbers from SH1 -----
sh1 = wb["SH1"]
invoice_numbers = []
# Assume column D (4) holds the labels and numbers
for row in sh1.iter_rows(min_row=2, max_col=4, values_only=True):
    val = row[3]  # column D
    if val is None:
        continue
    # Skip the header label
    if isinstance(val, str) and val.strip().upper() == "INVOICE NO":
        continue
    # Anything else is an invoice number (string)
    invoice_numbers.append(str(val).strip())

print("Extracted invoice numbers (order):", invoice_numbers)

# ----- 2. Fill DATA column D -----
data_ws = wb["DATA"]
# Determine column indices (1‑based)
col_A = column_index_from_string("A")
col_D = column_index_from_string("D")
col_E = column_index_from_string("E")

inv_idx = 0  # index in invoice_numbers
for row in data_ws.iter_rows(min_row=2, max_row=data_ws.max_row):
    # Only process rows where column E matches sheet name "SH1"
    sheet_name_cell = row[col_E - 1].value
    if sheet_name_cell != "SH1":
        continue

    cell_A = row[col_A - 1].value
    # If this is a TOTAL row, write the current invoice number then advance
    if isinstance(cell_A, str) and cell_A.strip().upper() == "TOTAL":
