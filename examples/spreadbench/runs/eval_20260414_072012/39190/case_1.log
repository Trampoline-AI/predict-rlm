import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_39190_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_39190_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Gather all values from column F (column 6), ignoring header and blanks
col_f_values = set()
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=6).value
    if val is not None:
        col_f_values.add(val)

# Prepare fill for highlighting
yellow_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")

# Write "Delete" into column C where A's value is in column F set
for r in range(2, ws.max_row + 1):
    val_a = ws.cell(row=r, column=1).value
    if val_a is not None and val_a in col_f_values:
        target_cell = ws.cell(row=r, column=3)  # column C
        # Only write if cell is empty or not already "Delete"
        if target_cell.value != "Delete":
            target_cell.value = "Delete"
        target_cell.fill = yellow_fill

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload data‑only to verify column C values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
# Print a few rows of column C to confirm
print("Verification of column C (first 10 rows):")
for r in range(2, min(12, ws_check.max_row + 1)):
    print(r, ws_check.cell(row=r, column=3).value)
