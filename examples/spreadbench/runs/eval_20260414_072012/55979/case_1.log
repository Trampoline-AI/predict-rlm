import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = '/sandbox/input/input_spreadsheet/1_55979_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print('Sheet names:', wb.sheetnames)

# Function to print sample rows

def print_samples(ws, n=5):
    rows = list(ws.iter_rows(min_row=1, max_row=min(ws.max_row, n), values_only=True))
    print(f'First {len(rows)} rows of sheet {ws.title}:')
    for r in rows:
        print(r)
    # last rows
    start = max(2, ws.max_row - n + 1)
    rows = list(ws.iter_rows(min_row=start, max_row=ws.max_row, values_only=True))
    print(f'Last {len(rows)} rows of sheet {ws.title}:')
    for r in rows:
        print(r)

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print('\n--- Sheet:', name, '---')
    # Print header row
    header = [cell.value for cell in ws[1]]
    print('Header:', header)
    # Print sample rows
    print_samples(ws, n=5)
