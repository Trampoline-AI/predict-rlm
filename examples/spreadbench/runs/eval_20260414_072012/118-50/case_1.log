import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_118-50_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_118-50_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# ------------------------------------------------------------------
# 1. Gather names from column A (skip header row)
names = []
for row in range(2, ws.max_row + 1):
    val = ws.cell(row=row, column=1).value
    names.append(val if isinstance(val, str) else "")

# 2. Sort names alphabetically (case‑insensitive), ignoring blanks
sorted_names = sorted([n for n in names if n], key=lambda s: s.lower())

# 3. Write sorted names back to column A, preserving row count
for i, row in enumerate(range(2, ws.max_row + 1)):
    if i < len(sorted_names):
        ws.cell(row=row, column=1).value = sorted_names[i]
    else:
        ws.cell(row=row, column=1).value = ""

# ------------------------------------------------------------------
# 4. Transform matching words and write to column B
pattern = "PEA"
for row in range(2, ws.max_row + 1):
    word = ws.cell(row=row, column=1).value
    if isinstance(word, str) and word.endswith(pattern) and len(word) >= 5:
        # Move the 5th character (index 4) to the front
        transformed = word[4] + word[:4] + word[5:]
        ws.cell(row=row, column=2).value = transformed
    else:
        ws.cell(row=row, column=2).value = None  # clear any previous content

# ------------------------------------------------------------------
# 5. Save workbook to output location
wb.save(output_path)

# 6. Recalculate formulas (required by workflow)
await recalculate(output_path)

# 7. Reload with data_only=True to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Print verification rows (first 5 data rows)
print("Verification (first 5 rows after processing):")
for r in range(2, 7):
    col_a = ws_check.cell(row=r, column=1).value
    col_b = ws_check.cell(row=r, column=2).value
    print(r, col_a, col_b)
