import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_118-50_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_118-50_init.xlsx")

# Load workbook (preserve formulas, though none needed here)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Gather names from column A (skip header row)
names = []
for row in range(2, ws.max_row + 1):
    val = ws.cell(row=row, column=1).value
    if isinstance(val, str):
        names.append(val)
    else:
        names.append("")  # preserve row count

# Sort names alphabetically (ignore empty strings)
sorted_names = sorted([n for n in names if n], key=lambda s: s.lower())
# Preserve empty rows positions: we will just write sorted list back sequentially
# starting at row 2, filling all rows up to the original count.
for i, row in enumerate(range(2, ws.max_row + 1)):
    if i < len(sorted_names):
        ws.cell(row=row, column=1).value = sorted_names[i]
    else:
        ws.cell(row=row, column=1).value = ""  # fill remaining with blank if any

# Pattern to match (last three letters)
pattern = "PEA"

# Transform matching words and write to column B
for row in range(2, ws.max_row + 1):
    word = ws.cell(row=row, column=1).value
    if isinstance(word, str) and word.endswith(pattern) and len(word) >= 5:
        # Move the 5th character (index 4) to the front
        transformed = word[4] + word[:4] + word[5:]
        ws.cell(row=row, column=2).value = transformed
    else:
        ws.cell(row=row, column=2).value = None  # leave blank

# Save to output location
wb.save(output_path)

# Recalculate (LibreOffice)
recalculate(output_path)

# Reload to verify (data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
# Print a few verification rows
print("Verification (first 5 rows after processing):")
for r in range(2, 7):
    print(r, ws_check.cell(row=r, column=1).value, ws_check.cell(row=r, column=2).value)
