import openpyxl, os, json
from openpyxl import load_workbook

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_59884_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_59884_init.xlsx')

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Gather data from columns A (1st) and B (2nd)
first_col = 1
second_col = 2

groups = {}
for row in range(2, ws.max_row + 1):
    first = ws.cell(row=row, column=first_col).value
    second = ws.cell(row=row, column=second_col).value
    if first is None:
        continue
    groups.setdefault(first, []).append(second)

# Write results to columns G (7), H (8), I (9)
out_first_col = 7
out_count_col = 8
out_list_col = 9

# Clear any existing content in those columns (optional but safe)
for row in range(2, ws.max_row + 1):
    ws.cell(row=row, column=out_first_col).value = None
    ws.cell(row=row, column=out_count_col).value = None
    ws.cell(row=row, column=out_list_col).value = None

# Write grouped data
out_row = 2
for first_val, seconds in groups.items():
    ws.cell(row=out_row, column=out_first_col).value = first_val
    ws.cell(row=out_row, column=out_count_col).value = len(seconds)
    # Join second values into a comma‑separated string, skipping None
    joined = ', '.join(str(s) for s in seconds if s is not None)
    ws.cell(row=out_row, column=out_list_col).value = joined
    out_row += 1

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify target cells
from await recalculate as recalc  # noqa: E402
await recalc(output_path)

# Reload with data_only to check results
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print('--- Verification ---')
for r in range(2, out_row):
    print(r, ws_check.cell(row=r, column=out_first_col).value,
          ws_check.cell(row=r, column=out_count_col).value,
          ws_check.cell(row=r, column=out_list_col).value)
```
