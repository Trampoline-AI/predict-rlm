start_row = 12
max_row_master = ws_master.max_row

# Build the SUMPRODUCT match expression using fixed criteria cells $G$2 and $H$2
match_expr = (
    f"SUMPRODUCT(( 'Master-RM'!A${start_row}:A${max_row_master}= $G$2 )"
    f"*('Master-RM'!B${start_row}:B${max_row_master}= $H$2 )"
    f"*ROW('Master-RM'!A${start_row}:A${max_row_master}))"
)

# Formulas for columns G‑I (pull from column I of Master‑RM)
formula_G_I = f"=INDEX('Master-RM'!I:I, {match_expr})"

# Formulas for columns J‑L (pull from column K of Master‑RM)
formula_J_L = f"=INDEX('Master-RM'!K:K, {match_expr})"

# Write formulas into row 10
for col_letter in ["G", "H", "I"]:
    ws_res[f"{col_letter}10"] = formula_G_I

for col_letter in ["J", "K", "L"]:
    ws_res[f"{col_letter}10"] = formula_J_L

