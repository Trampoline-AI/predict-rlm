import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_414-20_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_414-20_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Find first occurrence of "Invoice No." in column A (case‑insensitive)
target_row = None
for r in range(1, ws.max_row + 1):
    val = ws.cell(row=r, column=1).value
    if isinstance(val, str) and val.strip().lower() == "invoice no.":
        target_row = r
        break

if target_row is None:
    raise ValueError("Could not find 'Invoice No.' in column A")

# Delete all rows above the target row
if target_row > 1:
    ws.delete_rows(1, target_row - 1)

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify that the new first row contains "Invoice No."
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
first_val = ws_check.cell(row=1, column=1).value
print("New first row value (column A):", first_val)
