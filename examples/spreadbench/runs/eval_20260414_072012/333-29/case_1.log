- Column **F** (6) holds dates we need to retrieve.
- Cell **F1** on sheet **A** contains a text string to be matched against column **C** on sheet **B**.
The instruction’s final step is to paste the identified date into sheet **B** where the match occurs. A logical place is the next column (**D**, column 4) of the matching row. We will:
1. Locate the first row in **A** where column P is "Yes" or "NA".
2. Scan upward in column L to find the first cell with value 100.
3. Retrieve the date from column F of that same row.
4. Compare the text in **A!F1** with entries in column C of sheet **B**.
5. For any matching row in **B**, write the retrieved date into column D.
6. Save the workbook to the output directory and recalculate formulas.
Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_333-29_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheet references
ws_a = wb["A"]
ws_b = wb["B"]

# 1. Find first row in column P (16) with "Yes" or "NA"
status_col = column_index_from_string("P")  # 16
first_status_row = None
for r in range(2, ws_a.max_row + 1):
    val = ws_a.cell(row=r, column=status_col).value
    if isinstance(val, str) and val.strip() in ("Yes", "NA"):
        first_status_row = r
        break

if first_status_row is None:
    raise ValueError("No cell with 'Yes' or 'NA' found in column P of sheet A.")

# 2. Scan upward in column L (12) for first 100 above that row
lookup_col = column_index_from_string("L")  # 12
target_row = None
for r in range(first_status_row - 1, 1, -1):
    val = ws_a.cell(row=r, column=lookup_col).value
    if val == 100:
        target_row = r
        break

if target_row is None:
    raise ValueError("No value 100 found in column L above the status row.")

# 3. Retrieve date from column F (6) of that row
date_col = column_index_from_string("F")  # 6
identified_date = ws_a.cell(row=target_row, column=date_col).value

# 4. Get text from A!F1
lookup_text = ws_a.cell(row=1, column=date_col).value

# 5. Find matching entries in B column C and paste date into column D
match_col = column_index_from_string("C")  # 3
target_col = column_index_from_string("D")  # 4
for r in range(2, ws_b.max_row + 1):
    cell_val = ws_b.cell(row=r, column=match_col).value
    if cell_val == lookup_text:
        ws_b.cell(row=r, column=target_col).value = identified_date

# Save to output path
import os, shutil
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload to ensure sheet names unchanged (LibreOffice may rename)
wb2 = openpyxl.load_workbook(output_path, data_only=False)
if wb2.sheetnames != wb.sheetnames:
    # rename back if needed
    for old, new in zip(wb2.sheetnames, wb.sheetnames):
        ws = wb2[old]
        ws.title = new
    wb2.save(output_path)
    await recalculate(output_path)

# Verify final write (print for debugging)
print("First status row:", first_status_row)
print("Target row with 100:", target_row)
print("Identified date:", identified_date)
print("Lookup text (A!F1):", lookup_text)
print("Matches in B written to column D.")

```
