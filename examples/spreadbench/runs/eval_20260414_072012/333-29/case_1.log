import openpyxl, os
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)
print('Sheets:', wb.sheetnames)

# Function to print header and sample rows for a sheet

def inspect_sheet(name):
    ws = wb[name]
    # assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f"\nSheet '{name}' header (row 1):")
    print(headers)
    # print first 5 data rows
    print('First 5 data rows:')
    for r in range(2, min(ws.max_row, 6)):
        row = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(row)
    # print last 5 data rows
    print('Last 5 data rows:')
    start = max(2, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        row = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(row)

for sheet in wb.sheetnames:
    inspect_sheet(sheet)
