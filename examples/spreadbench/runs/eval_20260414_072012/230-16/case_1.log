import openpyxl
from openpyxl.utils import get_column_letter
import os
import shutil

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas, though none are needed)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Process rows
for r in range(2, ws.max_row + 1):
    cell_a = ws.cell(row=r, column=1)   # Column A
    cell_b = ws.cell(row=r, column=2)   # Column B
    if cell_a.value is not None:
        cell_b.value = cell_a.value      # copy to B
        cell_a.value = None              # clear A

# Save to output location
wb.save(output_path)

# Recalculate (LibreOffice)
recalculate(output_path)

# Verify by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification (first 5 rows after change):")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(r, [ws_check.cell(row=r, column=c).value for c in (1,2)])

# End of script
