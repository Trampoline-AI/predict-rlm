Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_160-6_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_160-6_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["SH"]

# Function to determine if a row is completely empty (all cells None)
def is_row_empty(ws, row_idx):
    for col in range(1, ws.max_column + 1):
        if ws.cell(row=row_idx, column=col).value is not None:
            return False
    return True

# Delete blank rows from bottom to top (skip header row 1)
for r in range(ws.max_row, 1, -1):
    if is_row_empty(ws, r):
        ws.delete_rows(r)

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify: reload with data_only=True and check for any empty rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["SH"]
empty_rows = []
for r in range(2, ws_check.max_row + 1):
    if all(ws_check.cell(row=r, column=c).value is None for c in range(1, ws_check.max_column + 1)):
        empty_rows.append(r)

print("Empty rows after cleanup:", empty_rows)
print("Final row count:", ws_check.max_row)
```
