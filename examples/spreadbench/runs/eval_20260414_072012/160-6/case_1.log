```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_160-6_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to inspect a sheet
def inspect_sheet(ws):
    print(f"\n--- Inspecting sheet: {ws.title} ---")
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Rows: {max_row}, Columns: {max_col}")
    # Get headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Print first 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last 5 rows
    print("Last 5 rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    inspect_sheet(ws)
