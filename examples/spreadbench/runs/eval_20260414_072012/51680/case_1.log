1. Load the workbook.
2. Read the header texts from row 1, columns A‑F.
3. Iterate over all data rows (2 to max_row).
4. For each row, collect the headers whose corresponding cell in columns A‑F is exactly “Y”.
5. Join the selected headers with ", " (no trailing comma) and write the string into column G.
6. Save the workbook to the output directory.
7. Call `recalculate` on the saved file, reload with `data_only=True`, and verify that every row now has a non‑empty value in column G.
Code:
```repl
import openpyxl, os
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_51680_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_51680_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Read headers from A1:F1 (columns 1‑6)
header_cells = [ws.cell(row=1, column=c) for c in range(1, 7)]
headers = [cell.value if cell.value is not None else "" for cell in header_cells]

# Process each data row
for r in range(2, ws.max_row + 1):
    # Gather headers where column A‑F has "Y"
    selected = []
    for c in range(1, 7):
        val = ws.cell(row=r, column=c).value
        if isinstance(val, str) and val.strip().upper() == "Y":
            selected.append(headers[c-1].strip())
    # Join with commas
    result = ", ".join(selected) if selected else ""
    # Write to column G (7)
    ws.cell(row=r, column=7, value=result)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
from recalculate import recalculate  # assuming the tool is available
await recalculate(output_path)

# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification of column G values:")
for r in range(2, ws_check.max_row + 1):
    print(r, ws_check.cell(row=r, column=7).value)
