Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50250_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_50250_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Reference value from G2
ref = ws["G2"].value

# Determine column indices for C, D, E and G
col_c = column_index_from_string('C')
col_d = column_index_from_string('D')
col_e = column_index_from_string('E')
col_g = column_index_from_string('G')

# Compute sum of numeric values in C‑E where column G equals ref
total = 0
for row in range(2, ws.max_row + 1):
    if ws.cell(row=row, column=col_g).value == ref:
        for col in (col_c, col_d, col_e):
            val = ws.cell(row=row, column=col).value
            if isinstance(val, (int, float)):
                total += val

# Write result to H2
ws["H2"] = total

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify H2
await recalculate(output_path)
# Reload with data_only to read cached values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("H2 value after recalculation:", ws2["H2"].value)
```
