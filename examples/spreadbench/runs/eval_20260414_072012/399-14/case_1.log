Code:
```repl
import openpyxl
from openpyxl.styles import Font
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_399-14_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_399-14_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming single sheet

# Define the target columns (1-indexed)
col_N = 14  # N
col_O = 15  # O

# Apply font to all cells and adjust hours
font_eq = Font(name="等线")
for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        # Set font
        cell.font = font_eq

    # Process column N and O for this row
    cell_N = ws.cell(row=row[0].row, column=col_N)
    cell_O = ws.cell(row=row[0].row, column=col_O)

    # Only act if N contains a number
    if isinstance(cell_N.value, (int, float)):
        if cell_N.value > 40:
            overtime = cell_N.value - 40
            cell_N.value = 40
            cell_O.value = overtime
        else:
            # Ensure O is blank if not overtime
            cell_O.value = None

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload to verify a few rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification samples (row, N, O):")
for r in range(2, min(8, ws_check.max_row + 1)):
    print(r, ws_check.cell(r, col_N).value, ws_check.cell(r, col_O).value)
```
