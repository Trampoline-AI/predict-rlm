import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_52216_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_52216_init.xlsx")

# Load workbook with formulas retained
wb = load_workbook(input_path, data_only=False)
ws = wb["INPUTS"]

# Helper to build corrected formula for a given cell

def build_formula(row, col_letter):
    # col_letter is like 'C', 'D', etc.
    # Determine the lookup row key cell in column A of the same row
    lookup_val = f"INPUTS!A{row}"
    # Determine the header lookup cell in row 3 of the same column (e.g., C3)
    header_cell = f"INPUTS!{col_letter}3"
    # The data range in Sheet2 varies per column: column C uses C3:G20, D uses D3:H20, etc.
    # We'll compute start column based on col_letter and end column = start+4 (since original range is 5 columns wide)
    # Map column letters to numbers
    from openpyxl.utils import column_index_from_string, get_column_letter
    start_idx = column_index_from_string(col_letter)
    end_idx = start_idx + 4  # inclusive range of 5 columns
    start_col = get_column_letter(start_idx)
    end_col = get_column_letter(end_idx)
    data_range = f"Sheet2!{start_col}3:{end_col}20"
    # Build the INDEX-MATCH formula using IFNA wrapper as original
    formula = f"=_xlfn.IFNA(INDEX({data_range},MATCH({lookup_val},Sheet2!A3:A20,0),MATCH({header_cell},Sheet2!{start_col}1:{end_col}1,0)),0)"
    return formula

# Update formulas for rows 15-20, columns C to G
for r in range(15, 21):
    for col_idx in range(3, 8):  # C=3, G=7
        col_letter = openpyxl.utils.get_column_letter(col_idx)
        cell = ws.cell(row=r, column=col_idx)
        # Only replace if current cell contains a formula (starts with '=')
        if isinstance(cell.value, str) and cell.value.startswith('='):
            new_formula = build_formula(r, col_letter)
            cell.value = new_formula
            print(f"Updated {cell.coordinate} to {new_formula}")

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas using the provided tool
from tool import recalculate
await recalculate(output_path)

# Reload to verify that formulas are present (data_only=False to see formulas)
wb_check = load_workbook(output_path, data_only=False)
ws_check = wb_check["INPUTS"]
print("Verification of updated formulas:")
for r in range(15, 21):
    for col_idx in range(3, 8):
        cell = ws_check.cell(row=r, column=col_idx)
        if isinstance(cell.value, str) and cell.value.startswith('='):
            print(f"{cell.coordinate}: {cell.value}")
