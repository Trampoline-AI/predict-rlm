# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws1 = wb["Sheet1"]

# Determine column indices for B and C (1‑based)
col_B = 2  # ITEM
col_C = 3  # CLASS

# Collect headers from Sheet1 (row 1)
headers = [ws1.cell(row=1, column=c).value for c in range(1, ws1.max_column + 1)]

# Filter rows
matched_rows = []
for r in range(2, ws1.max_row + 1):
    val_B = ws1.cell(row=r, column=col_B).value
    val_C = ws1.cell(row=r, column=col_C).value
    if val_B == "TELIVISION" or val_C in ("CLASS III", "CLASS IV"):
        row_vals = [ws1.cell(row=r, column=c).value for c in range(1, ws1.max_column + 1)]
        matched_rows.append(row_vals)

# Ensure Sheet2 exists
if "Sheet2" not in wb.sheetnames:
    ws2 = wb.create_sheet("Sheet2")
else:
    ws2 = wb["Sheet2"]

# Write headers to A2 (row 2)
for idx, header in enumerate(headers, start=1):
    ws2.cell(row=2, column=idx, value=header)

# Write matched rows starting at A3 (row 3)
