        old_idx = col
        break

if old_idx is None:
    raise ValueError(f"Header '{target_header}' not found in row {header_row}")

# 2. Insert a new column at B (index 2)
ws.insert_cols(2)

# After insertion, the original column shifts right by 1
src_idx = old_idx + 1  # column that now holds the original '0-15' data
dest_idx = 2            # column B

# 3. Copy values from src_idx to dest_idx for all rows (including header)
for row in range(1, ws.max_row + 1):
