Using an absolute start reference (`$F$2`) and a relative end reference (`F<row>`) makes the formula easy to copy down. We will:

1. Load the workbook.
2. Write the running‑total formula into column H for every row that has a year (i.e., until the last non‑empty row in column A).
3. Save the modified workbook to `/sandbox/output/output_spreadsheet/1_48643_init.xlsx`.
4. Call `recalculate()` on the saved file.
5. Reload the file with `data_only=True` and verify that the “Total ability” column now contains numeric values (no blanks or errors).
Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os
import shutil

# Paths
input_path = input_spreadsheet  # /sandbox/input/input_spreadsheet/1_48643_init.xlsx
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_48643_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Determine last data row by checking column A (Year) for non‑empty values
max_row = ws.max_row
last_data_row = 1
for r in range(2, max_row + 1):
    if ws.cell(row=r, column=1).value is not None:
        last_data_row = r

# Write running total formula into column H (index 8)
for r in range(2, last_data_row + 1):
    # Formula: =SUM($F$2:F<row>)
    formula = f"=SUM($F$2:F{r})"
    ws.cell(row=r, column=8).value = formula

# Save to output location
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify: reload with data_only=True and print a few total ability values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification of Total ability (column H):")
for r in range(2, min(2 + 5, last_data_row + 1)):
    val = ws_check.cell(row=r, column=8).value
    print(f"Row {r}: {val}")

# Also print the final row total
final_val = ws_check.cell(row=last_data_row, column=8).value
print(f"Final cumulative total at row {last_data_row}: {final_val}")
