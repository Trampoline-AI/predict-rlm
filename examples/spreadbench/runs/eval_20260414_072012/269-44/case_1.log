import openpyxl, os

# Load workbook
input_path = "/sandbox/input/input_spreadsheet/1_269-44_init.xlsx"
wb = openpyxl.load_workbook(input_path, data_only=False)

# Use the existing sheet (Sheet1) as target
ws = wb["Sheet1"]

# Determine max row/col
max_row = ws.max_row
max_col = ws.max_column

# Helper to get cell value as string (or None)
def get_val(r, c):
    v = ws.cell(row=r, column=c).value
    return str(v).strip() if isinstance(v, str) else v

# Find rows where column A == "Chassis"
chassis_rows = [r for r in range(1, max_row+1) if get_val(r,1) == "Chassis"]
print("Found 'Chassis' in rows:", chassis_rows)

# Show a few rows around each occurrence for verification
for r in chassis_rows:
    start = max(1, r-6)
    end = min(max_row, r+3)
    print(f"\nRows {start} to {end}:")
    for rr in range(start, end+1):
        row_vals = [ws.cell(row=rr, column=cc).value for cc in range(1, max_col+1)]
        print(f"{rr}: {row_vals}")

# Delete four rows before each 'Chassis' occurrence, processing from bottom to top
for r in sorted(chassis_rows, reverse=True):
    del_start = r - 4
    if del_start < 1:
        del_start = 1
    # Number of rows to delete: up to 4, but not beyond sheet start
    delete_count = r - del_start
    if delete_count > 0:
        print(f"Deleting rows {del_start} to {r-1} (count={delete_count})")
        ws.delete_rows(del_start, delete_count)

# Save to output directory
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))
wb.save(output_path)
print("Saved modified workbook to:", output_path)

# Recalculate formulas (if any) and verify
result = await recalculate(output_path)
print("Recalculate result:", result)

# Reload with data_only to verify that no 'Chassis' rows were shifted incorrectly
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2["Sheet1"]
new_max = ws2.max_row
print("New max row after deletions:", new_max)
print("Rows with 'Chassis' after deletion:", [r for r in range(1, new_max+1) if ws2.cell(row=r, column=1).value == "Chassis"])
