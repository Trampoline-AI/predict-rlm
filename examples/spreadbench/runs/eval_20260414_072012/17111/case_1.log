col_type_s1 = find_col(hdr_s1, 'Type')   or 3 (C)
col_amount_s1 = find_col(hdr_s1, 'Amount') or 4 (D)
col_status_s1 = find_col(hdr_s1, 'Status') or 5 (E)

# Ensure we have valid column numbers
col_name_s1 = col_name_s1 or 2
col_type_s1 = col_type_s1 or 3
col_amount_s1 = col_amount_s1 or 4
col_status_s1 = col_status_s1 or 5

# Add new header column to Summary (after existing columns)
new_col_idx = ws_summary.max_column + 1
new_col_letter = get_column_letter(new_col_idx)
ws_summary.cell(row=1, column=new_col_idx, value='SumByStatus')

