def find_col(headers, target):
    for i, v in enumerate(headers, start=1):
        if isinstance(v, str) and v.strip().lower() == target.lower():
            return i
    return None

# Read first row of Sheet1 for headers
hdr_s1 = [ws_sheet1.cell(row=1, column=c).value for c in range(1, ws_sheet1.max_column+1)]
