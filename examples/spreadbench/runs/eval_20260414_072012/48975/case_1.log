Code:
```repl
import openpyxl
from openpyxl import load_workbook

input_path = "/sandbox/input/input_spreadsheet/1_48975_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_48975_init.xlsx"

# Load workbook for editing
wb = load_workbook(input_path, data_only=False)

# Ensure Output sheet exists
if 'Output' not in wb.sheetnames:
    raise ValueError('Output sheet not found')

ws_in = wb['Input']
ws_out = wb['Output']

max_row = ws_in.max_row

for r in range(2, max_row + 1):
    # Read the 'To Do' cell in column E (5th column)
    to_do = ws_in.cell(row=r, column=5).value
    if isinstance(to_do, str) and to_do.strip().lower() == 'yes':
        val_a = ws_in.cell(row=r, column=1).value
        val_b = ws_in.cell(row=r, column=2).value
        # Skip if both are empty
        if val_a is None and val_b is None:
            continue
        # Write to Output sheet columns A and B (1 and 2)
        ws_out.cell(row=r, column=1).value = val_a
        ws_out.cell(row=r, column=2).value = val_b

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Verify by loading data_only and printing a few target rows
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check['Output']
print('Verification of copied rows:')
for r in range(2, max_row + 1):
    val_a = ws_check.cell(row=r, column=1).value
    val_b = ws_check.cell(row=r, column=2).value
    if val_a is not None or val_b is not None:
        print(f'Row {r}: A={val_a}, B={val_b}')
