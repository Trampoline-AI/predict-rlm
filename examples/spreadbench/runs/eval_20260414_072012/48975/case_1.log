import openpyxl
from openpyxl import load_workbook

input_path = "/sandbox/input/input_spreadsheet/1_48975_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_48975_init.xlsx"

# Load workbook for editing (write mode)
wb = load_workbook(input_path, data_only=False)

# Ensure required sheets exist
if 'Input' not in wb.sheetnames or 'Output' not in wb.sheetnames:
    raise ValueError("Both 'Input' and 'Output' sheets must exist")

ws_in = wb['Input']
ws_out = wb['Output']

max_row = ws_in.max_row

# 1. Clear existing data in Output columns A and B for all rows (starting at row 2)
for r in range(2, max_row + 1):
    ws_out.cell(row=r, column=1).value = None
    ws_out.cell(row=r, column=2).value = None

# 2. Copy values where column E = "yes"
for r in range(2, max_row + 1):
    to_do = ws_in.cell(row=r, column=5).value  # column E
    if isinstance(to_do, str) and to_do.strip().lower() == 'yes':
        val_a = ws_in.cell(row=r, column=1).value
        val_b = ws_in.cell(row=r, column=2).value
        # Skip rows where both source cells are empty
        if val_a is None and val_b is None:
            continue
        ws_out.cell(row=r, column=1).value = val_a
        ws_out.cell(row=r, column=2).value = val_b

# Save to the output location
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Verify the result by loading data_only and printing rows with any data
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check['Output']
print("Verification – rows with data in Output (A,B):")
for r in range(2, max_row + 1):
    a_val = ws_check.cell(row=r, column=1).value
    b_val = ws_check.cell(row=r, column=2).value
    if a_val is not None or b_val is not None:
        print(f"Row {r}: A={a_val}, B={b_val}")
