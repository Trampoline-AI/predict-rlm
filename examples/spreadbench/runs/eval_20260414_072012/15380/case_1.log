Code:
```repl
import openpyxl
from openpyxl import load_workbook
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_15380_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (preserve formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Write formula to B3
# Extract the month code (two characters after first underscore) from A3
# Then find that code in column D (codes2) and return the month name from column E (month)
# Use INDEX/MATCH for LibreOffice compatibility
formula = "=IFERROR(INDEX($E$3:$E$14, MATCH(MID($A$3, FIND(\"_\", $A$3)+1, 2), $D$3:$D$14, 0)), "")"
ws["B3"].value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
recalc_result = await recalculate(str(output_path))
print("Recalc result:", recalc_result)

# Reload with data_only to verify B3 value
wb2 = load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("B3 value after recalculation:", ws2["B3"].value)
```
