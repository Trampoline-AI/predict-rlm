macro = """'--- Optimized DeleteRows Macro ---------------------------------
Sub DeleteRowsOptimized()
    Dim sh As Worksheet
    Dim rngDelete As Range
    Dim lastRow As Long
    Dim critCol As Long
    Dim critValue As Variant

    '--- Settings -------------------------------------------------
    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.DisplayAlerts = False

    Set sh = ThisWorkbook.Worksheets("Delete")

    '--- Identify the column to test (e.g., column B = 2) ------------
    critCol = 2          ' change this to the column index you need
    critValue = "GROCERY"   ' change this to the value that triggers deletion

    '--- Find the last used row ------------------------------------
    lastRow = sh.Cells(sh.Rows.Count, critCol).End(xlUp).Row

    '--- Build a range of rows that meet the condition -------------
    Dim i As Long
    For i = 2 To lastRow   ' assume row 1 has headers
        If sh.Cells(i, critCol).Value = critValue Then
            If rngDelete Is Nothing Then
                Set rngDelete = sh.Rows(i)
            Else
                Set rngDelete = Union(rngDelete, sh.Rows(i))
            End If
        End If
    Next i

    '--- Delete all matching rows in one go -----------------------
    If Not rngDelete Is Nothing Then
        rngDelete.Delete
    End If

    '--- Clean up -------------------------------------------------
    Application.DisplayAlerts = True
    Application.EnableEvents = True
    Application.ScreenUpdating = True
End Sub
