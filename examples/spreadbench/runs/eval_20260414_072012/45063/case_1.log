```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load workbook
path = "/sandbox/input/input_spreadsheet/1_45063_init.xlsx"
wb = openpyxl.load_workbook(path, data_only=False)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows
def inspect_sheet(ws, max_rows=10):
    # Get header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f"Headers in {ws.title}:", headers)
    # Print first few rows
    print(f"First {max_rows} data rows in {ws.title}:")
    for r in range(2, min(ws.max_row, max_rows+1)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)
    # Print last few rows
    if ws.max_row > max_rows+1:
        print(f"Last {max_rows} rows in {ws.title}:")
        for r in range(ws.max_row - max_rows + 1, ws.max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
            print(r, row_vals)

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    inspect_sheet(ws, max_rows=10)

# Identify target columns
# Assuming Sheet1 column A is out-of-stock items, column B is where we will write quantity
sheet1 = wb[wb.sheetnames[0]]
sheet2 = wb[wb.sheetnames[1]] if len(wb.sheetnames) > 1 else None

print("\nSheet1 sample out-of-stock items (col A):")
for r in range(2, min(sheet1.max_row, 6)):
    print(r, sheet1.cell(row=r, column=1).value)

if sheet2:
    print("\nSheet2 sample products and quantities (col A, B):")
    for r in range(2, min(sheet2.max_row, 6)):
        print(r, sheet2.cell(row=r, column=1).value, sheet2.cell(row=r, column=2).value)

# Save a copy for later use (not modifying yet)
wb.save("/sandbox/output/output_spreadsheet/1_45063_init.xlsx")
```
