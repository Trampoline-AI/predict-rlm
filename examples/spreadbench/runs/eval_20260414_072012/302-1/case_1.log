import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path)
print('Sheets:', wb.sheetnames)

# Function to print first and last few rows of a sheet

def print_sample(ws, n=5):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print('Headers:', headers)
    # first n rows (excluding header)
    print('First rows:')
    for r in range(2, min(2+n, max_row+1)):
        print([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    # last n rows
    print('Last rows:')
    for r in range(max(max_row-n+1, 2), max_row+1):
        print([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])

# Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f'\n--- Sheet: {name} ---')
    print_sample(ws)
```
