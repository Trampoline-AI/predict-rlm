import openpyxl
from openpyxl import load_workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_374-31_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_374-31_init.xlsx"

# Load workbook (preserve formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet

# Find the row where column A contains "Code"
code_row = None
for r in range(1, ws.max_row + 1):
    if ws.cell(row=r, column=1).value == "Code":
        code_row = r
        break

if code_row is None:
    raise ValueError('No cell with text "Code" found in column A.')

# Delete blank rows above the "Code" row (rows 2 .. code_row-1)
# Ensure we only delete rows that are actually blank in column A
start_delete = 2
end_delete = code_row - 1
if end_delete >= start_delete:
    # Count how many rows to delete
    rows_to_delete = end_delete - start_delete + 1
    ws.delete_rows(start_delete, rows_to_delete)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload to verify
wb2 = load_workbook(output_path, data_only=True)
ws2 = wb2.active
print("After deletion, first 5 rows (including header):")
for r in range(1, min(6, ws2.max_row + 1)):
    row_vals = [ws2.cell(row=r, column=c).value for c in range(1, ws2.max_column + 1)]
    print(r, row_vals)
