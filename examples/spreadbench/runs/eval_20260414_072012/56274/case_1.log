import openpyxl
from openpyxl.utils import column_index_from_string
import shutil
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/initial.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "initial.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume primary sheet is the first

# Define the ranges (columns G to R = 7 to 18)
start_col = column_index_from_string('G')
end_col = column_index_from_string('R')

# Build the formula strings
# Opening Balance (row 4)
open_bal_formula = f"=INDEX(${openpyxl.utils.get_column_letter(start_col)}$4:${openpyxl.utils.get_column_letter(end_col)}$4, MATCH(D7, ${openpyxl.utils.get_column_letter(start_col)}$3:${openpyxl.utils.get_column_letter(end_col)}$3, 0))"
# Debits (row 5)
debits_formula = f"=INDEX(${openpyxl.utils.get_column_letter(start_col)}$5:${openpyxl.utils.get_column_letter(end_col)}$5, MATCH(D7, ${openpyxl.utils.get_column_letter(start_col)}$3:${openpyxl.utils.get_column_letter(end_col)}$3, 0))"
# Credits (row 6)
credits_formula = f"=INDEX(${openpyxl.utils.get_column_letter(start_col)}$6:${openpyxl.utils.get_column_letter(end_col)}$6, MATCH(D7, ${openpyxl.utils.get_column_letter(start_col)}$3:${openpyxl.utils.get_column_letter(end_col)}$3, 0))"
# Closing Balance = Opening + Debits - Credits
closing_formula = "=D9 + D10 - D11"

# Write formulas into D9:D12
ws["D9"] = open_bal_formula
ws["D10"] = debits_formula
ws["D11"] = credits_formula
ws["D12"] = closing_formula

# Save to output location
wb.save(output_path)

# Recalculate using LibreOffice (provided by the environment)
# The `recalculate` helper is available in the sandbox
recalculate(output_path)

# Reload with data_only to verify results
