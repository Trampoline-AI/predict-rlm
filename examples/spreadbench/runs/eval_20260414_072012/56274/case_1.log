ws_check = wb_check[wb_check.sheetnames[0]]

print("Verification after recalculation:")
for cell_ref in ["D9","D10","D11","D12"]:
    cell = ws_check[cell_ref]
    print(f"{cell_ref} = {cell.value} (type {type(cell.value)})")
