```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/initial.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "initial.xlsx")

# Load workbook (preserve formulas, but we will write literals)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # primary sheet

# 1. Get fiscal month from D7
fiscal_month_cell = ws["D7"]
fiscal_month = fiscal_month_cell.value  # should be a datetime
print("Fiscal month (D7):", fiscal_month)

# 2. Find the column (G‑R) where the header date matches fiscal_month
start_col = column_index_from_string('G')
end_col = column_index_from_string('R')
matched_col = None
for col in range(start_col, end_col + 1):
    header_val = ws.cell(row=3, column=col).value
    if isinstance(header_val, (int, float)):
        # Excel stores dates as numbers; convert fiscal_month to Excel serial number
        # openpyxl stores datetime as Python datetime, but the cell value is a datetime object.
        # Compare datetime objects directly.
        if header_val == fiscal_month:
            matched_col = col
            break
    else:
        # header may be a datetime object
        if header_val == fiscal_month:
            matched_col = col
            break

if matched_col is None:
    raise ValueError("Could not find a matching month column for D7.")

print("Matched column index:", matched_col, "letter:", get_column_letter(matched_col))

# 3. Retrieve values from rows 4,5,6 in that column
opening_balance = ws.cell(row=4, column=matched_col).value or 0
debits = ws.cell(row=5, column=matched_col).value or 0
credits = ws.cell(row=6, column=matched_col).value or 0

print("Opening Balance:", opening_balance)
print("Debits:", debits)
print("Credits:", credits)

# 4. Compute closing balance
closing_balance = opening_balance + debits - credits
print("Closing Balance:", closing_balance)

# 5. Write literals into D9‑D12
ws["D9"] = opening_balance
ws["D10"] = debits
ws["D11"] = credits
ws["D12"] = closing_balance

# Save to output location
wb.save(output_path)

# Recalculate (LibreOffice) to ensure any dependent formulas are updated
recalculate(output_path)

# Reload with data_only=True to verify values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("\nVerification after recalculation (data_only):")
