```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
print("Sheet names:", wb.sheetnames)

# Find the target sheet
target_name = "Final Recon Items"
if target_name not in wb.sheetnames:
    print(f"Target sheet '{target_name}' not found!")
else:
    ws = wb[target_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Sheet '{target_name}': rows={max_row}, cols={max_col}")

    # Print headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Helper to print a row as list
    def row_vals(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]

    # Print first 5 data rows (rows 2-6)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row+1)):
        print(r, row_vals(r))

    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        print(r, row_vals(r))
