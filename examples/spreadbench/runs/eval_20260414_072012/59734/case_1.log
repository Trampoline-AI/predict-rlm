    formula = (
        f"=IF(B{row}=\"\",\"\",B{row})"
        f"&IF(C{row}=\"\",\"\",\",\"&C{row})"
        f"&IF(D{row}=\"\",\"\",\",\"&D{row})"
        f"&IF(E{row}=\"\",\"\",\",\"&E{row})"
    )
    ws.cell(row=row, column=target_col_idx).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify first 10 rows of the new column (data_only)
