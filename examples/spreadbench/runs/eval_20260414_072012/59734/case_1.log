import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_59734_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_59734_init.xlsx')

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb['Sheet1']

# Header row
header_row = 1
max_row = ws.max_row

# Choose target column I (index 9)
target_col_idx = column_index_from_string('I')
target_header = "Programs_Last3Months"
ws.cell(row=header_row, column=target_col_idx).value = target_header

# Column indices for data
client_id_col = column_index_from_string('A')
prg_cols = [column_index_from_string(col) for col in ['B', 'C', 'D', 'E']]

# Write formulas into column I for each data row
for row in range(2, max_row + 1):
