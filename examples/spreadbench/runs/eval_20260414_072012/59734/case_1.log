import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string
from datetime import datetime, timedelta
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_59734_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_59734_init.xlsx')

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb['Sheet1']

# Identify header row and existing columns
header_row = 1
max_col = ws.max_column
max_row = ws.max_row

# Build list of headers
headers = [ws.cell(row=header_row, column=c).value for c in range(1, max_col+1)]

# Find or create target column "Programs_Last3Months"
target_header = "Programs_Last3Months"
if target_header in headers:
    target_col_idx = headers.index(target_header) + 1
else:
    target_col_idx = max_col + 1
    ws.cell(row=header_row, column=target_col_idx).value = target_header

# Determine column indices for needed data
client_id_col = column_index_from_string('A')
prg_cols = [column_index_from_string(col) for col in ['B', 'C', 'D', 'E']]  # PRGCode columns
startdate_col = column_index_from_string('R')  # STARTDATE

# Helper to safely get cell value
def get_cell_value(cell):
    return cell.value if cell.value is not None else None

# Compute three‑month cutoff (relative to today)
today = datetime.today().date()
three_months_ago = today - timedelta(days=90)  # approximate 3 months

# Populate target column
for row in range(2, max_row + 1):
    client_id = get_cell_value(ws.cell(row=row, column=client_id_col))
    if client_id is None:
        # skip empty rows
        continue

    # Get start date
    start_date_cell = ws.cell(row=row, column=startdate_col)
    start_date = get_cell_value(start_date_cell)
    if isinstance(start_date, datetime):
        start_date = start_date.date()
    elif isinstance(start_date, str):
        # try parsing
        try:
            start_date = datetime.strptime(start_date, "%Y-%m-%d").date()
        except Exception:
            start_date = None

    # If start date is missing or older than 3 months, leave blank
    if start_date is None or start_date < three_months_ago:
        ws.cell(row=row, column=target_col_idx).value = None
        continue

    # Collect program codes from PRGCode columns
    prog_codes = set()
    for col_idx in prg_cols:
        val = get_cell_value(ws.cell(row=row, column=col_idx))
        if val is not None and isinstance(val, (int, float, str)):
            prog_codes.add(str(val).strip())

    # Write comma‑separated list (or blank if none)
    if prog_codes:
        ws.cell(row=row, column=target_col_idx).value = ", ".join(sorted(prog_codes))
    else:
        ws.cell(row=row, column=target_col_idx).value = None

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to verify target column values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['Sheet1']
print("Verification of target column (first 10 rows):")
for r in range(2, min(12, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=target_col_idx).value
    print(f"Row {r}: {val}")

