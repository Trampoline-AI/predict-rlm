ws_check = wb_check[wb_check.sheetnames[0]]
print("Sample output from column", target_col_letter)
for r in range(first_data_row, first_data_row + 10):
    val = ws_check.cell(row=r, column=target_col_idx).value
    print(f"{target_col_letter}{r}: {val}")
