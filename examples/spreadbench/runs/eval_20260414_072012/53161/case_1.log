```repl
import openpyxl
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_53161_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_53161_init.xlsx"

# Load workbook (keep formulas if any)
wb = load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row
max_col = ws.max_column

# -------------------------------------------------
# 1. Identify time‑interval columns (header row 12)
time_header_row = 12
time_cols = []
for c in range(6, max_col + 1):
    val = ws.cell(row=time_header_row, column=c).value
    if isinstance(val, (int, float, str, openpyxl.cell.cell.Cell)):
        # time objects are datetime.time; also may be strings
        if isinstance(val, (datetime.time, str)):
            time_cols.append(c)
# If no time_cols found, fallback to all columns 6‑max_col
if not time_cols:
    time_cols = list(range(6, max_col + 1))

# -------------------------------------------------
# 2. Category names (row 3, columns 6‑max_col)
cat_name_row = 3
category_names = {}
for c in time_cols:
    name = ws.cell(row=cat_name_row, column=c).value
    if name:
        category_names[c] = str(name).strip()

# -------------------------------------------------
# 3. Agent → categories mapping (rows 4‑? until a blank in column 5)
agent_category = {}
row = 4
while row <= max_row:
    agent = ws.cell(row=row, column=5).value
    if not agent:
        break
    agent = str(agent).strip()
    cats = set()
    for c in time_cols:
        flag = ws.cell(row=row, column=c).value
        if flag == 1:
            cat_name = category_names.get(c)
            if cat_name:
                cats.add(cat_name)
    agent_category[agent] = cats
    row += 1

# -------------------------------------------------
# 4. Agent → schedule per time column (rows 13‑? until blank in column 5)
schedule = {}
row = 13
while row <= max_row:
    agent = ws.cell(row=row, column=5).value
    if not agent:
        break
    agent = str(agent).strip()
    flags = {}
    for c in time_cols:
        val = ws.cell(row=row, column=c).value
        flags[c] = 1 if val == 1 else 0
    schedule[agent] = flags
    row += 1

# -------------------------------------------------
# 5. Compute totals for each category row in result block
# Result block header is row 35, first category total row is 36
result_header_row = 35
first_result_row = result_header_row + 1

# Find how many category rows exist (stop when column5 is empty)
result_rows = []
row = first_result_row
while row <= max_row:
    cat_label = ws.cell(row=row, column=5).value
    if not cat_label:
        break
    result_rows.append(row)
    row += 1

# Write totals
for r in result_rows:
    cat_label = ws.cell(row=r, column=5).value
    if not cat_label:
        continue
    cat_label = str(cat_label).strip()
    # Determine which column(s) correspond to this category name in the header
    # The header row (row 3) may have the same name; we locate its column(s)
    target_cols = [c for c, name in category_names.items() if name == cat_label]
    if not target_cols:
        # If the result block uses a different naming (e.g., "Category 1" vs "Category 1")
        # fall back to matching by numeric suffix
        target_cols = [c for c, name in category_names.items() if cat_label in name]
    # Compute per‑time‑column totals
    for c in time_cols:
        total = 0
        for agent, cats in agent_category.items():
            if cat_label in cats:
                # add if agent is scheduled in this interval
                total += schedule.get(agent, {}).get(c, 0)
        ws.cell(row=r, column=c).value = total

# -------------------------------------------------
# 6. Save to output directory
import os
os.makedirs(out_dir, exist_ok=True)
wb.save(out_path)

# Recalculate (LibreOffice will evaluate any formulas; we have only static numbers)
from openpyxl import load_workbook
recalculate(out_path)

# Verify a few target cells (print first category, first time column)
first_cat_row = result_rows[0] if result_rows else None
first_time_col = time_cols[0] if time_cols else None
if first_cat_row and first_time_col:
    val = ws.cell(row=first_cat_row, column=first_time_col).value
    print("Sample verification - row", first_cat_row, "col", first_time_col, "value:", val)
else:
    print("No result rows or time columns detected.")
```
