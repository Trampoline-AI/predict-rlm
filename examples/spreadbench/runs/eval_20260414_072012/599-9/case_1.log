import openpyxl
from pathlib import Path
import asyncio

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_599-9_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Choose the sheet that contains the data (first sheet)
ws = wb[wb.sheetnames[0]]
print("Using sheet:", ws.title)

col_g = openpyxl.utils.column_index_from_string('G')  # 7
col_k = openpyxl.utils.column_index_from_string('K')  # 11

# Iterate rows and copy dates
for r in range(2, ws.max_row + 1):
    g_cell = ws.cell(row=r, column=col_g)
    k_cell = ws.cell(row=r, column=col_k)
    if g_cell.value is not None:
        # Copy the date/value from G to K
        k_cell.value = g_cell.value
        # Optional: preserve formatting (if any) – here we just copy the value
    # else: leave K unchanged

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(str(output_path))

# Verify a few rows after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws.title]

print("Verification of first 6 rows (G -> K):")
for r in range(2, 7):
    g_val = ws_check.cell(row=r, column=col_g).value
    k_val = ws_check.cell(row=r, column=col_k).value
    print(f"Row {r}: G={g_val!r}, K={k_val!r}")

# Also check a row where G was empty (row 4 in sample)
r = 4
g_val = ws_check.cell(row=r, column=col_g).value
k_val = ws_check.cell(row=r, column=col_k).value
print(f"Row {r} (G empty case): G={g_val!r}, K={k_val!r}")
