import openpyxl
import os

output_path = "/sandbox/output/output_spreadsheet/1_141-20_init.xlsx"

# Reload workbook with data_only to see values after recalculation
wb = openpyxl.load_workbook(output_path, data_only=True)

pl_ws = wb["PL Recon Items"]
stmt_ws = wb["Statement Recon Items"]

def print_rows(ws, name, max_rows=10):
    print(f"\n--- {name} (max {ws.max_row} rows) ---")
    # Print header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print("Header:", headers)
    # Print up to max_rows data rows
    for r in range(2, min(ws.max_row, max_rows+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", row_vals)
    # If more rows, print last few
    if ws.max_row > max_rows+1:
        print("... last rows ...")
        for r in range(max(2, ws.max_row-4), ws.max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
            print(f"Row {r}:", row_vals)

print_rows(pl_ws, "PL Recon Items")
print_rows(stmt_ws, "Statement Recon Items")
```
