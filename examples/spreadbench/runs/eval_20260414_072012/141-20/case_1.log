Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_141-20_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_141-20_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)

# Sheet names (as observed)
pl_sheet = wb["PL Recon Items"]
stmt_sheet = wb["Statement Recon Items"]

# Build a set of (Reference, Total Invoice Value) from Statement sheet
stmt_matches = set()
stmt_rows_to_delete = []
for r in range(2, stmt_sheet.max_row + 1):
    ref = stmt_sheet.cell(row=r, column=column_index_from_string('F')).value
    total = stmt_sheet.cell(row=r, column=column_index_from_string('I')).value
    # Only consider rows where both are not None
    if ref is not None and total is not None:
        stmt_matches.add((ref, total))

# Identify rows to delete in PL sheet and corresponding rows in Statement sheet
pl_rows_to_delete = []
for r in range(2, pl_sheet.max_row + 1):
    invoice = pl_sheet.cell(row=r, column=column_index_from_string('C')).value
    amount = pl_sheet.cell(row=r, column=column_index_from_string('D')).value
    if (invoice, amount) in stmt_matches:
        pl_rows_to_delete.append(r)
        # Find the matching Statement row(s) to delete as well
        for sr in range(2, stmt_sheet.max_row + 1):
            ref = stmt_sheet.cell(row=sr, column=column_index_from_string('F')).value
            total = stmt_sheet.cell(row=sr, column=column_index_from_string('I')).value
            if ref == invoice and total == amount:
                stmt_rows_to_delete.append(sr)

# Delete rows in reverse order to keep indices stable
for r in sorted(pl_rows_to_delete, reverse=True):
    pl_sheet.delete_rows(r, 1)

for r in sorted(set(stmt_rows_to_delete), reverse=True):
    stmt_sheet.delete_rows(r, 1)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Reload to verify deletions (data_only=True to see values)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
pl_check = wb_check["PL Recon Items"]
stmt_check = wb_check["Statement Recon Items"]
print("After deletion, PL rows:", pl_check.max_row)
print("After deletion, Statement rows:", stmt_check.max_row)
```
