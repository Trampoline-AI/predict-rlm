import openpyxl
import os
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_353-6_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming single sheet; adjust if multiple

# Identify rows to delete (column I = 9)
rows_to_delete = []
for r in range(2, ws.max_row + 1):  # skip header
    cell_val = ws.cell(row=r, column=9).value
    if isinstance(cell_val, str) and cell_val.strip().upper() == "HUB NOTES":
        rows_to_delete.append(r)

print(f"Rows to delete (count {len(rows_to_delete)}): {rows_to_delete}")

# Delete rows from bottom to top
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

# Save workbook
wb.save(output_path)

# Recalculate formulas
from predict import recalculate  # assuming the tool is available as described
await recalculate(str(output_path))

# Verify deletion
