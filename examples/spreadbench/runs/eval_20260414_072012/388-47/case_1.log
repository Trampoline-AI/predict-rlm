import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_388-47_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_388-47_init.xlsx")

# Load workbook
wb = load_workbook(input_path)
print("Sheet names:", wb.sheetnames)

# Assume first sheet (Sheets(1) in VBA) is the target
ws = wb[wb.sheetnames[0]]

# Determine max row
max_row = ws.max_row
print(f"Original max row: {max_row}")

# Delete rows where column E starts with Z1 or X1
# Iterate backwards to avoid shifting issues
delete_count = 0
for row in range(max_row, 1, -1):  # start from max_row down to 2 (preserve header)
    cell_val = ws.cell(row=row, column=5).value  # column E
    if isinstance(cell_val, str) and (cell_val.startswith("Z1") or cell_val.startswith("X1")):
        ws.delete_rows(row, 1)
        delete_count += 1

print(f"Deleted {delete_count} rows.")

# Save workbook
wb.save(output_path)

# Recalculate formulas
from predict import recalculate
await recalculate(output_path)

# Reload to verify
wb2 = load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("New max row after deletion:", ws2.max_row)
```
