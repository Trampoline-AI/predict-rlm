import openpyxl
from openpyxl.utils import column_index_from_string

# Load workbook (keep formulas)
wb_path = "/sandbox/input/input_spreadsheet/1_49333_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

ws = wb["Sheet1"]
# Identify columns for formulas: G (7), H (8), I (9)
col_indices = {7: 2, 8: 3, 9: 4}  # column index to return column in VLOOKUP

for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=7, max_col=9):
    for cell in row:
        if isinstance(cell.value, str) and cell.value.startswith("=VLOOKUP"):
            # Determine which return column this cell uses based on its column
            ret_col = col_indices[cell.column]
            # Build new formula with TRIM on the lookup value (column F = 6)
            new_formula = f"=VLOOKUP(TRIM(F{cell.row}),Sheet3!$A$2:$D$300,{ret_col},FALSE)"
            cell.value = new_formula

# Save to output directory with same filename
out_dir = "/sandbox/output/output_spreadsheet/"
import os
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, "1_49333_init.xlsx")
wb.save(out_path)

# Recalculate formulas
