```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_49333_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, "1_49333_init.xlsx")

# Load workbook (keep formulas for now)
wb = openpyxl.load_workbook(in_path, data_only=False)

# ---------- Build lookup dictionary from Sheet3 ----------
ws3 = wb["Sheet3"]
lookup = {}
for r in range(2, ws3.max_row + 1):
    name_cell = ws3.cell(row=r, column=1).value
    if name_cell is None:
        continue
    name_key = str(name_cell).strip()
    # columns B, C, D (2,3,4)
    val2 = ws3.cell(row=r, column=2).value
    val3 = ws3.cell(row=r, column=3).value
    val4 = ws3.cell(row=r, column=4).value
    lookup[name_key] = (val2, val3, val4)

# ---------- Replace VLOOKUP formulas in Sheet1 ----------
ws1 = wb["Sheet1"]
for r in range(2, ws1.max_row + 1):
    name_cell = ws1.cell(row=r, column=6).value  # column F
    if name_cell is None:
        continue
    key = str(name_cell).strip()
    if key in lookup:
        v2, v3, v4 = lookup[key]
        ws1.cell(row=r, column=7).value = v2   # G
        ws1.cell(row=r, column=8).value = v3   # H
        ws1.cell(row=r, column=9).value = v4   # I
    else:
        # No match – clear cells (or keep existing formula if preferred)
        ws1.cell(row=r, column=7).value = None
        ws1.cell(row=r, column=8).value = None
        ws1.cell(row=r, column=9).value = None

# Save workbook
wb.save(out_path)

# Recalculate (no formulas left, but call to meet workflow)
await recalculate(out_path)

# Verify a few rows after recalculation (data_only=True)
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("Post‑fix evaluated values (rows 2‑7):")
for r in range(2, 8):
    g = ws_check.cell(row=r, column=7).value
    h = ws_check.cell(row=r, column=8).value
    i = ws_check.cell(row=r, column=9).value
    print(f"Row {r}: G={g}, H={h}, I={i}")

# Confirm no #N/A errors remain
has_error = any(
    cell.value == "#N/A"
    for row in ws_check.iter_rows(min_row=2, max_row=ws_check.max_row, min_col=7, max_col=9)
    for cell in row
)
print("Any #N/A errors left?", has_error)
