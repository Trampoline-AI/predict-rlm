```repl
import openpyxl
import os
from pathlib import Path

# Load the input workbook (read‑only not needed for inspection)
input_path = Path(input_spreadsheet)
wb = openpyxl.load_workbook(input_path, data_only=False)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# 2. For each sheet, print row count and first few header cells
for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{name}': max_row={max_row}, max_col={max_col}")

    # Print header row (row 1) values for the first 20 columns
    headers = [ws.cell(row=1, column=c).value for c in range(1, min(21, max_col+1))]
    print("Headers (first 20 cols):", headers)

    # Show a sample of data rows (first 5 and last 5)
    sample_rows = []
    for r in range(2, min(7, max_row+1)):
        sample_rows.append([ws.cell(row=r, column=c).value for c in range(1, min(21, max_col+1))])
    print("First 5 data rows (cols 1‑20):")
    for row in sample_rows:
        print(row)

    # Last 5 rows (if enough rows)
    if max_row > 7:
        last_rows = []
        for r in range(max_row-4, max_row+1):
            last_rows.append([ws.cell(row=r, column=c).value for c in range(1, min(21, max_col+1))])
        print("Last 5 data rows (cols 1‑20):")
        for row in last_rows:
            print(row)

# Save this exploratory workbook (optional, not needed for final output)
