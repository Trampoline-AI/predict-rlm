Code:
```repl
import openpyxl
from pathlib import Path
import asyncio

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume the relevant sheet is the active one

# Determine column indices (A=1, B=2, C=3, Q=17)
col_a, col_b, col_c, col_q = 1, 2, 3, 17

# Iterate rows and apply condition
for row in range(2, ws.max_row + 1):
    val_a = ws.cell(row=row, column=col_a).value
    val_b = ws.cell(row=row, column=col_b).value
    val_c = ws.cell(row=row, column=col_c).value

    if val_a == "Government" and val_b == "Germany" and val_c == "Carretera":
        target_cell = ws.cell(row=row, column=col_q)
        # Write only if empty or error/placeholder
        if target_cell.value in (None, "", "#N/A", "#VALUE!", "#REF!"):
            target_cell.value = "Volkswagen"

# Save modified workbook
wb.save(output_path)

# Recalculate formulas (none added but required by workflow)
await recalculate(str(output_path))

# Verify a few rows where condition is met
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
matches = []
for row in range(2, ws_check.max_row + 1):
    if (ws_check.cell(row=row, column=col_a).value == "Government" and
        ws_check.cell(row=row, column=col_b).value == "Germany" and
        ws_check.cell(row=row, column=col_c).value == "Carretera"):
        matches.append((row, ws_check.cell(row=row, column=col_q).value))

print("Rows meeting condition and value in Q:", matches[:10])  # show first few
