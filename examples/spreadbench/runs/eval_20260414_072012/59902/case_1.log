```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_59902_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_59902_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet named Sheet1

# Determine last row with data
max_row = ws.max_row

# Write corrected formula for ascending dates in column C (Days Since Sale)
for row in range(5, max_row + 1):
    # Only process rows that belong to the ascending side (column A has a date)
    date_cell = ws.cell(row=row, column=1)  # column A
    name_cell = ws.cell(row=row, column=2)  # column B
    if isinstance(date_cell.value, (int, float, str, type(None))):
        # Skip rows without a proper date (e.g., empty rows or the descending block)
        continue
    # Build formula string for this row
    formula = f"=IFERROR(A{row}-INDEX($A$4:A{row-1},MATCH(B{row},$B$4:B{row-1},0),1),\"\")"
    ws.cell(row=row, column=3).value = formula  # column C

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify a few target cells (column C)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Sample results (Column C):")
for r in range(5, min(5+10, ws_check.max_row+1)):
    print(f"Row {r}: {ws_check.cell(row=r, column=3).value}")

# Clean up
del wb, ws, wb_check, ws_check
