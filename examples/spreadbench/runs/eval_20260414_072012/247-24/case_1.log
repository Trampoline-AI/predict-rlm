    if company == "Motorcycle":
        rows_to_delete.append(r)
    elif company == "Ahmed Sons" and location == "Canada":
        rows_to_delete.append(r)

# Delete rows in reverse order
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

# Update Bill Rate of Resource to 180 where Company='National TV' and Location='India'
for r in range(2, ws.max_row + 1):
    if cell_val(r, 1) == "National TV" and cell_val(r, 2) == "India":
        ws.cell(row=r, column=7).value = 180  # Column G

# Insert two new blank rows after the last data row
