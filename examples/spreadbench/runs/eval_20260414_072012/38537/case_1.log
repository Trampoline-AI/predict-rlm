# Write formula starting at A3
for r in range(3, target_row + 1):
    # Build cell reference for column B of this row
    b_cell = ws.cell(row=r, column=2)
    # If B is empty, we still write the IF formula which will result in blank
    formula = f'=IF(B{r}="","",TEXT(ROW()-2+9,"000")&$B$2)'
    ws.cell(row=r, column=1).value = formula

