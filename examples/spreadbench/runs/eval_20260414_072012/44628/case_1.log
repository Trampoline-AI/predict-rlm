The task is to group rows by the first character of the SKU (column A) and sum the corresponding quantities (column B). The results should be placed in cells D3, E3, F3, and G3.  
We will:
1. Load the workbook.
2. Compute a dictionary mapping each first‑letter to the total quantity.
3. Write the totals for the letters A, B, C, D (in that order) into D3:G3. If a letter is missing, write 0.
4. Save the workbook to the output directory, recalculate formulas, and verify the target cells contain the expected numbers.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_44628_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_44628_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Identify SKU and sales columns (A and B based on inspection)
sku_col = 1   # column A
sales_col = 2 # column B

# Compute sums per first letter
sums = {}
for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=sku_col, max_col=sales_col, values_only=True):
    sku, sales = row
    if sku is None or sales is None:
        continue
    first = str(sku)[0].upper()
    sums[first] = sums.get(first, 0) + sales

# Prepare values for D3:G3 (letters A, B, C, D)
target_letters = ['A', 'B', 'C', 'D']
target_cells = ['D3', 'E3', 'F3', 'G3']
for cell, letter in zip(target_cells, target_letters):
    ws[cell] = sums.get(letter, 0)

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and verify target cells
from __future__ import annotations
await recalculate(output_path)

# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification values:")
for cell in target_cells:
    print(cell, ws_check[cell].value)
