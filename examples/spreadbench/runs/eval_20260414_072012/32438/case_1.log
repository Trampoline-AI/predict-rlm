1. Load the workbook.
2. For each data row (starting at row 2), read the value in column I. It is a datetime string like `"2021-09-29 18:08:00"` (or a Python `datetime` if openpyxl parsed it).
3. Parse the string to a `datetime` object, extract the time component, and write that `time` value into column J.
4. Apply the number format `"hh:mm:ss AM/PM"` to each cell in column J so LibreOffice displays the time with AM/PM.
5. Save the workbook to the output directory, recalculate, and verify that the first few rows in column J now contain proper time values (e.g., `06:08:00 PM`).

This avoids reliance on a potentially unsupported formula and ensures the output is correct.
Code:
```python
import os
import openpyxl
from datetime import datetime

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_32438_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_32438_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine data range
max_row = ws.max_row

# Column indices (I = 9, J = 10)
col_I = 9
col_J = 10

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Process each row
for r in range(2, max_row + 1):
    # Read the datetime value from column I
    cell_I = ws.cell(row=r, column=col_I)
    val = cell_I.value
    # If it's already a datetime object, use it; otherwise parse the string
    dt_obj = None
    if isinstance(val, datetime):
        dt_obj = val
    elif isinstance(val, str):
        # Try common formats
        for fmt in ("%Y-%m-%d %H:%M:%S", "%d/%m/%Y %H:%M:%S"):
            try:
                dt_obj = datetime.strptime(val, fmt)
                break
            except ValueError:
                continue
    if dt_obj is None:
        # If parsing failed, skip this row
        continue

    # Extract time component
    time_val = dt_obj.time()

    # Write time to column J
    cell_J = ws.cell(row=r, column=col_J)
    cell_J.value = time_val
    # Apply time format with AM/PM
    cell_J.number_format = "hh:mm:ss AM/PM"

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Verify a few cells after recalculation (data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification (first 3 rows, column J):")
for r in range(2, min(5, ws_check.max_row + 1)):
    print(r, ws_check.cell(row=r, column=col_J).value)
```
