```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_32438_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_32438_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine data range
max_row = ws.max_row

# Column indices (I = 9, J = 10)
col_I = 9
col_J = 10

# Apply formula and number format to each row in column J
for r in range(2, max_row + 1):
    # Build formula for this row
    formula = f"=TIMEVALUE(RIGHT(I{r},8))"
    cell = ws.cell(row=r, column=col_J)
    cell.value = formula
    # Set time format with AM/PM
    cell.number_format = "hh:mm:ss AM/PM"

# Ensure output directory exists
