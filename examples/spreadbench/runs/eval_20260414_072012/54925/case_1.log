import os, asyncio
import openpyxl

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_54925_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, "1_54925_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume the first sheet is the target

# Determine column indices
col_B = 2
col_L = 12  # column L (empty in the original sheet)

# Step 1: copy original IDs from B to L for rows 2‑40
for r in range(2, 41):
    original_val = ws.cell(row=r, column=col_B).value
    ws.cell(row=r, column=col_L).value = original_val

# Step 2: write the IF/OR formula into column B
for r in range(2, 41):
    formula = f"=IF(AND($H{r}=$M$3, OR($K{r}=$N$3, $K{r}=$N$4)), $L{r}, \"\")"
    ws.cell(row=r, column=col_B).value = formula

# Save the modified workbook
wb.save(out_path)

# Recalculate formulas using LibreOffice (async)
await recalculate(out_path)

# Reload with data_only=True to read evaluated results
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Verify a few rows (2, 3, 4)
print("Verification (rows 2, 3, 4):")
for r in (2, 3, 4):
    print(r, ws_check.cell(row=r, column=col_B).value)
