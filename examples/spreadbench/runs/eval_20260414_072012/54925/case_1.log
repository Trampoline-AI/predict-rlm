```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os, asyncio

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_54925_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, "1_54925_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Apply formula to B2:B40
for r in range(2, 41):
    # Build formula string
    formula = f'=IF(AND($H{r}=$M$3, OR($K{r}=$N$3, $K{r}=$N$4)), $B{r}, "")'
    ws.cell(row=r, column=2).value = formula

# Save workbook
wb.save(out_path)

# Recalculate formulas
await recalculate(out_path)

# Verify a few rows after recalculation (data_only=True)
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification (rows 2,3,4):")
for r in (2,3,4):
    print(r, ws_check.cell(r,2).value)
