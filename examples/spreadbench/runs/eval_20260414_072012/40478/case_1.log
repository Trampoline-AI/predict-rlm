# Use the first sheet (assumed primary)
ws = wb[wb.sheetnames[0]]

# Determine max row/col safely
max_row = ws.max_row or 1
max_col = ws.max_column or 1
print(f"Detected dimensions - rows: {max_row}, cols: {max_col}")

# Extract headers from the first row (up to max_col)
headers = []
for c in range(1, max_col + 1):
