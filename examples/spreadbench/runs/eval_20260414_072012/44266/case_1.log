import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_44266_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_44266_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
data_ws = wb["Data"]
lookup_ws = wb["Lookup"]

# Determine the column range that contains years in Data row 4
# We'll scan the first 26 columns (A–Z) as a reasonable bound
max_col = 26
year_row = 4
value_row = 14

# Build the formula string (using absolute references)
# We'll use column letters A–Z for the range; adjust if more columns exist
col_start = "A"
col_end = get_column_letter(max_col)

# Formula template for each row in Lookup column B
formula_template = f'=IFERROR(INDEX(Data!${col_start}${value_row}:${col_end}${value_row}, MATCH(A{{row}}, Data!${col_start}${year_row}:${col_end}${year_row}, 0)), "")'

# Write formula down column B for all rows that have a year in column A
for r in range(2, lookup_ws.max_row + 1):
    year_cell = lookup_ws.cell(row=r, column=1)  # column A
    if year_cell.value is None:
        # Stop if we encounter a blank year (optional)
        continue
    target_cell = lookup_ws.cell(row=r, column=2)  # column B
    target_cell.value = formula_template.format(row=r)

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice)
import asyncio
result = await recalculate(output_path)
print("Recalculate result:", result)

# Verify a few target cells (B2, B3) after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
lookup_check = wb_check["Lookup"]
print("B2 value:", lookup_check["B2"].value)
print("B3 value:", lookup_check["B3"].value)
