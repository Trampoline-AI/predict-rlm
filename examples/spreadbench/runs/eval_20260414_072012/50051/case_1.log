for r in range(2, max_row + 1):
    cb_cell = ws.cell(row=r, column=col_cb)
    cc_cell = ws.cell(row=r, column=col_cc)
    if cb_cell.value is None:
        cc_cell.value = None
    else:
        # LibreOffice‑compatible formula
        cc_cell.value = f'=IFERROR(MATCH({get_column_letter(col_cb)}{r}, $T$2:$T$600, 0), "")'

# Save the modified workbook
