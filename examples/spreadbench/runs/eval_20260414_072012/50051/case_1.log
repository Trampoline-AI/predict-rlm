import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50051_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_50051_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Column indices
col_cb = column_index_from_string("CB")   # 80
col_cc = column_index_from_string("CC")   # 81

max_row = ws.max_row

# Write formula into CC for rows where CB is not empty
for r in range(2, max_row + 1):
    cb_cell = ws.cell(row=r, column=col_cb)
    cc_cell = ws.cell(row=r, column=col_cc)
    # If CB is empty or None, leave CC blank
    if cb_cell.value is None:
        cc_cell.value = None
    else:
        # Write the MATCH formula (LibreOffice compatible)
        cc_cell.value = f'=IFERROR(MATCH({get_column_letter(col_cb)}{r}, $T$2:$T$600, 0), "")'

# Save workbook
