import openpyxl
from openpyxl.utils import get_column_letter

# Paths
inp_path = "/sandbox/input/input_spreadsheet/1_46646_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_46646_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(inp_path, data_only=False)
ws = wb.active  # only one sheet

# Helper to write formula in a given column at row 11
def write_formula(col_idx):
    col_letter = get_column_letter(col_idx)
    # Find the year cell in the same column (search rows 2‑5 for a numeric year)
    year = None
    for r in range(2, 6):
        val = ws.cell(row=r, column=col_idx).value
        if isinstance(val, (int, float)):
            year = int(val)
            break
    if year is None:
        # fallback: use the topmost numeric year in column O if col is O
        for r in range(2, 6):
            val = ws.cell(row=r, column=col_idx).value
            if isinstance(val, (int, float)):
                year = int(val)
                break
    if year is None:
        year = 2020  # default if not found

    # Assume month = 1 (January) for calculation; night shift days = 5 (example)
    # Formula components:
    # days_in_month = DAY(EOMONTH(DATE(year, month, 1),0))
    # night_days = 5
    # perc = night_days / days_in_month
    # Formatting:
    #   IF(perc=0,"0", IF(ROUND(perc,1)=perc, TEXT(perc,"0.0"), TEXT(perc,"0.000000000")))
    formula = (
        f"=IF(5/DAY(EOMONTH(DATE({year},1,1),0))=0,"
        f"\"0\","
        f"IF(ROUND(5/DAY(EOMONTH(DATE({year},1,1),0)),1)=5/DAY(EOMONTH(DATE({year},1,1),0)),"
        f"TEXT(5/DAY(EOMONTH(DATE({year},1,1),0)),\"0.0\"),"
        f"TEXT(5/DAY(EOMONTH(DATE({year},1,1),0)),\"0.000000000\")))"
    )
    ws.cell(row=11, column=col_idx).value = formula

# Write formulas in column B (2) and column O (15) as they contain year headers
write_formula(2)   # Column B
write_formula(15)  # Column O

# Save to output directory
