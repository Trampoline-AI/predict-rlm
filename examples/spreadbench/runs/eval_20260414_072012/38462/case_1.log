import openpyxl, math, os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_38462_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_38462_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Find the column with timedelta values by inspecting row 2
target_col = None
for col in range(1, ws.max_column + 1):
    cell = ws.cell(row=2, column=col)
    if isinstance(cell.value, datetime.timedelta):
        target_col = col
        break

if target_col is None:
    raise RuntimeError("Could not locate a column with timedelta values.")

# Process all rows in that column
for row in range(2, ws.max_row + 1):
    cell = ws.cell(row=row, column=target_col)
    if isinstance(cell.value, datetime.timedelta):
        td = cell.value
        total_hours = td.days * 24 + td.seconds / 3600
        rounded = math.ceil(total_hours)
        cell.value = rounded
        # Set number format to General
        cell.number_format = "General"

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify a few rows
sample_rows = [2, min(3, ws.max_row), ws.max_row]
for r in sample_rows:
    print(f"Row {r}, col {get_column_letter(target_col)}:", ws.cell(row=r, column=target_col).value)
