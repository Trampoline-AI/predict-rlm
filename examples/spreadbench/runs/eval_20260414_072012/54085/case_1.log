import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_54085_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_54085_init.xlsx")

# Load workbook (preserve formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Write formula into C2:C4
for row in range(2, 5):  # rows 2,3,4
    ws.cell(row=row, column=3).value = f"=IF(B{row}=$A$2,\"\",B{row})"

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify results by loading with data_only=True
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
results = [ws_check.cell(row=r, column=3).value for r in range(2,5)]
print("C2:C4 values after recalculation:", results)
