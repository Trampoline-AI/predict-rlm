output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_36191_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume single sheet

# Inspect sheet
print("Sheet name:", ws.title)
print("Max row:", ws.max_row, "Max column:", ws.max_column)

# Get headers from first row
headers = [ws.cell(row=1, column=col).value for col in range(1, ws.max_column + 1)]
print("Headers:", headers)

# Find column B index (should be 2) and Result column
col_B = 2
result_col = None
for idx, hdr in enumerate(headers, start=1):
    if isinstance(hdr, str) and hdr.strip().lower() == "result":
        result_col = idx
        break

if result_col is None:
    # Add new column after the last column
    result_col = ws.max_column + 1
    ws.cell(row=1, column=result_col).value = "Result"
    print(f"Added 'Result' header at column {get_column_letter(result_col)}")
else:
    print(f"'Result' column already exists at {get_column_letter(result_col)}")

# Write formula for each data row
