import openpyxl
from openpyxl.utils import get_column_letter
from datetime import datetime, timedelta
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_58942_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_58942_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# 1. Fill column A with full timeline dates (A2 onward)
start_date = datetime(2018, 1, 1)
end_date   = datetime(2020, 12, 31)
delta = end_date - start_date
total_days = delta.days + 1  # inclusive

for i in range(total_days):
    cell = ws.cell(row=2 + i, column=1)  # column A
    cell.value = start_date + timedelta(days=i)

# 2. Write VLOOKUP formula in column C to pull values from pasted source (E:F)
# Determine last row of timeline
last_row = 1 + total_days  # because row1 is header
lookup_range = f"$E$2:$F${ws.max_row}"  # use current max row for source data (E2:F6)
formula = f'=IFERROR(VLOOKUP(A2,{lookup_range},2,FALSE),"")'

# Write formula in C2 and copy down
for r in range(2, last_row + 1):
    ws.cell(row=r, column=3).value = formula.replace("A2", f"A{r}")

# Save workbook
wb.save(output_path)

# Recalculate (LibreOffice)
recalculate(output_path)

# Reload with data_only to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[ws2.sheetnames[0]]

# Print sample verification rows (first 5 and last 5 of timeline)
print("Verification sample rows (A, C):")
for r in list(range(2, 7)) + list(range(last_row-4, last_row+1)):
    date_val = ws2.cell(row=r, column=1).value
    val = ws2.cell(row=r, column=3).value
    print(f"Row {r}: Date={date_val}, Value={val}")

# Also print the source mapping for sanity
print("\nSource mapping (E, F):")
for r in range(2, 7):
    print(f"E{r}={ws2.cell(row=r, column=5).value}, F{r}={ws2.cell(row=r, column=6).value}")
