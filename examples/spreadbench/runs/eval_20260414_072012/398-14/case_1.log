```repl
import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_398-14_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_398-14_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Helper to find column index by header name (case‑insensitive)
def col_index(ws, header_name):
    for cell in ws[1]:
        if isinstance(cell.value, str) and cell.value.strip().upper() == header_name.upper():
            return cell.column
    return None

# 1) Add BALANCE column to each data sheet (except COLLECTION)
for ws in wb.worksheets:
    if ws.title.upper() == "COLLECTION":
        continue

    # Determine existing columns
    sale_col = col_index(ws, "SALE")
    ret_col = col_index(ws, "RET")

    # Insert new column after the last used column
    last_col = ws.max_column
    ws.insert_cols(last_col + 1)  # new empty column
    bal_col = last_col + 1
    ws.cell(row=1, column=bal_col).value = "BALANCE"

    # Write formulas for each data row
    for r in range(2, ws.max_row + 1):
        # Build formula based on which columns exist
        if sale_col and ret_col:
            sale_cell = f"{get_column_letter(sale_col)}{r}"
            ret_cell = f"{get_column_letter(ret_col)}{r}"
            formula = f"={sale_cell}-{ret_cell}"
        elif sale_col:  # only sale present
            sale_cell = f"{get_column_letter(sale_col)}{r}"
            formula = f"={sale_cell}"
        elif ret_col:   # only ret present
            ret_cell = f"{get_column_letter(ret_col)}{r}"
            formula = f"=-{ret_cell}"
        else:
            formula = None  # no data to compute

        if formula:
            ws.cell(row=r, column=bal_col).value = formula

# 2) Aggregate data across all sheets into COLLECTION
collection_ws = wb["COLLECTION"]
# Clear existing data rows (keep header)
for r in range(2, collection_ws.max_row + 1):
    for c in range(1, collection_ws.max_column + 1):
        collection_ws.cell(row=r, column=c).value = None

# Aggregate dict: key = (ITEM,BR,TY,OR) -> sums
agg = {}

def add_to_agg(key, sale, ret):
    if key not in agg:
        agg[key] = {"SALE": 0.0, "RET": 0.0}
    if isinstance(sale, (int, float)):
        agg[key]["SALE"] += sale
    if isinstance(ret, (int, float)):
        agg[key]["RET"] += ret

for ws in wb.worksheets:
    if ws.title.upper() == "COLLECTION":
        continue
    # locate column indices
    item_col = col_index(ws, "ITEM")
    br_col = col_index(ws, "BR")
    ty_col = col_index(ws, "TY")
    or_col = col_index(ws, "OR")
    sale_col = col_index(ws, "SALE")
    ret_col = col_index(ws, "RET")

    for r in range(2, ws.max_row + 1):
        key = (
            ws.cell(r, item_col).value if item_col else None,
            ws.cell(r, br_col).value if br_col else None,
            ws.cell(r, ty_col).value if ty_col else None,
            ws.cell(r, or_col).value if or_col else None,
        )
        sale_val = ws.cell(r, sale_col).value if sale_col else None
        ret_val = ws.cell(r, ret_col).value if ret_col else None
        # treat non‑numeric or None as 0 for aggregation
        sale_val = sale_val if isinstance(sale_val, (int, float)) else 0.0
        ret_val = ret_val if isinstance(ret_val, (int, float)) else 0.0
        add_to_agg(key, sale_val, ret_val)

# Write aggregated rows back to COLLECTION
out_row = 2
for key, sums in agg.items():
    # write ITEM, BR, TY, OR, SALE, RET
    for col_idx, value in enumerate(key, start=1):
        collection_ws.cell(row=out_row, column=col_idx).value = value
    collection_ws.cell(row=out_row, column=5).value = sums["SALE"]
    collection_ws.cell(row=out_row, column=6).value = sums["RET"]
    # BALANCE formula =Erow-Frow
    collection_ws.cell(row=out_row, column=7).value = f"=E{out_row}-F{out_row}"
    out_row += 1

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
from await recalculate
calc_result = await recalculate(str(output_path))
print("Recalculate result:", calc_result)

# Verify a few cells in COLLECTION
wb_check = openpyxl.load_workbook(output_path, data_only=True)
col_ws = wb_check["COLLECTION"]
print("Sample COLLECTION rows after aggregation:")
for r in range(2, min(7, col_ws.max_row + 1)):
    print([col_ws.cell(r, c).value for c in range(1, 8)])
```
