import openpyxl
from pathlib import Path

# Load the workbook
wb_path = Path("/sandbox/input/input_spreadsheet/1_398-14_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
sheet_names = wb.sheetnames
print("Sheet names:", sheet_names)

# Function to print header and sample rows for a sheet
def inspect_sheet(ws, max_rows=5):
    # Assuming first row is header
    headers = [cell.value for cell in ws[1]]
    print(f"\nSheet '{ws.title}' headers ({len(headers)} columns):", headers)
    max_row = ws.max_row
    # Print first few data rows (skip header)
    print("First data rows:")
    for r in range(2, min(2 + max_rows, max_row + 1)):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    # Print last few data rows if enough rows
    if max_row > max_rows + 1:
        print("Last data rows:")
        start = max(2, max_row - max_rows + 1)
        for r in range(start, max_row + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(r, row_vals)

# Inspect each sheet
for name in sheet_names:
    ws = wb[name]
    inspect_sheet(ws, max_rows=5)
