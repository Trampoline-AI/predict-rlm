Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_56786_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_56786_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Identify last row with a date in column A
last_data_row = 0
for r in range(ws.max_row, 1, -1):
    if ws.cell(row=r, column=1).value is not None:
        last_data_row = r
        break
print(f"Last data row based on column A: {last_data_row}")

# Write rolling average formula into column C (3) for each data row starting at row 4
for r in range(4, last_data_row + 1):
    # Build formula string
    formula = (
        f"=AVERAGEIFS($B$2:$B${last_data_row},$A$2:$A${last_data_row},"\">=\"&EDATE(A{r},-12),$A$2:$A${last_data_row},"\"<=\"&A{r})"
    )
    ws.cell(row=r, column=3).value = formula

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)
# Save workbook
wb.save(output_path)

# Recalculate formulas using LibreOffice helper
await recalculate(output_path)

# Reload with data_only to inspect results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[ws2.sheetnames[0]]

# Print a few sample results from column C
sample_rows = [4, 5, 6, last_data_row-2, last_data_row-1, last_data_row]
for r in sample_rows:
    val = ws2.cell(row=r, column=3).value
    print(f"Row {r} rolling avg: {val}")
```
