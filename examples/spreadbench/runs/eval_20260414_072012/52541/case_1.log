```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
inp_path = "/sandbox/input/input_spreadsheet/1_52541_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_52541_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(inp_path)
ws = wb[wb.sheetnames[0]]

# Identify header row (already known to be row 5)
header_row = 5

# Column indices (based on inspection)
col_amount = 8   # Amount Outstanding
col_overdue = 9   # Over Due Days
col_remarks = 10  # Remarks

# Build the new formula string using structured references (Table2)
new_formula = (
    "=IF(Table2[[#This Row],[Amount Outstanding]]<0,"
    "\"Prepaid\","
    "IF(Table2[[#This Row],[Over Due Days]]=\"\","
    "\"\","
    "IF(Table2[[#This Row],[Over Due Days]]<90,"
    "\"Call Customer\","
    "\"Bad Debts\")))"
)

# Apply the formula to all data rows (rows after header until the last non‑empty row)
data_start = header_row + 1
for r in range(data_start, ws.max_row + 1):
    # Stop if the entire row is empty (optional safety)
    if all(ws.cell(r, c).value is None for c in range(1, ws.max_column + 1)):
        continue
    ws.cell(r, col_remarks).value = new_formula

# Save to output location
wb.save(out_path)

# Recalculate formulas (LibreOffice)
await recalculate(out_path)

# Reload with data_only to verify a few cells
wb2 = openpyxl.load_workbook(out_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("Sample remarks after recalculation:")
for r in range(data_start, min(data_start + 5, ws2.max_row + 1)):
    print(r, ws2.cell(r, col_remarks).value)
