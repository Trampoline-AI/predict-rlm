ws2 = wb2[ws2.sheetnames[0]]
print("Verification after recalculation:")
for r in range(2, min(7, ws2.max_row+1)):
    print(f"Row {r}: E={ws2.cell(r,5).value}, F={ws2.cell(r,6).value}, H={ws2.cell(r,8).value}")
