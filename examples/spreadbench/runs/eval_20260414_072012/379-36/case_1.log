import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_379-36_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = out_dir + "1_379-36_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row
max_col = ws.max_column

# Show column K (11) values for first few rows to confirm target text
print("Column K sample values:")
for r in range(2, min(7, max_row+1)):
    print(f"Row {r}: K={ws.cell(r, 11).value}")

# Define fills
no_fill = PatternFill(fill_type=None)  # removes any fill

# Process rows
for r in range(2, max_row + 1):
    # Check column K for the exact text
    cell_k = ws.cell(r, 11)
    if cell_k.value == "Georgia Its Tax":
        # Get column F value
        val_f = ws.cell(r, 6).value
        # Determine if whole number (no pennies)
        is_whole = False
        if isinstance(val_f, (int, float)):
            # Use tolerance for floating point
            is_whole = abs(val_f - round(val_f)) < 1e-9
        # Update column E accordingly
        target_cell = ws.cell(r, 5)  # column E
        if is_whole:
            target_cell.value = "Georgia WH Tax"
        else:
            target_cell.value = "Georgia Sales Tax"
    # Clear background colour of column H (column 8)
    cell_h = ws.cell(r, 8)
    cell_h.fill = no_fill

# Ensure output directory exists
import os
os.makedirs(out_dir, exist_ok=True)

# Save workbook
wb.save(out_path)
print("Workbook saved to", out_path)

# Recalculate formulas
from await recalculate
result = await recalculate(out_path)
print("Recalculate result:", result)

# Reload to verify a few rows
