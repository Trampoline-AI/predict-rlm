1. Removes any character that is not a digit, minus sign, or comma (the decimal separator) using REGEX.
2. Replaces the comma with a dot so Excel/LibreOffice can interpret it as a decimal point.
3. Wraps the result with VALUE to convert the text to a number.
The formula will be placed in each data row of column C (starting at row 2). After saving, we will call recalculate() and then verify that the numeric values appear correctly.
Code:
```repl
import openpyxl
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_48257_init.xlsx"

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # assuming the data is in the first sheet

# Determine the column index for the target column ("I need:")
header_row = 1
target_col = None
for col in range(1, ws.max_column + 1):
    val = ws.cell(row=header_row, column=col).value
    if isinstance(val, str) and val.strip().lower() == "i need:":
        target_col = col
        break
if target_col is None:
    raise ValueError("Target column with header 'I need:' not found")

# Build formula string (LibreOffice compatible)
# REGEX removes everything except digits, minus, and comma.
# Then SUBSTITUTE changes comma to dot for numeric conversion.
# VALUE converts the text to a number.
formula = "=VALUE(SUBSTITUTE(REGEX(A{},"[^0-9,-]",""),",","."))"

# Apply formula to each data row
for row in range(2, ws.max_row + 1):
    # Use column A (Movement) as reference for the REGEX; the amount text is in column B.
    # Adjust the formula to point to column B (the Amount column).
    formula_row = f"=VALUE(SUBSTITUTE(REGEX(B{row},"[^0-9,-]",""),",","."))"
    ws.cell(row=row, column=target_col).value = formula_row

# Save to output location
import os
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas
from __future__ import annotations
await recalculate(output_path)

# Reload with data_only to verify results
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification of extracted numbers:")
for row in range(2, ws_check.max_row + 1):
    print(row, ws_check.cell(row=row, column=target_col).value)
```
