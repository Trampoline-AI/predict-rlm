import openpyxl
from openpyxl import load_workbook

# Load workbook
wb_path = input_spreadsheet
wb = load_workbook(wb_path, data_only=False)

# List sheet names and row counts
for ws in wb.worksheets:
    print(f"Sheet: {ws.title}, max_row: {ws.max_row}, max_column: {ws.max_column}")

    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 rows:")
    for r in range(2, min(7, ws.max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)

    # Print last 5 rows
    print("Last 5 rows:")
    start = max(2, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)

    print("-"*40)
