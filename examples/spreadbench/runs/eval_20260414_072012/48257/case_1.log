import os
import openpyxl
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_48257_init.xlsx")

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # assume the data is in the first sheet

# Locate the target column with header "I need:"
header_row = 1
target_col = None
for col in range(1, ws.max_column + 1):
    cell_val = ws.cell(row=header_row, column=col).value
    if isinstance(cell_val, str) and cell_val.strip().lower() == "i need:":
        target_col = col
        break
if target_col is None:
    raise ValueError("Target column with header 'I need:' not found")

# Build and write the formula for each data row
for row in range(2, ws.max_row + 1):
    # LibreOffice uses ';' as argument separator.
    # The formula removes "USD ", "EUR", spaces, then converts comma to dot, then VALUE.
    formula = (
        f'=VALUE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(B{row};"USD ";"");"EUR";"");" ";"");",";"."))'
    )
    ws.cell(row=row, column=target_col).value = formula

