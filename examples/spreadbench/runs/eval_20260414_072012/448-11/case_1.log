import openpyxl, os
from openpyxl.utils import get_column_letter

# Load workbook
wb = openpyxl.load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Identify rows to delete based on duplicate values in column A (column 1)
seen = set()
rows_to_delete = []

for row in range(2, ws.max_row + 1):
    val = ws.cell(row=row, column=1).value
    # Skip empty rows
    if val is None:
        continue
    if val in seen:
        rows_to_delete.append(row)
    else:
        seen.add(val)

# Delete rows from bottom to top
for row in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(row, 1)

# Save to output directory
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify deletion: count rows after deletion
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("Rows after deletion:", ws2.max_row)
