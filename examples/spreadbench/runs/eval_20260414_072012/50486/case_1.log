Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50486_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_50486_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Determine data range
max_row = ws.max_row
max_col = ws.max_column

# Write formula into column A for each data row
for r in range(2, max_row + 1):
    # Formula: if C is number -> "Chep", else if D is number -> "Loscam", else blank
    formula = f'=IF(ISNUMBER(C{r}),"Chep",IF(ISNUMBER(D{r}),"Loscam",""))'
    ws.cell(row=r, column=1).value = formula

# Save to output location
wb.save(output_path)

# Recalculate using LibreOffice (provided by the environment)
recalculate(output_path)

# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Verification of column A values (first 10 rows):")
for r in range(2, min(12, ws_check.max_row + 1)):
    print(r, ws_check.cell(r, 1).value)
```
