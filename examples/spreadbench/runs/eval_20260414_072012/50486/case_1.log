output_path = os.path.join(output_dir, "1_50486_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Determine data range
max_row = ws.max_row

# Write formula into column A for each data row
for r in range(2, max_row + 1):
    formula = f'=IF(ISNUMBER(C{r}),"Chep",IF(ISNUMBER(D{r}),"Loscam",""))'
    ws.cell(row=r, column=1).value = formula

# Save to output location
