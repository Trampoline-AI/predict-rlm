1. Load the workbook.
2. Identify all contiguous ranges where column A is non‑blank.
3. For each range, read the rows, sort them by column A, and write the sorted values back to the same cells.
4. Save the modified workbook to the output folder, recalculate formulas, and verify that the target columns contain the expected sorted data.
We will not create new sheets or columns; we will modify the existing data in place.
Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume the first sheet is the target

max_row = ws.max_row

# Helper to get cell value safely

def get_val(row, col):
    return ws.cell(row=row, column=col).value

# Identify contiguous non‑blank blocks in column A (column 1)
blocks = []
start = None
for r in range(2, max_row + 1):  # start after header row
    val = get_val(r, 1)
    if val is not None and str(val).strip() != "":
        if start is None:
            start = r
    else:
        if start is not None:
            blocks.append((start, r - 1))
            start = None
# close final block if file ends with data
if start is not None:
    blocks.append((start, max_row))

print("Detected blocks (row start‑end):", blocks)

# Sort each block by column A (alphabetical)
for (blk_start, blk_end) in blocks:
    rows = []
    for r in range(blk_start, blk_end + 1):
        a_val = get_val(r, 1)
        b_val = get_val(r, 2)
        rows.append((a_val, b_val))
    # Sort by the first element (column A) using default string ordering
    rows.sort(key=lambda x: ("" if x[0] is None else str(x[0])))
    # Write back sorted values
    for idx, (a_val, b_val) in enumerate(rows, start=blk_start):
        ws.cell(row=idx, column=1).value = a_val
        ws.cell(row=idx, column=2).value = b_val

# Save to output location
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas (if any) and reload to verify
await recalculate(output_path)
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
# Verify a few rows from each block
for (blk_start, blk_end) in blocks[:3]:  # sample first three blocks
    print(f"Block {blk_start}-{blk_end} sample:")
    for r in range(blk_start, min(blk_start+3, blk_end+1)):
        print(r, ws2.cell(r,1).value, ws2.cell(r,2).value)
```
