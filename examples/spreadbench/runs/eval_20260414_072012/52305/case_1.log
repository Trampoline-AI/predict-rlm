import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_52305_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_52305_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming the relevant sheet is the active one

# Determine first empty column after existing data
target_col_idx = ws.max_column + 1
target_col_letter = get_column_letter(target_col_idx)

# Write header for the count column
ws[f"{target_col_letter}1"] = "Count"

# Write corrected COUNTIFS formula for each data row
for row in range(2, ws.max_row + 1):
    name_cell = ws.cell(row=row, column=3)  # Column C holds the Name
    if name_cell.value is not None:
        formula = (
            f'=COUNTIFS($C:$C,${get_column_letter(3)}{row},'
            f'MOD($B:$B,1),">=TIME(21,30,0)",'
            f'MOD($B:$B,1),"< =TIME(22,0,0)")'
        )
        # Fix the stray space before <=
        formula = formula.replace("< =TIME", "<=TIME")
        ws[f"{target_col_letter}{row}"] = formula
    else:
        ws[f"{target_col_letter}{row}"] = None

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas using LibreOffice
await recalculate(output_path)

