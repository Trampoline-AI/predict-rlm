Code:
```repl
import openpyxl
from openpyxl.styles import PatternFill, Font
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_50631_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_50631_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb['Sheet1']

# 1. Determine holiday range in column J (index 10)
holiday_col = 10
last_holiday_row = 0
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=holiday_col).value
    if isinstance(val, (int, float, str, openpyxl.cell.cell.Cell)):
        # any non‑None value counts as a holiday entry
        last_holiday_row = r
# If no holidays found, default to row 1 (empty range)
if last_holiday_row < 2:
    holiday_range = "$J$1:$J$1"
else:
    holiday_range = f"$J$5:${get_column_letter(holiday_col)}${last_holiday_row}"

# 2. Update WORKDAY formulas in column H (index 8)
workday_col = 8
yellow_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
for r in range(7, ws.max_row + 1):  # based on sample, data starts at row 7
    cell = ws.cell(row=r, column=workday_col)
    if isinstance(cell.value, str) and cell.value.startswith('='):
        # Original pattern: =IF($B$3+ROWS($B$7:$B34)-1<=$F$3,WORKDAY($B$3+ROWS($B$7:$B34)-1,""))
        # We replace the empty string argument with the holiday range.
        # Extract the part before WORKDAY and after it.
        # Simple approach: replace the last occurrence of 'WORKDAY(' and the closing ')'
        import re
        # Find the inner WORKDAY call
        match = re.search(r'WORKDAY\(([^)]+)\)', cell.value)
        if match:
            inner = match.group(1)  # e.g., "$B$3+ROWS($B$7:$B34)-1"
            # Build new WORKDAY with holidays
            new_workday = f"WORKDAY({inner},{holiday_range})"
            # Replace the old WORKDAY call with the new one
            new_formula = cell.value[:match.start()] + new_workday + cell.value[match.end():]
            cell.value = new_formula
            # Apply yellow fill as "appropriate"
            cell.fill = yellow_fill

# 3. Hide gridlines
ws.sheet_view.showGridLines = False

# 4. Set Calibri font for all cells
calibri_font = Font(name='Calibri', size=11)
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        cell.font = calibri_font

# Save modified workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify that column H cells now have values (data_only load)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['Sheet1']
print("Verification of column H after recalculation (first 5 data rows):")
for r in range(7, min(12, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=workday_col).value
    print(r, val)

# End of processing
