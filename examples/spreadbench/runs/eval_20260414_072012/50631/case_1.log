ws = wb['Sheet1']

# -------------------------------------------------
# 1. Determine holiday range in column J (index 10)
holiday_col = 10
last_holiday_row = 0
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=holiday_col).value
    if val is not None:
        last_holiday_row = r
# Holidays start at row 5 (as seen in sample); if none found, use empty range
if last_holiday_row >= 5:
    holiday_range = f"$J$5:${get_column_letter(holiday_col)}${last_holiday_row}"
else:
    holiday_range = "$J$5:$J$5"   # empty range placeholder

# -------------------------------------------------
# 2. Update WORKDAY formulas in column H (index 8)
workday_col = 8
yellow_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")

for r in range(7, ws.max_row + 1):   # data rows start around 7
    cell = ws.cell(row=r, column=workday_col)
    if isinstance(cell.value, str) and cell.value.startswith('='):
        # Expected pattern: =IF(<cond>,WORKDAY(<inner>,""))
        # Extract the IF condition and the inner start expression
        m = re.match(r'^=IF\(([^,]+),\s*WORKDAY\(([^)]+)\)\s*,\s*""\s*\)', cell.value, re.IGNORECASE)
        if m:
            cond = m.group(1).strip()
            inner = m.group(2).strip()
            # Build corrected formula with days=0 and holiday range
            new_formula = f'=IF({cond},WORKDAY({inner},0,{holiday_range}),"")'
            cell.value = new_formula
            cell.fill = yellow_fill
        else:
            # Fallback: try to replace the empty second argument directly
            # Find the first WORKDAY call
            wd_match = re.search(r'WORKDAY\(([^)]+)\)', cell.value, re.IGNORECASE)
            if wd_match:
                inner = wd_match.group(1).strip()
                new_wd = f'WORKDAY({inner},0,{holiday_range})'
                cell.value = cell.value[:wd_match.start()] + new_wd + cell.value[wd_match.end():]
                cell.fill = yellow_fill

# -------------------------------------------------
# 3. Hide gridlines
ws.sheet_view.showGridLines = False

# -------------------------------------------------
# 4. Set Calibri font for all cells
calibri_font = Font(name='Calibri', size=11)
for row in ws.iter_rows(min_row=1, max_row=ws.max_row,
                        min_col=1, max_col=ws.max_column):
    for cell in row:
        cell.font = calibri_font

# -------------------------------------------------
# Save and recalculate
wb.save(output_path)
await recalculate(output_path)

# -------------------------------------------------
# Verify column H values after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['Sheet1']
print("Column H values after recalculation (first 5 data rows):")
for r in range(7, min(12, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=workday_col).value
    print(r, val)

# -------------------------------------------------
# End of processing
