Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
in_path = "/sandbox/input/input_spreadsheet/1_45944_init.xlsx"
out_dir = "/sandbox/output/output_spreadsheet/"
out_path = os.path.join(out_dir, "1_45944_init.xlsx")

# Ensure output directory exists
os.makedirs(out_dir, exist_ok=True)

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(in_path, data_only=False)
ws = wb.active  # only one sheet

# Column G (7) holds the old IF formulas
target_col = 7

# Update formulas
for row in range(2, ws.max_row + 1):
    cell = ws.cell(row=row, column=target_col)
    if isinstance(cell.value, str) and cell.value.startswith("=IF(Table1"):
        # Build new VLOOKUP formula for this row
        new_formula = f"=IF(VLOOKUP(D{row},Table1[#All],2,FALSE)>=E{row},TRUE(),FALSE())"
        cell.value = new_formula
        print(f"Updated row {row} formula to: {new_formula}")

# Save the modified workbook
wb.save(out_path)
print("Saved workbook to:", out_path)

# Recalculate formulas (async)
result = await recalculate(out_path)
print("Recalculate result:", result)

# Verify a few rows by loading with data_only=True
wb_check = openpyxl.load_workbook(out_path, data_only=True)
ws_check = wb_check.active
print("Verification of column G values (should be TRUE/FALSE):")
for r in [4, 5, 6, 20, 21, 22]:
    val = ws_check.cell(row=r, column=target_col).value
    print(f"Row {r} G: {val}")
```
