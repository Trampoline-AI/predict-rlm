output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_60-7_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Helper to read rows as tuples from a sheet (skip header row 1)
def read_rows(ws):
    rows = []
    for r in ws.iter_rows(min_row=2, max_col=ws.max_column, values_only=True):
        # Stop if the entire row is empty
        if all(v is None for v in r):
            continue
        rows.append(tuple(r))
    return rows

# Get sheets
ws_existing = wb["Existing Task"]
ws_add = wb["Additions"]
ws_retired = wb["Retired"]
ws_output = wb["Consolidated Tracker"]

