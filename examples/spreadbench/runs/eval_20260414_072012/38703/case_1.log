import openpyxl, pathlib, json
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_38703_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas
print("Sheets:", wb.sheetnames)

for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"\nSheet: {name}")
    print(f"Rows: {max_row}, Columns: {max_col}")
    print("Headers:", headers)
    # Print first 5 data rows (excluding header)
    print("First 5 rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last 5 rows
    print("Last 5 rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Merged cells
    merged = ws.merged_cells.ranges
    print(f"Merged cells ({len(merged)}):", [str(m) for m in merged])
