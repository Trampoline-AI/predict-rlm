1. Use the dynamic percentile bounds stored in G1 (lower) and H1 (upper).  
2. For each row `r` (2‑6), consider only rows **below** `r` (i.e., with a larger row index) whose percentile (column C) falls within the bounds.  
3. Compute the median of the market‑cap values (column B) of those rows.  
4. Write the resulting integer value into column E of the same row.  
5. Apply the requested formatting: left alignment, no decimals, no thousands separator, and a thin border around each cell.  

After writing the values, we will save the workbook, run `recalculate` (so LibreOffice updates any dependent formulas, though none remain), and finally verify that the target cells contain the expected numeric values and that the helper cells G1/H1 are present.
Code:
```python
```repl
import openpyxl
from pathlib import Path
from openpyxl.styles import Alignment, Border, Side

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_33722_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_33722_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Ensure helper cells for dynamic percentile bounds
ws["G1"] = 0          # lower bound
ws["H1"] = 0.01       # upper bound
ws["G1"].number_format = "0"
ws["H1"].number_format = "0.00"

# Helper to compute median of a list of numbers
def median(lst):
    n = len(lst)
    if n == 0:
        return None
    s = sorted(lst)
    mid = n // 2
    if n % 2 == 1:
        return s[mid]
    else:
        return (s[mid - 1] + s[mid]) / 2

# Determine data range (rows 2..max_row)
max_row = ws.max_row

# Extract marketcap and percentile columns into Python lists for speed
marketcaps = [ws.cell(row=r, column=2).value for r in range(2, max_row + 1)]
percentiles = [ws.cell(row=r, column=3).value for r in range(2, max_row + 1)]

# Write median values into E2:E6
align_left = Alignment(horizontal='left')
thin = Side(style='thin')
border = Border(left=thin, right=thin, top=thin, bottom=thin)

for target_row in range(2, 7):  # rows 2 through 6 inclusive
    # Indexes in Python lists are zero‑based; row 2 corresponds to index 0
    # We need rows *below* the current one, i.e., with larger row numbers
    below_indices = [i for i in range(target_row - 1, max_row - 1)  # zero‑based index start at current row
                    if percentiles[i] is not None
                    and ws["G1"].value <= percentiles[i] <= ws["H1"].value]
    # Collect marketcaps for those rows
    caps = [marketcaps[i] for i in below_indices if marketcaps[i] is not None]
    med = median(caps)
    # Write result (if no data, write blank)
    cell = ws.cell(row=target_row, column=5)  # column 5 = E
    if med is None:
        cell.value = None
    else:
        # Ensure integer format (no decimals, no commas)
        cell.value = int(med) if isinstance(med, (int, float)) else med
        cell.number_format = "0"
    # Apply formatting
    cell.alignment = align_left
    cell.border = border

# Save workbook
wb.save(output_path)

# Recalculate (LibreOffice will evaluate any remaining formulas, though none are needed here)
await recalculate(str(output_path))

# Verify the written values
wb2 = openpyxl.load_workbook(output_path, data_only=False)
ws2 = wb2[wb2.sheetnames[0]]
print("Verification of E2:E6 values:")
for r in range(2, 7):
    print(f"E{r}:", ws2.cell(row=r, column=5).value)
print("Helper cells:", ws2["G1"].value, ws2["H1"].value)
```
