```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_263-1_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_263-1_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet

# Determine data range
min_row = 2
max_row = ws.max_row
# Write header for totals if not present
if ws.cell(row=1, column=8).value is None:
    ws.cell(row=1, column=8).value = "Total Area"
if ws.cell(row=1, column=9).value is None:
    ws.cell(row=1, column=9).value = "sqf"

# Build formula string (using absolute references)
# Formula: =SUMPRODUCT((A$2:A$276=A2)*(B$2:B$276)*(C$2:C$276))
area_range = f"A${min_row}:A${max_row}"
width_range = f"B${min_row}:B${max_row}"
height_range = f"C${min_row}:C${max_row}"
for r in range(min_row, max_row + 1):
    material_cell = f"A{r}"
    formula = f"=SUMPRODUCT(({area_range}={material_cell})*({width_range})*({height_range}))"
    ws.cell(row=r, column=8).value = formula
    ws.cell(row=r, column=9).value = "sqf"

# Save workbook
wb.save(output_path)

# Recalculate (LibreOffice)
recalculate(output_path)

# Verify a few rows
ws_check = openpyxl.load_workbook(output_path, data_only=True).active
print("Sample verification (row, material, total area):")
for r in [2, 10, 50, 100, 200, 276]:
    print(r, ws_check.cell(row=r, column=1).value, ws_check.cell(row=r, column=8).value)
