1. Load the workbook.
2. Determine the data range (rows 2‑max_row, columns A‑C).
3. Ensure a header exists for the total area column (H) and unit column (I).
4. Write a SUMPRODUCT formula into each cell of column H that sums Width × Height for the material type in that row.
5. Save the workbook.
6. **Await** `recalculate(output_path)` to let LibreOffice evaluate the formulas.
7. Reload the workbook with `data_only=True` and verify that the total area values are now populated for a few sample rows.
8. Save the final workbook to the output directory.

We'll perform these steps in a single REPL block, using `await` for the asynchronous recalculation. After verification, we will be ready to submit the output spreadsheet.
Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_263-1_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_263-1_init.xlsx")

# Load workbook (read/write mode)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# Determine data range
min_row = 2
max_row = ws.max_row

# Ensure headers for total area (column H) and unit (column I)
if ws.cell(row=1, column=8).value is None:
    ws.cell(row=1, column=8).value = "Total Area"
if ws.cell(row=1, column=9).value is None:
    ws.cell(row=1, column=9).value = "sqf"

# Build absolute range strings for SUMPRODUCT
area_range = f"A${min_row}:A${max_row}"
width_range = f"B${min_row}:B${max_row}"
height_range = f"C${min_row}:C${max_row}"

# Write formula into each data row (column H) and unit into column I
for r in range(min_row, max_row + 1):
    material_cell = f"A{r}"
    formula = f"=SUMPRODUCT(({area_range}={material_cell})*({width_range})*({height_range}))"
    ws.cell(row=r, column=8).value = formula
    ws.cell(row=r, column=9).value = "sqf"

# Save workbook before recalculation
wb.save(output_path)

# Recalculate formulas using LibreOffice (await the async call)
await recalculate(output_path)

# Reload workbook with calculated values (data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Verify a few sample rows
print("Verification (row, material, total area):")
for r in [2, 10, 50, 100, 200, 276]:
    material = ws_check.cell(row=r, column=1).value
    total = ws_check.cell(row=r, column=8).value
    print(r, material, total)
```
