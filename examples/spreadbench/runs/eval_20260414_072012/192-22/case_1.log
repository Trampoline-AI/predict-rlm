import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_192-22_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_192-22_init.xlsx')

# Load workbook (we already saved a copy, but reload to be safe)
wb = openpyxl.load_workbook(output_path, data_only=False)
ws = wb['Sheet1']

# Keywords list (lowercase for case‑insensitive compare)
keywords = [
    'core activation',
    'core design',
    'mobile terminology',
    'mobile design',
    'mobile integration',
    'testing layer',
    'testing offshore',
    'carrier',
    'barrier'
]

# Process rows
for row in range(2, ws.max_row + 1):
    d_cell = ws.cell(row=row, column=4)  # Column D
    f_cell = ws.cell(row=row, column=6)  # Column F
    d_val = d_cell.value
    if isinstance(d_val, str):
        d_lower = d_val.lower()
        if any(kw in d_lower for kw in keywords):
            f_cell.value = "Billing PO"
        else:
            f_cell.value = None
    else:
        # Non‑string (e.g., None, number) → leave F blank
        f_cell.value = None

# Save modifications
wb.save(output_path)
print('Workbook saved after updating column F.')

# Recalculate formulas (if any)
calc_result = await recalculate(output_path)
print('Recalculate result:', calc_result)

# Verify by reloading with data_only=True and printing some rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['Sheet1']
print('Verification (row, Column D, Column F):')
for r in range(2, min(12, ws_check.max_row + 1)):
    print(r, ws_check.cell(r,4).value, ws_check.cell(r,6).value)
