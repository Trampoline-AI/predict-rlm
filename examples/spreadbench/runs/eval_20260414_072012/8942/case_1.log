# Function to print header and sample rows
def print_sheet_summary(ws, max_rows=10):
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f"\nSheet '{ws.title}' headers ({len(headers)} columns):")
    print(headers)
    # Print first few data rows
    for r in range(2, min(ws.max_row, max_rows)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", row_vals)
    # Print last few rows if many rows
    if ws.max_row > max_rows:
        print("... last rows ...")
        for r in range(ws.max_row - max_rows + 1, ws.max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
            print(f"Row {r}:", row_vals)

# Inspect overview sheet
if 'overview' in wb.sheetnames:
    ws_over = wb['overview']
    print("\n--- Overview sheet ---")
    # Print specific cells
    for cell_ref in ['A2','B2','C2','B5']:
        val = ws_over[cell_ref].value
        print(f"{cell_ref}: {val}")
    # Print header and sample rows
    print_sheet_summary(ws_over, max_rows=10)
else:
    print("No sheet named 'overview'")

# Inspect Pay Dates sheet
if 'Pay Dates' in wb.sheetnames:
    ws_pay = wb['Pay Dates']
    print("\n--- Pay Dates sheet ---")
    # Print header and sample rows
    print_sheet_summary(ws_pay, max_rows=10)
else:
    print("No sheet named 'Pay Dates'")
