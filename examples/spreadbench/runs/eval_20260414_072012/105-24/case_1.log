To keep the replacement dynamic for future additions, we will write an Excel VLOOKUP formula into each target cell. The formula will look up the ID in the Productivity table and return the Name; if the ID is not found, it will keep the original ID.

Steps:
1. Load the workbook.
2. Identify the last row in the Productivity sheet that contains an ID (non‑empty column A). This defines the VLOOKUP range.
3. For every data row in the Open sheet (starting at row 2), write a VLOOKUP formula into column C and column K:
   - Column C: `=IFERROR(VLOOKUP(C2, Productivity!$A$4:$B${last_row}, 2, FALSE), C2)`
   - Column K: `=IFERROR(VLOOKUP(K2, Productivity!$A$4:$B${last_row}, 2, FALSE), K2)`
   (The row number is adjusted per row.)
4. Save the modified workbook to the output directory.
5. Call `recalculate()` on the saved file, then reload it with `data_only=True` and print a few sample cells to verify the formulas were written correctly.
6. Finally, submit the path to the output spreadsheet.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_105-24_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_105-24_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheets
ws_open = wb["Open"]
ws_prod = wb["Productivity"]

# Determine last row with an ID in Productivity!A (skip header rows)
last_prod_row = 0
for r in range(ws_prod.max_row, 0, -1):
    if ws_prod.cell(row=r, column=1).value is not None:
        last_prod_row = r
        break
if last_prod_row < 4:
    raise ValueError("Could not locate data rows in Productivity sheet")

# Build VLOOKUP range string (starting at row 4 as seen in sample)
lookup_range = f"Productivity!$A$4:$B${last_prod_row}"

# Write formulas into Open sheet columns C (3) and K (11)
for row in range(2, ws_open.max_row + 1):
    # Column C
    cell_c = ws_open.cell(row=row, column=3)
    cell_c.value = f'=IFERROR(VLOOKUP(C{row}, {lookup_range}, 2, FALSE), C{row})'
    # Column K
    cell_k = ws_open.cell(row=row, column=11)
    cell_k.value = f'=IFERROR(VLOOKUP(K{row}, {lookup_range}, 2, FALSE), K{row})'

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with cached values to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Open"]
print("Sample verification (rows 2-4, columns C and K):")
for r in range(2, 5):
    print(f"Row {r}: C={ws_check.cell(r,3).value}, K={ws_check.cell(r,11).value}")

# Also print the VLOOKUP range used
print("VLOOKUP range used:", lookup_range)
```
