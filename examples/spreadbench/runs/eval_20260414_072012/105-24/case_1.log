```repl
import openpyxl
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_105-24_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_105-24_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Worksheets
ws_open = wb["Open"]
ws_prod = wb["Productivity"]

# Build ID → Name map from Productivity sheet (IDs in column A, Names in column B)
id_to_name = {}
for r in range(4, ws_prod.max_row + 1):   # data starts at row 4 as observed
    id_val = ws_prod.cell(row=r, column=1).value
    name_val = ws_prod.cell(row=r, column=2).value
    if id_val is not None:
        id_to_name[str(id_val).strip()] = name_val

# Replace IDs with Names in Open sheet columns C (3) and K (11)
for r in range(2, ws_open.max_row + 1):
    # Column C
    cell_c = ws_open.cell(row=r, column=3)
    if cell_c.value is not None:
        key = str(cell_c.value).strip()
        if key in id_to_name:
            cell_c.value = id_to_name[key]

    # Column K
    cell_k = ws_open.cell(row=r, column=11)
    if cell_k.value is not None:
        key = str(cell_k.value).strip()
        if key in id_to_name:
            cell_k.value = id_to_name[key]

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(output_path)

# Verify a few rows after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Open"]
print("Verification (rows 2‑5, columns C and K):")
for r in range(2, 6):
    print(f"Row {r}: C={ws_check.cell(r,3).value!r}, K={ws_check.cell(r,11).value!r}")
