import openpyxl
from openpyxl import load_workbook

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_105-24_init.xlsx"
wb = load_workbook(wb_path, data_only=False)

# Print sheet names
print("Sheet names:", wb.sheetnames)

def print_sheet_info(ws, max_rows=5):
    # Assume first row is header
    headers = [cell.value for cell in ws[1]]
    print(f"\nSheet '{ws.title}' headers: {headers}")
    max_row = ws.max_row
    # Print first few rows (excluding header)
    print("First rows:")
    for r in range(2, min(2 + max_rows, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    # Print last few rows
    if max_row > max_rows + 1:
        print("Last rows:")
        start = max(2, max_row - max_rows + 1)
        for r in range(start, max_row + 1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
            print(r, row_vals)

# Iterate sheets
for ws in wb.worksheets:
    print_sheet_info(ws)
