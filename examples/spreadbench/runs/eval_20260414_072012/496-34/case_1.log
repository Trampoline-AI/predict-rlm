for r in range(2, ws.max_row + 1):
    if ws.cell(row=r, column=1).value is not None:
        last_data_row = r

# Helper to get the top‑left cell of a merged region containing (row, col)
def get_writable_cell(row, col):
    coord = f"{get_column_letter(col)}{row}"
    # If the cell is a MergedCell, find the master cell
    cell = ws.cell(row=row, column=col)
    if isinstance(cell, MergedCell):
        # Find the merged range that contains this coordinate
        for mr in ws.merged_cells.ranges:
            if coord in mr:
                # Return the top‑left cell of that range
                tl = mr.min_row, mr.min_col
                return ws.cell(row=tl[0], column=tl[1])
    # Not merged, return the cell itself
    return cell

# Write the formula into column F (6) for each data row
for r in range(2, last_data_row + 1):
    formula = (
        f'=IF(COUNTIF($A$2:A{r}, A{r})=1, '
