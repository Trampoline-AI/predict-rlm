ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification of column F values:")
for r in range(2, last_data_row + 1):
    print(f"Row {r}: ID={ws_check.cell(r,1).value}, Total={ws_check.cell(r,6).value}")

