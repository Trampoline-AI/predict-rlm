import openpyxl
from openpyxl.utils import get_column_letter
import os

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine data range (exclude completely empty trailing rows)
max_row = ws.max_row
max_col = ws.max_column

# Identify the last row that has an ID (non‑None in column A)
last_data_row = 1
for r in range(2, max_row + 1):
    if ws.cell(row=r, column=1).value is not None:
        last_data_row = r

# Write formula into column F (6) for each data row
for r in range(2, last_data_row + 1):
    # Build formula with absolute references to the full data range
    formula = f'=IF(COUNTIF($A$2:A{r}, A{r})=1, SUMIF($A$2:$A${last_data_row}, A{r}, $D$2:$D${last_data_row}), "")'
    ws.cell(row=r, column=6).value = formula

# Prepare output path
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_496-34_init.xlsx")

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload to verify (data_only=True to see computed values)
