```repl
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.cell import MergedCell
import os

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine the last data row that has an ID in column A
last_data_row = 1
for r in range(2, ws.max_row + 1):
    if ws.cell(row=r, column=1).value is not None:
        last_data_row = r

# Build a set of rows that are the top‑left cell of a merged region in column F (6)
merged_master_rows = set()
for mr in ws.merged_cells.ranges:
    # If the merged range includes column F (col 6)
    if mr.min_col <= 6 <= mr.max_col:
        merged_master_rows.add(mr.min_row)

# Helper to decide whether a cell can hold a value (i.e., is the master cell)
def is_master_cell(row, col):
    cell = ws.cell(row=row, column=col)
    if isinstance(cell, MergedCell):
        # Only the top‑left cell of the merged range is writable
        return row in merged_master_rows
    return True  # not merged, writable

# Write the formula into column F (6) only for master cells
for r in range(2, last_data_row + 1):
    if not is_master_cell(r, 6):
        # Skip cells that are part of a merged block but not the master
        continue
    formula = (
        f'=IF(COUNTIF($A$2:A{r}, A{r})=1, '
        f'SUMIF($A$2:$A${last_data_row}, A{r}, $D$2:$D${last_data_row}), "")'
    )
    ws.cell(row=r, column=6).value = formula

# Save to output directory
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_496-34_init.xlsx")
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify results (load with data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of column F (Total per ID) values:")
for r in range(2, last_data_row + 1):
    id_val = ws_check.cell(row=r, column=1).value
    total_val = ws_check.cell(row=r, column=6).value
    print(f"Row {r}: ID={id_val}, Total={total_val}")
