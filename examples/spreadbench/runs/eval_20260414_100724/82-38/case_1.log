from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Instruction:\n", instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_used_range_info(ws):
    max_row, max_col = ws.max_row, ws.max_column
    # Find non-empty rows/cols more accurately
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value not in (None, ""):
                row_has = True
                nonempty_cols.add(cell.column)
        if row_has:
            nonempty_rows.append(row[0].row)
    true_max_row = max(nonempty_rows) if nonempty_rows else 0
    true_min_row = min(nonempty_rows) if nonempty_rows else 0
    true_max_col = max(nonempty_cols) if nonempty_cols else 0
    return {
        "ws_max_row": max_row,
        "ws_max_col": max_col,
        "true_min_row": true_min_row,
        "true_max_row": true_max_row,
        "true_max_col": true_max_col,
    }

def row_values(ws, r, upto=None):
    upto = upto or ws.max_column
    vals = []
    for c in range(1, upto + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

for s in wb.sheetnames:
    ws = wb[s]
    info = sheet_used_range_info(ws)
    print(f"\n=== Sheet: {s} ===")
    print(info)
    upto = min(max(info["true_max_col"], 1), 12)
    print("Top rows:")
    for r in range(1, min(info["true_max_row"], 10) + 1):
        print(r, row_values(ws, r, upto))
    if info["true_max_row"] > 10:
        print("Bottom rows:")
        start = max(1, info["true_max_row"] - 4)
        for r in range(start, info["true_max_row"] + 1):
            print(r, row_values(ws, r, upto))

# Focused inspection: SH1 and DATA
for s in ["SH1", "DATA"]:
    if s in wb.sheetnames:
        ws = wb[s]
        print(f"\n--- Focused inspection for {s} ---")
        upto = min(ws.max_column, 15)
        for r in range(1, min(ws.max_row, 25) + 1):
            vals = row_values(ws, r, upto)
            if any(v not in (None, "") for v in vals):
                print(r, vals)

# Search SH1 for relevant markers
if "SH1" in wb.sheetnames:
    ws = wb["SH1"]
    invoice_cells = []
    total_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str):
                txt = cell.value.strip().upper()
                if txt == "INVOICE NO":
                    invoice_cells.append(cell.coordinate)
                if txt == "TOTAL":
                    total_cells.append(cell.coordinate)
    print("\nSH1 invoice header cells:", invoice_cells)
    print("SH1 TOTAL cells:", total_cells[:50], "count=", len(total_cells))
    
    # Print neighborhoods around invoice headers
    for coord in invoice_cells:
        cell = ws[coord]
        r, c = cell.row, cell.column
        print(f"\nNeighborhood around {coord}:")
        for rr in range(max(1, r-1), min(ws.max_row, r+6) + 1):
            vals = []
            for cc in range(max(1, c-2), min(ws.max_column, c+3) + 1):
                vals.append(f"{get_column_letter(cc)}{rr}={ws.cell(rr,cc).value}")
            print(" | ".join(vals))

# Inspect DATA columns D and E and any existing formulas/values
if "DATA" in wb.sheetnames:
    ws = wb["DATA"]
    print("\nDATA columns D and E (rows with any content in first 10 cols):")
