from openpyxl import load_workbook
from pathlib import Path
import os

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Reload fresh workbook for editing
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
ws_sh1 = wb["SH1"]
ws_data = wb["DATA"]

def parse_sh1_invoice_list(ws):
    invoices = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 4).value  # D
        if isinstance(v, str) and v.strip().upper() == "INVOICE NO":
            inv = ws.cell(r + 1, 4).value
            if inv not in (None, ""):
                invoices.append(str(inv).strip())
    return invoices

def parse_groups(ws):
    groups = []
    r = 2  # row 1 header
    while r <= ws.max_row:
        row_has_data = any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1))
        if not row_has_data:
            r += 1
            continue
        start = r
        end = r
        while end <= ws.max_row:
            a = ws.cell(end, 1).value
            if isinstance(a, str) and a.strip().upper() == "TOTAL":
                break
            end += 1
        if end > ws.max_row:
            end = ws.max_row
        groups.append({
            "start": start,
            "end": end,
            "sheet_name": ws.cell(start, 5).value,
            "current_d": [ws.cell(rr, 4).value for rr in range(start, end + 1)],
        })
        r = end + 1
    return groups

invoice_list = parse_sh1_invoice_list(ws_sh1)
groups = parse_groups(ws_data)

print("Invoice list from SH1:", invoice_list)
print("DATA groups before update:")
for i, g in enumerate(groups, 1):
    print(i, g["start"], g["end"], g["sheet_name"], list(dict.fromkeys(g["current_d"])))

# Apply updates only to groups where E matches "SH1", in sequential order, and only while invoices remain.
target_sheet_name = "SH1"
invoice_idx = 0
changes = []

for g in groups:
    sheet_name = g["sheet_name"]
    if str(sheet_name).strip() == target_sheet_name and invoice_idx < len(invoice_list):
        new_invoice = invoice_list[invoice_idx]
        for rr in range(g["start"], g["end"] + 1):
            old = ws_data.cell(rr, 4).value
            ws_data.cell(rr, 4).value = new_invoice
            changes.append((rr, old, new_invoice, ws_data.cell(rr, 5).value))
        invoice_idx += 1
    else:
        # unmatched or extra groups are left unchanged
        pass

print("\nApplied changes (row, old, new, E):")
for ch in changes:
    print(ch)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Reload after recalc, fix sheet names if they changed
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames:
    # restore original names in order if same count
    if len(wb_post.sheetnames) == len(original_sheetnames):
        for ws_obj, original_name in zip(wb_post.worksheets, original_sheetnames):
            ws_obj.title = original_name
        wb_post.save(output_path)
        print("Restored sheet names to:", original_sheetnames)
    else:
        print("WARNING: sheet count changed; not renaming automatically.")

# Verify using data_only workbook
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["DATA"]

print("\nDATA!D/E verification rows 1:17")
for r in range(1, 18):
    print(r, {"A": wsv.cell(r,1).value, "D": wsv.cell(r,4).value, "E": wsv.cell(r,5).value})

# Compact group verification
verify_groups = parse_groups(wsv)
print("\nVerified DATA groups:")
for i, g in enumerate(verify_groups, 1):
    print(i, {"rows": f"{g['start']}:{g['end']}", "sheet_name": g["sheet_name"], "D_unique": list(dict.fromkeys(g["current_d"]))})

final_output_spreadsheet = str(output_path)
print("\nPrepared output file:", final_output_spreadsheet)
