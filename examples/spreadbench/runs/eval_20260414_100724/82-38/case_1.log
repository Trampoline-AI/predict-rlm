from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws_sh1 = wb["SH1"]
ws_data = wb["DATA"]
ws_fake = wb["FAKE"]

def parse_sh1_blocks(ws):
    blocks = []
    for row in range(1, ws.max_row + 1):
        v = ws.cell(row, 4).value  # column D
        if isinstance(v, str) and v.strip().upper() == "INVOICE NO":
            invoice = ws.cell(row + 1, 4).value
            total_row = None
            for r in range(row + 2, ws.max_row + 1):
                g = ws.cell(r, 7).value  # column G
                if isinstance(g, str) and g.strip().upper() == "TOTAL":
                    total_row = r
                    break
            blocks.append({
                "header_row": row,
                "invoice_row": row + 1,
                "invoice": invoice,
                "total_row": total_row,
            })
    return blocks

def parse_data_groups(ws):
    groups = []
    r = 2  # row 1 header
    while r <= ws.max_row:
        a = ws.cell(r, 1).value
        e = ws.cell(r, 5).value
        d = ws.cell(r, 4).value
        # identify a non-empty group start row
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            start = r
            end = r
            while end <= ws.max_row:
                if isinstance(ws.cell(end, 1).value, str) and ws.cell(end, 1).value.strip().upper() == "TOTAL":
                    break
                end += 1
            if end > ws.max_row:
                end = ws.max_row
            group_rows = list(range(start, end + 1))
            groups.append({
                "start": start,
                "end": end,
                "sheet_name": ws.cell(start, 5).value,
                "d_values": [ws.cell(rr, 4).value for rr in group_rows],
                "a_values": [ws.cell(rr, 1).value for rr in group_rows],
            })
            r = end + 1
        else:
            r += 1
    return groups

sh1_blocks = parse_sh1_blocks(ws_sh1)
data_groups = parse_data_groups(ws_data)
fake_groups = parse_data_groups(ws_fake)

print("SH1 blocks summary:")
for i, b in enumerate(sh1_blocks, 1):
    print(i, b)

print("\nDATA groups summary:")
for i, g in enumerate(data_groups, 1):
    uniq_d = list(dict.fromkeys(g["d_values"]))
