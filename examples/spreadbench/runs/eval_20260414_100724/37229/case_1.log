import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Using sheet:", ws.title)
print("Original sheet names:", original_sheetnames)

# Reconfirm target/source areas before writing
print("Target months B3:B14:")
for r in range(3, 15):
    print(r, ws[f"B{r}"].value)

print("Source data B17:G24:")
for r in range(17, 25):
    print(r, [ws.cell(r, c).value for c in range(2, 8)])

print("Current target C3:G14 before writing:")
for r in range(3, 15):
    print(r, [ws.cell(r, c).value for c in range(3, 8)])

# Write formulas to C3:G14
# Sum each data column by matching month/year of source date B17:B24 to target month date in column B.
for r in range(3, 15):
    for c in range(3, 8):  # C:G
        col = get_column_letter(c)
        formula_core = f'SUMIFS({col}$17:{col}$24,$B$17:$B$24,">="&$B{r},$B$17:$B$24,"<"&DATE(YEAR($B{r}),MONTH($B{r})+1,1))'
        ws.cell(r, c).value = f'=IF({formula_core}=0,"",{formula_core})'

print("Formulas written to C3:G14:")
for r in range(3, 15):
    print(r, [ws.cell(r, c).value for c in range(3, 8)])

# Save to output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # Rename sheets back by position
    for i, old_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas still present in formula workbook
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Verified formulas in C3:G14:")
for r in range(3, 15):
    print(r, [ws_formula.cell(r, c).value for c in range(3, 8)])

# Verify calculated values in data_only workbook
wb_values = load_workbook(outfile, data_only=True)
sheet_name_for_values = original_sheetnames[0] if original_sheetnames[0] in wb_values.sheetnames else wb_values.sheetnames[0]
ws_values = wb_values[sheet_name_for_values]

print("Calculated values in C3:G14 after recalc:")
for r in range(3, 15):
    vals = [ws_values.cell(r, c).value for c in range(3, 8)]
    print(r, vals)

# Basic sanity checks on key rows based on visible sample data
print("Sanity check key cells:")
for addr in ["C3","D3","E3","C4","D4","E4","F4","G4","C5","D5","E5"]:
    print(addr, "formula:", ws_formula[addr].value, "| value:", ws_values[addr].value)

output_spreadsheet = outfile
