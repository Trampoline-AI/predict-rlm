```repl
import os
from datetime import datetime, time
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload original workbook fresh
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Find true last data row based on A:D having any value
last_data_row = 1
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    if any(v not in (None, "") for v in vals):
        last_data_row = r
print("True last data row based on A:D:", last_data_row)

# Print criteria / target setup again briefly
print("Criteria:")
for coord in ["I3", "K3", "J5", "K5", "L5", "M5", "N5", "H6", "I6", "H23", "I23"]:
    print(coord, ws[coord].value)

# Helper to convert datetime/time to fraction of day for Python verification
def tod_fraction(v):
    if isinstance(v, datetime):
        t = v.time()
    elif isinstance(v, time):
        t = v
    else:
        return None
    return (t.hour*3600 + t.minute*60 + t.second + t.microsecond/1_000_000) / 86400

# Build Python sanity-check counts
dest_crit = ws["I3"].value
type_crit = ws["K3"].value
name_headers = [ws.cell(5, c).value for c in range(10, 15)]  # J:N

python_counts = {}
for r in range(6, 25):
    start = ws.cell(r, 8).value  # H
    end = ws.cell(r, 9).value    # I
    start_f = tod_fraction(start)
    end_f = tod_fraction(end)
    row_counts = []
    for c in range(10, 15):
        name = ws.cell(5, c).value
        cnt = 0
        for sr in range(2, last_data_row + 1):
            typ = ws.cell(sr, 1).value
            dtv = ws.cell(sr, 2).value
            nm = ws.cell(sr, 3).value
            dest = ws.cell(sr, 4).value
            tf = tod_fraction(dtv)
            if (
                typ == type_crit
                and dest == dest_crit
                and nm == name
                and tf is not None
                and start_f <= tf < end_f
            ):
                cnt += 1
        row_counts.append(cnt)
    python_counts[r] = row_counts

print("Python sanity-check counts for a few rows:")
for r in [6, 16, 20, 22, 23, 24]:
    print(r, python_counts[r])

# Write formulas into J6:N24
for r in range(6, 25):
    for c in range(10, 15):  # J:N
        cell = ws.cell(r, c)
        # SUMPRODUCT is used because we must ignore the date portion in col B via MOD(B,1)
        formula = (
            f'=SUMPRODUCT(($C$2:$C${last_data_row}={get_column_letter(c)}$5)*'
            f'($D$2:$D${last_data_row}=$I$3)*'
            f'($A$2:$A${last_data_row}=$K$3)*'
            f'(MOD($B$2:$B${last_data_row},1)>=$H{r})*'
            f'(MOD($B$2:$B${last_data_row},1)<$I{r}))'
        )
        cell.value = formula

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for old, new in zip(orig_sheet_names, wb_check.sheetnames):
        if old != new:
            wb_check[new].title = old
    wb_check.save(out_path)
    print("Renamed sheets back to original names:", orig_sheet_names)

# Verify formulas and evaluated values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nSample formulas in target range:")
for coord in ["J6", "J23", "K23", "L20", "N24"]:
    print(coord, "formula =", ws_formula[coord].value)

print("\nEvaluated target J6:N24:")
for r in range(6, 25):
    vals = [ws_values.cell(r, c).value for c in range(10, 15)]
    print(r, vals)

# Cross-check a few cells against Python counts
print("\nCross-check against Python counts:")
for r in [6, 16, 20, 22, 23, 24]:
    excel_vals = [ws_values.cell(r, c).value for c in range(10, 15)]
    print("Row", r, "excel=", excel_vals, "python=", python_counts[r])

output_spreadsheet = out_path
