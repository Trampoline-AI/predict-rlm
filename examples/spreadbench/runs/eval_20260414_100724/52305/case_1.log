import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # print headers for first few rows to detect actual header row
    for r in range(1, min(ws.max_row, 5) + 1):
        print(f"Row {r}:", row_values(ws, r, min(ws.max_column, 12)))
    # identify likely header row as first row with at least 2 non-empty cells
    header_candidates = []
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty >= 2:
            header_candidates.append((r, vals))
    print("Header candidates (first 10 rows):", [(r, vals[:12]) for r, vals in header_candidates[:5]])
    
    # sample first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    # sample last 5 rows
    print("Last rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))

    # show formulas in used range (up to first 20 rows/20 cols)
    formula_cells = []
    for r in range(1, min(ws.max_row, 25) + 1):
        for c in range(1, min(ws.max_column, 20) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first 25x20 region:", formula_cells[:30], "count=", len(formula_cells))
