```repl
from openpyxl import load_workbook
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet2"]

# Determine true last non-empty row for A:F
last_nonempty = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value is not None for c in range(1, 7)):
        last_nonempty = r

print("Original sheet names:", orig_sheet_names)
print("True last non-empty row:", last_nonempty)

# Build row records for populated rows
records = []
for r in range(2, last_nonempty + 1):
    emp = ws.cell(r, 1).value
    month_dt = ws.cell(r, 3).value
    hours = ws.cell(r, 4).value
    if emp is None and month_dt is None and hours is None:
        continue
    records.append({
        "row": r,
        "emp": emp,
        "month_dt": month_dt,
        "month_idx": month_dt.year * 12 + month_dt.month if month_dt else None,
        "hours": hours,
    })

# Group by employee
by_emp = {}
for rec in records:
    by_emp.setdefault(rec["emp"], []).append(rec)

# Compute expected outputs based on current month + previous 3 months
computed = {}
for emp, emp_recs in by_emp.items():
    # sort by date, but store result by original row
    emp_recs = sorted(emp_recs, key=lambda x: x["month_idx"])
    for rec in emp_recs:
        curr_idx = rec["month_idx"]
        window = [x for x in emp_recs if x["month_idx"] is not None and curr_idx - 3 <= x["month_idx"] <= curr_idx]
        if len(window) < 4:
            avg_out = "n/a"
            flag_out = "n/a - less that 4 weeks"
        else:
            avg_num = sum(x["hours"] for x in window) / len(window)
            avg_num = round(avg_num, 1)  # align with shown examples like 42.5 / 53.5
            if abs(avg_num - round(avg_num)) < 1e-9:
                avg_out = int(round(avg_num))
            else:
                avg_out = avg_num
            flag_out = "More than 48" if avg_num > 48 else "Less that 48"
        computed[rec["row"]] = (avg_out, flag_out)

# Print concise mismatch summary before writing
mismatches = []
for r in range(2, last_nonempty + 1):
    existing_e = ws.cell(r, 5).value
    existing_f = ws.cell(r, 6).value
    comp_e, comp_f = computed[r]
    if existing_e != comp_e or existing_f != comp_f:
        mismatches.append((r, existing_e, comp_e, existing_f, comp_f))

print("Mismatches before writing:")
for m in mismatches:
    print(m)
print("Mismatch count:", len(mismatches))

# Write only blanks or mismatches in E:F for populated rows
for r in range(2, last_nonempty + 1):
    if not any(ws.cell(r, c).value is not None for c in range(1, 4+1)):
        continue
    comp_e, comp_f = computed[r]
    if ws.cell(r, 5).value != comp_e:
        ws.cell(r, 5).value = comp_e
    if ws.cell(r, 6).value != comp_f:
        ws.cell(r, 6).value = comp_f

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(str(output_path))
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    if len(wb_after.sheetnames) == len(orig_sheet_names):
        for i, old_name in enumerate(orig_sheet_names):
            wb_after.worksheets[i].title = old_name
        wb_after.save(output_path)
        print("Renamed sheets back to:", orig_sheet_names)

# Verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

print("\nVerified target range A:F rows 2:25")
for r in range(2, last_nonempty + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

# Explicit checks for no blank outputs in target rows
blank_targets = []
for r in range(2, last_nonempty + 1):
    if any(wsv.cell(r, c).value is not None for c in range(1, 5)):
        if wsv.cell(r, 5).value in (None, "") or wsv.cell(r, 6).value in (None, ""):
            blank_targets.append(r)
print("\nRows with blank target cells after verification:", blank_targets)

final_output_spreadsheet = str(output_path)
