import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load and modify
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
deletion_info = []

for ws in wb.worksheets:
    target_row = None
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if isinstance(v, str) and "invoice no." in v.lower():
            target_row = r
            break
    deletion_info.append((ws.title, ws.max_row, target_row))
    print(f"Before modification - sheet {ws.title}: max_row={ws.max_row}, first match row={target_row}")
    if target_row and target_row > 1:
        # Show values around target before deletion
        for rr in range(max(1, target_row - 3), min(ws.max_row, target_row + 2) + 1):
            print(" pre", ws.title, rr, ws.cell(rr, 1).value)
        ws.delete_rows(1, target_row - 1)
        print(f"Deleted rows 1:{target_row-1} in {ws.title}")
    elif target_row == 1:
        print(f"No deletion needed in {ws.title}; target already at row 1")
    else:
        print(f"No 'Invoice No.' found in {ws.title}; no changes made")

wb.save(output_path)
print("Saved initial output to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring to", original_sheetnames)
    for i, expected_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected_name
    wb_after.save(output_path)
else:
    print("Sheet names preserved after recalc:", wb_after.sheetnames)

# Verification with formulas/view workbook
wb_verify = load_workbook(output_path)
print("Verification workbook sheetnames:", wb_verify.sheetnames)
for ws in wb_verify.worksheets:
    print(f"\nVerified sheet: {ws.title}, rows={ws.max_row}, cols={ws.max_column}")
    # Print first 10 rows of column A after deletion
    for r in range(1, min(ws.max_row, 10) + 1):
        print(" post", ws.title, r, ws.cell(r, 1).value)
    # Re-scan for Invoice No.
    matches = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if isinstance(v, str) and "invoice no." in v.lower():
            matches.append((r, v))
    print("Matches after deletion:", matches)

# Verification with data_only too
wb_data = load_workbook(output_path, data_only=True)
for ws in wb_data.worksheets:
    print(f"Data-only check {ws.title}: row1={ws.cell(1,1).value!r}, row_count={ws.max_row}")
