import os, json, math, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
print("Workbook sheets:", wb.sheetnames)

inspection = {}

for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    
    # headers from first non-empty-ish row candidates 1..5
    candidate_rows = []
    for r in range(1, min(max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        nonempty = sum(v is not None and str(v).strip() != "" for v in vals)
        candidate_rows.append((r, nonempty, vals[:min(max_col, 12)]))
    
    # sample rows: first 10 and last 5
    first_rows = []
    for r in range(1, min(max_row, 10) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        first_rows.append((r, row_vals[:min(max_col, 12)]))
    
    last_rows = []
    start_last = max(1, max_row - 4)
    for r in range(start_last, max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        last_rows.append((r, row_vals[:min(max_col, 12)]))
    
    # scan column A for invoice no text case-insensitive
    matches = []
    colA_preview = []
    for r in range(1, max_row + 1):
        v = ws.cell(r, 1).value
        if r <= 20:
            colA_preview.append((r, v))
        if isinstance(v, str) and "invoice no." in v.lower():
            matches.append((r, v))
    
    inspection[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "candidate_rows": candidate_rows,
        "first_rows": first_rows,
        "last_rows": last_rows,
        "matches": matches,
        "colA_preview": colA_preview,
    }

for sheet, info in inspection.items():
    print("\n" + "="*80)
    print(f"Sheet: {sheet}")
    print(f"Dimensions: {info['max_row']} rows x {info['max_col']} cols")
    print("Top candidate header rows (row, nonempty_count, first 12 vals):")
    for item in info["candidate_rows"]:
        print(item)
    print("First rows:")
    for item in info["first_rows"]:
        print(item)
    print("Last rows:")
    for item in info["last_rows"]:
        print(item)
    print("Column A preview (first 20 rows):")
    for item in info["colA_preview"]:
        print(item)
    print("Matches for 'Invoice No.' in column A:")
    print(info["matches"] if info["matches"] else "None")
