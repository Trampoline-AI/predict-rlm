    ws[f"K{r}"] = f'=IFERROR(SUMPRODUCT(($B$3:$B$42=H{r})*$C$3:$C$42*$E$3:$E$42)/SUMIF($B$3:$B$42,H{r},$C$3:$C$42),"")'
    ws[f"L{r}"] = f'=IFERROR(SUMPRODUCT(($B$3:$B$42=H{r})*$C$3:$C$42*$F$3:$F$42)/SUMIF($B$3:$B$42,H{r},$C$3:$C$42),"")'

print("\nRewritten formulas J3:L6:")
