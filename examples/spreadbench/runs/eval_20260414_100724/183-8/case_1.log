import os
from collections import defaultdict
from openpyxl import load_workbook

# Load workbook
infile = input_spreadsheet
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheet names:", orig_sheetnames)
print("Target sheet:", ws.title)

# Compute expected weighted averages in Python for verification
detail_rows = []
for r in range(3, ws.max_row + 1):
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    d = ws[f"D{r}"].value
    e = ws[f"E{r}"].value
    f = ws[f"F{r}"].value
    if isinstance(b, str) and isinstance(c, (int, float)) and isinstance(d, (int, float)) and isinstance(e, (int, float)) and isinstance(f, (int, float)):
        detail_rows.append(r)

agg = defaultdict(lambda: {"w": 0.0, "wd": 0.0, "we": 0.0, "wf": 0.0, "rows": []})
for r in detail_rows:
    fy = ws[f"B{r}"].value
    wt = float(ws[f"C{r}"].value)
    agg[fy]["w"] += wt
    agg[fy]["wd"] += wt * float(ws[f"D{r}"].value)
    agg[fy]["we"] += wt * float(ws[f"E{r}"].value)
    agg[fy]["wf"] += wt * float(ws[f"F{r}"].value)
    agg[fy]["rows"].append(r)

print("\nExpected weighted averages by FY (Python):")
expected = {}
for r in range(3, 7):
    fy = ws[f"H{r}"].value
    a = agg[fy]
    expected[r] = {
        "FY": fy,
        "J": a["wd"] / a["w"],
        "K": a["we"] / a["w"],
        "L": a["wf"] / a["w"],
        "weight_sum": a["w"],
        "rows": a["rows"],
    }
    print(r, expected[r])

# Print existing nearby formulas to preserve pattern understanding
print("\nExisting formulas near target:")
for coord in ["I3","I4","I5","I6","J7","K7","L7"]:
    print(coord, "=", ws[coord].value)

# Write formulas only in J3:L6
# Use bounded ranges to avoid header text and keep Calc compatibility.
for r in range(3, 7):
    ws[f"J{r}"] = f'=IFERROR(SUMPRODUCT(($B$3:$42=H{r})*$C$3:$42*$D$3:$42)/SUMPRODUCT(($B$3:$42=H{r})*$C$3:$42),"")'
    ws[f"K{r}"] = f'=IFERROR(SUMPRODUCT(($B$3:$42=H{r})*$C$3:$42*$E$3:$42)/SUMPRODUCT(($B$3:$42=H{r})*$C$3:$42),"")'
    ws[f"L{r}"] = f'=IFERROR(SUMPRODUCT(($B$3:$42=H{r})*$C$3:$42*$F$3:$42)/SUMPRODUCT(($B$3:$42=H{r})*$C$3:$42),"")'

print("\nWritten formulas J3:L6:")
for r in range(3, 7):
    print(r, ws[f"J{r}"].value, ws[f"K{r}"].value, ws[f"L{r}"].value)

# Save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename back in order
    for i, expected_name in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected_name
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and evaluated values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("\nVerification of target cells J3:L6:")
for r in range(3, 7):
    formula_vals = [ws_formula[f"{col}{r}"].value for col in ["J","K","L"]]
    data_vals = [ws_values[f"{col}{r}"].value for col in ["J","K","L"]]
    print(
        f"Row {r} FY={ws_values[f'H{r}'].value!r} | formulas={formula_vals} | values={data_vals} | expected={[expected[r]['J'], expected[r]['K'], expected[r]['L']]}"
    )

# Keep output path in variable for submission
final_output_spreadsheet = outfile
