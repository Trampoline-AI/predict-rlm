```repl
from openpyxl import load_workbook
from openpyxl.styles import Border, Side, Font
import os, re

# Reload original workbook for modification
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
original_sheet_names = wb.sheetnames[:]

print("Inspecting exact source cells B2:B6 and target C2:C6")
for r in range(2, 7):
    print(f"Row {r} A={ws[f'A{r}'].value!r}")
    print(f"   B{r}={ws[f'B{r}'].value!r}")
    print(f"   C{r} current={ws[f'C{r}'].value!r}")

def count_non_xz_locations(text):
    if text is None:
        return None, []
    parts = [p.strip() for p in str(text).split(",") if p is not None and str(p).strip() != ""]
    included = []
    excluded = []
    for p in parts:
        # Count a location entry unless it starts with X or Z
        stripped = p.lstrip()
        if stripped.upper().startswith("X") or stripped.upper().startswith("Z"):
            excluded.append(p)
        else:
            included.append(p)
    return len(included), {"included": included, "excluded": excluded, "all_parts": parts}

preview_counts = {}
for r in range(2, 7):
    cnt, detail = count_non_xz_locations(ws[f"B{r}"].value)
    preview_counts[r] = cnt
    print(f"\nRow {r} split parts:")
    print("  all:", detail["all_parts"])
    print("  included:", detail["included"])
    print("  excluded:", detail["excluded"])
    print("  => count to write in C{0}: {1}".format(r, cnt))

# Apply values to C2:C6
for r in range(2, 7):
    ws[f"C{r}"] = preview_counts[r]

# Apply all borders + Courier New 9 pt to C2:C6
thin = Side(style="thin", color="000000")
all_border = Border(left=thin, right=thin, top=thin, bottom=thin)
font = Font(name="Courier New", size=9)

for r in range(2, 7):
    cell = ws[f"C{r}"]
    cell.border = all_border
    cell.font = font

# Save to output path
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate per instructions
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # Rename back by position
    for i, expected in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
print("\nVerification:")
print("Sheet names final:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

for r in range(2, 7):
    print(f"C{r} verified value={wsv[f'C{r}'].value!r}")

# Verify formatting from non-data_only workbook
wb_fmt = load_workbook(output_path)
wsf = wb_fmt[original_sheet_names[0]]
for r in range(2, 7):
    c = wsf[f"C{r}"]
    print(
        f"C{r} style -> font=({c.font.name}, {c.font.sz}), "
        f"borders=({c.border.left.style},{c.border.right.style},{c.border.top.style},{c.border.bottom.style})"
    )

output_spreadsheet = output_path
```
