```repl
from openpyxl import load_workbook
from copy import copy
import os

path = input_spreadsheet
wb = load_workbook(path)
ws_main = wb["Main unique ID"]
ws_get = wb["Result what i am getting"]
ws_exp = wb["Result what i am expecting "]

# Read IDs
main_ids = [ws_main.cell(r, 1).value for r in range(1, ws_main.max_row + 1) if ws_main.cell(r, 1).value is not None]
get_ids = [ws_get.cell(r, 1).value for r in range(2, ws_get.max_row + 1) if ws_get.cell(r, 1).value is not None]
exp_ids = [ws_exp.cell(r, 1).value for r in range(2, ws_exp.max_row + 1) if ws_exp.cell(r, 1).value is not None]

missing = [x for x in main_ids if x not in get_ids]

print("Main IDs:", main_ids)
print("Getting IDs:", get_ids)
print("Expected IDs:", exp_ids)
print("Missing IDs (Main - Getting):", missing)

# Show expected rows for missing IDs
print("\nExpected sheet rows for missing IDs:")
for mid in missing:
    for r in range(2, ws_exp.max_row + 1):
        if ws_exp.cell(r, 1).value == mid:
            print(f"Expected row {r} for ID {mid}: {[ws_exp.cell(r, c).value for c in range(1, ws_exp.max_column + 1)]}")
            break

# Show neighboring rows in getting sheet around intended insertion points
print("\nNeighbor rows in 'getting' around insertion points:")
for mid in missing:
    prev_ids = [x for x in main_ids if x < mid and x in get_ids]
    next_ids = [x for x in main_ids if x > mid and x in get_ids]
    prev_id = prev_ids[-1] if prev_ids else None
    next_id = next_ids[0] if next_ids else None
    prev_row = next((r for r in range(2, ws_get.max_row + 1) if ws_get.cell(r,1).value == prev_id), None)
    next_row = next((r for r in range(2, ws_get.max_row + 1) if ws_get.cell(r,1).value == next_id), None)
    print(f"Missing ID {mid}: prev existing ID={prev_id} row={prev_row}, next existing ID={next_id} row={next_row}")
    if prev_row:
        print("  prev row:", [ws_get.cell(prev_row, c).value for c in range(1, ws_get.max_column + 1)])
    if next_row:
        print("  next row:", [ws_get.cell(next_row, c).value for c in range(1, ws_get.max_column + 1)])

# Verify whether getting sheet already has any blank rows or formulas in target area
blank_rows = []
for r in range(2, ws_get.max_row + 1):
    row_vals = [ws_get.cell(r, c).value for c in range(1, ws_get.max_column + 1)]
    if all(v is None for v in row_vals):
        blank_rows.append(r)
print("\nBlank rows currently in 'getting':", blank_rows)

# Perform transformation: rewrite data rows of "getting" to match main_ids order.
# Existing rows are preserved for present IDs; missing IDs get a new blank row with only column A filled.
header = [ws_get.cell(1, c).value for c in range(1, ws_get.max_column + 1)]
existing_rows_by_id = {}
for r in range(2, ws_get.max_row + 1):
    uid = ws_get.cell(r, 1).value
    if uid is not None and uid not in existing_rows_by_id:
        existing_rows_by_id[uid] = [ws_get.cell(r, c).value for c in range(1, ws_get.max_column + 1)]

print("\nHeader:", header)
print("Will write total data rows:", len(main_ids))

# Clear existing data area first
for r in range(2, ws_get.max_row + 1):
    for c in range(1, ws_get.max_column + 1):
        ws_get.cell(r, c).value = None

# Write rows in Main unique ID order
for i, uid in enumerate(main_ids, start=2):
    if uid in existing_rows_by_id:
        row_vals = existing_rows_by_id[uid]
    else:
        row_vals = [None] * ws_get.max_column
        row_vals[0] = uid
    for c, val in enumerate(row_vals, start=1):
        ws_get.cell(i, c).value = val

# Ensure leftover rows beyond new data are blank
for r in range(2 + len(main_ids), ws_get.max_row + 1):
    for c in range(1, ws_get.max_column + 1):
        ws_get.cell(r, c).value = None

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
orig_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if changed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    for old_name, expected_name in zip(wb2.sheetnames, orig_sheetnames):
        if old_name != expected_name:
            wb2[old_name].title = expected_name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify output
wbv = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wbv.sheetnames)
wsv = wbv["Result what i am getting"]

print("\nFinal rows in 'Result what i am getting':")
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    if r <= 12 or r >= max(1, wsv.max_row - 5):
        print(r, vals)

print("\nVerify target rows for missing IDs:")
for mid in missing:
    found = []
    for r in range(2, wsv.max_row + 1):
        if wsv.cell(r, 1).value == mid:
            found = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
            print(f"ID {mid} found at row {r}: {found}")
            break
    if not found:
        print(f"ID {mid} NOT FOUND")

output_file = out_path
