from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from collections import defaultdict
import os, json

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def cell_fill_info(cell):
    fill = cell.fill
    if fill is None:
        return None
    if fill.fill_type is None:
        return None
    # Prefer rgb if present
    fg = getattr(fill.fgColor, "rgb", None)
    if fg is None or fg == "00000000":
        fg = getattr(fill.start_color, "rgb", None)
    return {"type": fill.fill_type, "color": fg}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # headers from first 3 rows to detect layout
    for r in range(1, min(ws.max_row, 3) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # first 10 rows
    print("-- First rows --")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"{r}: {vals}")
    
    # last 5 rows
    print("-- Last rows --")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"{r}: {vals}")
    
    # formulas
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print("Formula cells:", formulas[:20], f"(total {len(formulas)})")
    
    # yellow-ish fills
    yellow_cells = []
    for row in ws.iter_rows():
        for cell in row:
            info = cell_fill_info(cell)
            if info and info["color"]:
                color = info["color"].upper()
                # common yellows: FFFF00, FFFFFF00, FFE699 etc. capture all non-default fills for now
                yellow_like = any(k in color for k in ["FFFF00", "FFFFFF00", "FFE699", "FFD966", "FFF2CC"])
                if yellow_like:
                    yellow_cells.append((cell.coordinate, cell.value, info))
    print("Yellow-like filled cells (up to 30):", yellow_cells[:30], f"(total {len(yellow_cells)})")

# Save workbook object/state for next iterations
orig_sheetnames = wb.sheetnames
