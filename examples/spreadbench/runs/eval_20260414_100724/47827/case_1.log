        return {
            "fill_type": fill.fill_type,
            "fg_rgb": fill.fgColor.rgb,
            "fg_type": fill.fgColor.type,
            "start_rgb": getattr(fill.start_color, "rgb", None),
            "start_type": getattr(fill.start_color, "type", None),
        }
    except Exception as e:
        return {"err": str(e)}

for ws in wb.worksheets:
    print("\n" + "="*60)
    print("Sheet:", ws.title, "size:", ws.max_row, "x", ws.max_column)
    nonempty = []
    for r in range(1, ws.max_row+1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        if any(v not in (None, "") for v in vals):
            nonempty.append(r)
    print("Nonempty rows:", nonempty[:20], "... last:", nonempty[-5:])
    for r in nonempty[:10]:
