from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]

ws = wb["3 straights to 3 boxed"]

# Determine true target rows: rows with actual data in columns A:E
target_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    if any(v not in (None, "") for v in vals):
        target_rows.append(r)

print("Target rows:", target_rows)

# Style for boxed values
fill = PatternFill(fill_type="solid", start_color="FFEBF1DE", end_color="FFEBF1DE")
bold_font = Font(
    name=ws["G2"].font.name,
    sz=ws["G2"].font.sz,
    b=True,
    i=ws["G2"].font.i,
    color=ws["G2"].font.color.type == "rgb" and ws["G2"].font.color.rgb or ws["G2"].font.color.rgb if ws["G2"].font.color else None
)
# Simpler: copy all existing font attributes where possible by using copy
from copy import copy

changed = []
for r in target_rows:
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    g = ws.cell(r, 7)
    digits = [int(b), int(c), int(d)]
    boxed = "".join(str(x) for x in sorted(digits))
    
    # Write/refresh value in column G as a 3-character string
    old_val = g.value
    g.value = boxed
    g.number_format = "000"
    
    # Apply formatting to all boxed values in column G
    g.fill = fill
    new_font = copy(g.font)
    new_font.bold = True
    g.font = new_font
    
    changed.append((r, old_val, g.value))

print("Changed/confirmed rows in column G:")
for item in changed:
    print(item)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
