from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from copy import copy
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
print("Original sheets:", original_sheetnames)

# Fill color #EBF1DE
boxed_fill = PatternFill(fill_type="solid", start_color="FFEBF1DE", end_color="FFEBF1DE")

# --- Sheet 1: complete column G ---
ws = wb["3 straights to 3 boxed"]

target_rows = []
for r in range(2, ws.max_row + 1):
    row_has_data = any(ws.cell(r, c).value not in (None, "") for c in range(1, 6))
    if row_has_data:
        target_rows.append(r)

print("Target rows on first sheet:", target_rows)

for r in target_rows:
    digits = [ws.cell(r, 2).value, ws.cell(r, 3).value, ws.cell(r, 4).value]
    if all(v is not None and v != "" for v in digits):
        sorted_digits = sorted(int(v) for v in digits)
        boxed_value = "".join(str(v) for v in sorted_digits)
        ws.cell(r, 7).value = boxed_value  # string preserves leading zeros

# --- Apply bold + fill to all 'boxed' value columns across sheets ---
styled_ranges = []
for sheet in wb.worksheets:
    # locate columns with header exactly 'boxed'
    boxed_cols = []
    for c in range(1, sheet.max_column + 1):
        if sheet.cell(1, c).value == "boxed":
            boxed_cols.append(c)
    print(f"Sheet {sheet.title} boxed header columns:", boxed_cols)

    for c in boxed_cols:
        styled_cells = []
        for r in range(2, sheet.max_row + 1):
            cell = sheet.cell(r, c)
            if cell.value not in (None, ""):
                new_font = copy(cell.font)
                new_font.bold = True
                cell.font = new_font
                cell.fill = copy(boxed_fill)
                styled_cells.append(cell.coordinate)
        styled_ranges.append((sheet.title, c, styled_cells[:5], len(styled_cells)))

print("Styled ranges summary:", styled_ranges)

# Save
wb.save(outfile)
print("Saved:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if changed
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for i, nm in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = nm
    wb_post.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification: values + formatting
wb_verify = load_workbook(outfile, data_only=False)
print("Final sheet names:", wb_verify.sheetnames)

wsv = wb_verify["3 straights to 3 boxed"]
print("\nVerify G2:G16 on first sheet:")
for r in target_rows:
    cell = wsv.cell(r, 7)
    fill_rgb = cell.fill.fgColor.rgb if cell.fill.fgColor.type == "rgb" else f"type:{cell.fill.fgColor.type}"
    print(cell.coordinate, cell.value, "bold=", cell.font.bold, "fill=", fill_rgb)

if "boxed" in wb_verify.sheetnames:
    wsb = wb_verify["boxed"]
    print("\nVerify E2:E10 on second sheet:")
    for r in range(2, min(10, wsb.max_row) + 1):
        cell = wsb.cell(r, 5)
        fill_rgb = cell.fill.fgColor.rgb if cell.fill.fgColor.type == "rgb" else f"type:{cell.fill.fgColor.type}"
        print(cell.coordinate, cell.value, "bold=", cell.font.bold, "fill=", fill_rgb)

output_spreadsheet = outfile
print("\nPrepared output:", output_spreadsheet)
