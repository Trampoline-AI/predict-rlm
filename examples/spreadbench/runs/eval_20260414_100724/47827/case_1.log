if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    # Rename in positional order if counts match
    if len(wb_check.sheetnames) == len(original_sheetnames):
        for i, old_name in enumerate(original_sheetnames):
