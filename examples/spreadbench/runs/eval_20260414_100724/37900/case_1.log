Code:
```repl
import os
from openpyxl import load_workbook

# Reload fresh workbook from input
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Verify target cells before writing
print("Before writing:")
for coord in ["D4", "E4", "D5", "E5"]:
    c = ws[coord]
    print(coord, "->", c.value, "| format:", c.number_format)

# Write formulas to exact target cells
ws["E4"] = "=TODAY()"
ws["E4"].number_format = "mm-dd-yy"

ws["E5"] = '=IFERROR(VLOOKUP(E4,$A$5:$B$16,2,TRUE),"")'
ws["E5"].number_format = ws["B5"].number_format

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload to verify sheet names after recalc
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)

# Rename back if LibreOffice changed names
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for old_name, desired_name in zip(wb_after.sheetnames[:], original_sheetnames):
        wb_after[old_name].title = desired_name
    wb_after.save(output_path)
    print("Renamed sheets back to original:", original_sheetnames)

# Reload formula view and data_only view for verification
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]

wb_data = load_workbook(output_path, data_only=True)
ws_data = wb_data[original_sheetnames[0]]

print("\nFormula verification:")
print("E4 formula:", ws_formula["E4"].value)
print("E5 formula:", ws_formula["E5"].value)

print("\nData-only verification:")
for coord in ["E4", "E5"]:
    c = ws_data[coord]
    print(coord, "->", c.value, "| format:", c.number_format)

# Extra sanity check against lookup table
print("\nReference rows A5:B16:")
for r in range(5, 17):
    print(r, ws_data[f"A{r}"].value, ws_data[f"B{r}"].value)

final_output_spreadsheet = output_path
```
