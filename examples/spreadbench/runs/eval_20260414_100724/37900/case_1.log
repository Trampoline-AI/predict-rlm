```repl
import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

workbook_summary = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    
    # Find first 10 non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    print("First non-empty rows:", nonempty_rows[:10])
    print("Last non-empty rows:", nonempty_rows[-10:])
    
    print("\nFirst up to 10 non-empty rows:")
    for r in nonempty_rows[:10]:
        print(f"Row {r}:", row_values(ws, r, ws.max_column))
    
    print("\nLast up to 5 non-empty rows:")
    for r in nonempty_rows[-5:]:
        print(f"Row {r}:", row_values(ws, r, ws.max_column))
    
    # Scan for formulas
    formula_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print(f"\nFormula cell count: {len(formula_cells)}")
    print("First 20 formula cells:", formula_cells[:20])
    
    workbook_summary[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "headers": headers,
        "nonempty_rows": nonempty_rows,
        "formula_cells": formula_cells,
    }

print("\nInspection complete.")
```
