            "J": wsd.cell(r,10).value,
            "K": wsd.cell(r,11).value,
            "A": wsd.cell(r, 1).value,
        }
    )

# Compute expected sequential ranks from recalculated cached data and compare
records = []
for r in range(6, last_row + 1):
    records.append({
        "row": r,
        "B": wsd.cell(r, 2).value,
        "I": wsd.cell(r, 9).value,
        "J": wsd.cell(r,10).value,
        "K": wsd.cell(r,11).value,
        "A": wsd.cell(r, 1).value,
    })

detail_rows = [
    rec for rec in records
    if rec["I"] not in (None, "") and rec["J"] not in (None, "") and isinstance(rec["B"], (int, float))
]

by_class = defaultdict(list)
for rec in detail_rows:
    by_class[rec["I"]].append(rec)

expected_by_row = {}
for cls, rows in by_class.items():
    rows_sorted = sorted(rows, key=lambda x: (-x["B"], x["row"]))
    for rank, rec in enumerate(rows_sorted, start=1):
        expected_by_row[rec["row"]] = rank

mismatches = []
blanks = []
for rec in detail_rows:
    actual = rec["K"]
    expected = expected_by_row[rec["row"]]
    if actual in (None, ""):
