        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            return r
    return 0

last_row = last_nonempty_row(ws)

print("Original sheet names:", original_sheetnames)
print("Target sheet:", ws.title)
print("Header row 5, cols A:P:", [ws.cell(5, c).value for c in range(1, 17)])
print("Target column K header:", ws["K5"].value)
print("Used last row:", last_row)

# Inspect current K formulas before modification
sample_rows = [6, 110, 127, 176, 177, 198, 201, 202, 346, 451, 452, 503, 504, 607]
print("\nCurrent K cell contents before change:")
for r in sample_rows:
    cell = ws.cell(r, 11)
    v = cell.value
    if isinstance(v, ArrayFormula):
        desc = {"type": "ArrayFormula", "text": v.text, "ref": v.ref}
    else:
        desc = {"type": type(v).__name__, "value": v}
    print(f"K{r}:", desc)

# Replace K6:Klast_row with sequential rank formulas.
# Logic:
# rank = count of rows in same Item Class with greater Net Sales
#      + count of same Item Class + same Net Sales rows from row 6 through current row
# This breaks ties by sheet order and creates sequential ranks.
for r in range(6, last_row + 1):
    formula = (
        f'=IF(J{r}="","",'
        f'SUMPRODUCT(($I$6:$I${last_row}=I{r})*($B$6:$B${last_row}>B{r}))'
        f'+COUNTIFS($I$6:I{r},I{r},$B$6:B{r},B{r}))'
    )
    ws.cell(r, 11).value = formula

print("\nNew K formulas written for sample rows:")
for r in sample_rows:
    print(f"K{r}:", ws.cell(r, 11).value)

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculate changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    if len(wb_after.sheetnames) == len(original_sheetnames):
        for i, original_name in enumerate(original_sheetnames):
            wb_after[wb_after.sheetnames[i]].title = original_name
        wb_after.save(output_path)
        print("Restored sheet names to:", original_sheetnames)
    else:
        print("Could not safely restore sheet names due to different sheet count.")
else:
    print("Sheet names unchanged after recalc.")

# Verification using cached values
wbd = load_workbook(output_path, data_only=True)
wsd = wbd["RS.Food"]

print("\nVerification target area (rows with known tie cases):")
verify_rows = [110,111,112,127,129,130,176,177,178,179,180,190,191,192,193,194,197,198,199,200,201,202,346,451,452,503,504]
for r in verify_rows:
