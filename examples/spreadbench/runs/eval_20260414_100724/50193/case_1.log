dup_groups = [((cls, sales), rows) for (cls, sales), rows in dup_groups.items() if len(rows) > 1]
dup_groups.sort(key=lambda kv: (-len(kv[1]), str(kv[0][0]), kv[0][1]))

print("\nDuplicate-group verification (first 12 groups):")
