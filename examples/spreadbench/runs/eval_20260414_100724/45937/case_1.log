import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and capture original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)

# Reconfirm target area before writing
for r in range(7, 10):
    print(f"Before: B{r}={ws[f'B{r}'].value}, C{r}={ws[f'C{r}'].value}, D{r}={ws[f'D{r}'].value}, E{r}={ws[f'E{r}'].value}")

# Identify relevant data rows in the main table under row 6 headers
target_rows = []
for r in range(7, ws.max_row + 1):
    if ws[f"B{r}"].value is not None or ws[f"C{r}"].value is not None or ws[f"D{r}"].value is not None:
        # only rows in the left/main table, not legend rows
        if r < 17:
            target_rows.append(r)

print("Target rows for column E:", target_rows)

# Write formulas to column E for all relevant data rows
for r in target_rows:
    formula = f'=IF(OR(C{r}="",D{r}=""),"",INDEX($J$20:$N$22,MATCH(C{r},$H$20:$H$22,1),MATCH(D{r},$J$18:$N$18,0)))'
    ws[f"E{r}"] = formula
    print(f"Wrote E{r} -> {formula}")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# After recalculation, sheet names may have changed; restore if needed
wb_post = load_workbook(output_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != original_sheet_names:
    # rename by position back to original names
    for idx, original_name in enumerate(original_sheet_names):
        wb_post.worksheets[idx].title = original_name
    wb_post.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas and evaluated results
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("\nVerification of target cells E7:E9")
