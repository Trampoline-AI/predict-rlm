import os, json, textwrap

print("INPUT FILE:", input_spreadsheet)
print("\nFULL INSTRUCTION:\n")
print(instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("\nSHEETS:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_c = ws.max_column if max_cols is None else min(ws.max_column, max_cols)
    return [ws.cell(r, c).value for c in range(1, max_c + 1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    
    # show headers (first 3 rows, since header may not always be row 1)
    for r in range(1, min(ws.max_row, 3) + 1):
        vals = row_values(ws, r, max_cols=ws.max_column)
        print(f"Row {r}: {vals}")
    
    # first 5 data-ish rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"  {r}: {row_values(ws, r, max_cols=min(ws.max_column, 15))}")
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(f"  {r}: {row_values(ws, r, max_cols=min(ws.max_column, 15))}")

    headers = row_values(ws, 1)
    header_map = {get_column_letter(i): headers[i-1] for i in range(1, ws.max_column+1)}
    print("Header map:", header_map)

print("\nInspection complete.")
