from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Reload clean workbook from input
wb = load_workbook(input_spreadsheet)
ws = wb["Delete"]

print("Target sheet:", ws.title)
print("Max row before:", ws.max_row, "Max col before:", ws.max_column)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Inspect exact target column values and classify rows
delete_types = {"STATIONERY", "VEGETABLES"}
rows_to_delete = []
rows_to_keep = []

for r in range(2, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    cell_b = ws.cell(r, 2).value
    if cell_b in delete_types:
        rows_to_delete.append((r, row_vals))
    else:
        rows_to_keep.append((r, row_vals))

print("Rows matching deletion condition:")
for r, vals in rows_to_delete:
    print(f"  row {r}: {vals}")

print("Rows to keep:")
for r, vals in rows_to_keep:
    print(f"  row {r}: {vals}")

# Perform deletion bottom-up so row indices remain valid
for r, _ in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

print("Max row after in-memory deletion:", ws.max_row)
print("Final in-memory rows:")
for r in range(1, ws.max_row + 1):
    print(f"  row {r}: {[ws.cell(r, c).value for c in range(1, ws.max_column + 1)]}")

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
orig_sheet_names = ["Delete"]
if wb_check.sheetnames != orig_sheet_names and len(wb_check.sheetnames) == len(orig_sheet_names):
    for ws_obj, orig_name in zip(wb_check.worksheets, orig_sheet_names):
        ws_obj.title = orig_name
    wb_check.save(out_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Delete"]

print("Verified final sheet dimensions:", wsv.max_row, wsv.max_column)
print("Verified final rows:")
for r in range(1, wsv.max_row + 1):
    print(f"  row {r}: {[wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]}")

# Sanity checks
remaining_types = [wsv.cell(r, 2).value for r in range(2, wsv.max_row + 1)]
print("Remaining TYPE values:", remaining_types)
print("Any forbidden types left?:", any(v in delete_types for v in remaining_types))

output_spreadsheet = out_path
