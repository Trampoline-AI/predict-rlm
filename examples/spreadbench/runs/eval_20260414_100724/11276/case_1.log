from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
import os, re, shutil

input_path = input_spreadsheet
orig_wb = load_workbook(input_path)
orig_ws = orig_wb[orig_wb.sheetnames[0]]

start_c = column_index_from_string("F")
end_c = column_index_from_string("AJ")

# 1) Inspect formulas in the ORIGINAL workbook that reference row 3
refs = []
for row in orig_ws.iter_rows():
    for cell in row:
        v = cell.value
        if isinstance(v, str) and v.startswith("=") and re.search(r'(?<!\d)\$?[A-Z]{1,3}\$?3(?!\d)', v):
            refs.append((cell.coordinate, v))

print("Original sheet names:", orig_wb.sheetnames)
print("Original formulas referencing row 3:", len(refs))
for item in refs[:100]:
    print(item)

# Narrow to formulas referencing the target day-code cells and checking against "F"
f_refs = []
for coord, formula in refs:
    if '"F"' in formula or "'F'" in formula or '=IF(' in formula.upper():
        f_refs.append((coord, formula))
print("\nPotential dependent formulas that may need adjustment:", len(f_refs))
for item in f_refs[:100]:
    print(item)

# 2) Rebuild from ORIGINAL workbook
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Write corrected formulas in F3:AJ3
for c in range(start_c, end_c + 1):
    col = get_column_letter(c)
    ws.cell(3, c).value = f'=TEXT({col}4,"ddd")'

# 3) Update dependent formulas that reference row 3 and compare to "F"
#    Only replace the exact quoted token "F" in formulas that also reference row 3.
updated_formulas = []
for row in ws.iter_rows():
    for cell in row:
        v = cell.value
        if isinstance(v, str) and v.startswith("=") and re.search(r'(?<!\d)\$?[A-Z]{1,3}\$?3(?!\d)', v):
            new_v = v.replace('"F"', '"Fri"')
            if new_v != v:
                cell.value = new_v
                updated_formulas.append((cell.coordinate, v, new_v))

print("\nUpdated dependent formulas:", len(updated_formulas))
for item in updated_formulas[:100]:
    print(item)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
wb.save(out_path)
print("\nSaved rebuilt workbook to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
orig_sheetnames = load_workbook(input_path).sheetnames[:]
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    for i, name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)
    print("Restored original sheet names:", orig_sheetnames)

# Verify target cells
wbf = load_workbook(out_path)
wbd = load_workbook(out_path, data_only=True)
wsf = wbf[orig_sheetnames[0]]
wsd = wbd[orig_sheetnames[0]]

print("\nVerify F3:AJ3 formula/value pairs:")
