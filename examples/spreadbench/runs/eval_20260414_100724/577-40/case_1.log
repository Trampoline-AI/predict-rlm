```repl
import os
from copy import copy
from openpyxl import load_workbook

# Reload fresh workbook from input for clean modification
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet2"]

placeholder_values = {"", "-", "0", "$", "$0", "$0.0"}

def normalize(v):
    if v is None:
        return ""
    if isinstance(v, str):
        return v.strip()
    # Treat numeric zero / zero-point-zero as placeholder 0
    if isinstance(v, (int, float)) and v == 0:
        return "0"
    return str(v).strip()

# Recompute candidate rows carefully
candidates = []
for r in range(2, ws.max_row + 1):
    j_raw = ws.cell(r, 10).value
    k_raw = ws.cell(r, 11).value
    j = normalize(j_raw)
    k = normalize(k_raw)
    if j in placeholder_values and k in placeholder_values:
        candidates.append(r)

print("Candidate rows to delete:", candidates)
print("Total candidate rows:", len(candidates))

# Print candidate rows with full row values for verification
for r in candidates:
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"Delete row {r}: J={ws.cell(r,10).value!r}, K={ws.cell(r,11).value!r}, full={row_vals}")

# Also print examples of rows that should be retained because only one of J/K is placeholder/blank
retain_examples = []
for r in range(2, ws.max_row + 1):
    j = normalize(ws.cell(r,10).value)
    k = normalize(ws.cell(r,11).value)
    j_bad = j in placeholder_values
    k_bad = k in placeholder_values
    if j_bad ^ k_bad:
        retain_examples.append((r, ws.cell(r,10).value, ws.cell(r,11).value))
print("Sample rows to retain (only one side blank/placeholder):", retain_examples[:10])

original_sheet_names = wb.sheetnames[:]
original_max_row = ws.max_row

# Delete from bottom to top
for r in sorted(candidates, reverse=True):
    ws.delete_rows(r, 1)

print("Original row count:", original_max_row)
print("New row count after deletion:", ws.max_row)

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate even though no formulas, per instructions
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculate changed them
wb_after = load_workbook(output_path)
current_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", current_names)

renamed = False
if current_names != original_sheet_names and len(current_names) == len(original_sheet_names):
    for i, expected in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(output_path)
    renamed = True

print("Renamed sheets back?" , renamed)

# Verification with data_only=True
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb[original_sheet_names[0]]
print("Verified sheet names:", verify_wb.sheetnames)
print("Verified row count:", verify_ws.max_row)

# Check remaining J/K rows for accidental survivors among deletable cases
remaining_bad = []
for r in range(2, verify_ws.max_row + 1):
    j = normalize(verify_ws.cell(r,10).value)
    k = normalize(verify_ws.cell(r,11).value)
    if j in placeholder_values and k in placeholder_values:
        remaining_bad.append((r, verify_ws.cell(r,10).value, verify_ws.cell(r,11).value))
print("Remaining rows still matching delete condition:", remaining_bad)

# Print first 10 and last 5 rows after deletion
def row_values(ws, r):
    return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]

print("First 10 rows after deletion:")
for r in range(1, min(10, verify_ws.max_row) + 1):
    print(f"Row {r}: {row_values(verify_ws, r)}")

print("Last 5 rows after deletion:")
for r in range(max(1, verify_ws.max_row - 4), verify_ws.max_row + 1):
    print(f"Row {r}: {row_values(verify_ws, r)}")

# store for submit
final_output_spreadsheet = output_path
