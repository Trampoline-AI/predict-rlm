from collections import defaultdict
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Fresh load
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["OUT CAS"]

print("Original sheets:", original_sheetnames)
print("OUT CAS headers:", [ws.cell(1, c).value for c in range(1, 16)])

# Target blocks verified from inspection
blocks = {
    "PUR PURCHASE": (1, 2, 3),   # A:C
    "PUR PAID": (5, 6, 7),       # E:G
    "CASH SS": (9, 10, 11),      # I:K
    "EXPRR": (13, 14, 15),       # M:O
}

def categorize(ref):
    s = str(ref).strip()
    if s.startswith("PUR PURCHASE"):
        return "PUR PURCHASE"
    if s.startswith("PUR PAID"):
        return "PUR PAID"
    if s.startswith("CASH SS"):
        return "CASH SS"
    if s.startswith("EXPRR"):
        return "EXPRR"
    return None

def sort_key(ref):
    s = str(ref).strip()
    m = re.search(r'(EX\d+|\d+)\s*$', s, re.I)
    if m:
        tok = m.group(1)
        if tok.upper().startswith("EX"):
            return (0, int(tok[2:]), s)
        return (0, int(tok), s)
    return (1, s)

# Aggregate source data from all sheets except OUT CAS
