    for r in range(2, src.max_row + 1):
        ref = src.cell(r, 2).value
        if ref in (None, ""):
            continue
        debit = src.cell(r, 3).value
        credit = src.cell(r, 4).value
        amount = debit if debit not in (None, "") else credit
        cat = categorize(ref)
        rec = {
            "sheet": sname,
            "row": r,
            "ref": ref,
            "amount": amount,
        }
        if cat is None:
            uncategorized.append(rec)
        else:
            bucket_rows[cat].append(rec)

