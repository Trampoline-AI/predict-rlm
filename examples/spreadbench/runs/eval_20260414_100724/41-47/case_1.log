        cat = categorize(ref)
        amt = debit if debit not in (None, "") else credit
        rec = {"sheet": sname, "row": r, "date": date, "ref": ref, "debit": debit, "credit": credit, "amount": amt}
        if cat is None:
            uncat.append(rec)
