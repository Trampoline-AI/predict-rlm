    if m:
        token = m.group(1)
        if token.upper().startswith("EX"):
            try:
                return (0, int(token[2:]), s)
            except:
                return (0, token, s)
        try:
            return (0, int(token), s)
        except:
            return (0, token, s)
    return (1, s)

