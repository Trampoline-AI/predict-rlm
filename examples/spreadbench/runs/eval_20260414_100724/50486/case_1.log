import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def cell_display(v):
    if v is None:
        return None
    return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find actual non-empty bounds a bit more carefully
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for c in row:
            if c.value is not None:
                row_has = True
                nonempty_cols.add(c.column)
        if row_has:
            nonempty_rows.append(row[0].row)
    if nonempty_rows:
        first_row = min(nonempty_rows)
        last_row = max(nonempty_rows)
    else:
        first_row = last_row = None
    print("Non-empty row range:", first_row, "to", last_row)
    
    # Header candidates: first 3 rows
    for r in range(1, min(ws.max_row, 3) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # Print header mapping based on row 1
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Column headers/indexes:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)} ({c}): {h}")
    
    # First 10 rows
    print("\nFirst 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"  Row {r}: {vals}")
    
    # Last 5 rows
    print("\nLast 5 rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"  Row {r}: {vals}")
    
    # Inspect column A values and formulas, plus nearby columns A:E if present
    print("\nColumn A inspection (first 15 data rows):")
    for r in range(1, min(ws.max_row, 15) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 5) + 1)]
        print(f"  Row {r} A:{ws.cell(r,1).value!r} | A:E -> {row_vals}")
    
    # Detect numeric-heavy columns to infer the relevant pair
    numeric_counts = {}
    for c in range(1, ws.max_column + 1):
        count = 0
        examples = []
        for r in range(2, ws.max_row + 1):
            v = ws.cell(r, c).value
            if isinstance(v, (int, float)) and not isinstance(v, bool):
                count += 1
                if len(examples) < 5:
                    examples.append(v)
        numeric_counts[c] = (count, examples)
    print("\nNumeric counts by column:")
    for c in range(1, ws.max_column + 1):
        count, examples = numeric_counts[c]
        print(f"  {get_column_letter(c)} ({headers[c-1]}): numeric_count={count}, examples={examples}")
    
    # Look for any columns with header mentioning Chep/Loscam
    print("\nHeaders containing 'chep' or 'loscam':")
    found = False
    for c in range(1, ws.max_column + 1):
        h = ws.cell(1, c).value
        if isinstance(h, str) and ("chep" in h.lower() or "loscam" in h.lower()):
            print(f"  {get_column_letter(c)} ({c}): {h}")
            found = True
    if not found:
        print("  None found in row 1 headers.")
