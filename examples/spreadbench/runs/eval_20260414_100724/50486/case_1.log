```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing, current target area A1:D10:")
for r in range(1, 11):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])

# Identify actual data rows: rows where CHEP or LOSCAM columns contain data
target_rows = []
for r in range(2, ws.max_row + 1):
    c_val = ws.cell(r, 3).value  # C = CHEP
    d_val = ws.cell(r, 4).value  # D = LOSCAM
    if c_val is not None or d_val is not None:
        target_rows.append(r)

print("Target rows based on data in columns C/D:", target_rows)

# Write formula to column A for all relevant rows
for r in target_rows:
    formula = f'=IF(ISNUMBER(C{r}),"Chep",IF(ISNUMBER(D{r}),"Loscam",""))'
    print(f"Writing A{r}: {formula} (was {ws.cell(r,1).value!r})")
    ws.cell(r, 1).value = formula

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and fix sheet names if changed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    for i, old_name in enumerate(original_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("Verified target cells in column A:")
verified = {}
for r in target_rows:
    verified[f"A{r}"] = wsv.cell(r, 1).value
    print(f"A{r} =", wsv.cell(r, 1).value)

print("Verified A1:D10 after recalc:")
for r in range(1, 11):
    print(r, [wsv.cell(r, c).value for c in range(1, 5)])

output_spreadsheet = output_path
