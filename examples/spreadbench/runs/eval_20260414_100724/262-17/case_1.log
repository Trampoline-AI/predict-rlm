import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws1 = wb[original_sheet_names[0]]
ws2 = wb[original_sheet_names[1]]

# Dynamically find header row and target columns on the first worksheet
def normalize(v):
    return str(v).strip().lower() if v is not None else ""

header_row = None
task_col = None
resp_col = None

for r in range(1, min(ws1.max_row, 20) + 1):
    row_vals = [ws1.cell(r, c).value for c in range(1, ws1.max_column + 1)]
    norm_map = {normalize(v): c for c, v in enumerate(row_vals, start=1) if v not in (None, "")}
    if "task" in norm_map and "responsibility" in norm_map:
        header_row = r
        task_col = norm_map["task"]
        resp_col = norm_map["responsibility"]
        break

print("Detected header_row:", header_row)
print("Detected Task column:", task_col, get_column_letter(task_col))
print("Detected Responsibility column:", resp_col, get_column_letter(resp_col))

# Determine actual used data rows on Sheet1
data_rows = []
used_row_indices = []
for r in range(header_row + 1, ws1.max_row + 1):
    vals = [ws1.cell(r, c).value for c in range(1, ws1.max_column + 1)]
    if any(v not in (None, "") for v in vals):
        data_rows.append(vals)
        used_row_indices.append(r)

print("Used data rows in Sheet1:", used_row_indices)
print("Original first few data rows:")
for row in data_rows[:5]:
    print(row)
print("Original last few data rows:")
for row in data_rows[-5:]:
    print(row)

# Sort by Task ascending, then Responsibility ascending
sorted_rows = sorted(
    data_rows,
    key=lambda row: (
        "" if row[task_col - 1] is None else str(row[task_col - 1]).strip(),
        "" if row[resp_col - 1] is None else str(row[resp_col - 1]).strip(),
    )
)

print("Sorted preview:")
for row in sorted_rows:
    print(row)

# Write sorted data back to Sheet1 only
start_write_row = header_row + 1
for i, row_vals in enumerate(sorted_rows, start=start_write_row):
    for c, val in enumerate(row_vals, start=1):
        ws1.cell(i, c).value = val

# If there were any leftover populated rows below the sorted block, clear them
last_data_row = start_write_row + len(sorted_rows) - 1
for r in range(last_data_row + 1, ws1.max_row + 1):
    vals = [ws1.cell(r, c).value for c in range(1, ws1.max_column + 1)]
    if any(v not in (None, "") for v in vals):
        for c in range(1, ws1.max_column + 1):
            ws1.cell(r, c).value = None

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_post = load_workbook(output_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != original_sheet_names and len(post_names) == len(original_sheet_names):
    for idx, old_name in enumerate(original_sheet_names):
        wb_post[wb_post.sheetnames[idx]].title = old_name
    wb_post.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verification with formulas/data_only view
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

vws1 = wb_verify[original_sheet_names[0]]
vws2 = wb_verify[original_sheet_names[1]]

def nonempty_rows(ws):
    out = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            out.append((r, vals))
    return out

sheet1_verified = nonempty_rows(vws1)
sheet2_verified = nonempty_rows(vws2)

print("\nVerified Sheet1 non-empty rows:")
for r, vals in sheet1_verified:
    print(r, vals)

print("\nVerified Sheet2 non-empty rows:")
for r, vals in sheet2_verified:
    print(r, vals)

sheet1_main = [vals for r, vals in sheet1_verified if r >= header_row + 1]
sheet2_main = []
for r, vals in sheet2_verified:
    if r >= 2 and any(v not in (None, "") for v in vals):
        if not ((len(vals) >= 3 and vals[2] == "First Sort") or (len(vals) >= 6 and vals[5] == "Second Sort")):
            sheet2_main.append(vals)

print("\nCounts -> Sheet1 sorted rows:", len(sheet1_main), "Sheet2 expected rows:", len(sheet2_main))
print("Sheet1 matches Sheet2 expected sorted rows:", sheet1_main == sheet2_main)

# Explicit target range verification
print("\nTarget header cells:")
print("Task header:", vws1.cell(header_row, task_col).value, f"at {get_column_letter(task_col)}{header_row}")
print("Responsibility header:", vws1.cell(header_row, resp_col).value, f"at {get_column_letter(resp_col)}{header_row}")

print("\nFirst 5 sorted rows in target output region:")
for r in range(header_row + 1, min(header_row + 5, vws1.max_row) + 1):
    print(r, [vws1.cell(r, c).value for c in range(1, vws1.max_column + 1)])

print("\nLast 5 sorted rows in target output region:")
start_last = max(header_row + 1, last_data_row - 4)
for r in range(start_last, last_data_row + 1):
    print(r, [vws1.cell(r, c).value for c in range(1, vws1.max_column + 1)])

# Keep output path for submission
final_output_spreadsheet = output_path
