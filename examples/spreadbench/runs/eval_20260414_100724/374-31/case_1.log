import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Copy input file first, then modify the copy
shutil.copy2(infile, outfile)

wb2 = load_workbook(outfile)
original_sheet_names = wb2.sheetnames[:]

def row_vals(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

def is_fully_blank_row(ws, r):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None and str(v) != "":
            return False
    return True

deletions_summary = {}

for ws in wb2.worksheets:
    code_rows = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        if isinstance(v, str) and v.strip() == "Code":
            code_rows.append(r)

    # Determine exact blank rows immediately above each Code row
    rows_to_delete = set()
    contexts = []
    for cr in code_rows:
        blank_block = []
        r = cr - 1
        while r >= 1 and is_fully_blank_row(ws, r):
            blank_block.append(r)
            r -= 1
        contexts.append((cr, list(reversed(blank_block))))
        rows_to_delete.update(blank_block)

    print(f"Sheet {ws.title}: code_rows={code_rows}")
    print(f"Sheet {ws.title}: blank rows immediately above each Code row={contexts}")

    # Delete bottom-up so row indices remain valid
    for r in sorted(rows_to_delete, reverse=True):
        ws.delete_rows(r, 1)

    deletions_summary[ws.title] = sorted(rows_to_delete)

wb2.save(outfile)
print("Saved output to:", outfile)
print("Deletion summary:", deletions_summary)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate altered them
wb_check = load_workbook(outfile)
current_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != original_sheet_names and len(current_names) == len(original_sheet_names):
    for ws, desired in zip(wb_check.worksheets, original_sheet_names):
        ws.title = desired
    wb_check.save(outfile)
