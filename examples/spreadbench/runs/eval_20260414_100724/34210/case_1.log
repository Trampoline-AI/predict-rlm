import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Target sheet:", ws.title)
print("max_row:", ws.max_row, "max_column before write:", ws.max_column)

# Confirm target column C is blank before writing
preexisting_c = [(r, ws.cell(r, 3).value) for r in range(1, ws.max_row + 1) if ws.cell(r, 3).value not in (None, "")]
print("Preexisting nonblank C cells:", preexisting_c)

# Write formulas into column C for all populated rows
if ws.max_row >= 1:
    ws["C1"] = "=A1"
for r in range(2, ws.max_row + 1):
    # Only write for rows that are part of the used data area; here every row 1:max_row has column B data
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 3)):
        ws.cell(r, 3).value = f'=IF(A{r}<>"",A{r},C{r-1})'

# Save workbook
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
current_sheet_names = wb_check.sheetnames[:]
print("Sheet names after recalc reload:", current_sheet_names)

if current_sheet_names != orig_sheet_names:
    # Rename by position back to originals
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas exist in target cells
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("Formula check:")
for cell_ref in ["C1", "C2", "C10", "C11", "C20", "C32", "C44", "C55"]:
    print(cell_ref, "->", ws_formula[cell_ref].value)

# Verify calculated values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerified calculated ranges:")
for start, end in [(1, 10), (11, 19), (20, 31), (32, 43), (44, 55)]:
    vals = [ws_values.cell(r, 3).value for r in range(start, end + 1)]
    print(f"C{start}:C{end} ->", vals)

# Extra sanity checks
problems = []
for r in range(1, ws_values.max_row + 1):
    b = ws_values.cell(r, 2).value
    c = ws_values.cell(r, 3).value
    if b not in (None, "") and c in (None, ""):
        problems.append((r, b, c))

print("Rows with column B populated but C blank:", problems[:20], "count=", len(problems))

output_spreadsheet = output_path
