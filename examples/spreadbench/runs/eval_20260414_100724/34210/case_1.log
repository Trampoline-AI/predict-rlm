import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", headers)
    
    # Determine non-empty row count approximately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "First/last non-empty rows:",
          (nonempty_rows[0] if nonempty_rows else None, nonempty_rows[-1] if nonempty_rows else None))
    
    # Print first 10 rows
    print("\nFirst up to 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Print last 5 rows
    print("\nLast up to 5 rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Focus on columns A and C
    print("\nColumn A and C sample values:")
    for r in range(1, min(ws.max_row, 15) + 1):
        print(f"Row {r}: A={ws.cell(r,1).value!r}, C={ws.cell(r,3).value!r}")
    if ws.max_row > 15:
        print("...")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(f"Row {r}: A={ws.cell(r,1).value!r}, C={ws.cell(r,3).value!r}")

for ws in wb.worksheets:
    sheet_summary(ws)
