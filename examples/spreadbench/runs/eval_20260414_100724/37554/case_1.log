import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheet names:", original_sheet_names)

def sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", ws.dimensions, "max_row:", max_row, "max_col:", max_col)
    print("Headers row 1:", headers)
    
    # first 10 rows
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, vals)
    
    # last 5 rows
    start_last = max(1, max_row - 4)
    print(f"Last rows {start_last}-{max_row}:")
    for r in range(start_last, max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Inspect the specifically referenced cell/range and nearby area
