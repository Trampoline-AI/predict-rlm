import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook and confirm target
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before write:")
print("G4 existing value:", repr(ws["G4"].value))
print("Inputs:", {c: ws[c].value for c in ["B4", "C4", "D4", "E4", "F4"]})

# Write nested IF formula to the exact target cell
formula = '=IF(F4<=B4,F4/B4,IF(F4<C4,MIN(F4/B4,1.09),IF(F4=C4,MIN(F4/B4,1.1),IF(F4<D4,MIN(F4/B4,1.19),MIN(F4/B4,1.2)))))'
ws["G4"] = formula

print("Written formula to G4:", ws["G4"].value)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheetnames:
    # Rename sheets back by position
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify formula and computed result
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Final formula in G4:", ws_formula["G4"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("Verified computed G4 value:", ws_values["G4"].value)
print("Target row values B4:G4:", [ws_values[c].value for c in ["B4","C4","D4","E4","F4","G4"]])

output_spreadsheet = output_path
