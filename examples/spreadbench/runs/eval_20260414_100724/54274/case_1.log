import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Rebuild final output from the original input so the live formula is preserved.
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Sheet names:", wb.sheetnames)
print("Headers row 3:", [ws.cell(3, c).value for c in range(1, ws.max_column + 1)])

# Identify all relevant data rows under the header row.
target_rows = []
for r in range(4, ws.max_row + 1):
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    d = ws[f"D{r}"].value
    f = ws[f"F{r}"].value
    if any(v is not None for v in [b, c, d, f]):
        target_rows.append(r)

print("Relevant rows for Points formula:", target_rows)
for r in target_rows:
    print(f"Before: G{r}={repr(ws[f'G{r}'].value)} | inputs B{r}:F{r}=",
          [ws[f"{col}{r}"].value for col in ["B","C","D","E","F"]])

# Write the requested nested IF formula into the existing Points column.
for r in target_rows:
    formula = (
        f'=IF(F{r}<=B{r},F{r}/B{r},'
        f'IF(F{r}<C{r},MIN(F{r}/B{r},1.09),'
        f'IF(F{r}=C{r},MIN(F{r}/B{r},1.1),'
        f'IF(F{r}<D{r},MIN(F{r}/B{r},1.19),MIN(F{r}/B{r},1.2)))))'
    )
    ws[f"G{r}"] = formula

wb.save(output_path)
print("Saved final workbook with live formula to:", output_path)

# Verify the formula is present in the final file.
wb_verify = load_workbook(output_path, data_only=False)
ws_verify = wb_verify[original_sheetnames[0]]

for r in target_rows:
    print(f"After: G{r} formula/value =", repr(ws_verify[f'G{r}'].value))

output_spreadsheet = output_path
```
