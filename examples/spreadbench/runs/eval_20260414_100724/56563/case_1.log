import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
print("Original sheet names:", wb.sheetnames)

def display(v):
    try:
        if isinstance(v, str):
            return v
        return repr(v)
    except Exception:
        return f"<unrepr {type(v)}>"

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # headers from first few rows to avoid assuming row 1 only
    for header_row in range(1, min(4, ws.max_row) + 1):
        vals = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {header_row} values:", vals)
    
    # first 10 rows
    top_n = min(10, ws.max_row)
    print("\nTop rows:")
    for r in range(1, top_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # last 5 rows if applicable
    if ws.max_row > 10:
        print("\nBottom rows:")
        start = max(1, ws.max_row - 4)
        for r in range(start, ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}: {vals}")
    
    # print all formulas and error-like values
    print("\nFormula cells / error-like cells:")
    found_any = False
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                print(f"{cell.coordinate}: FORMULA {v}")
                found_any = True
            elif isinstance(v, str) and v.startswith("#"):
                print(f"{cell.coordinate}: ERROR/TEXT {v}")
                found_any = True
    if not found_any:
        print("(none found)")
    
    # Specifically inspect column C and likely sum area
    if ws.max_column >= 3:
        print("\nColumn C detailed values:")
        for r in range(1, ws.max_row + 1):
            print(f"C{r}:", display(ws[f'C{r}'].value))
