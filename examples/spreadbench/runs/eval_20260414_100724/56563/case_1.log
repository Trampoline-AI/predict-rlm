import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["AB"]

# Verify target before editing
print("Original sheet names:", original_sheetnames)
print("Target cell C14 current value:", ws["C14"].value)
print("Range C2:C13 values:", [ws[f"C{r}"].value for r in range(2, 14)])

# Replace the broken SUM with a formula that ignores errors
# Using SUMPRODUCT(IFERROR(...,0)) to sum numeric values and treat errors as zero
ws["C14"] = "=SUMPRODUCT(IFERROR(C2:C13,0))"

# Save
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)
print("Written formula in C14:", ws["C14"].value)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_post = load_workbook(outfile)
if wb_post.sheetnames != original_sheetnames:
    print("Sheet names changed after recalculation:", wb_post.sheetnames)
    # rename by position back to originals
    for i, orig_name in enumerate(original_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = orig_name
    wb_post.save(outfile)
    print("Restored sheet names to:", wb_post.sheetnames)
else:
    print("Sheet names preserved after recalculation.")

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["AB"]
print("Post-save formula in C14:", ws_formula["C14"].value)

# Verify evaluated result
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["AB"]
evaluated_c14 = ws_values["C14"].value
print("Evaluated C14:", evaluated_c14)
print("Verification range C2:C13 values (data_only):", [ws_values[f"C{r}"].value for r in range(2, 14)])

# Compute expected sum from non-error numeric inputs for sanity check
raw_vals = [ws_values[f"C{r}"].value for r in range(2, 14)]
expected = 0
for v in raw_vals:
    if isinstance(v, (int, float)):
        expected += v
print("Expected numeric-only total:", expected)

output_spreadsheet = outfile
