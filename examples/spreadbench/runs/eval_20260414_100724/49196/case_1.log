2. Replace formulas in `C2:C47` with a formula that builds a true datetime from K.
3. Set the display format in C to UK-style slashes.
4. Save to the output path, recalculate, restore sheet names if needed, reload, and verify key rows including the 2021→2022 transition.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheet names:", orig_sheetnames)
print("Target range:", f"C2:C{ws.max_row}")
print("Original C2 formula:", ws["C2"].value)
print("Original K2 value:", ws["K2"].value)
print("Original C35 formula:", ws["C35"].value, "| K35:", ws["K35"].value)

# Replace formulas in column C with a true datetime formula derived from K
updated_rows = []
for r in range(2, ws.max_row + 1):
    kval = ws[f"K{r}"].value
    c = ws[f"C{r}"]
    if kval not in (None, ""):
        # Build a true date/time from dd.mm.yy hh:mm text in K, then format with slashes.
        c.value = (
            f'=IF(K{r}="","",'
            f'DATE(2000+VALUE(MID(K{r},7,2)),VALUE(MID(K{r},4,2)),VALUE(LEFT(K{r},2)))'
            f'+TIMEVALUE(RIGHT(K{r},5)))'
        )
        c.number_format = "dd/mm/yy hh:mm"
        updated_rows.append(r)
    else:
        # Keep blank if K is blank
        c.value = None

print("Updated rows count:", len(updated_rows))
print("New C2 formula:", ws["C2"].value)
print("New C35 formula:", ws["C35"].value)
print("C2 number format:", ws["C2"].number_format)

# Save before recalculation
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    if len(wb_after.sheetnames) == len(orig_sheetnames):
        for old, new in zip(wb_after.sheetnames, orig_sheetnames):
            wb_after[old].title = new
        wb_after.save(outfile)
        print("Restored sheet names to:", orig_sheetnames)
    else:
        print("Warning: sheet name count changed unexpectedly.")

# Verification using cached values
wb_v = load_workbook(outfile, data_only=True)
ws_v = wb_v[orig_sheetnames[0]]

# Also inspect formulas after save
wb_f = load_workbook(outfile, data_only=False)
ws_f = wb_f[orig_sheetnames[0]]

verify_rows = [2, 3, 34, 35, 36, 43, 47]
print("\nVerification of target/output rows:")
for r in verify_rows:
    print(
        f"Row {r}: "
        f"K={ws_f[f'K{r}'].value!r} | "
        f"C_formula={ws_f[f'C{r}'].value!r} | "
        f"C_value={ws_v[f'C{r}'].value!r} | "
        f"D_value={ws_v[f'D{r}'].value!r} | "
        f"E_value={ws_v[f'E{r}'].value!r}"
    )

# Basic sanity checks
problems = []
for r in updated_rows:
    if ws_v[f"C{r}"].value in (None, ""):
        problems.append(f"C{r} blank")
    if ws_v[f"D{r}"].value in (None, ""):
        problems.append(f"D{r} blank")
    if ws_v[f"E{r}"].value in (None, ""):
        problems.append(f"E{r} blank")

print("\nProblem count:", len(problems))
print("Problem samples:", problems[:10])

# Explicitly print the year transition rows
print("\nTransition rows 34-36:")
for r in [34, 35, 36]:
    print(
        r,
        "K=", ws_f[f"K{r}"].value,
        "| C value=", ws_v[f"C{r}"].value,
        "| D=", ws_v[f"D{r}"].value,
        "| E=", ws_v[f"E{r}"].value
    )
