import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INPUT:", input_spreadsheet)
print("INSTRUCTION FULL:")
print(instruction)

wb = load_workbook(input_spreadsheet)
print("\nSHEETS:", wb.sheetnames)

def nonempty_bounds(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # detect actual used rows/cols more robustly
    last_row = 0
    last_col = 0
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value not in (None, ""):
                row_has = True
                last_col = max(last_col, cell.column)
        if row_has:
            last_row = row[0].row
    return last_row or max_row, last_col or max_col

for s in wb.sheetnames:
    ws = wb[s]
    last_row, last_col = nonempty_bounds(ws)
    headers = [ws.cell(1, c).value for c in range(1, last_col + 1)]
    print(f"\n=== SHEET: {s} ===")
    print("ws.max_row/max_col:", ws.max_row, ws.max_column)
    print("Detected used rows/cols:", last_row, last_col)
    print("Headers row 1:", headers)
    
    # print first 10 rows
    print("\nFirst 10 rows:")
    for r in range(1, min(last_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, last_col + 1)]
        print(f"Row {r}: {vals}")
    
    # print last 5 rows
    print("\nLast 5 rows:")
    start = max(1, last_row - 4)
    for r in range(start, last_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, last_col + 1)]
        print(f"Row {r}: {vals}")
    
    # Inspect columns C and K specifically
    print("\nColumn C and K inspection (first 15 data rows or available):")
    for r in range(1, min(last_row, 15) + 1):
        c_val = ws[f"C{r}"].value if last_col >= 3 else None
        k_val = ws[f"K{r}"].value if last_col >= 11 else None
        print(f"Row {r}: C={c_val!r}, K={k_val!r}")
    
    if last_row > 15:
        print("\nColumn C and K inspection (last 5 rows):")
        for r in range(max(1, last_row - 4), last_row + 1):
            c_val = ws[f"C{r}"].value if last_col >= 3 else None
            k_val = ws[f"K{r}"].value if last_col >= 11 else None
            print(f"Row {r}: C={c_val!r}, K={k_val!r}")
    
    # Print formulas in column C if any
    c_formulas = []
