Code:
```repl
from openpyxl import load_workbook
from openpyxl.styles import Font, PatternFill
from copy import copy
import os

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing, current C column values/fills:")
for r in range(1, ws.max_row + 1):
    c = ws[f"C{r}"]
    fill_rgb = c.fill.fgColor.rgb if c.fill.fgColor and c.fill.fgColor.type == "rgb" else c.fill.fgColor.indexed
    print(r, c.value, c.fill.fill_type, fill_rgb)

# Apply Calibri font throughout workbook while preserving other font attributes
for sh in wb.worksheets:
    for row in sh.iter_rows():
        for cell in row:
            old_font = cell.font
            cell.font = copy(old_font)
            cell.font = cell.font.copy(name="Calibri")

# Write formulas to column C for all populated data rows (exclude header)
# Logic: text after first space in A must equal B exactly
for r in range(2, ws.max_row + 1):
    a_val = ws[f"A{r}"].value
    b_val = ws[f"B{r}"].value
    if (a_val is None or a_val == "") and (b_val is None or b_val == ""):
        continue
    formula = f'=TRIM(MID(A{r},FIND(" ",A{r})+1,LEN(A{r})))=TRIM(B{r})'
    ws[f"C{r}"] = formula

# Change fill color of values in column C (not header) to #00B050
green_fill = PatternFill(fill_type="solid", start_color="FF00B050", end_color="FF00B050")
for r in range(2, ws.max_row + 1):
    ws[f"C{r}"].fill = green_fill

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reopen and restore sheet names if needed
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames:
    # Rename by position back to original titles
    for i, orig_name in enumerate(original_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = orig_name
    wb_post.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification: formulas and data_only values
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nVerification - formulas in C2:C6:")
for r in range(2, wsf.max_row + 1):
    print(f"C{r} formula:", wsf[f"C{r}"].value)

wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
print("\nVerification - cached values and fills/fonts:")
for r in range(1, wsv.max_row + 1):
    row_vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    print(f"Row {r} values:", row_vals)

# verify fill/font from formula workbook (styles not visible in data_only workbook reliably)
print("\nStyle verification for column C and sample fonts:")
for r in range(1, wsf.max_row + 1):
    c = wsf[f"C{r}"]
    fill_rgb = c.fill.fgColor.rgb if c.fill.fgColor and c.fill.fgColor.type == "rgb" else c.fill.fgColor.indexed
    print(
        f"C{r}: value={c.value}, fill_type={c.fill.fill_type}, fill_rgb={fill_rgb}, "
        f"font={c.font.name}, bold={c.font.bold}"
    )

print("\nWorkbook sheet names final:", wb_values.sheetnames)

output_spreadsheet = outfile
