import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input spreadsheet:", input_spreadsheet)
print("Instruction:", instruction)

# Load workbook twice if needed later; for now normal mode to inspect formulas.
wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Original sheet names:", original_sheet_names)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Gather headers from first few rows to detect where header/data starts
    for hr in range(1, min(ws.max_row, 3) + 1):
        vals = [ws.cell(hr, c).value for c in range(1, min(ws.max_column, 12) + 1)]
        print(f"Row {hr} first cols:", vals)
    
    # Print column letters and apparent headers from row 1
    headers = {}
    for c in range(1, ws.max_column + 1):
        v = ws.cell(1, c).value
        headers[get_column_letter(c)] = v
    print("Headers/row1 values by column:", headers)
    
    # Determine non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in row_vals):
            nonempty_rows.append(r)
    if nonempty_rows:
        print("First non-empty row:", nonempty_rows[0], "Last non-empty row:", nonempty_rows[-1], "Count:", len(nonempty_rows))
    else:
        print("No non-empty rows")
        return
    
    # Print first 10 and last 5 rows across used columns
    first_rows = nonempty_rows[:10]
    last_rows = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
    printed = set()
    for r in first_rows + last_rows:
        if r in printed:
            continue
        printed.add(r)
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # Special focus on columns A-C since instruction references A and C
    print("\nFocused view of columns A:C")
    for r in first_rows + last_rows:
        if r in printed:  # already printed but still show focused A:C
            pass
        print(f"Row {r} A:C =", [ws.cell(r, c).value for c in range(1, min(3, ws.max_column) + 1)])
    
    # Print formulas/values in column C specifically
    print("\nColumn C inspection (up to first 20 non-empty/interesting rows):")
    count = 0
    for r in nonempty_rows:
        a = ws.cell(r, 1).value if ws.max_column >= 1 else None
        c = ws.cell(r, 3).value if ws.max_column >= 3 else None
        if a is not None or c is not None:
            print(f"Row {r}: A={a!r}, C={c!r}")
            count += 1
            if count >= 20:
                break

for ws in wb.worksheets:
    sheet_summary(ws)
