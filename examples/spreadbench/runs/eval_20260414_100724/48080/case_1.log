import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

# Load workbook for editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)

# Reconfirm target area and pattern
a_data_rows = [
    r for r in range(2, ws.max_row + 1)
    if ws.cell(r, 1).value is not None
]
print("Non-header source rows in column A:", a_data_rows)

target_rows = list(range(2, 2 + len(a_data_rows)))
print("Target rows in column C:", target_rows)

print("Before writing, C2:C10:")
for r in range(2, 11):
    print(f"C{r} =", ws.cell(r, 3).value)

# Fill only missing target cells in column C, preserving existing examples
for idx, src_row in enumerate(a_data_rows, start=2):
    target_cell = ws.cell(idx, 3)
    desired_formula = f"=A{src_row}"
    current = target_cell.value
    if current in (None, ""):
        target_cell.value = desired_formula
        print(f"Wrote C{idx} = {desired_formula}")
    else:
        print(f"Preserved existing C{idx} = {current!r}")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check/restore sheet names after recalculation if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    if len(wb_after.sheetnames) == len(original_sheet_names):
        for i, name in enumerate(original_sheet_names):
            wb_after.worksheets[i].title = name
        wb_after.save(output_path)
        print("Renamed sheets back to original names:", original_sheet_names)
    else:
        print("Warning: sheet count changed unexpectedly.")

# Verification with formulas visible
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula[original_sheet_names[0]]

print("\nVerified formulas in target range C1:C6:")
for r in range(1, 7):
    print(f"C{r} = {wsf.cell(r, 3).value!r}")

# Verification with cached/calculated values
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values[original_sheet_names[0]]

print("\nVerified calculated values in target range C1:C6:")
for r in range(1, 7):
    print(f"C{r} = {wsv.cell(r, 3).value!r}")

# Sanity check source vs result
print("\nSource A rows and resulting C values:")
for idx, src_row in enumerate(a_data_rows, start=2):
    print(
        f"A{src_row}={wsv.cell(src_row,1).value!r} -> "
        f"C{idx}={wsv.cell(idx,3).value!r}"
    )
