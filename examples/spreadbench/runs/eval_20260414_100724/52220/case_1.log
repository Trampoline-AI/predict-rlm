```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Inspect relevant cells more deeply before modifying
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Sheet names:", wb.sheetnames)
print("Target sheet:", ws.title)
print("Relevant headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Relevant cells before writing:")
for coord in ["A2", "B2", "C2", "A3", "B3", "C3"]:
    cell = ws[coord]
    print(
        coord,
        "value=", repr(cell.value),
        "number_format=", repr(cell.number_format),
        "fill=", cell.fill.fill_type,
    )

# Apply conditional formula to existing data rows in column C ("next revision")
# Formula: show A+B only if both A and B are not empty, else blank.
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3)
    print(f"Row {r} before -> A={a!r}, B={b!r}, C={c.value!r}")
    c.value = f'=IF(AND(A{r}<>"",B{r}<>""),A{r}+B{r},"")'
    # Preserve/assign a sensible display format for date + duration result
    c.number_format = 'yyyy-mm-dd hh:mm:ss'
    print(f"Row {r} written formula -> {c.value}, number_format={c.number_format}")

# Save output
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# After recalc, ensure sheet names still match original
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "restoring to", orig_sheetnames)
    for i, expected_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected_name
    wb_after.save(outfile)

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
print("Verification (formula view):")
for coord in ["C2", "C3"]:
    print(coord, "formula/value=", repr(ws_formula[coord].value), "number_format=", repr(ws_formula[coord].number_format))

# Verify computed values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]
print("Verification (data_only values):")
for coord in ["A2", "B2", "C2", "A3", "B3", "C3"]:
    print(coord, "->", repr(ws_values[coord].value))

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
