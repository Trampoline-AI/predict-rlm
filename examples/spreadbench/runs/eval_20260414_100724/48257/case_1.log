```repl
import os, re
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

def parse_amount(text):
    if text is None:
        return None
    s = str(text).strip()
    if not s:
        return None

    # Keep only digits, separators, spaces, and minus sign
    cleaned = re.sub(r"[^0-9,.\-\s]", "", s)
    cleaned = re.sub(r"\s+", " ", cleaned).strip()

    # Determine negativity once; then remove minus signs before parsing
    negative = "-" in cleaned
    cleaned_no_sign = cleaned.replace("-", "").strip()

    if not cleaned_no_sign:
        return None

    # Rightmost comma/dot is treated as decimal separator
    last_comma = cleaned_no_sign.rfind(",")
    last_dot = cleaned_no_sign.rfind(".")
    dec_pos = max(last_comma, last_dot)

    if dec_pos != -1:
        int_part = re.sub(r"[^\d]", "", cleaned_no_sign[:dec_pos])
        frac_part = re.sub(r"[^\d]", "", cleaned_no_sign[dec_pos + 1:])
        if int_part == "" and frac_part == "":
            return None
        num_str = int_part if int_part != "" else "0"
        if frac_part != "":
            num_str += "." + frac_part
    else:
        num_str = re.sub(r"[^\d]", "", cleaned_no_sign)
        if num_str == "":
            return None

    value = float(num_str)
    return -value if negative else value

# Quick parser sanity-check before editing workbook
samples = ["USD 4 884,59", "-41,52 EUR", "-1,65 EUR", "4 841,42 "]
print("Parser test:")
for x in samples:
    print(x, "->", parse_amount(x))

# Reload original workbook for clean modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("\nTarget cells before write:")
for r in range(1, ws.max_row + 1):
    print(f"Row {r}: A={ws.cell(r,1).value!r}, B={ws.cell(r,2).value!r}, C={ws.cell(r,3).value!r}")

# Fill only blank target cells in column C
written = []
for r in range(2, ws.max_row + 1):
    src = ws.cell(r, 2).value
    tgt = ws.cell(r, 3)
    parsed = parse_amount(src)
    if (tgt.value is None or tgt.value == "") and parsed is not None:
        tgt.value = parsed
        written.append((r, parsed))
    print(f"Row {r}: source={src!r}, parsed={parsed!r}, final_C={tgt.value!r}")

print("Written cells:", written)

# Save
wb.save(output_path)
print("Saved:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculate changed them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names:
    for i, expected in enumerate(orig_sheet_names):
        if i < len(wb_post.sheetnames):
            wb_post[wb_post.sheetnames[i]].title = expected
    wb_post.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify using data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

print("\nVerified target cells after write:")
for r in range(1, wsv.max_row + 1):
    print(f"Row {r}: A={wsv.cell(r,1).value!r}, B={wsv.cell(r,2).value!r}, C={wsv.cell(r,3).value!r}")

final_output_path = output_path
