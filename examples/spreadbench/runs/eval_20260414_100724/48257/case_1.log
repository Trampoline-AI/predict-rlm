import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload workbook for modification
wb = load_workbook(input_path)
ws = wb["Sheet1"]

print("Target area before modification:")
for r in range(1, ws.max_row + 1):
    print(f"Row {r}: A={ws[f'A{r}'].value!r}, B={ws[f'B{r}'].value!r}, C={ws[f'C{r}'].value!r}")

def parse_amount(text):
    """
    Extract numeric value from strings like:
    'USD 4 884,59' -> 4884.59
    '-41,52 EUR'   -> -41.52
    '4 841,42 '    -> 4841.42
    Handles currency before/after, spaces as thousand sep, comma/dot decimal sep.
    """
    if text is None:
        return None
    s = str(text).strip()
    if not s:
        return None

    # Keep only digits, separators, spaces, and sign
    cleaned = re.sub(r"[^0-9,.\-\s]", "", s).strip()
    cleaned = re.sub(r"\s+", " ", cleaned)

    # Determine decimal separator: use the rightmost of comma/dot if present
    last_comma = cleaned.rfind(",")
    last_dot = cleaned.rfind(".")
    dec_pos = max(last_comma, last_dot)

    if dec_pos != -1:
        int_part = re.sub(r"[\s,\.]", "", cleaned[:dec_pos])
        frac_part = re.sub(r"[\s,\.]", "", cleaned[dec_pos+1:])
        sign = "-" if "-" in cleaned[:dec_pos+1] else ""
        num_str = f"{sign}{int_part}.{frac_part}" if frac_part != "" else f"{sign}{int_part}"
    else:
        sign = "-" if "-" in cleaned else ""
        digits = re.sub(r"[\s,\.]", "", cleaned)
        digits = digits.replace("-", "")
        num_str = f"{sign}{digits}"

    if num_str in {"", "-", ".", "-."}:
        return None
    return float(num_str)

# Fill only missing target cells in column C
for r in range(2, ws.max_row + 1):
    src = ws.cell(r, 2).value  # column B
    tgt = ws.cell(r, 3)        # column C
    parsed = parse_amount(src)
    print(f"Row {r} parsed from {src!r} -> {parsed!r}; existing C={tgt.value!r}")
    if (tgt.value is None or tgt.value == "") and parsed is not None:
        tgt.value = parsed

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
