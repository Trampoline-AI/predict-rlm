Code:
```repl
from openpyxl import load_workbook
from collections import defaultdict
from pathlib import Path
import os

input_path = input_spreadsheet
orig_wb = load_workbook(input_path)
original_sheet_names = orig_wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

def norm_amount(x):
    if x is None or x == "":
        return None
    try:
        return round(float(x), 10)
    except Exception:
        return None

# Inspect and identify pairs to delete
ws = orig_wb["Imported Data"]
print(f"Working sheet: {ws.title}, rows={ws.max_row}, cols={ws.max_column}")
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Build one-to-one pair matches by (Reference, Narrative, Amount)
debit_rows = defaultdict(list)   # key -> rows where col C == amount and > 0
credit_rows = defaultdict(list)  # key -> rows where col D == amount and > 0

for r in range(2, ws.max_row + 1):
    ref = ws.cell(r, 1).value
    debit = norm_amount(ws.cell(r, 3).value)
    credit = norm_amount(ws.cell(r, 4).value)
    narrative = ws.cell(r, 6).value
    
    if debit not in (None, 0):
        debit_rows[(ref, narrative, debit)].append(r)
    if credit not in (None, 0):
        credit_rows[(ref, narrative, credit)].append(r)

pairs_to_delete = []
for key in sorted(set(debit_rows) & set(credit_rows), key=lambda x: (str(x[0]), str(x[1]), x[2])):
    d_rows = sorted(debit_rows[key])
    c_rows = sorted(credit_rows[key])
    pair_count = min(len(d_rows), len(c_rows))
    for i in range(pair_count):
        debit_row = d_rows[i]
        credit_row = c_rows[i]
        if debit_row != credit_row:
            pairs_to_delete.append((credit_row, debit_row, key))  # store both rows and the match key

print("\nMatched row pairs to delete:")
for credit_row, debit_row, key in pairs_to_delete:
    ref, narrative, amount = key
    print(
        f"ref={ref!r}, narrative={narrative!r}, amount={amount} -> "
        f"credit row {credit_row}, debit row {debit_row}"
    )
    print("  Credit row values:", [ws.cell(credit_row, c).value for c in range(1, ws.max_column + 1)])
    print("  Debit  row values:", [ws.cell(debit_row, c).value for c in range(1, ws.max_column + 1)])

rows_to_delete = sorted({r for credit_row, debit_row, _ in pairs_to_delete for r in (credit_row, debit_row)}, reverse=True)
print("\nRows that will be deleted (descending):", rows_to_delete)

# Save modified workbook to output path
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

# Reload fresh workbook for modification
wb = load_workbook(input_path)
ws = wb["Imported Data"]

for r in rows_to_delete:
    ws.delete_rows(r, 1)

wb.save(output_path)
print("\nSaved modified workbook to:", str(output_path))

# Recalculate
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
post_wb = load_workbook(output_path)
print("Sheet names after recalc reload:", post_wb.sheetnames)
if post_wb.sheetnames != original_sheet_names and len(post_wb.sheetnames) == len(original_sheet_names):
    for idx, expected_name in enumerate(original_sheet_names):
        post_wb.worksheets[idx].title = expected_name
    post_wb.save(output_path)
    print("Renamed sheets back to original names:", original_sheet_names)

# Verification using data_only=True
verify_wb = load_workbook(output_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
verify_ws = verify_wb["Imported Data"]

print(f"\nFinal sheet dimensions: rows={verify_ws.max_row}, cols={verify_ws.max_column}")
print("Final rows:")
for r in range(1, verify_ws.max_row + 1):
    print(f"Row {r}: {[verify_ws.cell(r, c).value for c in range(1, verify_ws.max_column + 1)]}")

# Specific verification of remaining 624521 rows
matching_624521 = []
for r in range(2, verify_ws.max_row + 1):
    vals = [verify_ws.cell(r, c).value for c in range(1, verify_ws.max_column + 1)]
    if vals[0] == 624521:
        matching_624521.append((r, vals))
print("\nRows still present with Reference 624521:")
for item in matching_624521:
    print(item)

# Store for submission
final_output_spreadsheet = str(output_path)
print("\nPrepared output path:", final_output_spreadsheet)
