    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, min(ws.max_column, 15))
        nonempty = sum(v not in (None, "") for v in vals)
        print(f"Row {r} first {min(ws.max_column,15)} cells:", vals, f"| nonempty={nonempty}")
    
    # first 10 rows full-ish limited to 15 cols
    print("\nFirst sample rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"R{r}:", row_values(ws, r, min(ws.max_column, 15)))
    
    print("\nLast sample rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(f"R{r}:", row_values(ws, r, min(ws.max_column, 15)))
    
    # detect formulas in used range, limit print
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print(f"\nFormula cells found: {len(formulas)}")
    for item in formulas[:20]:
        r, c, v = item
        print(f"  {get_column_letter(c)}{r}: {v}")
    
    # print merged ranges if any
    merged = list(ws.merged_cells.ranges)
    print("Merged ranges:", merged[:20], f"(total {len(merged)})")
