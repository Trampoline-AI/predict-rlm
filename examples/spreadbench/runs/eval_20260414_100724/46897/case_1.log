import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load source workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Reconfirm target cells and current state
print("Original sheet names:", original_sheetnames)
for addr in ["H1","I1","H2","I2","H3","I3"]:
    print(addr, "before =>", ws[addr].value)

# Determine actual data table extents from row 1 non-empty headers up to the last non-empty header before the helper area
headers = []
for c in range(1, ws.max_column + 1):
    headers.append(ws.cell(1, c).value)

# Based on inspection, the source table is contiguous in A:D and helper area starts at H:I.
# Verify source headers explicitly.
source_cols = []
for c in range(1, ws.max_column + 1):
