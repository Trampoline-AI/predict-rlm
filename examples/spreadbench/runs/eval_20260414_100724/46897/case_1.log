    if v not in (None, "") and c <= 4:
        source_cols.append(c)

print("Source header columns:", [(get_column_letter(c), ws.cell(1, c).value) for c in source_cols])

first_data_row = 2
last_data_row = ws.max_row
first_source_col = min(source_cols)
last_source_col = max(source_cols)

header_range = f"${get_column_letter(first_source_col)}$1:${get_column_letter(last_source_col)}$1"
data_range = f"${get_column_letter(first_source_col)}${first_data_row}:${get_column_letter(last_source_col)}${last_data_row}"

# Expected result from data for verification
header_title = ws["I1"].value
lookup_value = ws["I2"].value

target_col = None
for c in source_cols:
    if ws.cell(1, c).value == header_title:
        target_col = c
        break

expected_count = 0
matching_rows = []
if target_col is not None:
    for r in range(first_data_row, last_data_row + 1):
        if ws.cell(r, target_col).value == lookup_value:
            expected_count += 1
            matching_rows.append(r)

print("Target header title:", repr(header_title))
print("Lookup value:", repr(lookup_value))
print("Matched source column:", get_column_letter(target_col) if target_col else None)
print("Expected count:", expected_count)
print("Matching rows:", matching_rows)

# Primary formula: dynamic COUNTIF over matched header column
formula_primary = f'=COUNTIF(INDEX({data_range},0,MATCH($I$1,{header_range},0)),$I$2)'
print("Primary formula for I3:", formula_primary)

# Fallback formula: nested IF/COUNTIF for max compatibility
parts = []
for c in source_cols:
    col_letter = get_column_letter(c)
    hdr_cell = f"${col_letter}$1"
    rng = f"${col_letter}${first_data_row}:${col_letter}${last_data_row}"
    parts.append((hdr_cell, rng))

formula_fallback = ""
for hdr_cell, rng in reversed(parts):
    if formula_fallback == "":
        formula_fallback = f'IF($I$1={hdr_cell},COUNTIF({rng},$I$2),"")'
    else:
        formula_fallback = f'IF($I$1={hdr_cell},COUNTIF({rng},$I$2),{formula_fallback})'
formula_fallback = "=" + formula_fallback
print("Fallback formula for I3:", formula_fallback)

# Write primary formula first
ws["I3"] = formula_primary
print("I3 written formula:", ws["I3"].value)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if changed
