def row_vals(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

def nonempty_row_count(ws):
    count = 0
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            count += 1
    return count

for sname in wb.sheetnames:
    ws = wb[sname]
    print("\n" + "=" * 100)
    print(f"Sheet: {sname}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}, nonempty_rows={nonempty_row_count(ws)}")
    
    headers1 = row_vals(ws, 1, ws.max_column)
    headers2 = row_vals(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row 1:", headers1)
    print("Row 2:", headers2)
    
    # first 10 rows
    first_n = min(10, ws.max_row)
