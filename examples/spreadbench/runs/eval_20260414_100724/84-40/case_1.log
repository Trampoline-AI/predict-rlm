```repl
from openpyxl import load_workbook
import os
from pathlib import Path

# Load workbook
wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]

# Identify LIST sheet exactly
list_name = None
for s in wb.sheetnames:
    if s.lower() == "list":
        list_name = s
        break
if list_name is None:
    raise ValueError("No LIST/list sheet found.")

list_idx = wb.sheetnames.index(list_name)
source_sheet_names = wb.sheetnames[:list_idx]  # sheets before LIST only, per instruction
ws_list = wb[list_name]

print("Original sheet names:", original_sheet_names)
print("List sheet:", list_name)
print("Source sheets:", source_sheet_names)

def numeric_sum_from_col(ws, col_idx, start_row=2):
    total = 0
    contributing = []
    for r in range(start_row, ws.max_row + 1):
        v = ws.cell(r, col_idx).value
        if isinstance(v, (int, float)) and not isinstance(v, bool):
            total += v
            contributing.append((r, v))
    return total, contributing

# Compute totals
summaries = []
for sname in source_sheet_names:
    ws = wb[sname]
    total_c, contrib_c = numeric_sum_from_col(ws, 3, 2)
    total_d, contrib_d = numeric_sum_from_col(ws, 4, 2)
    summaries.append({
        "sheet": sname,
        "import_total": total_c,
        "export_total": total_d,
        "balance": total_c - total_d,
    })
    print(f"{sname}: C total={total_c}, D total={total_d}, balance={total_c-total_d}")
    print(f"  sample C contributors: {contrib_c[:5]} ... total count {len(contrib_c)}")
    print(f"  sample D contributors: {contrib_d[:5]} ... total count {len(contrib_d)}")

# Print current target area before modifying
print("\nCurrent LIST target area before clearing/writing:")
for r in range(1, max(ws_list.max_row, len(summaries) + 2) + 1):
    vals = [ws_list.cell(r, c).value for c in range(1, 6)]
    print(f"R{r}: {vals}")

# Clear existing body rows in A:E below header to remove stale data
for r in range(2, ws_list.max_row + 1):
    for c in range(1, 6):
        ws_list.cell(r, c).value = None

# Rewrite summary rows
start_row = 2
for i, item in enumerate(summaries, start=1):
    r = start_row + i - 1
    ws_list.cell(r, 1).value = i
    ws_list.cell(r, 2).value = item["sheet"]
    ws_list.cell(r, 3).value = item["import_total"]
    ws_list.cell(r, 4).value = item["export_total"]
    ws_list.cell(r, 5).value = f"=C{r}-D{r}"

# Total row
total_row = start_row + len(summaries)
ws_list.cell(total_row, 1).value = None
ws_list.cell(total_row, 2).value = "TOTAL"
if len(summaries) >= 1:
    first_data_row = start_row
    last_data_row = total_row - 1
    ws_list.cell(total_row, 3).value = f"=SUM(C{first_data_row}:C{last_data_row})"
    ws_list.cell(total_row, 4).value = f"=SUM(D{first_data_row}:D{last_data_row})"
    ws_list.cell(total_row, 5).value = f"=C{total_row}-D{total_row}"
else:
    ws_list.cell(total_row, 3).value = 0
    ws_list.cell(total_row, 4).value = 0
    ws_list.cell(total_row, 5).value = 0

print("\nLIST target area after writing (formulas shown):")
for r in range(1, total_row + 1):
    vals = [ws_list.cell(r, c).value for c in range(1, 6)]
    print(f"R{r}: {vals}")

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(out_path)
after_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", after_names)

if after_names != original_sheet_names and len(after_names) == len(original_sheet_names):
    for i, expected in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(out_path)
    print("Restored original sheet names:", original_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
verify_list_name = None
for s in wb_verify.sheetnames:
    if s.lower() == "list":
        verify_list_name = s
        break
if verify_list_name is None:
    raise ValueError("LIST sheet missing after save/recalc.")

wsv = wb_verify[verify_list_name]
print("\nVerified LIST values after recalc (data_only):")
for r in range(1, total_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 6)]
    print(f"R{r}: {vals}")

# Basic verification checks
for i, item in enumerate(summaries, start=1):
    r = start_row + i - 1
    assert wsv.cell(r, 2).value == item["sheet"], f"Sheet name mismatch at row {r}"
    assert wsv.cell(r, 3).value is not None, f"Blank import total at row {r}"
    assert wsv.cell(r, 4).value is not None, f"Blank export total at row {r}"
    assert wsv.cell(r, 5).value is not None, f"Blank balance at row {r}"

assert str(wsv.cell(total_row, 2).value).strip() == "TOTAL", "TOTAL label missing"
assert wsv.cell(total_row, 3).value is not None, "Blank total import"
assert wsv.cell(total_row, 4).value is not None, "Blank total export"
assert wsv.cell(total_row, 5).value is not None, "Blank total balance"

output_spreadsheet = out_path
print("\nPrepared output_spreadsheet:", output_spreadsheet)
