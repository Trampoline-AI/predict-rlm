from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_c = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_c + 1)]

sheet_summaries = {}
for ws in wb.worksheets:
    headers = row_values(ws, 1, ws.max_column)
    sheet_summaries[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "headers": headers,
    }
    print(f"\n--- Sheet: {ws.title} ---")
    print("Rows:", ws.max_row, "Cols:", ws.max_column)
    print("Headers row 1:", headers)
    
    # Print first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_values(ws, r, ws.max_column))

# Inspect likely target area on each sheet
for ws in wb.worksheets:
    print(f"\n=== Target inspection on sheet: {ws.title} ===")
    for r in range(1, min(ws.max_row, 15) + 1):
        b = ws[f"B{r}"].value
        e = ws[f"E{r}"].value if ws.max_column >= 5 else None
        if r >= 1:
            print(f"Row {r}: B{r}={b!r}, E{r}={e!r}")
    print("Specific instruction range B6:B13 and E6:E13:")
    for r in range(6, min(ws.max_row, 13) + 1):
        b = ws[f"B{r}"].value
        e = ws[f"E{r}"].value if ws.max_column >= 5 else None
        print(f"B{r}={b!r} | E{r}={e!r}")

# Save workbook/sheet references for next iteration
inspection_wb = wb
inspection_summary = sheet_summaries
