from openpyxl import load_workbook
import os
from shutil import copyfile

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load original workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing, current E6:E13 values/formulas:")
for r in range(6, 14):
    print(r, "B=", ws[f"B{r}"].value, "E=", ws[f"E{r}"].value)

# Write formulas to the exact target range E6:E13
# Use SEARCH for case-insensitive matching; blank if neither term is found.
for r in range(6, 14):
    ws[f"E{r}"] = f'=IF(B{r}="","",IF(ISNUMBER(SEARCH("deposit",B{r})),"Revenue",IF(ISNUMBER(SEARCH("withdrawal",B{r})),"Expenses","")))'

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names remain the same after recalc
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # Rename sheets back to original names by position
    for i, old_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Renamed sheets back to original:", original_sheet_names)

# Verify with formulas visible
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula["Sheet1"]
print("\nFormulas in E6:E13:")
for r in range(6, 14):
    print(f"E{r} formula:", wsf[f"E{r}"].value)

# Verify calculated values
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values["Sheet1"]
print("\nCalculated values in E6:E13:")
verified = []
for r in range(6, 14):
    b = wsv[f"B{r}"].value
    e = wsv[f"E{r}"].value
    verified.append((r, b, e))
    print(f"Row {r}: B{r}={b!r}, E{r}={e!r}")

# Basic sanity check
all_ok = all(v is not None and str(v).strip() != "" for _, _, v in verified)
print("All target cells populated:", all_ok)

final_output_spreadsheet = output_path
