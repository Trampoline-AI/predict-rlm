import zipfile, os, shutil, tempfile
import xml.etree.ElementTree as ET
from openpyxl import load_workbook

out_path = "/sandbox/output/output_spreadsheet/1_55060_init.xlsx"

# Inspect current workbook state before patch
wb_formula_pre = load_workbook(out_path, data_only=False)
ws_formula_pre = wb_formula_pre["Deal 8"]
wb_data_pre = load_workbook(out_path, data_only=True)
ws_data_pre = wb_data_pre["Deal 8"]

print("Before patch:")
print("  formula-view J23:", ws_formula_pre["J23"].value, "type:", ws_formula_pre["J23"].data_type)
print("  data-view    I12:", ws_data_pre["I12"].value)
print("  data-view    J23:", ws_data_pre["J23"].value)

# Patch raw XML so J23 stores BOTH formula and cached value
tmp_fd, tmp_zip_path = tempfile.mkstemp(suffix=".xlsx")
os.close(tmp_fd)

with zipfile.ZipFile(out_path, "r") as zin, zipfile.ZipFile(tmp_zip_path, "w", zipfile.ZIP_DEFLATED) as zout:
    names = zin.namelist()
    # Single-sheet workbook from inspection; worksheet is xl/worksheets/sheet1.xml
    sheet_xml_name = "xl/worksheets/sheet1.xml"
    ns = {"main": "http://schemas.openxmlformats.org/spreadsheetml/2006/main"}
    ET.register_namespace("", ns["main"])
    
    for name in names:
        data = zin.read(name)
        if name == sheet_xml_name:
            root = ET.fromstring(data)
            sheetData = root.find("main:sheetData", ns)
            target_row = None
            for row in sheetData.findall("main:row", ns):
                if row.attrib.get("r") == "23":
                    target_row = row
                    break
            if target_row is None:
                target_row = ET.SubElement(sheetData, f'{{{ns["main"]}}}row', {"r": "23"})
            
            target_cell = None
            for c in target_row.findall("main:c", ns):
                if c.attrib.get("r") == "J23":
                    target_cell = c
                    break
            if target_cell is None:
                target_cell = ET.SubElement(target_row, f'{{{ns["main"]}}}c', {"r": "J23"})
            
            # Preserve style if present; set type for formula returning string
            target_cell.attrib["t"] = "str"
            
            # Remove existing children
            for child in list(target_cell):
                target_cell.remove(child)
            
            # Use cached result from I12
            cached_value = ws_data_pre["I12"].value
            if cached_value is None:
                cached_value = ""
            else:
                cached_value = str(cached_value)
            
            f = ET.SubElement(target_cell, f'{{{ns["main"]}}}f')
            f.text = 'IF(I12="","",I12)'
            v = ET.SubElement(target_cell, f'{{{ns["main"]}}}v')
            v.text = cached_value

            new_data = ET.tostring(root, encoding="utf-8", xml_declaration=True)
            zout.writestr(name, new_data)
        else:
            zout.writestr(name, data)

shutil.move(tmp_zip_path, out_path)

# Verify after patch
wb_formula_post = load_workbook(out_path, data_only=False)
ws_formula_post = wb_formula_post["Deal 8"]
wb_data_post = load_workbook(out_path, data_only=True)
ws_data_post = wb_data_post["Deal 8"]

print("\nAfter patch:")
print("  formula-view J23:", ws_formula_post["J23"].value, "type:", ws_formula_post["J23"].data_type)
print("  data-view    I12:", ws_data_post["I12"].value)
print("  data-view    J23:", ws_data_post["J23"].value)
print("  J23 number_format:", ws_formula_post["J23"].number_format)
print("  Sheet names:", wb_formula_post.sheetnames)

output_spreadsheet = out_path
```
