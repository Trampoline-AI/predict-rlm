from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row 2 values:", row_values(ws, 2, ws.max_column))
    # first 5-10 rows
    first_end = min(ws.max_row, 10)
    print(f"First rows 1-{first_end}:")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, ws.max_column))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}-{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # print I12 and J23 if within range
    for coord in ["I12", "J23"]:
        cell = ws[coord]
        print(f"{ws.title}!{coord} raw value:", cell.value, "data_type:", cell.data_type)

# Also inspect formulas by loading with data_only=False (already default) and cached values with data_only=True
wb_data = load_workbook(input_spreadsheet, data_only=True)
print("\nCached values view:")
for ws in wb_data.worksheets:
    for coord in ["I12", "J23"]:
        print(f"{ws.title}!{coord} cached/data_only value:", ws[coord].value)
