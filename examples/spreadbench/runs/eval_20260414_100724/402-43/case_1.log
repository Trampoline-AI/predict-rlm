def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:")
    for i, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)}: {h}")
    ag_idx = column_index_from_string("AG")
    print("Column AG header:", ws.cell(1, ag_idx).value)
    
    # find last non-empty row in column A and in any column
    last_a = 0
    last_any = 0
    for r in range(1, ws.max_row + 1):
        if ws.cell(r, 1).value not in (None, ""):
            last_a = r
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            last_any = r
    print("Last non-empty row in col A:", last_a)
    print("Last non-empty row in sheet:", last_any)
    
    sample_rows = list(range(1, min(ws.max_row, 10) + 1))
    tail_start = max(1, ws.max_row - 4)
    tail_rows = list(range(tail_start, ws.max_row + 1))
    print("\nFirst rows sample:")
    for r in sample_rows:
        vals = row_values(ws, r, min(ws.max_column, ag_idx))
        print(f"Row {r}: A={ws.cell(r,1).value!r}, AG={ws.cell(r,ag_idx).value!r}, first10={vals[:10]}")
    print("\nLast rows sample:")
    for r in tail_rows:
        vals = row_values(ws, r, min(ws.max_column, ag_idx))
        print(f"Row {r}: A={ws.cell(r,1).value!r}, AG={ws.cell(r,ag_idx).value!r}, first10={vals[:10]}")
    
    # print rows with non-empty AG among first/last and a small scan summary
