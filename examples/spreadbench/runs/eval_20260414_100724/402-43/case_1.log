from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
from copy import copy
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

max_col = ws.max_column
count_col = column_index_from_string("AG")

def row_has_any_value(ws, r, max_col):
    return any(ws.cell(r, c).value not in (None, "") for c in range(1, max_col + 1))

# Detect source rows: contiguous non-empty rows after header until first blank row
source_rows = []
for r in range(2, ws.max_row + 1):
    if not source_rows:
        if row_has_any_value(ws, r, max_col):
            source_rows.append(r)
    else:
        if row_has_any_value(ws, r, max_col):
            source_rows.append(r)
        else:
            break

# Detect existing output header row (repeated header block)
target_header_row = None
for r in range((source_rows[-1] + 1) if source_rows else 2, ws.max_row + 1):
    if ws.cell(r, 1).value == ws.cell(1, 1).value and ws.cell(r, count_col).value == ws.cell(1, count_col).value:
        target_header_row = r
        break

if target_header_row is None:
    target_header_row = ws.max_row + 2  # fallback append below if no target block exists

target_start_row = target_header_row + 1

print("Source rows detected:", source_rows)
print("Target header row:", target_header_row)
print("Target start row:", target_start_row)

# Build expanded mapping: each entry references the source row to copy
expanded_source_rows = []
for r in source_rows:
    raw_count = ws.cell(r, count_col).value
    try:
        count = int(raw_count)
    except Exception:
        count = 0
    if count < 0:
        count = 0
    expanded_source_rows.extend([r] * count)

print("Expanded source mapping:", expanded_source_rows)
print("Expected output row count:", len(expanded_source_rows))

# Preserve target header row as-is; rewrite data rows below it
old_max_row = ws.max_row

# Clear old target data area below target header
for r in range(target_start_row, old_max_row + 1):
    for c in range(1, max_col + 1):
        ws.cell(r, c).value = None
        # keep styles/layout intact where possible

# Write expanded rows
for idx, src_r in enumerate(expanded_source_rows, start=target_start_row):
    for c in range(1, max_col + 1):
        src = ws.cell(src_r, c)
        dst = ws.cell(idx, c)
        dst.value = src.value
        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.font:
            dst.font = copy(src.font)
        if src.fill:
            dst.fill = copy(src.fill)
        if src.border:
            dst.border = copy(src.border)
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.protection:
            dst.protection = copy(src.protection)
        if src.hyperlink:
            dst._hyperlink = copy(src.hyperlink)
        if src.comment:
            dst.comment = copy(src.comment)

# Save workbook
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for i, old_name in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = old_name
    wb_post.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify output
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]

verify_rows = range(target_header_row, target_start_row + len(expanded_source_rows))
print("Verification of target block key columns:")
for r in verify_rows:
    print(
        r,
        {
            "A": wsv.cell(r, 1).value,
            "C": wsv.cell(r, 3).value,
            "D": wsv.cell(r, 4).value,
            "H": wsv.cell(r, 8).value,
            "S": wsv.cell(r, 19).value,
            "AE": wsv.cell(r, 31).value,
            "AF": wsv.cell(r, 32).value,
            "AG": wsv.cell(r, 33).value,
        },
    )

# Additional sanity checks
expected_total = len(expanded_source_rows)
actual_nonempty_target = 0
for r in range(target_start_row, target_start_row + expected_total):
    if any(wsv.cell(r, c).value not in (None, "") for c in range(1, max_col + 1)):
        actual_nonempty_target += 1

print("Expected duplicated rows:", expected_total)
print("Actual non-empty duplicated rows:", actual_nonempty_target)

# keep for next turn
final_output_spreadsheet = output_path
print("final_output_spreadsheet =", final_output_spreadsheet)
```
