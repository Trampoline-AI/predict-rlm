import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
orig_sheetnames = wb.sheetnames[:]
print("Sheet names:", orig_sheetnames)

def printable(v):
    if v is None:
        return None
    s = str(v)
    return s if len(s) <= 120 else s[:117] + "..."

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # print first several rows raw
    rows_to_show_top = list(range(1, min(ws.max_row, 10) + 1))
    rows_to_show_bottom = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in rows_to_show_top + rows_to_show_bottom:
        if r not in seen:
            rows_to_show.append(r)
            seen.add(r)
    
    # show row contents across used columns
    for r in rows_to_show:
        vals = [printable(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # candidate headers: first 3 rows
    print("Header candidates:")
    for r in range(1, min(4, ws.max_row + 1)):
        vals = [printable(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"  row {r}: {vals}")
    
    # list columns with letters and first-row/second-row values
    print("Column map:")
    for c in range(1, ws.max_column + 1):
        v1 = printable(ws.cell(1, c).value)
        v2 = printable(ws.cell(2, c).value) if ws.max_row >= 2 else None
        print(f"  {get_column_letter(c)} ({c}): row1={v1!r}, row2={v2!r}")
    
    # inspect formulas in first 15 rows
    formula_cells = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
            val = ws.cell(r, c).value
            if isinstance(val, str) and val.startswith("="):
                formula_cells.append((ws.cell(r, c).coordinate, val))
    print("Formulas in first 20 rows:", formula_cells[:20], f"(total shown {len(formula_cells)})")

# Extra focused inspection on Summary-like sheets
summary_like = [s for s in wb.sheetnames if "summary" in s.lower()]
print("\nSummary-like sheets:", summary_like)
for s in summary_like:
    ws = wb[s]
    print(f"\nFocused inspection of {s}")
    for r in range(1, min(ws.max_row, 20) + 1):
        row_vals = [printable(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {row_vals}")
    # print all non-empty cells with coordinates in first 30 rows
    nonempty = []
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, ws.max_column + 1):
            val = ws.cell(r, c).value
            if val is not None:
                nonempty.append((ws.cell(r, c).coordinate, printable(val)))
    print("Non-empty cells first 30 rows:", nonempty[:100])
