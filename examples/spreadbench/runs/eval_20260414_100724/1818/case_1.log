import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Reload fresh workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws_data = wb["Data"]
ws_sum = wb["Summary"]

# Inspect source data carefully
headers = {c: ws_data.cell(1, c).value for c in range(1, ws_data.max_column + 1)}
print("Data headers:", headers)

matches = []
for r in range(2, ws_data.max_row + 1):
    student_no = ws_data.cell(r, 2).value
    student_name = ws_data.cell(r, 3).value
    perf = ws_data.cell(r, 4).value
    if perf == "Lowest Performing":
        matches.append((r, student_no, student_name, perf))

print("Lowest Performing count:", len(matches))
print("Lowest Performing rows:", matches)

# Inspect current Summary target area
inspect_to = max(17, 2 + len(matches) + 3)
print("Current Summary target area before writing:")
for r in range(2, inspect_to + 1):
    print(r, ws_sum[f"B{r}"].value, ws_sum[f"C{r}"].value)

# Write formulas starting in B3/C3
# Fill down enough rows to cover the full data extent so the Summary remains dynamic.
start_row = 3
end_row = ws_data.max_row + 1  # enough rows for all possible data records

data_first = 2
data_last = ws_data.max_row

# Clear old target area first only in intended output columns
for r in range(start_row, end_row + 1):
    ws_sum[f"B{r}"] = None
    ws_sum[f"C{r}"] = None

for r in range(start_row, end_row + 1):
    k_b = f"ROWS(B$3:B{r})"
    k_c = f"ROWS(C$3:C{r})"
    formula_b = (
        f'=IFERROR(INDEX(Data!$B${data_first}:$B${data_last},'
        f'_xlfn.AGGREGATE(15,6,(ROW(Data!$D${data_first}:$D${data_last})-ROW(Data!$D${data_first})+1)/'
        f'(Data!$D${data_first}:$D${data_last}="Lowest Performing"),{k_b})),"")'
    )
    formula_c = (
        f'=IFERROR(INDEX(Data!$C${data_first}:$C${data_last},'
        f'_xlfn.AGGREGATE(15,6,(ROW(Data!$D${data_first}:$D${data_last})-ROW(Data!$D${data_first})+1)/'
        f'(Data!$D${data_first}:$D${data_last}="Lowest Performing"),{k_c})),"")'
    )
    ws_sum[f"B{r}"] = formula_b
    ws_sum[f"C{r}"] = formula_c

# Save workbook
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open after recalc and restore sheet names if changed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename sheets back to original names by position
    for i, desired in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = desired
    wb_after.save(outfile)
    print("Renamed sheets back to original:", orig_sheetnames)

# Verify formulas and evaluated values
wb_formula = load_workbook(outfile, data_only=False)
ws_sum_formula = wb_formula["Summary"]

print("Sample formulas written:")
for r in range(3, min(8, end_row + 1)):
    print(r, ws_sum_formula[f"B{r}"].value, ws_sum_formula[f"C{r}"].value)

wb_vals = load_workbook(outfile, data_only=True)
ws_sum_vals = wb_vals["Summary"]

print("Verified Summary values after recalc:")
verified = []
for r in range(3, 3 + max(len(matches), 5)):
    verified.append((r, ws_sum_vals[f"B{r}"].value, ws_sum_vals[f"C{r}"].value))
print(verified)

# Check against source matches
expected_pairs = [(m[1], m[2]) for m in matches]
actual_pairs = []
for r in range(3, end_row + 1):
    b = ws_sum_vals[f"B{r}"].value
    c = ws_sum_vals[f"C{r}"].value
    if b not in (None, "") or c not in (None, ""):
        actual_pairs.append((b, c))

print("Expected pairs:", expected_pairs)
print("Actual nonblank pairs:", actual_pairs)
print("Match status:", expected_pairs == actual_pairs)
```
