        if any(ws.cell(r, c).value not in (None, "") for r in range(1, ws.max_row + 1)):
            return c
    return 0

def row_values(ws, r, cmax):
    vals = []
    for c in range(1, cmax + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

