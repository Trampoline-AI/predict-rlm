from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os, shutil

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

def last_nonempty_row(ws, cols=None):
    cols = cols or range(1, ws.max_column + 1)
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(r, c).value not in (None, "") for c in cols):
            return r
    return 0

# Load workbook and inspect exact target/source areas again before editing
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet4"]
src = wb["CBtrans"]

print("Original sheet names:", original_sheetnames)
print("Sheet4 dims:", ws.max_row, ws.max_column)
print("CBtrans dims:", src.max_row, src.max_column)

print("\nCurrent target area Sheet4!A:K rows 1:7")
for r in range(1, 8):
    print(r, [ws.cell(r, c).value for c in range(1, 12)])

print("\nCurrent K2:K7 raw values/formulas before change")
for r in range(2, 8):
    print(f"K{r}:", ws[f"K{r}"].value)

src_last = last_nonempty_row(src, cols=range(1, 12))
print("\nCBtrans source rows 1:7 A:K")
for r in range(1, min(src_last, 7) + 1):
    print(r, [src.cell(r, c).value for c in range(1, 12)])

# Compute expected values in Python for sanity check
source_tuples = set()
for r in range(2, src_last + 1):
    comp = src.cell(r, 1).value   # A company
    acct = src.cell(r, 8).value   # H account
    xchar = src.cell(r, 11).value # K xchar
    source_tuples.add((comp, acct, xchar))

expected = {}
for r in range(2, 8):
    key = (ws.cell(r, 2).value, ws.cell(r, 9).value, ws.cell(r, 5).value)  # B, I, E
    expected[r] = "Match" if key in source_tuples else "-"
print("\nExpected results from Python check:", expected)

# Write formulas into K2:K7
pink_fill = PatternFill(fill_type="solid", start_color="FFFF66CC", end_color="FFFF66CC")

for r in range(2, 8):
    formula = f'=IF(COUNTIFS(CBtrans!$A$2:$A${src_last},B{r},CBtrans!$H$2:$H${src_last},I{r},CBtrans!$K$2:$K${src_last},E{r})>0,"Match","-")'
    ws[f"K{r}"] = formula
    ws[f"K{r}"].fill = pink_fill

print("\nWritten formulas in K2:K7")
for r in range(2, 8):
    print(f"K{r}:", ws[f"K{r}"].value)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    # rename by position back to originals
    for i, orig_name in enumerate(original_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = orig_name
    wb_check.save(outfile)
    print("Restored sheet names to:", wb_check.sheetnames)
else:
    print("Sheet names preserved.")

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet4"]

print("\nVerification: formulas and fills in K2:K7")
for r in range(2, 8):
    cell = ws_formula[f"K{r}"]
    print(
        f"K{r}: formula={cell.value!r}, "
        f"fill={cell.fill.fill_type}, color={cell.fill.start_color.rgb}"
    )

# Verify cached values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet4"]

verified_values = {}
any_none = False
for r in range(2, 8):
    v = ws_values[f"K{r}"].value
    verified_values[r] = v.strip() if isinstance(v, str) else v
    if v in (None, ""):
        any_none = True

print("\nVerification: cached values in K2:K7 after recalc")
print(verified_values)

# Fallback to literals only if formula evaluation failed
if any_none:
    print("Some cached values are blank after recalc; falling back to literal values.")
    wb_fix = load_workbook(outfile)
    ws_fix = wb_fix["Sheet4"]
    for r in range(2, 8):
        ws_fix[f"K{r}"] = expected[r]
        ws_fix[f"K{r}"].fill = pink_fill
    wb_fix.save(outfile)

    wb_values2 = load_workbook(outfile, data_only=True)
    ws_values2 = wb_values2["Sheet4"]
    verified_values = {r: ws_values2[f"K{r}"].value for r in range(2, 8)}
    print("Post-fallback values:", verified_values)

# Final concise verification against expected
print("\nFinal expected vs actual")
for r in range(2, 8):
    actual = verified_values[r]
    print(f"K{r}: expected={expected[r]!r}, actual={actual!r}")

output_spreadsheet = outfile
