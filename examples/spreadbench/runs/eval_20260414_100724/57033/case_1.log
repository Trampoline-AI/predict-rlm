    headers = [(get_column_letter(c), ws.cell(1, c).value) for c in range(1, min(last_col, 20) + 1)]
    sheet_summaries[s] = {"last_row": last_row, "last_col": last_col, "headers": headers}

print("\nSHEET SUMMARIES")
