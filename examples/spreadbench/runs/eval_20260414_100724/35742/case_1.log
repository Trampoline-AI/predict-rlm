from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from shutil import copyfile

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook with formulas
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Working sheet:", ws.title, "size:", ws.max_row, "x", ws.max_column)

# Exact target columns identified from inspection
section1_place_cols = [5, 7, 9, 11, 13]     # E,G,I,K,M
section1_point_cols = [6, 8, 10, 12, 14]    # F,H,J,L,N
later_place_cols = [18, 20, 22, 24]         # R,T,V,X
later_point_cols = [19, 21, 23, 25]         # S,U,W,Y
target_total_col = 15                       # O

# Determine rows that actually need a Section Total formula in O
target_rows = []
for r in range(4, ws.max_row + 1):
    has_participant_info = any(ws.cell(r, c).value not in (None, "") for c in [1, 2, 3, 4])
    has_section1_places = any(ws.cell(r, c).value not in (None, "") for c in section1_place_cols)
    has_existing_total = ws.cell(r, target_total_col).value not in (None, "")
    if has_participant_info or has_section1_places or has_existing_total:
        target_rows.append(r)

print("Target rows for column O:", len(target_rows), "sample first 15:", target_rows[:15], "last 10:", target_rows[-10:])

# Show current formulas before changing a few representative cells
print("\nExisting sample point formulas before change:")
for coord in ["F4", "H4", "J4", "L4", "N4", "S4", "U4", "W4", "Y4"]:
    print(coord, "=", ws[coord].value)

# Rewrite point formulas so they return NUMBERS, not quoted text.
# This preserves the intended logic but makes summation work.
def numeric_points_formula(place_ref):
    return f'=IF({place_ref}="","",IF({place_ref}="-","",IF({place_ref}="1st",3,IF({place_ref}="2nd",2,IF({place_ref}="3rd",1,IF({place_ref}="CH",5,IF({place_ref}="RCH",4,"")))))))'

# Update all existing points columns throughout the sheet
updated_point_cells = 0
for r in range(4, ws.max_row + 1):
    for place_col, point_col in zip(section1_place_cols, section1_point_cols):
        place_ref = f"{get_column_letter(place_col)}{r}"
        ws.cell(r, point_col).value = numeric_points_formula(place_ref)
        updated_point_cells += 1
    for place_col, point_col in zip(later_place_cols, later_point_cols):
        place_ref = f"{get_column_letter(place_col)}{r}"
        ws.cell(r, point_col).value = numeric_points_formula(place_ref)
        updated_point_cells += 1

print("Updated point-formula cells:", updated_point_cells)

# Write Section Total formulas into O for relevant rows only
written_total_formulas = 0
for r in target_rows:
    # Keep truly empty rows blank; sum only where section 1 place cells have something
    formula = f'=IF(COUNTA(E{r},G{r},I{r},K{r},M{r})=0,"",SUM(F{r},H{r},J{r},L{r},N{r}))'
    ws.cell(r, target_total_col).value = formula
    written_total_formulas += 1

print("Written O formulas:", written_total_formulas)

# Print sample target formulas after change
