from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from shutil import copyfile

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and inspect target again before writing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

def row_has_data(ws, r):
    return any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1))

true_last_row = 0
for r in range(ws.max_row, 0, -1):
    if row_has_data(ws, r):
        true_last_row = r
        break

print("Original sheet names:", original_sheet_names)
print("Target sheet:", ws.title)
print("True last row:", true_last_row)
print("Current M2:", ws["M2"].value)
print("A2:", ws["A2"].value)

# Build the formula for M2 using the verified paired columns
pairs = [("O","P"), ("Q","R"), ("S","T"), ("U","V"), ("W","X")]
formula_parts = [f'SUMIF({part}2:{part}{true_last_row},A2,{qty}2:{qty}{true_last_row})' for part, qty in pairs]
m2_formula = "=" + "+".join(formula_parts)

print("Writing formula to M2:")
print(m2_formula)

ws["M2"] = m2_formula

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)

renamed = False
if wb_after.sheetnames != original_sheet_names and len(wb_after.sheetnames) == len(original_sheet_names):
    for i, expected_name in enumerate(original_sheet_names):
        if wb_after.worksheets[i].title != expected_name:
            wb_after.worksheets[i].title = expected_name
            renamed = True
    if renamed:
        wb_after.save(output_path)
        print("Restored original sheet names:", original_sheet_names)

# Verify formula text
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]
print("Verified formula in M2:", ws_formula["M2"].value)

# Verify calculated value
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]
print("Verified cached value in M2:", ws_values["M2"].value)

# Also print source matches again for sanity
target_pn = ws_values["A2"].value
print("Target PN:", target_pn)
for part_col, qty_col in pairs:
    part_idx = ord(part_col) - ord("A") + 1
    qty_idx = ord(qty_col) - ord("A") + 1
    for r in range(2, true_last_row + 1):
        part_val = ws_values.cell(r, part_idx).value
        qty_val = ws_values.cell(r, qty_idx).value
        if part_val == target_pn:
            print(f"Match at {part_col}{r}/{qty_col}{r}:", part_val, qty_val)

output_spreadsheet = output_path
print("Prepared output_spreadsheet:", output_spreadsheet)
