import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load fresh workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws_open = wb["Open"]
ws_prod = wb["Productivity"]

# Build lookup from Productivity A:B
lookup = {}
prod_nonblank_rows = []
for r in range(1, ws_prod.max_row + 1):
    a = ws_prod[f"A{r}"].value
    b = ws_prod[f"B{r}"].value
    if a not in (None, "") or b not in (None, ""):
        prod_nonblank_rows.append((r, a, b))

# Use rows where both A and B have real values, excluding header-like rows
for r, a, b in prod_nonblank_rows:
    if (
        isinstance(a, str) and isinstance(b, str)
        and a.strip() not in ("", "MUD ID", "P R O D U C T I V I T Y    T R A C K E R")
        and b.strip() not in ("", "Name")
    ):
        lookup[a.strip()] = b.strip()

print("Lookup size:", len(lookup))
print("Lookup sample:", list(lookup.items())[:5])

# Replace IDs with Names in Open columns C and K, only when exact match exists
changes = []
for r in range(1, ws_open.max_row + 1):
    for col in ["C", "K"]:
        cell = ws_open[f"{col}{r}"]
        val = cell.value
        if isinstance(val, str):
            key = val.strip()
            if key in lookup:
                new_val = lookup[key]
                if val != new_val:
                    changes.append((f"{col}{r}", val, new_val))
                    cell.value = new_val

print("Total replacements:", len(changes))
print("First 20 replacements:")
for item in changes[:20]:
    print(item)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open and restore original sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    # Rename sheets by position back to originals
    if len(wb_check.sheetnames) == len(original_sheet_names):
        for i, old_name in enumerate(original_sheet_names):
            wb_check.worksheets[i].title = old_name
        wb_check.save(output_path)
        print("Restored sheet names to:", original_sheet_names)
    else:
        print("Unexpected sheet count; not renaming.")
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

wsv_open = wb_verify["Open"]

# Print exact target range values after replacement
print("\nVerified Open!C4:C23 and K4:K23")
verified_rows = []
for r in range(4, wsv_open.max_row + 1):
    c_val = wsv_open[f"C{r}"].value
    k_val = wsv_open[f"K{r}"].value
    verified_rows.append((r, c_val, k_val))
    print((r, c_val, k_val))

# Sanity checks
remaining_ids = []
for r, c_val, k_val in verified_rows:
    for col, val in [("C", c_val), ("K", k_val)]:
        if isinstance(val, str) and val.strip() in lookup:
            remaining_ids.append((f"{col}{r}", val))

blank_targets = []
for r, c_val, k_val in verified_rows:
    if c_val in (None, ""):
        blank_targets.append(f"C{r}")
    if k_val in (None, ""):
        blank_targets.append(f"K{r}")

print("\nRemaining direct lookup IDs still present in targets:", remaining_ids)
print("Blank target cells in data rows:", blank_targets)
print("Verification summary: rows checked =", len(verified_rows), ", replacements made =", len(changes))

# Keep path available for submission next turn
final_output_path = output_path
print("final_output_path =", final_output_path)
```
