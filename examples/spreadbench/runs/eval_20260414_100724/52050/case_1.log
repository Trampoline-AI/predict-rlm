```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string

# Reload fresh workbook for modification
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Helper bounds
start_col = column_index_from_string("D")
end_col = column_index_from_string("BC")
target_col = column_index_from_string("BE")

# Verify existing target cells / examples and compare to candidate logic
print("Existing BE cells and candidate sums:")
sample_compare = []
for r in range(3, ws.max_row + 1):
    row_has_data = ws[f"C{r}"].value is not None or any(ws.cell(r, c).value is not None for c in range(start_col, end_col + 1))
    if not row_has_data:
        continue
    current_week = ws["B2"].value
    candidate = 0
    for c in range(start_col, end_col + 1):
        header_week = ws.cell(2, c).value
        val = ws.cell(r, c).value
        if isinstance(header_week, (int, float)) and isinstance(current_week, (int, float)) and header_week >= current_week:
            candidate += (val or 0)
    existing = ws.cell(r, target_col).value
    sample_compare.append((r, existing, candidate))
    print(f"Row {r}: existing BE={existing}, candidate={candidate}")

# Write formula to all relevant rows in BE
written_rows = []
for r in range(3, ws.max_row + 1):
    row_has_data = ws[f"C{r}"].value is not None or any(ws.cell(r, c).value is not None for c in range(start_col, end_col + 1))
    if not row_has_data:
        continue
    formula = f'=SUMIF($D$2:$BC$2,">="&$B$2,D{r}:BC{r})'
    ws.cell(r, target_col).value = formula
    written_rows.append(r)

print("\nWritten formulas in BE:")
for r in written_rows:
    print(f"BE{r} -> {ws[f'BE{r}'].value}")

# Save output
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # Rename back in order
    for i, original_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(outfile)
    print("Restored original sheet names:", orig_sheet_names)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification of target cells BE3:BE14")
verification = []
for r in written_rows:
    formula = ws_formula[f"BE{r}"].value
    value = ws_values[f"BE{r}"].value
    verification.append((r, formula, value))
    print(f"Row {r}: formula={formula} | value={value}")

# Extra sanity check against Python computation
print("\nSanity check vs Python-computed totals:")
mismatches = []
for r in written_rows:
    current_week = ws_values["B2"].value
    py_total = 0
    for c in range(start_col, end_col + 1):
        header_week = ws_values.cell(2, c).value
        val = ws_values.cell(r, c).value
        if isinstance(header_week, (int, float)) and isinstance(current_week, (int, float)) and header_week >= current_week:
            py_total += (val or 0)
    be_val = ws_values[f"BE{r}"].value
    print(f"Row {r}: BE={be_val}, Python total={py_total}")
    if be_val != py_total:
        mismatches.append((r, be_val, py_total))

print("\nMismatches:", mismatches)
output_spreadsheet = outfile
