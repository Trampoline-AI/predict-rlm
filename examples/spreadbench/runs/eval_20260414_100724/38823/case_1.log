```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Thorough targeted inspection
print("Original sheet names:", original_sheetnames)
print("Sheet1 size:", ws.max_row, ws.max_column)

print("\nRelevant area A2:I15 before modification:")
for r in range(2, min(ws.max_row, 15) + 1):
    vals = [ws.cell(r, c).value for c in range(1, 10)]
    print(f"R{r}: {vals}")

print("\nSpecific referenced cells before modification:")
for coord in ["E3", "E4", "F4", "H4", "H5", "H6", "H7", "I3", "I4", "I5", "I6", "I7"]:
    print(coord, "=", ws[coord].value)

# Identify source data extent in A:C
data_start_row = 3
data_end_row = 0
for r in range(ws.max_row, data_start_row - 1, -1):
    if any(ws.cell(r, c).value is not None for c in [1, 2, 3]):
        data_end_row = r
        break

# Identify all non-empty search terms in H starting at row 4
search_rows = []
for r in range(4, ws.max_row + 1):
    if ws.cell(r, 8).value not in (None, ""):
        search_rows.append(r)

print("\nDetected source data rows:", data_start_row, "to", data_end_row)
print("Detected search-term rows in column H:", search_rows)

# Show the example relationship explicitly
print("\nSource rows contributing to example understanding:")
for r in range(data_start_row, data_end_row + 1):
    print(
        f"R{r}: date={ws.cell(r,1).value}, fabric={ws.cell(r,2).value}, units={ws.cell(r,3).value}"
    )

# Write formulas into column I for all search terms in H
# Use SUMPRODUCT with SEARCH for "contains", date bounds inclusive, fixed criteria dates in E4/F4
for r in search_rows:
    formula = (
        f'=SUMPRODUCT(($A${data_start_row}:$A${data_end_row}>=$E$4)*'
        f'($A${data_start_row}:$A${data_end_row}<=$F$4)*'
        f'ISNUMBER(SEARCH(H{r},$B${data_start_row}:$B${data_end_row}))*'
        f'$C${data_start_row}:$C${data_end_row})'
    )
    print(f"Writing I{r} =", formula)
    ws.cell(r, 9).value = formula

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename in order back to original names
    for i, orig_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas exist
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[original_sheetnames[0]]

print("\nFormulas in target cells after save:")
for r in search_rows:
    print(f"I{r} formula:", wsf[f"I{r}"].value)

# Verify evaluated values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[original_sheetnames[0]]

print("\nEvaluated target cells after recalculation:")
for r in search_rows:
    print(
        f"Row {r}: H{r}={wsv[f'H{r}'].value!r}, I{r}={wsv[f'I{r}'].value!r}"
    )

# Additional sanity-check expected values from visible data
print("\nVerification summary:")
for r in search_rows:
    term = wsv[f"H{r}"].value
    val = wsv[f"I{r}"].value
    ok = (term not in (None, "")) and (val is not None)
    print(f"search term={term!r}, result={val!r}, nonblank_ok={ok}")

output_path = outfile
print("\nPrepared output_path =", output_path)
```
