import os, json, textwrap, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws):
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # detect headers from first few rows
    for header_row in range(1, min(4, ws.max_row) + 1):
        vals = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {header_row}:", vals)
    
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Assumed headers row 1:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}: {h}")
    
    # first 10 rows
    first_n = min(10, ws.max_row)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"R{r}: {vals}")
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"R{r}: {vals}")
    
    # inspect formulas / non-empty cells in columns around H
    print("\nCells with formulas (first 50 found):")
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
    for coord, formula in formula_cells[:50]:
        print(coord, formula)
    print("Total formula cells:", len(formula_cells))
    
    if ws.max_column >= 8:
        print("\nColumn H values (first 15 non-empty):")
        shown = 0
        for r in range(1, ws.max_row + 1):
            v = ws.cell(r, 8).value
            if v is not None:
                print(f"H{r}={v}")
                shown += 1
            if shown >= 15:
                break
        
        print("Column H values (last 10 non-empty):")
        nonempty_h = [(r, ws.cell(r, 8).value) for r in range(1, ws.max_row + 1) if ws.cell(r, 8).value is not None]
        for r, v in nonempty_h[-10:]:
            print(f"H{r}={v}")

for ws in wb.worksheets:
    sheet_summary(ws)
