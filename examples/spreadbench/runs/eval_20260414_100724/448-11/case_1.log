```repl
from openpyxl import load_workbook
import os
from copy import copy

# Reload fresh from input for clean modification
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

def last_nonempty_row(ws):
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            return r
    return 1

def normalize_key(v):
    if isinstance(v, str):
        s = v.strip()
        return s if s != "" else None
    return v

used_last_row = last_nonempty_row(ws)
print("Sheet:", ws.title)
print("Used last row:", used_last_row, "Max column:", ws.max_column)

print("\nDetailed rows in used range:")
for r in range(1, used_last_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(r, vals)

# Determine header/data rows from inspection
header_row = 2
data_start_row = 3
print("\nHeader row values:", [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)])
print("Column A data values before deletion:")
for r in range(data_start_row, used_last_row + 1):
    print(f"Row {r}: A={ws.cell(r,1).value}")

# Find duplicates in Column A only, keeping first occurrence
seen = {}
rows_to_delete = []
dup_details = []
for r in range(data_start_row, used_last_row + 1):
    key = normalize_key(ws.cell(r, 1).value)
    if key is None:
        continue
    if key in seen:
        rows_to_delete.append(r)
        dup_details.append((r, key, seen[key]))
    else:
        seen[key] = r

print("\nDuplicate rows based on Column A only (row_to_delete, key, first_kept_row):")
print(dup_details)

# Delete from bottom up
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

wb.save(outfile)
print("\nSaved initial output to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheet_names:
    # rename sheets back by position
    if len(wb2.sheetnames) == len(original_sheet_names):
        for i, original_name in enumerate(original_sheet_names):
            wb2.worksheets[i].title = original_name
        wb2.save(outfile)
        print("Renamed sheets back to original names:", original_sheet_names)
    else:
        print("Warning: sheet count changed unexpectedly")

# Verification with formulas cached values
wb_verify = load_workbook(outfile, data_only=True)
print("\nVerified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

used_last_row_after = last_nonempty_row(wsv)
print("Used last row after deletion:", used_last_row_after)

print("\nRows after deletion:")
for r in range(1, used_last_row_after + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    print(r, vals)

# Re-check duplicates in column A after deletion
seen_after = {}
dup_after = []
for r in range(data_start_row, used_last_row_after + 1):
    key = normalize_key(wsv.cell(r, 1).value)
    if key is None:
        continue
    if key in seen_after:
        dup_after.append((r, key, seen_after[key]))
    else:
        seen_after[key] = r

print("\nDuplicate rows remaining based on Column A:", dup_after)
print("Output file ready:", outfile)
