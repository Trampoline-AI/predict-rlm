from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

def sheet_preview(ws, max_cols=12):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Detect headers from row 1
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers[:max_cols], "..." if ws.max_column > max_cols else "")
    
    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols) + 1)]
        print(r, vals)
    
    # print last 5 rows if applicable
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols) + 1)]
            print(r, vals)
    
    # show formulas if any in visible sample area
    formulas = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, min(ws.max_column, max_cols) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Sample formulas in first area:", formulas[:10] if formulas else "None")
    
    # analyze duplicates in column A (excluding completely blank cells)
    colA = []
    for r in range(1, ws.max_row + 1):
        v = ws.cell(r, 1).value
        colA.append(v)
    nonblank = [(i+1, v) for i, v in enumerate(colA) if v not in (None, "")]
    seen = {}
    dups = []
    for r, v in nonblank:
        if v in seen:
            dups.append((r, v, seen[v]))
        else:
            seen[v] = r
    print(f"Nonblank values in col A: {len(nonblank)}; duplicate occurrences after first: {len(dups)}")
    if dups:
        print("First duplicate examples in col A (dup_row, value, first_seen_row):", dups[:10])

for ws in wb.worksheets:
    sheet_preview(ws)
```
