from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def display(v):
    if v is None:
        return None
    return str(v)

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # Find actual non-empty bounds a bit more robustly
    nonempty_rows = []
    nonempty_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for c in row:
            if c.value is not None:
                row_has = True
                nonempty_cols.add(c.column)
        if row_has:
            nonempty_rows.append(row[0].row)
    if nonempty_rows:
        print(f"Non-empty row range: {min(nonempty_rows)} to {max(nonempty_rows)}")
        print(f"Non-empty columns: {[get_column_letter(c) for c in sorted(nonempty_cols)]}")
    else:
        print("No non-empty cells")
        continue
    
    # Print first 10 rows and last 5 rows, limited to used columns
    max_col = max(nonempty_cols) if nonempty_cols else ws.max_column
    def row_values(r):
        vals = []
        for c in range(1, max_col + 1):
            vals.append(ws.cell(r, c).value)
        return vals
    
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("First rows:")
    for r in first_rows:
        print(r, row_values(r))
    print("Last rows:")
    for r in last_rows:
        print(r, row_values(r))
    
    # Print formulas and notable cells in first 20 rows
    print("Formulas in first 30 rows:")
    found_formula = False
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                print(f"  {get_column_letter(c)}{r}: {v}")
                found_formula = True
    if not found_formula:
        print("  (none in first 30 rows)")
    
    # Print all non-empty cells in a compact way if sheet is small
    if ws.max_row <= 20 and max_col <= 10:
        print("All non-empty cells:")
        for r in range(1, ws.max_row + 1):
            for c in range(1, max_col + 1):
                v = ws.cell(r, c).value
                if v is not None:
                    print(f"  {get_column_letter(c)}{r} = {v}")
