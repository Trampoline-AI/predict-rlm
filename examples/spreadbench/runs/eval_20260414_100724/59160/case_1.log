```repl
from openpyxl import load_workbook
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and original sheet names
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine true last data row in source columns A:B
last_row = 1
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_row = r
        break

print("Using source range:", f"A2:A{last_row}", f"B2:B{last_row}")
print("Before writing:")
for coord in ["F3", "G3"]:
    print(coord, "=", ws[coord].value)

# Write formulas only into the blank target cells
# F3 counts rows where date == F1 and value == F2
# G3 counts rows where date == F1 and value == G2
ws["F3"] = f'=COUNTIFS($A$2:$A${last_row},$F$1,$B$2:$B${last_row},F2)'
ws["G3"] = f'=COUNTIFS($A$2:$A${last_row},$F$1,$B$2:$B${last_row},G2)'

print("Written formulas:")
print("F3 =", ws["F3"].value)
print("G3 =", ws["G3"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for i, old_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)
    print("Restored original sheet names:", original_sheetnames)

# Verify formulas exist in formula view
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("Formula verification:")
for coord in ["D3", "E3", "F3", "G3"]:
    print(coord, "formula/raw =", ws_formula[coord].value)

# Verify evaluated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]
print("Evaluated values in target area D1:G3:")
for r in range(1, 4):
    print(r, [ws_values.cell(r, c).value for c in range(4, 8)])

print("Target cell checks:")
for coord in ["F3", "G3"]:
    val = ws_values[coord].value
    print(coord, "=", val, "blank?" , val in (None, ""))

output_spreadsheet = outfile
```
