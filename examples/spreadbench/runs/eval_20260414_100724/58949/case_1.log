```repl
from openpyxl import load_workbook
from collections import OrderedDict, defaultdict
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws_src = wb["Extract"]
ws_tgt = wb["Desired Result"]

print("Original sheet names:", orig_sheet_names)

# Inspect target area before writing
print("\nTarget area BEFORE writing:")
for r in range(1, ws_tgt.max_row + 1):
    print(r, [ws_tgt.cell(r, c).value for c in range(1, ws_tgt.max_column + 1)])

# Read predefined headers from Desired Result row 1
target_headers = [ws_tgt.cell(1, c).value for c in range(2, ws_tgt.max_column + 1)]
print("\nPredefined target headers:", target_headers)

# Read existing target people rows; if blanks exist, we'll fill them later if needed
existing_target_people = []
existing_target_rows = {}
for r in range(2, ws_tgt.max_row + 1):
    person = ws_tgt.cell(r, 1).value
    if person not in (None, ""):
        existing_target_people.append(person)
        existing_target_rows[person] = r

print("Existing target people/rows:", existing_target_rows)

# Build source mapping: Person -> Car -> Value
source_people_order = []
person_car_to_value = {}
duplicates = []

for r in range(2, ws_src.max_row + 1):
    person = ws_src.cell(r, 1).value
    car = ws_src.cell(r, 2).value
    value = ws_src.cell(r, 3).value
    
    if person not in source_people_order:
        source_people_order.append(person)
    key = (person, car)
    if key in person_car_to_value:
        duplicates.append((r, key, person_car_to_value[key], value))
    person_car_to_value[key] = value

print("\nSource people order:", source_people_order)
print("Duplicate person/car pairs found:", duplicates if duplicates else "None")

# Ensure every source person has a target row.
# Prefer existing rows in Desired Result; append new rows only if necessary.
next_row = ws_tgt.max_row + 1
for person in source_people_order:
    if person not in existing_target_rows:
        ws_tgt.cell(next_row, 1).value = person
        existing_target_rows[person] = next_row
        next_row += 1

print("Final target people/rows after ensuring coverage:", existing_target_rows)

# Fill values across predefined headers.
# For missing entries, write "N/A" per instruction.
for person in source_people_order:
    tgt_row = existing_target_rows[person]
    for idx, header in enumerate(target_headers, start=2):
        value = person_car_to_value.get((person, header), "N/A")
        ws_tgt.cell(tgt_row, idx).value = value

# Also handle any pre-existing target people not present in source: fill N/A across headers
for person, tgt_row in existing_target_rows.items():
    if person not in source_people_order:
        for idx, header in enumerate(target_headers, start=2):
            if ws_tgt.cell(tgt_row, idx).value in (None, ""):
                ws_tgt.cell(tgt_row, idx).value = "N/A"

print("\nTarget area AFTER writing, before save:")
for r in range(1, ws_tgt.max_row + 1):
    print(r, [ws_tgt.cell(r, c).value for c in range(1, ws_tgt.max_column + 1)])

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    if len(wb_check.sheetnames) == len(orig_sheet_names):
        for i, original_name in enumerate(orig_sheet_names):
            wb_check.worksheets[i].title = original_name
        wb_check.save(output_path)
        print("Restored sheet names to:", orig_sheet_names)
    else:
        print("Warning: sheet count changed unexpectedly; not renaming automatically.")
else:
    print("Sheet names unchanged after recalc.")

# Verify output with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
ws_verify = wb_verify["Desired Result"]

print("\nVerified target range in Desired Result:")
for r in range(1, ws_verify.max_row + 1):
    print(r, [ws_verify.cell(r, c).value for c in range(1, ws_verify.max_column + 1)])

# Explicit key-cell verification
target_coords = ["A1","B1","I1","A2","B2","C2","D2","A3","D3","F3","A4","C4","D4","E4","G4","A5","D5","H5","I5"]
print("\nKey cell verification:")
for coord in target_coords:
    print(coord, "=>", ws_verify[coord].value)

# Keep output_path available for submission
print("\nReady to submit:", output_path)
