from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, textwrap

print("INPUT FILE:", input_spreadsheet)
print("\nFULL INSTRUCTION:\n")
print(instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("\nORIGINAL SHEET NAMES:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

def nonempty_bounds(ws):
    min_r = None
    max_r = 0
    min_c = None
    max_c = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                r, c = cell.row, cell.column
                if min_r is None or r < min_r:
                    min_r = r
                if min_c is None or c < min_c:
                    min_c = c
                if r > max_r:
                    max_r = r
                if c > max_c:
                    max_c = c
    return min_r, max_r, min_c, max_c

workbook_summary = {}

for s in wb.sheetnames:
    ws = wb[s]
    min_r, max_r_nonempty, min_c, max_c_nonempty = nonempty_bounds(ws)
    info = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "nonempty_bounds": (min_r, max_r_nonempty, min_c, max_c_nonempty),
        "merged_ranges": [str(rng) for rng in ws.merged_cells.ranges],
    }
    workbook_summary[s] = info
    
    print("\n" + "="*80)
    print(f"SHEET: {s}")
    print(f"ws.max_row={ws.max_row}, ws.max_column={ws.max_column}")
    print(f"Non-empty bounds: rows {min_r}-{max_r_nonempty}, cols {min_c}-{max_c_nonempty}")
    if info["merged_ranges"]:
        print("Merged ranges:", info["merged_ranges"][:10], "(showing up to 10)")
    else:
        print("Merged ranges: none")
    
    # show first few rows with coordinates
    sample_cols = max(1, min(ws.max_column, 12))
    print(f"\nFirst 10 rows (first {sample_cols} columns):")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, sample_cols)
        print(f"Row {r}: {vals}")
    
    if ws.max_row > 10:
        print(f"\nLast 5 rows (first {sample_cols} columns):")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            vals = row_values(ws, r, sample_cols)
            print(f"Row {r}: {vals}")
    
    # candidate headers from first few rows
    print("\nHeader candidate scan (rows 1-5):")
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r, min(ws.max_column, 20))
        nonempty = sum(v not in (None, "") for v in vals)
        print(f"Row {r}: nonempty={nonempty}, values={vals}")

print("\nSUMMARY JSON:")
print(json.dumps(workbook_summary, indent=2, default=str))
