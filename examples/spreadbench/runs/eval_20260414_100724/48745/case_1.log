from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, re

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Focused inspection before writing:")
print("Sheet:", ws.title)
print("Target/source rows C5:D10:")
for r in range(5, 11):
    print(r, {"C": ws[f"C{r}"].value, "D": ws[f"D{r}"].value})
print("Lookup table G5:H10:")
for r in range(5, 11):
    print(r, {"G": ws[f"G{r}"].value, "H": ws[f"H{r}"].value})

# Build lookup table from G:H
lookup = {}
for r in range(1, ws.max_row + 1):
    code = ws.cell(r, 7).value  # G
    group = ws.cell(r, 8).value # H
    if code not in (None, "") and group not in (None, ""):
        lookup[str(code).strip()] = str(group).strip()

print("Lookup dict:", lookup)

def group_sort_key(g):
    m = re.search(r'(\d+)', str(g))
    return (int(m.group(1)) if m else 10**9, str(g))

def compute_group_result(cell_value):
    if cell_value in (None, ""):
        return None
    parts = [p.strip() for p in str(cell_value).split(";")]
    codes = [p for p in parts if p]  # ignore blanks from trailing semicolons
    groups = []
    for code in codes:
        grp = lookup.get(code)
        if grp and grp not in groups:
            groups.append(grp)
    groups = sorted(groups, key=group_sort_key)
    if not groups:
        return None
    return ", ".join(groups)

# Compute expected results for all relevant rows
expected = {}
for r in range(5, ws.max_row + 1):
    cval = ws.cell(r, 3).value
    if cval not in (None, ""):
        expected[r] = compute_group_result(cval)

print("Computed expected results:")
for r, v in expected.items():
    print(f"Row {r}: C={ws[f'C{r}'].value!r} -> {v!r}")

# Write only to intended target cells in column D; preserve existing correct values
changes = []
for r, result in expected.items():
    target = ws.cell(r, 4)  # D
    current = target.value
    if current in (None, ""):
        target.value = result
        changes.append((f"D{r}", current, result, "filled blank"))
    else:
        if str(current).strip() != str(result).strip():
            # Since instruction says preserve existing examples, do not overwrite;
            # just report if any mismatch existed.
            changes.append((f"D{r}", current, result, "preserved existing nonblank"))
        else:
            changes.append((f"D{r}", current, result, "already correct"))

print("Write decisions:")
for item in changes:
    print(item)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc and restore if needed
wb_post = load_workbook(outfile)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != orig_sheetnames:
    # rename by position back to original names
    for i, orig_name in enumerate(orig_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = orig_name
    wb_post.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify output values with data_only=True
verify_wb = load_workbook(outfile, data_only=True)
verify_ws = verify_wb[orig_sheetnames[0]]

print("Verification of target cells D5:D10:")
verification = {}
for r in range(5, 11):
    verification[f"D{r}"] = verify_ws[f"D{r}"].value
    print(f"D{r} =", verify_ws[f'D{r}'].value)

# Sanity checks
for cell, val in verification.items():
    row = int(re.search(r'(\d+)', cell).group(1))
    if verify_ws[f"C{row}"].value not in (None, ""):
        assert val not in (None, ""), f"{cell} is blank but should have a value"

print("Final verification passed.")
output_spreadsheet = outfile
