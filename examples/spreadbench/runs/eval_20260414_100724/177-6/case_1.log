Code:
```repl
from openpyxl import load_workbook
from copy import copy
from collections import OrderedDict
import os

# Load source workbook
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
data_ws = wb["DATA"]
combined_ws = wb["combined"]

# Build ordered groups by column H (ComboKey)
groups = OrderedDict()
for r in range(2, data_ws.max_row + 1):
    key = data_ws.cell(r, 8).value
    if key not in (None, "", "\xa0"):
        groups.setdefault(key, []).append(r)

print("Ordered groups to write:", [(k, v) for k, v in groups.items()])

# Keep header row in combined, clear existing data area A:R from row 2 downward
for r in range(2, combined_ws.max_row + 1):
    for c in range(1, 19):
        cell = combined_ws.cell(r, c)
        cell.value = None

# Write consolidated output
out_row = 2
written_rows = []

for key, src_rows in groups.items():
    src_r = src_rows[0]

    # copy row height if present
    if src_r in data_ws.row_dimensions and data_ws.row_dimensions[src_r].height is not None:
        combined_ws.row_dimensions[out_row].height = data_ws.row_dimensions[src_r].height

    # A:H copied from first row in group, preserving style
    for c in range(1, 9):
        src = data_ws.cell(src_r, c)
        dst = combined_ws.cell(out_row, c)
        dst.value = src.value
        dst._style = copy(src._style)
        dst.number_format = src.number_format
        dst.font = copy(src.font)
        dst.fill = copy(src.fill)
        dst.border = copy(src.border)
        dst.alignment = copy(src.alignment)
        dst.protection = copy(src.protection)

    # I:R summed across group, preserving style base from first source row but forcing 0.00
    summed_vals = []
    for c in range(9, 19):
        total = 0.0
        has_num = False
        for rr in src_rows:
            v = data_ws.cell(rr, c).value
            if isinstance(v, (int, float)):
                total += float(v)
                has_num = True
            elif isinstance(v, str):
                sv = v.replace(",", "").strip()
                if sv and sv != "\xa0":
                    try:
                        total += float(sv)
                        has_num = True
                    except:
                        pass

        src = data_ws.cell(src_r, c)
        dst = combined_ws.cell(out_row, c)
        dst._style = copy(src._style)
        dst.font = copy(src.font)
        dst.fill = copy(src.fill)
        dst.border = copy(src.border)
        dst.alignment = copy(src.alignment)
        dst.protection = copy(src.protection)
        dst.number_format = "0.00"  # 2 decimals, no commas

        if (not has_num) or abs(total) < 1e-12:
            dst.value = None
            summed_vals.append(None)
        else:
            # write as numeric
            dst.value = float(total)
            summed_vals.append(float(total))

    written_rows.append((out_row, key, src_rows, summed_vals))
    out_row += 1

# If combined had more old rows than new rows, clear leftovers A:R
for r in range(out_row, combined_ws.max_row + 1):
    for c in range(1, 19):
        combined_ws.cell(r, c).value = None

# Save output
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate as required
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for idx, expected_name in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = expected_name
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheetnames)
else:
    print("Sheet names unchanged or not safely restorable.")

# Verification
verify_wb = load_workbook(output_path, data_only=True)
verify_wb_fmt = load_workbook(output_path, data_only=False)

print("Verified final sheet names:", verify_wb.sheetnames)
vws = verify_wb["combined"]
vws_fmt = verify_wb_fmt["combined"]

print("\nFinal combined rows 1 through", len(written_rows) + 1)
for r in range(1, len(written_rows) + 2):
    vals = [vws.cell(r, c).value for c in range(1, 19)]
    print(f"row {r}: {vals}")

print("\nFinal combined I:R number formats by output row:")
for r in range(2, len(written_rows) + 2):
    fmts = [vws_fmt.cell(r, c).number_format for c in range(9, 19)]
    print(f"row {r}: {fmts}")

print("\nWritten row summary:")
for item in written_rows:
    print(item)

# keep path available for submit
final_output_spreadsheet = output_path
