```repl
import os, zipfile, tempfile, shutil
import xml.etree.ElementTree as ET
from openpyxl import load_workbook

output_path = output_spreadsheet
print("Patching workbook to preserve formulas with cached values:", output_path)

# Desired formulas and cached results
cached_counts = {2: 0, 3: 2, 4: 3, 5: 0, 6: 0, 7: 1, 8: 0}

# First, rewrite formulas with openpyxl
wb = load_workbook(output_path)
ws = wb["Sheet1"]
data_start_row, data_end_row = 2, 8

for r in range(data_start_row, data_end_row + 1):
    formula = (
        f"=(B{r}=MAX(B$2:B$8))"
        f"+(C{r}=MAX(C$2:C$8))"
        f"+(D{r}=MAX(D$2:D$8))"
        f"+(E{r}=MAX(E$2:E$8))"
        f"+(F{r}=MAX(F$2:F$8))"
        f"+(G{r}=MAX(G$2:G$8))"
    )
    ws[f"H{r}"] = formula

wb.save(output_path)
print("Rewrote formulas with openpyxl.")

# Now patch cached values into the sheet XML
tmpdir = tempfile.mkdtemp(prefix="xlsxpatch_")
try:
    with zipfile.ZipFile(output_path, "r") as zin:
        zin.extractall(tmpdir)

    sheet_xml_path = os.path.join(tmpdir, "xl", "worksheets", "sheet1.xml")
    print("Sheet XML path exists:", os.path.exists(sheet_xml_path), sheet_xml_path)

    ns = {"main": "http://schemas.openxmlformats.org/spreadsheetml/2006/main"}
    ET.register_namespace("", ns["main"])
    tree = ET.parse(sheet_xml_path)
    root = tree.getroot()

    sheetData = root.find("main:sheetData", ns)
    assert sheetData is not None

    for r in range(data_start_row, data_end_row + 1):
        cell_ref = f"H{r}"
        target_row = None
        for row_el in sheetData.findall("main:row", ns):
            if row_el.attrib.get("r") == str(r):
                target_row = row_el
                break
        assert target_row is not None, f"Row {r} not found"

        cell_el = None
        for c in target_row.findall("main:c", ns):
            if c.attrib.get("r") == cell_ref:
                cell_el = c
                break
        if cell_el is None:
            cell_el = ET.SubElement(target_row, f"{{{ns['main']}}}c", {"r": cell_ref})

        # Remove string type if present; formula numeric result should be numeric/general
        if "t" in cell_el.attrib:
            del cell_el.attrib["t"]

        # Formula text in XML should NOT include leading "="
        formula_text = (
            f"(B{r}=MAX(B$2:B$8))"
            f"+(C{r}=MAX(C$2:C$8))"
            f"+(D{r}=MAX(D$2:D$8))"
            f"+(E{r}=MAX(E$2:E$8))"
            f"+(F{r}=MAX(F$2:F$8))"
            f"+(G{r}=MAX(G$2:G$8))"
        )

        f_el = cell_el.find("main:f", ns)
        if f_el is None:
            f_el = ET.SubElement(cell_el, f"{{{ns['main']}}}f")
        f_el.text = formula_text

        v_el = cell_el.find("main:v", ns)
        if v_el is None:
            v_el = ET.SubElement(cell_el, f"{{{ns['main']}}}v")
        v_el.text = str(cached_counts[r])

    tree.write(sheet_xml_path, encoding="utf-8", xml_declaration=True)

    # Rebuild xlsx
    patched_path = output_path + ".patched"
    with zipfile.ZipFile(patched_path, "w", zipfile.ZIP_DEFLATED) as zout:
        for folder, _, files in os.walk(tmpdir):
            for file in files:
                full = os.path.join(folder, file)
                arc = os.path.relpath(full, tmpdir)
                zout.write(full, arc)

    shutil.move(patched_path, output_path)
    print("Patched workbook written.")
finally:
    shutil.rmtree(tmpdir, ignore_errors=True)

# Verify both formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("Formula-mode H2:H8:")
for r in range(2, 9):
    cell = ws_formula[f"H{r}"]
    print(r, cell.value, cell.data_type)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("Data-only H2:H8:")
for r in range(2, 9):
    print(r, ws_values[f"A{r}"].value, ws_values[f"H{r}"].value)

# keep variable for submit
output_spreadsheet = output_path
```
