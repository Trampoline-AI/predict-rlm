```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and identify original sheet names
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheetnames:", original_sheetnames)
print("Target header H1:", ws["H1"].value)
print("Pre-write H2:H8:", [ws[f"H{r}"].value for r in range(2, ws.max_row + 1)])

# Determine actual data rows: names in col A
data_start_row = 2
data_end_row = ws.max_row
while data_end_row >= data_start_row and ws.cell(data_end_row, 1).value in (None, ""):
    data_end_row -= 1

print("Data rows:", data_start_row, "to", data_end_row)

# Write formulas into H for all player rows
for r in range(data_start_row, data_end_row + 1):
    formula = (
        f"=(B{r}=MAX(B${data_start_row}:B${data_end_row}))"
        f"+(C{r}=MAX(C${data_start_row}:C${data_end_row}))"
        f"+(D{r}=MAX(D${data_start_row}:D${data_end_row}))"
        f"+(E{r}=MAX(E${data_start_row}:E${data_end_row}))"
        f"+(F{r}=MAX(F${data_start_row}:F${data_end_row}))"
        f"+(G{r}=MAX(G${data_start_row}:G${data_end_row}))"
    )
    ws[f"H{r}"] = formula

print("Written formulas H2:H8:")
for r in range(data_start_row, data_end_row + 1):
    print(f"H{r} -> {ws[f'H{r}'].value}")

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc and restore if changed
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # Rename sheets back by position
    for i, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheetnames)

# Verify evaluated results
wb_verify = load_workbook(output_path, data_only=False)
ws_verify = wb_verify["Sheet1"]
print("Final formulas in H2:H8:")
for r in range(data_start_row, data_end_row + 1):
    print(f"H{r} formula: {ws_verify[f'H{r}'].value}")

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
verified = {}
for r in range(data_start_row, data_end_row + 1):
    verified[f"H{r}"] = ws_values[f"H{r}"].value

print("Verified evaluated H2:H8:", verified)

# Also print names with counts for sanity check
pairs = [(ws_values[f"A{r}"].value, ws_values[f"H{r}"].value) for r in range(data_start_row, data_end_row + 1)]
print("Player win counts:", pairs)

output_spreadsheet = output_path
