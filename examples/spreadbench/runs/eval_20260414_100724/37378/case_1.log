from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load and inspect target area more explicitly
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheetnames:", original_sheetnames)
print("Target sheet:", ws.title)
print("Header A1/B1:", ws["A1"].value, ws["B1"].value)

# Find last meaningful row in column B (the referenced/input column)
last_b_row = 1
for r in range(2, ws.max_row + 1):
    bval = ws.cell(r, 2).value
    if bval is not None and str(bval) != "":
        last_b_row = r

print("ws.max_row:", ws.max_row)
print("Last non-empty row in column B:", last_b_row)

print("\nBefore modification:")
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    print(f"Row {r}: A{r}={a!r}, B{r}={b!r}")

# Write formulas only through the last non-empty row in B
for r in range(2, last_b_row + 1):
    formula = f'=IF(B{r}<>"",COUNTIF($B$2:B{r},"<>"),"")'
    ws.cell(r, 1).value = formula
    print(f"Wrote A{r}: {formula}")

# Leave rows below last_b_row unchanged if they are blank
for r in range(last_b_row + 1, ws.max_row + 1):
    print(f"Leaving row {r} unchanged: A{r}={ws.cell(r,1).value!r}, B{r}={ws.cell(r,2).value!r}")

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_after = load_workbook(output_path)
print("Sheetnames after recalc/reload:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename positionally back to original
    for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Restored sheetnames to:", original_sheetnames)

# Verify formulas and computed values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target cells:")
for r in range(2, last_b_row + 1):
    print(
        f"A{r} formula={ws_formula.cell(r,1).value!r}, "
        f"A{r} value={ws_values.cell(r,1).value!r}, "
        f"B{r} value={ws_values.cell(r,2).value!r}"
    )

print("\nFinal row check including blanks:")
for r in range(2, ws_values.max_row + 1):
    print(f"Row {r}: A{r}={ws_values.cell(r,1).value!r}, B{r}={ws_values.cell(r,2).value!r}")
