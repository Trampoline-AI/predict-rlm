```repl
from openpyxl import load_workbook
import os

# Reload fresh from input
wb = load_workbook(input_spreadsheet)
orig_names = wb.sheetnames[:]
ws1 = wb[orig_names[0]]
ws2 = wb[orig_names[1]]

def true_last_row(ws, cols):
    last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in cols):
            last = r
    return last

sheet1_last = true_last_row(ws1, [1, 2, 3] if ws1.max_column >= 3 else [1, 2])
sheet2_last = true_last_row(ws2, [1, 2])

print("Target rows on Sheet1:", sheet1_last)
print("Lookup rows on Sheet2:", sheet2_last)

# Print target area before rewriting
print("\nBefore rewrite:")
for r in range(1, sheet1_last + 1):
    print(f"Row {r}: A={ws1[f'A{r}'].value!r}, B={ws1[f'B{r}'].value!r}")

lookup_range = f"{ws2.title}!$A$2:$B${sheet2_last}"

# Write formula to ALL relevant data rows under header
written = []
for r in range(2, sheet1_last + 1):
    if ws1[f"A{r}"].value not in (None, ""):
        formula = f'=IF(A{r}="","",IFERROR(VLOOKUP(A{r},{lookup_range},2,FALSE),""))'
        ws1[f"B{r}"] = formula
        written.append((f"B{r}", formula))

print("\nFormulas written:")
for item in written:
    print(item)

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if changed
wb_post = load_workbook(out_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)
if post_names != orig_names:
    for i, nm in enumerate(orig_names):
        wb_post.worksheets[i].title = nm
    wb_post.save(out_path)
    print("Sheet names restored:", orig_names)

# Verify formulas
wb_formula = load_workbook(out_path, data_only=False)
ws1f = wb_formula[orig_names[0]]
print("\nFormula verification Sheet1 B2:B6:")
for r in range(2, sheet1_last + 1):
    print(f"B{r}:", ws1f[f"B{r}"].value)

# Verify computed values
wb_vals = load_workbook(out_path, data_only=True)
ws1v = wb_vals[orig_names[0]]
ws2v = wb_vals[orig_names[1]]

print("\nComputed values Sheet1 A:B:")
for r in range(1, sheet1_last + 1):
    print((r, ws1v[f"A{r}"].value, ws1v[f"B{r}"].value))

# Build expected results from Sheet2 for sanity check
expected = {}
for r in range(2, sheet2_last + 1):
    expected[ws2v[f"A{r}"].value] = ws2v[f"B{r}"].value

print("\nExpected vs actual:")
for r in range(2, sheet1_last + 1):
    prod = ws1v[f"A{r}"].value
    actual = ws1v[f"B{r}"].value
    exp = expected.get(prod, "")
    print(f"Row {r}: {prod!r} -> expected {exp!r}, actual {actual!r}")

output_spreadsheet = out_path
