    max_r = ws.max_row
    max_c = ws.max_column
    if cols_to_check is None:
        cols_to_check = range(1, max_c + 1)
    last = 0
    for r in range(1, max_r + 1):
        vals = [ws.cell(r, c).value for c in cols_to_check]
        if any(v not in (None, "") for v in vals):
            last = r
    return last

sheet1_last = last_nonempty_row(ws1, cols_to_check=[1,2,3] if ws1.max_column >= 3 else [1,2])
sheet2_last = last_nonempty_row(ws2, cols_to_check=[1,2])

