from openpyxl import load_workbook
import os
from collections import Counter

output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))

# Reload saved workbook
wbf = load_workbook(output_path, data_only=False)
wsf = wbf["Sheet1"]
wbv = load_workbook(output_path, data_only=True)
wsv = wbv["Sheet1"]

print("Column positions: R,S,T,U =", 18,19,20,21)
print("Headers row 3 R:U =", [wsv.cell(3, c).value for c in range(18, 22)])

# Show target rows with criteria and computed result
def show_rows(rows):
    for r in rows:
        print(r, {
            "R": wsv[f"R{r}"].value,
            "S": wsv[f"S{r}"].value,
            "T": wsv[f"T{r}"].value,
            "U_formula": wsf[f"U{r}"].value,
            "U_value": wsv[f"U{r}"].value,
        })

print("\nTop target rows:")
show_rows(range(4, 16))

print("\nBottom target rows:")
show_rows(range(64, 76))

# Diagnose target output quality
filled_rows = [r for r in range(4, wsv.max_row + 1)
               if any(wsv.cell(r, c).value not in (None, "") for c in range(18, 21))]
blank_rows = [r for r in filled_rows if wsv.cell(r, 21).value in (None, "")]
zero_rows = [r for r in filled_rows if wsv.cell(r, 21).value == 0]
text_rows = [r for r in filled_rows if isinstance(wsv.cell(r, 21).value, str)]
print("\nFilled target rows:", len(filled_rows))
print("Blank U rows:", blank_rows[:20], "count=", len(blank_rows))
print("Zero U rows:", zero_rows[:20], "count=", len(zero_rows))
print("Text U rows:", text_rows[:20], "count=", len(text_rows))

# Inspect source matrix values, especially rows that were external-reference formulas
print("\nSource matrix sample, data_only values:")
for r in list(range(4, 11)) + list(range(11, 18)) + list(range(30, 41)):
    vals = [wsv.cell(r, c).value for c in range(1, 12)]  # A:K
    print(r, vals)

# Build Python lookup from visible/cached source values
headers = {wsv.cell(3, c).value: c for c in range(3, 12) if wsv.cell(3, c).value not in (None, "")}
lookup = {}
for r in range(4, 76):
    cat = wsv.cell(r, 1).value
    mem = wsv.cell(r, 2).value
    if cat in (None, "") or mem in (None, ""):
        continue
    rowmap = {}
    for hdr, c in headers.items():
        rowmap[hdr] = wsv.cell(r, c).value
    lookup[(cat, mem)] = rowmap

print("\nLookup key count:", len(lookup))
print("Sample lookup keys:", list(lookup.keys())[:10])

# Compare expected Python lookup values to current U values
mismatches = []
missing_from_lookup = []
for r in filled_rows:
    key = (wsv.cell(r, 18).value, wsv.cell(r, 19).value)
    hdr = wsv.cell(r, 20).value
    expected = None
    if key in lookup and hdr in lookup[key]:
        expected = lookup[key][hdr]
    else:
        missing_from_lookup.append((r, key, hdr))
    actual = wsv.cell(r, 21).value
    if expected != actual:
        mismatches.append((r, key, hdr, expected, actual))

print("Rows missing from lookup:", missing_from_lookup[:20], "count=", len(missing_from_lookup))
print("Mismatch count:", len(mismatches))
for item in mismatches[:25]:
    print("Mismatch:", item)
