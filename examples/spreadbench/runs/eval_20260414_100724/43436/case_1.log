```repl
import os, re, calendar
from datetime import datetime
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook for inspection/writing
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Sheetnames:", wb.sheetnames)
print("Dimensions:", ws.max_row, ws.max_column)

# Inspect exact relevant area
print("\nRelevant header/target area G1:K6")
for r in range(1, 7):
    vals = [ws.cell(r, c).value for c in range(7, 12)]
    print(f"Row {r}: {vals}")

print("\nExisting formulas/values in H2:H6 and target I2:K6")
for r in range(2, 7):
    row = {}
    for c in range(8, 12):
        coord = f"{get_column_letter(c)}{r}"
        row[coord] = ws[coord].value
    print(row)

# Detect department rows in column G (rows with labels under Department header)
dept_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 7).value not in (None, ""):
        dept_rows.append(r)
print("\nDepartment rows in col G:", dept_rows)

# Identify actual data extent from columns A:D
data_start = 2
data_end = 1
for r in range(2, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 5)):
        data_end = r
print("Data rows:", data_start, "to", data_end)

# Parse target month headers in I:K
month_map = {m: i for i, m in enumerate(calendar.month_name) if m}
target_cols = []
for c in range(9, ws.max_column + 1):
    header = ws.cell(1, c).value
    if isinstance(header, str) and "Open by" in header:
        m = re.search(r'(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\s+(\d{4})', header)
        if m:
            mon_name = m.group(1)
            year = int(m.group(2))
            # normalize 3-letter month to full via month_abbr
            month_num = None
            for i in range(1, 13):
                if calendar.month_abbr[i] == mon_name:
                    month_num = i
                    break
            if month_num is None:
                continue
            first_day = datetime(year, month_num, 1)
            last_day = datetime(year, month_num, calendar.monthrange(year, month_num)[1])
            target_cols.append((c, header, first_day, last_day))

print("\nParsed target columns:")
for c, header, first_day, last_day in target_cols:
    print(get_column_letter(c), header, first_day.date(), last_day.date())

# Python sanity-check expected counts
records = []
for r in range(data_start, data_end + 1):
    dept = ws.cell(r, 2).value
    created = ws.cell(r, 3).value
    closed = ws.cell(r, 4).value
    if dept not in (None, "") and isinstance(created, datetime):
        records.append({"row": r, "dept": dept, "created": created, "closed": closed})

print("\nPython sanity-check counts:")
for r in dept_rows:
    dept = ws.cell(r, 7).value
    counts = {}
    for c, header, first_day, last_day in target_cols:
        count = 0
        for rec in records:
            if rec["dept"] != dept:
                continue
            created_ok = rec["created"].date() <= last_day.date()
            closed_val = rec["closed"]
            closed_ok = (closed_val is None) or (closed_val.date() >= first_day.date())
            if created_ok and closed_ok:
                count += 1
        counts[get_column_letter(c)] = count
    print(f"Dept {dept}: {counts}")

# Write formulas into target cells only where the header indicates a monthly end-of-month open count
for r in dept_rows:
    dept_cell = f"$G{r}"
    for c, header, first_day, last_day in target_cols:
        coord = f"{get_column_letter(c)}{r}"
        existing = ws[coord].value
        print(f"Writing {coord}; existing value={existing!r}")
        # Formula: created on/before month end AND (closed blank OR closed on/after first day of month)
        formula = (
            f'=COUNTIFS($B${data_start}:$B${data_end},{dept_cell},'
            f'$C${data_start}:$C${data_end},"<="&DATE({last_day.year},{last_day.month},{last_day.day}),'
            f'$D${data_start}:$D${data_end},"")'
            f'+COUNTIFS($B${data_start}:$B${data_end},{dept_cell},'
            f'$C${data_start}:$C${data_end},"<="&DATE({last_day.year},{last_day.month},{last_day.day}),'
            f'$D${data_start}:$D${data_end},">="&DATE({first_day.year},{first_day.month},{first_day.day}))'
        )
        ws[coord] = formula

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Ensure sheet names preserved after recalc
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    # rename sheets by index back to original names
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(outfile)
else:
    print("Sheet names preserved.")

# Verify formulas and computed values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target cells I2:K6")
for r in dept_rows:
    pieces = []
    for c, header, first_day, last_day in target_cols:
        coord = f"{get_column_letter(c)}{r}"
        pieces.append({
            "cell": coord,
            "formula": ws_formula[coord].value,
            "value": ws_values[coord].value
        })
    print(f"Row {r} / Dept {ws_values[f'G{r}'].value}: {pieces}")

# keep path for submit
output_spreadsheet = outfile
print("\nOutput file ready:", output_spreadsheet)
```
