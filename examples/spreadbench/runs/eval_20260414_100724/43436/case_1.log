import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # print first 10 rows and last 5 rows
    sample_top = min(ws.max_row, 10)
    print(f"-- Top {sample_top} rows --")
    for r in range(1, sample_top+1):
        print(f"Row {r}:", row_values(ws, r))
    
    if ws.max_row > 10:
        print(f"-- Bottom {min(5, ws.max_row)} rows --")
        start = max(1, ws.max_row - 4)
        for r in range(start, ws.max_row+1):
            print(f"Row {r}:", row_values(ws, r))
