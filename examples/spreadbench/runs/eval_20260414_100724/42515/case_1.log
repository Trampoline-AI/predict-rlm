from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print(f"\n=== SHEET: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # find non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last nonempty rows:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # print first 10 non-empty rows and last 5 non-empty rows
    sample_rows = nonempty_rows[:10]
    tail_rows = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
    seen = set()
    print("-- First non-empty rows --")
    for r in sample_rows:
        seen.add(r)
        vals = row_values(ws, r, min(ws.max_column, 12))
        print(r, vals)
    print("-- Last non-empty rows --")
    for r in tail_rows:
        if r in seen:
            continue
        vals = row_values(ws, r, min(ws.max_column, 12))
        print(r, vals)

    # detect likely header rows among first 10 non-empty rows
    print("-- Candidate headers among first 10 non-empty rows --")
    for r in sample_rows[:10]:
        vals = row_values(ws, r, ws.max_column)
        nonempty = [(get_column_letter(i+1), v) for i, v in enumerate(vals) if v not in (None, "")]
        if nonempty:
            print("Row", r, nonempty[:15])

    # search for TABLE 2 text or formula mentions
    matches = []
    formula_matches = []
    ref_matches = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                text = v
                if "TABLE 2" in text.upper() or "FOREIGN" in text.upper() or "EXCHANGE" in text.upper():
                    matches.append((cell.coordinate, text))
                if text.startswith("="):
                    if "$B$8" in text or "B5" in text or "SUM(1/((1/B5)*" in text.replace(" ", ""):
                        formula_matches.append((cell.coordinate, text))
                else:
                    if "$B$8" in text or "B5" in text:
                        ref_matches.append((cell.coordinate, text))
    print("-- Text matches (TABLE 2 / FOREIGN / EXCHANGE) --", matches[:20])
    print("-- Formula matches relevant --", formula_matches[:20])
    print("-- Other ref-like matches --", ref_matches[:20])
