from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Confirm target range before writing
print("Before writing, existing F5:F19 formulas:")
for r in range(5, 20):
    print(r, ws[f"F{r}"].value)

# Write dynamic formulas into the exact existing target cells F5:F19
# Logic: divide row's GBP cross-rate by the GBP-EUR midrate for the same date
for r in range(5, 20):
    ws[f"F{r}"] = f'=B{r}/SUMIFS($B$5:$B$19,$A$5:$A$19,"GBP-EUR",$C$5:$C$19,C{r})'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Reload after recalc, restore sheet names if LibreOffice changed them
wb_after = load_workbook(outfile)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", original_sheetnames)
    # Rename by position
    for i, expected in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("\nVerified formulas in F5:F19:")
