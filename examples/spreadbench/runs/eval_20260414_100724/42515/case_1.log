```repl
import os, zipfile, shutil, tempfile
import xml.etree.ElementTree as ET
from openpyxl import load_workbook

outfile = output_spreadsheet
print("Patching workbook to restore formulas while preserving cached values:", outfile)

# Compute cached values from the sheet data
wb_vals_src = load_workbook(outfile, data_only=True)
ws_vals_src = wb_vals_src["Sheet1"]

rate_by_date = {}
for r in range(5, 20):
    if ws_vals_src[f"A{r}"].value == "GBP-EUR":
        rate_by_date[ws_vals_src[f"C{r}"].value] = ws_vals_src[f"B{r}"].value

cached_E = {}
cached_F = {}
for r in range(5, 20):
    pair = ws_vals_src[f"A{r}"].value
    dt = ws_vals_src[f"C{r}"].value
    b = ws_vals_src[f"B{r}"].value
    cached_E[r] = f"EUR-{str(pair)[-3:]}" if pair else None
    denom = rate_by_date.get(dt)
    cached_F[r] = (b / denom) if (b is not None and denom not in (None, 0)) else None

print("Sample cached values:")
for r in range(5, 10):
    print(r, cached_E[r], cached_F[r])

# Patch xl/worksheets/sheet1.xml
NS = "http://schemas.openxmlformats.org/spreadsheetml/2006/main"
ET.register_namespace("", NS)

def q(tag):
    return f"{{{NS}}}{tag}"

with tempfile.TemporaryDirectory() as td:
    tmp_xlsx = os.path.join(td, "patched.xlsx")
    with zipfile.ZipFile(outfile, "r") as zin, zipfile.ZipFile(tmp_xlsx, "w", zipfile.ZIP_DEFLATED) as zout:
        for item in zin.infolist():
            data = zin.read(item.filename)
            if item.filename == "xl/worksheets/sheet1.xml":
                root = ET.fromstring(data)

                # Map cells by coordinate
                cells = {}
                for c in root.iter(q("c")):
                    ref = c.attrib.get("r")
                    if ref:
                        cells[ref] = c

                for r in range(5, 20):
                    # Restore E formula
                    ecoord = f"E{r}"
                    ecell = cells[ecoord]
                    for child in list(ecell):
                        ecell.remove(child)
                    ecell.set("t", "str")
                    ef = ET.SubElement(ecell, q("f"))
                    ef.text = f'"EUR"&"-"&RIGHT($A{r},3)'
                    ev = ET.SubElement(ecell, q("v"))
                    ev.text = cached_E[r]

                    # Restore F formula
                    fcoord = f"F{r}"
                    fcell = cells[fcoord]
                    for child in list(fcell):
                        fcell.remove(child)
                    if "t" in fcell.attrib:
                        del fcell.attrib["t"]
                    ff = ET.SubElement(fcell, q("f"))
                    ff.text = f'B{r}/SUMIFS($B$5:$B$19,$A$5:$A$19,"GBP-EUR",$C$5:$C$19,C{r})'
                    fv = ET.SubElement(fcell, q("v"))
                    fv.text = str(cached_F[r])

                data = ET.tostring(root, encoding="utf-8", xml_declaration=True)

            zout.writestr(item, data)

    shutil.copy2(tmp_xlsx, outfile)

# Verify formulas preserved
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("\nVerification data_only=False (should show formulas):")
for r in range(5, 10):
    print(r, "E", ws_formula[f"E{r}"].value, "| F", ws_formula[f"F{r}"].value)

wb_data = load_workbook(outfile, data_only=True)
ws_data = wb_data["Sheet1"]
print("\nVerification data_only=True (should show cached values):")
for r in range(5, 10):
    print(r, "E", ws_data[f"E{r}"].value, "| F", ws_data[f"F{r}"].value)

# Full target-range validation
formula_missing = [f"F{r}" for r in range(5, 20) if not (isinstance(ws_formula[f'F{r}'].value, str) and ws_formula[f'F{r}'].value.startswith("="))]
value_blank = [f"F{r}" for r in range(5, 20) if ws_data[f"F{r}"].value in (None, "")]
print("\nFormula-missing F cells:", formula_missing)
print("Blank cached-value F cells:", value_blank)

# Also verify E formulas restored
e_formula_missing = [f"E{r}" for r in range(5, 20) if not (isinstance(ws_formula[f'E{r}'].value, str) and ws_formula[f'E{r}'].value.startswith("="))]
e_value_blank = [f"E{r}" for r in range(5, 20) if ws_data[f"E{r}"].value in (None, "")]
print("Formula-missing E cells:", e_formula_missing)
print("Blank cached-value E cells:", e_value_blank)

output_spreadsheet = outfile
print("\nReady to submit:", output_spreadsheet)
