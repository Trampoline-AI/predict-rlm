import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload from original input so I don't preserve the broken formulas
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Before fixing, current target area from original input:")
for r in range(11, 16):
    print(
        r,
        "T=", ws[f"T{r}"].value,
        "U=", ws[f"U{r}"].value,
        "items=", {col: ws[f"{col}{r}"].value for col in "EFGHIJK"}
    )

# Write explicit LibreOffice-friendly formulas
for r in range(11, 16):
    formula = (
        f"=E{r}*$Y$13+F{r}*$Y$14+G{r}*$Y$15+H{r}*$Y$16+"
        f"I{r}*$Y$17+J{r}*$Y$18+K{r}*$Y$19"
    )
    ws[f"T{r}"] = formula

print("\nWritten formulas:")
for r in range(11, 16):
    print(f"T{r} -> {ws[f'T{r}'].value}")

wb.save(output_path)
print("\nSaved fixed workbook to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalc changed them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for i, expected in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = expected
    wb_post.save(output_path)
    print("Restored sheet names:", original_sheetnames)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula[original_sheetnames[0]]
print("\nFormula verification:")
for r in range(11, 16):
    print(f"T{r} formula:", wsf[f"T{r}"].value)

# Verify calculated values
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values[original_sheetnames[0]]

print("\nCalculated values verification:")
for r in range(11, 16):
    print(
        f"Row {r}: T{r}={wsv[f'T{r}'].value!r}, "
        f"U{r}={wsv[f'U{r}'].value!r}, "
        f"inputs={[(c, wsv[f'{c}{r}'].value) for c in 'EFGHIJK']}"
    )

# Check against expected values from current sheet data
expected = {
    11: 16,  # J11=1, Item 6 price 16
    12: 20,  # F12=1 (8) + I12=1 (12)
    13: 8,   # F13=1 (8)
    14: 12,  # I14=1 (12)
    15: 32,  # F15=4 (8 each)
}
print("\nExpected vs actual:")
all_ok = True
for r, exp in expected.items():
    actual = wsv[f"T{r}"].value
    ok = actual == exp
    all_ok = all_ok and ok
    print(f"T{r}: actual={actual!r}, expected={exp}, ok={ok}")

output_spreadsheet = output_path
print("\noutput_spreadsheet prepared:", output_spreadsheet)
print("All target T cells correct?", all_ok)
