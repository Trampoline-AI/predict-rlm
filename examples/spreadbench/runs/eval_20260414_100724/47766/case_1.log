from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.utils.datetime import from_excel
from collections import defaultdict
from datetime import datetime
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load formula workbook for editing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Writing to:", output_path)

# Verify current target formulas/values before overwrite
print("\nCurrent target formulas before overwrite:")
for r in [40, 41, 42, 45, 46, 47, 50, 51, 52]:
    print(r, [ws.cell(r, c).value for c in range(10, 16)])  # J:O

blocks = {
    "Rentals": (8, 37),
    "Sales": (41, 58),
    "Commercial": (62, 74),
}

sections = [
    {"token": "PE", "header_row": 43, "row_map": {"Rentals": 40, "Sales": 41, "Commercial": 42}},
    {"token": "GS", "header_row": 48, "row_map": {"Rentals": 45, "Sales": 46, "Commercial": 47}},
    {"token": "CC", "header_row": 53, "row_map": {"Rentals": 50, "Sales": 51, "Commercial": 52}},
]

# Write formulas into K:O for each summary row
for section in sections:
    token = section["token"]
    header_row = section["header_row"]
    for label, target_row in section["row_map"].items():
        start, end = blocks[label]
        for col in range(11, 16):  # K:O
            col_letter = get_column_letter(col)
            formula = (
                f'=SUMIFS($C${start}:$C${end},'
                f'$H${start}:$H${end},"*{token}*",'
                f'$F${start}:$F${end},">="&{col_letter}${header_row},'
                f'$F${start}:$F${end},"<"&DATE(YEAR({col_letter}${header_row})+1,1,1))'
            )
            ws.cell(target_row, col).value = formula

# Save edited workbook
wb.save(output_path)
print("\nSaved edited workbook.")

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalc/localization changed them
