post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != orig_sheet_names and len(post_names) == len(orig_sheet_names):
    for i, desired in enumerate(orig_sheet_names):
        wb_post.worksheets[i].title = desired
    wb_post.save(output_path)
    print("Renamed sheets back to original names:", orig_sheet_names)
else:
    print("No sheet rename needed.")

# Reload for formula inspection and cached value verification
wb_formula = load_workbook(output_path)
wsf = wb_formula[orig_sheet_names[0]]

wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals[orig_sheet_names[0]]

def to_dt(val):
    if isinstance(val, datetime):
        return val
    if isinstance(val, (int, float)):
        try:
            return from_excel(val)
        except Exception:
            return None
    return None

# Print formulas written to target cells
print("\nWritten formulas in target area:")
for r in [40, 41, 42, 45, 46, 47, 50, 51, 52]:
    row_repr = []
    for c in range(11, 16):  # K:O
        addr = f"{get_column_letter(c)}{r}"
        row_repr.append((addr, wsf[addr].value))
    print(row_repr)

# Compute expected totals from source data
years = [2021, 2022, 2023, 2024, 2025]
expected = {sec["token"]: {label: {y: 0.0 for y in years} for label in blocks} for sec in sections}

for label, (start, end) in blocks.items():
    for r in range(start, end + 1):
        h = wsv[f"H{r}"].value
        cval = wsv[f"C{r}"].value
        dt = to_dt(wsv[f"F{r}"].value)
        if not isinstance(h, str) or not isinstance(cval, (int, float)) or dt is None:
            continue
        for sec in sections:
            token = sec["token"]
            if token in h and dt.year in expected[token][label]:
                expected[token][label][dt.year] += float(cval)

# Read actual target values after recalc and compare
actual = {}
mismatches = []

for sec in sections:
    token = sec["token"]
    header_row = sec["header_row"]
    actual[token] = {}
    header_years = {}
    for c in range(11, 16):
        header_val = wsv.cell(header_row, c).value
        dt = to_dt(header_val)
        header_years[c] = dt.year if dt else None
    for label, target_row in sec["row_map"].items():
