import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # Find non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    # Print first 10 rows with coordinates
    top_n = min(10, ws.max_row)
    print("\nTop rows:")
    for r in range(1, top_n + 1):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                vals.append(f"{get_column_letter(c)}{r}={v!r}")
        print("Row", r, vals[:20], ("..." if len(vals) > 20 else ""))
    # Print last 5 rows
    start = max(1, ws.max_row - 4)
    print("\nBottom rows:")
    for r in range(start, ws.max_row + 1):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                vals.append(f"{get_column_letter(c)}{r}={v!r}")
        print("Row", r, vals[:20], ("..." if len(vals) > 20 else ""))
    # Header guess rows 1-3
    for hr in range(1, min(3, ws.max_row) + 1):
        headers = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        print(f"Possible header row {hr}:", headers)

for ws in wb.worksheets:
    sheet_summary(ws)
