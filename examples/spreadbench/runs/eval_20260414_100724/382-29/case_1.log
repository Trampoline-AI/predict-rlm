# Detailed Totals sheet inspection
ws = wb["Totals"]
print("\nTotals dimensions:", ws.max_row, ws.max_column)

# print rows 1:30, columns A:H and also Y:AB if present
def vals(row, start, end):
    return [ws.cell(row, c).value for c in range(start, end + 1)]

print("\nTotals rows 1:30, cols A:H")
for r in range(1, min(ws.max_row, 30) + 1):
    print(f"Row {r}: {vals(r,1,min(8, ws.max_column))}")

if ws.max_column >= 28:
    print("\nTotals rows 1:30, cols Y:AB")
    for r in range(1, min(ws.max_row, 30) + 1):
        print(f"Row {r}: {vals(r,25,min(28, ws.max_column))}")

# Explicitly inspect target-ish cells and formulas
