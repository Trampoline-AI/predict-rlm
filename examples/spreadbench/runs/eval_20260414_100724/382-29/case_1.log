import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and inspect exact mapping one more time
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
totals_ws = wb["Totals"]
data_sheets = [s for s in wb.sheetnames if s != "Totals"]

print("Original sheet names:", original_sheet_names)
print("Data sheets:", data_sheets)
print("Target range on Totals: B2:B26")

# Verify row/code mapping between Totals and employee sheets
mapping = []
for totals_row in range(2, 27):
    src_row = totals_row + 3
    total_code = totals_ws[f"A{totals_row}"].value
    src_codes = {s: wb[s][f"A{src_row}"].value for s in data_sheets}
    existing_formula = totals_ws[f"B{totals_row}"].value
    mapping.append((totals_row, src_row, total_code, src_codes, existing_formula))

print("\nRow/code mapping check:")
for item in mapping[:5] + mapping[-5:]:
    totals_row, src_row, total_code, src_codes, existing_formula = item
    print(
        f"Totals row {totals_row} code={total_code!r} -> source row {src_row}, "
        f"source codes={src_codes}, existing Totals!B{totals_row}={existing_formula!r}"
    )

# Fill formulas into Totals!B2:B26
written_formulas = {}
for totals_row in range(2, 27):
    src_row = totals_row + 3
    refs = [f"'{sheet}'!AB{src_row}" for sheet in data_sheets]
    formula = "=" + "+".join(refs)  # match existing example pattern closely
    totals_ws[f"B{totals_row}"] = formula
    written_formulas[f"B{totals_row}"] = formula

print("\nWritten formulas (sample):")
for k in list(written_formulas.keys())[:5] + list(written_formulas.keys())[-5:]:
    print(k, "->", written_formulas[k])

# Save output
wb.save(output_path)
print("\nSaved workbook to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open after recalc and restore original sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheet_names:
    print("Sheet names changed; restoring original names...")
    if len(wb_after.sheetnames) == len(original_sheet_names):
        for ws_obj, orig_name in zip(wb_after.worksheets, original_sheet_names):
            ws_obj.title = orig_name
        wb_after.save(output_path)
        print("Restored sheet names and re-saved.")
    else:
        print("WARNING: Sheet count changed unexpectedly; cannot safely restore by position.")

# Verify formulas in normal mode
wb_verify_formula = load_workbook(output_path, data_only=False)
totals_formula_ws = wb_verify_formula["Totals"]
print("\nFinal formulas in Totals!B2:B26:")
for r in range(2, 27):
    print(f"A{r}={totals_formula_ws[f'A{r}'].value!r}, B{r} formula={totals_formula_ws[f'B{r}'].value!r}")

# Verify computed values in data_only mode
wb_verify_values = load_workbook(output_path, data_only=True)
totals_value_ws = wb_verify_values["Totals"]

print("\nComputed values in Totals!B2:B26 after recalculation:")
verified_values = {}
blank_targets = []
for r in range(2, 27):
    code = totals_value_ws[f"A{r}"].value
    val = totals_value_ws[f"B{r}"].value
    verified_values[f"B{r}"] = val
    print(f"A{r}={code!r}, B{r}={val!r}")
    if val in (None, ""):
        blank_targets.append(f"B{r}")

# Also print source computed values from employee sheets for a few rows to sanity-check totals
print("\nSanity-check source computed AB values (first 5 and last 5 rows):")
for sheet in data_sheets:
    ws_vals = wb_verify_values[sheet]
    print(f"\n{sheet}")
    for src_row in list(range(5, 10)) + list(range(25, 30)):
        print(
            f"A{src_row}={ws_vals[f'A{src_row}'].value!r}, "
            f"AB{src_row}={ws_vals[f'AB{src_row}'].value!r}"
        )

print("\nBlank target cells after recalculation:", blank_targets)
final_output_path = output_path
