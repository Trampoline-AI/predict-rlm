Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Re-open clean workbook for editing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Using sheet:", ws.title)
print("Column E current values around source table:")
for r in range(3, 14):
    print(f"E{r} =", ws[f"E{r}"].value)

# Identify matching source rows explicitly
lighting_rows = []
for r in range(4, 23):
    item = ws.cell(r, 2).value
    kw = ws.cell(r, 3).value
    num = ws.cell(r, 4).value
    if item == "Lighting":
        lighting_rows.append((r, item, kw, num))
print("Lighting source rows found:", lighting_rows)

print("Current target cells before writing:")
for r in range(3, 7):
    vals = [ws.cell(r, c).value for c in range(6, 9)]
    print(f"F{r}:H{r} ->", vals)

# Helper formulas in column E: number only the lighting rows
for r in range(4, 23):
    ws[f"E{r}"] = f'=IF(B{r}="Lighting",COUNTIF($B$4:B{r},"Lighting"),"")'

# Output formulas in F4:H6
for r in range(4, 7):
    n_expr = str(r - 3)  # 1,2,3
    ws[f"F{r}"] = f'=IFERROR(INDEX($B$4:$B$22,MATCH({n_expr},$E$4:$E$22,0)),"")'
    ws[f"G{r}"] = f'=IFERROR(INDEX($C$4:$C$22,MATCH({n_expr},$E$4:$E$22,0)),"")'
    ws[f"H{r}"] = f'=IFERROR(INDEX($D$4:$D$22,MATCH({n_expr},$E$4:$E$22,0)),"")'

# Keep headers as-is, but print formulas written
print("\nFormulas written:")
for r in range(4, 7):
    print(f"E{r}:", ws[f"E{r}"].value)
    print(f"F{r}:", ws[f"F{r}"].value)
    print(f"G{r}:", ws[f"G{r}"].value)
    print(f"H{r}:", ws[f"H{r}"].value)

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename sheets positionally back to original names
    for i, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

print("\nVerified target range F3:H6 (data_only):")
for r in range(3, 7):
    vals = [wsv.cell(r, c).value for c in range(6, 9)]
    print(f"r{r}:", vals)

print("\nVerified helper E4:E12 (data_only):")
for r in range(4, 13):
    print(f"E{r} =", wsv[f"E{r}"].value)

# Also inspect formulas in non-data_only workbook
wb_formula_check = load_workbook(output_path, data_only=False)
wsf = wb_formula_check[orig_sheet_names[0]]
print("\nFormula strings in F4:H6:")
for r in range(4, 7):
    print(f"r{r}:", [wsf.cell(r, c).value for c in range(6, 9)])

final_output_path = output_path
