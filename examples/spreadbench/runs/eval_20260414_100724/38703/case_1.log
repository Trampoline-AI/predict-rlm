from openpyxl import load_workbook
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

# Helper
def unique_nonblank_count(values):
    cleaned = []
    for v in values:
        if v is None:
            continue
        if isinstance(v, str):
            v = v.strip()
            if v == "":
                continue
        cleaned.append(v)
    return len(set(cleaned))

# Compute counts from actual data
count_1 = unique_nonblank_count(ws.cell(r, 5).value for r in range(2, 11))   # E2:E10
count_2 = unique_nonblank_count(ws.cell(r, 5).value for r in range(11, 21))  # E11:E20
count_3 = unique_nonblank_count(ws.cell(r, 5).value for r in range(21, 25))  # E21:E24

print("Computed counts:", {"H10": count_1, "H20": count_2, "H24": count_3})

# Unmerge all merged cells first
merged_ranges = [str(rng) for rng in ws.merged_cells.ranges]
print("Merged ranges before unmerge:", merged_ranges)
for rng in merged_ranges:
    ws.unmerge_cells(rng)

# Write outputs to exact target cells
ws["H10"] = count_1
ws["H20"] = count_2
ws["H24"] = count_3

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheet_names:
    # Rename sheets back by position
    for i, expected in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = expected
    wb_check.save(output_path)
    print("Renamed sheets back to original:", original_sheet_names)

# Verification load
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

# Also inspect merged ranges after save
wb_verify_formula = load_workbook(output_path)
wsv_formula = wb_verify_formula[original_sheet_names[0]]
print("Remaining merged ranges after save:", [str(r) for r in wsv_formula.merged_cells.ranges])

verification = {
    "H10": wsv["H10"].value,
    "H20": wsv["H20"].value,
    "H24": wsv["H24"].value,
}
print("Verification target values:", verification)

# Print nearby rows/cols around targets to confirm exact placement
for r in [10, 20, 24]:
    vals = [wsv.cell(r, c).value for c in range(7, 10)]  # G:I
    print(f"Row {r} G:I -> {vals}")

final_output_path = output_path
