```repl
import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Fresh copy from input
shutil.copy2(input_path, output_path)

# Re-inspect exact reprs for the relevant example rows
wb = load_workbook(output_path)
print("Original sheet names:", wb.sheetnames)

for sheet_name in ["Before", "After"]:
    ws = wb[sheet_name]
    print(f"\nExact repr inspection for sheet: {sheet_name}")
    if sheet_name == "Before":
        rows = range(1, min(ws.max_row, 10) + 1)
    else:
        rows = range(1, min(ws.max_row, 10) + 1)
    for r in rows:
        a = ws.cell(r, 1).value
        b = ws.cell(r, 2).value
        print(f"Row {r}: A={a!r}, B={b!r}")

# Determine target sheet(s): source-like sheets where col A has data rows and col B is blank for those rows
target_sheets = []
for ws in wb.worksheets:
    nonempty_a_blank_b = 0
    for r in range(2, ws.max_row + 1):
        a = ws.cell(r, 1).value
        b = ws.cell(r, 2).value if ws.max_column >= 2 else None
        if a not in (None, "") and b in (None, ""):
            nonempty_a_blank_b += 1
    print(f"Sheet {ws.title}: rows with A non-empty and B blank below header = {nonempty_a_blank_b}")
    if nonempty_a_blank_b > 0:
        target_sheets.append(ws.title)

print("Chosen target sheets:", target_sheets)

letter_pat = re.compile(r"[A-Za-z]")

def split_from_first_letter(val):
    """Return (new_a, new_b) by splitting string at first alphabetic character.
    new_a keeps everything before the first letter; new_b gets everything from first letter onward.
    If no letter is found, return original and None.
    """
    if not isinstance(val, str):
        return val, None
    m = letter_pat.search(val)
    if not m:
        return val, None
    idx = m.start()
    return val[:idx], val[idx:]

# Apply transformation only to true source sheets, preserving row 1 header
modifications = []
for sheet_name in target_sheets:
    ws = wb[sheet_name]
    # true last used row based on any non-empty cell in sheet
    true_last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            true_last = r
    print(f"\nApplying transformation on sheet {sheet_name}, true_last={true_last}")

    for r in range(2, true_last + 1):
        a_cell = ws.cell(r, 1)
        b_cell = ws.cell(r, 2)
        a = a_cell.value
        b = b_cell.value

        # do not overwrite rows already populated in B or fully blank rows
        if a in (None, ""):
            continue
        if b not in (None, ""):
            continue

        new_a, new_b = split_from_first_letter(a)
        # Only write if a split actually happened
        if new_b is not None:
            modifications.append((sheet_name, r, a, new_a, new_b))
            a_cell.value = new_a
            b_cell.value = new_b

print(f"\nTotal modifications: {len(modifications)}")
for item in modifications[:20]:
    sheet_name, r, old_a, new_a, new_b = item
    print(f"{sheet_name} row {r}:")
    print(f"  old A: {old_a!r}")
    print(f"  new A: {new_a!r}")
    print(f"  new B: {new_b!r}")

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate as required
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames:
    print("Sheet names changed; restoring original names")
    for ws_obj, original_name in zip(wb_after.worksheets, wb.sheetnames):
        ws_obj.title = original_name
    wb_after.save(output_path)
    print("Restored sheet names to:", wb.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("\nVerification sheet names:", wb_verify.sheetnames)

# Verify target cells in Before
if "Before" in wb_verify.sheetnames:
    ws_v = wb_verify["Before"]
    print("\nVerified Before!A1:B10")
    for r in range(1, min(10, ws_v.max_row) + 1):
        print(f"Row {r}: A={ws_v.cell(r,1).value!r}, B={ws_v.cell(r,2).value!r}")

# Also confirm After still exists and inspect it
if "After" in wb_verify.sheetnames:
    ws_a = wb_verify["After"]
    print("\nVerified After!A1:B10 (should remain as example/reference)")
    for r in range(1, min(10, ws_a.max_row) + 1):
        print(f"Row {r}: A={ws_a.cell(r,1).value!r}, B={ws_a.cell(r,2).value!r}")

# Keep path for submission
final_output_path = output_path
print("\nfinal_output_path =", final_output_path)
```
