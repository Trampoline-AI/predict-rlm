# Determine headers from source and exact formula ranges
source_key_range = f"Sheet1!$D$2:$D${sheet1_last}"
source_b_range = f"Sheet1!$B$2:$B${sheet1_last}"
source_c_range = f"Sheet1!$C$2:$C${sheet1_last}"

print("\nFormula ranges:")
print("Lookup key range:", source_key_range)
print("Return B range:", source_b_range)
print("Return C range:", source_c_range)

# Preserve existing B1, fill C1 if blank
