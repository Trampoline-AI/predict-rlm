import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)

print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    print(f"merged_ranges={list(ws.merged_cells.ranges)}")
    
    # headers from first few rows to help identify real header row
    for r in range(1, min(ws.max_row, 3) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r} values:", vals)
    
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Header candidates row1:", headers)
    
    # First 10 rows
    first_n = min(ws.max_row, 10)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"R{r}: {vals}")
    
    # Last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"R{r}: {vals}")
    
    # collect formulas
    formulas = []
    nonempty = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                nonempty.append((r, c, v))
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    
    print(f"\nNon-empty cell count: {len(nonempty)}")
    print(f"Formula cell count: {len(formulas)}")
    if formulas:
        print("Formula cells:")
        for r, c, v in formulas[:20]:
            print(f"  {get_column_letter(c)}{r}: {v}")
    
    if len(nonempty) <= 200:
        print("\nAll non-empty cells:")
        for r, c, v in nonempty:
            print(f"  {get_column_letter(c)}{r}: {v}")

for ws in wb.worksheets:
    sheet_summary(ws)
