import os
from collections import defaultdict
from openpyxl import load_workbook

# Re-open fresh workbook for modification
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Using sheet:", ws.title)
print("Sheet size:", ws.max_row, "rows x", ws.max_column, "cols")

# Inspect exact relevant area and any existing formulas/values
for cell_ref in ["A1", "B1", "A2", "B2", "D1", "E1", "F1", "G1", "D2", "E2", "F2", "G2", "D3", "E3", "F3", "G3"]:
    print(cell_ref, "=", ws[cell_ref].value)

# Determine actual data extent for rows with source data in A/B
data_rows = []
for r in range(2, ws.max_row + 1):
    product = ws.cell(r, 1).value
    qty = ws.cell(r, 2).value
    if product is not None and qty is not None:
        data_rows.append(r)

print("Data rows detected:", data_rows)
first_data_row = min(data_rows)
last_data_row = max(data_rows)
print("Data range:", first_data_row, "to", last_data_row)

# Python sanity-check aggregation by first letter
py_sums = defaultdict(float)
for r in data_rows:
    product = str(ws.cell(r, 1).value).strip()
    qty = ws.cell(r, 2).value
    first_letter = product[0] if product else ""
    if isinstance(qty, (int, float)) and first_letter:
        py_sums[first_letter] += qty

print("Python-computed sums by first letter:", dict(py_sums))

# Confirm target headers in D2:G2
target_cols = range(4, 8)  # D:G
headers = [ws.cell(2, c).value for c in target_cols]
print("Target headers D2:G2:", headers)

# Write formulas into D3:G3 based on header letters in row 2
# Use bounded ranges for LibreOffice compatibility.
for c in target_cols:
    header_cell = ws.cell(2, c).coordinate
    target_cell = ws.cell(3, c)
    formula = f'=SUMPRODUCT((LEFT($A${first_data_row}:$A${last_data_row},1)={header_cell})*($B${first_data_row}:$B${last_data_row}))'
    print(f"Writing {target_cell.coordinate}: {formula}")
    target_cell.value = formula

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# After recalc, sheet names may change; restore if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for i, original_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify formulas and cached results
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("Verification area D2:G3 (formulas workbook):")
for r in [2, 3]:
    print("Row", r, [ws_formula.cell(r, c).value for c in range(4, 8)])

print("Verification area D2:G3 (data_only workbook):")
verified_values = {}
for c in target_cols:
    key = ws_values.cell(2, c).value
    val = ws_values.cell(3, c).value
    verified_values[key] = val
    print(f"{ws_values.cell(2, c).coordinate}={key}, {ws_values.cell(3, c).coordinate}={val}")

print("Expected Python sums for target headers:", {h: py_sums.get(str(h), 0) for h in headers})

# Store for submit
final_output_path = output_path
