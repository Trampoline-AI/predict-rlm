```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for modification
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
ws = wb[orig_sheet_names[0]]

print("Sheet names:", wb.sheetnames)
print("Target sheet:", ws.title)
print("Max row / col:", ws.max_row, ws.max_column)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Inspect the exact target area and confirm pattern
print("\nDetailed rows 14-30 before writing:")
for r in range(14, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    print(f"Row {r}: A={a!r}, B={b!r}")

# Infer expected fill-down values from column A and compare with existing example in B
expected_by_row = {}
last_seen = None
mismatches = []
for r in range(2, ws.max_row + 1):  # skip header
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a not in (None, ""):
        last_seen = a
        expected = a
    else:
        expected = last_seen
    expected_by_row[r] = expected
    if b not in (None, "") and b != expected:
        mismatches.append((r, a, b, expected))

print("\nExisting B mismatches against inferred pattern:", mismatches)

# Record which B cells are blank before writing
original_blank_targets = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 2).value in (None, "") and expected_by_row[r] not in (None, ""):
        original_blank_targets.append((r, expected_by_row[r]))
print("Blank B targets to fill:", original_blank_targets)

# Fill only blank cells in column B, preserving existing example values
filled = []
for r, expected in original_blank_targets:
    ws.cell(r, 2).value = expected
    filled.append((r, expected))

print("\nFilled cells in column B:")
for item in filled:
    print(item)

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # Rename sheets back by position
    for idx, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(output_path)
    print("Restored original sheet names:", wb_after.sheetnames)

# Verify output values with data_only=True
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb[orig_sheet_names[0]]

print("\nVerification rows 1-30 (A and B):")
for r in range(1, verify_ws.max_row + 1):
    a = verify_ws.cell(r, 1).value
    b = verify_ws.cell(r, 2).value
    print(f"Row {r}: A={a!r}, B={b!r}")

# Specific verification for previously blank target cells
verification_issues = []
print("\nVerification of filled target cells:")
for r, expected in original_blank_targets:
    actual = verify_ws.cell(r, 2).value
    print(f"B{r}: actual={actual!r}, expected={expected!r}")
    if actual in (None, "") or actual != expected:
        verification_issues.append((r, actual, expected))

print("Verification issues:", verification_issues)

final_output_path = output_path
