def sheet_nonempty_bounds(ws):
    max_r, max_c = ws.max_row, ws.max_column
    # Determine actual used rows/cols based on non-empty values
    used_rows = set()
    used_cols = set()
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                used_rows.add(cell.row)
                used_cols.add(cell.column)
    return {
        "max_row": max_r,
        "max_col": max_c,
        "used_min_row": min(used_rows) if used_rows else None,
        "used_max_row": max(used_rows) if used_rows else None,
        "used_min_col": min(used_cols) if used_cols else None,
        "used_max_col": max(used_cols) if used_cols else None,
    }

for sname in wb.sheetnames:
