    bounds = sheet_nonempty_bounds(ws)
    print("\n=== SHEET:", sname, "===")
    print("Dimensions:", bounds)
    
    # Header row candidate: row 1
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
