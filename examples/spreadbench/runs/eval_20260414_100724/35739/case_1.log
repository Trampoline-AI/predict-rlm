from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_nonempty_bounds(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # find last non-empty row
    last_row = 0
    last_col = 0
    for r in range(1, max_row + 1):
        row_has = False
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if v is not None and v != "":
                row_has = True
                last_col = max(last_col, c)
        if row_has:
            last_row = r
    return last_row, last_col

for sname in wb.sheetnames:
    ws = wb[sname]
    last_row, last_col = sheet_nonempty_bounds(ws)
    print("\n" + "="*80)
    print(f"Sheet: {sname}")
    print(f"ws.max_row={ws.max_row}, ws.max_column={ws.max_column}, last_nonempty_row={last_row}, last_nonempty_col={last_col} ({get_column_letter(last_col) if last_col else 'N/A'})")
    
    # headers from row 1
    headers = [ws.cell(1, c).value for c in range(1, max(ws.max_column, last_col) + 1)]
    print("Header row 1:", headers)
    
    # first 10 rows
    first_n = min(last_row if last_row else ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, max(last_col, ws.max_column) + 1)]
        print(f"Row {r}: {vals}")
    
    # last 5 non-empty rows
    if last_row:
        start = max(1, last_row - 4)
        print(f"Last rows {start}:{last_row}:")
        for r in range(start, last_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, max(last_col, ws.max_column) + 1)]
            print(f"Row {r}: {vals}")

# Focused inspection of Sheet1 A:C and formulas around target
if "Sheet1" in wb.sheetnames:
    ws = wb["Sheet1"]
    print("\n" + "="*80)
    print("Focused inspection: Sheet1 columns A:C")
    for r in range(1, min(ws.max_row, 15) + 1):
        row_vals = []
        for c in range(1, 4):
            cell = ws.cell(r, c)
            row_vals.append(f"{cell.coordinate}={cell.value!r}")
        print(" | ".join(row_vals))
    
    # inspect last non-empty relevant rows in A:C
