ws_formula = wb_formula["Sheet1"]

wb_values = load_workbook(output_path, data_only=True)
# Handle possible renamed sheet edge case after saving
values_sheet_name = "Sheet1" if "Sheet1" in wb_values.sheetnames else wb_values.sheetnames[0]
ws_values = wb_values[values_sheet_name]

print("\nVerification of target cells/formulas:")
check_rows = [2, 3, 4, 8, 9, 10, 11, 14, 15, 96, 97, 100]
for r in check_rows:
    a = ws_values[f"A{r}"].value
    b = ws_values[f"B{r}"].value
    c_formula = ws_formula[f"C{r}"].value
    c_value = ws_values[f"C{r}"].value
    print(f"Row {r}: A={a!r}, B={b!r}, C_formula={c_formula!r}, C_value={c_value!r}")

# Extra sanity checks for blanks and midnight rows
print("\nSanity checks:")
for r in [9, 10, 11]:  # midnight crossover examples
