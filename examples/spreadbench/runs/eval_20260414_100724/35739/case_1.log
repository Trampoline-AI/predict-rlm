from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from shutil import copyfile

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Re-open fresh workbook for editing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
ws = wb["Sheet1"]

print("Original sheet names:", orig_sheet_names)
print("Target sheet:", ws.title)
print("Sheet1 dimensions:", ws.max_row, ws.max_column)

# Inspect data types / number formats for relevant cells before modifying
print("\nPre-write inspection of key cells:")
for r in [2, 8, 9, 10, 11, 96, 97, 100]:
    vals = []
    for c in [1, 2, 3]:
        cell = ws.cell(r, c)
        vals.append(
            f"{cell.coordinate}: value={cell.value!r}, data_type={cell.data_type!r}, number_format={cell.number_format!r}"
        )
    print(" | ".join(vals))

# Determine rows that actually need output based on A/B usage.
# We'll preserve structure and only write formulas where there is data or where the existing output column is part of the designed range.
# Since C already has formulas through row 100 and rows 96:100 are blank inputs, we can safely fill C2:C100 with blank-safe formula.
start_row = 2
end_row = ws.max_row
print(f"\nWriting corrected formulas to C{start_row}:C{end_row}")

formula_samples = {}
for r in range(start_row, end_row + 1):
    formula = f'=IF(OR(A{r}="",B{r}=""),"",MOD(B{r}-TIME(0,30,0),1))'
    ws[f"C{r}"] = formula
    # Apply time format to display correctly
    ws[f"C{r}"].number_format = ws[f"B{r}"].number_format if ws[f"B{r}"].number_format else "hh:mm"
    if r in [2, 8, 9, 10, 11, 96, 100]:
        formula_samples[r] = ws[f"C{r}"].value

print("Sample written formulas:")
for r in sorted(formula_samples):
    print(f"C{r}: {formula_samples[r]!r}, number_format={ws[f'C{r}'].number_format!r}")

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # Rename by position to original names
    if len(wb_after.sheetnames) == len(orig_sheet_names):
        for idx, orig_name in enumerate(orig_sheet_names):
            wb_after.worksheets[idx].title = orig_name
        wb_after.save(output_path)
        print("Renamed sheets back to original names:", orig_sheet_names)
    else:
        print("Warning: sheet count changed unexpectedly; not renaming automatically.")

# Verify formulas and evaluated values
