from openpyxl import load_workbook
import os

# Reload original workbook to inspect types carefully
path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Detailed source inspection for rows 2:23 (showing B,D,F types and values)")
for rr in range(2, ws.max_row + 1):
    b = ws[f"B{rr}"].value
    d = ws[f"D{rr}"].value
    f = ws[f"F{rr}"].value
    print(rr, f"B={b!r} ({type(b).__name__})", f"D={d!r} ({type(d).__name__})", f"F={f!r}")

print("\nInspecting lookup cells J7:K9 with types")
for r in range(7, 10):
    j = ws[f"J{r}"].value
    k = ws[f"K{r}"].value
    l = ws[f"L{r}"].value
    print(r, f"J{r}={j!r} ({type(j).__name__})", f"K{r}={k!r} ({type(k).__name__})", f"L{r}={l!r}")

def norm(v):
    if v is None:
        return None
    return str(v).strip()

print("\nMatches after normalized string comparison:")
results = {}
for r in range(7, 10):
    j = norm(ws[f"J{r}"].value)  # target D
    k = norm(ws[f"K{r}"].value)  # target B
    found = None
    all_hits = []
    for rr in range(2, ws.max_row + 1):
        b = norm(ws[f"B{rr}"].value)
        d = norm(ws[f"D{rr}"].value)
        f = ws[f"F{rr}"].value
        if b == k and d == j:
            all_hits.append((rr, b, d, f))
            if found is None:
                found = f
    results[r] = found if found is not None else ""
    print(f"Target L{r} from J{r}/K{r} => hits={all_hits} => chosen={results[r]!r}")

# Write literal values to exact target cells L7:L9
for r in range(7, 10):
    before = ws[f"L{r}"].value
    ws[f"L{r}"] = results[r]
    print(f"Wrote L{r}: before={before!r}, after={ws[f'L{r}'].value!r}")

# Save output
