print("Inspecting target/output area J6:L12")
for r in range(6, 13):
    print(r, [ws.cell(r, c).value for c in range(10, 13)])  # J:L

print("\nChecking intended matches for each target row (7:9)")
for r in range(7, 10):
    d_target = ws[f"J{r}"].value   # work center / "Match from D"
    b_target = ws[f"K{r}"].value   # order / "Match from B"
    print(f"\nTarget row {r}: J{r}={d_target!r}, K{r}={b_target!r}, current L{r}={ws[f'L{r}'].value!r}")
    matches = []
    for rr in range(2, ws.max_row + 1):
        b = ws[f"B{rr}"].value
        d = ws[f"D{rr}"].value
        f = ws[f"F{rr}"].value
        if b == b_target and d == d_target:
