Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Re-open for modification
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect exact target region before writing
print("Original sheet names:", original_sheetnames)
print("Inspecting D2:H5 before writing:")
for r in range(2, 6):
    vals = []
    for c in range(4, 9):  # D:H
        vals.append(f"{get_column_letter(c)}{r}={repr(ws.cell(r,c).value)}")
    print(" | ".join(vals))

# Identify data rows needing output: rows with any numeric/non-empty values in D:G, below header row
target_rows = []
for r in range(3, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(4, 8)]  # D:G
    if any(v not in (None, "") for v in row_vals):
        target_rows.append(r)

print("Target rows for formulas in column H:", target_rows)

# Print any existing formulas in target column
for r in target_rows:
    print(f"Before write H{r}:", repr(ws[f'H{r}'].value))

# Write formula into H for all relevant rows
for r in target_rows:
    formula = f"=INDEX($D$2:$G$2,1,MATCH(MAX(D{r}:G{r}),D{r}:G{r},0))"
    ws[f"H{r}"] = formula

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc; fix sheet names if changed
wb_check = load_workbook(outfile)
print("Sheet names after recalc reload:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # Rename sheets back by position
    for idx, orig_name in enumerate(original_sheetnames):
        wb_check.worksheets[idx].title = orig_name
    wb_check.save(outfile)
    print("Renamed sheets back to original:", original_sheetnames)

# Verify formulas and values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target cells H3:H5:")
for r in target_rows:
    print(
        f"Row {r}: formula={ws_formula[f'H{r}'].value!r}, "
        f"value={ws_values[f'H{r}'].value!r}, "
        f"source_row={[ws_values.cell(r,c).value for c in range(4,8)]}"
    )

print("\nFinal D2:H5 (data_only):")
for r in range(2, 6):
    vals = []
    for c in range(4, 9):
        vals.append(f"{get_column_letter(c)}{r}={repr(ws_values.cell(r,c).value)}")
    print(" | ".join(vals))

output_spreadsheet = outfile
print("\nPrepared output_spreadsheet:", output_spreadsheet)
