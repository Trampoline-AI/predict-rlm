from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def display_val(v):
    if v is None:
        return None
    return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print("Sheet:", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find actual used rows/cols with any non-empty cells
    used_rows = []
    used_cols = set()
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value is not None:
                row_has = True
                used_cols.add(cell.column)
        if row_has:
            used_rows.append(row[0].row)
    if used_rows:
        print("Actual used rows:", min(used_rows), "to", max(used_rows), "count", len(used_rows))
        print("Actual used cols:", min(used_cols), "to", max(used_cols), "count", len(used_cols))
    else:
        print("No used rows")
        continue
    
    # Print first few rows with coordinates and values
    print("\nTop rows:")
    top_n = min(ws.max_row, 10)
    for r in range(1, top_n + 1):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            vals.append(f"{get_column_letter(c)}{r}={repr(display_val(v))}")
        print(" | ".join(vals))
    
    # Print last 5 rows
    print("\nBottom rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            vals.append(f"{get_column_letter(c)}{r}={repr(display_val(v))}")
        print(" | ".join(vals))
    
    # Candidate header rows: first 5 rows with most strings / non-empty
    print("\nCandidate header analysis:")
    for r in range(1, min(5, ws.max_row) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v is not None and v != "" for v in row_vals)
        strings = sum(isinstance(v, str) for v in row_vals if v is not None)
        print(f"Row {r}: nonempty={nonempty}, strings={strings}, values={row_vals}")
    
    # Print formulas found
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print(f"\nFound {len(formulas)} formula cells")
    for item in formulas[:20]:
        r, c, v = item
        print(f"{get_column_letter(c)}{r}: {v}")
    
    # Print merged ranges if any
    if ws.merged_cells.ranges:
        print("Merged ranges:", list(ws.merged_cells.ranges))
    else:
        print("Merged ranges: none")
