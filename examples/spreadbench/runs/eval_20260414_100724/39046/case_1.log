print("Workbook sheets:", wb.sheetnames)

def cell_display(v):
    try:
        return v.text if hasattr(v, "text") else v
    except Exception:
        return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # detect non-empty rows/cols more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None, 
          "count=", len(nonempty_rows))
    
    headers1 = [cell_display(ws.cell(1, c).value) for c in range(1, ws.max_column + 1)]
    headers2 = [cell_display(ws.cell(2, c).value) for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print("Row 1 headers/values:", headers1)
    if headers2:
        print("Row 2 values:", headers2)
    
    # print first 10 non-empty rows and last 5 non-empty rows
    sample_rows = nonempty_rows[:10] + [r for r in nonempty_rows[-5:] if r not in nonempty_rows[:10]]
    print("Sample rows:")
    for r in sample_rows:
        rowvals = [cell_display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {rowvals}")
    
    # focus on columns A:F since instruction references B,D,E,F
    print("Focused A:F preview")
    for r in sample_rows[:12]:
        vals = [cell_display(ws.cell(r, c).value) for c in range(1, min(6, ws.max_column) + 1)]
        print(f"Row {r} A:F -> {vals}")
    
    # print existing formulas / values in E and F columns for first 20 rows if exist
    for col in [2, 4, 5, 6]:
        if col <= ws.max_column:
            col_letter = get_column_letter(col)
            values = []
            for r in range(1, min(ws.max_row, 20) + 1):
                v = ws.cell(r, col).value
                values.append((r, cell_display(v)))
            print(f"Column {col_letter} first 20 rows:", values)
    
    # search for any existing formulas in sheet
