```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Determine actual data rows based on any non-empty cells in A:F
data_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    if any(v not in (None, "") for v in vals):
        data_rows.append(r)

print("Sheet names:", wb.sheetnames)
print("Actual data rows:", data_rows)
print("Headers A:F:", [ws.cell(1, c).value for c in range(1, 7)])

print("\nCurrent target area B:F")
for r in data_rows:
    print(r, [ws.cell(r, c).value for c in range(2, 7)])

# Python dry-run to infer expected pattern
subrefs = []
for r in data_rows:
    d = ws.cell(r, 4).value
    if isinstance(d, str) and d.strip():
        subrefs.append(d.strip())

print("\nAll non-empty SUBREFS in D:", subrefs)

expected = {}
for r in data_rows:
    ref = ws.cell(r, 2).value
    status = ws.cell(r, 3).value
    count = 0
    if isinstance(ref, str) and str(status).strip().upper() == "CANCELLED":
        count = sum(1 for s in subrefs if ref in s)
    expected[r] = {
        "ref": ref,
        "status": status,
        "count_matches": count,
        "subs?": "Yes" if count > 0 else "No",
        "existing_E": ws.cell(r, 5).value,
        "existing_F": ws.cell(r, 6).value,
    }

print("\nDry-run expected outputs:")
for r in data_rows:
    print(r, expected[r])

# Prepare output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))

# Write formulas into the existing output columns E and F for all actual data rows
# Use bounded range, not full-column refs, for LibreOffice compatibility/performance
start_row = min(data_rows) if data_rows else 2
end_row = max(data_rows) if data_rows else 2
d_range = f"$D${start_row}:$D${end_row}"

for r in data_rows:
    # Only rows with a REF should receive formulas
    ref = ws.cell(r, 2).value
    if ref in (None, ""):
        continue
    f_formula = f'=IF($C{r}="CANCELLED",COUNTIF({d_range},"*"&$B{r}&"*"),0)'
    e_formula = f'=IF($F{r}>0,"Yes","No")'
    print(f"Writing row {r}: E{r}={e_formula} | F{r}={f_formula}")
    ws.cell(r, 5).value = e_formula
    ws.cell(r, 6).value = f_formula

wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
orig_sheetnames = wb.sheetnames[:]
wb2 = load_workbook(out_path)
print("Sheet names after recalc before fix:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for old_name, desired_name in zip(wb2.sheetnames, orig_sheetnames):
        if old_name != desired_name:
            wb2[old_name].title = desired_name
    wb2.save(out_path)
    print("Restored sheet names:", load_workbook(out_path).sheetnames)

# Verify formulas and calculated values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("\nVerification of target cells E:F")
for r in data_rows:
    print({
        "row": r,
        "B": ws_values.cell(r, 2).value,
        "C": ws_values.cell(r, 3).value,
        "D": ws_values.cell(r, 4).value,
        "E_formula": ws_formula.cell(r, 5).value,
        "F_formula": ws_formula.cell(r, 6).value,
        "E_value": ws_values.cell(r, 5).value,
        "F_value": ws_values.cell(r, 6).value,
    })

output_spreadsheet = out_path
print("\nPrepared output_spreadsheet:", output_spreadsheet)
