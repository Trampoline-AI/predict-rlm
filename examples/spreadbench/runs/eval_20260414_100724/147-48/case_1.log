import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def sheet_used_bounds(ws):
    min_row = None
    max_row = 0
    min_col = None
    max_col = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                if min_row is None or cell.row < min_row:
                    min_row = cell.row
                if min_col is None or cell.column < min_col:
                    min_col = cell.column
                if cell.row > max_row:
                    max_row = cell.row
                if cell.column > max_col:
                    max_col = cell.column
    if min_row is None:
        return None
    return min_row, max_row, min_col, max_col

def row_values(ws, r, max_col=None):
    if max_col is None:
        max_col = ws.max_column
    vals = []
    for c in range(1, max_col + 1):
        v = ws.cell(r, c).value
        if hasattr(v, "text"):  # array formula object etc.
            try:
                v = v.text
            except:
                v = str(v)
        vals.append(v)
    return vals

for sname in wb.sheetnames:
    ws = wb[sname]
    bounds = sheet_used_bounds(ws)
    print("\n" + "="*80)
    print("Sheet:", sname)
    print("openpyxl max_row/max_col:", ws.max_row, ws.max_column)
    print("Used bounds:", bounds)
    if bounds is None:
        print("Sheet is empty")
        continue
    min_row, max_row, min_col, max_col = bounds
    headers = row_values(ws, min_row, max_col)
    print("Header/first used row values:")
    for i, v in enumerate(headers, start=1):
        if v not in (None, ""):
            print(f"  {get_column_letter(i)}{min_row} = {v!r}")
    preview_cols = min(max_col, 12)
    print(f"\nFirst up to 10 rows (cols A:{get_column_letter(preview_cols)}):")
    for r in range(min_row, min(max_row, min_row + 9) + 1):
        print(f"Row {r}: {row_values(ws, r, preview_cols)}")
    print(f"\nLast up to 5 rows (cols A:{get_column_letter(preview_cols)}):")
    start_last = max(min_row, max_row - 4)
    for r in range(start_last, max_row + 1):
        print(f"Row {r}: {row_values(ws, r, preview_cols)}")
    
    # Focused inspection of columns A onward to identify manual transpose pattern
    print("\nFocused non-empty cells in first 8 columns for first 30 rows:")
    for r in range(min_row, min(max_row, min_row + 29) + 1):
        vals = row_values(ws, r, min(max_col, 8))
        if any(v not in (None, "") for v in vals):
            print(f"Row {r}: {vals}")

    # Print formulas if any in first 12 cols / first 30 rows
    formula_cells = []
    for r in range(min_row, min(max_row, min_row + 29) + 1):
        for c in range(1, min(max_col, 12) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    if formula_cells:
        print("\nFormulas found near top-left:")
        for addr, formula in formula_cells:
            print(addr, "=", formula)
    else:
        print("\nNo standard formulas found near top-left.")

# Save variables for next iteration
inspection_done = True
