import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Re-open workbook for clean inspection and possible editing
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
original_sheet_names = wb.sheetnames[:]

# Helper to display row slices
def row_slice(ws, r, c1, c2):
    return [ws.cell(r, c).value for c in range(c1, c2 + 1)]

# Build contiguous non-empty groups from column A
groups = []
current = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v not in (None, ""):
        current.append((r, v))
    else:
        if current:
            groups.append(current)
            current = []
if current:
    groups.append(current)

print("Detected groups from Column A:")
for i, grp in enumerate(groups, start=1):
    print(f"Group {i}: rows {grp[0][0]}-{grp[-1][0]}, values={[v for _, v in grp]}")

print("\nExisting values in Columns C onward for rows 1..number of groups:")
for r in range(1, len(groups) + 2):
    print(f"Row {r}, C:H =", row_slice(ws, r, 3, min(8, ws.max_column if ws.max_column >= 8 else 8)))

# Verify the inferred mapping against the first two existing example rows
inferred_ok = True
for i, grp in enumerate(groups[:2], start=1):
    expected = [v for _, v in grp]
    existing = [ws.cell(i, 2 + j).value for j in range(1, len(expected) + 1)]  # C onward
    print(f"Check example row {i}: expected {expected}, existing {existing}")
    if existing != expected:
        inferred_ok = False

print("Pattern confirmed from examples?" , inferred_ok)

# Apply transpose of each group horizontally starting in column C
# Also clear old output area in C onward for affected rows to avoid stale values
start_col = 3  # Column C
target_rows = len(groups)
max_group_len = max(len(g) for g in groups) if groups else 0

for r in range(1, target_rows + 1):
    for c in range(start_col, start_col + max_group_len):
        ws.cell(r, c).value = None

for out_row, grp in enumerate(groups, start=1):
    values = [v for _, v in grp]
    for offset, v in enumerate(values):
        ws.cell(out_row, start_col + offset).value = v

print("\nAfter writing, target area preview:")
for r in range(1, target_rows + 1):
    print(f"Row {r}, C:{get_column_letter(start_col + max_group_len - 1)} =",
          row_slice(ws, r, start_col, start_col + max_group_len - 1))

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate as required
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb2 = load_workbook(out_path)
if wb2.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring to", original_sheet_names)
    # Rename by position to original names
    for idx, orig_name in enumerate(original_sheet_names):
        wb2.worksheets[idx].title = orig_name
    wb2.save(out_path)
else:
    print("Sheet names preserved after recalc:", wb2.sheetnames)

# Verification with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("\nVerification of target cells/range:")
all_ok = True
for out_row, grp in enumerate(groups, start=1):
    expected = [v for _, v in grp]
    actual = [wsv.cell(out_row, start_col + i).value for i in range(len(expected))]
    print(f"Output row {out_row}: expected={expected} actual={actual}")
    if actual != expected:
        all_ok = False

print("Verification passed?", all_ok)

output_spreadsheet = out_path
