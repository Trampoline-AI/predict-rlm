```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine actual data range for source list in A:B and lookup list in D
last_row = 1
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
        last_row = r
print("Original sheet names:", original_sheetnames)
print("Detected last used row:", last_row)

# Print current target area before modification
print("\nBefore modification E2:E9:")
for r in range(2, 10):
    print(r, ws[f"D{r}"].value, ws[f"E{r}"].value)

# Build nth-match formula using AGGREGATE pattern referenced by the instruction.
# Bounded ranges only.
src_start = 2
src_end = last_row
for r in range(2, 10):
    formula = (
        f'=IF(D{r}="","",'
        f'IFERROR(INDEX($B${src_start}:$B${src_end},'
        f'_xlfn.AGGREGATE(15,6,'
        f'(ROW($A${src_start}:$A${src_end})-ROW($A${src_start})+1)/($A${src_start}:$A${src_end}=D{r}),'
        f'COUNTIF($D$2:D{r},D{r})'
        f')),""))'
    )
    ws[f"E{r}"] = formula

# Apply requested formatting to E2:E9
fill = PatternFill(start_color="FCE4D6", end_color="FCE4D6", fill_type="solid")
font = Font(name="Calibri", size=11)
for r in range(2, 10):
    cell = ws[f"E{r}"]
    cell.fill = fill
    cell.font = font
    # hide zeros if any numeric zero is ever returned
    cell.number_format = '0;-0;;@'

# Also set the sheet to display zeros as blanks for extra compliance
try:
    ws.sheet_view.showZeros = False
    print("Set ws.sheet_view.showZeros = False")
except Exception as e:
    print("Could not set showZeros:", e)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc, repair sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc; restoring original names.")
    for i, name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)
    print("Restored sheet names and re-saved.")

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("\nVerification of D2:E9 (data_only):")
for r in range(2, 10):
    print(
        f"Row {r}: D={wsv[f'D{r}'].value!r}, E={wsv[f'E{r}'].value!r}"
    )

# Verify formulas/styles in normal workbook
wb_formula = load_workbook(outfile)
wsf = wb_formula[original_sheetnames[0]]
print("\nVerification of formulas/styles in E2:E9:")
for r in range(2, 10):
    c = wsf[f"E{r}"]
    print(
        f"E{r}: formula={c.value!r}, font={c.font.name!r}, "
        f"fill={c.fill.fgColor.rgb!r}, numfmt={c.number_format!r}"
    )
