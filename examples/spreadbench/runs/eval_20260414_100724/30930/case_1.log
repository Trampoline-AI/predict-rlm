```repl
from openpyxl import load_workbook
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load source and inspect exact target cells again
wb = load_workbook(input_path, data_only=False)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

rows_b_eq_1 = [r for r in range(1, ws.max_row + 1) if ws.cell(r, 2).value == 1]

print("Sheet names:", wb.sheetnames)
print("Sheet1 dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
print("Target rows where B=1:", rows_b_eq_1)

print("\nCurrent A:C at target rows:")
for r in rows_b_eq_1:
    print(f"Row {r}: A={ws.cell(r,1).value!r}, B={ws.cell(r,2).value!r}, C={ws.cell(r,3).value!r}")

# Compute expected counts correctly
expected = {}
prev = None
for r in rows_b_eq_1:
    if prev is None:
        expected[r] = None
    else:
        cnt = 0
        for rr in range(prev + 1, r):
            v = ws.cell(rr, 1).value
            if isinstance(v, (int, float)) and v > 0:
                cnt += 1
        expected[r] = cnt
    prev = r

print("\nExpected results on rows where B=1:")
for r in rows_b_eq_1:
    print(f"C{r} -> {expected[r]!r}")

# Write formulas on marker rows, blank elsewhere in C
# First marker stays blank because there is no prior occurrence of 1.
for r in range(1, ws.max_row + 1):
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3)
    if b != 1:
        if c.value not in (None, ""):
            c.value = None
    else:
        if expected[r] is None:
            c.value = None
        else:
            # Count A>0 for rows after the previous B=1 and before current row.
            # Uses only bounded ranges for LibreOffice compatibility.
            prev_end = r - 1
            formula = (
                f'=IF(B{r}<>1,"",'
                f'IF(COUNTIF($B$1:$B{prev_end},1)=0,"",'
                f'SUMPRODUCT((ROW($A$1:$A{prev_end})>'
                f'LOOKUP(2,1/($B$1:$B{prev_end}=1),ROW($B$1:$B{prev_end})))'
                f'*($A$1:$A{prev_end}>0))))'
            )
            c.value = formula

print("\nWritten formulas / values in Column C at target rows:")
for r in rows_b_eq_1:
    print(f"C{r} = {ws.cell(r,3).value!r}")

wb.save(output_path)
print("\nSaved formula version to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if LibreOffice changed them
wb_after = load_workbook(output_path, data_only=False)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    for old_title, desired_title in zip(wb_after.sheetnames[:], orig_sheetnames):
        wb_after[old_title].title = desired_title
    wb_after.save(output_path)
else:
    print("Sheet names after recalc:", wb_after.sheetnames)

# Verify data-only results
ver_wb = load_workbook(output_path, data_only=True)
ver_ws = ver_wb["Sheet1"]

verification = []
formula_ok = True
for r in rows_b_eq_1:
    val = ver_ws.cell(r, 3).value
    verification.append((r, expected[r], val))
    if val != expected[r]:
        formula_ok = False

print("\nVerification after formula write (row, expected, actual):")
for item in verification:
    print(item)

# Fallback to static values if formulas did not evaluate properly
if not formula_ok:
    print("\nFormula verification failed; falling back to static computed values.")
    fix_wb = load_workbook(output_path, data_only=False)
    fix_ws = fix_wb["Sheet1"]

    for r in range(1, fix_ws.max_row + 1):
        if fix_ws.cell(r, 2).value == 1:
            fix_ws.cell(r, 3).value = expected[r]
        else:
            fix_ws.cell(r, 3).value = None

    fix_wb.save(output_path)
    recalc_result2 = await recalculate(output_path)
    print("Recalculate after fallback:", recalc_result2)

    wb_after2 = load_workbook(output_path, data_only=False)
    if wb_after2.sheetnames != orig_sheetnames and len(wb_after2.sheetnames) == len(orig_sheetnames):
        print("Sheet names changed after fallback recalc:", wb_after2.sheetnames, "-> restoring", orig_sheetnames)
        for old_title, desired_title in zip(wb_after2.sheetnames[:], orig_sheetnames):
            wb_after2[old_title].title = desired_title
        wb_after2.save(output_path)

    ver_wb2 = load_workbook(output_path, data_only=True)
    ver_ws2 = ver_wb2["Sheet1"]
    print("\nVerification after fallback (row, expected, actual):")
    for r in rows_b_eq_1:
        print((r, expected[r], ver_ws2.cell(r, 3).value))

# Final spot-check: non-target rows in C should be blank
nonblank_non_targets = []
final_ver_wb = load_workbook(output_path, data_only=True)
final_ver_ws = final_ver_wb["Sheet1"]
for r in range(1, final_ver_ws.max_row + 1):
    if final_ver_ws.cell(r, 2).value != 1 and final_ver_ws.cell(r, 3).value not in (None, ""):
        nonblank_non_targets.append((r, final_ver_ws.cell(r, 3).value))

print("\nNonblank C cells where B!=1:", nonblank_non_targets[:20], "count:", len(nonblank_non_targets))
print("Output path ready:", output_path)
