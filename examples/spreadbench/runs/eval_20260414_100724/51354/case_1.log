import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

# Load workbook and inspect exact target cells before modifying
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheetnames)
print("Target headers:", {c: ws[f"{c}1"].value for c in ["A","B","C","D","E"]})

# Determine relevant rows: non-empty in column A below header
target_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 1).value not in (None, ""):
        target_rows.append(r)

print("Target rows based on non-empty column A:", target_rows)
for r in target_rows:
    print(
        f"Before row {r}:",
        {
            "A": ws[f"A{r}"].value,
            "D": ws[f"D{r}"].value,
            "E": ws[f"E{r}"].value,
        }
    )

# Orange fill requested for column D
orange_fill = PatternFill(start_color="FFC000", end_color="FFC000", fill_type="solid")

# Robust formula:
# - year from last 2 chars
# - month abbrev from first 3 chars of last 6 chars
# - convert month text to month number with MATCH over month list
# - add one month by using DATE with month_num + 1
# - format as MMM YY
#
# Example for Oct 21:
# RIGHT(A2,6) -> "Oct 21"
# LEFT(RIGHT(A2,6),3) -> "Oct"
# MATCH(...) -> 10
# DATE(2021,11,1) -> Nov 2021
# TEXT(...,"MMM YY") -> "Nov 21"

month_array = '{"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"}'

for r in target_rows:
    # Keep column D as just the 2-digit year number
    d_formula = f'=VALUE(RIGHT($A{r},2))'
    ws[f"D{r}"] = d_formula
    ws[f"D{r}"].fill = orange_fill

    # Output next month-year in column E
    e_formula = (
        f'=TEXT('
        f'DATE(2000+VALUE(RIGHT($A{r},2)),'
        f'MATCH(LEFT(RIGHT($A{r},6),3),{month_array},0)+1,1),'
        f'"MMM YY")'
    )
    ws[f"E{r}"] = e_formula

print("\nWritten formulas:")
for r in target_rows:
    print(f"Row {r} D formula:", ws[f"D{r}"].value)
    print(f"Row {r} E formula:", ws[f"E{r}"].value)

os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open and fix sheet names if recalc changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # Rename sheets back by position
    for i, original_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = original_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification:")
for r in target_rows:
    d_formula = ws_formula[f"D{r}"].value
    e_formula = ws_formula[f"E{r}"].value
    d_value = ws_values[f"D{r}"].value
    e_value = ws_values[f"E{r}"].value
    fill_rgb = ws_formula[f"D{r}"].fill.start_color.rgb
    print(
        f"Row {r}:",
        {
            "A": ws_values[f"A{r}"].value,
            "D_formula": d_formula,
            "D_value": d_value,
            "D_fill": fill_rgb,
            "E_formula": e_formula,
            "E_value": e_value,
        }
    )

output_spreadsheet = outfile
