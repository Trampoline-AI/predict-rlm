import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

outfile = output_spreadsheet  # from prior step
print("Fixing file:", outfile)

# Load current output workbook
wb = load_workbook(outfile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect current D formatting before change
print("Before fix:")
for r in range(2, ws.max_row + 1):
    if ws[f"A{r}"].value not in (None, ""):
        print(
            f"Row {r}",
            {
                "A": ws[f"A{r}"].value,
                "D_value": ws[f"D{r}"].value,
                "D_number_format": ws[f"D{r}"].number_format,
                "E_formula": ws[f"E{r}"].value,
            }
        )

orange_fill = PatternFill(start_color="FFC000", end_color="FFC000", fill_type="solid")

# Replace D formulas with literal integers and enforce numeric format/fill
target_rows = [r for r in range(2, ws.max_row + 1) if ws[f"A{r}"].value not in (None, "")]
for r in target_rows:
    text = str(ws[f"A{r}"].value).strip()
    year2 = int(text[-2:])  # last 2 chars are the year number per instruction/data
    ws[f"D{r}"] = year2
    ws[f"D{r}"].fill = orange_fill
    ws[f"D{r}"].number_format = "0"

# Double-check formulas/values before save
print("\nAfter in-memory fix, before save:")
for r in target_rows:
    print(
        f"Row {r}",
        {
            "D_value": ws[f"D{r}"].value,
            "D_number_format": ws[f"D{r}"].number_format,
            "D_fill": ws[f"D{r}"].fill.start_color.rgb,
            "E_formula": ws[f"E{r}"].value,
        }
    )

wb.save(outfile)
print("\nSaved fixed workbook.")

# Recalculate so E formula caches remain valid
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Ensure sheet names unchanged
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames:
    for i, nm in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = nm
    wb_post.save(outfile)
    print("Renamed sheets back:", original_sheetnames)

# Final verification
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_vals = load_workbook(outfile, data_only=True)
ws_vals = wb_vals["Sheet1"]

print("\nFinal verification:")
for r in target_rows:
    print(
        f"Row {r}",
        {
            "A": ws_vals[f"A{r}"].value,
            "D_formula_or_value": ws_formula[f"D{r}"].value,
            "D_data_only": ws_vals[f"D{r}"].value,
            "D_type": type(ws_vals[f"D{r}"].value).__name__,
            "D_number_format": ws_formula[f"D{r}"].number_format,
            "D_fill": ws_formula[f"D{r}"].fill.start_color.rgb,
            "E_formula": ws_formula[f"E{r}"].value,
            "E_data_only": ws_vals[f"E{r}"].value,
            "E_type": type(ws_vals[f"E{r}"].value).__name__,
        }
    )

# Keep output path for submit
output_spreadsheet = outfile
