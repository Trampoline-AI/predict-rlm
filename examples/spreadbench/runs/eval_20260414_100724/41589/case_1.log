import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Contact List"]

# Identify rows that truly have data (excluding header row, and excluding column J itself)
target_rows = []
for r in range(4, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, 10)] + [ws.cell(r, 11).value]  # A:I and K
    if any(v is not None and v != "" for v in row_vals):
        target_rows.append(r)

print("Target rows to populate in Column J:", target_rows)

# Write formula only to relevant rows so blank template rows remain blank
for r in target_rows:
    formula = (
        f'=IF(AND(H{r}<>"",H{r}>=TODAY()-30,UPPER(TRIM(I{r}))="YES"),"HOLD",'
        f'IF(AND(H{r}<>"",H{r}<TODAY()-30,UPPER(TRIM(I{r}))="YES"),"TOUCH BASE","NO ACTION"))'
    )
    print(f"Writing J{r} formula:", formula)
    ws[f"J{r}"] = formula

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open and restore original sheet names if LibreOffice changed them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names:
    # Rename by position to restore original names
    for i, expected_name in enumerate(original_sheet_names):
        wb_post.worksheets[i].title = expected_name
    wb_post.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verify formula text
wb_verify_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_verify_formula["Contact List"]
for r in target_rows:
    print(f"Formula in J{r}:", ws_formula[f'J{r}'].value)

# Verify calculated values
wb_verify_values = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify_values.sheetnames)
ws_values = wb_verify_values["Contact List"]
for r in target_rows:
    print(
        f"Verified row {r}: H{r}={ws_values[f'H{r}'].value!r}, "
        f"I{r}={ws_values[f'I{r}'].value!r}, J{r}={ws_values[f'J{r}'].value!r}"
    )

# Keep path ready for submission next turn
final_output_spreadsheet = output_path
