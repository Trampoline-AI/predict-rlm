        print("Duplicates", coord, fmt_cell_info(ws_dup, coord))

# Determine sort order using parsed dates where needed
def parse_excelish_date(v):
    if isinstance(v, datetime):
        return v
    if isinstance(v, str):
        for fmt in ("%d/%m/%Y", "%Y-%m-%d", "%m/%d/%Y"):
            try:
                return datetime.strptime(v, fmt)
            except Exception:
                pass
    return None

candidate_rows = []
for r in dup_rows:
    rowvals = [ws_src.cell(r, c).value for c in range(1, ws_src.max_column + 1)]
    bal = ws_src.cell(r, 5).value
