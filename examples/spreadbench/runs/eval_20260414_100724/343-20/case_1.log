print("Workbook:", input_path)
print("Sheets:", orig_sheet_names)

def sheet_nonempty_bounds(ws):
    max_row, max_col = ws.max_row, ws.max_column
    # find actual last non-empty row/col
    last_row = 0
    last_col = 0
    for r in ws.iter_rows():
        row_has = False
        for cell in r:
            if cell.value not in (None, ""):
                row_has = True
                if cell.column > last_col:
                    last_col = cell.column
        if row_has:
            last_row = cell.row
    return last_row, last_col

def row_values(ws, r, max_col=None):
    mc = max_col or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

workbook_summary = {}
for s in wb.sheetnames:
    ws = wb[s]
    last_row, last_col = sheet_nonempty_bounds(ws)
    headers = row_values(ws, 1, last_col) if last_row >= 1 else []
    workbook_summary[s] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "used_last_row": last_row,
        "used_last_col": last_col,
        "headers_row1": headers,
    }

print("\n=== SHEET SUMMARIES ===")
for s, info in workbook_summary.items():
    print(f"\nSheet: {s}")
    print(f"  ws.max_row={info['max_row']}, ws.max_col={info['max_col']}, used_last_row={info['used_last_row']}, used_last_col={info['used_last_col']}")
    print(f"  Row1 headers/values: {info['headers_row1']}")

    ws = wb[s]
    last_row, last_col = info["used_last_row"], info["used_last_col"]
    if last_row == 0:
        print("  (empty sheet)")
        continue

    first_rows = list(range(1, min(last_row, 10) + 1))
    last_rows = list(range(max(1, last_row - 4), last_row + 1))
    print("  First rows:")
    for r in first_rows:
        print(f"    R{r}: {row_values(ws, r, last_col)}")
    print("  Last rows:")
    for r in last_rows:
        print(f"    R{r}: {row_values(ws, r, last_col)}")

# Extra detailed inspection of the Duplicates sheet example area
if "Duplicates" in wb.sheetnames:
    ws = wb["Duplicates"]
