from openpyxl.styles import PatternFill
from copy import copy
from collections import Counter
from datetime import datetime

ws_src = wb["Imported Data"]
ws_dup = wb["Duplicates"]

def fmt_cell_info(ws, coord):
    c = ws[coord]
    return {
        "value": c.value,
        "number_format": c.number_format,
        "alignment": {
            "horizontal": c.alignment.horizontal,
            "vertical": c.alignment.vertical,
            "text_rotation": c.alignment.textRotation,
            "wrap_text": c.alignment.wrap_text,
        },
        "font_bold": c.font.bold,
        "fill": c.fill.fill_type,
    }

print("Exact current target area in Duplicates (A1:E10):")
for r in range(1, 11):
    print(f"R{r}:", [ws_dup.cell(r, c).value for c in range(1, 6)])

# Duplicate analysis on column C
vals = [(r, ws_src.cell(r, 3).value) for r in range(2, ws_src.max_row + 1) if ws_src.cell(r, 3).value not in (None, "")]
counts = Counter(v for _, v in vals)
dup_keys = sorted([k for k, cnt in counts.items() if cnt > 1])
dup_rows = [r for r, v in vals if v in counts and counts[v] > 1]

print("\nDuplicated keys in column C:", dup_keys)
print("Rows with duplicated keys:", dup_rows)

print("\nFull rows with duplicated keys:")
for r in dup_rows:
    row = [ws_src.cell(r, c).value for c in range(1, ws_src.max_column + 1)]
    print(f"R{r}: {row}")

print("\nStyle / format inspection for source duplicate rows and target example rows:")
for coord in ["D2", "D4", "D7", "D9"]:
    if ws_src[coord].value is not None:
