```repl
from openpyxl import load_workbook
from copy import copy
from collections import Counter
from pathlib import Path
from datetime import datetime
import os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = str(output_dir / Path(input_path).name)

def actual_last_row(ws):
    last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            last = r
    return last

def parse_sort_date(v):
    if isinstance(v, datetime):
        return v
    if isinstance(v, str):
        txt = v.strip()
        for fmt in ("%d/%m/%Y", "%Y-%m-%d", "%m/%d/%Y", "%d-%m-%Y"):
            try:
                return datetime.strptime(txt, fmt)
            except Exception:
                pass
    return datetime.max

def numeric_or_inf(v):
    try:
        return float(v)
    except Exception:
        return float("inf")

# Reload fresh workbook for writing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]

# Resolve sheet names robustly
source_name = "Imported Data" if "Imported Data" in wb.sheetnames else ("Import Data" if "Import Data" in wb.sheetnames else None)
target_name = "Duplicates" if "Duplicates" in wb.sheetnames else None
if source_name is None or target_name is None:
    raise ValueError(f"Expected source/target sheets not found. Sheets={wb.sheetnames}")

ws_src = wb[source_name]
ws_tgt = wb[target_name]

src_last_row = actual_last_row(ws_src)
src_last_col = ws_src.max_column
tgt_last_row_before = actual_last_row(ws_tgt)

# Find duplicated values in column C (excluding blanks)
c_values = []
for r in range(2, src_last_row + 1):
    val = ws_src.cell(r, 3).value
    if val not in (None, ""):
        c_values.append((r, val))

counts = Counter(v for _, v in c_values)
dup_rows = [r for r, v in c_values if counts[v] > 1]

# Sort: Balance asc, then Invoiced Date asc, then row number for stability
sorted_dup_rows = sorted(
    dup_rows,
    key=lambda r: (
        numeric_or_inf(ws_src.cell(r, 5).value),
        parse_sort_date(ws_src.cell(r, 4).value),
        r,
    )
)

print("Source sheet:", source_name)
print("Target sheet:", target_name)
print("Source last row:", src_last_row)
print("Duplicate row numbers:", dup_rows)
print("Sorted duplicate row numbers:", sorted_dup_rows)

# Clear existing data area below header in target sheet
clear_to_row = max(tgt_last_row_before, 1 + len(sorted_dup_rows))
for r in range(2, clear_to_row + 1):
    for c in range(1, ws_tgt.max_column + 1):
        ws_tgt.cell(r, c).value = None
        # leave existing styles unless overwritten; this avoids stale values

# Write duplicate rows with copied formatting from source
for out_r, src_r in enumerate(sorted_dup_rows, start=2):
    for c in range(1, src_last_col + 1):
        src_cell = ws_src.cell(src_r, c)
        tgt_cell = ws_tgt.cell(out_r, c)
        tgt_cell.value = src_cell.value
        tgt_cell._style = copy(src_cell._style)
        tgt_cell.number_format = src_cell.number_format
        tgt_cell.font = copy(src_cell.font)
        tgt_cell.fill = copy(src_cell.fill)
        tgt_cell.border = copy(src_cell.border)
        tgt_cell.alignment = copy(src_cell.alignment)
        tgt_cell.protection = copy(src_cell.protection)
        if src_cell.has_style:
            pass
        if src_cell.hyperlink:
            tgt_cell._hyperlink = copy(src_cell.hyperlink)
        if src_cell.comment:
            tgt_cell.comment = copy(src_cell.comment)

# Ensure header remains intact (copy from target row 1 already there; do nothing)
wb.save(output_path)
print("Saved:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_post = load_workbook(output_path)
if wb_post.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_post.sheetnames, "-> restoring to", orig_sheet_names)
    # rename by position
    for i, desired in enumerate(orig_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = desired
    wb_post.save(output_path)
else:
    print("Sheet names unchanged after recalc.")

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

ws_verify = wb_verify[target_name]
verify_last_row = actual_last_row(ws_verify)

print("\nFinal Duplicates sheet rows A:E:")
for r in range(1, verify_last_row + 1):
    print(f"R{r}:", [ws_verify.cell(r, c).value for c in range(1, 6)])

# Also verify formula-free target cells and count
expected_output_rows = len(sorted_dup_rows)
actual_output_rows = max(0, verify_last_row - 1)
print("\nExpected output row count:", expected_output_rows)
print("Actual output row count:", actual_output_rows)

# Verify exact target rows not blank
blank_issues = []
for r in range(2, 2 + expected_output_rows):
    vals = [ws_verify.cell(r, c).value for c in range(1, 6)]
    if any(v is None for v in vals):
        blank_issues.append((r, vals))
print("Blank issues:", blank_issues)

# Reload non-data_only to inspect final written alignment/format in date column
wb_verify_fmt = load_workbook(output_path, data_only=False)
ws_verify_fmt = wb_verify_fmt[target_name]
print("\nFinal D column formatting/alignment in Duplicates:")
for r in range(2, 2 + expected_output_rows):
    cell = ws_verify_fmt.cell(r, 4)
    print(
        f"D{r}: value={cell.value!r}, number_format={cell.number_format!r}, "
        f"alignment_horizontal={cell.alignment.horizontal!r}"
    )

# Keep output path in a variable for submission next turn
final_output_spreadsheet = output_path
print("\nReady to submit:", final_output_spreadsheet)
```
