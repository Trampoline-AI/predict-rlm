import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input spreadsheet:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    print("Headers row 1:")
    for c, v in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}1 = {v!r}")
    
    # first 10 rows
    print("\nFirst 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, min(ws.max_column, 12))
        print(f"Row {r}: {vals}")
    
    # last 5 rows
    print("\nLast 5 rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = row_values(ws, r, min(ws.max_column, 12))
        print(f"Row {r}: {vals}")
    
    # specific inspection of columns I and J if they exist
    if ws.max_column >= 10:
        print("\nInspecting columns I and J (rows 1 to min(15, max_row)):")
        for r in range(1, min(ws.max_row, 15) + 1):
            ci = ws[f"I{r}"]
            cj = ws[f"J{r}"]
            print(
                f"Row {r}: "
                f"I{r} value={ci.value!r}, type={type(ci.value).__name__}, numfmt={ci.number_format!r}; "
                f"J{r} value={cj.value!r}, type={type(cj.value).__name__}, numfmt={cj.number_format!r}"
            )
    else:
        print("\nSheet has fewer than 10 columns; no I/J inspection possible.")
