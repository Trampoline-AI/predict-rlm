Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string
import os

# Load workbook
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheet_names)
print("Target header row:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Before writing, A2:", ws["A2"].value, "B2:", ws["B2"].value)
print("Column B index check:", column_index_from_string("B"))

# Identify actual rows needing output: non-empty A cells below header
target_rows = []
for r in range(2, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    b_val = ws.cell(r, 2).value
    if a_val not in (None, ""):
        target_rows.append(r)
        print(f"Row {r} current A/B:", a_val, b_val)

# Write formula to column B for all relevant rows
for r in target_rows:
    formula = f'=TRIM(LEFT(A{r},FIND(";",A{r}&";")-1))'
    ws.cell(r, 2).value = formula
    print(f"Wrote B{r} formula:", ws.cell(r, 2).value)

# Save
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload to check sheet names; restore if recalc changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheet_names:
    # rename sheets back by position
    for i, expected_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = expected_name
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas exist
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]
for r in target_rows:
    print(f"Formula in B{r}:", ws_formula[f'B{r}'].value)

# Verify cached results after recalculation
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

for r in target_rows:
    print(f"Verified values row {r}: A{r}={ws_values[f'A{r}'].value!r}, B{r}={ws_values[f'B{r}'].value!r}")

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
