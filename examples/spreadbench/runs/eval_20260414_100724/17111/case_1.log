```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
summary = wb["Summary"]
sheet1 = wb["Sheet1"]
original_sheetnames = wb.sheetnames[:]

# Determine actual data extent on Sheet1
last_row_sheet1 = 1
for r in range(sheet1.max_row, 0, -1):
    if any(sheet1.cell(r, c).value is not None for c in range(1, sheet1.max_column + 1)):
        last_row_sheet1 = r
        break

print("Original sheet names:", original_sheetnames)
print("Sheet1 data rows: 1 to", last_row_sheet1)
print("Summary target area before writing:")
for r in range(1, 7):
    print(f"Row {r}:", [summary.cell(r, c).value for c in range(1, 7)])

# Compute expected results in Python for verification
def norm(x):
    return "" if x is None else str(x).strip().lower()

allowed_statuses = {"completed", "not completed"}

# Build source records
records = []
for r in range(2, last_row_sheet1 + 1):
    status = sheet1.cell(r, 1).value
    name = sheet1.cell(r, 2).value
    typ = sheet1.cell(r, 3).value
    amt = sheet1.cell(r, 4).value
    if name is None and typ is None and amt is None and status is None:
        continue
    try:
        amt_num = float(amt)
    except Exception:
        continue
    records.append({
        "status": norm(status),
        "name": norm(name),
        "type": norm(typ),
        "amt": amt_num,
    })

expected = {}
target_rows = []
for r in range(2, summary.max_row + 1):
    name = summary.cell(r, 1).value
    if name is None or str(name).strip() == "":
        continue
    target_rows.append(r)
    name_n = norm(name)
    status_sel = summary.cell(r, 6).value
    status_n = norm(status_sel)
    for c in [2, 3]:
        typ = summary.cell(1, c).value
        typ_n = norm(typ)
        total = 0.0
        for rec in records:
            if rec["name"] == name_n and rec["type"] == typ_n:
                if status_n in {"", "both"}:
                    if rec["status"] in allowed_statuses:
                        total += rec["amt"]
                elif status_n in allowed_statuses:
                    if rec["status"] == status_n:
                        total += rec["amt"]
                else:
                    total += 0.0
        expected[(r, c)] = total

print("\nExpected values under intended logic (blank status = both allowed statuses):")
for r in target_rows:
    print(
        f"Row {r} name={summary.cell(r,1).value!r}, status={summary.cell(r,6).value!r} -> "
        f"HD={expected[(r,2)]}, SD={expected[(r,3)]}"
    )

# Show current formulas in target cells
print("\nExisting target cell formulas/values:")
for r in target_rows:
    print(
        f"B{r}={summary[f'B{r}'].value} | C{r}={summary[f'C{r}'].value}"
    )

# Write corrected formulas into Summary!B:C for all name rows
# Logic:
# - blank or Both => Completed + Not Completed
# - Completed / Not Completed => that status only
# - any other status => 0
for r in target_rows:
    for c in [2, 3]:
        col_letter = {2: "B", 3: "C"}[c]
        formula = (
            f'=IF(OR($F{r}="",$F{r}="Both"),'
            f'SUMIFS(Sheet1!$D$2:$D${last_row_sheet1},Sheet1!$B$2:$B${last_row_sheet1},$A{r},Sheet1!$C$2:$C${last_row_sheet1},{col_letter}$1,Sheet1!$A$2:$A${last_row_sheet1},"Completed")'
            f'+SUMIFS(Sheet1!$D$2:$D${last_row_sheet1},Sheet1!$B$2:$B${last_row_sheet1},$A{r},Sheet1!$C$2:$C${last_row_sheet1},{col_letter}$1,Sheet1!$A$2:$A${last_row_sheet1},"Not Completed"),'
            f'IF(OR($F{r}="Completed",$F{r}="Not Completed"),'
            f'SUMIFS(Sheet1!$D$2:$D${last_row_sheet1},Sheet1!$B$2:$B${last_row_sheet1},$A{r},Sheet1!$C$2:$C${last_row_sheet1},{col_letter}$1,Sheet1!$A$2:$A${last_row_sheet1},$F{r}),'
            f'0))'
        )
        summary.cell(r, c).value = formula

print("\nTarget cells after writing formulas:")
for r in target_rows:
    print(
        f"B{r}={summary[f'B{r}'].value}\nC{r}={summary[f'C{r}'].value}"
    )

# Save
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(outfile)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    rename_map = {}
    for i, old_name in enumerate(original_sheetnames):
        if i < len(wb_after.sheetnames):
            rename_map[wb_after.sheetnames[i]] = old_name
    for current_name, desired_name in rename_map.items():
        if current_name != desired_name:
            wb_after[current_name].title = desired_name
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)
else:
    print("Sheet names unchanged after recalc.")

# Verify using data_only
wb_verify = load_workbook(outfile, data_only=True)
print("\nVerification sheet names:", wb_verify.sheetnames)

summary_v = wb_verify["Summary"]
print("Verified target cells (data_only):")
verification_ok = True
for r in target_rows:
    b_val = summary_v.cell(r, 2).value
    c_val = summary_v.cell(r, 3).value
    print(
        f"Row {r}: Name={summary_v.cell(r,1).value!r}, Status={summary_v.cell(r,6).value!r}, "
        f"B{r}={b_val!r}, C{r}={c_val!r}, expected=({expected[(r,2)]}, {expected[(r,3)]})"
    )
    if b_val is None or c_val is None:
        verification_ok = False

output_spreadsheet = outfile
print("\nverification_ok:", verification_ok)
print("output_spreadsheet:", output_spreadsheet)
