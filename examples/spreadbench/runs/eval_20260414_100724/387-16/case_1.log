from openpyxl import load_workbook
from collections import Counter
from pathlib import Path
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Inspect exact target ranges again
print("Before modification:")
for coord in ["A2","B2","D2","D4","E2","G2","H2","J2","K2"]:
    print(coord, "=", ws[coord].value)

# Determine populated A/B rows and result-values rows
ab_start_row = 3
ab_end_row = ws.max_row  # 21 here, but keep general
ab_pairs = []
for r in range(ab_start_row, ab_end_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is not None or b is not None:
        ab_pairs.append((r, a, b))

result_values = []
for r in range(5, ws.max_row + 1):
    d = ws.cell(r, 4).value
    if d is not None:
        result_values.append(d)

print("\nOriginal A/B pairs:")
print(ab_pairs)
print("Result values:", result_values)

# Remove only one instance per occurrence in result_values, preserving order
to_remove = Counter(result_values)
remaining_pairs = []
removed_pairs = []

for r, a, b in ab_pairs:
    if a in to_remove and to_remove[a] > 0:
        removed_pairs.append((r, a, b))
        to_remove[a] -= 1
    else:
        remaining_pairs.append((a, b))

print("\nRemoved pairs:")
print(removed_pairs)
print("Remaining pairs to compact:")
print(remaining_pairs)

# Write compacted remaining pairs starting at row 3
write_row = ab_start_row
for a, b in remaining_pairs:
    ws.cell(write_row, 1).value = a
    ws.cell(write_row, 2).value = b
    write_row += 1

# Clear remaining old cells in A/B below compacted output
for r in range(write_row, ab_end_row + 1):
    ws.cell(r, 1).value = None
    ws.cell(r, 2).value = None

# Update formulas according to instruction
# Solver result should be the sum of column A over the data area
ws["H2"] = f"=SUM(A{ab_start_row}:A{ab_end_row})"
# Difference = solver result - target value
ws["K2"] = "=H2-E2"

# Save
Path(outdir).mkdir(parents=True, exist_ok=True)
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_post = load_workbook(outfile)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != original_sheetnames and len(post_names) == len(original_sheetnames):
    for i, old_name in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = old_name
    wb_post.save(outfile)
    print("Restored original sheet names:", original_sheetnames)

# Verify with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[original_sheetnames[0]]
print("\nVerification of written formulas:")
print("H2 formula:", wsf["H2"].value)
print("K2 formula:", wsf["K2"].value)

print("\nVerification of compacted A/B rows (formula workbook):")
for r in range(3, ab_end_row + 1):
    print(r, wsf.cell(r,1).value, wsf.cell(r,2).value)

# Verify evaluated values after recalculation
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[original_sheetnames[0]]

print("\nEvaluated key cells after recalc:")
for coord in ["E2","H2","K2"]:
    print(coord, "=", wsv[coord].value)

print("\nFinal A/B values after compaction:")
final_ab = []
for r in range(3, ab_end_row + 1):
    a = wsv.cell(r,1).value
    b = wsv.cell(r,2).value
    final_ab.append((r, a, b))
print(final_ab)

# Basic sanity checks
