from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

print("Instruction:")
print(instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_summary(ws, sample_first=8, sample_last=5):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            nonempty_rows.append(r)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None, "count:", len(nonempty_rows))
    
    # print first few rows with coordinates
    def row_vals(r):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            vals.append(v)
        return vals
    
    print("\nFirst rows:")
    for r in range(1, min(ws.max_row, sample_first) + 1):
        print(f"Row {r}: {row_vals(r)}")
    
    print("\nLast rows:")
    start = max(1, ws.max_row - sample_last + 1)
    for r in range(start, ws.max_row + 1):
        print(f"Row {r}: {row_vals(r)}")
    
    # candidate header rows: first 5 rows with some text
    print("\nCandidate header rows:")
    for r in range(1, min(ws.max_row, 6) + 1):
        vals = row_vals(r)
        if any(isinstance(v, str) and v.strip() for v in vals):
            headers = [f"{get_column_letter(i+1)}={vals[i]!r}" for i in range(len(vals)) if vals[i] is not None]
            print(f"Row {r}: {headers}")
    
    # search for instruction-related keywords
    keywords = ["Value", "Values", "Binaries", "Result", "Result values", "Difference", "solver", "Solver"]
    found = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                for kw in keywords:
                    if kw.lower() in v.lower():
                        found.append((r, c, v))
                        break
    print("\nKeyword matches:")
    for item in found[:50]:
        r, c, v = item
        print(f"{get_column_letter(c)}{r} = {v!r}")
    if len(found) > 50:
        print("... more omitted ...")

for ws in wb.worksheets:
    sheet_summary(ws)
