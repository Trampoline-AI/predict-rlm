# Write formulas only to blank Result cells where Code exists
written = 0
preserved = 0
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1)
    b = ws.cell(r, 2)
    if b.value not in (None, ""):
        if a.value in (None, ""):
            a.value = f'=IF(B{r}="","",VALUE(RIGHT(B{r},LEN(B{r})-3)))'
            written += 1
        else:
            preserved += 1

print("\nRows with formulas written:", written)
print("Existing nonblank Result cells preserved:", preserved)

