    print("Row 1 headers/values:", headers)
    if last_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, last_col + 1)]
        print("Row 2:", row2)
    if last_row >= 3:
        row3 = [ws.cell(3, c).value for c in range(1, last_col + 1)]
        print("Row 3:", row3)
    
    sample_top_end = min(last_row, 10)
    print(f"Top rows 1-{sample_top_end}:")
    for r in range(1, sample_top_end + 1):
        vals = [ws.cell(r, c).value for c in range(1, last_col + 1)]
        print(r, vals)
    
    if last_row > 10:
        start_last = max(1, last_row - 4)
        print(f"Last rows {start_last}-{last_row}:")
        for r in range(start_last, last_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, last_col + 1)]
            print(r, vals)
    
    # print formulas / non-empty cells in used range
    formula_cells = []
    for r in range(1, last_row + 1):
        for c in range(1, last_col + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((ws.cell(r, c).coordinate, v))
    print("Formula cells:", formula_cells[:50], "count=", len(formula_cells))
    
