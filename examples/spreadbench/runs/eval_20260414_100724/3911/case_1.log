wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def sheet_nonempty_bounds(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # find actual non-empty last row/col
    last_row = 0
    last_col = 0
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                last_col = max(last_col, c)
        if row_has:
            last_row = r
    return last_row, last_col

for ws in wb.worksheets:
    last_row, last_col = sheet_nonempty_bounds(ws)
    print(f"\n=== Sheet: {ws.title} ===")
    print("ws.max_row/max_column:", ws.max_row, ws.max_column)
    print("actual non-empty last row/col:", last_row, last_col, f"({get_column_letter(last_col) if last_col else 'N/A'})")
    
    # print first 10 rows x used columns
