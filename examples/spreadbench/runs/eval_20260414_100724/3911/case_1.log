Code:
```repl
import os
from functools import lru_cache
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload clean workbook from input
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)

# Identify employee rows from actual data
employee_rows = []
for r in range(2, ws.max_row + 1):
    empcode = ws.cell(r, 2).value
    salary = ws.cell(r, 5).value
    if empcode not in (None, "") and isinstance(salary, (int, float)):
        employee_rows.append(r)

print("Employee rows detected:", employee_rows)

# Identify denomination columns H:P and total column Q from row 1
denom_cols = {}
for c in range(8, 17):  # H:P
    header = ws.cell(1, c).value
    denom_cols[int(header)] = c
total_col = 17

denoms_desc = sorted(denom_cols.keys(), reverse=True)
print("Denomination columns:", {d: get_column_letter(c) for d, c in sorted(denom_cols.items(), reverse=True)})
print("Total column:", get_column_letter(total_col), ws.cell(1, total_col).value)

# Print current target range before writing
print("\nCurrent H1:Q8 before writing:")
for r in range(1, 9):
    print(r, [ws.cell(r, c).value for c in range(8, 18)])

# Read inventory from lower table (rows 13:21)
inventory = {d: 0 for d in denoms_desc}
for r in range(13, 22):
    denom = ws.cell(r, 3).value
    count = ws.cell(r, 4).value
    if isinstance(denom, (int, float)) and int(denom) in inventory:
        inventory[int(denom)] = int(count or 0)

print("\nInventory read from rows 13:21:", inventory)
print("Total notes available:", sum(inventory.values()))
print("Total amount available:", sum(d * cnt for d, cnt in inventory.items()))

# Employee salaries
employees = []
for r in employee_rows:
    employees.append({
        "row": r,
        "empcode": ws.cell(r, 2).value,
        "name": ws.cell(r, 3).value,
        "salary": int(ws.cell(r, 5).value),
    })

print("\nEmployees:")
for e in employees:
    print(e["row"], e["empcode"], e["name"], e["salary"])
print("Total salary:", sum(e["salary"] for e in employees))

# Base 1000-note allocation from actual structure/data
base_thousands = sum(e["salary"] // 1000 for e in employees)
print("\nSum of salary // 1000:", base_thousands, "Inventory 1000:", inventory[1000])

alloc = {e["row"]: {d: 0 for d in denoms_desc} for e in employees}
for e in employees:
    alloc[e["row"]][1000] = e["salary"] // 1000

# Remaining remainders must be built from sub-1000 denominations
small_denoms = [d for d in denoms_desc if d != 1000]
small_inventory = {d: inventory[d] for d in small_denoms}
remainders = [{"row": e["row"], "salary": e["salary"], "rem": e["salary"] % 1000} for e in employees]

print("Remainders:", [(x["row"], x["rem"]) for x in remainders])
print("Total remainder amount:", sum(x["rem"] for x in remainders))
print("Small-denom amount available:", sum(d * c for d, c in small_inventory.items()))

# Solve remainder allocation with backtracking on actual data
# Sort by larger remainder first for easier solving
remainders_sorted = sorted(remainders, key=lambda x: x["rem"], reverse=True)
small_denoms_desc = sorted(small_denoms, reverse=True)

def gen_combos_for_target(target, denoms, avail):
    results = []
    def rec(i, remaining, combo):
        if i == len(denoms):
            if remaining == 0:
                results.append(tuple(combo))
            return
        d = denoms[i]
        max_use = min(avail[i], remaining // d)
        for use in range(max_use, -1, -1):  # prefer larger denominations
            combo.append(use)
            rec(i + 1, remaining - use * d, combo)
            combo.pop()
    rec(0, target, [])
    return results

@lru_cache(None)
def solve_rem(idx, avail_tuple):
    if idx == len(remainders_sorted):
        # success only if all remainder amounts allocated exactly; leftover notes can remain only if amount 0
        return {}
    target = remainders_sorted[idx]["rem"]
    combos = gen_combos_for_target(target, small_denoms_desc, list(avail_tuple))
    for combo in combos:
        new_avail = tuple(avail_tuple[i] - combo[i] for i in range(len(avail_tuple)))
        if any(x < 0 for x in new_avail):
            continue
        sub = solve_rem(idx + 1, new_avail)
        if sub is not None:
            out = dict(sub)
            out[remainders_sorted[idx]["row"]] = {small_denoms_desc[i]: combo[i] for i in range(len(small_denoms_desc))}
            return out
    return None

start_avail = tuple(small_inventory[d] for d in small_denoms_desc)
solution = solve_rem(0, start_avail)
print("\nRemainder solution found:", solution is not None)

if solution is None:
    raise RuntimeError("Could not find a valid note allocation for the given salaries and inventory.")

# Merge small-denom solution into full allocation
for row, dmap in solution.items():
    for d, cnt in dmap.items():
        alloc[row][d] = cnt

# Validate against salary and inventory
row_checks = []
for e in employees:
    row = e["row"]
    total_amt = sum(d * alloc[row][d] for d in denoms_desc)
    row_checks.append((row, e["salary"], total_amt, alloc[row]))
    if total_amt != e["salary"]:
        raise RuntimeError(f"Row {row} total {total_amt} != salary {e['salary']}")

used_inventory = {d: sum(alloc[e["row"]][d] for e in employees) for d in denoms_desc}
print("\nRow checks:")
for item in row_checks:
    print(item[0], "salary=", item[1], "allocated=", item[2], "notes=", item[3])

print("\nUsed inventory vs source inventory:")
for d in denoms_desc:
    print(d, used_inventory[d], "/", inventory[d])
    if used_inventory[d] != inventory[d]:
        raise RuntimeError(f"Denomination {d} used {used_inventory[d]} != inventory {inventory[d]}")

print("Total notes used:", sum(used_inventory.values()))
print("Total amount used:", sum(d * used_inventory[d] for d in denoms_desc))

# Write results to H:Q for employee rows only
for e in employees:
    r = e["row"]
    for d in denoms_desc:
        ws.cell(r, denom_cols[d]).value = alloc[r][d]
    ws.cell(r, total_col).value = e["salary"]

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate as required
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename in order back to original names
    if len(wb_after.sheetnames) == len(orig_sheet_names):
        for i, old_name in enumerate(orig_sheet_names):
            wb_after.worksheets[i].title = old_name
        wb_after.save(out_path)
        print("Renamed sheets back to:", orig_sheet_names)
    else:
        raise RuntimeError(f"Sheet count changed unexpectedly: {wb_after.sheetnames} vs {orig_sheet_names}")

# Verification with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_sheet_names[0]]

print("\nVerified target range H1:Q8 after save/recalc:")
for r in range(1, 9):
    print(r, [wsv.cell(r, c).value for c in range(8, 18)])

# Verify totals per employee
print("\nPer-employee verification:")
for e in employees:
    r = e["row"]
    row_counts = {d: wsv.cell(r, denom_cols[d]).value for d in denoms_desc}
    q_val = wsv.cell(r, total_col).value
    calc_amt = sum(d * int(row_counts[d] or 0) for d in denoms_desc)
    print(r, e["empcode"], "Q=", q_val, "calc=", calc_amt, "counts=", row_counts)
    if q_val in (None, ""):
        raise RuntimeError(f"Q{r} is blank after save.")
    if calc_amt != e["salary"]:
        raise RuntimeError(f"Verification mismatch on row {r}: {calc_amt} != {e['salary']}")
    if int(q_val) != e["salary"]:
        raise RuntimeError(f"Q{r} value {q_val} != salary {e['salary']}")

# Verify denomination totals across employee rows
print("\nDenomination totals verification from written cells:")
for d in denoms_desc:
    total_used = sum(int(wsv.cell(e["row"], denom_cols[d]).value or 0) for e in employees)
    print(d, total_used, "expected", inventory[d])
    if total_used != inventory[d]:
        raise RuntimeError(f"Column {get_column_letter(denom_cols[d])} total mismatch for denom {d}")

output_spreadsheet = out_path
print("\nPrepared output file:", output_spreadsheet)
