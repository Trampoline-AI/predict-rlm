from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws):
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # Find first non-empty rows and headers
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)]
        print(f"Row {r} first cols:", vals)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Header row 1:", headers[:20])
    if ws.max_row >= 2:
        headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row 2:", headers2[:20])
    # first 10 rows
    print("First rows sample:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)]
        print(f"  R{r}:", vals)
    # last 5 rows
    print("Last rows sample:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)]
        print(f"  R{r}:", vals)

for ws in wb.worksheets:
    sheet_summary(ws)

# Search formulas and relevant cells
print("\n=== Searching for formulas / relevant patterns ===")
matches = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                if any(k in v.upper() for k in ["INDEX", "MATCH", "SUM"]):
                    matches.append((ws.title, cell.coordinate, v))
print("Relevant formula cells found:", len(matches))
for item in matches[:100]:
    print(item)

# Search for exact text in instruction pattern area
target_like = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if v == '=SUM(INDEX(B3:B5,0,MATCH(A7,$B$2:$Z$2,0)))':
                target_like.append((ws.title, cell.coordinate, v))
print("Exact formula matches:", target_like)

# Print a broader neighborhood around formula cells
for ws_name, coord, formula in matches[:20]:
    ws = wb[ws_name]
    row = ws[coord].row
    col = ws[coord].column
    print(f"\nNeighborhood around {ws_name}!{coord} -> {formula}")
    for r in range(max(1, row-2), min(ws.max_row, row+2)+1):
        vals = []
        for c in range(max(1, col-3), min(ws.max_column, col+3)+1):
            vals.append(f"{get_column_letter(c)}{r}={ws.cell(r,c).value}")
        print(" | ".join(vals))
