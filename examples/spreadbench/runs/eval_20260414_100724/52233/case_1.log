from openpyxl import load_workbook
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print current target area before modification
print("Before modification:")
for r in range(7, 11):
    print(f"A{r}={ws[f'A{r}'].value!r}, B{r}={ws[f'B{r}'].value!r}")

# Correct formula pattern: fixed data rows, dynamic lookup row
for r in range(7, 11):
    ws[f"B{r}"] = f"=SUM(INDEX($B$3:$E$5,0,MATCH(A{r},$B$2:$E$2,0)))"

# Print formulas after modification
print("\nAfter modification (formulas written):")
for r in range(7, 11):
    print(f"B{r} formula -> {ws[f'B{r}'].value}")

# Save
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "restoring to", orig_sheetnames)
    for i, expected in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("\nVerification - formulas in B7:B10:")
for r in range(7, 11):
    print(f"B{r}: {ws_formula[f'B{r}'].value}")

# Verify calculated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]
print("\nVerification - calculated values in B7:B10:")
for r in range(7, 11):
    print(f"A{r}={ws_values[f'A{r}'].value!r}, B{r}={ws_values[f'B{r}'].value!r}")

output_spreadsheet = outfile
