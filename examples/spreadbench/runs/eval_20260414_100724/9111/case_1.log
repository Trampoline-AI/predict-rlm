    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 values / headers:", headers)
    if ws.max_row >= 2:
        print("Row 2 values:", row_values(ws, 2, ws.max_column))
    
    first_n = min(10, ws.max_row)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast {ws.max_row - start_last + 1} rows:")
    for r in range(start_last, ws.max_row + 1):
