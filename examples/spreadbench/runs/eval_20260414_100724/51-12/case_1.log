import os
from openpyxl import load_workbook

# Load workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Compute the count for A1:M1 using the described restart logic
values = [ws.cell(1, c).value for c in range(1, 14)]
print("Input A1:M1 values:", values)

count = 0
hits = []
i = 0
while i < len(values):
    ref = values[i]
    if ref is None:
        break
    found = False
    for j in range(i + 1, len(values)):
        v = values[j]
        if v is None:
            break
        if v >= ref * 1.10:
            count += 1
            hits.append((i + 1, j + 1, ref, v, count))  # 1-based cols
            i = j + 1  # restart from cell immediately right of the found cell
            found = True
            break
    if not found:
        break

print("Detected hits:", hits)
print("Computed count:", count)
print("Current B6 before write:", ws["B6"].value)

# Write result to the exact target cell
ws["B6"] = count

