from decimal import Decimal
import os
from openpyxl import load_workbook

def to_decimal(x):
    if x is None or x == "":
        return None
    return Decimal(str(x))

def count_restart_10pct(vals):
    vals = [to_decimal(v) for v in vals]
    count = 0
    hits = []
    i = 0
    while i < len(vals):
        ref = vals[i]
        if ref is None:
            break
        found = False
        threshold = ref * Decimal("1.10")
        for j in range(i + 1, len(vals)):
            v = vals[j]
            if v is None:
                break
            if v >= threshold:
                count += 1
                hits.append((i + 1, j + 1, float(ref), float(v), count))
                i = j + 1  # restart from the cell immediately right of the hit
                found = True
                break
        if not found:
            break
    return count, hits

# Reload original input, recompute correctly, and write to B6
wb = load_workbook(input_spreadsheet)
orig_names = wb.sheetnames[:]
ws = wb["Sheet1"]

row_vals = [ws.cell(1, c).value for c in range(1, 14)]
print("A1:M1 values:", row_vals)
print("Existing B6 before fix:", ws["B6"].value)
print("Row 2 markers A2:M2:", [ws.cell(2, c).value for c in range(1, 14)])

correct_count, correct_hits = count_restart_10pct(row_vals)
print("Correct hits:", correct_hits)
print("Correct count:", correct_count)

ws["B6"] = correct_count

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved fixed workbook to:", out_path)

recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalc changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb_check.worksheets[i].title = name
    wb_check.save(out_path)
    print("Restored sheet names:", wb_check.sheetnames)

# Verify target cells
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["Sheet1"]
print("Verified B6:", wsv["B6"].value)
print("Verified A1:M1:", [wsv.cell(1, c).value for c in range(1, 14)])
print("Verified row 2 A2:M2:", [wsv.cell(2, c).value for c in range(1, 14)])

output_spreadsheet = out_path
```
