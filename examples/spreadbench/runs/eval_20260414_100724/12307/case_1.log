from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]
original_sheetnames = wb.sheetnames[:]

print("Sheet names:", wb.sheetnames)
print("Merged ranges:", list(ws.merged_cells.ranges))
print("Tables:", list(ws.tables.keys()) if hasattr(ws, "tables") else [])

print("\nAll non-empty cells with coordinates:")
nonempty = []
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None:
            nonempty.append((ws.cell(r, c).coordinate, v))
