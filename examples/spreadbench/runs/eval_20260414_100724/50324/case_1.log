print("Workbook sheets:", wb.sheetnames)

def nonempty_bounds(ws):
    min_row = None
    max_row = 0
    min_col = None
    max_col = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                if min_row is None or cell.row < min_row:
                    min_row = cell.row
                if min_col is None or cell.column < min_col:
                    min_col = cell.column
                if cell.row > max_row:
                    max_row = cell.row
                if cell.column > max_col:
                    max_col = cell.column
    return min_row, max_row, min_col, max_col

def row_values(ws, r, c1, c2):
    vals = []
    for c in range(c1, c2+1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

for s in wb.sheetnames:
    ws = wb[s]
    b = nonempty_bounds(ws)
    print(f"\nSheet={s!r}, max_row={ws.max_row}, max_col={ws.max_column}, nonempty_bounds={b}")
    min_row, max_row, min_col, max_col = b
    if min_row is None:
        continue
    c1 = max(1, min_col)
    c2 = min(ws.max_column, max_col, c1 + 11)  # print up to 12 cols
    print("Columns shown:", [f"{get_column_letter(c)}" for c in range(c1, c2+1)])
    # first 10 rows in used range
    first_rows = list(range(min_row, min(max_row, min_row + 9) + 1))
    last_rows = list(range(max(min_row, max_row - 4), max_row + 1))
    print("First rows:")
