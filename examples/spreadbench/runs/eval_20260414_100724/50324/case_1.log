from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
print("FULL INSTRUCTION:\n", instruction)

# Reconfirm exact relevant areas
for s in ["Datensatz", "Analyse"]:
    ws = wb[s]
    print(f"\n--- {s} compact inspection ---")
    for r in range(1, ws.max_row + 1):
        if s == "Datensatz" and r > 10 and r < ws.max_row - 4:
            continue
        vals = [ws.cell(r, c).value for c in range(3, min(ws.max_column, 11) + 1)]
        print(f"Row {r:>2} C:K -> {vals}")

ws_data = wb["Datensatz"]
ws_an = wb["Analyse"]

# Exact target range
print("\nAnalyse target area C4:K12")
for r in range(4, 13):
    row = []
    for c in range(3, 12):
        cell = ws_an.cell(r, c)
        row.append(f"{get_column_letter(c)}{r}={cell.value!r}")
    print(" | ".join(row))

# Build boolean purchase matrix (>0 means product sold)
headers = [ws_data.cell(3, c).value for c in range(4, 12)]
customers = [ws_data.cell(r, 3).value for r in range(4, 34)]
purchase = {}
for c in range(4, 12):
    product = ws_data.cell(3, c).value
    vals = []
    for r in range(4, 34):
        v = ws_data.cell(r, c).value
        vals.append(1 if (isinstance(v, (int, float)) and v > 0) else 0)
    purchase[product] = vals

print("\nProduct purchase counts (>0):")
for p in headers:
    print(p, sum(purchase[p]))

# Candidate matrices
def mat_total():
    out = {}
    total = len(customers)
    for rp in headers:
        out[rp] = {}
        for cp in headers:
            both = sum(1 for a, b in zip(purchase[rp], purchase[cp]) if a and b)
            out[rp][cp] = both / total
    return out

def mat_rowden():
    out = {}
    for rp in headers:
        denom = sum(purchase[rp])
        out[rp] = {}
        for cp in headers:
            both = sum(1 for a, b in zip(purchase[rp], purchase[cp]) if a and b)
            out[rp][cp] = None if denom == 0 else both / denom
    return out

def mat_colden():
    out = {}
    for rp in headers:
        out[rp] = {}
        for cp in headers:
            denom = sum(purchase[cp])
            both = sum(1 for a, b in zip(purchase[rp], purchase[cp]) if a and b)
            out[rp][cp] = None if denom == 0 else both / denom
    return out

mt = mat_total()
mr = mat_rowden()
mc = mat_colden()

def print_matrix(title, m):
    print(f"\n{title}")
    print("rows=base product, cols=paired product")
    print("      " + " | ".join([p.replace("Product ", "P") for p in headers]))
    for rp in headers:
