        for cp in headers:
            v = m[rp][cp]
            vals.append("None" if v is None else f"{v:.9f}")
        print(rp.replace("Product ", "P").ljust(6), " | ".join(vals))

print_matrix("Candidate A: both sold / total customers", mt)
print_matrix("Candidate B: both sold / customers who bought ROW product", mr)
print_matrix("Candidate C: both sold / customers who bought COLUMN product", mc)
