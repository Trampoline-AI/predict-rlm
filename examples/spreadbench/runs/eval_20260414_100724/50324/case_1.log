```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
from openpyxl.styles import PatternFill

# Paths
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws_data = wb["Datensatz"]
ws_an = wb["Analyse"]

print("Original sheet names:", orig_sheetnames)
print("Target range in Analyse is D5:K12")
print("Column indices: D=", column_index_from_string("D"), " K=", column_index_from_string("K"))

# Confirm current target values before writing
print("\nCurrent Analyse!D5:K12 before writing:")
for r in range(5, 13):
    print(r, [ws_an.cell(r, c).value for c in range(4, 12)])

# Build product -> source column mapping from Datensatz headers
data_headers = {}
for c in range(4, 12):
    product = ws_data.cell(3, c).value
    data_headers[product] = c

analyse_col_headers = [ws_an.cell(4, c).value for c in range(4, 12)]
analyse_row_headers = [ws_an.cell(r, 3).value for r in range(5, 13)]

print("\nDatensatz header mapping:")
for k, v in data_headers.items():
    print(f"{k} -> {get_column_letter(v)}")

print("\nAnalyse column headers:", analyse_col_headers)
print("Analyse row headers:", analyse_row_headers)

# Compute expected values in Python for verification / fallback
customer_rows = list(range(4, 34))
total_customers = len(customer_rows)
expected = {}

for row_product in analyse_row_headers:
    expected[row_product] = {}
    row_col = data_headers[row_product]
    for col_product in analyse_col_headers:
        col_col = data_headers[col_product]
        if row_product == col_product:
            val = 1.0
        else:
            both = 0
            for rr in customer_rows:
                a = ws_data.cell(rr, row_col).value
                b = ws_data.cell(rr, col_col).value
                a_pos = isinstance(a, (int, float)) and a > 0
                b_pos = isinstance(b, (int, float)) and b > 0
                if a_pos and b_pos:
                    both += 1
            val = both / total_customers
        expected[row_product][col_product] = val

print("\nExpected sample values:")
for coord_info in [("D5", "Product 1", "Product 1"),
                   ("E5", "Product 1", "Product 2"),
                   ("D6", "Product 2", "Product 1"),
                   ("K12", "Product 8", "Product 8")]:
    coord, rp, cp = coord_info
    print(coord, expected[rp][cp])

# Apply formulas, formatting, and fill
fill = PatternFill(start_color="FFF2F2F2", end_color="FFF2F2F2", fill_type="solid")
numfmt = "0.#########"  # up to 9 decimals, no trailing zeros, 1 stays as 1

for r in range(5, 13):
    row_product = ws_an.cell(r, 3).value
    row_src_col = data_headers[row_product]
    row_src_letter = get_column_letter(row_src_col)
    for c in range(4, 12):
        col_product = ws_an.cell(4, c).value
        col_src_col = data_headers[col_product]
        col_src_letter = get_column_letter(col_src_col)
        target = ws_an.cell(r, c)
        # Direct-range COUNTIFS formula for robustness in LibreOffice
        formula = (
            f'=IF($C{r}={get_column_letter(c)}$4,1,'
            f'COUNTIFS('
            f'Datensatz!${row_src_letter}$4:${row_src_letter}$33,">0",'
            f'Datensatz!${col_src_letter}$4:${col_src_letter}$33,">0"'
            f')/ROWS(Datensatz!$C$4:$C$33))'
        )
        target.value = formula
        target.number_format = numfmt
        target.fill = fill

# Save workbook with formulas
wb.save(output_path)
print("\nSaved formula workbook to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Ensure sheet names remain the same after recalculation
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames and len(wb_post.sheetnames) == len(orig_sheetnames):
    for ws_obj, orig_name in zip(wb_post.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    wb_post.save(output_path)
    print("Renamed sheets back to original names:", orig_sheetnames)

# Verify formulas and cached values
wb_formula_check = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
ws_an_formula = wb_formula_check["Analyse"]
ws_an_values = wb_values["Analyse"]

print("\nFormula samples:")
for coord in ["D5", "E5", "D6", "K12"]:
    print(coord, "->", ws_an_formula[coord].value)

# Read entire target matrix
value_matrix = []
none_cells = []
error_like = []
mismatch_cells = []

for r in range(5, 13):
    row_vals = []
    row_product = ws_an_values.cell(r, 3).value
    for c in range(4, 12):
        col_product = ws_an_values.cell(4, c).value
        coord = f"{get_column_letter(c)}{r}"
        v = ws_an_values.cell(r, c).value
        row_vals.append(v)
        if v is None or v == "":
            none_cells.append(coord)
        if isinstance(v, str) and v.startswith("#"):
            error_like.append((coord, v))
        exp = expected[row_product][col_product]
        if isinstance(v, (int, float)):
            if abs(v - exp) > 1e-9:
                mismatch_cells.append((coord, v, exp))
        else:
            if v not in (None, "") and not (isinstance(v, str) and v.startswith("#")):
                mismatch_cells.append((coord, v, exp))
    value_matrix.append(row_vals)

print("\nVerified Analyse!D5:K12 values after recalculation:")
for idx, row_vals in enumerate(value_matrix, start=5):
    print(idx, row_vals)

print("\nNone cells:", none_cells)
print("Error-like cells:", error_like[:10])
print("Mismatch sample:", mismatch_cells[:10])

# Fallback to static values if formulas did not evaluate correctly
if none_cells or error_like:
    print("\nFormula evaluation incomplete; falling back to static computed values.")
    wb_fix = load_workbook(output_path)
    ws_fix = wb_fix["Analyse"]
    for r in range(5, 13):
        row_product = ws_fix.cell(r, 3).value
        for c in range(4, 12):
            col_product = ws_fix.cell(4, c).value
            cell = ws_fix.cell(r, c)
            cell.value = expected[row_product][col_product]
            cell.number_format = numfmt
            cell.fill = fill
    wb_fix.save(output_path)
    recalc_result2 = await recalculate(output_path)
    print("Recalculate after fallback:", recalc_result2)

    wb_post2 = load_workbook(output_path)
    if wb_post2.sheetnames != orig_sheetnames and len(wb_post2.sheetnames) == len(orig_sheetnames):
        for ws_obj, orig_name in zip(wb_post2.worksheets, orig_sheetnames):
            ws_obj.title = orig_name
        wb_post2.save(output_path)
        print("Renamed sheets back after fallback.")

    wb_values2 = load_workbook(output_path, data_only=True)
    ws_an_values2 = wb_values2["Analyse"]
    print("\nFinal verified Analyse!D5:K12 after fallback:")
    for r in range(5, 13):
        print(r, [ws_an_values2.cell(r, c).value for c in range(4, 12)])

# Final spot-check of fill and number format from normal workbook
wb_final_style = load_workbook(output_path, data_only=False)
ws_final_style = wb_final_style["Analyse"]
print("\nStyle checks:")
for coord in ["D5", "E5", "K12"]:
    cell = ws_final_style[coord]
    print(coord, "number_format=", cell.number_format, "fill=", cell.fill.start_color.rgb)

output_spreadsheet = output_path
print("\nPrepared output file:", output_spreadsheet)
