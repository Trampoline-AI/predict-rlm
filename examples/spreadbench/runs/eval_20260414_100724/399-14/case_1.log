```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
output_path = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Helper
def is_numeric(x):
    return isinstance(x, (int, float)) and not isinstance(x, bool)

def is_whole_number(x, tol=1e-9):
    return is_numeric(x) and abs(x - round(x)) < tol

# 1) Apply 等线 font throughout the used sheet area, preserving other font properties
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        new_font = copy(cell.font)
        new_font.name = "等线"
        cell.font = new_font

# 2) Split regular/overtime hours for numeric rows in column N
changed_rows = []
for r in range(1, ws.max_row + 1):
    n_cell = ws.cell(r, 14)  # N
    o_cell = ws.cell(r, 15)  # O
    n_val = n_cell.value
    
    if is_numeric(n_val):
        original_hours = float(n_val)
        # Only process data rows; numeric header rows do not exist here, but this is safe
        if original_hours > 40:
            overtime = round(original_hours - 40, 2)
            n_cell.value = 40
            o_cell.value = overtime
            changed_rows.append((r, original_hours, n_cell.value, o_cell.value))
        else:
            # Keep REG unchanged; preserve OT blank if already blank
            if o_cell.value in ("",):
                o_cell.value = None

# 3) Apply number formatting to columns N, O, P for numeric cells
for col in [14, 15, 16]:  # N, O, P
    for r in range(1, ws.max_row + 1):
        cell = ws.cell(r, col)
        v = cell.value
        if is_numeric(v):
            if is_whole_number(float(v)):
                cell.number_format = "General"
            else:
                cell.number_format = "#,##0.##"

# Save before recalculation
wb.save(output_path)
print("Saved initial output to:", output_path)
print("Changed rows:", changed_rows)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# 4) Restore original sheet names if recalculation changed them
wb_post = load_workbook(output_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != original_sheetnames and len(post_names) == len(original_sheetnames):
    for i, expected_name in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = expected_name
    wb_post.save(output_path)
    print("Restored sheet names to:", original_sheetnames)
else:
    print("No sheet name restoration needed.")

# 5) Verification: reload workbook for styles and values
wb_verify = load_workbook(output_path)
ws_verify = wb_verify[original_sheetnames[0]]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target range N6:P23")
for r in range(6, 24):
    vals = [ws_values.cell(r, c).value for c in range(14, 17)]
    print(f"Row {r}: N/O/P = {vals}")

print("\nVerification of changed rows only:")
for r, original_hours, _, _ in changed_rows:
    n_v = ws_values.cell(r, 14).value
    o_v = ws_values.cell(r, 15).value
    p_v = ws_values.cell(r, 16).value
    print(f"Row {r}: original N={original_hours} -> N={n_v}, O={o_v}, P={p_v}")

print("\nVerify fonts:")
for coord in ["L6", "M6", "N6", "O6", "P6", "N12", "O12", "P12"]:
    c = ws_verify[coord]
    print(coord, "font.name=", c.font.name, "numfmt=", c.number_format, "value=", c.value)

print("\nVerify number formats in N/O/P for data rows:")
for r in range(7, 24):
    print(
        f"r{r}:",
        "N", ws_verify.cell(r,14).value, ws_verify.cell(r,14).number_format,
        "| O", ws_verify.cell(r,15).value, ws_verify.cell(r,15).number_format,
        "| P", ws_verify.cell(r,16).value, ws_verify.cell(r,16).number_format,
    )

# Sanity assertions
assert wb_values.sheetnames == original_sheetnames, f"Sheet names mismatch: {wb_values.sheetnames} vs {original_sheetnames}"

# Expected overtime rows should now have values in O and 40 in N
for r in [12, 15, 16, 18, 21, 22]:
    assert ws_values.cell(r, 14).value == 40, f"N{r} not 40"
    assert ws_values.cell(r, 15).value is not None, f"O{r} should have overtime"

# Non-overtime rows should remain with O blank
for r in [7, 8, 9, 10, 11, 13, 14, 17, 19, 20, 23]:
    assert ws_values.cell(r, 15).value in (None, ""), f"O{r} should be blank"

print("\nAll verification checks passed.")
