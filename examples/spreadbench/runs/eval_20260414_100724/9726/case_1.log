from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Dimensions:", ws.calculate_dimension(), "max_row", ws.max_row, "max_col", ws.max_column)

# Print non-empty cells by row for all rows
print("\nNon-empty cells by row:")
for r in range(1, ws.max_row + 1):
    vals = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None:
            vals.append(f"{get_column_letter(c)}{r}={v!r}")
    if vals:
        print(r, vals)

# Inspect Table 2 area in detail
print("\nDetailed H:J rows 1-10:")
for r in range(1, min(10, ws.max_row) + 1):
    row = []
    for c in range(8, 11):
        cell = ws.cell(r, c)
        v = cell.value
        info = {"coord": cell.coordinate, "type": type(v).__name__, "value": v}
        if isinstance(v, ArrayFormula):
            info["text"] = getattr(v, "text", None)
            info["ref"] = getattr(v, "ref", None)
        row.append(info)
    print(row)

# Inspect target cell J2 thoroughly
