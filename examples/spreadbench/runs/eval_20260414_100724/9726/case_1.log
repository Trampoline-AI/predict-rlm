```repl
import os
from collections import defaultdict
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook normally for editing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheet names:", orig_sheetnames)

# Build Table 1 source data from A:C
source_rows = []
for r in range(2, ws.max_row + 1):
    student = ws.cell(r, 1).value  # A
    visit_date = ws.cell(r, 3).value  # C
    if student is not None and visit_date is not None:
        source_rows.append((r, student, visit_date))

print("Source rows found:", source_rows)

visits_by_student = defaultdict(list)
for r, student, visit_date in source_rows:
    visits_by_student[str(student).strip()].append(visit_date)

for student in visits_by_student:
    visits_by_student[student].sort()

# Find relevant Table 2 rows in H:J
target_rows = []
for r in range(2, ws.max_row + 1):
    student = ws.cell(r, 8).value  # H
    submission = ws.cell(r, 9).value  # I
    current = ws.cell(r, 10).value  # J
    if student is not None or submission is not None or current is not None:
        target_rows.append((r, student, submission, current))

print("Target rows before update:", [
    (r, s, sub, type(cur).__name__, getattr(cur, "text", cur)) for r, s, sub, cur in target_rows
])

# Apply update to ALL relevant target rows with actual student/submission values
updated = []
for r, student, submission, current in target_rows:
    if student is None or submission is None:
        continue
    student_key = str(student).strip()
    candidate_dates = [d for d in visits_by_student.get(student_key, []) if d < submission]
    chosen = max(candidate_dates) if candidate_dates else None

    cell = ws.cell(r, 10)  # J
    before = cell.value

    # Write literal date result (or blank if no prior visit exists)
    cell.value = chosen

    # Preserve date formatting from existing J cell if present, otherwise copy from I/C
    if ws.cell(r, 10).number_format:
        pass
    if chosen is not None:
        # If target format is generic, align with source date format
        if not cell.number_format or cell.number_format == "General":
            cell.number_format = ws["C2"].number_format or ws["I2"].number_format
    updated.append((r, student_key, submission, before, chosen))

print("Updated rows:")
for item in updated:
    r, student_key, submission, before, chosen = item
    print(
        f"row {r}: student={student_key}, submission={submission}, "
        f"before={getattr(before, 'text', before)}, after={chosen}"
    )

# Save initial output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc; restore sheet names if LibreOffice changed them
wb_after = load_workbook(outfile)
after_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", after_names)

if after_names != orig_sheetnames and len(after_names) == len(orig_sheetnames):
    for i, expected in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

wsv = wb_verify[orig_sheetnames[0]]

# Print all target cells/ranges mentioned
print("Verification of Table 2 H:J:")
for r in range(1, ws.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(8, 11)]
    if any(v is not None for v in vals):
        print(r, vals)

# Specific verification for J2
print("J2 verified value:", wsv["J2"].value)
print("Expected prior date for H2/I2 should be 2016-06-12 00:00:00")

output_spreadsheet = outfile
