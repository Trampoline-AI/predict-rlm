        row_has = False
        for c in row:
            if c.value is not None:
                row_has = True
                last_col = max(last_col, c.column)
        if row_has:
            last_row = row[0].row
    print(f"last_nonempty_row={last_row}, last_nonempty_col={last_col} ({get_column_letter(last_col) if last_col else 'N/A'})")
    
    # Row 1-5 as potential headers/sample
