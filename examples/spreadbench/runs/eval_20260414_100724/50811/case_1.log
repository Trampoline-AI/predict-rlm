from openpyxl import load_workbook
from pathlib import Path
import os, shutil

infile = Path(input_spreadsheet)
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / infile.name

# Copy original first
shutil.copy2(infile, outfile)

wb = load_workbook(outfile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Reconfirm exact source data bounds from the lookup table above the target area
source_start = 5
source_end = 0
for r in range(source_start, 20):  # source table is above row 20
    if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
        source_end = r
print("Using source rows:", source_start, "to", source_end)

# Print current target values/formulas before writing
print("Before writing:")
for coord in ["D21", "D22", "D23"]:
    print(coord, "value=", ws[coord].value, "number_format=", ws[coord].number_format)

def build_formula(r, start_row, end_row):
    match_client = f'MATCH($C{r},$C${start_row}:$C${end_row},0)'
    formula = (
        f'=IF(OR($B{r}="",$C{r}=""),"",'
        f'IFERROR('
        f'IF(INDEX($F${start_row}:$F${end_row},{match_client})=$B{r},INDEX($H${start_row}:$H${end_row},{match_client}),'
        f'IF(INDEX($I${start_row}:$I${end_row},{match_client})=$B{r},INDEX($K${start_row}:$K${end_row},{match_client}),'
        f'IF(INDEX($L${start_row}:$L${end_row},{match_client})=$B{r},INDEX($N${start_row}:$N${end_row},{match_client}),'
        f'IF(INDEX($O${start_row}:$O${end_row},{match_client})=$B{r},INDEX($Q${start_row}:$Q${end_row},{match_client}),'
        f'IF(INDEX($R${start_row}:$R${end_row},{match_client})=$B{r},INDEX($T${start_row}:$T${end_row},{match_client}),"")))))'
        f',""))'
    )
    return formula

# Write formulas into the exact yellow target cells D21:D23
written = {}
for r in range(21, 24):
    formula = build_formula(r, source_start, source_end)
    ws.cell(r, 4).value = formula
    written[f"D{r}"] = formula

print("\nWritten formulas:")
for coord, formula in written.items():
    print(coord, formula)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(str(outfile))
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for i, old_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas are present in the formula workbook
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("\nVerification of formulas in targets:")
for coord in ["D21", "D22", "D23"]:
    print(coord, ws_formula[coord].value)

# Verify cached evaluated values after recalc
wb_values = load_workbook(outfile, data_only=True)
# if sheet names changed unexpectedly and were not restored, fall back to first sheet
verify_sheet = orig_sheet_names[0] if orig_sheet_names[0] in wb_values.sheetnames else wb_values.sheetnames[0]
ws_values = wb_values[verify_sheet]

print("\nVerification of evaluated target values:")
for coord in ["D21", "D22", "D23"]:
    print(coord, ws_values[coord].value)

# Also print rep/client/% rows for exact target range
print("\nFinal target area B20:D23:")
for r in range(20, 24):
    print(r, [ws_values.cell(r, c).value for c in range(2, 5)])

output_spreadsheet = str(outfile)
print("\nPrepared output_spreadsheet:", output_spreadsheet)
