def cell_disp(cell):
    v = cell.value
    if hasattr(v, "text"):  # ArrayFormula or similar
        v = f"<FORMULA_OBJ:{v.text}>"
    fill = cell.fill
    fill_info = None
    if fill and fill.fill_type:
        fill_info = {
            "fill_type": fill.fill_type,
            "start": getattr(fill.start_color, "rgb", None),
            "end": getattr(fill.end_color, "rgb", None),
            "index": getattr(fill.start_color, "index", None),
        }
    return {"coord": cell.coordinate, "value": v, "fill": fill_info}

for ws in wb.worksheets:
    print("\n" + "="*80)
