import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
print("Sheet names:", original_sheetnames)

def cell_display(v):
    if v is None:
        return None
    s = str(v)
    if len(s) > 60:
        s = s[:57] + "..."
    return s

workbook_info = {}

for ws in wb.worksheets:
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    # also inspect row 2 in case row 1 isn't true header
    row2 = [ws.cell(2, c).value for c in range(1, max_col + 1)] if max_row >= 2 else []
    
    # collect sample rows: first 10 and last 5
    sample_first = []
    for r in range(1, min(max_row, 10) + 1):
        row_vals = [cell_display(ws.cell(r, c).value) for c in range(1, max_col + 1)]
        sample_first.append((r, row_vals))
    sample_last = []
    start_last = max(1, max_row - 4)
    for r in range(start_last, max_row + 1):
        row_vals = [cell_display(ws.cell(r, c).value) for c in range(1, max_col + 1)]
        sample_last.append((r, row_vals))
    
    # find formulas
    formulas = []
    for r in range(1, max_row + 1):
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    workbook_info[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers_row1": headers,
        "row2": row2,
        "sample_first": sample_first,
        "sample_last": sample_last,
        "formulas": formulas[:20],
        "formula_count": len(formulas),
    }

for sheet, info in workbook_info.items():
    print("\n" + "="*80)
    print(f"Sheet: {sheet}")
    print(f"Dimensions: rows={info['max_row']}, cols={info['max_col']}")
    print("Row 1 headers:", [cell_display(x) for x in info["headers_row1"]])
    print("Row 2:", [cell_display(x) for x in info["row2"]])
    print("First rows:")
    for r, vals in info["sample_first"]:
        print(f"  Row {r}: {vals}")
    print("Last rows:")
    for r, vals in info["sample_last"]:
        print(f"  Row {r}: {vals}")
    print(f"Formula count: {info['formula_count']}")
    if info["formulas"]:
        print("Sample formulas:", info["formulas"])

# Extra targeted scan for relevant headers/keywords
keywords = ["department", "status", "turnaround", "average", "avg", "review", "progress"]
for ws in wb.worksheets:
    hits = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                low = v.lower()
                if any(k in low for k in keywords):
                    hits.append((f"{get_column_letter(c)}{r}", v))
    print(f"\nKeyword hits in {ws.title} (up to 40):", hits[:40])
