```repl
import os
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheet names:", orig_sheetnames)

# Print relevant current values / target area before writing
print("\nCurrent source data rows 1:7")
for r in range(1, 8):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

print("\nCurrent calculation area rows 9:13")
for r in range(9, 14):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

# Identify target rows under the calculation table
# We verified row 10 is the header row for the output table.
target_rows = []
r = 11
while r <= ws.max_row:
    dept = ws.cell(r, 1).value
    if dept is None or str(dept).strip() == "":
        break
    target_rows.append(r)
    r += 1

print("\nTarget rows detected:", target_rows)
for r in target_rows:
    print(f"A{r}={ws[f'A{r}'].value!r}, B{r}={ws[f'B{r}'].value!r}, B{r} number_format={ws[f'B{r}'].number_format!r}")

# Compute averages according to instruction:
# status in {"In Progress", "In Review"} and turnaround >= 6
allowed_status = {"In Progress", "In Review"}
dept_values = defaultdict(list)

for r in range(2, 8):  # actual data area observed from inspection
    dept = ws.cell(r, 1).value
    status = ws.cell(r, 2).value
    tat = ws.cell(r, 3).value
    try:
        tat_num = float(tat) if tat is not None and str(tat).strip() != "" else None
    except Exception:
        tat_num = None
    if dept is not None and status in allowed_status and tat_num is not None and tat_num >= 6:
        dept_values[str(dept)].append(tat_num)

computed = {}
for r in target_rows:
    dept = ws.cell(r, 1).value
    vals = dept_values.get(str(dept), [])
    if vals:
        avg = sum(vals) / len(vals)
        # write integer if whole number, else float
        computed[str(dept)] = int(avg) if float(avg).is_integer() else avg
    else:
        computed[str(dept)] = None

print("\nComputed results by department:", computed)

# Write results into existing target cells only
for r in target_rows:
    dept = str(ws.cell(r, 1).value)
    target_cell = ws.cell(r, 2)
    old_val = target_cell.value
    new_val = computed[dept]
    target_cell.value = new_val
    target_cell.number_format = "General"
    print(f"Wrote B{r}: old={old_val!r} -> new={new_val!r}")

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate (required)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb_check = load_workbook(output_path)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalculation:", wb_check.sheetnames)
    # rename back in order
    for i, original_name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)
else:
    print("Sheet names preserved after recalculation.")

# Final verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("\nVerified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheetnames[0]]

print("\nFinal calculation area rows 10:13 (data_only):")
for r in range(10, 14):
    print(r, [wsv.cell(r, c).value for c in range(1, 4)])

verified_targets = {f"B{r}": wsv.cell(r, 2).value for r in target_rows}
print("\nVerified target cells:", verified_targets)

# Sanity checks
assert wb_verify.sheetnames == orig_sheetnames, "Sheet names mismatch after output save"
assert wsv["B11"].value == 15, f"Unexpected B11: {wsv['B11'].value!r}"
assert wsv["B12"].value in (None, ""), f"Expected blank B12, got {wsv['B12'].value!r}"
assert wsv["B13"].value == 12, f"Unexpected B13: {wsv['B13'].value!r}"

final_output_spreadsheet = output_path
print("\nPrepared output file:", final_output_spreadsheet)
