import os, shutil
from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]
desired2 = wb["Desired Sheet1 after delrow2"]

def vals(ws, r, c1=1, c2=14):
    return [ws.cell(r, c).value for c in range(c1, c2+1)]

# Inspect exact rows in Sheet1 where col C is #N/A error
na_rows = []
non_na_rows = []
for r in range(2, ws.max_row + 1):
    cell = ws.cell(r, 3)
    is_na_error = (cell.data_type == 'e' and cell.value == '#N/A')
    if is_na_error:
        na_rows.append(r)
    else:
        non_na_rows.append(r)

print("Sheet1 max_row:", ws.max_row)
print("Rows with #N/A error in C:", na_rows)
print("Count keep:", len(na_rows), "Count delete:", len(non_na_rows))
print("\nSheet1 rows to keep (all columns A:N):")
for r in na_rows:
    print(r, vals(ws, r))

print("\nDesired Sheet1 after delrow2 max_row:", desired2.max_row)
print("Desired rows 1 to max (A:N):")
for r in range(1, desired2.max_row + 1):
    print(r, vals(desired2, r))

# Compare expected kept rows from Sheet1 to desired rows 2:end
expected = [vals(ws, r) for r in na_rows]
actual = [vals(desired2, r) for r in range(2, desired2.max_row + 1)]
print("\nExpected kept row count:", len(expected))
print("Desired data row count:", len(actual))
print("Matches desired exactly?:", expected == actual)

# Now perform modification on Sheet1 in a fresh workbook copy
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
shutil.copy(infile, outfile)

wb2 = load_workbook(outfile)
orig_names = wb2.sheetnames[:]
ws2 = wb2["Sheet1"]

# Delete from bottom upward, preserving row 1 blank
deleted = []
for r in range(ws2.max_row, 1, -1):
    cell = ws2.cell(r, 3)
    is_na_error = (cell.data_type == 'e' and cell.value == '#N/A')
    if not is_na_error:
        ws2.delete_rows(r, 1)
        deleted.append(r)

print("\nDeleted row count:", len(deleted))
print("New Sheet1 max_row:", ws2.max_row)
print("Resulting Sheet1 rows A:N:")
for r in range(1, ws2.max_row + 1):
    print(r, vals(ws2, r))

wb2.save(outfile)
print("Saved to:", outfile)

# Recalculate and handle possible sheet-name changes
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

wb3 = load_workbook(outfile)
print("Sheet names after recalc:", wb3.sheetnames)
if wb3.sheetnames != orig_names:
    # rename back by position
    for i, name in enumerate(orig_names):
        wb3.worksheets[i].title = name
    wb3.save(outfile)
    print("Renamed sheets back to:", orig_names)

# Verification with data_only
wbv = load_workbook(outfile, data_only=True)
wsv = wbv["Sheet1"]
print("\nVERIFICATION")
print("Verified sheet names:", wbv.sheetnames)
print("Verified Sheet1 max_row:", wsv.max_row)
for r in range(1, wsv.max_row + 1):
    row = vals(wsv, r)
    cval = wsv.cell(r, 3).value
    print(f"Row {r}: C={cval!r}, row={row}")

# Strong checks
row1_blank = all(wsv.cell(1, c).value is None for c in range(1, wsv.max_column + 1))
all_kept_are_na = all(wsv.cell(r, 3).value == '#N/A' for r in range(2, wsv.max_row + 1))
matches_desired_after = [vals(wsv, r) for r in range(2, wsv.max_row + 1)] == actual
print("Row1 blank:", row1_blank)
print("All remaining data rows have C == #N/A:", all_kept_are_na)
print("Output matches provided desired delrow2 sheet:", matches_desired_after)

output_spreadsheet = outfile
