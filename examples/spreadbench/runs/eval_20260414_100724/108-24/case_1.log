import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload fresh workbook for modification
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]

src = wb["BZTB"]
tgt = wb["Tema UV COS"]
manual = wb["Manual Extraction"]

def true_last_nonempty_row(ws, max_scan_cols=None):
    max_cols = min(ws.max_column, max_scan_cols or ws.max_column)
    for r in range(ws.max_row, 0, -1):
        for c in range(1, max_cols + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                return r
    return 0

src_last = true_last_nonempty_row(src, 4)
tgt_last = true_last_nonempty_row(tgt, 4)
manual_last = true_last_nonempty_row(manual, 4)

prefixes = ["COS Pass", "COS Comm", "COS W/S"]

matches = []
for r in range(1, src_last + 1):
    row_vals = [src.cell(r, c).value for c in range(1, 5)]
    a, b, c, d = row_vals
    b_str = "" if b is None else str(b)
    a_str = "" if a is None else str(a).strip()
    starts = any(b_str.startswith(p) for p in prefixes)
    used = "Used" in b_str
    excluded = (a_str == "398726") or ("398726" in b_str)
    if starts and used and not excluded:
        matches.append(row_vals)

print("Original sheet names:", original_sheet_names)
print("Source last row:", src_last)
print("Target pre-write last non-empty row:", tgt_last)
print("Manual Extraction last row:", manual_last)
print("Filtered match count (after excluding 398726):", len(matches))
print("\nFiltered rows to write:")
for i, row in enumerate(matches, start=1):
    print(i, row)

print("\nManual Extraction rows for comparison:")
manual_rows = []
for r in range(1, manual_last + 1):
    vals = [manual.cell(r, c).value for c in range(1, 5)]
    manual_rows.append(vals)
    print(r, vals)

print("\nMatches exactly equal Manual Extraction:", matches == manual_rows)

print("\nTarget sheet current first 10 rows A:D before write:")
for r in range(1, 11):
    print(r, [tgt.cell(r, c).value for c in range(1, 5)])

# Clear existing content in target A:D for rows that may hold old output
clear_to = max(tgt_last, len(matches))
for r in range(1, clear_to + 1):
    for c in range(1, 5):
        tgt.cell(r, c).value = None

# Write results starting at row 1, columns A:D
for out_r, row_vals in enumerate(matches, start=1):
    for c, val in enumerate(row_vals, start=1):
        tgt.cell(out_r, c).value = val

# Save
wb.save(output_path)
print("\nSaved workbook to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_post = load_workbook(output_path)
print("Sheet names after recalc reload:", wb_post.sheetnames)

if wb_post.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc; restoring original names.")
    for ws, orig_name in zip(wb_post.worksheets, original_sheet_names):
        ws.title = orig_name
    wb_post.save(output_path)
    wb_post = load_workbook(output_path)

print("Final sheet names:", wb_post.sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
verify_tgt = wb_verify["Tema UV COS"]

verify_rows = []
for r in range(1, len(matches) + 1):
    vals = [verify_tgt.cell(r, c).value for c in range(1, 5)]
    verify_rows.append(vals)

print("\nVerified target rows Tema UV COS!A:D:")
for i, row in enumerate(verify_rows, start=1):
    print(i, row)

# Additional checks
blanks = []
for r, row in enumerate(verify_rows, start=1):
    if all(v in (None, "") for v in row):
        blanks.append(r)

print("\nVerification summary:")
print("Row count written:", len(matches))
print("Blank output rows among expected rows:", blanks)
print("Output exactly matches intended filtered rows:", verify_rows == matches)

# Keep path for submission
final_output_path = output_path
