from openpyxl import load_workbook
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

# Load workbook and capture original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Before change:")
print("A323 =", ws["A323"].value)
print("B323 formula =", ws["B323"].value)
print("B323 number_format =", ws["B323"].number_format)

# Apply fix: exclude B323 from MAX range to avoid circular reference
fixed_formula = '=IF(A323="E","",MAX(B$7:B322)+1)'
ws["B323"] = fixed_formula

print("\nAfter change (in-memory):")
print("B323 formula =", ws["B323"].value)
print("B323 number_format =", ws["B323"].number_format)

# Save
wb.save(output_path)
print("\nSaved to:", str(output_path))

# Recalculate
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Reload after recalc to ensure sheet names still match original
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheet_names:
    # Rename back if LibreOffice changed them
    if len(wb_after.worksheets) == len(original_sheet_names):
        for ws_obj, orig_name in zip(wb_after.worksheets, original_sheet_names):
            ws_obj.title = orig_name
        wb_after.save(output_path)
        print("Renamed sheets back to original names:", original_sheet_names)
    else:
        print("Warning: sheet count changed unexpectedly")

# Verify formulas and evaluated values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)

wsf = wb_formula[original_sheet_names[0]]
wsv = wb_values[original_sheet_names[0]]

print("\nVerification:")
print("Sheet names final (formula wb):", wb_formula.sheetnames)
print("A323 =", wsf["A323"].value)
print("B323 formula final =", wsf["B323"].value)
print("B323 number_format final =", wsf["B323"].number_format)
print("B323 evaluated/data_only final =", wsv["B323"].value)

# Extra sanity check
nums = []
for r in range(7, 323):
    v = wsf[f"B{r}"].value
    if isinstance(v, (int, float)) and not isinstance(v, bool):
        nums.append(v)
print("Sanity max B7:B322 =", max(nums) if nums else None)
print("Expected next value =", (max(nums) + 1) if nums else None)

# Keep output path available for submission next turn
final_output_path = str(output_path)
