import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Detailed verification of target area and source area
print("Instruction:", instruction)
print("Original sheet names:", orig_sheetnames)
print("Target area before writing:")
for r in range(9, 12):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value)

print("Source area details:")
for r in range(2, 7):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    print(r, repr(a), type(a).__name__, repr(b), type(b).__name__)

# Detect source data rows: rows with date in col A and numeric in col B after header row
data_rows = []
for r in range(3, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is not None and b is not None and not (isinstance(a, str) and a.strip().lower() in {"result", "july", "august"}):
        # stop only if we hit the result block? safer to just gather valid data rows before row 9
        if r < 9:
            data_rows.append(r)

print("Detected data rows:", data_rows)
start_row, end_row = min(data_rows), max(data_rows)
date_range = f"$A${start_row}:$A${end_row}"
amount_range = f"$B${start_row}:$B${end_row}"

# Write formulas to exact target cells B10:B11 if blank
targets = [10, 11]
for r in targets:
    current = ws.cell(r, 2).value
    print(f"Before B{r}:", current)
    formula = f'=SUMPRODUCT((TEXT({date_range},"MMMM")=A{r})*({amount_range}<>0)*{amount_range})'
    if current in (None, ""):
        ws.cell(r, 2).value = formula
    print(f"Written B{r} formula:", ws.cell(r, 2).value)

# Save output
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename by position
    for i, orig_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
print("Final formulas in target cells:")
for r in targets:
    print(f"B{r} formula:", ws_formula[f"B{r}"].value)

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]
print("Verified target values after recalc:")
for r in targets:
    print(f"A{r}={ws_values[f'A{r}'].value!r}, B{r}={ws_values[f'B{r}'].value!r}")

output_spreadsheet = outfile
