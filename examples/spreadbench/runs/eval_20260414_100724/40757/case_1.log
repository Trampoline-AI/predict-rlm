import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook path:", path)
print("Sheet names:", wb.sheetnames)

def display(v):
    if v is None:
        return None
    return str(v)

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find actual non-empty rows/cols
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in row_vals):
            nonempty_rows.append(r)
            for c, v in enumerate(row_vals, start=1):
                if v is not None:
                    nonempty_cols.add(c)
    print("Non-empty row count:", len(nonempty_rows))
    print("Non-empty col letters:", [get_column_letter(c) for c in sorted(nonempty_cols)])
    
    # Print first 10 rows and last 5 rows across used columns
    used_cols = sorted(nonempty_cols) if nonempty_cols else list(range(1, ws.max_column + 1))
    if not used_cols:
        used_cols = [1]
    print("Headers row 1:", {get_column_letter(c): display(ws.cell(1, c).value) for c in used_cols})
    
    def row_dict(r):
        return {get_column_letter(c): display(ws.cell(r, c).value) for c in used_cols}
    
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("First rows:")
    for r in first_rows:
        print(r, row_dict(r))
    print("Last rows:")
    for r in last_rows:
        print(r, row_dict(r))
    
    # Print formulas and blanks in top area to detect target cells
    print("Cells with formulas (first 50 rows / first 20 cols):")
    formula_cells = []
    for r in range(1, min(ws.max_row, 50) + 1):
        for c in range(1, min(ws.max_column, 20) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print(formula_cells[:50])
    
    # Also inspect merged cells
    if ws.merged_cells.ranges:
        print("Merged ranges:", [str(rng) for rng in ws.merged_cells.ranges][:20])
    else:
        print("Merged ranges: none")
