from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os, json

# Re-open clean workbook for inspection/modification
input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb["TEST_SHEET"]

# Inspect exact current target area and existing formula text
print("Target area / context:")
for coord in ["B4","C4","B5","C5","B6","C6","B9","C9","D9","B10","C10","D10","B11","C11","D11","B12","C12","D12"]:
    cell = ws[coord]
    val = cell.value
    if isinstance(val, ArrayFormula):
        shown = {"type": "ArrayFormula", "text": val.text, "ref": val.ref}
    else:
        shown = val
    print(coord, "=>", shown)

# Discover 3-row blocks from column K labels
blocks = []
for r in range(17, ws.max_row + 1):
    k = ws[f"K{r}"].value
    if k == "Machine" and r + 2 <= ws.max_row and ws[f"K{r+1}"].value == "Person" and ws[f"K{r+2}"].value == "Time (Mins)":
        blocks.append((r, r+1, r+2))

print("\nDetected blocks (Machine, Person, Time rows):", blocks)

# Compute expected totals in Python for verification
summary_expected = {}
for machine in ["M1", "M2", "M3"]:
    for phase in ["SETUP", "RUN"]:
        total = 0
        for r_machine, r_person, r_time in blocks:
            date_received = ws[f"I{r_time}"].value
            date_delivery = ws[f"J{r_time}"].value
            start_date = ws["C4"].value
            end_date = ws["C5"].value
            in_range = (date_received >= start_date) and (date_delivery <= end_date)
            if not in_range:
                continue
            for c in range(12, 24):  # L:W
                phase_val = ws.cell(16, c).value
                machine_val = ws.cell(r_machine, c).value
                time_val = ws.cell(r_time, c).value
                # convert simple formulas like =35*10 after recalc later; for Python, evaluate obvious numeric literals only if already numbers
                if phase_val == phase and machine_val == machine:
                    if isinstance(time_val, (int, float)):
                        total += time_val
                    elif isinstance(time_val, str) and time_val.startswith("="):
                        # tiny safe evaluator for simple arithmetic literals present in this workbook
                        expr = time_val.lstrip("=").replace("^", "**")
                        if all(ch in "0123456789.+-*/() " for ch in expr):
                            total += eval(expr, {"__builtins__": {}}, {})
        summary_expected[(machine, phase)] = total

print("\nExpected summary totals computed in Python:")
for k, v in summary_expected.items():
    print(k, "=>", v)

# Build formulas: one SUMPRODUCT term per block, so no array/CSE formula is needed
def make_formula(machine_cell, phase_cell):
    terms = []
    start_cell = "$C$4"
    end_cell = "$C$5"
    for r_machine, r_person, r_time in blocks:
        # Each block contributes sum across L:W for matching phase and machine, gated by date range
        term = (
            f"SUMPRODUCT(($L$16:$W$16={phase_cell})*"
            f"($L${r_machine}:$W${r_machine}={machine_cell})*"
            f"N($L${r_time}:$W${r_time})*"
            f"($I${r_time}>={start_cell})*($J${r_time}<={end_cell}))"
        )
        terms.append(term)
    return "=" + "+".join(terms)

targets = {
    "C10": ("$B10", "C$9"),
    "D10": ("$B10", "D$9"),
    "C11": ("$B11", "C$9"),
    "D11": ("$B11", "D$9"),
    "C12": ("$B12", "C$9"),
    "D12": ("$B12", "D$9"),
}

print("\nFormulas to write:")
for coord, (machine_ref, phase_ref) in targets.items():
    formula = make_formula(machine_ref, phase_ref)
    print(coord, formula)
    ws[coord] = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))
orig_sheetnames = wb.sheetnames[:]
wb.save(out_path)
