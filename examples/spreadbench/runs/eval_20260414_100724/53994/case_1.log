        for ws_obj, orig_name in zip(wb_post.worksheets, orig_sheetnames):
            ws_obj.title = orig_name
        wb_post.save(out_path)
else:
    print("Sheet names preserved:", wb_post.sheetnames)

# Verify with data_only
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_sheetnames[0]]

print("\nVerified target values after recalculation:")
for coord in ["C10","D10","C11","D11","C12","D12"]:
    print(coord, "=>", wsv[coord].value)

print("\nCross-check expected vs actual:")
mapping = {
    "C10": ("M1","SETUP"),
    "D10": ("M1","RUN"),
    "C11": ("M2","SETUP"),
    "D11": ("M2","RUN"),
    "C12": ("M3","SETUP"),
    "D12": ("M3","RUN"),
}
