from openpyxl import load_workbook
from openpyxl.worksheet.formula import ArrayFormula
import os

input_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))

# Reload original workbook so we replace the broken formula cleanly
wb_fix = load_workbook(input_path)
ws = wb_fix["TEST_SHEET"]
orig_sheetnames = wb_fix.sheetnames[:]

# Detect blocks again
blocks = []
for r in range(17, ws.max_row + 1):
    if ws[f"K{r}"].value == "Machine" and ws[f"K{r+1}"].value == "Person" and ws[f"K{r+2}"].value == "Time (Mins)":
        blocks.append((r, r+1, r+2))
print("Blocks:", blocks)

# Compute expected totals and contributing cells from workbook logic
machines = ["M1", "M2", "M3"]
phases = ["SETUP", "RUN"]
expected = {}
contributors = {}

def num_from_cell_value(v):
    if isinstance(v, (int, float)):
        return v
    if isinstance(v, str) and v.startswith("="):
        expr = v[1:].replace("^", "**")
        if all(ch in "0123456789.+-*/() " for ch in expr):
            return eval(expr, {"__builtins__": {}}, {})
    return None

for machine in machines:
    for phase in phases:
        total = 0
        cells = []
        for r_machine, r_person, r_time in blocks:
            if not (ws[f"I{r_time}"].value >= ws["C4"].value and ws[f"J{r_time}"].value <= ws["C5"].value):
                continue
            for c in range(12, 24):  # L:W
                if ws.cell(16, c).value == phase and ws.cell(r_machine, c).value == machine:
                    v = num_from_cell_value(ws.cell(r_time, c).value)
                    if v is not None:
                        total += v
                        cells.append((ws.cell(r_time, c).coordinate, v))
        expected[(machine, phase)] = total
        contributors[(machine, phase)] = cells

print("Expected totals:")
for k, v in expected.items():
    print(k, "=>", v, "contributors:", contributors[k])

# Build robust scalar formulas (no array logic)
def build_explicit_formula(machine_ref, phase_ref):
    terms = []
    for r_machine, r_person, r_time in blocks:
        for c in range(12, 24):  # L:W
            col = ws.cell(1, c).column_letter
            term = (
                f'IF(AND($I${r_time}>=$C$4,$J${r_time}<=$C$5,'
                f'{col}$16={phase_ref},{col}${r_machine}={machine_ref}),'
                f'{col}${r_time},0)'
            )
            terms.append(term)
    return "=" + "+".join(terms)

target_map = {
    "C10": ("$B10", "C$9", ("M1", "SETUP")),
    "D10": ("$B10", "D$9", ("M1", "RUN")),
    "C11": ("$B11", "C$9", ("M2", "SETUP")),
    "D11": ("$B11", "D$9", ("M2", "RUN")),
    "C12": ("$B12", "C$9", ("M3", "SETUP")),
    "D12": ("$B12", "D$9", ("M3", "RUN")),
}

for coord, (machine_ref, phase_ref, key) in target_map.items():
    formula = build_explicit_formula(machine_ref, phase_ref)
    ws[coord] = formula
    print(coord, "formula prefix:", formula[:160] + ("..." if len(formula) > 160 else ""))
    print(" expected ->", expected[key])

# Save and recalc
wb_fix.save(out_path)
print("Saved:", out_path)

recalc_result = await recalculate(out_path)
print("Recalc:", recalc_result)

# Restore sheet names if needed
wb_post = load_workbook(out_path)
if wb_post.sheetnames != orig_sheetnames and len(wb_post.sheetnames) == len(orig_sheetnames):
    print("Restoring sheet names:", wb_post.sheetnames, "->", orig_sheetnames)
    for ws_obj, orig_name in zip(wb_post.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    wb_post.save(out_path)

# Verify formulas and cached results
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula["TEST_SHEET"]
print("Stored formulas in targets:")
for coord in target_map:
    print(coord, "=>", str(wsf[coord].value)[:140] + ("..." if len(str(wsf[coord].value)) > 140 else ""))

wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["TEST_SHEET"]
print("\nVerified target values:")
ok = True
for coord, (_, _, key) in target_map.items():
    actual = wsv[coord].value
    exp = expected[key]
    print(coord, "actual=", actual, "expected=", exp)
    if actual != exp:
        ok = False

output_spreadsheet = out_path
print("\nVerification passed:", ok)
