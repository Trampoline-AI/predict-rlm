import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        vals.append(ws.cell(r, c).value)
    return vals

workbook_summary = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        headers2 = row_values(ws, 2, ws.max_column)
        print("Row 2:", headers2)
    
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(f"R{r}: {row_values(ws, r, ws.max_column)}")
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(f"R{r}: {row_values(ws, r, ws.max_column)}")
    
    # inspect columns H and I specifically
    h_col, i_col = 8, 9
    print("Column letters check:", get_column_letter(h_col), get_column_letter(i_col))
    hi_rows = []
    for r in range(1, ws.max_row + 1):
        h = ws.cell(r, h_col).value if ws.max_column >= h_col else None
        i = ws.cell(r, i_col).value if ws.max_column >= i_col else None
        if h is not None or i is not None:
            hi_rows.append((r, h, i))
    print(f"Rows with any value in H or I: count={len(hi_rows)}")
    print("First up to 20 H/I rows:", hi_rows[:20])
    print("Last up to 10 H/I rows:", hi_rows[-10:])
    
    delete_candidates = []
    for r in range(1, ws.max_row + 1):
        h = ws.cell(r, h_col).value if ws.max_column >= h_col else None
        i = ws.cell(r, i_col).value if ws.max_column >= i_col else None
        h_blank = h is None or (isinstance(h, str) and h.strip() == "")
        i_has = not (i is None or (isinstance(i, str) and i.strip() == ""))
        if i_has and h_blank:
            delete_candidates.append(r)
    print("Deletion candidate rows (I has value, H blank):", delete_candidates[:50], "total=", len(delete_candidates))
    
    workbook_summary[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "headers_row1": headers,
        "headers_row2": row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else None,
        "delete_candidates": delete_candidates,
    }

print("\nWorkbook summary keys:", list(workbook_summary.keys()))
