import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Re-open fresh workbook for modification
wb2 = load_workbook(input_spreadsheet)
original_sheet_names = wb2.sheetnames[:]
ws = wb2["Sheet1"]

def is_blank(v):
    return v is None or (isinstance(v, str) and v.strip() == "")

def has_value(v):
    return not is_blank(v)

def sheet_rows_snapshot(ws, start, end):
    out = []
    for r in range(start, min(end, ws.max_row) + 1):
        out.append((r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]))
    return out

print("Pre-delete snapshot rows 1-7:")
for r, vals in sheet_rows_snapshot(ws, 1, 7):
    print(f"R{r}: {vals}")

# Identify candidate rows again for safety
candidate_rows = []
for r in range(1, ws.max_row + 1):
    h = ws.cell(r, 8).value
    i = ws.cell(r, 9).value
    if has_value(i) and is_blank(h):
        candidate_rows.append(r)

print("Candidate rows to delete (bottom-up):", candidate_rows)

# Delete from bottom to top
for r in sorted(candidate_rows, reverse=True):
    ws.delete_rows(r, 1)

print("Post-delete in-memory max_row:", ws.max_row)
print("Post-delete snapshot all rows:")
for r, vals in sheet_rows_snapshot(ws, 1, ws.max_row):
    print(f"R{r}: {vals}")

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc reload:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names and len(wb_check.sheetnames) == len(original_sheet_names):
    for old_name, desired_name in zip(wb_check.sheetnames, original_sheet_names):
        if old_name != desired_name:
            wb_check[old_name].title = desired_name
    wb_check.save(output_path)
    print("Renamed sheets back to original names:", original_sheet_names)

# Verification with values/formulas view
wb_verify = load_workbook(output_path)
wsv = wb_verify[original_sheet_names[0]]
print("Verified sheet names:", wb_verify.sheetnames)
print("Verified max_row/max_column:", wsv.max_row, wsv.max_column)

print("Final rows after save:")
for r in range(1, wsv.max_row + 1):
    row_vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    print(f"R{r}: {row_vals}")

remaining_bad = []
for r in range(1, wsv.max_row + 1):
    h = wsv.cell(r, 8).value
    i = wsv.cell(r, 9).value
    if has_value(i) and is_blank(h):
        remaining_bad.append((r, h, i))
print("Remaining rows violating condition:", remaining_bad)

# Also verify with data_only
wb_verify_data = load_workbook(output_path, data_only=True)
wsv_data = wb_verify_data[original_sheet_names[0]]
print("Data-only final H/I values:")
for r in range(1, wsv_data.max_row + 1):
    print(r, wsv_data.cell(r, 8).value, wsv_data.cell(r, 9).value)
