import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]

src = wb["Source"]
src2 = wb["Source2"]
res = wb["Result"]

# Confirm target cells/column before writing
print("Target sheet:", res.title)
print("Target header A1:", res["A1"].value)
print("Existing Result rows before write:")
for r in range(1, res.max_row + 1):
    print(f"  Row {r}: {res.cell(r, 1).value}")

# Extract values from Source and Source2
source_values = []
for r in range(2, src.max_row + 1):
    source_values.append(src.cell(r, 2).value)  # Value column in Source

source2_values = []
for r in range(2, src2.max_row + 1):
    source2_values.append(src2.cell(r, 1).value)  # Value column in Source2

print("Source values:", source_values)
print("Source2 values:", source2_values)

source2_set = set(source2_values)

# Build result values preserving Source order and deduplicating output
result_values = []
seen = set()
for v in source_values:
    include = False
    if v == 2 and v in source2_set:
        include = True
    elif v not in source2_set:
        include = True
    
    if include and v not in seen:
        result_values.append(v)
        seen.add(v)

print("Computed result values to write:", result_values)

# Clear old result data below header in column A
for r in range(2, res.max_row + 1):
    res.cell(r, 1).value = None

# Write results to Result!A starting at A2
for i, v in enumerate(result_values, start=2):
    res.cell(i, 1).value = v

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_status = await recalculate(output_path)
print("Recalculate status:", recalc_status)

# Reload and restore original sheet names if recalculation changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalculation:", wb_check.sheetnames)
    # rename by position back to original names
    for ws_obj, orig_name in zip(wb_check.worksheets, original_sheet_names):
        ws_obj.title = orig_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

res_v = wb_verify["Result"]
verified_values = []
for r in range(1, max(res_v.max_row, len(result_values) + 1) + 1):
    verified_values.append(res_v.cell(r, 1).value)

print("Verified Result column A values:")
for r in range(1, res_v.max_row + 1):
    print(f"  A{r} = {res_v.cell(r, 1).value}")

# Keep path available for submission
final_output_spreadsheet = output_path
print("Final output path ready for submission:", final_output_spreadsheet)
