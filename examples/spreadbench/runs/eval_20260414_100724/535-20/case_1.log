import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames

print("Input path:", input_path)
print("Sheet names:", original_sheet_names)

inspection = {}

for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    match_cols = []
    for c, h in enumerate(headers, start=1):
        if isinstance(h, str) and "/description" in h:
            match_cols.append((c, get_column_letter(c), h))
    
    # sample first 5 rows and last 5 rows
    first_n = min(7, max_row)
    first_rows = []
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(max_col, 12) + 1)]
        first_rows.append(vals)
    
    last_rows = []
    start_last = max(1, max_row - 4)
    for r in range(start_last, max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(max_col, 12) + 1)]
        last_rows.append((r, vals))
    
    # compact header preview
    header_preview_start = [(c, get_column_letter(c), headers[c-1]) for c in range(1, min(max_col, 20) + 1)]
    header_preview_end = [(c, get_column_letter(c), headers[c-1]) for c in range(max(1, max_col-9), max_col + 1)]
    
    inspection[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "match_cols": match_cols,
        "header_preview_start": header_preview_start,
        "header_preview_end": header_preview_end,
        "first_rows": first_rows,
        "last_rows": last_rows,
    }

for sheet, info in inspection.items():
    print("\n=== SHEET:", sheet, "===")
    print("Rows:", info["max_row"], "Cols:", info["max_col"])
    print("Header preview start:", info["header_preview_start"])
    print("Header preview end:", info["header_preview_end"])
    print("Columns with '/description' in row 1:", info["match_cols"][:50], "count=", len(info["match_cols"]))
    print("First sample rows (first 12 cols):")
    for row in info["first_rows"]:
        print(row)
    print("Last sample rows (first 12 cols):")
    for r, row in info["last_rows"]:
        print(r, row)
