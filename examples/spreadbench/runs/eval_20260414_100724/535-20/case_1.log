import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload clean workbook for modification
wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames[:]

targets_by_sheet = {}

for ws in wb2.worksheets:
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    matches = [(c, get_column_letter(c), headers[c-1]) for c in range(1, ws.max_column + 1)
               if isinstance(headers[c-1], str) and "/description" in headers[c-1]]
    targets_by_sheet[ws.title] = matches

    print(f"\nSheet {ws.title}: before deletion -> rows={ws.max_row}, cols={ws.max_column}")
    print(f"Matching '/description' columns: {len(matches)}")
    print("First 10 matches:", matches[:10])
    print("Last 10 matches:", matches[-10:])

    # Show nearby headers around first and last match to verify exact targets
    if matches:
        for label, col_idx in [("first_match", matches[0][0]), ("last_match", matches[-1][0])]:
            start = max(1, col_idx - 2)
            end = min(ws.max_column, col_idx + 2)
            nearby = [(c, get_column_letter(c), ws.cell(1, c).value) for c in range(start, end + 1)]
            print(f"Nearby headers around {label}:", nearby)

# Perform deletion right-to-left on each worksheet
for ws in wb2.worksheets:
    match_cols = [c for c, _, _ in targets_by_sheet[ws.title]]
    for c in sorted(match_cols, reverse=True):
        ws.delete_cols(c, 1)

# Save before recalculation
wb2.save(output_path)
print("\nSaved modified workbook to:", output_path)

# Recalculate (not really needed for deletions, but required by workflow)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open after recalculation and restore original sheet names if changed
wb3 = load_workbook(output_path)
current_names = wb3.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != orig_sheet_names and len(current_names) == len(orig_sheet_names):
    for ws, orig_name in zip(wb3.worksheets, orig_sheet_names):
        ws.title = orig_name
    wb3.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verification with formulas/data cache not important here, but reload normally and inspect targets
verify_wb = load_workbook(output_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)

verification_summary = {}

for original_ws_name in orig_sheet_names:
    ws = verify_wb[original_ws_name]
    new_headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    remaining_matches = [(c, get_column_letter(c), new_headers[c-1]) for c in range(1, ws.max_column + 1)
                         if isinstance(new_headers[c-1], str) and "/description" in new_headers[c-1]]
    verification_summary[original_ws_name] = {
        "rows": ws.max_row,
        "cols": ws.max_column,
        "remaining_match_count": len(remaining_matches),
        "header_start": [(c, get_column_letter(c), new_headers[c-1]) for c in range(1, min(ws.max_column, 12) + 1)],
        "header_end": [(c, get_column_letter(c), new_headers[c-1]) for c in range(max(1, ws.max_column - 11), ws.max_column + 1)],
    }

for sheet, info in verification_summary.items():
    print(f"\nVERIFICATION {sheet}: rows={info['rows']}, cols={info['cols']}, remaining '/description' headers={info['remaining_match_count']}")
    print("Header start:", info["header_start"])
    print("Header end:", info["header_end"])

# Keep path in variable for submission
final_output_spreadsheet = output_path
print("\nFinal output path prepared:", final_output_spreadsheet)
