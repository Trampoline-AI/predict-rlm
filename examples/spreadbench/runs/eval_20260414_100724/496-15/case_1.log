```repl
import os, re, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Reload workbook for modification
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Focused inspection of target columns D and E")
print("Headers:", ws["D1"].value, ws["E1"].value)

candidate_rows = []
for r in range(2, ws.max_row + 1):
    d = ws.cell(r, 4).value
    e = ws.cell(r, 5).value
    if isinstance(e, str) and "Check" in e:
        candidate_rows.append((r, d, e, ws.cell(r, 4).data_type, ws.cell(r, 5).data_type))

print("Candidate row count:", len(candidate_rows))
for item in candidate_rows:
    print(item)

# Determine extraction pattern
def extract_check_number(text):
    # Prefer numbers appearing after the last occurrence of "check" with optional #/spaces.
    m = re.search(r'(?i)check\s*#?\s*(\d+)\s*$', text.strip())
    if m:
        return m.group(1)
    # Fallback: last digit sequence anywhere in the string
    nums = re.findall(r'(\d+)', text)
    return nums[-1] if nums else None

print("\nExtraction preview:")
for r, d, e, *_ in candidate_rows:
    print(f"Row {r}: {e!r} -> {extract_check_number(e)!r}")

# Perform updates
modified = []
for r in range(2, ws.max_row + 1):
    e = ws.cell(r, 5).value
    if isinstance(e, str) and "Check" in e:
        num = extract_check_number(e)
        if num is not None:
            ws.cell(r, 4).value = num
            ws.cell(r, 5).value = "Check Paid"
            modified.append((r, num))

print("\nModified rows:", modified)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    for i, expected in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Restored original sheet names:", orig_sheetnames)

# Verify with formulas/data cache
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify[orig_sheetnames[0]]

print("\nVerification of target cells:")
for r, num in modified:
    d_val = vws.cell(r, 4).value
    e_val = vws.cell(r, 5).value
    print(f"Row {r}: D={d_val!r}, E={e_val!r}")
    if d_val in (None, "") or e_val in (None, ""):
        print("WARNING blank target cell at row", r)

print("\nFinal header check:")
print("D1 =", vws["D1"].value, "| E1 =", vws["E1"].value)

output_spreadsheet = outfile
print("\nPrepared output_spreadsheet:", output_spreadsheet)
