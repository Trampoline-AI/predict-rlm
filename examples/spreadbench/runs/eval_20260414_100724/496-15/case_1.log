import os, re, json, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
original_sheetnames = wb.sheetnames[:]
print("Sheet names:", original_sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find rows that contain any non-empty cell
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print(f"Non-empty row count: {len(nonempty_rows)}")
    if not nonempty_rows:
        continue

    # Print first few rows to infer headers
    sample_top = nonempty_rows[:10]
    sample_bottom = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
    
    print("Top sample rows:")
    for r in sample_top:
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}: {vals}")
    
    if sample_bottom:
        print("Bottom sample rows:")
        for r in sample_bottom:
            vals = row_values(ws, r, ws.max_column)
            print(f"Row {r}: {vals}")

    headers = row_values(ws, nonempty_rows[0], ws.max_column)
    header_map = {get_column_letter(i+1): headers[i] for i in range(len(headers))}
    print("Assumed header row:", nonempty_rows[0])
    print("Headers by column:", header_map)
    
    # Specifically inspect columns D and E
    print("Column D header/value sample:", ws["D1"].value)
    print("Column E header/value sample:", ws["E1"].value)

    check_rows = []
    for r in nonempty_rows:
        d = ws.cell(r, 4).value
        e = ws.cell(r, 5).value
        if isinstance(e, str) and "Check" in e:
            check_rows.append((r, d, e))
    print(f"Rows with 'Check' in column E: {len(check_rows)}")
    for item in check_rows[:15]:
        print("Check row:", item)

    # Print exact current values in D/E for first several rows, plus last few
