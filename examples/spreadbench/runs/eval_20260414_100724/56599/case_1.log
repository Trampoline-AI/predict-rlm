    print(r, [ws.cell(r, c).value for c in range(7, 11)])
print("Last lookup rows 26:30:")
for r in range(26, 31):
    print(r, [ws.cell(r, c).value for c in range(7, 11)])

# Determine actual data extent
data_rows = []
for r in range(6, ws.max_row + 1):
    g, h, j = ws[f"G{r}"].value, ws[f"H{r}"].value, ws[f"J{r}"].value
    if any(v is not None and v != "" for v in (g, h, j)):
        data_rows.append(r)

first_row, last_row = min(data_rows), max(data_rows)
print("Lookup rows:", first_row, last_row)

# Write requested formula into B2
formula = (
    f'=IF(M5="","not found - please re-enter",'
    f'IF(COUNTIFS($G${first_row}:$G${last_row},"<="&M5,$H${first_row}:$H${last_row},">="&M5)=0,'
    f'"not found - please re-enter",'
    f'SUMIFS($J${first_row}:$J${last_row},$G${first_row}:$G${last_row},"<="&M5,$H${first_row}:$H${last_row},">="&M5)))'
)
ws["B2"] = formula
ws["M5"] = None

# Set calc flags so spreadsheet apps know to recalc on open
wb.calculation.calcMode = "auto"
wb.calculation.fullCalcOnLoad = True
wb.calculation.forceFullCalc = True
wb.calculation.calcOnSave = True
wb.calculation.calcCompleted = False
wb.calculation.calcId = 0

wb.save(outfile)
print("Saved fresh output with formula.")
