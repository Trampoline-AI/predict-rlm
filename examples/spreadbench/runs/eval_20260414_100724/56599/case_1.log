# Patch final file XML so B2 retains formula + cached blank-input value
NS = "http://schemas.openxmlformats.org/spreadsheetml/2006/main"
ET.register_namespace("", NS)

with zipfile.ZipFile(outfile, "r") as zin:
    files = {name: zin.read(name) for name in zin.namelist()}

sheet_xml_name = "xl/worksheets/sheet1.xml"
root = ET.fromstring(files[sheet_xml_name])

def q(tag):
    return f"{{{NS}}}{tag}"

# find or create row 2
sheetData = root.find(q("sheetData"))
row2 = None
for row in sheetData.findall(q("row")):
    if row.get("r") == "2":
        row2 = row
        break
if row2 is None:
    row2 = ET.Element(q("row"), {"r": "2"})
    sheetData.append(row2)

# find or create cell B2
b2 = None
for c in row2.findall(q("c")):
    if c.get("r") == "B2":
        b2 = c
        break
if b2 is None:
    b2 = ET.Element(q("c"), {"r": "B2"})
    row2.append(b2)

# clear existing children and set formula + cached string value
for child in list(b2):
    b2.remove(child)
b2.set("t", "str")
f = ET.SubElement(b2, q("f"))
f.text = formula[1:] if formula.startswith("=") else formula
v = ET.SubElement(b2, q("v"))
v.text = "not found - please re-enter"

# ensure workbook calcPr exists and requests recalc
wb_root = ET.fromstring(files["xl/workbook.xml"])
calcPr = wb_root.find(q("calcPr"))
if calcPr is None:
    calcPr = ET.SubElement(wb_root, q("calcPr"))
calcPr.set("calcId", "0")
calcPr.set("calcMode", "auto")
calcPr.set("fullCalcOnLoad", "1")
calcPr.set("calcOnSave", "1")
calcPr.set("forceFullCalc", "1")
calcPr.set("calcCompleted", "0")

# write patched archive
tmp_out = outfile + ".tmp"
with zipfile.ZipFile(tmp_out, "w", zipfile.ZIP_DEFLATED) as zout:
    for name, data in files.items():
        if name == sheet_xml_name:
            zout.writestr(name, ET.tostring(root, encoding="utf-8", xml_declaration=False))
        elif name == "xl/workbook.xml":
            zout.writestr(name, ET.tostring(wb_root, encoding="utf-8", xml_declaration=False))
        else:
            zout.writestr(name, data)
os.replace(tmp_out, outfile)

# Verify final file
