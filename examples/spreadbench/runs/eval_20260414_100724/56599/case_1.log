import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect non-empty rows and cols a bit more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # print first 10 rows and last 5 rows with coordinates
    def row_vals(r):
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            vals.append(v)
        return vals
    
    top_rows = list(range(1, min(ws.max_row, 10) + 1))
    bottom_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("Top rows:")
    for r in top_rows:
        print(r, row_vals(r))
    print("Bottom rows:")
    for r in bottom_rows:
        print(r, row_vals(r))
    
    # probable header rows: first few nonempty rows
    print("First few nonempty rows with coordinates:")
    for r in nonempty_rows[:5]:
        pairs = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None and v != "":
                pairs.append(f"{get_column_letter(c)}{r}={v}")
        print("Row", r, pairs[:20], "..." if len(pairs) > 20 else "")
    
    # specific cells/ranges likely relevant
    for coord in ["B2", "M5", "A1", "B1", "M1", "M2", "M3", "M4", "M5", "M6"]:
        if ws.max_row >= 1 and ws.max_column >= 1:
            print(f"{coord}:", ws[coord].value)

for ws in wb.worksheets:
    sheet_info(ws)
