def sheet_summary(ws, sample_first=8, sample_last=5, max_cols_show=20):
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Header guess: first non-empty row among first 5 rows
    header_row = None
    for r in range(1, min(6, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols_show) + 1)]
        if any(v is not None and str(v).strip() != "" for v in vals):
            header_row = r
            break
    print("First non-empty/header-candidate row:", header_row)
    
    # Print column letters + header candidate values
    if header_row:
        headers = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(header_row, c).value
            headers.append(f"{get_column_letter(c)}={v!r}")
        print("Headers/row values:", headers[:max_cols_show])
        if len(headers) > max_cols_show:
            print(f"... ({len(headers)-max_cols_show} more columns)")
    
    # first rows
    print("\nFirst rows:")
    for r in range(1, min(ws.max_row, sample_first) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols_show) + 1)]
        print(f"Row {r}: {row_vals}")
    
    # last rows
    print("\nLast rows:")
    start_last = max(1, ws.max_row - sample_last + 1)
    for r in range(start_last, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols_show) + 1)]
        print(f"Row {r}: {row_vals}")

for ws in wb.worksheets:
    sheet_summary(ws)

# Focused inspection for likely sheets
if "Transactions" in wb.sheetnames:
    ws = wb["Transactions"]
    print("\n" + "="*80)
    print("Focused inspection: Transactions")
    # print columns A-J for first 15 and last 10 rows
    for r in range(1, min(16, ws.max_row+1)):
