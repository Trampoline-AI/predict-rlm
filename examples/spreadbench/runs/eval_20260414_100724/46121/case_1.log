```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws_t = wb["Transactions"]
ws_y = wb["2022"]

print("Original sheet names:", original_sheetnames)

# Determine bounded source range for income data (A:D)
last_income_row = 2
for r in range(ws_t.max_row, 2, -1):
    vals = [ws_t.cell(r, c).value for c in range(1, 5)]
    if any(v is not None and str(v).strip() != "" for v in vals):
        last_income_row = r
        break

print("Detected last relevant income row on Transactions:", last_income_row)
print("Transactions income range values:")
for r in range(2, last_income_row + 1):
    print(r, [ws_t.cell(r, c).value for c in range(1, 5)])

# Verify target area before writing
print("\nTarget area before writing (2022!B5:M8):")
for r in range(5, 9):
    vals = [ws_y.cell(r, c).value for c in range(2, 14)]
    print(f"Row {r} category={ws_y.cell(r,1).value!r} -> {vals}")

print("\nCurrent month headers B3:M3:")
for c in range(2, 14):
    print(f"{get_column_letter(c)}3 = {ws_y.cell(3,c).value!r}")

# Existing broken formula / nearby formulas
for coord in ["D7", "N5", "N6", "N7", "N8", "B9", "D9", "E9", "N9"]:
    cell = ws_y[coord]
    print(f"Before {coord}: value={cell.value!r}, fmt={cell.number_format!r}")

# Use existing currency format from N5 if available
currency_fmt = ws_y["N5"].number_format or '"$"#,##0.00'
print("Currency format to apply:", repr(currency_fmt))

# Write formulas to B5:M8
# Criteria: month in Transactions!A matches month header in row 3, category in Transactions!D matches row label in col A
for r in range(5, 9):      # income rows
    for c in range(2, 14): # Jan-Dec columns B:M
        coord = f"{get_column_letter(c)}{r}"
        formula = (
            f'=SUMIFS('
            f'Transactions!$C$3:$C${last_income_row},'
            f'Transactions!$A$3:$A${last_income_row},TRIM({get_column_letter(c)}$3),'
            f'Transactions!$D$3:$D${last_income_row},TRIM($A{r})'
            f')'
        )
        ws_y[coord] = formula
        ws_y[coord].number_format = currency_fmt

# Apply currency formatting to totals in income section too, preserving formulas
for r in range(5, 10):
    for c in range(2, 15):  # B:N
        ws_y.cell(r, c).number_format = currency_fmt

print("\nTarget area after writing formulas (show formulas for B5:M8):")
for r in range(5, 9):
    formulas = [ws_y.cell(r, c).value for c in range(2, 14)]
    print(f"Row {r} category={ws_y.cell(r,1).value!r} -> {formulas}")

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    # rename by position back to originals
    for i, expected in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Sheet names restored to:", original_sheetnames)
else:
    print("Sheet names preserved after recalc.")

# Verification with data_only=True
wb_val = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)

wsv = wb_val["2022"]

print("\nVerified values in target income section B5:M8:")
for r in range(5, 9):
    vals = [wsv.cell(r, c).value for c in range(2, 14)]
    print(f"Row {r} category={wsv.cell(r,1).value!r} -> {vals}")

print("\nKey target checks:")
for coord in ["D7", "E7", "N7", "D9", "E9", "N9"]:
    print(coord, "=", wsv[coord].value)

# Also verify formulas still present in normal load
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["2022"]
print("\nFormula spot checks:")
for coord in ["B5", "D7", "E7", "M8"]:
    print(coord, "formula:", wsf[coord].value, "| fmt:", wsf[coord].number_format)
