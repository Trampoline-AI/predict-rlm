from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from collections import defaultdict
import os
from copy import copy

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# ----------------------------
# Inspect exact target again
# ----------------------------
wb_in = load_workbook(input_path)
orig_sheet_names = wb_in.sheetnames[:]
ws_in = wb_in[orig_sheet_names[0]]

print("Instruction:", instruction)
print("Original sheet names:", orig_sheet_names)
print("Target sheet:", ws_in.title)
print("Header row:", [ws_in.cell(1, c).value for c in range(1, ws_in.max_column + 1)])
print("Current D1:D10:", [ws_in.cell(r, 4).value for r in range(1, min(10, ws_in.max_row) + 1)])

# Determine true data rows from A:C
data_rows = []
for r in range(2, ws_in.max_row + 1):
    vals = [ws_in.cell(r, c).value for c in range(1, 4)]
    if any(v not in (None, "") for v in vals):
        data_rows.append(r)
first_data_row = min(data_rows)
last_data_row = max(data_rows)
print("Data rows:", first_data_row, "to", last_data_row)

# ----------------------------
# Compute expected answers in Python
# ----------------------------
customer_rows = defaultdict(list)
for r in data_rows:
    cust = ws_in.cell(r, 1).value
    total = ws_in.cell(r, 2).value
    country = ws_in.cell(r, 3).value
    customer_rows[str(cust)].append((r, total, country))

best_non_us_country = {}
best_non_us_amount = {}
for cust_key, rows in customer_rows.items():
    non_us = [(r, total, country) for r, total, country in rows if country != "US"]
    if not non_us:
        best_non_us_country[cust_key] = None
        best_non_us_amount[cust_key] = None
    else:
        best = max(non_us, key=lambda x: x[1])
        best_non_us_country[cust_key] = best[2]
        best_non_us_amount[cust_key] = best[1]

expected = {}
for r in data_rows:
    cust_key = str(ws_in.cell(r, 1).value)
    country = ws_in.cell(r, 3).value
    expected[r] = country if country != "US" else best_non_us_country[cust_key]

print("Expected D values for all target rows:")
for r in data_rows:
    print(f"D{r} expected -> {expected[r]}")

# ----------------------------
# Attempt formula solution first
# ----------------------------
wb_formula = load_workbook(input_path)
ws_formula = wb_formula[orig_sheet_names[0]]

# Formula notes:
# - Compare customer IDs as text using &"" to handle mixed numeric/text cells.
# - Use AGGREGATE(LARGE, ignore errors) to get max B for matching same-customer non-US rows.
# - Then INDEX/MATCH to retrieve the corresponding country.
# - If current row is non-US, just return C row value.
rngA = f"$A${first_data_row}:$A${last_data_row}"
rngB = f"$B${first_data_row}:$B${last_data_row}"
rngC = f"$C${first_data_row}:$C${last_data_row}"

for r in data_rows:
    formula = (
        f'=IF(C{r}<>"US",C{r},'
        f'INDEX({rngC},MATCH(1,INDEX((({rngA}&"")=(A{r}&""))*({rngC}<>"US")*'
        f'({rngB}=_xlfn.AGGREGATE(14,6,{rngB}/((({rngA}&"")=(A{r}&""))*({rngC}<>"US")),1)),0),0)))'
    )
    ws_formula.cell(r, 4).value = formula

print("\nSample formulas written to D:")
for r in list(data_rows[:5]) + list(data_rows[-5:]):
    print(f"D{r} =", ws_formula.cell(r, 4).value)

wb_formula.save(output_path)
print("\nSaved formula version to:", output_path)

# Recalculate formula version
recalc_result = await recalculate(output_path)
print("Recalculate result (formula version):", recalc_result)

# Fix sheet names if LibreOffice renamed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheet_names)
    # Rename sheets back in order
    for i, desired in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = desired
    wb_check.save(output_path)
else:
    print("Sheet names preserved after recalc.")

# Verify formula results
wb_formula_verify = load_workbook(output_path, data_only=True)
ws_formula_verify = wb_formula_verify[orig_sheet_names[0]]

formula_failures = []
formula_results = {}
for r in data_rows:
    val = ws_formula_verify.cell(r, 4).value
    formula_results[r] = val
    if (val is None) or (str(val).strip() != str(expected[r]).strip()):
        formula_failures.append((r, val, expected[r]))

print("\nVerified D values after formula recalc:")
for r in data_rows:
    print(f"Row {r}: C={ws_formula_verify.cell(r,3).value}, D={formula_results[r]}, expected={expected[r]}")

print("\nFormula failure count:", len(formula_failures))
if formula_failures:
    print("First formula failures:", formula_failures[:10])

# ----------------------------
# Fallback to literal values if formula failed
# ----------------------------
used_fallback = False
if formula_failures:
    used_fallback = True
    print("\nFalling back to writing literal values into D because formula verification failed or was incompatible.")
    wb_out = load_workbook(input_path)
    ws_out = wb_out[orig_sheet_names[0]]
    
    # Preserve D1 header, write only data rows
    for r in data_rows:
        ws_out.cell(r, 4).value = expected[r]
    
    wb_out.save(output_path)
    print("Saved literal-value version to:", output_path)
    
    recalc_result_2 = await recalculate(output_path)
    print("Recalculate result (literal version):", recalc_result_2)
    
    wb_check2 = load_workbook(output_path)
    if wb_check2.sheetnames != orig_sheet_names:
        print("Sheet names changed after recalc on literal version:", wb_check2.sheetnames, "-> restoring", orig_sheet_names)
        for i, desired in enumerate(orig_sheet_names):
            wb_check2.worksheets[i].title = desired
        wb_check2.save(output_path)
    else:
        print("Sheet names preserved on literal version.")
    
    wb_final_verify = load_workbook(output_path, data_only=True)
    ws_final_verify = wb_final_verify[orig_sheet_names[0]]
    
    final_failures = []
    print("\nFinal verified target range D2:D27:")
