        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    if nonempty_rows:
        print("non-empty row range:", min(nonempty_rows), "to", max(nonempty_rows), "count:", len(nonempty_rows))
    else:
        print("No non-empty rows")
        continue
    
    # headers from first few rows to infer header row
    for r in range(1, min(3, ws.max_row) + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    
    headers = [display(ws.cell(1, c).value) for c in range(1, ws.max_column + 1)]
    print("Assumed row 1 headers:", headers)
    
    # sample first 10 rows
