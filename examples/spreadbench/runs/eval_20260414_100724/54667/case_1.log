            if r <= 10 or r >= 54 or (isinstance(g, str) and g.startswith("=")):
                print(f"Row {r}: D={d!r}, E={e!r}, G={g!r}, M={m!r}")

# Also inspect formulas in DATA sheet if present
if "DATA" in wb.sheetnames:
