# Modify G3:G58 by wrapping existing formula
for r in range(3, 59):
    g_cell = ws[f"G{r}"]
    old_formula = g_cell.value
    if isinstance(old_formula, str) and old_formula.startswith("="):
        inner = old_formula[1:]  # strip leading "=" for nesting
        new_formula = f'=IF(E{r}=D{r},M{r},{inner})'
