        "row": r,
        "ESTAB": estab,
        "URN": urn,
        "SCHNAME": ws_ks4[f"D{r}"].value,
        "ATT8SCR": ws_ks4[f"E{r}"].value,
        "P8PUP": ws_ks4[f"F{r}"].value,
        "P8MEA": ws_ks4[f"G{r}"].value,
        "P8CILOW": ws_ks4[f"H{r}"].value,
        "P8CIUPP": ws_ks4[f"I{r}"].value,
        "P8MEA_ORIG": ws_ks4[f"J{r}"].value,
        "PTL2BASICS_95": ws_ks4[f"K{r}"].value,
        "EBACCAPS": ws_ks4[f"L{r}"].value,
    }
    if estab is not None:
        ks4_by_estab[estab] = rec
    if urn is not None:
        ks4_by_urn[urn] = rec

ks4_stats = Counter()
for r in range(2, ws_comp.max_row + 1):
    estab = as_intish(ws_comp[f"C{r}"].value)
    if estab is None:
        ks4_stats["blank_c"] += 1
    elif estab in ks4_by_estab:
        ks4_stats["ks4_match_by_estab"] += 1
    else:
        ks4_stats["no_ks4_for_estab"] += 1

print("\nKS4 join stats against compiled C:")
print(dict(ks4_stats))

print("\nRelevant compiled samples around targets (rows 2-12 and last 5):")
for r in list(range(2, 13)) + list(range(ws_comp.max_row - 4, ws_comp.max_row + 1)):
    vals = {col: ws_comp[f"{col}{r}"].value for col in ["A","B","C","E","L","AC","AD","AE","AF","AG","AH","AI","AJ"]}
    print(r, vals)
