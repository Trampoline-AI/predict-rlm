        print(f"Row {r} first cols:", vals)
    # header candidates row1 and row2
    row1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print("Row1 headers/values:", row1)
    if row2:
        print("Row2 values:", row2)
    # first non-empty 10 rows
    print("\nFirst up to 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    print("\nLast up to 5 rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Also scan for formulas in first/used area
print("\nFormula scan:")
for ws in wb.worksheets:
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print(ws.title, "formula_count:", len(formulas))
    print("First 20 formulas:", formulas[:20])

# Print merged cells and hidden clues
for ws in wb.worksheets:
    if ws.merged_cells.ranges:
        print(f"{ws.title} merged ranges:", list(ws.merged_cells.ranges)[:20])
