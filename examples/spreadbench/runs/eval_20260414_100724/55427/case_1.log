def sheet_info(ws):
    print(f"\n=== SHEET: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # collect first 3 rows raw
    for r in range(1, min(ws.max_row, 3) + 1):
