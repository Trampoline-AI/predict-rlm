import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

workbook_summary = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    headers = row_values(ws, 1, ws.max_column)
    workbook_summary[sname] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
    }
    print(f"\n=== Sheet: {sname} ===")
    print(f"Rows: {ws.max_row}, Cols: {ws.max_column}")
    print("Headers row 1:")
    for idx, h in enumerate(headers, start=1):
        print(f"  {idx} ({get_column_letter(idx)}): {h!r}")
    print("First 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"Row {r}: {row_values(ws, r, ws.max_column)}")
    print("Last 5 rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        print(f"Row {r}: {row_values(ws, r, ws.max_column)}")

# Try to identify relevant sheet/header row candidates
candidates = []
for sname in wb.sheetnames:
    ws = wb[sname]
    for hr in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
        normalized = [str(v).strip().lower() if v is not None else "" for v in vals]
        if any("procedure category id" == v for v in normalized):
            candidates.append((sname, hr, normalized.index("procedure category id") + 1))

print("\nHeader candidates for 'Procedure Category ID':", candidates)

# Print detailed context around candidates
for sname, hr, col in candidates:
    ws = wb[sname]
    print(f"\nDetailed context for candidate sheet={sname}, header_row={hr}, proc_col={col} ({get_column_letter(col)})")
    headers = [ws.cell(hr, c).value for c in range(1, ws.max_column + 1)]
    for idx, h in enumerate(headers, start=1):
        print(f"  {idx} ({get_column_letter(idx)}): {h!r}")
    # Show rows near top and bottom using the detected header row
    first_data = hr + 1
    for r in range(first_data, min(ws.max_row, first_data + 9) + 1):
        print(f"Data row {r}: {row_values(ws, r, ws.max_column)}")
    for r in range(max(first_data, ws.max_row - 4), ws.max_row + 1):
        print(f"Tail row {r}: {row_values(ws, r, ws.max_column)}")
