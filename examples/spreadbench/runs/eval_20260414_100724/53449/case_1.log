```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Confirm exact target/source cells before writing
print("Using sheet:", ws.title)
print("Source header F1:", ws["F1"].value)
print("Current target G1:", ws["G1"].value)
print("Current G2:G16 before write:", [ws.cell(r, 7).value for r in range(2, ws.max_row + 1)])

# Write header in new column G and copy formatting from prior column/header
ws["G1"] = "Test"
ws["G1"].font = copy(ws["F1"].font)
ws["G1"].fill = copy(ws["F1"].fill)
ws["G1"].border = copy(ws["F1"].border)
ws["G1"].alignment = copy(ws["F1"].alignment)
ws["G1"].number_format = ws["F1"].number_format
ws["G1"].protection = copy(ws["F1"].protection)

# Copy column width from F to G if defined
if "F" in ws.column_dimensions:
    ws.column_dimensions["G"].width = ws.column_dimensions["F"].width

# Fill data rows: X only where Procedure Category ID == "Covid Test", else blank
written = []
for r in range(2, ws.max_row + 1):
    source_val = ws.cell(r, 6).value
    target = ws.cell(r, 7)
    source_style = ws.cell(r, 6)

    # Copy formatting from prior column same row
    target.font = copy(source_style.font)
    target.fill = copy(source_style.fill)
    target.border = copy(source_style.border)
    target.alignment = copy(source_style.alignment)
    target.number_format = source_style.number_format
    target.protection = copy(source_style.protection)

    target.value = "X" if source_val == "Covid Test" else ""
    written.append((r, source_val, target.value))

print("Written rows summary:", written)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate as required
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation; fix sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheet_names:
    # Rename sheets back by position
    for idx, original_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = original_name
    wb_check.save(output_path)
    print("Renamed sheets back to original:", original_sheet_names)

# Final verification with data_only read
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Sheet1"]

target_values = [(f"G{r}", wsv.cell(r, 7).value) for r in range(1, wsv.max_row + 1)]
print("Verified G1:G16:", target_values)

# Sanity-check expected flags
x_rows = [r for r in range(2, wsv.max_row + 1) if wsv.cell(r, 7).value == "X"]
blank_rows = [r for r in range(2, wsv.max_row + 1) if wsv.cell(r, 7).value in (None, "")]
print("Rows flagged X:", x_rows)
print("Rows blank:", blank_rows)

final_output_spreadsheet = output_path
```
