import os
import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.styles import PatternFill

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Reload fresh workbook for modification
wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]

# Find exact target sheet/header cell for '0-15'
target = None
for sname in wb.sheetnames:
    ws = wb[sname]
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.strip() == "0-15":
                target = (sname, r, c)
                break
        if target:
            break
    if target:
        break

print("Target found:", target)
assert target is not None, "Could not find exact header '0-15'"

sheet_name, header_row, source_col = target
ws = wb[sheet_name]

print("Before move:")
for r in range(header_row, min(ws.max_row, header_row + 6) + 1):
    print(r, [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)])

# Only move if 0-15 is not already in column B
if ws.cell(header_row, 2).value != "0-15":
    # Insert new column B
    ws.insert_cols(2, 1)
    
    # After inserting B, original source col shifts right by 1 if it was >= 2
    shifted_source_col = source_col + 1 if source_col >= 2 else source_col
    
    # Copy full column contents/styles from shifted source into new B
    max_row = ws.max_row
    for r in range(1, max_row + 1):
        src = ws.cell(r, shifted_source_col)
        dst = ws.cell(r, 2)
        
        dst.value = src.value
        if src.has_style:
            dst.font = copy.copy(src.font)
            dst.fill = copy.copy(src.fill)
            dst.border = copy.copy(src.border)
            dst.alignment = copy.copy(src.alignment)
            dst.number_format = src.number_format
            dst.protection = copy.copy(src.protection)
        if src._style is not None:
            dst._style = copy.copy(src._style)
        if src.hyperlink:
            dst._hyperlink = copy.copy(src.hyperlink)
        if src.comment:
            dst.comment = copy.copy(src.comment)
    
    # Match column width/hidden state from source column to B
    src_letter = get_column_letter(shifted_source_col)
    b_dim = ws.column_dimensions["B"]
    src_dim = ws.column_dimensions[src_letter]
    b_dim.width = src_dim.width
    b_dim.hidden = src_dim.hidden
    b_dim.bestFit = src_dim.bestFit
    b_dim.outlineLevel = src_dim.outlineLevel
    b_dim.collapsed = src_dim.collapsed
    if src_dim.style is not None:
        b_dim.style = src_dim.style
    
    # Delete the old shifted source column to complete a true move
    ws.delete_cols(shifted_source_col, 1)

print("\nAfter move (in-memory):")
for r in range(header_row, min(ws.max_row, header_row + 6) + 1):
    print(r, [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12) + 1)])

# Save output
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open after recalc and repair sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
current_sheet_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_sheet_names)

if current_sheet_names != original_sheet_names:
    # Rename back by position
    for idx, orig_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = orig_name
    wb_check.save(outfile)
    print("Renamed sheet names back to:", original_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("\nVerified sheet names:", wb_verify.sheetnames)

vws = wb_verify[sheet_name]
print("\nVerification target area A:L rows 5:11")
