print("After writing formulas (sample):")
for r in [2, 3, 4, 5, ws.max_row-2, ws.max_row-1, ws.max_row]:
    if 2 <= r <= ws.max_row:
        print(f"E{r} formula:", ws[f"E{r}"].value)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc; fix sheet names if LibreOffice changed them
wb_post = load_workbook(output_path)
post_sheet_names = wb_post.sheetnames[:]
print("Sheet names after recalc/reload:", post_sheet_names)

if post_sheet_names != original_sheet_names:
    print("Sheet names changed; renaming back to originals.")
    if len(post_sheet_names) == len(original_sheet_names):
        for ws_obj, orig_name in zip(wb_post.worksheets, original_sheet_names):
            ws_obj.title = orig_name
        wb_post.save(output_path)
        print("Renamed back and saved.")
    else:
        print("WARNING: Sheet count mismatch; cannot safely rename by position.")

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["master"]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["master"]

print("\nVerification of target cells/formulas/values:")
sample_rows = [2, 3, 4, 5, 10, 20, 50, 100, 150, 154]
sample_rows = [r for r in sample_rows if r <= ws_formula.max_row]

for r in sample_rows:
    print(
        f"Row {r}: "
        f"B={ws_values[f'B{r}'].value}, "
        f"D={ws_values[f'D{r}'].value}, "
        f"E_formula={ws_formula[f'E{r}'].value}, "
