import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def sheet_preview(ws, max_sample_head=10, max_sample_tail=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    
    # find actual non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("First non-empty row:", nonempty_rows[0], "Last non-empty row:", nonempty_rows[-1])
    
    head_rows = nonempty_rows[:max_sample_head]
    tail_rows = nonempty_rows[-max_sample_tail:] if len(nonempty_rows) > max_sample_head else []
    shown = []
    for r in head_rows + [rr for rr in tail_rows if rr not in head_rows]:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        shown.append((r, vals))
    print("Sample rows:")
    for r, vals in shown:
        print(f"Row {r}: {vals}")

for ws in wb.worksheets:
    sheet_preview(ws)

# Inspect specific referenced cells/range
for ws in wb.worksheets:
    print(f"\nSpecific inspection on sheet {ws.title}:")
    for coord in ["B2", "D2", "E2", "A1", "A2", "B1", "C1", "D1", "E1"]:
        print(coord, "=>", ws[coord].value)

    # print row 2 with coordinates
    row2 = {f"{get_column_letter(c)}2": ws.cell(2, c).value for c in range(1, min(ws.max_column, 10)+1)}
    print("Row 2 first 10 cols:", row2)
