        if bval > 37.5 and gt_row is None:
            gt_row = r
    if lt_row and eq_row and gt_row:
        break

print("\nRepresentative condition checks:")
for label, r in [("hours<37.5", lt_row), ("hours=37.5", eq_row), ("hours>37.5", gt_row)]:
    if r is not None:
        print(
