    )

# Find representative rows for each condition to verify logic
lt_row = eq_row = gt_row = None
for r in range(2, ws_values.max_row + 1):
    bval = ws_values[f"B{r}"].value
    if isinstance(bval, (int, float)):
        if bval < 37.5 and lt_row is None:
