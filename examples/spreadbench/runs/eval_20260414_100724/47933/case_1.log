os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook normally
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["master"]

print("Original sheet names:", original_sheet_names)
print("Target sheet:", ws.title)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Target column/header:", "E /", ws["E1"].value)
print("Rows to inspect/write:", 2, "to", ws.max_row)

# Print existing target formulas before modification
print("\nBefore modification (sample E formulas):")
for r in [2, 3, 4, 5, ws.max_row-2, ws.max_row-1, ws.max_row]:
    if 2 <= r <= ws.max_row:
        print(
            f"Row {r}:",
            "B=", ws[f"B{r}"].value,
            "D=", ws[f"D{r}"].value,
            "E=", ws[f"E{r}"].value
        )

# Write corrected formulas to all relevant rows in column E
written_rows = []
for r in range(2, ws.max_row + 1):
