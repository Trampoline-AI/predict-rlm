Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load original workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Confirm exact target columns again
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
header_map = {str(h).strip().lower(): i for i, h in enumerate(headers, start=1) if h is not None}
source_col = header_map["column1"]   # A
total_col = header_map["total"]      # D

print("Headers:", headers)
print("Source column:", source_col, get_column_letter(source_col))
print("Target column:", total_col, get_column_letter(total_col))

# Print existing formulas before modification
print("\nExisting Total formulas before change:")
for r in range(2, ws.max_row + 1):
    print(f"D{r}:", ws.cell(r, total_col).value)

# Modify existing formulas in-place
for r in range(2, ws.max_row + 1):
    src_ref = f"{get_column_letter(source_col)}{r}"
    cell = ws.cell(r, total_col)
    current = cell.value
    
    # Only modify existing formula cells in Total column
    if isinstance(current, str) and current.startswith("="):
        base = current[1:]  # strip leading "=" before nesting
        new_formula = f'=IF({src_ref}="A",({base})+10,IF({src_ref}="B",({base})-10,({base})))'
        cell.value = new_formula
    else:
        # Fallback if there were no existing formula/value pattern
        b_ref = f"B{r}"
        c_ref = f"C{r}"
        cell.value = f'=IF({src_ref}="A",SUM({b_ref}:{c_ref})+10,IF({src_ref}="B",SUM({b_ref}:{c_ref})-10,SUM({b_ref}:{c_ref})))'

print("\nUpdated Total formulas:")
for r in range(2, ws.max_row + 1):
    print(f"D{r}:", ws.cell(r, total_col).value)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore any changed sheet names
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", original_sheet_names)
    for i, expected_name in enumerate(original_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected_name
    wb_after.save(output_path)

# Verify formulas in normal mode
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula["Sheet1"]
print("\nVerification - formulas in target cells:")
for r in range(2, wsf.max_row + 1):
    print(f"D{r} formula:", wsf[f"D{r}"].value)

# Verify evaluated values in data_only mode
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values["Sheet1"]

print("\nVerification - evaluated values:")
verified = []
for r in range(2, wsv.max_row + 1):
    a = wsv[f"A{r}"].value
    b = wsv[f"B{r}"].value
    c = wsv[f"C{r}"].value
    d = wsv[f"D{r}"].value
    expected = (b + c + 10) if a == "A" else ((b + c - 10) if a == "B" else (b + c if b is not None and c is not None else None))
    verified.append((r, a, b, c, d, expected))
    print(f"Row {r}: A={a!r}, B={b}, C={c}, D={d}, expected={expected}")

all_ok = all(d == expected and d is not None for _, _, _, _, d, expected in verified)
print("\nAll verified:", all_ok)

final_output_path = output_path
```
