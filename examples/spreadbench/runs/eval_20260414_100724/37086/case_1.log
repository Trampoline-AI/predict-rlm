        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(f"Row {r}: {row_values(ws, r, ws.max_column)}")
    
    # Header mapping and likely target/source columns
    normalized = {}
    for idx, h in enumerate(headers, start=1):
        key = str(h).strip().lower() if h is not None else ""
        if key:
            normalized[key] = idx
    
    print("\nDetected header mapping:")
    for k, idx in normalized.items():
        print(f"  {k!r} -> {get_column_letter(idx)} ({idx})")
    
