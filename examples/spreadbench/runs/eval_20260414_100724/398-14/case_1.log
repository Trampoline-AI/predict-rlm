from openpyxl.styles import Alignment, Font
from collections import defaultdict
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb["COLLECTION"]

print("COLLECTION dimensions:", ws.max_row, ws.max_column)
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"Row {r}: {vals}")

print("\nCOLLECTION formulas and styles:")
for r in range(1, ws.max_row + 1):
    row_info = []
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        row_info.append({
            "coord": cell.coordinate,
            "value": cell.value,
            "bold": cell.font.bold,
            "name": cell.font.name,
            "size": cell.font.sz,
            "color": cell.font.color.type + ":" + str(cell.font.color.rgb) if cell.font.color and getattr(cell.font.color, "type", None) else None,
            "halign": cell.alignment.horizontal,
        })
    print(f"Detailed row {r}:")
    for x in row_info:
        print(x)

# Aggregate source sheets by (TY, OR), also track BR and items seen
src_sheets = [s for s in wb.sheetnames if s != "COLLECTION"]
agg = defaultdict(lambda: {"sale": 0.0, "ret": 0.0, "brs": set(), "rows": []})

for s in src_sheets:
    sh = wb[s]
    headers = [sh.cell(1, c).value for c in range(1, sh.max_column + 1)]
    header_idx = {h: i+1 for i, h in enumerate(headers) if h is not None}
    print(f"\nSheet {s} header_idx:", header_idx)
    for r in range(2, sh.max_row + 1):
        ty = sh.cell(r, header_idx["TY"]).value if "TY" in header_idx else None
        orv = sh.cell(r, header_idx["OR"]).value if "OR" in header_idx else None
        br = sh.cell(r, header_idx["BR"]).value if "BR" in header_idx else None
        sale = sh.cell(r, header_idx["SALE"]).value if "SALE" in header_idx else None
        ret = sh.cell(r, header_idx["RET"]).value if "RET" in header_idx else None
        if ty is None and orv is None and br is None and sale is None and ret is None:
            continue
        key = (ty, orv)
        if br is not None:
            agg[key]["brs"].add(br)
        def num(v):
            if v in (None, "", "-"):
                return 0.0
            return float(v)
        agg[key]["sale"] += num(sale) if "SALE" in header_idx else 0.0
        agg[key]["ret"] += num(ret) if "RET" in header_idx else 0.0
        agg[key]["rows"].append((s, r, br, sale, ret))

print("\nAggregated by (TY, OR):")
for key in sorted(agg.keys(), key=lambda x: (str(x[0]), str(x[1]))):
    print(key, agg[key])

print("\nCompare COLLECTION existing rows to aggregate:")
for r in range(2, ws.max_row + 1):
    item, br, ty, orv, sale, ret, bal = [ws.cell(r, c).value for c in range(1, 8)]
    key = (ty, orv)
    print({
        "row": r,
        "key": key,
        "collection": {"item": item, "br": br, "sale": sale, "ret": ret, "bal": bal},
        "aggregate": agg.get(key)
    })
