```repl
from openpyxl import load_workbook
from openpyxl.styles import Font, Alignment
from copy import copy
from collections import defaultdict
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]

# Identify collection sheet case-insensitively
collection_name = None
for s in wb.sheetnames:
    if s.strip().lower() == "collection":
        collection_name = s
        break
if collection_name is None:
    raise ValueError("Could not find collection sheet")
ws = wb[collection_name]

# Inspect current collection succinctly
print("Using collection sheet:", collection_name)
print("Current collection rows:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 8)])

# Build dynamic aggregation across all other sheets
source_sheets = [s for s in wb.sheetnames if s != collection_name]
agg = defaultdict(lambda: {"sale": 0.0, "ret": 0.0, "br": None, "seen": []})
first_seen_order = []

def as_num(v):
    if v in (None, "", "-"):
        return 0.0
    try:
        return float(v)
    except Exception:
        return 0.0

for s in source_sheets:
    sh = wb[s]
    headers = [sh.cell(1, c).value for c in range(1, sh.max_column + 1)]
    idx = {h: i + 1 for i, h in enumerate(headers) if h is not None}
    print(f"Source {s}: max_row={sh.max_row}, headers={headers}")
    for needed in ["BR", "TY", "OR"]:
        if needed not in idx:
            raise ValueError(f"Sheet {s} missing required column {needed}")
    for r in range(2, sh.max_row + 1):
        ty = sh.cell(r, idx["TY"]).value
        orv = sh.cell(r, idx["OR"]).value
        br = sh.cell(r, idx["BR"]).value
        sale = sh.cell(r, idx["SALE"]).value if "SALE" in idx else None
        ret = sh.cell(r, idx["RET"]).value if "RET" in idx else None
        
        if all(v in (None, "") for v in [ty, orv, br, sale, ret]):
            continue
        
        key = (ty, orv)
        if key not in agg:
            first_seen_order.append(key)
        if agg[key]["br"] is None and br not in (None, ""):
            agg[key]["br"] = br
        agg[key]["sale"] += as_num(sale) if "SALE" in idx else 0.0
        agg[key]["ret"] += as_num(ret) if "RET" in idx else 0.0
        agg[key]["seen"].append((s, r, br, sale, ret))

print("\nAggregated keys in source order:")
for k in first_seen_order:
    print(k, agg[k]["br"], agg[k]["sale"], agg[k]["ret"])

# Existing collection order / rows
existing_keys = []
existing_key_to_row = {}
existing_item_map = {}
existing_br_map = {}

for r in range(2, ws.max_row + 1):
    item = ws.cell(r, 1).value
    br = ws.cell(r, 2).value
    ty = ws.cell(r, 3).value
    orv = ws.cell(r, 4).value
    if ty in (None, "") and orv in (None, ""):
        continue
    key = (ty, orv)
    existing_keys.append(key)
    existing_key_to_row[key] = r
    existing_item_map[key] = item
    existing_br_map[key] = br

print("\nExisting collection order:", existing_keys)

# Final order: preserve existing, append missing from sources
final_keys = existing_keys[:]
for key in first_seen_order:
    if key not in existing_key_to_row:
        final_keys.append(key)

print("Final keys:", final_keys)

# Determine template row for appended styling
template_row = ws.max_row if ws.max_row >= 2 else 2
template_styles = {}
for c in range(1, 8):
    template_styles[c] = {
        "style": copy(ws.cell(template_row, c)._style),
        "number_format": ws.cell(template_row, c).number_format,
        "fill": copy(ws.cell(template_row, c).fill),
        "border": copy(ws.cell(template_row, c).border),
        "protection": copy(ws.cell(template_row, c).protection),
    }

# Helper for display formatting
def display_component(value):
    # Per instruction, empties/zeros should show hyphen instead of zero
    return "-" if abs(value) < 1e-12 else value

def font_for_value(v):
    color = "FF0000" if isinstance(v, (int, float)) and v < 0 else None
    return Font(name="Calibri", size=11, bold=False, color=color)

def alignment_for_cell(row_idx, col_idx):
    # Header row all left aligned; data rows A,E,F,G right and B,C,D left
    if row_idx == 1:
        return Alignment(horizontal="left", vertical="center")
    if col_idx in [1, 5, 6, 7]:
        return Alignment(horizontal="right", vertical="center")
    return Alignment(horizontal="left", vertical="center")

# Write/overwrite rows
max_existing_item = 0
for v in existing_item_map.values():
    try:
        max_existing_item = max(max_existing_item, int(float(v)))
    except Exception:
        pass

next_item = max_existing_item + 1

for idx_final, key in enumerate(final_keys, start=2):
    ty, orv = key
    row = idx_final
    info = agg.get(key, {"sale": 0.0, "ret": 0.0, "br": existing_br_map.get(key), "seen": []})
    sale_total = info["sale"]
    ret_total = info["ret"]
    bal_total = sale_total - ret_total
    
    # Determine ITEM and BR
    if key in existing_item_map:
        item_val = existing_item_map[key]
    else:
        item_val = next_item
        next_item += 1
    
    br_val = existing_br_map.get(key)
    if br_val in (None, ""):
        br_val = info["br"]
    
    # If appending beyond current rows, copy styles from template row
    if row > ws.max_row:
        for c in range(1, 8):
            cell = ws.cell(row, c)
            cell._style = copy(template_styles[c]["style"])
            cell.number_format = template_styles[c]["number_format"]
            cell.fill = copy(template_styles[c]["fill"])
            cell.border = copy(template_styles[c]["border"])
            cell.protection = copy(template_styles[c]["protection"])
    
    # Values
    ws.cell(row, 1).value = item_val
    ws.cell(row, 2).value = br_val
    ws.cell(row, 3).value = ty
    ws.cell(row, 4).value = orv
    ws.cell(row, 5).value = display_component(sale_total)
    ws.cell(row, 6).value = display_component(ret_total)
    # G should show calculated value, not formula
    ws.cell(row, 7).value = bal_total if abs(bal_total) >= 1e-12 else "-"
    
    # Font + alignment
    for c in range(1, 8):
        cell = ws.cell(row, c)
        cell.font = font_for_value(cell.value)
        cell.alignment = alignment_for_cell(row, c)

# Header row
headers = ["ITEM", "BR", "TY", "OR", "SALE", "RET", "BALANCE"]
for c, h in enumerate(headers, start=1):
    ws.cell(1, c).value = h
    ws.cell(1, c).font = Font(name="Calibri", size=11, bold=False, color=None)
    ws.cell(1, c).alignment = Alignment(horizontal="left", vertical="center")

# If there are any extra old rows below final output, clear A:G there but don't disturb rest of sheet
for row in range(len(final_keys) + 2, ws.max_row + 1):
    if any(ws.cell(row, c).value not in (None, "") for c in range(1, 8)):
        for c in range(1, 8):
            ws.cell(row, c).value = None
            ws.cell(row, c).font = Font(name="Calibri", size=11, bold=False, color=None)
            ws.cell(row, c).alignment = alignment_for_cell(row, c)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != original_sheetnames:
    print("Sheet names changed after recalculation:", wb_post.sheetnames)
    current_names = wb_post.sheetnames[:]
    if len(current_names) == len(original_sheetnames):
        for old_name, desired_name in zip(current_names, original_sheetnames):
            if old_name != desired_name:
                wb_post[old_name].title = desired_name
        wb_post.save(output_path)
        print("Restored sheet names to:", original_sheetnames)
else:
    print("Sheet names preserved.")

# Verify final output (data values)
wb_verify = load_workbook(output_path, data_only=True)
print("\nVerified sheet names:", wb_verify.sheetnames)
vws = wb_verify[collection_name if collection_name in wb_verify.sheetnames else original_sheetnames[original_sheetnames.index(collection_name)]]

print("\nVerified COLLECTION rows:")
for r in range(1, len(final_keys) + 2):
    print(r, [vws.cell(r, c).value for c in range(1, 8)])

# Verify styles from non-data_only workbook
wb_style = load_workbook(output_path)
sws = wb_style[collection_name if collection_name in wb_style.sheetnames else original_sheetnames[original_sheetnames.index(collection_name)]]

print("\nVerified style snapshot:")
for r in range(1, len(final_keys) + 2):
    vals = [sws.cell(r, c).value for c in range(1, 8)]
    aligns = [sws.cell(r, c).alignment.horizontal for c in range(1, 8)]
    fonts = [(sws.cell(r, c).font.name, sws.cell(r, c).font.sz, sws.cell(r, c).font.bold, sws.cell(r, c).font.color.type if sws.cell(r, c).font.color else None, sws.cell(r, c).font.color.rgb if sws.cell(r, c).font.color and sws.cell(r, c).font.color.type == "rgb" else None) for c in range(1, 8)]
    print(f"Row {r} values={vals}")
    print(f"Row {r} aligns={aligns}")
    print(f"Row {r} fonts={fonts}")

# Store for submission next turn
final_output_path = output_path
