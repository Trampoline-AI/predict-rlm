```repl
import os, zipfile, tempfile, shutil
import xml.etree.ElementTree as ET
from openpyxl import load_workbook

outfile = final_output_spreadsheet
sheet_name = "Sheet1"

# Intended formulas
formula_map = {
    f"E{r}": (
        f'=IF(COUNTIFS($C$4:$C$14,"<"&$B$2,$D$4:$D$14,">"&$B$2)=0,'
        f'"Do Not Select",'
        f'IF($B$2<D{r},"Select Period","Do Not Select"))'
    )
    for r in range(4, 15)
}

# Read current cached values from the recalculated file
wb_cached = load_workbook(outfile, data_only=True)
ws_cached = wb_cached[sheet_name]
cached_map = {cell_ref: ws_cached[cell_ref].value for cell_ref in formula_map}
print("Cached values before XML patch:")
for k, v in cached_map.items():
    print(k, v)

# Determine worksheet XML path from workbook metadata
NS = {
    "main": "http://schemas.openxmlformats.org/spreadsheetml/2006/main",
    "rel": "http://schemas.openxmlformats.org/package/2006/relationships",
    "rmain": "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
}
ET.register_namespace("", NS["main"])
ET.register_namespace("r", NS["rmain"])

with tempfile.TemporaryDirectory() as tmpdir:
    with zipfile.ZipFile(outfile, "r") as zf:
        zf.extractall(tmpdir)

    workbook_xml = os.path.join(tmpdir, "xl", "workbook.xml")
    rels_xml = os.path.join(tmpdir, "xl", "_rels", "workbook.xml.rels")

    wb_tree = ET.parse(workbook_xml)
    wb_root = wb_tree.getroot()
    rels_tree = ET.parse(rels_xml)
    rels_root = rels_tree.getroot()

    # Find r:id for the requested sheet name
    sheet_rid = None
    for sh in wb_root.find("main:sheets", NS):
        if sh.attrib.get("name") == sheet_name:
            sheet_rid = sh.attrib.get(f"{{{NS['rmain']}}}id")
            break
    print("sheet_rid:", sheet_rid)

    target_rel = None
    for rel in rels_root:
        if rel.attrib.get("Id") == sheet_rid:
            target_rel = rel.attrib.get("Target")
            break

    if not target_rel:
        raise RuntimeError(f"Could not find XML target for sheet {sheet_name}")

    sheet_xml_path = os.path.normpath(os.path.join(tmpdir, "xl", target_rel))
    print("Worksheet XML path:", sheet_xml_path)

    sheet_tree = ET.parse(sheet_xml_path)
    sheet_root = sheet_tree.getroot()
    sheetdata = sheet_root.find("main:sheetData", NS)

    # Helper: find/create row and cell
    def get_or_create_row(row_num):
        for row in sheetdata.findall("main:row", NS):
            if int(row.attrib["r"]) == row_num:
                return row
        # create new row in order
        new_row = ET.Element(f"{{{NS['main']}}}row", {"r": str(row_num)})
        inserted = False
        rows = sheetdata.findall("main:row", NS)
        for idx, row in enumerate(rows):
            if int(row.attrib["r"]) > row_num:
                sheetdata.insert(idx, new_row)
                inserted = True
                break
        if not inserted:
            sheetdata.append(new_row)
        return new_row

    def get_or_create_cell(cell_ref):
        import re
        m = re.match(r"([A-Z]+)(\d+)$", cell_ref)
        col_letters, row_num = m.group(1), int(m.group(2))
        row = get_or_create_row(row_num)
        for c in row.findall("main:c", NS):
            if c.attrib.get("r") == cell_ref:
                return c
        new_cell = ET.Element(f"{{{NS['main']}}}c", {"r": cell_ref})
        row.append(new_cell)
        return new_cell

    # Patch each target formula cell with formula + cached string result
    for cell_ref, formula in formula_map.items():
        c = get_or_create_cell(cell_ref)
        # preserve style if present
        preserved_attrs = dict(c.attrib)
        preserved_attrs["r"] = cell_ref
        preserved_attrs["t"] = "str"
        c.attrib.clear()
        c.attrib.update(preserved_attrs)

        for child in list(c):
            c.remove(child)

        f_el = ET.SubElement(c, f"{{{NS['main']}}}f")
        f_el.text = formula[1:] if formula.startswith("=") else formula
        v_el = ET.SubElement(c, f"{{{NS['main']}}}v")
        v_el.text = "" if cached_map[cell_ref] is None else str(cached_map[cell_ref]).strip()

    sheet_tree.write(sheet_xml_path, encoding="utf-8", xml_declaration=True)

    # Repack workbook
    patched_out = outfile
    with zipfile.ZipFile(patched_out, "w", zipfile.ZIP_DEFLATED) as zf:
        for root, dirs, files in os.walk(tmpdir):
            for file in files:
                full = os.path.join(root, file)
                arc = os.path.relpath(full, tmpdir)
                zf.write(full, arc)

print("XML patch complete.")

# Verify formulas are present
wb_formula_view = load_workbook(outfile, data_only=False)
wsf = wb_formula_view[sheet_name]
print("\nFormula view E4:E14:")
for r in range(4, 15):
    print(f"E{r}:", wsf[f"E{r}"].value)

# Verify cached values still present
wb_value_view = load_workbook(outfile, data_only=True)
wsv = wb_value_view[sheet_name]
print("\nData-only view E4:E14:")
for r in range(4, 15):
    print(f"E{r}:", wsv[f"E{r}"].value)

# Extra exact-target verification
print("\nTarget cells verification:")
print("B2:", wsv["B2"].value)
for r in range(4, 15):
    print(
        f"Row {r}: C={wsv[f'C{r}'].value}, D={wsv[f'D{r}'].value}, "
        f"E_formula={wsf[f'E{r}'].value}, E_value={wsv[f'E{r}'].value}"
    )

final_output_spreadsheet = outfile
print("\nReady for submission:", final_output_spreadsheet)
