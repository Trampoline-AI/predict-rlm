        f_el.text = formula[1:] if formula.startswith("=") else formula

        v_el = ET.SubElement(c, f"{{{NS_MAIN}}}v")
        cached = cached_map[cell_ref]
        v_el.text = "" if cached is None else str(cached).strip()

    sheet_tree.write(xml_path, encoding="utf-8", xml_declaration=True)

