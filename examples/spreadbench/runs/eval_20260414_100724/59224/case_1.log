    # Map sheet name -> relationship id
    rid = None
    for sh in wb_root.find("main:sheets", {"main": NS_MAIN}):
        if sh.attrib.get("name") == sheet_name:
            rid = sh.attrib.get(f"{{{NS_DOCREL}}}id")
            break
    print("Sheet rid:", rid)

    target = None
    for rel in rels_root:
        if rel.attrib.get("Id") == rid:
            target = rel.attrib.get("Target")
            break
    print("Relationship target:", target)

    # Resolve absolute vs relative package path
    if target.startswith("/"):
        member_path = target.lstrip("/")
    else:
        member_path = os.path.normpath(os.path.join("xl", target))
    xml_path = os.path.join(tmpdir, *member_path.split("/"))
