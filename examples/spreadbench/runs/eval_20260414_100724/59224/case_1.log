    sheet_data = sheet_root.find("main:sheetData", {"main": NS_MAIN})

    def cell_parts(cell_ref):
        m = re.fullmatch(r"([A-Z]+)(\d+)", cell_ref)
        return m.group(1), int(m.group(2))

    def col_num(col_letters):
        n = 0
        for ch in col_letters:
            n = n * 26 + (ord(ch) - 64)
        return n

    def get_or_create_row(row_num):
        rows = sheet_data.findall(f"{{{NS_MAIN}}}row")
        for row in rows:
            if int(row.attrib["r"]) == row_num:
                return row
        new_row = ET.Element(f"{{{NS_MAIN}}}row", {"r": str(row_num)})
        inserted = False
        for idx, row in enumerate(rows):
            if int(row.attrib["r"]) > row_num:
                sheet_data.insert(idx, new_row)
                inserted = True
                break
        if not inserted:
            sheet_data.append(new_row)
        return new_row

    def get_or_create_cell(cell_ref):
        col_letters, row_num = cell_parts(cell_ref)
        target_col = col_num(col_letters)
        row_el = get_or_create_row(row_num)
        cells = row_el.findall(f"{{{NS_MAIN}}}c")
        for c in cells:
            if c.attrib.get("r") == cell_ref:
                return c
        new_c = ET.Element(f"{{{NS_MAIN}}}c", {"r": cell_ref})
        inserted = False
        for idx, c in enumerate(cells):
            existing_ref = c.attrib.get("r")
            existing_col = col_num(cell_parts(existing_ref)[0])
            if existing_col > target_col:
