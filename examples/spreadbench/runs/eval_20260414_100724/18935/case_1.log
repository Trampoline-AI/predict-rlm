import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

# Load and inspect targeted areas again before modifying
wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheet_names)
print("Target header D16:", ws["D16"].value)
print("Current target cells D17:D22:")
for r in range(17, 23):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value, "->", ws[f"D{r}"].value)

# Identify data table header row and report row ranges from observed structure
data_header_row = 4
data_start_row = 5
# scan until first blank in both A and B after the data header
data_rows = []
r = data_start_row
while r <= ws.max_row:
    if ws.cell(r, 1).value is None and ws.cell(r, 2).value is None:
        break
    data_rows.append(r)
    r += 1

report_header_row = 16
report_rows = []
r = report_header_row + 1
while r <= ws.max_row:
    if all(ws.cell(r, c).value is None for c in range(1, 5)):
        break
    if any(ws.cell(r, c).value is not None for c in range(1, 4)):
        report_rows.append(r)
    r += 1

print("Data rows detected:", data_rows)
print("Report rows detected:", report_rows)

# Map category names to data table columns
category_to_col = {}
for c in range(3, 6):  # C:E
    category_to_col[ws.cell(data_header_row, c).value] = c
print("Category columns:", category_to_col)

# Build lookup values
computed = {}
for rr in report_rows:
    work = ws.cell(rr, 1).value
    category = ws.cell(rr, 2).value
    material = ws.cell(rr, 3).value
    
    target_col = category_to_col.get(category)
    total = 0
    matches = []
    if target_col is not None:
        for dr in data_rows:
            if ws.cell(dr, 1).value == work and ws.cell(dr, 2).value == material:
                val = ws.cell(dr, target_col).value
                num = 0 if val in (None, "") else float(val)
                total += num
                matches.append((dr, val))
    computed[rr] = total
    print(f"Row {rr}: work={work}, category={category}, material={material}, matches={matches}, result={total}")

# Write results into the existing Category Value column D
for rr, val in computed.items():
    # preserve ints like 0 as numeric 0 rather than 0.0 if exact integer
    ws.cell(rr, 4).value = int(val) if float(val).is_integer() else val

# Save
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheet_names)
    # Rename by position back to original names
    for i, orig_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify with data_only=True
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values[original_sheet_names[0]]

print("Verified target cells D17:D22 after save/recalc:")
for r in report_rows:
    print(f"D{r} =", wsv.cell(r, 4).value)

output_spreadsheet = outfile
