```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(outfile if os.path.exists(outfile) else infile)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before rewrite, D17:D22 current contents:")
for r in range(17, 23):
    print(f"D{r} raw =", ws[f"D{r}"].value)

# Use explicit LibreOffice-compatible formulas in the existing target cells.
# Data table: A5:E10 with headers in row 4
for r in range(17, 23):
    formula = (
        f'=IF(B{r}=$C$4,'
        f'SUMPRODUCT(($A$5:$A$10=A{r})*($B$5:$B$10=C{r})*($C$5:$C$10)),'
        f'IF(B{r}=$D$4,'
        f'SUMPRODUCT(($A$5:$A$10=A{r})*($B$5:$B$10=C{r})*($D$5:$D$10)),'
        f'IF(B{r}=$E$4,'
        f'SUMPRODUCT(($A$5:$A$10=A{r})*($B$5:$B$10=C{r})*($E$5:$E$10)),0)))'
    )
    ws[f"D{r}"] = formula

print("Written formulas D17:D22:")
for r in range(17, 23):
    print(f"D{r} formula =", ws[f'D{r}'].value)

os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved formula version to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Restore original sheet names if needed
wb_post = load_workbook(outfile)
if wb_post.sheetnames != original_sheet_names:
    print("Sheet names changed:", wb_post.sheetnames, "restoring to", original_sheet_names)
    for i, orig in enumerate(original_sheet_names):
        wb_post.worksheets[i].title = orig
    wb_post.save(outfile)

# Verify formulas still present
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("Post-save formulas D17:D22:")
for r in range(17, 23):
    print(f"D{r} formula =", wsf[f"D{r}"].value)

# Verify cached results
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]
print("Post-recalc values D17:D22:")
for r in range(17, 23):
    print(f"A{r},B{r},C{r} -> D{r} =", wsv[f"A{r}"].value, wsv[f"B{r}"].value, wsv[f"C{r}"].value, "->", wsv[f"D{r}"].value)

output_spreadsheet = outfile
```
