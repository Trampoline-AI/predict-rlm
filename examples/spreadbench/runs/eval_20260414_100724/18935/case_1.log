original_sheet_names = wb.sheetnames[:]
print("Workbook:", path)
print("Sheet names:", original_sheet_names)

def used_range(ws):
    min_row = None
    max_row = 0
    min_col = None
    max_col = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                if min_row is None or cell.row < min_row:
                    min_row = cell.row
                if min_col is None or cell.column < min_col:
                    min_col = cell.column
                if cell.row > max_row:
                    max_row = cell.row
                if cell.column > max_col:
                    max_col = cell.column
    return min_row, max_row, min_col, max_col

def row_values(ws, r, start_col, end_col):
    vals = []
    for c in range(start_col, end_col + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

for sname in wb.sheetnames:
    ws = wb[sname]
