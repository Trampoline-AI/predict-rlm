Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload fresh
infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheetnames:", original_sheetnames)
print("Sheet dimensions:", ws.max_row, ws.max_column)

# Data layout identified from inspection
data_start_row = 4
label_col = 1       # A
source_start_col = 2  # B
source_end_col = 13   # M
target_col = 14       # N

start_letter = get_column_letter(source_start_col)
end_letter = get_column_letter(source_end_col)
target_letter = get_column_letter(target_col)

# Determine rows that actually contain customer data
data_rows = []
for r in range(data_start_row, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(label_col, source_end_col + 1)]
    if any(v is not None for v in row_vals):
        data_rows.append(r)

print("Data rows:", data_rows)

# Python sanity-check of expected outputs
def is_num(v):
    return isinstance(v, (int, float)) and not isinstance(v, bool)

expected = {}
for r in data_rows:
    vals = [ws.cell(r, c).value for c in range(source_start_col, source_end_col + 1)]
    num_positions = [i + 1 for i, v in enumerate(vals) if is_num(v)]
    if len(num_positions) < 2:
        expected[r] = ""
    else:
        first_pos = num_positions[0]
        second_pos = num_positions[1]
        first_val = vals[first_pos - 1]
        expected[r] = 1 if first_val > 1 else (second_pos - first_pos)

print("Expected Python results:", {f"{target_letter}{r}": expected[r] for r in data_rows})

# Write formulas to target cells
for r in data_rows:
    rng = f"{start_letter}{r}:{end_letter}{r}"
    formula = (
        f'=IF(COUNT({rng})<2,"",'
        f'IF(INDEX({rng},1,MATCH(1,INDEX((ISNUMBER({rng}))*1,0),0))>1,'
        f'1,'
        f'MATCH(1,INDEX(((COLUMN({rng})-COLUMN({start_letter}{r})+1)>MATCH(1,INDEX((ISNUMBER({rng}))*1,0),0))*(ISNUMBER({rng}))*1,0),0)'
        f'-MATCH(1,INDEX((ISNUMBER({rng}))*1,0),0)'
        f'))'
    )
    ws[f"{target_letter}{r}"] = formula

print("Written formulas:")
for r in data_rows:
    print(f"{target_letter}{r} =", ws[f'{target_letter}{r}'].value)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate and restore sheet names if needed
async def recalc_and_restore(path, original_names):
    recalc_result = await recalculate(path)
    print("Recalculate result:", recalc_result)
    wb_chk = load_workbook(path)
    current_names = wb_chk.sheetnames[:]
    print("Sheet names after recalc:", current_names)
    if current_names != original_names and len(current_names) == len(original_names):
        for cur, orig in zip(current_names, original_names):
            if cur != orig:
                wb_chk[cur].title = orig
        wb_chk.save(path)
        print("Restored sheet names to:", wb_chk.sheetnames)
    return

await recalc_and_restore(outfile, original_sheetnames)

# Verify formula results
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]

verified = {f"{target_letter}{r}": wsv[f"{target_letter}{r}"].value for r in data_rows}
print("Verified values after recalc:", verified)

# If formula evaluation failed, fall back to literal values
invalid = []
for r in data_rows:
    v = wsv[f"{target_letter}{r}"].value
    if v is None or (isinstance(v, str) and v.strip().startswith("#")):
        invalid.append(r)

if invalid:
    print("Formula verification failed for rows:", invalid)
    print("Falling back to static computed values.")
    wb_fix = load_workbook(outfile)
    ws_fix = wb_fix["Sheet1"]
    for r in invalid:
        ws_fix[f"{target_letter}{r}"] = expected[r]
    wb_fix.save(outfile)
    await recalc_and_restore(outfile, original_sheetnames)
    wb_verify2 = load_workbook(outfile, data_only=True)
    ws_verify2 = wb_verify2["Sheet1"]
    verified2 = {f"{target_letter}{r}": ws_verify2[f"{target_letter}{r}"].value for r in data_rows}
    print("Verified values after fallback:", verified2)

# Final exact target area printout
wb_final_formula = load_workbook(outfile, data_only=False)
wsf = wb_final_formula["Sheet1"]
print("Final target cells/formulas:")
for r in data_rows:
    print(
        f"{target_letter}{r}: formula={wsf[f'{target_letter}{r}'].value!r}, "
        f"value={load_workbook(outfile, data_only=True)['Sheet1'][f'{target_letter}{r}'].value!r}"
    )
```
