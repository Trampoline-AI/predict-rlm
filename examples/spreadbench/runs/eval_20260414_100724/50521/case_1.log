    if ws.max_row >= 2:
        print("\nColumn letters + row2 values (up to 25 cols):")
        for c in range(1, min(ws.max_column, 25) + 1):
            print(f"{get_column_letter(c)}: {ws.cell(2,c).value}")
    
    # Scan a small area for formulas
