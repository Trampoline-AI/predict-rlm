import os
from openpyxl import load_workbook

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

targets = {"@9T", "SAL", "T9A"}

# Find true last non-empty row and sample last non-empty rows
true_last_row = 0
for r in range(ws.max_row, 0, -1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v not in (None, "") for v in vals):
        true_last_row = r
        break

print("Worksheet max_row:", ws.max_row)
print("True last non-empty row:", true_last_row)
print("Last 5 non-empty rows:")
for r in range(max(1, true_last_row - 4), true_last_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Collect rows to delete based on exact match in column A, excluding header
rows_to_delete = []
for r in range(2, true_last_row + 1):
    if ws.cell(r, 1).value in targets:
        rows_to_delete.append(r)

print("Total matching rows to delete:", len(rows_to_delete))
print("First 20 matching row numbers:", rows_to_delete[:20])
print("Last 20 matching row numbers:", rows_to_delete[-20:])

# Group into contiguous ranges for efficient deletion
ranges = []
if rows_to_delete:
    start = prev = rows_to_delete[0]
    for r in rows_to_delete[1:]:
        if r == prev + 1:
            prev = r
        else:
            ranges.append((start, prev))
            start = prev = r
    ranges.append((start, prev))

print("Contiguous delete ranges:", ranges)

# Delete from bottom to top
for start, end in reversed(ranges):
    amount = end - start + 1
    ws.delete_rows(start, amount)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
original_names = wb.sheetnames
if wb_after.sheetnames != original_names and len(wb_after.sheetnames) == len(original_names):
    for i, old_name in enumerate(original_names):
        wb_after.worksheets[i].title = old_name
    wb_after.save(out_path)
    print("Renamed sheets back to original:", original_names)

# Verify output
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[original_names[0]]

verify_last_row = 0
for r in range(wsv.max_row, 0, -1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    if any(v not in (None, "") for v in vals):
        verify_last_row = r
        break

remaining_matches = []
for r in range(2, verify_last_row + 1):
    v = wsv.cell(r, 1).value
    if v in targets:
        remaining_matches.append((r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]))

print("Verified sheet names:", wb_verify.sheetnames)
print("Verified true last non-empty row:", verify_last_row)
print("Remaining target rows after deletion:", len(remaining_matches))
print("Remaining matches sample:", remaining_matches[:10])

print("First 10 rows after deletion:")
for r in range(1, min(10, verify_last_row) + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

print("Last 5 non-empty rows after deletion:")
for r in range(max(1, verify_last_row - 4), verify_last_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

final_output_path = out_path
