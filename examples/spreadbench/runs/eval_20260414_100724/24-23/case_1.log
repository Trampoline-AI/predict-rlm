```repl
import os, json, math
from collections import Counter
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input file:", path, os.path.exists(path))

wb = load_workbook(path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

inspection = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    max_row, max_col = ws.max_row, ws.max_column
    
    # headers from row 1
    headers = row_values(ws, 1, max_col)
    
    # sample rows: first 10, last 5 (without duplication)
    first_rows_idx = list(range(1, min(max_row, 10) + 1))
    last_rows_idx = list(range(max(1, max_row - 4), max_row + 1))
    sample_idx = []
    seen = set()
    for r in first_rows_idx + last_rows_idx:
        if r not in seen:
            sample_idx.append(r)
            seen.add(r)
    
    # collect non-empty count in column A and unique sample values
    colA_vals = []
    for r in range(1, max_row + 1):
        v = ws.cell(r, 1).value
        if v is not None and v != "":
            colA_vals.append(v)
    colA_counter = Counter(colA_vals)
    
    inspection[sname] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers": headers,
        "samples": {r: row_values(ws, r, max_col) for r in sample_idx},
        "colA_top_counts": colA_counter.most_common(15),
        "target_counts": {k: colA_counter.get(k, 0) for k in ["@9T", "SAL", "T9A"]},
    }

# Print compact but thorough inspection
for sname, info in inspection.items():
    print("\n" + "="*80)
    print("Sheet:", sname)
    print("Rows:", info["max_row"], "Columns:", info["max_col"])
    print("Headers (row 1):")
    for i, h in enumerate(info["headers"], start=1):
        print(f"  {get_column_letter(i)}: {h!r}")
    print("Column A target counts:", info["target_counts"])
    print("Column A top values:", info["colA_top_counts"][:10])
    print("Sample rows:")
    for r, vals in info["samples"].items():
        print(f"  Row {r}: {vals}")

# Also print exact rows in first 50 where column A matches target values
targets = {"@9T", "SAL", "T9A"}
for sname in wb.sheetnames:
    ws = wb[sname]
    matches = []
    for r in range(1, min(ws.max_row, 200) + 1):
        if ws.cell(r, 1).value in targets:
            matches.append((r, row_values(ws, r, min(ws.max_column, 10))))
    print(f"\nFirst matches in first 200 rows for sheet {sname}:")
    print(matches[:20] if matches else "None")
```
