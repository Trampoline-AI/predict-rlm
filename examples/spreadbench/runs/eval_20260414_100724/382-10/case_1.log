import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Reload fresh workbook for editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[wb.sheetnames[0]]

print("Editing workbook:", input_path)
print("Original sheet names:", original_sheet_names)
print("Target sheet:", ws.title)
print("Target column:", "A")

# Inspect target cells before modifying
before_vals = [(r, ws.cell(r, 1).value) for r in range(1, ws.max_row + 1)]
print("Column A before:", before_vals)

modified_rows = []
kept_rows = []
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 1)
    v = cell.value
    if v is None or v == "":
        continue
    is_comments = isinstance(v, str) and v.strip().lower() == "comments"
    if is_comments:
        kept_rows.append((r, v))
    else:
        modified_rows.append((r, v))
        cell.value = None  # clear value only; preserve formatting

print("Rows kept:", kept_rows)
print("Rows cleared:", modified_rows)

# Save
wb.save(output_path)
print("Saved to:", output_path, "exists:", os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc reload:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # Rename sheets back positionally if recalc/LibreOffice changed names
    if len(wb_after.sheetnames) == len(original_sheet_names):
        for ws_obj, orig_name in zip(wb_after.worksheets, original_sheet_names):
            ws_obj.title = orig_name
        wb_after.save(output_path)
        print("Renamed sheets back to original names:", original_sheet_names)
    else:
        print("WARNING: sheet count changed unexpectedly")

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

after_vals = [(r, wsv.cell(r, 1).value) for r in range(1, wsv.max_row + 1)]
print("Column A after:", after_vals)

# Strong verification
problems = []
for r in range(1, wsv.max_row + 1):
    v = wsv.cell(r, 1).value
    if r in [row for row, _ in kept_rows]:
        if not (isinstance(v, str) and v.strip() == "Comments"):
            problems.append(f"A{r} should be Comments but is {v!r}")
    if r in [row for row, _ in modified_rows]:
        if v not in (None, ""):
            problems.append(f"A{r} should be blank but is {v!r}")

print("Verification problems:", problems if problems else "None")

# Additional concise summary for submission turn
verification_summary = {
    "output_path": output_path,
    "sheet_names": wb_verify.sheetnames,
    "kept_rows": [r for r, _ in kept_rows],
    "cleared_rows": [r for r, _ in modified_rows],
    "problems": problems,
}
print("Verification summary:", verification_summary)
