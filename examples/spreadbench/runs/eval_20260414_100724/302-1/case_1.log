from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string
import os

# Reload fresh workbook from input
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
print("Original sheet names:", original_sheetnames)

# Resolve sheet names robustly
sheet_map = {name.lower(): name for name in wb.sheetnames}
items_name = sheet_map["items"]
sheet1_name = sheet_map["sheet1"] if "sheet1" in sheet_map else sheet_map["sheet1".lower()] if "sheet1".lower() in sheet_map else sheet_map["sheet1"]
sheet2_name = sheet_map["sheet2"] if "sheet2" in sheet_map else sheet_map["sheet2".lower()] if "sheet2".lower() in sheet_map else sheet_map["sheet2"]

# Because actual names are uppercase SHEET1/SHEET2, handle explicitly
if "sheet1" not in sheet_map:
    sheet1_name = [n for n in wb.sheetnames if n.lower() == "sheet1"][0]
else:
    sheet1_name = sheet_map["sheet1"]
if "sheet2" not in sheet_map:
    sheet2_name = [n for n in wb.sheetnames if n.lower() == "sheet2"][0]
else:
    sheet2_name = sheet_map["sheet2"]

ws_items = wb[items_name]
ws1 = wb[sheet1_name]
ws2 = wb[sheet2_name]

print("Resolved target sheets:", items_name, sheet1_name, sheet2_name)
print("Column B index:", column_index_from_string("B"))

# Inspect exact target ranges before writing
def print_b_range(ws, label):
    print(f"\n{label} current column B values:")
    for r in range(1, ws.max_row + 1):
        print(f"{label}!B{r} = {ws.cell(r, 2).value!r}")

print_b_range(ws_items, items_name)
print_b_range(ws1, sheet1_name)
print_b_range(ws2, sheet2_name)

# Perform row-by-row replacement based on ITEMS column B
changes = []
for target_ws, target_name in [(ws1, sheet1_name), (ws2, sheet2_name)]:
    last_row = min(target_ws.max_row, ws_items.max_row)
    for r in range(2, last_row + 1):  # skip header row
        src_val = ws_items.cell(r, 2).value
        old_val = target_ws.cell(r, 2).value
        if src_val is not None and old_val != src_val:
            target_ws.cell(r, 2).value = src_val
            changes.append((target_name, r, old_val, src_val))

print(f"\nTotal changes made: {len(changes)}")
for ch in changes:
    print(f"{ch[0]}!B{ch[1]}: {ch[2]!r} -> {ch[3]!r}")

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # Rename back by position to preserve original names
    if len(wb_check.sheetnames) == len(original_sheetnames):
        for ws, orig_name in zip(wb_check.worksheets, original_sheetnames):
            ws.title = orig_name
        wb_check.save(out_path)
        print("Restored original sheet names:", original_sheetnames)
    else:
        print("Warning: sheet name count changed unexpectedly; not renaming.")

# Verify saved output values after recalculation
wb_verify = load_workbook(out_path, data_only=True)
print("\nVerification sheet names:", wb_verify.sheetnames)

v_items = wb_verify[items_name]
v1 = wb_verify[sheet1_name]
v2 = wb_verify[sheet2_name]

def verify_match(target_ws, target_name, items_ws):
    last_row = min(target_ws.max_row, items_ws.max_row)
    mismatches = []
    print(f"\nVerifying {target_name}!B2:B{last_row} against {items_name}!B2:B{last_row}")
    for r in range(2, last_row + 1):
        tgt = target_ws.cell(r, 2).value
        src = items_ws.cell(r, 2).value
        print(f"Row {r}: {target_name}!B{r}={tgt!r} | {items_name}!B{r}={src!r}")
        if tgt != src or tgt in (None, ""):
            mismatches.append((r, tgt, src))
    return mismatches

m1 = verify_match(v1, sheet1_name, v_items)
m2 = verify_match(v2, sheet2_name, v_items)

print("\nMismatch summary:")
print("SHEET1 mismatches:", m1)
print("SHEET2 mismatches:", m2)

final_output_path = out_path
