def nonempty_bounds(ws):
    max_r = ws.max_row
    max_c = ws.max_column
    # Trim trailing empty rows
    last_r = 0
    last_c = 0
    for r in range(1, max_r + 1):
        row_has = False
        for c in range(1, max_c + 1):
            v = ws.cell(r, c).value
            if v is not None and v != "":
                row_has = True
                last_c = max(last_c, c)
        if row_has:
            last_r = r
    return last_r, last_c

for s in wb.sheetnames:
    ws = wb[s]
    last_r, last_c = nonempty_bounds(ws)
    headers = [ws.cell(1, c).value for c in range(1, last_c + 1)]
    print(f"\n=== Sheet: {s} ===")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}, nonempty_last_row={last_r}, nonempty_last_col={last_c}")
    print("Headers row 1:", headers)
    # Print B2 and a few column B values + formulas info
    for target in ["B1", "B2", "B3", "B4", "B5"]:
        cell = ws[target]
        print(f"{s}!{target} -> value={cell.value!r}, data_type={cell.data_type}")
