import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, row)
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, row)
    
    # Print column E values if present
    if ws.max_column >= 5:
        print("Column E sample values (rows 1-15):")
        for r in range(1, min(ws.max_row, 15) + 1):
            print(f"E{r} =", ws.cell(r, 5).value)
        matches = []
        for r in range(1, ws.max_row + 1):
            v = ws.cell(r, 5).value
            s = "" if v is None else str(v)
            if s.startswith("Z1") or s.startswith("X1"):
                matches.append((r, v))
        print("Rows where col E starts with Z1 or X1 (up to first 50 shown):", matches[:50], "count=", len(matches))

for ws in wb.worksheets:
    sheet_summary(ws)
