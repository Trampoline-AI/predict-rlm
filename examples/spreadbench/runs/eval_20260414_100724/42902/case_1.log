import os
from openpyxl import load_workbook

# Reload fresh workbook for full inspection and modification
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
original_sheet_names = wb.sheetnames[:]

print("Full source column A values:")
source_vals = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    source_vals.append(v)
    print(f"A{r} = {v!r}")

# Determine non-empty source rows in A
nonempty_a_rows = [r for r in range(1, ws.max_row + 1) if ws.cell(r, 1).value not in (None, "")]
print("Non-empty A rows:", nonempty_a_rows)
print("Count:", len(nonempty_a_rows))

# Inspect exact target area before writing
record_count = len(nonempty_a_rows) // 3
print(f"Expected complete groups of 3: {record_count}")
print("Target range before writing:")
for r in range(1, record_count + 1):
    print(f"Row {r}: D={ws.cell(r,4).value!r}, E={ws.cell(r,5).value!r}, F={ws.cell(r,6).value!r}")

# Perform transpose: each group of 3 rows in A becomes one row in D:F
for i in range(record_count):
    group = source_vals[i*3:(i+1)*3]
    ws.cell(i + 1, 4).value = group[0]  # D
    ws.cell(i + 1, 5).value = group[1]  # E
    ws.cell(i + 1, 6).value = group[2]  # F

print("Target range after writing (in-memory):")
for r in range(1, record_count + 1):
    print(f"Row {r}: D={ws.cell(r,4).value!r}, E={ws.cell(r,5).value!r}, F={ws.cell(r,6).value!r}")

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if they changed
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheet_names)
    # Rename by position to original names
    for idx, orig_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = orig_name
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Final sheet names:", wb_check.sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

verified = []
print("Verified target cells after save/recalc:")
for r in range(1, record_count + 1):
    row_vals = (wsv.cell(r,4).value, wsv.cell(r,5).value, wsv.cell(r,6).value)
    verified.append(row_vals)
    print(f"D{r}:F{r} = {row_vals}")

# Basic sanity checks
all_nonblank = all(any(v not in (None, "") for v in row) for row in verified)
print("All target rows populated:", all_nonblank)

output_spreadsheet = output_path
print("Prepared output_spreadsheet:", output_spreadsheet)
