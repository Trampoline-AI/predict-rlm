import zipfile, shutil, posixpath, xml.etree.ElementTree as ET
from pathlib import Path
from openpyxl import load_workbook

out_path = Path(output_spreadsheet)
print("Working on:", out_path)

# Desired formula and cached value
formula_with_equals = '=SUMIFS($B$2:$B$31,$A$2:$A$31,">="&WORKDAY($I$4,-3),$A$2:$A$31,"<="&$I$4)'
formula_text = formula_with_equals[1:]

# Recompute cached value from sheet data for safety
