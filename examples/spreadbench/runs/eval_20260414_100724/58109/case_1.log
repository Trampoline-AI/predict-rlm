        vals.append((d, v))
cached_value = sum(v for d, v in vals[-4:])
print("Cached value to store:", cached_value)

NS = {
    "main": "http://schemas.openxmlformats.org/spreadsheetml/2006/main",
    "rel": "http://schemas.openxmlformats.org/officeDocument/2006/relationships",
    "pkgrel": "http://schemas.openxmlformats.org/package/2006/relationships",
}
ET.register_namespace("", NS["main"])
ET.register_namespace("r", NS["rel"])

def map_sheet_name_to_xml(zf):
    wb_xml = ET.fromstring(zf.read("xl/workbook.xml"))
    rels_xml = ET.fromstring(zf.read("xl/_rels/workbook.xml.rels"))

    rel_map = {}
    for rel in rels_xml.findall("{%s}Relationship" % NS["pkgrel"]):
        rel_map[rel.attrib["Id"]] = rel.attrib["Target"]

    mapping = {}
    for sheet in wb_xml.find("{%s}sheets" % NS["main"]).findall("{%s}sheet" % NS["main"]):
        name = sheet.attrib["name"]
        rid = sheet.attrib["{%s}id" % NS["rel"]]
        target = rel_map[rid]
        if not target.startswith("xl/"):
            target = "xl/" + target
        mapping[name] = target
    return mapping

with zipfile.ZipFile(out_path, "r") as zin:
    sheet_map = map_sheet_name_to_xml(zin)
    print("Sheet XML mapping:", sheet_map)
    sheet_xml_path = sheet_map["Sheet1"]

    sheet_root = ET.fromstring(zin.read(sheet_xml_path))
    sheet_data = sheet_root.find("{%s}sheetData" % NS["main"])

    target_cell = None
    target_row = None
    for row in sheet_data.findall("{%s}row" % NS["main"]):
        if row.attrib.get("r") == "6":
            target_row = row
            for c in row.findall("{%s}c" % NS["main"]):
                if c.attrib.get("r") == "I6":
                    target_cell = c
                    break
            break

    print("Found target row:", target_row is not None, "Found I6:", target_cell is not None)
    if target_cell is None:
        raise RuntimeError("Could not locate I6 in sheet XML")

    # Preserve existing attributes like style, but ensure this is a formula cell
    preserved_attrs = dict(target_cell.attrib)
    preserved_attrs.pop("t", None)  # numeric/formula cell shouldn't have string type
    target_cell.attrib.clear()
    target_cell.attrib.update(preserved_attrs)

    # Remove existing children and replace with formula + cached value
    for child in list(target_cell):
        target_cell.remove(child)

    f_el = ET.SubElement(target_cell, "{%s}f" % NS["main"])
    f_el.text = formula_text
    v_el = ET.SubElement(target_cell, "{%s}v" % NS["main"])
    v_el.text = str(cached_value)

    new_sheet_xml = ET.tostring(sheet_root, encoding="utf-8", xml_declaration=True)

    tmp_path = out_path.with_name(out_path.stem + "_patched.xlsx")
    with zipfile.ZipFile(tmp_path, "w", zipfile.ZIP_DEFLATED) as zout:
        for item in zin.infolist():
            data = new_sheet_xml if item.filename == sheet_xml_path else zin.read(item.filename)
            zout.writestr(item, data)

shutil.move(tmp_path, out_path)
print("Patched workbook saved.")

