To sum the last four workdays up to and including the date in `I4`, the correct logic is to sum rows where the date is between `WORKDAY(I4,-3)` and `I4`, inclusive. For this sheet, that corresponds to the four weekday dates `2021-01-06`, `2021-01-07`, `2021-01-08`, and `2021-01-11`.

I’ll write the corrected bounded-range formula into `I6`, save to the output folder with the same filename, recalculate, restore any sheet name changes if needed, and verify the final formula/value in the output file.
Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Determine actual data extent in columns A:B
last_row = 1
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_row = r
        break

print("Original sheetnames:", original_sheetnames)
print("Detected data rows:", 2, "to", last_row)
print("Current I4:", ws["I4"].value)
print("Current I6 formula:", ws["I6"].value)

# Build corrected formula:
# Sum last 4 workdays up to and including I4 -> dates >= WORKDAY(I4,-3) and <= I4
new_formula = f'=SUMIFS($B$2:$B${last_row},$A$2:$A${last_row},">="&WORKDAY($I$4,-3),$A$2:$A${last_row},"<="&$I$4)'
ws["I6"] = new_formula

print("New I6 formula:", ws["I6"].value)

# Save to output path with same filename
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(str(out_path))
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(out_path)
print("Sheetnames after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames:
    print("Restoring original sheet names...")
    for i, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(out_path)
    print("Restored sheetnames:", wb_after.sheetnames)

# Verification: formula workbook
wb_verify_formula = load_workbook(out_path, data_only=False)
wsf = wb_verify_formula[original_sheetnames[0]]

# Verification: values workbook
wb_verify_values = load_workbook(out_path, data_only=True)
wsv = wb_verify_values[original_sheetnames[0]]

print("\nVerification:")
print("Sheetnames final (formula wb):", wb_verify_formula.sheetnames)
print("I4:", wsf["I4"].value)
print("H6:", wsf["H6"].value)
print("I6 formula:", wsf["I6"].value)
print("I6 cached value:", wsv["I6"].value)

# Sanity-check expected value in Python for last four workdays inclusive of I4
today = wsv["I4"].value
matching_rows = []
for r in range(2, last_row + 1):
    d = wsv.cell(r, 1).value
    v = wsv.cell(r, 2).value
    if d is not None and d <= today:
        matching_rows.append((d, v))

last_four = matching_rows[-4:]
expected_sum = sum(v for d, v in last_four)
print("Last four data rows up to I4:", last_four)
print("Expected Python sum:", expected_sum)

output_spreadsheet = str(out_path)
