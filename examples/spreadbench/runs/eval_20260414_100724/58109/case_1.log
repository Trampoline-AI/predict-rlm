from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

inspection = {}

for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Dimensions: rows={max_row}, cols={max_col}")
    print("Headers (row 1):", headers)

    # First 10 rows
    first_n = min(10, max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(f"Row {r}: {row_vals}")

    # Last 5 rows (avoid duplicates if small sheet)
    start_last = max(1, max_row - 4)
    if start_last <= first_n:
        start_last = first_n + 1
    if start_last <= max_row:
        print("Last rows:")
        for r in range(start_last, max_row + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
            print(f"Row {r}: {row_vals}")

    # Print I-column related cells if they exist
    print("Key cells around I4/I6 and nearby:")
    for coord in ["H3", "I3", "H4", "I4", "H5", "I5", "H6", "I6", "H7", "I7"]:
        print(coord, "=", ws[coord].value)

    # Print row 6 formulas/values across columns A:I at least
    upto = min(max_col, 12)
    print("Row 6 detailed A:{}".format(get_column_letter(upto)))
    for c in range(1, upto + 1):
        coord = f"{get_column_letter(c)}6"
        print(coord, "=", ws[coord].value)

    inspection[ws.title] = {
        "rows": max_row,
        "cols": max_col,
        "headers": headers,
    }
