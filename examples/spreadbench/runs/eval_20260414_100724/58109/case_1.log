wsv = wbv["Sheet1"]
today = wsv["I4"].value
rows = []
for r in range(2, 32):
    d = wsv.cell(r, 1).value
    v = wsv.cell(r, 2).value
    if d is not None and d <= today:
        rows.append((d, v))
cached_value = sum(v for d, v in rows[-4:])
print("Cached value:", cached_value)
print("Last four rows used:", rows[-4:])

NS_MAIN = "http://schemas.openxmlformats.org/spreadsheetml/2006/main"
NS_REL = "http://schemas.openxmlformats.org/officeDocument/2006/relationships"
NS_PKGREL = "http://schemas.openxmlformats.org/package/2006/relationships"

ET.register_namespace("", NS_MAIN)
ET.register_namespace("r", NS_REL)

def normalize_target(target: str) -> str:
    target = target.replace("\\", "/")
    if target.startswith("/"):
        target = target[1:]
    if not target.startswith("xl/"):
        target = "xl/" + target
    return posixpath.normpath(target)

with zipfile.ZipFile(out_path, "r") as zin:
    names = zin.namelist()
    print("First 20 zip entries:", names[:20])

    wb_xml = ET.fromstring(zin.read("xl/workbook.xml"))
    rels_xml = ET.fromstring(zin.read("xl/_rels/workbook.xml.rels"))

    rel_map = {}
    for rel in rels_xml.findall(f"{{{NS_PKGREL}}}Relationship"):
        rid = rel.attrib["Id"]
        target = rel.attrib["Target"]
        rel_map[rid] = target
    print("Workbook rel targets:", rel_map)

    sheet_map = {}
    sheets_node = wb_xml.find(f"{{{NS_MAIN}}}sheets")
    for sheet in sheets_node.findall(f"{{{NS_MAIN}}}sheet"):
        name = sheet.attrib["name"]
        rid = sheet.attrib[f"{{{NS_REL}}}id"]
        raw_target = rel_map[rid]
        norm_target = normalize_target(raw_target)
        sheet_map[name] = norm_target

    print("Normalized sheet map:", sheet_map)

    sheet_xml_path = sheet_map["Sheet1"]
    print("Chosen sheet xml path:", sheet_xml_path)
    print("Path exists in zip:", sheet_xml_path in names)

    sheet_root = ET.fromstring(zin.read(sheet_xml_path))
    sheet_data = sheet_root.find(f"{{{NS_MAIN}}}sheetData")

    target_row = None
    target_cell = None
    for row in sheet_data.findall(f"{{{NS_MAIN}}}row"):
        if row.attrib.get("r") == "6":
            target_row = row
            for c in row.findall(f"{{{NS_MAIN}}}c"):
                if c.attrib.get("r") == "I6":
                    target_cell = c
                    break
            break

    print("Found row 6:", target_row is not None)
    print("Found I6:", target_cell is not None)
    if target_cell is None:
        raise RuntimeError("I6 not found in XML")

    print("I6 XML before patch:", ET.tostring(target_cell, encoding="unicode"))

    # Preserve style/reference attrs, remove string type if present
    attrs = dict(target_cell.attrib)
    attrs.pop("t", None)
    target_cell.attrib.clear()
    target_cell.attrib.update(attrs)

    # Remove current children
    for child in list(target_cell):
        target_cell.remove(child)

    # Write formula and cached value
    f_el = ET.SubElement(target_cell, f"{{{NS_MAIN}}}f")
    f_el.text = formula_text
    v_el = ET.SubElement(target_cell, f"{{{NS_MAIN}}}v")
    v_el.text = str(cached_value)

    print("I6 XML after patch:", ET.tostring(target_cell, encoding="unicode"))

    new_sheet_xml = ET.tostring(sheet_root, encoding="utf-8", xml_declaration=True)

    tmp_path = out_path.with_name(out_path.stem + "_patched.xlsx")
    with zipfile.ZipFile(tmp_path, "w", zipfile.ZIP_DEFLATED) as zout:
        for item in zin.infolist():
            if item.filename == sheet_xml_path:
                zout.writestr(item, new_sheet_xml)
            else:
                zout.writestr(item, zin.read(item.filename))

shutil.move(tmp_path, out_path)
print("Patched workbook written.")

# Verify formula view and cached-value view
