from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

def vals(r, c1=1, c2=5):
    return [ws.cell(r, c).value for c in range(c1, c2+1)]

print("Sheetnames:", wb.sheetnames)
print("Inspecting full relevant range A1:E20 on", ws.title)
for r in range(1, min(20, ws.max_row)+1):
    print(f"Row {r:>2}: {vals(r)}")

# Identify candidate delete pairs based on clarified instruction:
# if column A == 'Line No' and row below in column A is blank, delete both rows
candidates = []
for r in range(1, ws.max_row):
    a = ws.cell(r, 1).value
    below = ws.cell(r+1, 1).value
    if isinstance(a, str) and a.strip() == "Line No" and (below is None or str(below).strip() == ""):
        candidates.append((r, r+1))
        print(f"Candidate pair: rows {r},{r+1} because A{r}='Line No' and A{r+1} is blank")

print("All candidate pairs:", candidates)

# Simulate remaining rows after deleting those pairs
rows_to_delete = sorted({r for pair in candidates for r in pair})
print("Rows to delete:", rows_to_delete)

remaining = []
for r in range(1, ws.max_row+1):
    if r not in rows_to_delete:
        remaining.append((r, vals(r)))
print("Remaining first 15 original rows after simulated deletion:")
for item in remaining[:15]:
