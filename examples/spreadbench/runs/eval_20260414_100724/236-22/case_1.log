import os
from copy import copy
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
print("Original sheet names:", original_sheetnames)

# Determine sheets to process.
# User mentioned starting from 'BR1' onwards, but the actual workbook has no BR1.
# So process all existing sheets in this workbook.
if "BR1" in wb.sheetnames:
    start_idx = wb.sheetnames.index("BR1")
    sheet_names_to_process = wb.sheetnames[start_idx:]
else:
    sheet_names_to_process = wb.sheetnames[:]

print("Sheets selected for processing:", sheet_names_to_process)

def is_blank(v):
    return v is None or (isinstance(v, str) and v.strip() == "")

def is_line_no_header(v):
    return isinstance(v, str) and "line no" in v.strip().lower()

processed_info = {}

for sname in sheet_names_to_process:
    ws = wb[sname]
    pairs = []
    for r in range(1, ws.max_row):
        a = ws.cell(r, 1).value
        below = ws.cell(r + 1, 1).value
        if is_line_no_header(a) and is_blank(below):
            pairs.append((r, r + 1, a, below))
    processed_info[sname] = pairs
    
    print(f"\nBefore deletion - sheet {sname}")
    for r in range(1, min(ws.max_row, 20) + 1):
        print(f"Row {r:>2}: {[ws.cell(r, c).value for c in range(1, 6)]}")
    print("Pairs to delete:", [(p[0], p[1]) for p in pairs])
    
    # Delete bottom-up, deleting the lower row first then the header row
    for r1, r2, _, _ in sorted(pairs, key=lambda x: x[0], reverse=True):
        ws.delete_rows(r2, 1)
        ws.delete_rows(r1, 1)

# Save
wb.save(output_path)
print("\nSaved modified workbook to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc/reload:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed; restoring original names.")
    # Rename by position if counts match
    if len(wb_after.sheetnames) == len(original_sheetnames):
        for ws, orig_name in zip(wb_after.worksheets, original_sheetnames):
            ws.title = orig_name
        wb_after.save(output_path)
    else:
        print("Warning: sheet count changed unexpectedly; cannot safely restore names by position.")

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

for sname in wb_verify.sheetnames:
    ws = wb_verify[sname]
    print(f"\nAfter deletion - sheet {sname} | rows={ws.max_row} cols={ws.max_column}")
    for r in range(1, min(ws.max_row, 20) + 1):
        print(f"Row {r:>2}: {[ws.cell(r, c).value for c in range(1, 6)]}")

# Store for submit
final_output_path = output_path
