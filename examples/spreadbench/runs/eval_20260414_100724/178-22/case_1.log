from openpyxl import load_workbook
import os
from shutil import copyfile

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]

# Confirm all matching rows from Sheet1 using instruction criteria:
# column B == 'TELIVISION' OR column C == 'CLASS III' OR column C == 'CLASS IV'
matches = []
for r in range(2, ws1.max_row + 1):
    a = ws1.cell(r, 1).value
    b = ws1.cell(r, 2).value
    c = ws1.cell(r, 3).value
    if b == "TELIVISION" or c == "CLASS III" or c == "CLASS IV":
        matches.append([a, b, c])

print("Original sheet names:", wb.sheetnames)
print("Headers from Sheet1:", [ws1.cell(1, c).value for c in range(1, ws1.max_column + 1)])
print("Matching row count:", len(matches))
print("Matching rows:")
for i, row in enumerate(matches, start=1):
    print(i, row)

# Create or clear Sheet2 as destination, because instruction explicitly targets Sheet2
if "Sheet2" in wb.sheetnames:
    ws2 = wb["Sheet2"]
    # Clear any existing target area contents minimally
    for r in range(1, ws2.max_row + 1):
        for c in range(1, max(ws2.max_column, 3) + 1):
            ws2.cell(r, c).value = None
else:
    ws2 = wb.create_sheet("Sheet2")

# Write headers in A2:C2
headers = [ws1.cell(1, c).value for c in range(1, 4)]
for c_idx, header in enumerate(headers, start=1):
    ws2.cell(2, c_idx).value = header

# Write matching rows starting at A3
out_row = 3
for row in matches:
    for c_idx, val in enumerate(row, start=1):
        ws2.cell(out_row, c_idx).value = val
    out_row += 1

# Save to output path
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
original_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename by position to original names
    for idx, expected_name in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = expected_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheetnames)

# Verify exact target cells/range with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
ws2v = wb_verify["Sheet2"]

# Determine populated target range
last_written_row = 2 + len(matches)
print(f"Verifying Sheet2 A2:C{last_written_row}")
for r in range(1, last_written_row + 1):
