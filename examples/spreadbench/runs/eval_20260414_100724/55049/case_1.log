import os
from collections import defaultdict
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws1 = wb["book1"]
ws2 = wb["book2"]

# Find true last non-empty row in book2
last_row_book2 = 1
for r in range(1, ws2.max_row + 1):
    if any(ws2.cell(r, c).value is not None for c in range(1, ws2.max_column + 1)):
        last_row_book2 = r

print("Original sheet names:", orig_sheet_names)
print("Target write range: book1!B3:B23")
print("book2 true data rows: 2 to", last_row_book2)

# Show current formulas in target range before replacing
print("\nBefore replacement:")
for r in range(3, ws1.max_row + 1):
    v = ws1[f"B{r}"].value
    if hasattr(v, "text"):
        v = v.text
    print(f"B{r}:", v)

# Compute expected sums in Python for verification
expected = defaultdict(float)
for r in range(2, last_row_book2 + 1):
    key = ws2.cell(r, 1).value
    if key in (None, ""):
        continue
    total = 0
    for c in (8, 9, 10):  # H, I, J
        val = ws2.cell(r, c).value
        if val in (None, ""):
            continue
        if isinstance(val, (int, float)):
            total += val
        else:
            try:
                total += float(val)
            except:
                pass
    expected[key] += total

# Replace broken formulas in the exact same cells
for r in range(3, ws1.max_row + 1):
    if ws1[f"A{r}"].value in (None, ""):
        continue
    formula = (
        f"=SUMIF(book2!$A$2:$A${last_row_book2},A{r},book2!$H$2:$H${last_row_book2})"
        f"+SUMIF(book2!$A$2:$A${last_row_book2},A{r},book2!$I$2:$I${last_row_book2})"
        f"+SUMIF(book2!$A$2:$A${last_row_book2},A{r},book2!$J$2:$J${last_row_book2})"
    )
    ws1[f"B{r}"] = formula

print("\nAfter replacement formulas:")
for r in range(3, ws1.max_row + 1):
    print(f"B{r}:", ws1[f"B{r}"].value)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalc changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)
else:
    print("Sheet names preserved.")

# Verify results with cached values
wb_verify_vals = load_workbook(output_path, data_only=True)
wb_verify_formulas = load_workbook(output_path, data_only=False)
print("\nVerification results for book1!B3:B23:")
mismatches = []
for r in range(3, wb_verify_vals["book1"].max_row + 1):
    key = wb_verify_vals["book1"][f"A{r}"].value
    val = wb_verify_vals["book1"][f"B{r}"].value
    formula = wb_verify_formulas["book1"][f"B{r}"].value
    exp = expected.get(key, 0.0)
    print(f"Row {r} | {key} | value={val!r} | expected={exp} | formula={formula}")
    if val is None or (isinstance(val, str) and val.strip() in ("", "#VALUE!", "#REF!", "#N/A", "#NAME?")):
        mismatches.append((r, key, val, exp, "blank_or_error"))
    else:
        try:
            if abs(float(val) - float(exp)) > 1e-9:
                mismatches.append((r, key, val, exp, "numeric_mismatch"))
        except:
            mismatches.append((r, key, val, exp, "non_numeric"))

print("\nMismatch count:", len(mismatches))
if mismatches:
    print("Mismatches:", mismatches[:10])

final_output_spreadsheet = output_path
