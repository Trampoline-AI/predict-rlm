import os, math
from openpyxl import load_workbook

# Reload fresh workbook
wb = load_workbook(input_spreadsheet, data_only=False)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Confirm target and relevant cells before writing
print("Target cell before:", ws["R6"].value)
print("Criteria cells:", {
    "P6": ws["P6"].value,
    "Q6": ws["Q6"].value,
    "R3": ws["R3"].value,
    "R4": ws["R4"].value,
})

# Compute expected result in Python for verification
date_from = ws["P6"].value
date_to = ws["Q6"].value
time_from = ws["R3"].value
time_to = ws["R4"].value

data_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, 1).value is not None]
data_cols = [c for c in range(2, ws.max_column + 1) if ws.cell(1, c).value is not None]

selected_rows = [r for r in data_rows if date_from <= ws.cell(r, 1).value <= date_to]
selected_cols = [c for c in data_cols if time_from <= ws.cell(1, c).value <= time_to]

expected_total = 0.0
for r in selected_rows:
    for c in selected_cols:
        v = ws.cell(r, c).value
        if isinstance(v, (int, float)):
            expected_total += v

print("Selected rows:", selected_rows)
print("Selected cols:", selected_cols)
print("Expected total (Python):", expected_total)

# Write LibreOffice-compatible formula into R6
# Table is B2:M16, dates in A2:A16, times in B1:M1
formula = (
    "=SUMPRODUCT("
    "(ROW(B2:M16)>=ROW(B2)-1+MATCH(P6,A2:A16,0))*"
    "(ROW(B2:M16)<=ROW(B2)-1+MATCH(Q6,A2:A16,0))*"
    "(COLUMN(B2:M16)>=COLUMN(B2)-1+MATCH(R3,B1:M1,0))*"
    "(COLUMN(B2:M16)<=COLUMN(B2)-1+MATCH(R4,B1:M1,0))*"
    "B2:M16)"
)
ws["R6"] = formula

# Match numeric formatting from nearby data cell if possible
ws["R6"].number_format = ws["B6"].number_format

print("Formula written to R6:", ws["R6"].value)

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# After recalc, restore original sheet names if they changed
wb_after = load_workbook(output_path, data_only=False)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for i, name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = name
    wb_after.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify output by reloading both formula and data_only
wb_formula = load_workbook(output_path, data_only=False)
wb_value = load_workbook(output_path, data_only=True)

wsf = wb_formula["Sheet1"]
wsv = wb_value["Sheet1"]

print("Verified formula in R6:", wsf["R6"].value)
print("Verified cached value in R6:", wsv["R6"].value)
print("Expected total:", expected_total)

# If LibreOffice didn't evaluate the formula, fall back to a simpler INDEX-based formula and retry once
bad_value = (
    wsv["R6"].value is None or
    (isinstance(wsv["R6"].value, str) and wsv["R6"].value.startswith("#"))
)

if bad_value:
    print("First formula did not evaluate correctly; trying alternative formula.")
    wb_retry = load_workbook(output_path, data_only=False)
    ws_retry = wb_retry["Sheet1"]
    alt_formula = (
        "=SUM("
        "INDEX(B2:M16,MATCH(P6,A2:A16,0),MATCH(R3,B1:M1,0)):"
        "INDEX(B2:M16,MATCH(Q6,A2:A16,0),MATCH(R4,B1:M1,0))"
        ")"
    )
    ws_retry["R6"] = alt_formula
    ws_retry["R6"].number_format = ws_retry["B6"].number_format
    wb_retry.save(output_path)
    print("Alternative formula written:", alt_formula)

    recalc_result_2 = await recalculate(output_path)
    print("Second recalculate result:", recalc_result_2)

    wb_formula2 = load_workbook(output_path, data_only=False)
    wb_value2 = load_workbook(output_path, data_only=True)
    print("R6 formula after retry:", wb_formula2["Sheet1"]["R6"].value)
    print("R6 cached value after retry:", wb_value2["Sheet1"]["R6"].value)

output_spreadsheet = output_path
print("Final output path prepared:", output_spreadsheet)
