Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from decimal import Decimal, ROUND_HALF_UP
from calendar import monthrange
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target area and inputs
print("Target row label A11:", ws["A11"].value)
print("Year cell O11:", ws["O11"].value)
print("Month headers B8:M8:", [ws.cell(8, c).value for c in range(2, 14)])
print("Night shift counts B9:M9:", [ws.cell(9, c).value for c in range(2, 14)])
print("Current target cells B11:M11:", [ws.cell(11, c).value for c in range(2, 14)])

year = int(ws["O11"].value)
months = list(range(1, 13))
results = []

for idx, c in enumerate(range(2, 14), start=1):
    shifts = ws.cell(9, c).value
    if shifts is None or shifts == "":
        results.append(None)
        continue
    
    days_in_month = monthrange(year, idx)[1]
    value_dec = (Decimal(str(shifts)) / Decimal(str(days_in_month)))
    
    # Determine storage value and number format
    rounded9 = value_dec.quantize(Decimal("0.000000001"), rounding=ROUND_HALF_UP)
    
    if rounded9 == Decimal("0"):
        store_value = 0
        num_format = "0"
    else:
        rounded1 = value_dec.quantize(Decimal("0.0"), rounding=ROUND_HALF_UP)
        # If after rounding to 9 decimals, the value is effectively representable with 1 decimal place
        if rounded9 == rounded1:
            store_value = float(rounded1)
            num_format = "0.0"
        else:
            store_value = float(rounded9)
            num_format = "0.000000000"
    
    cell = ws.cell(11, c)
    cell.value = store_value
    cell.number_format = num_format
    
    results.append((get_column_letter(c), shifts, days_in_month, store_value, num_format))

print("\nComputed results to write:")
for item in results:
    print(item)

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    # Rename by position
    for i, name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Sheet names after final check:", wb_check.sheetnames)

# Verification with data_only for values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
wb_formats = load_workbook(output_path)
ws_formats = wb_formats["Sheet1"]

verified = []
for c in range(2, 14):
    coord = f"{get_column_letter(c)}11"
    verified.append((coord, ws_values[coord].value, ws_formats[coord].number_format))

print("\nVerified B11:M11 (value, format):")
for item in verified:
    print(item)

# Also print as display-intended strings for sanity
def display_string(value, fmt):
    if value is None:
        return None
    if fmt == "0":
        return f"{int(round(value))}"
    elif fmt == "0.0":
        return f"{value:.1f}"
    elif fmt == "0.000000000":
        return f"{value:.9f}"
    return str(value)

display_vals = [(coord, display_string(val, fmt)) for coord, val, fmt in verified]
print("\nDisplay-intended strings:")
for item in display_vals:
    print(item)

final_output_path = output_path
```
