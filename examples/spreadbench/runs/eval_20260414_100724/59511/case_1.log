Code:
```repl
import os, shutil, zipfile
import xml.etree.ElementTree as ET
from openpyxl import load_workbook

infile = input_spreadsheet
final_output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))
formula_base_path = os.path.join("/sandbox/output/output_spreadsheet", "__formula_base.xlsx")
recalc_copy_path = os.path.join("/sandbox/output/output_spreadsheet", "__recalc_copy.xlsx")

# 1) Rebuild formula workbook from the original input
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

target_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, 5).value not in (None, "")]
print("Target rows:", target_rows)

for r in target_rows:
    # Google Sheets compatible, simple arithmetic, no XLOOKUP
    ws[f"F{r}"] = f'=IF(E{r}="","",ROUNDUP(E{r}/1000,0))'

wb.save(formula_base_path)
print("Saved formula base:", formula_base_path)

# 2) Recalculate a copy to get computed values
shutil.copyfile(formula_base_path, recalc_copy_path)
recalc_result = await recalculate(recalc_copy_path)
print("Recalc copy result:", recalc_result)

# 3) Patch formula workbook with cached values from recalculated copy
ns = {"main": "http://schemas.openxmlformats.org/spreadsheetml/2006/main"}
sheet_xml_name = "xl/worksheets/sheet1.xml"  # only one sheet in this workbook

with zipfile.ZipFile(formula_base_path, "r") as zf_formula, zipfile.ZipFile(recalc_copy_path, "r") as zf_recalc:
    formula_xml = zf_formula.read(sheet_xml_name)
    recalc_xml = zf_recalc.read(sheet_xml_name)

formula_root = ET.fromstring(formula_xml)
recalc_root = ET.fromstring(recalc_xml)

# map recalculated cells by reference
recalc_cells = {}
for c in recalc_root.findall(".//main:c", ns):
    ref = c.attrib.get("r")
    if ref:
        recalc_cells[ref] = c

patched_count = 0
for c in formula_root.findall(".//main:c", ns):
    ref = c.attrib.get("r")
    f = c.find("main:f", ns)
    if f is None or ref not in recalc_cells:
        continue

    rc = recalc_cells[ref]
    rv = rc.find("main:v", ns)
    if rv is None:
        continue

    # ensure cached value node exists
    fv = c.find("main:v", ns)
    if fv is None:
        fv = ET.SubElement(c, "{http://schemas.openxmlformats.org/spreadsheetml/2006/main}v")
    fv.text = rv.text

    # copy result type for non-numeric cases if needed
    rtype = rc.attrib.get("t")
    if rtype and rtype != "n":
        c.attrib["t"] = rtype
    elif "t" in c.attrib and c.attrib["t"] != "str":
        # for numeric cached results, remove unnecessary explicit type
        c.attrib.pop("t", None)

    patched_count += 1

patched_xml_bytes = ET.tostring(formula_root, encoding="utf-8", xml_declaration=False)

with zipfile.ZipFile(formula_base_path, "r") as zin, zipfile.ZipFile(final_output_path, "w", compression=zipfile.ZIP_DEFLATED) as zout:
    for item in zin.infolist():
        data = patched_xml_bytes if item.filename == sheet_xml_name else zin.read(item.filename)
        zout.writestr(item, data)

print("Patched final output:", final_output_path)
print("Patched formula cells count:", patched_count)

# 4) Verify sheet names and formulas/values
wb_formula = load_workbook(final_output_path, data_only=False)
wb_values = load_workbook(final_output_path, data_only=True)

print("Sheet names formula view:", wb_formula.sheetnames)
print("Sheet names value view:", wb_values.sheetnames)

wsf = wb_formula[orig_sheetnames[0]]
wsv = wb_values[orig_sheetnames[0]]

print("\nVerification F2:F6:")
for r in target_rows:
    print(
        f"Row {r}: E{r}={wsv[f'E{r}'].value!r}, "
        f"F{r} formula={wsf[f'F{r}'].value!r}, "
        f"F{r} value={wsv[f'F{r}'].value!r}"
    )

print("\nExtra verification A3/B3 still formulas with cached values:")
for coord in ["A3", "B3", "A4", "B4"]:
    print(coord, "formula_view=", wsf[coord].value, "data_only=", wsv[coord].value)

# Keep final path for submission
print("\nReady to submit:", final_output_path)
```
