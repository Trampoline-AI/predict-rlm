import os
from openpyxl import load_workbook

# Paths
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheet names:", original_sheetnames)
print("Using sheet:", ws.title)

# Identify target rows: rows where column E has an input value
target_rows = []
for r in range(2, ws.max_row + 1):
    e_val = ws.cell(r, 5).value  # column E
    if e_val not in (None, ""):
        target_rows.append(r)

print("Target rows based on nonblank E:", target_rows)

# Print existing target area before modification
print("\nBefore writing:")
for r in target_rows:
    print(f"E{r}={ws[f'E{r}'].value!r}, F{r}={ws[f'F{r}'].value!r}")

# Write Google-Sheets-compatible formula into column F
# Logic: blank if E is blank, else at least 1, and increment by 1 per 1000
for r in target_rows:
    formula = f'=IF(E{r}="","",MAX(1,ROUNDUP(E{r}/1000,0)))'
    ws[f"F{r}"] = formula

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation and ensure sheet names preserved
wb_after = load_workbook(outfile)
after_sheetnames = wb_after.sheetnames[:]
print("Sheet names after recalc:", after_sheetnames)

if after_sheetnames != original_sheetnames:
    # Rename sheets back to original names by position
    for i, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    print("Renamed sheets back to original names and re-saved.")

# Reload for verification
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula[original_sheetnames[0]]
wsv = wb_values[original_sheetnames[0]]

print("\nVerification of target cells:")
for r in target_rows:
    print(
        f"Row {r}: "
        f"E{r}={wsv[f'E{r}'].value!r}, "
        f"F{r} formula={wsf[f'F{r}'].value!r}, "
        f"F{r} value={wsv[f'F{r}'].value!r}"
    )

# Store output path for submission
final_output_path = outfile
print("\nFinal output path ready:", final_output_path)
