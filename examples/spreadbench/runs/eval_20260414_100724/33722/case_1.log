from openpyxl import load_workbook

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

# Inspect all rows in A:E to verify exact target area and whether D is fully blank
print("All rows A:E")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Compute expected medians for 1% buckets 0-1,1-2,...4-5 in Python
data = []
for r in range(2, ws.max_row + 1):
    mc = ws.cell(r, 2).value
    pct = ws.cell(r, 3).value
    if mc is not None and pct is not None:
        data.append((r, mc, pct))

bucket_results = []
for i in range(5):
    low = i / 100
    high = (i + 1) / 100
    vals = [mc for _, mc, pct in data if pct >= low and pct < high]
    vals_sorted = sorted(vals)
    n = len(vals_sorted)
    if n == 0:
        median = None
    elif n % 2 == 1:
        median = vals_sorted[n // 2]
    else:
        median = (vals_sorted[n // 2 - 1] + vals_sorted[n // 2]) / 2
    bucket_results.append((i, low, high, vals_sorted, median))

print("\nBucket inspection:")
for i, low, high, vals_sorted, median in bucket_results:
    print(f"Row E{i+2}: bucket {low:.0%}-{high:.0%}, count={len(vals_sorted)}, values={vals_sorted}, median={median}")
