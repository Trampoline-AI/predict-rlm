```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Alignment, Border, Side

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

# Load input
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Determine real data extent from cols B and C
last_row = 1
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 2).value is not None or ws.cell(r, 3).value is not None:
        last_row = r
        break

print("Using sheet:", ws.title)
print("Detected last data row:", last_row)
print("Source ranges:", f"B2:B{last_row}", f"C2:C{last_row}")

# Precompute expected bucket medians in Python for verification/fallback
expected = {}
for out_row in range(2, 7):
    low = (out_row - 2) / 100
    high = (out_row - 1) / 100
    vals = []
    for r in range(2, last_row + 1):
        mc = ws.cell(r, 2).value
        pct = ws.cell(r, 3).value
        if mc is None or pct is None:
            continue
        try:
            mc_num = float(mc)
            pct_num = float(pct)
        except Exception:
            continue
        if pct_num >= low and pct_num < high:
            vals.append(mc_num)
    vals.sort()
    n = len(vals)
    if n == 0:
        med = None
    elif n % 2 == 1:
        med = vals[n // 2]
    else:
        med = (vals[n // 2 - 1] + vals[n // 2]) / 2
    expected[out_row] = med

print("Expected medians by row:", expected)

# Write formulas into E2:E6
# Row-relative bucket:
# E2 => 0%-1%, E3 => 1%-2%, etc.
countifs_expr = f'COUNTIFS($C$2:$C${last_row},">="&((ROW()-2)/100),$C$2:$C${last_row},"<"&((ROW()-1)/100))'
formula = (
    f'=IF({countifs_expr}=0,"",'
    f'AVERAGE('
    f'_xlfn.AGGREGATE(15,6,$B$2:$B${last_row}/(($C$2:$C${last_row}>=((ROW()-2)/100))*($C$2:$C${last_row}<((ROW()-1)/100))),ROUNDUP({countifs_expr}/2,0)),'
    f'_xlfn.AGGREGATE(15,6,$B$2:$B${last_row}/(($C$2:$C${last_row}>=((ROW()-2)/100))*($C$2:$C${last_row}<((ROW()-1)/100))),ROUNDDOWN({countifs_expr}/2+1,0))'
    f'))'
)

for r in range(2, 7):
    ws[f"E{r}"] = formula

# Formatting for column E associated rows
thin = Side(style="thin", color="000000")
border = Border(left=thin, right=thin, top=thin, bottom=thin)
left_align = Alignment(horizontal="left", vertical="center")

for r in range(1, 7):  # include header row
    cell = ws[f"E{r}"]
    cell.border = border
    cell.alignment = left_align
    if r >= 2:
        cell.number_format = "0"   # no decimals, no commas

# Save initial formula version
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved formula version to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# If recalc changed sheet names, restore originals
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    for s, desired in zip(wb_after.worksheets, orig_sheetnames):
        s.title = desired
    wb_after.save(outfile)
else:
    print("Sheet names after recalc:", wb_after.sheetnames)

# Verify raw formulas + cached values
wb_raw = load_workbook(outfile, data_only=False)
wb_val = load_workbook(outfile, data_only=True)
ws_raw = wb_raw[orig_sheetnames[0]]
ws_val = wb_val[orig_sheetnames[0]]

print("\nVerification after formula write:")
formula_ok = True
for r in range(2, 7):
    raw = ws_raw[f"E{r}"].value
    val = ws_val[f"E{r}"].value
    print(f"E{r}: raw={raw!r}, value={val!r}, expected={expected[r]!r}")
    if r == 2:
        # E2 should definitely have a numeric result for this dataset
        if not isinstance(val, (int, float)):
            formula_ok = False

# Fallback to static values if LibreOffice didn't evaluate formula correctly
if not formula_ok:
    print("\nFormula evaluation did not verify correctly; falling back to static values.")
    wb_fb = load_workbook(outfile)
    ws_fb = wb_fb[orig_sheetnames[0]]
    for r in range(2, 7):
        med = expected[r]
        ws_fb[f"E{r}"] = med if med is not None else ""
        ws_fb[f"E{r}"].border = border
        ws_fb[f"E{r}"].alignment = left_align
        ws_fb[f"E{r}"].number_format = "0"
    ws_fb["E1"].border = border
    ws_fb["E1"].alignment = left_align
    wb_fb.save(outfile)

    recalc_result2 = await recalculate(outfile)
    print("Recalculate after fallback:", recalc_result2)

    wb_check = load_workbook(outfile)
    if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
        for s, desired in zip(wb_check.worksheets, orig_sheetnames):
            s.title = desired
        wb_check.save(outfile)

    wb_raw = load_workbook(outfile, data_only=False)
    wb_val = load_workbook(outfile, data_only=True)
    ws_raw = wb_raw[orig_sheetnames[0]]
    ws_val = wb_val[orig_sheetnames[0]]

print("\nFinal target range verification E1:E6:")
for r in range(1, 7):
    raw = ws_raw[f"E{r}"].value
    val = ws_val[f"E{r}"].value
    c = ws_raw[f"E{r}"]
    print(
        f"E{r}: raw={raw!r}, value={val!r}, "
        f"align=({c.alignment.horizontal},{c.alignment.vertical}), "
        f"numfmt={c.number_format!r}, "
        f"borders=({c.border.left.style},{c.border.right.style},{c.border.top.style},{c.border.bottom.style})"
    )

print("\nFinal sheet names:", load_workbook(outfile).sheetnames)
print("Output ready:", outfile)
