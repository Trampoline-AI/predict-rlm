from openpyxl import load_workbook
import os
from shutil import copy2

# Reload workbook fresh
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet2"]

# Inspect current target number formats before writing
for coord in ["D7", "D9", "D10", "D11", "D12"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "numfmt=", cell.number_format)

# Write dynamic formulas based on D7 fiscal month
# Source table: G3:R7 (month headers in first row, values in rows 2:5 of lookup table)
formulas = {
    "D9": '=HLOOKUP($D$7,$G$3:$R$7,2,FALSE)',
    "D10": '=HLOOKUP($D$7,$G$3:$R$7,3,FALSE)',
    "D11": '=HLOOKUP($D$7,$G$3:$R$7,4,FALSE)',
    "D12": '=HLOOKUP($D$7,$G$3:$R$7,5,FALSE)',
}

for coord, formula in formulas.items():
    print("Writing", coord, "->", formula)
    ws[coord] = formula

# Save to output path with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore original sheet name if recalc changed it
wb_after = load_workbook(out_path)
original_sheetnames = ["Sheet2"]
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename sheets positionally back to original
    for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(out_path)
    print("Renamed sheets back to:", wb_after.sheetnames)

# Verify formulas exist
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula["Sheet2"]
print("\nFormulas written:")
for coord in ["D9", "D10", "D11", "D12"]:
    print(coord, ws_formula[coord].value)

# Verify evaluated values
