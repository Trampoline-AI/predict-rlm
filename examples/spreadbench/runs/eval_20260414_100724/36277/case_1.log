```repl
from openpyxl import load_workbook
import os
from shutil import copyfile

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Start from the original file
copyfile(input_path, output_path)

# Load workbook for editing
wb = load_workbook(output_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet2"]

# Confirm target area again before writing
print("Original sheet names:", original_sheetnames)
print("Target area before writing:")
for r in range(1, 6):
    print(f"H{r}: {ws[f'H{r}'].value!r}, I{r}: {ws[f'I{r}'].value!r}")

# Build Excel-2019-compatible drag-down formula
last_row = ws.max_row
formula_template = '=IFERROR(INDEX($A$2:$E$%d,MATCH($I$1,$B$2:$B$%d,0),MATCH(H%d,$A$1:$E$1,0)),"")'

for r in range(2, 6):
    ws[f"I{r}"] = formula_template % (last_row, last_row, r)

print("\nFormulas written to I2:I5:")
for r in range(2, 6):
    print(f"I{r} formula:", ws[f"I{r}"].value)

# Save before recalculation
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # Rename sheets back by position
    for i, original_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheetnames)
else:
    print("Sheet names preserved after recalc.")

# Verify formulas still present in normal load
wb_verify_formula = load_workbook(output_path)
wsf = wb_verify_formula["Sheet2"]
print("\nVerification - formulas in I2:I5:")
for r in range(2, 6):
    print(f"I{r}:", wsf[f"I{r}"].value)

# Verify evaluated values in data_only mode
wb_verify_vals = load_workbook(output_path, data_only=True)
wsv = wb_verify_vals["Sheet2"]

print("\nVerification - evaluated target range H1:I5:")
for r in range(1, 6):
    print(r, [wsv.cell(r, c).value for c in range(8, 10)])

# Additional sanity checks
expected_nonblank = []
for r in range(2, 6):
    val = wsv[f"I{r}"].value
    expected_nonblank.append((f"I{r}", val, val is not None and str(val).strip() != ""))

print("\nNonblank checks:")
for item in expected_nonblank:
    print(item)

output_spreadsheet = output_path
```
