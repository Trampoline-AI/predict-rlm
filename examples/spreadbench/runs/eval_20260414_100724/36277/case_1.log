from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def display(v):
    if v is None:
        return None
    s = str(v)
    return s if len(s) <= 80 else s[:77] + "..."

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # Find first 3 rows raw values to infer header row
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [display(ws.cell(r,c).value) for c in range(1, min(ws.max_column, 12)+1)]
        print(f"Row {r}:", vals)
    
    # Choose header candidate as first non-mostly-empty row among first 5
    header_row = None
    best_nonempty = -1
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r,c).value for c in range(1, ws.max_column+1)]
        nonempty = sum(v not in (None, "") for v in vals)
        if nonempty > best_nonempty:
            best_nonempty = nonempty
            header_row = r
    headers = [display(ws.cell(header_row,c).value) for c in range(1, ws.max_column+1)]
    print(f"Chosen header row: {header_row}")
    print("Headers:", headers)
    
    # Print first 5-10 data rows after header
    start = min(header_row + 1, ws.max_row)
    end = min(ws.max_row, start + 9)
    print(f"Sample data rows {start} to {end}:")
    for r in range(start, end + 1):
        vals = [display(ws.cell(r,c).value) for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", vals)
    
    # Print last 5 rows
    tail_start = max(start, ws.max_row - 4)
    print(f"Last rows {tail_start} to {ws.max_row}:")
    for r in range(tail_start, ws.max_row + 1):
        vals = [display(ws.cell(r,c).value) for c in range(1, ws.max_column+1)]
        print(f"Row {r}:", vals)
    
    # Find formula cells
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, display(cell.value)))
    print(f"Formula cells found: {len(formula_cells)}")
    if formula_cells:
        print("First formulas:", formula_cells[:20])

    # Print column letters with headers
    mapping = [(get_column_letter(c), display(ws.cell(header_row, c).value)) for c in range(1, ws.max_column+1)]
    print("Column mapping:", mapping)
