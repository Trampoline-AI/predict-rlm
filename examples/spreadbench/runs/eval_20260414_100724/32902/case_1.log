import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)
print("\nInput file:", input_spreadsheet)

wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
print("\nSheet names:", original_sheetnames)

def safe(v):
    if v is None:
        return None
    return str(v)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

def nonempty_bounds(ws):
    min_r = min_c = None
    max_r = max_c = 0
    count = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                count += 1
                if min_r is None or cell.row < min_r:
                    min_r = cell.row
                if min_c is None or cell.column < min_c:
                    min_c = cell.column
                if cell.row > max_r:
                    max_r = cell.row
                if cell.column > max_c:
                    max_c = cell.column
    return {"nonempty_count": count, "min_row": min_r, "min_col": min_c, "max_row": max_r, "max_col": max_c}

inspection = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    bounds = nonempty_bounds(ws)
    inspection[sname] = bounds
    
    print(f"\n=== SHEET: {sname} ===")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}, nonempty={bounds['nonempty_count']}, "
          f"used_range=({bounds['min_row']},{bounds['min_col']}) to ({bounds['max_row']},{bounds['max_col']})")
    
    # Print headers / first rows
    sample_cols = min(ws.max_column, 12)
    print("Top rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, sample_cols)
        print(f"Row {r}: {vals}")
    
    print("Bottom rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = row_values(ws, r, sample_cols)
        print(f"Row {r}: {vals}")
    
    # Column summary from first 3 rows
    print("Column letters / first 3-row preview:")
    for c in range(1, min(ws.max_column, 15) + 1):
        letter = get_column_letter(c)
        vals = [ws.cell(r, c).value for r in range(1, min(ws.max_row, 3) + 1)]
        print(f"  {letter}: {vals}")
    
    # Find formulas
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print(f"Formula cells found: {len(formulas)}")
    for coord, formula in formulas[:15]:
        print(f"  {coord}: {formula}")
    
    # Look for relevant headers/keywords
    keywords = ["income", "salary", "earn", "bonus", "tier", "commission", "pay"]
    hits = []
    for r in range(1, min(ws.max_row, 5) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                low = v.strip().lower()
                if any(k in low for k in keywords):
                    hits.append((ws.cell(r, c).coordinate, v))
    print("Keyword hits in first 5 rows:", hits if hits else "None")

print("\nStored inspection summary in variable `inspection`.")
