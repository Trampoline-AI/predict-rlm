```repl
import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheetnames)
print("Before writing, current target area A5:F10:")
for r in range(5, 11):
    print(r, [ws.cell(r, c).value for c in range(1, 7)])

# Use an existing currency-like format already present in the sheet
currency_fmt = ws["F6"].number_format

# Write formulas for all actual quarter rows (6:9)
# Tier 1: every dollar over 60,000 up to 90,000 at 0.15
# Tier 2: every dollar over 90,000 up to 120,000 at 0.25
# Tier 3: every dollar over 120,000 at 0.35
for r in range(6, 10):
    quarter_label = ws[f"A{r}"].value
    income_val = ws[f"B{r}"].value
    if quarter_label is None or str(quarter_label).strip().lower() == "total":
        continue
    if income_val is None or (isinstance(income_val, str) and not income_val.strip()):
        continue

    ws[f"C{r}"] = f'=MAX(0,MIN(B{r},90000)-60000)*0.15'
    ws[f"D{r}"] = f'=MAX(0,MIN(B{r},120000)-90000)*0.25'
    ws[f"E{r}"] = f'=MAX(0,B{r}-120000)*0.35'

    ws[f"C{r}"].number_format = currency_fmt
    ws[f"D{r}"].number_format = currency_fmt
    ws[f"E{r}"].number_format = currency_fmt

# Save
wb.save(output_path)
print("\nSaved workbook to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open after recalculation to ensure sheet names are preserved
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc; renaming back.")
    # Rename sheets by position back to originals
    for i, original_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Renamed back to:", wb_after.sheetnames)

# Verification using cached values
wb_verify = load_workbook(output_path, data_only=False)
ws_verify = wb_verify["Sheet1"]

print("\nFormulas now in C6:E9 and totals in F6:F10:")
for coord in ["C6","D6","E6","F6","C7","D7","E7","F7","C8","D8","E8","F8","C9","D9","E9","F9","B10","C10","D10","E10","F10"]:
    print(coord, ws_verify[coord].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerified cached values A5:F10:")
for r in range(5, 11):
    print(r, [ws_values.cell(r, c).value for c in range(1, 7)])

# Focused verification of target cells
targets = ["C6","D6","E6","F6","C7","D7","E7","F7","C8","D8","E8","F8","C9","D9","E9","F9","C10","D10","E10","F10"]
verified = {coord: ws_values[coord].value for coord in targets}
print("\nTarget cached values:")
for k, v in verified.items():
    print(k, repr(v))

# Sanity checks
assert wb_values.sheetnames == original_sheetnames, f"Sheet names mismatch: {wb_values.sheetnames} vs {original_sheetnames}"
for coord in ["C8","D8","E8","F8","C9","D9","E9","F9"]:
    assert ws_values[coord].value is not None, f"{coord} is blank after recalc"

print("\nDone: formulas written, recalculated, and verified.")
final_output_path = output_path
