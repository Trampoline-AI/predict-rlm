def tier_values(income):
    t1 = max(0, min(income, 90000) - 60000) * 0.15
    t2 = max(0, min(income, 120000) - 90000) * 0.25
    t3 = max(0, income - 120000) * 0.35
    return (round(t1, 10), round(t2, 10), round(t3, 10), round(t1+t2+t3, 10))

print("\nExpected tier values by row based on income:")
for r in range(6, 10):
    income = ws[f"B{r}"].value
    print(f"Row {r}, income={income} -> {tier_values(income)}")
