from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

# Reload source workbook
src_path = input_spreadsheet
orig_wb = load_workbook(src_path)
orig_sheetnames = orig_wb.sheetnames[:]
ws = orig_wb["Sheet1"]

# Identify bounds and relevant columns from headers
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
header_map = {str(v).strip().upper(): i+1 for i, v in enumerate(headers) if v is not None}
print("Headers:", headers)
print("Header map:", header_map)
print("Current D1/D2:", ws["D1"].value, ws["D2"].value)

product_col = header_map["PRODUCT ID"]
qty_col = header_map["QTY"]
target_cell = "D2"

start_row = 2
end_row = ws.max_row

product_col_letter = get_column_letter(product_col)
qty_col_letter = get_column_letter(qty_col)

# Build formula requested: sum QTY where PRODUCT ID = 111111
formula = f'=SUMIF(${product_col_letter}${start_row}:${product_col_letter}${end_row},111111,${qty_col_letter}${start_row}:${qty_col_letter}${end_row})'
ws[target_cell] = formula
print("Written formula to D2:", ws[target_cell].value)

# Save to output directory with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(src_path))
orig_wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check for sheet-name changes after recalc; rename back if needed
post_wb = load_workbook(output_path)
print("Sheet names after recalc:", post_wb.sheetnames)
if post_wb.sheetnames != orig_sheetnames:
    # Rename sheets back in order
    for ws_obj, orig_name in zip(post_wb.worksheets, orig_sheetnames):
        ws_obj.title = orig_name
    post_wb.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify using formula view and data_only view
verify_formula_wb = load_workbook(output_path, data_only=False)
verify_data_wb = load_workbook(output_path, data_only=True)

vf_ws = verify_formula_wb[orig_sheetnames[0]]
vd_ws = verify_data_wb[orig_sheetnames[0]]

print("Final sheet names (formula wb):", verify_formula_wb.sheetnames)
print("D2 formula:", vf_ws["D2"].value)
print("D2 cached value:", vd_ws["D2"].value)
print("Sanity check rows with PRODUCT ID 111111:")
matches = []
for r in range(2, ws.max_row + 1):
    pid = ws.cell(r, product_col).value
    qty = ws.cell(r, qty_col).value
    if pid == 111111:
        matches.append((r, pid, qty))
print(matches)
print("Expected Python sum:", sum(q for _, _, q in matches if isinstance(q, (int, float))))
