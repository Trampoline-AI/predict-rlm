import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input file:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def display(v):
    if v is None:
        return None
    s = str(v)
    return s if len(s) <= 80 else s[:77] + "..."

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Detect non-empty rows/cols more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            nonempty_rows.append(r)
    nonempty_cols = []
    for c in range(1, ws.max_column + 1):
        if any(ws.cell(r, c).value is not None for r in range(1, ws.max_row + 1)):
            nonempty_cols.append(c)
    print(f"Non-empty row span: {nonempty_rows[0] if nonempty_rows else None} to {nonempty_rows[-1] if nonempty_rows else None}")
    print(f"Non-empty columns: {[get_column_letter(c) for c in nonempty_cols]}")
    
    # Print first few rows raw to identify header row
    print("\nTop 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, min(ws.max_column, 12) + 1)]
        print(f"Row {r}: {row_vals}")
    
    # Assume header row is 1 unless clearly blank
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("\nHeader row 1:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}: {display(h)}")
    
    # Print first 5 data rows and last 5 non-empty rows
    if nonempty_rows:
        data_rows = [r for r in nonempty_rows if r != 1]
        first_data = data_rows[:10]
        last_data = data_rows[-5:] if len(data_rows) > 5 else []
        
        print("\nFirst data rows:")
        for r in first_data:
            row_vals = [display(ws.cell(r, c).value) for c in range(1, min(ws.max_column, 12) + 1)]
            print(f"Row {r}: {row_vals}")
        
        if last_data:
            print("\nLast data rows:")
            for r in last_data:
                row_vals = [display(ws.cell(r, c).value) for c in range(1, min(ws.max_column, 12) + 1)]
                print(f"Row {r}: {row_vals}")
    
    # Focus on B and H
    print("\nFocused inspection of columns B and H:")
    for col in [2, 8]:
        if col <= ws.max_column:
            header = ws.cell(1, col).value
            print(f"Column {get_column_letter(col)} header: {display(header)}")
        else:
            print(f"Column {get_column_letter(col)} does not exist on this sheet.")
    
    if ws.max_column >= 8:
        # first 10 non-empty-ish rows for B/H
        inspect_rows = []
        for r in range(2, ws.max_row + 1):
            b = ws.cell(r, 2).value
            h = ws.cell(r, 8).value
            if b is not None or h is not None:
                inspect_rows.append(r)
        print(f"Rows with any data in B or H: {len(inspect_rows)}")
        
        print("First 15 rows with B/H data:")
        for r in inspect_rows[:15]:
            bcell = ws.cell(r, 2)
            hcell = ws.cell(r, 8)
            print(
                f"Row {r}: B={display(bcell.value)} ({type(bcell.value).__name__}), "
                f"H={display(hcell.value)} ({type(hcell.value).__name__})"
            )
        
        print("Last 10 rows with B/H data:")
        for r in inspect_rows[-10:]:
            bcell = ws.cell(r, 2)
            hcell = ws.cell(r, 8)
            print(
                f"Row {r}: B={display(bcell.value)} ({type(bcell.value).__name__}), "
                f"H={display(hcell.value)} ({type(hcell.value).__name__})"
            )
        
        # Check for formulas in B/H
        formula_rows = []
        for r in range(2, ws.max_row + 1):
            bv = ws.cell(r, 2).value
            hv = ws.cell(r, 8).value
            if isinstance(bv, str) and bv.startswith("="):
                formula_rows.append((r, "B", bv))
            if isinstance(hv, str) and hv.startswith("="):
                formula_rows.append((r, "H", hv))
        print("\nAny formulas in B or H:")
        if formula_rows:
            for item in formula_rows[:20]:
                print(item)
        else:
            print("None found in B/H.")
        
        # Check whether H looks like expanded version of B
        compare_rows = []
        for r in inspect_rows[:20]:
            compare_rows.append((r, display(ws.cell(r, 2).value), display(ws.cell(r, 8).value)))
        print("\nComparison sample B -> H:")
        for t in compare_rows:
            print(t)
