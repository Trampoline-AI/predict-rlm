Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before write:")
for r in range(2, ws.max_row + 1):
    print(f"Row {r}: B={ws[f'B{r}'].value!r} | H={ws[f'H{r}'].value!r}")

# Overwrite only actual data rows, leaving the label row (row 2) intact
modified_rows = []
for r in range(3, ws.max_row + 1):
    h_val = ws.cell(r, 8).value  # H
    if h_val not in (None, ""):
        ws.cell(r, 2).value = h_val  # B
        modified_rows.append(r)

wb.save(outfile)
print("\nSaved to:", outfile)
print("Modified rows in column B:", modified_rows)

# Recalculate as required
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names match original; fix if LibreOffice renamed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheetnames:
    # Rename by position to restore original names
    for i, expected in enumerate(original_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification using normal workbook and data_only workbook
wb_formula = load_workbook(outfile)
ws_formula = wb_formula["Sheet1"]

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification of target cells B3:B22 against H3:H22:")
all_ok = True
for r in range(3, ws_formula.max_row + 1):
    b_formula = ws_formula.cell(r, 2).value
    h_formula = ws_formula.cell(r, 8).value
    b_value = ws_values.cell(r, 2).value
    h_value = ws_values.cell(r, 8).value
    row_ok = (str(b_formula).strip() == str(h_formula).strip() and str(b_value).strip() == str(h_value).strip())
    print(
        f"Row {r}: B(formula/raw)={b_formula!r} | H(raw)={h_formula!r} | "
        f"B(data_only)={b_value!r} | H(data_only)={h_value!r} | match={row_ok}"
    )
    if not row_ok:
        all_ok = False

print("\nHeader row check (should remain unchanged):")
print("B2 =", ws_formula["B2"].value)
print("H2 =", ws_formula["H2"].value)

print("\nFinal verification status:", all_ok)

output_spreadsheet = outfile
