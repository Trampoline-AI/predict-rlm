from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

def nonempty_cells_in_row(ws, r):
    vals = row_values(ws, r, ws.max_column)
    return sum(v is not None and str(v) != "" for v in vals)

workbook_summary = {}
for s in wb.sheetnames:
    ws = wb[s]
    # determine actual non-empty rows and cols
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            nonempty_rows.append(r)
    nonempty_cols = []
    for c in range(1, ws.max_column + 1):
        if any(ws.cell(r, c).value not in (None, "") for r in range(1, ws.max_row + 1)):
            nonempty_cols.append(c)
    first_nonempty_row = nonempty_rows[0] if nonempty_rows else None
    last_nonempty_row = nonempty_rows[-1] if nonempty_rows else None
    last_nonempty_col = nonempty_cols[-1] if nonempty_cols else None
    headers = row_values(ws, first_nonempty_row, min(ws.max_column, 15)) if first_nonempty_row else []
    workbook_summary[s] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "first_nonempty_row": first_nonempty_row,
        "last_nonempty_row": last_nonempty_row,
        "last_nonempty_col": last_nonempty_col,
        "headers_preview": headers,
    }

print("Workbook summary:")
for s, info in workbook_summary.items():
    print(s, info)

# Detailed inspection for all sheets, focusing on SH and CP if present
for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n=== Sheet: {s} ===")
    print(f"Dimensions: max_row={ws.max_row}, max_col={ws.max_column}")
    # Print first 10 rows and last 5 rows, limited columns for readability
    max_cols_to_show = min(ws.max_column, 12)
    print("Column letters shown:", [get_column_letter(c) for c in range(1, max_cols_to_show + 1)])
    print("First 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, max_cols_to_show))
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_values(ws, r, max_cols_to_show))

if "SH" in wb.sheetnames:
    ws = wb["SH"]
    blank_rows_sh = []
    partially_filled_rows_sh = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        nonempty = [v for v in vals if v not in (None, "")]
        if len(nonempty) == 0:
            blank_rows_sh.append(r)
        elif len(nonempty) < ws.max_column:
            partially_filled_rows_sh.append((r, len(nonempty)))
    print("\nSH blank row count:", len(blank_rows_sh))
    print("First 50 blank rows in SH:", blank_rows_sh[:50])
    print("Sample partially filled rows in SH (row, nonempty_count):", partially_filled_rows_sh[:20])
    # identify contiguous used-range rows
    nonempty_rows_sh = [r for r in range(1, ws.max_row + 1) if nonempty_cells_in_row(ws, r) > 0]
    print("SH first/last nonempty rows:", (nonempty_rows_sh[0], nonempty_rows_sh[-1]) if nonempty_rows_sh else None)
    # Show rows around first few blank rows
    for br in blank_rows_sh[:10]:
        start = max(1, br - 1)
        end = min(ws.max_row, br + 1)
        print(f"\nRows around blank row {br}:")
        for r in range(start, end + 1):
            print(r, row_values(ws, r, min(ws.max_column, 12)))
else:
    print("Sheet SH not found!")

# store objects/summary for later iterations
exploration_wb = wb
