Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

# Reload fresh from input so modifications start from original file
infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb["SH"]

def row_vals(ws, r, upto=None):
    upto = upto or ws.max_column
    return [ws.cell(r, c).value for c in range(1, upto + 1)]

def is_blank_row(ws, r):
    return all(ws.cell(r, c).value in (None, "") for c in range(1, ws.max_column + 1))

def nonempty_rows(ws):
    return [r for r in range(1, ws.max_row + 1) if not is_blank_row(ws, r)]

# Additional inspection requested by workflow: formulas / merged cells / target region
formula_cells = []
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if isinstance(v, str) and v.startswith("="):
            formula_cells.append(f"{get_column_letter(c)}{r}:{v}")
print("Merged ranges on SH:", list(ws.merged_cells.ranges))
print("Formula cells on SH:", formula_cells if formula_cells else "None")

ne_rows = nonempty_rows(ws)
first_nonempty, last_nonempty = ne_rows[0], ne_rows[-1]
target_blank_rows = [r for r in range(first_nonempty + 1, last_nonempty) if is_blank_row(ws, r)]
print("Target sheet:", ws.title)
print("Target rows to delete:", target_blank_rows)
print("Current values in affected area (rows 1-14, cols A:L):")
for r in range(1, min(14, ws.max_row) + 1):
    print(r, row_vals(ws, r, 12))

# Delete blank rows from bottom to top so indices remain valid
for r in reversed(target_blank_rows):
    ws.delete_rows(r, 1)

print("\nAfter deletion, SH dimensions:", ws.max_row, ws.max_column)
print("Post-delete values in rows 1-10, cols A:L:")
for r in range(1, min(10, ws.max_row) + 1):
    print(r, row_vals(ws, r, 12))

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# After recalc, verify sheet names; if changed, restore originals and save (no second recalc)
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names:
    # rename sheets positionally back to original names
    for idx, orig_name in enumerate(original_sheet_names):
        wb_post.worksheets[idx].title = orig_name
    wb_post.save(outfile)
    print("Restored sheet names to:", original_sheet_names)

# Verification using data_only=True after recalc
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["SH"]

print("\nVerification rows 1-8 in SH (A:L):")
for r in range(1, min(8, wsv.max_row) + 1):
    print(r, row_vals(wsv, r, 12))

verify_nonempty = [r for r in range(1, wsv.max_row + 1) if not is_blank_row(wsv, r)]
verify_first, verify_last = verify_nonempty[0], verify_nonempty[-1]
remaining_internal_blank_rows = [r for r in range(verify_first + 1, verify_last) if is_blank_row(wsv, r)]
print("Remaining internal blank rows:", remaining_internal_blank_rows)
print("Final max_row:", wsv.max_row)

# store output path for submission next turn
final_output_spreadsheet = outfile
