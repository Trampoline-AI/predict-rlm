from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load original workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

def is_blank(v):
    return v is None or (isinstance(v, str) and v == "")

# Identify rows to delete based on ORIGINAL range 14:83 and cols F:L
rows_to_delete = []
rows_to_keep = []
for r in range(14, 84):
    vals_fl = [ws.cell(r, c).value for c in range(6, 13)]  # F:L
    if all(is_blank(v) for v in vals_fl):
        rows_to_delete.append(r)
    else:
        rows_to_keep.append((r, vals_fl))

print("Rows to delete (F:L all blank):", rows_to_delete)
print("Delete count:", len(rows_to_delete))
print("Rows to keep count:", len(rows_to_keep))
print("First kept rows:", rows_to_keep[:10])

# Delete bottom-up so row indices remain valid
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring to", original_sheetnames)
    # rename sheets by position
    for i, expected_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected_name
    wb_after.save(output_path)
    wb_after = load_workbook(output_path)

print("Final sheet names:", wb_after.sheetnames)

# Verification: read values after deletion
wsv = wb_after["Sheet1"]
print("Final max_row:", wsv.max_row, "max_col:", wsv.max_column)

print("\nPost-delete rows 13 onward, cols E:M (first 20 relevant rows):")
for r in range(13, min(wsv.max_row, 32) + 1):
    print(r, [wsv.cell(r, c).value for c in range(5, 14)])

# Verify no remaining blank rows in F:L within the compacted data block beneath row 13
remaining_blank_rows = []
for r in range(14, wsv.max_row + 1):
    vals_em = [wsv.cell(r, c).value for c in range(5, 14)]
    # stop after trailing fully empty area starts
    vals_fl = [wsv.cell(r, c).value for c in range(6, 13)]
    vals_entire = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    if all(is_blank(v) for v in vals_entire):
        continue
    if all(is_blank(v) for v in vals_fl):
        remaining_blank_rows.append((r, vals_em))

print("\nRemaining non-empty-sheet rows whose F:L are still blank:", remaining_blank_rows)

# data_only verification after recalc
wb_data = load_workbook(output_path, data_only=True)
wsd = wb_data["Sheet1"]
print("\nData-only verification, rows 13:32 cols E:M")
for r in range(13, min(wsd.max_row, 32) + 1):
    print(r, [wsd.cell(r, c).value for c in range(5, 14)])

final_output_spreadsheet = output_path
