import os
import re
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheet_names)
print("Target sheet:", ws.title)
print("Headers A:I:", [ws.cell(1, c).value for c in range(1, 10)])

# Keywords from instruction + observed typo-tolerant pattern from examples
keywords = [
    "Core Activation",
    "Core Design",
    "Mobile Terminology",
    "Mobile Design",
    "Mobile Integration",
    "Testing Layer",
    "Testing Offshore",
    "Carrier",
    "Barrier",
]

literal_keywords_lower = [k.lower() for k in keywords]

def matches_billing_po(val):
    """Case-insensitive partial match + observed typo handling for 'Tesing Layer'."""
    if val is None:
        return False, None
    s = str(val).strip()
    if s == "":
        return False, None
    low = s.lower()

    # Exact instructed behavior: case-insensitive partial match
    for kw in literal_keywords_lower:
        if kw in low:
            return True, kw

    # Inferred from existing examples: misspelled 'Tesing  Layer...' should count
    if re.search(r"\btes(?:t)?ing\s+layer\b", low):
        return True, "testing layer (typo-tolerant)"

    return False, None

# Inspect current D/F before writing
pre_rows = []
for r in range(2, ws.max_row + 1):
    d = ws.cell(r, 4).value
    f = ws.cell(r, 6).value
    if d not in (None, ""):
        pre_rows.append((r, d, f))
print("Populated D rows before update:", len(pre_rows))
print("Sample before update (first 15 populated D rows):")
for item in pre_rows[:15]:
    print(item)

# Apply transformation to ALL populated D rows
changed = []
matched_rows = []
blank_rows = []

for r in range(2, ws.max_row + 1):
    d = ws.cell(r, 4).value
    if d in (None, ""):
        continue  # only scan populated D cells

    is_match, why = matches_billing_po(d)
    new_val = "Billing PO" if is_match else None
    old_val = ws.cell(r, 6).value

    if old_val != new_val:
        ws.cell(r, 6).value = new_val
        changed.append((r, d, old_val, new_val, why))

    if is_match:
        matched_rows.append((r, d, why))
    else:
        blank_rows.append((r, d))

print("\nMatched rows count:", len(matched_rows))
print("Matched rows:")
for row in matched_rows:
    print(row)

print("\nChanged rows count:", len(changed))
for row in changed:
    print(row)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheet_names:
    # Rename sheets back by position
    for idx, original_name in enumerate(original_sheet_names):
        wb_after.worksheets[idx].title = original_name
    wb_after.save(output_path)
    print("Renamed sheets back to original names:", original_sheet_names)

# Final verification
verify_wb = load_workbook(output_path, data_only=True)
print("Final verified sheet names:", verify_wb.sheetnames)
vws = verify_wb["Sheet1"]

# Verify target cells/range
verified = []
for r in range(2, vws.max_row + 1):
    d = vws.cell(r, 4).value
    f = vws.cell(r, 6).value
    if d not in (None, ""):
        verified.append((r, d, f))

print("\nVerification sample first 20 populated D rows (row, D, F):")
for row in verified[:20]:
    print(row)

print("\nVerification sample last 20 populated D rows (row, D, F):")
for row in verified[-20:]:
    print(row)

# Explicit checks for important rows
check_rows = [3,4,5,6,7,8,20,27,28,29,30,31,32,48,51,52,53,54,55,56,63]
print("\nExplicit target row checks:")
for r in check_rows:
    print(f"Row {r}: D={vws.cell(r,4).value!r} | F={vws.cell(r,6).value!r}")

# Sanity checks
issues = []
for r in range(2, vws.max_row + 1):
    d = vws.cell(r, 4).value
    if d in (None, ""):
        continue
    expected_match, why = matches_billing_po(d)
    actual = vws.cell(r, 6).value
    if expected_match and actual != "Billing PO":
        issues.append((r, d, "expected Billing PO", actual, why))
    if (not expected_match) and actual not in (None, ""):
        issues.append((r, d, "expected blank", actual, why))

print("\nVerification issues:", issues)
print("Total verification issues:", len(issues))

# Keep path for submission
final_output_spreadsheet = output_path
print("\nfinal_output_spreadsheet =", final_output_spreadsheet)
