import os
from openpyxl import load_workbook

# Re-open to inspect formulas explicitly
wb = load_workbook(input_spreadsheet)
ws = wb["Query"]

print("Pre-write inspection of target column D:")
for r in range(1, ws.max_row + 1):
    print(r, ws[f"D{r}"].coordinate, "value=", repr(ws[f"D{r}"].value), "data_type=", ws[f"D{r}"].data_type)

# Exact target cells: D2:D8 (all data rows under header 'Result')
target_rows = range(2, ws.max_row + 1)
print("Writing formulas to:", [f"D{r}" for r in target_rows])

# Write formula for each data row.
# Logic: first non-#N/A from A, then B, then C; blank if all are #N/A
for r in target_rows:
    formula = f'=IF(A{r}<>"#N/A",A{r},IF(B{r}<>"#N/A",B{r},IF(C{r}<>"#N/A",C{r},"")))'
    ws[f"D{r}"] = formula
    print(f"D{r} formula -> {formula}")

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
