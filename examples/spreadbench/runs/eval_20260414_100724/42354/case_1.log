from openpyxl import load_workbook
import os

# Inspect source cell types to confirm whether #N/A is an Excel error
wb_dbg = load_workbook(input_spreadsheet, data_only=False)
ws_dbg = wb_dbg["Query"]

print("Inspecting A:C cell types and values:")
for r in range(2, ws_dbg.max_row + 1):
    parts = []
    for c in range(1, 4):
        cell = ws_dbg.cell(r, c)
        parts.append(f"{cell.coordinate}: value={cell.value!r}, data_type={cell.data_type}")
    print(" | ".join(parts))

# Rewrite with error-aware formula
wb = load_workbook(input_spreadsheet)
ws = wb["Query"]

for r in range(2, ws.max_row + 1):
    formula = f'=IF(ISNA(A{r}),IF(ISNA(B{r}),IF(ISNA(C{r}),"",C{r}),B{r}),A{r})'
    ws[f"D{r}"] = formula
    print(f"D{r} <- {formula}")

output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and verify
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)

# Ensure sheet name preserved
print("Sheet names after recalc:", wb_formula.sheetnames)
if wb_formula.sheetnames != ["Query"]:
    current_names = wb_formula.sheetnames[:]
    for old, new in zip(current_names, ["Query"]):
        wb_formula[old].title = new
    wb_formula.save(output_path)
    print("Renamed sheets back:", wb_formula.sheetnames)

wsf = wb_formula["Query"]
wsv = wb_values["Query"]

print("\nVerification D2:D8 after fix:")
for r in range(2, wsf.max_row + 1):
    print(
        f"Row {r}:",
        f"A={wsv[f'A{r}'].value!r}",
        f"B={wsv[f'B{r}'].value!r}",
        f"C={wsv[f'C{r}'].value!r}",
        f"D_formula={wsf[f'D{r}'].value!r}",
        f"D_value={wsv[f'D{r}'].value!r}",
    )

output_spreadsheet = output_path
