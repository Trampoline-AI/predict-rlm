```repl
import os
import re
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Using sheet:", ws.title)
print("Headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Reconfirm target/output area
print("\nCurrent target area E:G:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(5, 8)])

# Build candidate source records from A:B
records = []
for r in range(2, ws.max_row + 1):
    rec_id = ws.cell(r, 1).value
    comment = ws.cell(r, 2).value
    if rec_id not in (None, "") and comment not in (None, ""):
        records.append({"row": r, "id": str(rec_id).strip(), "comment": str(comment).strip()})

print("\nSource records:")
for rec in records:
    print(rec)

def compile_param_pattern(param):
    """Boundary-aware pattern tolerant of separators inside the parameter."""
    s = str(param).strip()
    parts = [p for p in re.split(r'[^A-Za-z0-9]+', s.lower()) if p]
    if not parts:
        return None
    core = r'[^A-Za-z0-9]*'.join(re.escape(p) for p in parts)
    return re.compile(r'(^|[^A-Za-z0-9])' + core + r'(?=$|[^A-Za-z0-9])', re.IGNORECASE)

def normalized_contains(comment, param):
    c = re.sub(r'[^A-Za-z0-9]+', '', str(comment).lower())
    p = re.sub(r'[^A-Za-z0-9]+', '', str(param).lower())
    return p != "" and p in c

def matches_param(comment, param):
    pat = compile_param_pattern(param)
    if pat and pat.search(str(comment)):
        return True
    # fallback for odd separator cases
    return normalized_contains(comment, param)

# Fill Found ID in G for rows with both parameters present
updates = []
for r in range(2, ws.max_row + 1):
    p1 = ws.cell(r, 5).value
    p2 = ws.cell(r, 6).value
    current_g = ws.cell(r, 7).value
    
    if p1 not in (None, "") and p2 not in (None, ""):
        matches = []
        for rec in records:
            c = rec["comment"]
            if matches_param(c, p1) and matches_param(c, p2):
                matches.append(rec)
        
        print(f"\nRow {r} search params: {p1!r}, {p2!r}")
        print("Matched records:", matches)
        
        # Only write if G is blank or empty
        if current_g in (None, ""):
            if len(matches) >= 1:
                # choose the first match; dataset appears to imply a unique match
                ws.cell(r, 7).value = matches[0]["id"]
                updates.append((r, matches[0]["id"]))
            else:
                ws.cell(r, 7).value = None
                updates.append((r, None))

print("\nUpdates written to column G:")
for u in updates:
    print(u)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalc changed them
wb_check = load_workbook(output_path)
current_sheetnames = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_sheetnames)

if current_sheetnames != original_sheetnames and len(current_sheetnames) == len(original_sheetnames):
    for old, new in zip(original_sheetnames, current_sheetnames):
        wb_check[new].title = old
    wb_check.save(output_path)
    print("Restored original sheet names:", original_sheetnames)

# Verify output values after recalculation
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("\nVerified target cells G2:G5:")
verified = {}
for r in range(2, min(ws.max_row, 5) + 1):
    verified[f"G{r}"] = wsv.cell(r, 7).value
    print(f"G{r} =", wsv.cell(r, 7).value)

# Also print the full final rows 2:5 columns A:G for sanity
print("\nFinal rows 2:5 A:G")
for r in range(2, min(ws.max_row, 5) + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 8)])
