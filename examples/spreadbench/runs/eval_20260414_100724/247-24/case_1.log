from openpyxl import load_workbook
from copy import copy
from pathlib import Path
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Main"]
lookup_ws = wb["Lookup"]

print("Original sheet names:", orig_sheet_names)
print("Main size before:", ws.max_row, ws.max_column)
print("Lookup size:", lookup_ws.max_row, lookup_ws.max_column)

# Build lookup map for verification/fallback/sanity
lookup_map = {}
for r in range(2, lookup_ws.max_row + 1):
    lookup_map[lookup_ws.cell(r, 1).value] = lookup_ws.cell(r, 2).value

# Inspect exact target columns
headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Headers:", headers)
print("Target columns confirmed:")
print("A =", ws["A1"].value)
print("B =", ws["B1"].value)
print("C =", ws["C1"].value)
print("G =", ws["G1"].value)
print("M =", ws["M1"].value)

# Capture existing styles from a representative data row
style_template = {}
template_row = 2
for c in range(1, ws.max_column + 1):
    cell = ws.cell(template_row, c)
    style_template[c] = {
        "font": copy(cell.font),
        "fill": copy(cell.fill),
        "border": copy(cell.border),
        "alignment": copy(cell.alignment),
        "number_format": cell.number_format,
        "protection": copy(cell.protection),
    }

template_height = ws.row_dimensions[template_row].height

# Read original data rows
source_rows = []
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v not in (None, "") for v in vals):
        source_rows.append(vals)

print("Original non-header data rows:", len(source_rows))

# Transform rows
output_rows = []   # row content only, excluding header
deleted_motorcycle = 0
deleted_ahmed_canada = 0
modified_national_india = 0
inserted_blank_rows = 0

# Track positions for verification
kept_row_positions = []         # list of dicts with output row metadata
inserted_blank_positions = []   # output row numbers that should be blank
national_india_output_rows = []

for vals in source_rows:
    company = vals[0]
    location = vals[1]

    # Rule 1: delete Company == Motorcycle
    if company == "Motorcycle":
        deleted_motorcycle += 1
        continue

    # Rule 2: delete Ahmed Sons + Canada
    if company == "Ahmed Sons" and location == "Canada":
        deleted_ahmed_canada += 1
        continue

    new_vals = list(vals)

    # Rule 3: change G to 180 for National TV + India
    if company == "National TV" and location == "India":
        new_vals[6] = 180
        modified_national_india += 1

    output_rows.append(new_vals)
    current_output_excel_row = len(output_rows) + 1  # +1 because header is row 1
    kept_row_positions.append({
        "row": current_output_excel_row,
        "company": company,
        "location": location,
        "emp_id": new_vals[2],
    })
    if company == "National TV" and location == "India":
        national_india_output_rows.append(current_output_excel_row)

    # Rule 4: insert two new blank rows after each remaining Ahmed Sons row
    if company == "Ahmed Sons":
        output_rows.append([None] * ws.max_column)
        inserted_blank_positions.append(len(output_rows) + 1)
        output_rows.append([None] * ws.max_column)
        inserted_blank_positions.append(len(output_rows) + 1)
        inserted_blank_rows += 2

print("Deleted Motorcycle rows:", deleted_motorcycle)
print("Deleted Ahmed Sons/Canada rows:", deleted_ahmed_canada)
print("Modified National TV/India rows:", modified_national_india)
print("Inserted blank rows:", inserted_blank_rows)
print("Final data row count (excluding header):", len(output_rows))
print("Final worksheet row count (including header):", len(output_rows) + 1)

# Verify expected counts before writing
remaining_ahmed_rows = sum(1 for d in kept_row_positions if d["company"] == "Ahmed Sons")
print("Remaining Ahmed Sons rows:", remaining_ahmed_rows)
print("Expected inserted rows (2 each):", remaining_ahmed_rows * 2)

# Rewrite the Main sheet in-place
# First clear a sufficiently large area across all used columns and new row extent
clear_to_row = max(ws.max_row, len(output_rows) + 5)
for r in range(2, clear_to_row + 1):
    for c in range(1, ws.max_column + 1):
        ws.cell(r, c).value = None

# Write transformed rows
lookup_last_row = lookup_ws.max_row
for idx, vals in enumerate(output_rows, start=2):
    is_blank_row = all(v in (None, "") for v in vals)

    # Set row height template
    if template_height is not None:
        ws.row_dimensions[idx].height = template_height

    for c in range(1, ws.max_column + 1):
        cell = ws.cell(idx, c)
        # Apply style template for consistency
        cell.font = copy(style_template[c]["font"])
        cell.fill = copy(style_template[c]["fill"])
        cell.border = copy(style_template[c]["border"])
        cell.alignment = copy(style_template[c]["alignment"])
        cell.number_format = style_template[c]["number_format"]
        cell.protection = copy(style_template[c]["protection"])

        # Fill base values first
        cell.value = vals[c - 1]

    # Regenerate formulas only for actual data rows
    if not is_blank_row:
        ws.cell(idx, 9).value  = f"=G{idx}*H{idx}"             # I
        ws.cell(idx,10).value  = f"=G{idx}-30"                # J
        ws.cell(idx,11).value  = f"=J{idx}*H{idx}"            # K
        ws.cell(idx,12).value  = f"=I{idx}-K{idx}"            # L
        ws.cell(idx,13).value  = f'=IF(C{idx}="","",VLOOKUP(C{idx},Lookup!$A$2:$B${lookup_last_row},2,FALSE))'  # M
    else:
        # Ensure inserted rows are truly blank, including formula columns
        for c in range(1, ws.max_column + 1):
            ws.cell(idx, c).value = None

# Extra cleanup for any rows beyond final data
