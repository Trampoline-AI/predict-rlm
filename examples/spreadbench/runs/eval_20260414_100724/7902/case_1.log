from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Workbook:", input_path)
print("Sheets:", original_sheet_names)

def nonempty_row_count(ws):
    count = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            count += 1
    return count

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

def sample_rows(ws, first_n=8, last_n=5):
    rows = []
    for r in range(1, min(ws.max_row, first_n) + 1):
        rows.append((r, row_values(ws, r)))
    start_last = max(first_n + 1, ws.max_row - last_n + 1)
    if start_last <= ws.max_row:
        for r in range(start_last, ws.max_row + 1):
            rows.append((r, row_values(ws, r)))
    return rows

all_formulas = []

for sname in wb.sheetnames:
    ws = wb[sname]
    print("\n--- SHEET:", sname, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column, "nonempty_rows:", nonempty_row_count(ws))
    headers1 = row_values(ws, 1)
    headers2 = row_values(ws, 2) if ws.max_row >= 2 else []
    print("Row 1:", headers1)
    print("Row 2:", headers2)
    print("Sample rows:")
    for r, vals in sample_rows(ws, first_n=8, last_n=5):
        print(f"  Row {r}: {vals}")
    # collect formulas
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                all_formulas.append((sname, r, c, v))

print("\nTotal formulas found:", len(all_formulas))
for item in all_formulas[:50]:
    sname, r, c, v = item
    print(f"{sname}!{get_column_letter(c)}{r} = {v}")

# Specific inspection relevant to instruction
if "Grouping" in wb.sheetnames:
    ws_g = wb["Grouping"]
    print("\nGrouping sheet rows 1-10:")
    for r in range(1, min(10, ws_g.max_row) + 1):
        print(f"Grouping row {r}: {row_values(ws_g, r)}")

# inspect row 3 across all sheets, especially C3 and nearby cells
