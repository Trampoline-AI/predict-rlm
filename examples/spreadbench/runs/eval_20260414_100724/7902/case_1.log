def expected_rate(formula_row):
    material = ws.cell(formula_row, 2).value
    main_group = ws.cell(formula_row, 3).value
    amounts = [ws.cell(formula_row, c).value for c in range(12, 19)]  # L:R

    # last non-zero amount bucket index (0-based)
    idx = None
    for i, amt in enumerate(amounts):
        if amt not in (None, "", 0):
