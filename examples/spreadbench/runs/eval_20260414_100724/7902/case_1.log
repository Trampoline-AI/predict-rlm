                break

    if material_match and material_match["main_group"] == main_group:
        source = f"material row {material_match['row']}"
        value = material_match["rates"][idx]
    else:
        generic_match = None
        for row in group_rows:
            if row["main_group"] == main_group:
                generic_match = row
                break
        source = f"group row {generic_match['row']}" if generic_match else "none"
        value = generic_match["rates"][idx] if generic_match else None

    return {"bucket_index": idx, "amounts": amounts, "source": source, "value": value}

