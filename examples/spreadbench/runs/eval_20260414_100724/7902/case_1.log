from openpyxl import load_workbook
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Formula Required"]

def build_formula(r):
    # Condition: if material-specific lookup exists and its main group matches C[r], use material row; else fallback to group row
    cond = f'IFERROR(VLOOKUP(B{r},Grouping!$B$2:$I$7,1,FALSE),"")=C{r}'
    # Bucket branches from rightmost bucket to leftmost bucket
    # For material lookup range B:I, bucket cols are 2..8
    # For group lookup range A:I, bucket cols are 3..9
    formula = (
        f'=IF(C{r}="","",'
        f'IF(R{r}<>0,IF({cond},VLOOKUP(B{r},Grouping!$B$2:$I$7,8,FALSE),VLOOKUP(C{r},Grouping!$A$2:$I$7,9,FALSE)),'
        f'IF(Q{r}<>0,IF({cond},VLOOKUP(B{r},Grouping!$B$2:$I$7,7,FALSE),VLOOKUP(C{r},Grouping!$A$2:$I$7,8,FALSE)),'
        f'IF(P{r}<>0,IF({cond},VLOOKUP(B{r},Grouping!$B$2:$I$7,6,FALSE),VLOOKUP(C{r},Grouping!$A$2:$I$7,7,FALSE)),'
        f'IF(O{r}<>0,IF({cond},VLOOKUP(B{r},Grouping!$B$2:$I$7,5,FALSE),VLOOKUP(C{r},Grouping!$A$2:$I$7,6,FALSE)),'
        f'IF(N{r}<>0,IF({cond},VLOOKUP(B{r},Grouping!$B$2:$I$7,4,FALSE),VLOOKUP(C{r},Grouping!$A$2:$I$7,5,FALSE)),'
        f'IF(M{r}<>0,IF({cond},VLOOKUP(B{r},Grouping!$B$2:$I$7,3,FALSE),VLOOKUP(C{r},Grouping!$A$2:$I$7,4,FALSE)),'
        f'IF(L{r}<>0,IF({cond},VLOOKUP(B{r},Grouping!$B$2:$I$7,2,FALSE),VLOOKUP(C{r},Grouping!$A$2:$I$7,3,FALSE)),"")))))))'
    )
    return formula

target_rows = []
for r in range(3, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in [2, 3]) or any(ws.cell(r, c).value not in (None, "") for c in range(12, 19)):
        target_rows.append(r)

print("Target rows:", target_rows)
print("Existing T values before write:")
for r in target_rows:
    print(f"T{r}:", ws[f"T{r}"].value)

for r in target_rows:
    ws[f"T{r}"] = build_formula(r)

print("\nFormulas written to T cells:")
for r in target_rows:
    print(f"T{r} formula:", ws[f'T{r}'].value)

wb.save(output_path)
print("\nSaved to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_post.sheetnames, "-> restoring", original_sheet_names)
    for i, expected in enumerate(original_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = expected
    wb_post.save(output_path)

# Verification with formulas
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula["Formula Required"]
print("\nVerification - formulas in T:")
for r in target_rows:
    print(f"T{r} formula:", wsf[f"T{r}"].value)

# Verification with calculated values
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values["Formula Required"]
print("\nVerification - calculated T values:")
verified_values = {}
for r in target_rows:
    verified_values[r] = wsv[f"T{r}"].value
    print(f"T{r} value:", repr(verified_values[r]))

output_spreadsheet = output_path
print("\nOutput path variable set:", output_spreadsheet)
