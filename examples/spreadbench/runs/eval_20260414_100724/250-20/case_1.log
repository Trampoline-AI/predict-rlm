def nonempty_row_values(ws, row_idx, max_cols=None):
    mc = max_cols or ws.max_column
    vals = [ws.cell(row=row_idx, column=c).value for c in range(1, mc+1)]
    return vals

def row_is_nonempty(vals):
    return any(v not in (None, "") for v in vals)

for sname in wb.sheetnames:
