import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload ORIGINAL workbook to redo the operation correctly
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

def find_chassis_rows(sheet):
    rows = []
    for r in range(1, sheet.max_row + 1):
        v = sheet.cell(r, 1).value
        if isinstance(v, str) and v.strip() == "Chassis":
            rows.append(r)
    return rows

print("Original sheet names:", wb.sheetnames)
print("Working sheet:", ws.title)
print("Original A1:A15:")
for r in range(1, min(ws.max_row, 15) + 1):
    print(r, repr(ws.cell(r, 1).value))

orig_chassis = find_chassis_rows(ws)
print("Original Chassis rows:", orig_chassis)

if len(orig_chassis) != 2:
    raise ValueError(f"Expected exactly 2 'Chassis' rows, found {len(orig_chassis)}")

# Step 1: move first Chassis to A2 by deleting rows 2 through row_before_first_chassis
first_row = orig_chassis[0]
delete_count_before_first = first_row - 2  # keep row 1
if delete_count_before_first > 0:
    ws.delete_rows(2, delete_count_before_first)

mid_chassis = find_chassis_rows(ws)
print("After step 1, Chassis rows:", mid_chassis)
print("After step 1, A1:A12:")
for r in range(1, min(ws.max_row, 12) + 1):
    print(r, repr(ws.cell(r, 1).value))

# Step 2: move second Chassis to A3 by deleting all rows between the two Chassis rows
mid_chassis = find_chassis_rows(ws)
if len(mid_chassis) != 2:
    raise ValueError(f"After step 1, expected 2 'Chassis' rows, found {len(mid_chassis)}")

first_now, second_now = mid_chassis
rows_between = second_now - first_now - 1
if first_now != 2:
    raise ValueError(f"Expected first 'Chassis' to be at row 2 after step 1, got row {first_now}")

if rows_between > 0:
    ws.delete_rows(first_now + 1, rows_between)

final_chassis = find_chassis_rows(ws)
print("After step 2, Chassis rows:", final_chassis)

# Save
wb.save(output_path)
print("Saved corrected workbook to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check/restore sheet names if recalc altered them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names:
    for i, nm in enumerate(original_sheet_names):
        wb_post.worksheets[i].title = nm
    wb_post.save(output_path)
    print("Restored sheet names:", original_sheet_names)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

print("Verified A1:A10:")
for r in range(1, min(wsv.max_row, 10) + 1):
    print(r, repr(wsv.cell(r, 1).value))

print("Target cells verification:")
print("A2 =", repr(wsv["A2"].value))
print("A3 =", repr(wsv["A3"].value))
print("A4 =", repr(wsv["A4"].value))

final_output_path = output_path
