import os
from decimal import Decimal, InvalidOperation
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

def norm_num(v):
    if v is None or v == "":
        return None
    if isinstance(v, bool):
        return v
    try:
        # Normalize numeric-like values to 2 decimals where applicable
        d = Decimal(str(v))
        return d.quantize(Decimal("0.01"))
    except (InvalidOperation, ValueError):
        return str(v).strip()

def make_key(ref, amt):
    nref = norm_num(ref)
    namt = norm_num(amt)
    if nref in (None, "") or namt in (None, ""):
        return None
    return (nref, namt)

# Load fresh workbook for modification
wb2 = load_workbook(infile)
original_sheetnames = wb2.sheetnames[:]
pl = wb2["PL Recon Items"]
st = wb2["Statement Recon Items"]

# Build row->key mappings from the exact instructed columns
pl_rows = {}
for r in range(2, pl.max_row + 1):
    key = make_key(pl.cell(r, 3).value, pl.cell(r, 4).value)   # C,D
    if key is not None:
        pl_rows[r] = key

st_rows = {}
for r in range(2, st.max_row + 1):
    key = make_key(st.cell(r, 6).value, st.cell(r, 9).value)   # F,I
    if key is not None:
        st_rows[r] = key

pl_keys = set(pl_rows.values())
st_keys = set(st_rows.values())
common_keys = pl_keys & st_keys

print("PL row->key:", pl_rows)
print("Statement row->key:", st_rows)
print("Common keys to delete:", common_keys)

pl_delete = [r for r, k in pl_rows.items() if k in common_keys]
st_delete = [r for r, k in st_rows.items() if k in common_keys]

print("PL rows marked for deletion:", pl_delete)
print("Statement rows marked for deletion:", st_delete)

# Delete bottom-up to avoid row shifting
for r in sorted(pl_delete, reverse=True):
    pl.delete_rows(r, 1)
for r in sorted(st_delete, reverse=True):
    st.delete_rows(r, 1)

wb2.save(outfile)
print("Saved:", outfile)

