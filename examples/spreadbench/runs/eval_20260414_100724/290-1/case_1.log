from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, start=1, end=None):
    end = end or ws.max_column
    return [ws.cell(r, c).value for c in range(start, end+1)]

def nonempty_row_count(ws):
    cnt = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            cnt += 1
    return cnt

def last_nonempty_row(ws):
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            return r
    return 0

def headers_guess(ws, top_n=5):
    guesses = {}
    for r in range(1, min(top_n, ws.max_row)+1):
        vals = row_values(ws, r, 1, min(ws.max_column, 30))
        guesses[r] = vals
    return guesses

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}, nonempty_rows={nonempty_row_count(ws)}, last_nonempty_row={last_nonempty_row(ws)}")
    
    # Print first 5 rows up to first 24 columns (A:X) or available
    end_col = min(ws.max_column, 24)
    print("Top rows (A:{}):".format(get_column_letter(end_col)))
    for r in range(1, min(ws.max_row, 10)+1):
        print(f"Row {r}: {row_values(ws, r, 1, end_col)}")
    
    # Print last 5 non-empty-ish rows
    lnr = last_nonempty_row(ws)
    if lnr:
        start_last = max(1, lnr - 4)
        print(f"Bottom rows around last_nonempty_row={lnr} (A:{get_column_letter(end_col)}):")
        for r in range(start_last, lnr + 1):
            print(f"Row {r}: {row_values(ws, r, 1, end_col)}")
    
    # Print column letters and row 1 values
    print("Column headers / row1 preview:")
    for c in range(1, min(ws.max_column, 24)+1):
        print(f"{get_column_letter(c)}1={ws.cell(1,c).value!r}", end=" | ")
    print()
    
    # Focus on K:V because instruction mentions these columns
    if ws.max_column >= 22:
