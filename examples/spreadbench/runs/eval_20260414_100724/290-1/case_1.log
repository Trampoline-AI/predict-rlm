from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, math, shutil

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Identify source rows (data rows under header, based on non-empty col A)
source_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, 1).value not in (None, "")]
print("Source rows:", source_rows)

# Output structure in K:V = 4 blocks of (I, H, blank)
target_start_row = 2
block_starts = [11, 14, 17, 20]  # K, N, Q, T

# Build expected mapping and print current values before writing
num_groups = math.ceil(len(source_rows) / 4)
target_rows = list(range(target_start_row, target_start_row + num_groups))
print("Target rows:", target_rows)

for g, out_r in enumerate(target_rows):
    src_group = source_rows[g*4:(g+1)*4]
    print(f"Before row {out_r}, source group {src_group}:",
          [ws.cell(out_r, c).value for c in range(11, 23)])

# Fill only target range for all groups; preserve formatting by writing values only
for g, out_r in enumerate(target_rows):
    src_group = source_rows[g*4:(g+1)*4]
    # start with all blanks across K:V
    values = [None] * 12
    for j in range(4):
        if j < len(src_group):
            src_r = src_group[j]
            base = j * 3
            values[base] = ws.cell(src_r, 9).value   # I -> number
            values[base + 1] = ws.cell(src_r, 8).value  # H -> string
            values[base + 2] = None  # separator blank
    # Write K:V
    for offset, val in enumerate(values):
        ws.cell(out_r, 11 + offset).value = val

# Print after writing in-memory
for out_r in target_rows:
    print(f"After row {out_r}:", [ws.cell(out_r, c).value for c in range(11, 23)])

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalculation changed them
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # rename by position
    for i, orig_name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = orig_name
    wb2.save(outfile)
else:
    print("Sheet names preserved:", wb2.sheetnames)

# Verify with data_only reload
verify_wb = load_workbook(outfile, data_only=True)
verify_ws = verify_wb[orig_sheetnames[0]]

print("\nVerified target range K:V rows 2:7")
for r in range(2, 8):
    vals = [verify_ws.cell(r, c).value for c in range(11, 23)]
    print(f"Row {r} K:V -> {vals}")

# Extra explicit verification of exact filled cells
print("\nExplicit key cells:")
for coord in ["K4","L4","N4","O4","Q4","R4","T4","U4",
              "K5","L5","N5","O5","Q5","R5","T5","U5",
              "K6","L6","N6","O6","Q6","R6","T6","U6",
              "K7","L7","N7","O7","Q7","R7","T7","U7"]:
    print(coord, "=", verify_ws[coord].value)
