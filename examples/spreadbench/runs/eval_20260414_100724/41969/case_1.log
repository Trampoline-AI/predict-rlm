```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and inspect original sheet names for post-recalc validation
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheet names:", original_sheetnames)
print("Before write, A6:C6:", [ws.cell(6, c).value for c in range(1, 4)])

# Apply formulas to A6:C6 with 3-column shifting pattern from row 3
for idx, start_col in enumerate([1, 4, 7], start=1):  # A, D, G -> write to A6, B6, C6
    end_col = start_col + 2
    formula = f"=COUNTBLANK({get_column_letter(start_col)}3:{get_column_letter(end_col)}3)"
    ws.cell(6, idx).value = formula
    print(f"Writing {ws.cell(6, idx).coordinate} -> {formula}")

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_post = load_workbook(outfile)
print("Sheet names after recalc reload:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames:
    # rename by position back to originals
    for i, expected_name in enumerate(original_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = expected_name
    wb_post.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification with formulas
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula[original_sheetnames[0]]
print("Verified formulas in A6:C6:", [wsf.cell(6, c).value for c in range(1, 4)])

# Verification with calculated values
wb_verify_values = load_workbook(outfile, data_only=True)
wsv = wb_verify_values[original_sheetnames[0]]
values = [wsv.cell(6, c).value for c in range(1, 4)]
print("Calculated values in A6:C6:", values)

# Also print referenced ranges to sanity-check plausibility
for label, cols in zip(["A6", "B6", "C6"], [(1,3), (4,6), (7,9)]):
    row_vals = [wsv.cell(3, c).value for c in range(cols[0], cols[1]+1)]
    print(label, "references row3 values:", row_vals, "blank_count:", sum(v is None for v in row_vals))

# Final existence checks
print("Output exists:", os.path.exists(outfile))
print("Final sheet names:", load_workbook(outfile).sheetnames)

output_file_for_submit = outfile
```
