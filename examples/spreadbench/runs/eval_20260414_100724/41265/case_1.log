Code:
```repl
import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine actual non-empty data ranges
keyword_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value  # A
    b = ws.cell(r, 2).value  # B
    if a not in (None, "") and b not in (None, ""):
        keyword_rows.append(r)

root_rows = []
for r in range(2, ws.max_row + 1):
    d = ws.cell(r, 4).value  # D
    # Only write where there is a root term; stop assuming fixed row count
    if d not in (None, ""):
        root_rows.append(r)

print("Keyword/source rows:", keyword_rows)
print("Root/output rows:", root_rows)

# Print source rows and current target state before writing
print("\nSource data A:B")
for r in keyword_rows:
    print(r, ws.cell(r, 1).value, ws.cell(r, 2).value)

print("\nRoots and current E values")
for r in root_rows:
    print(r, "D=", ws.cell(r, 4).value, "E current=", ws.cell(r, 5).value)

def whole_word_match(root, keyword):
    if root is None or keyword is None:
        return False
    root = str(root).strip()
    keyword = str(keyword).strip()
    if not root or not keyword:
        return False
    pattern = r'(?<!\w)' + re.escape(root) + r'(?!\w)'
    return re.search(pattern, keyword, flags=re.IGNORECASE) is not None

# Compute sums and write to column E
computed = {}
for r in root_rows:
    root = ws.cell(r, 4).value
    total = 0
    matched_rows = []
    for sr in keyword_rows:
        keyword = ws.cell(sr, 1).value
        volume = ws.cell(sr, 2).value
        if whole_word_match(root, keyword):
            try:
                total += float(volume)
            except Exception:
                pass
            matched_rows.append(sr)
    # Write int when whole number
    if abs(total - int(total)) < 1e-9:
        total = int(total)
    ws.cell(r, 5).value = total
    computed[r] = {"root": root, "total": total, "matched_rows": matched_rows}

print("\nComputed results before save:")
for r, info in computed.items():
    print(f"Row {r}: root={info['root']!r}, matched_rows={info['matched_rows']}, total={info['total']}")

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate as required
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # Rename by position back to originals
    for i, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheetnames)

# Verify using data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]

print("\nVerification of target cells E2:E5:")
for r in root_rows:
    print(f"E{r} =", wsv.cell(r, 5).value, "| root =", wsv.cell(r, 4).value)

output_spreadsheet = output_path
```
