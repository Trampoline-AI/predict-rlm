from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Inspecting R:S:U rows 2-20 with value + data_type + formula check")
for r in range(2, ws.max_row + 1):
    r_cell = ws.cell(r, 18)
    s_cell = ws.cell(r, 19)
    u_cell = ws.cell(r, 21)
    print(
        f"Row {r}: "
        f"R={r_cell.value!r} (type={r_cell.data_type}), "
        f"S={s_cell.value!r} (type={s_cell.data_type}), "
        f"U={u_cell.value!r} (type={u_cell.data_type})"
    )

print("\nExisting formulas in column R (if any):")
for r in range(2, ws.max_row + 1):
    val = ws.cell(r, 18).value
    if isinstance(val, str) and val.startswith("="):
        print(f"R{r}: {val}")

# Determine relevant rows: rows where S or U has data
target_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 19).value is not None or ws.cell(r, 21).value is not None:
        target_rows.append(r)
print("\nTarget rows:", target_rows)

# Write formula to Remarks column R for all relevant rows
# Logic:
# - S error -> Upload
# - else if U between -1 and 1 inclusive -> Do not Upload
# - else -> to Check
for r in target_rows:
    formula = f'=IF(ISERROR(S{r}),"Upload",IF(AND(U{r}>=-1,U{r}<=1),"Do not Upload","to Check"))'
    ws.cell(r, 18).value = formula

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc and restore if changed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_names = wb.sheetnames[:]
if wb_after.sheetnames != orig_names:
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)
    print("Restored original sheet names:", orig_names)

# Verify results with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[orig_names[0]]

print("\nVerified target cells R2:R20 (data_only values):")
for r in target_rows:
    print(f"R{r}={wsv.cell(r,18).value!r}, S{r}={wsv.cell(r,19).value!r}, U{r}={wsv.cell(r,21).value!r}")

# Also inspect formulas directly
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
print("\nWritten formulas in R2:R20:")
for r in target_rows:
    print(f"R{r}: {wsf.cell(r,18).value}")
