Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load and inspect exact target cells before editing
wb = load_workbook(infile)
ws = wb["Sheet1"]

print("Sheet names before:", wb.sheetnames)
print("Headers:", ws["A1"].value, "|", ws["B1"].value)
print("Current A2:", ws["A2"].value)
print("Current B2:", ws["B2"].value)

# Write formula to all relevant rows in existing sheet/column B
# Formula parses text like "2 to 5" and counts inclusively: 5 - 2 + 1 = 4
written = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if isinstance(a, str) and a.strip():
        formula = f'=IF(A{r}="","",VALUE(TRIM(MID(A{r},FIND("to",A{r})+2,LEN(A{r}))))-VALUE(TRIM(LEFT(A{r},FIND("to",A{r})-1)))+1)'
        ws.cell(r, 2).value = formula
        written.append((r, a, formula))

print("Rows written:", written)

# Save output
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc reload:", wb_after.sheetnames)
original_names = ["Sheet1"]
if wb_after.sheetnames != original_names:
    for i, expected in enumerate(original_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Renamed sheets back to:", wb_after.sheetnames)

# Verify with data_only=True
wb_val = load_workbook(outfile, data_only=True)
ws_val = wb_val["Sheet1"]
print("Verified A2:", repr(ws_val["A2"].value))
print("Verified B2:", repr(ws_val["B2"].value))

output_spreadsheet = outfile
