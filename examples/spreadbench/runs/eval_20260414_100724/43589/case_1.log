import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def display_val(v):
    if v is None:
        return None
    return v

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # Find non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[:3], nonempty_rows[-3:] if nonempty_rows else []))
    
    # Print headers from first few rows to detect header row
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [display_val(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"row {r}:", vals)
    
    # Choose header candidate as first non-empty row
    header_row = nonempty_rows[0] if nonempty_rows else 1
    headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
    print("header candidate row", header_row, "headers:", headers)
    
    # Print first 10 non-empty rows and last 5 non-empty rows
    first_rows = nonempty_rows[:10]
    last_rows = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
    printed = set()
    print("Sample first non-empty rows:")
    for r in first_rows:
        printed.add(r)
        vals = [display_val(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"row {r}:", vals)
    if last_rows:
        print("Sample last non-empty rows:")
        for r in last_rows:
            if r in printed:
                continue
            vals = [display_val(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
            print(f"row {r}:", vals)
    
    # Search for cells containing 'to' pattern that may be the text ranges
    matches = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and "to" in v.lower():
                matches.append((r, c, v))
    print("Cells containing 'to':", matches[:20], "total:", len(matches))
