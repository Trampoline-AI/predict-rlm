original_sheet_names = wb.sheetnames[:]
print("Workbook:", input_path)
print("Sheet names:", original_sheet_names)
print("="*100)

def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

def nonempty_count(vals):
    return sum(v not in (None, "") for v in vals)

def detect_header_row(ws, top_n=5):
    candidates = []
    for r in range(1, min(top_n, ws.max_row) + 1):
        vals = row_vals(ws, r)
        candidates.append((nonempty_count(vals), r, vals))
    candidates.sort(reverse=True)
    return candidates[0][1] if candidates else 1

for ws in wb.worksheets:
    print(f"\nSHEET: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    header_row = detect_header_row(ws, top_n=5)
    print(f"Detected header row: {header_row}")
    headers = row_vals(ws, header_row)
    print("Headers:", headers)
    
    # Find cells with formulas in first 30 rows
    formula_cells = []
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append(f"{get_column_letter(c)}{r}={v}")
    print("Formula cells in first 30 rows:", formula_cells[:20] if formula_cells else "None")
    
    # Print first 10 rows
    first_n = min(10, ws.max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_vals(ws, r))
    
    # Print last 5 rows if distinct
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(r, row_vals(ws, r))
    print("-"*100)
