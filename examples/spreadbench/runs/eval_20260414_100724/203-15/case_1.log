```repl
import os
from collections import OrderedDict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload fresh workbook from input
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
ws_main = wb["Main"]
ws_out = wb["Output Required"]

print("Original sheetnames:", original_sheetnames)
print("Main max_row/max_col:", ws_main.max_row, ws_main.max_column)
print("Output Required before write max_row/max_col:", ws_out.max_row, ws_out.max_column)

# Inspect exact target cells before writing
print("Pre-write Output Required A1:M5")
for r in range(1, 6):
    print(r, [ws_out.cell(r, c).value for c in range(1, 14)])

# Copy headers A:G from main
main_headers_ag = [ws_main.cell(1, c).value for c in range(1, 8)]
print("Main headers A:G:", main_headers_ag)

# Requested output allowance headers
allowance_headers = [
    "Basic",
    "Housing Allowance",
    "Transport Allowance",
    "Other Allowance",
    "Social Allowance",
]
total_header = "Total"

# Normalize source allowance descriptions to requested output headers
def normalize_allowance(desc):
    if desc is None:
        return None
    d = str(desc).strip().lower()
    mapping = {
        "basic": "Basic",
        "housing allowance": "Housing Allowance",
        "transport allowance": "Transport Allowance",
        "transport allowances": "Transport Allowance",
        "other allowance": "Other Allowance",
        "other allowances": "Other Allowance",
        "social allowance": "Social Allowance",
        "social allowances": "Social Allowance",
    }
    return mapping.get(d)

# Build one row per staff member, preserving input order
staff_rows = OrderedDict()

for r in range(2, ws_main.max_row + 1):
    base_vals = [ws_main.cell(r, c).value for c in range(1, 8)]  # A:G
    if not any(v is not None and v != "" for v in base_vals):
        continue

    staff_key = tuple(base_vals)
    if staff_key not in staff_rows:
        staff_rows[staff_key] = {
            "base": base_vals,
            "Basic": None,
            "Housing Allowance": None,
            "Transport Allowance": None,
            "Other Allowance": None,
            "Social Allowance": None,
        }

    desc = ws_main.cell(r, 8).value   # H Description
    amt = ws_main.cell(r, 9).value    # I Amount
    norm = normalize_allowance(desc)

    if norm:
        existing = staff_rows[staff_key][norm]
        if existing in (None, ""):
            staff_rows[staff_key][norm] = amt
        else:
            # sum duplicate allowance lines if any exist
            try:
                staff_rows[staff_key][norm] = (existing or 0) + (amt or 0)
            except Exception:
                staff_rows[staff_key][norm] = amt

print("Detected staff count:", len(staff_rows))
for i, (k, v) in enumerate(staff_rows.items(), start=1):
    print(f"Staff row {i} base:", v["base"], "allowances:",
          {h: v[h] for h in allowance_headers})

# Clear existing output values in a safe used area A:M, including extra old rows
clear_to_row = max(ws_out.max_row, len(staff_rows) + 5)
for r in range(1, clear_to_row + 1):
    for c in range(1, 14):  # A:M
        ws_out.cell(r, c).value = None

# Write headers
for c, val in enumerate(main_headers_ag, start=1):
    ws_out.cell(1, c).value = val
for idx, val in enumerate(allowance_headers, start=8):  # H:L
    ws_out.cell(1, idx).value = val
ws_out["M1"] = total_header

# Write data rows
out_row = 2
for staff_key, rec in staff_rows.items():
    # A:G
    for c, val in enumerate(rec["base"], start=1):
        ws_out.cell(out_row, c).value = val
    # H:L
    for idx, h in enumerate(allowance_headers, start=8):
        ws_out.cell(out_row, idx).value = rec[h]
    # M total formula
    ws_out.cell(out_row, 13).value = f"=SUM(H{out_row}:L{out_row})"
    out_row += 1

print("Post-write formulas/values in Output Required A1:M5 (before save/recalc)")
for r in range(1, min(out_row + 2, 6)):
    print(r, [ws_out.cell(r, c).value for c in range(1, 14)])

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Check if sheet names changed after recalc; if so, restore
wb_after = load_workbook(out_path)
after_sheetnames = wb_after.sheetnames[:]
print("Sheetnames after recalc:", after_sheetnames)

if after_sheetnames != original_sheetnames:
    print("Sheet names changed after recalc; restoring original names.")
    if len(after_sheetnames) == len(original_sheetnames):
        for ws, orig_name in zip(wb_after.worksheets, original_sheetnames):
            ws.title = orig_name
        wb_after.save(out_path)
        print("Restored sheet names and re-saved.")
    else:
        print("Unexpected sheet count mismatch; leaving as-is for now.")

# Verify by reloading data_only=True
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheetnames:", wb_verify.sheetnames)

wsv = wb_verify["Output Required"]
print("Verified Output Required max_row/max_col:", wsv.max_row, wsv.max_column)

# Print exact target range A1:M plus all populated rows
print("Verified target range Output Required A1:M{}".format(max(3, len(staff_rows) + 1)))
for r in range(1, len(staff_rows) + 2):
    print(r, [wsv.cell(r, c).value for c in range(1, 14)])

# Sanity checks
issues = []
expected_headers = main_headers_ag + allowance_headers + [total_header]
actual_headers = [wsv.cell(1, c).value for c in range(1, 14)]
if actual_headers != expected_headers:
    issues.append(("header_mismatch", actual_headers, expected_headers))

for r in range(2, len(staff_rows) + 2):
    # A:G should be nonblank
    for c in range(1, 8):
        if wsv.cell(r, c).value in (None, ""):
            issues.append((f"blank_base_cell", f"{get_column_letter(c)}{r}", wsv.cell(r, c).value))
    # Total should not be blank
    if wsv.cell(r, 13).value in (None, ""):
        issues.append((f"blank_total", f"M{r}", wsv.cell(r, 13).value))

print("Verification issues:", issues)

final_output_path = out_path
```
