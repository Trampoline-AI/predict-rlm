```repl
import os
from copy import copy
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]

ws_emp = wb["Emp"]
ws_lookup = wb["Lookup"]
ws_exp = wb["Expected"]

# Inspect target cells before writing
print("Target sheet before writing:")
for r in range(1, ws_exp.max_row + 1):
    print(r, [ws_exp.cell(r, c).value for c in range(1, ws_exp.max_column + 1)])

# Build lookup map
lookup_map = {}
for r in range(2, ws_lookup.max_row + 1):
    var = ws_lookup.cell(r, 1).value
    cat = ws_lookup.cell(r, 2).value
    sub = ws_lookup.cell(r, 3).value
    if var not in (None, ""):
        lookup_map[str(var).strip()] = (cat, sub)

# Determine source headers and exact columns
emp_headers = [ws_emp.cell(1, c).value for c in range(1, ws_emp.max_column + 1)]
fixed_headers = emp_headers[:4]
variable_headers = emp_headers[4:]

print("\nEmp headers:", emp_headers)
print("Fixed headers:", fixed_headers)
print("Variable headers:", variable_headers)
print("Lookup keys:", list(lookup_map.keys()))

# Build transformed rows
output_headers = ["seqno", "Empno", "ename", "Jobid", "Variable", "Category", "Subcategory", "Value"]
transformed = []
for r in range(2, ws_emp.max_row + 1):
    fixed_vals = [ws_emp.cell(r, c).value for c in range(1, 5)]
    if all(v in (None, "") for v in fixed_vals):
        continue
    for c in range(5, ws_emp.max_column + 1):
        var = ws_emp.cell(1, c).value
        val = ws_emp.cell(r, c).value
        cat, sub = lookup_map.get(str(var).strip(), (None, None))
        transformed.append(fixed_vals + [var, cat, sub, val])

print("\nTransformed row count:", len(transformed))
print("First 10 transformed rows:")
for i, row in enumerate(transformed[:10], start=2):
    print(i, row)
print("Last 5 transformed rows:")
for i, row in enumerate(transformed[-5:], start=len(transformed)-5+2):
    print(i, row)

# Write headers exactly into Expected
for c, header in enumerate(output_headers, start=1):
    ws_exp.cell(1, c).value = header

# Write transformed rows into Expected rows 2..
for i, row in enumerate(transformed, start=2):
    for c, value in enumerate(row, start=1):
        ws_exp.cell(i, c).value = value

# Clear any leftover rows below the output range if present
for r in range(len(transformed) + 2, ws_exp.max_row + 1):
    for c in range(1, len(output_headers) + 1):
        ws_exp.cell(r, c).value = None

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
current_sheetnames = wb2.sheetnames[:]
print("Sheet names after recalc:", current_sheetnames)

if current_sheetnames != original_sheetnames and len(current_sheetnames) == len(original_sheetnames):
    for ws, orig_name in zip(wb2.worksheets, original_sheetnames):
        ws.title = orig_name
    wb2.save(outfile)
    print("Restored original sheet names:", original_sheetnames)

# Verification reload with data_only
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)

wsv = wbv["Expected"]
verified_rows = []
for r in range(1, 1 + len(transformed) + 1):
    verified_rows.append([wsv.cell(r, c).value for c in range(1, 9)])

print("\nVerified Expected rows:")
for idx, row in enumerate(verified_rows, start=1):
    print(idx, row)

# Sanity checks
assert wbv.sheetnames == original_sheetnames, f"Sheet names mismatch: {wbv.sheetnames} vs {original_sheetnames}"
assert verified_rows[0] == output_headers, f"Header mismatch: {verified_rows[0]}"
for i, src_row in enumerate(transformed, start=2):
    out_row = [wsv.cell(i, c).value for c in range(1, 9)]
    assert out_row == src_row, f"Row {i} mismatch: expected {src_row}, got {out_row}"
    assert out_row[4] is not None, f"Variable blank at row {i}"
    assert out_row[5] is not None, f"Category blank at row {i}"
    assert out_row[6] is not None, f"Subcategory blank at row {i}"
    assert out_row[7] is not None, f"Value blank at row {i}"

print("\nVerification passed. Output path ready for submission:")
print(outfile)

output_path = outfile
```
