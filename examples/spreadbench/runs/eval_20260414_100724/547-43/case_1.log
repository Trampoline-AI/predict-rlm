import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Input:", path)
print("Instruction:", instruction)
print("Sheet names:", wb.sheetnames)

def nonempty_bounds(ws):
    last_row = 0
    last_col = 0
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value not in (None, ""):
                row_has = True
                if cell.column > last_col:
                    last_col = cell.column
        if row_has:
            last_row = row[0].row
    return last_row, last_col

def row_values(ws, r, max_cols):
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

sheet_meta = {}

for ws in wb.worksheets:
    lr, lc = nonempty_bounds(ws)
    sheet_meta[ws.title] = (lr, lc)
    show_cols = min(max(lc, 1), 20)
    print(f"\n=== Sheet: {ws.title} ===")
    print("ws.max_row/max_col:", ws.max_row, ws.max_column)
    print("nonempty last_row/last_col:", lr, lc)
    print("Header row 1:", row_values(ws, 1, show_cols))
    if lr >= 2:
        print("Header row 2:", row_values(ws, 2, show_cols))
    table_names = list(ws.tables.keys()) if hasattr(ws, "tables") else []
    print("Tables:", table_names if table_names else "None")
    for tn in table_names:
        t = ws.tables[tn]
        print("  table", tn, "ref:", t.ref)
    merged = list(ws.merged_cells.ranges)
    print("Merged ranges:", merged[:10] if merged else "None")
    print("First rows:")
    for r in range(1, min(lr, 10) + 1):
        print(r, row_values(ws, r, show_cols))
    if lr > 10:
        print("Last rows:")
        for r in range(max(1, lr - 4), lr + 1):
            print(r, row_values(ws, r, show_cols))

print("\n=== Defined names / named ranges ===")
try:
    # openpyxl versions differ; handle both mapping-like and iterable cases
    dn_obj = wb.defined_names
    if hasattr(dn_obj, "items"):
        items = list(dn_obj.items())
        if items:
            for name, defn in items:
                print("Name:", name, "->", getattr(defn, "attr_text", defn))
        else:
            print("No defined names")
    else:
        printed = False
        for defn in dn_obj:
            printed = True
            print("Name:", getattr(defn, "name", None), "->", getattr(defn, "attr_text", defn))
        if not printed:
            print("No defined names")
except Exception as e:
    print("Could not inspect defined names:", repr(e))

keywords = ["Emp", "emp", "Comp1-performance", "category", "subcategory", "lookup", "variable", "performance"]
hits = []
for ws in wb.worksheets:
    lr, lc = sheet_meta[ws.title]
    for r in range(1, lr + 1):
        for c in range(1, lc + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                low = v.lower()
                if any(k.lower() in low for k in keywords):
                    hits.append((ws.title, f"{get_column_letter(c)}{r}", v))
print("\nKeyword hits (up to 200):")
for h in hits[:200]:
    print(h)

formula_hits = []
for ws in wb.worksheets:
    lr, lc = sheet_meta[ws.title]
    for r in range(1, min(lr, 150) + 1):
        for c in range(1, min(lc, 80) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_hits.append((ws.title, f"{get_column_letter(c)}{r}", v))
print("\nFormula hits (up to 100):")
for h in formula_hits[:100]:
