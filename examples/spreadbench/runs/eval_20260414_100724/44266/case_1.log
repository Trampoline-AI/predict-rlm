import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Load workbook and preserve original sheet names
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
data_ws = wb["Data"]
lookup_ws = wb["Lookup"]

print("Original sheet names:", original_sheet_names)
print("Current target cells/formulas before writing:")
for r in range(2, lookup_ws.max_row + 1):
    print(f"A{r}={lookup_ws[f'A{r}'].value!r}, B{r}={lookup_ws[f'B{r}'].value!r}")

# Write INDEX/MATCH formulas to the exact target range B2:B12
for r in range(2, lookup_ws.max_row + 1):
    year_ref = f"A{r}"
    formula = f'=IFERROR(INDEX(Data!$14:$14, MATCH({year_ref}, Data!$4:$4, 0)+1), "")'
    lookup_ws[f"B{r}"] = formula

print("\nFormulas written:")
for r in range(2, lookup_ws.max_row + 1):
    print(f"B{r} formula -> {lookup_ws[f'B{r}'].value}")

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload to check/restore sheet names if recalculate changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    # Restore names by position
    for ws, expected_name in zip(wb_check.worksheets, original_sheet_names):
        ws.title = expected_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)
else:
    print("Sheet names unchanged.")

# Verify output values after recalculation
