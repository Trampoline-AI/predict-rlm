def nonempty_rows_cols(ws):
    max_r, max_c = ws.max_row, ws.max_column
    # Determine used rows/cols more reliably
    used_rows = set()
    used_cols = set()
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                used_rows.add(cell.row)
                used_cols.add(cell.column)
    return (max(used_rows) if used_rows else 0, max(used_cols) if used_cols else 0, used_rows, used_cols)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for s in wb.sheetnames:
