import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheetnames:", original_sheetnames)
print("Target sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)

# Determine actual last row with data in A:F
last_row = 1
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value is not None for c in range(1, 7)):
        last_row = r
        break
print("Detected last data row:", last_row)

# Verify target cells before writing
print("Before writing, sample target area A:C and F:")
for r in list(range(1, min(10, last_row) + 1)) + list(range(max(1, last_row - 4), last_row + 1)):
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value, ws[f"F{r}"].value)

# Fill color RGB 146-208-80 -> hex 92D050
green_fill = PatternFill(start_color="92D050", end_color="92D050", fill_type="solid")

# Write formulas in column C and apply fills only where A and B are numeric
written_rows = []
delete_candidate_rows = []
for r in range(2, last_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3)
    if a is None and b is None:
        continue

    # Write formula to existing target column C
    c.value = f'=IF(COUNTIF($F$2:$F${last_row},A{r})>0,"Delete","")'
    written_rows.append(r)

    # Highlight C where both A and B are numbers
    if isinstance(a, (int, float)) and isinstance(b, (int, float)):
        c.fill = green_fill

print("Rows written in C:", written_rows[:10], "... total", len(written_rows))

# Save
wb.save(output_path)
print("Saved to:", output_path, "exists:", os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for idx, expected in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = expected
    wb_after.save(output_path)
    print("Renamed sheets back to original:", original_sheetnames)

# Verify formulas evaluated
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

wb_styles = load_workbook(output_path)
ws_styles = wb_styles[original_sheetnames[0]]

print("\nVerification of target cells/range:")
print("Header row:", [ws_values.cell(1, c).value for c in range(1, 7)])

# Compute expected rows based on source logic
src_wb = load_workbook(input_path, data_only=True)
src_ws = src_wb[original_sheetnames[0]]
f_values = {src_ws.cell(r, 6).value for r in range(2, last_row + 1) if src_ws.cell(r, 6).value is not None}
expected_delete_rows = [r for r in range(2, last_row + 1) if src_ws.cell(r, 1).value in f_values]
print("Expected Delete rows:", expected_delete_rows)

actual_delete_rows = []
blank_problem_rows = []
fill_problem_rows = []

for r in range(2, last_row + 1):
    a = ws_values.cell(r, 1).value
    b = ws_values.cell(r, 2).value
    c_val = ws_values.cell(r, 3).value
    f = ws_values.cell(r, 6).value
    fill_rgb = ws_styles.cell(r, 3).fill.start_color.rgb

    if c_val == "Delete":
        actual_delete_rows.append(r)

    should_delete = a in f_values
    if should_delete and c_val != "Delete":
        blank_problem_rows.append((r, a, c_val))

    should_fill = isinstance(a, (int, float)) and isinstance(b, (int, float))
    # openpyxl may store as '0092D050' or 'FF92D050' depending on file
    if should_fill and fill_rgb not in ("0092D050", "FF92D050", "92D050"):
        fill_problem_rows.append((r, fill_rgb))

    print(f"Row {r}: A={a}, B={b}, C={c_val!r}, F={f}, C_fill={fill_rgb}")

print("\nActual Delete rows:", actual_delete_rows)
print("Missing/incorrect Delete rows:", blank_problem_rows)
print("Fill verification problems:", fill_problem_rows[:10], "count=", len(fill_problem_rows))

assert wb_values.sheetnames == original_sheetnames, f"Sheet names mismatch: {wb_values.sheetnames} vs {original_sheetnames}"
assert not blank_problem_rows, f"Some expected Delete cells were not populated: {blank_problem_rows}"
assert not fill_problem_rows, f"Some fill colors were not applied correctly: {fill_problem_rows}"

final_output_path = output_path
print("\nFinal output ready:", final_output_path)
