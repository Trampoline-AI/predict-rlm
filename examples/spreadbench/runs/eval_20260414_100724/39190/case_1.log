path = input_spreadsheet
print("Input path:", path, "exists:", os.path.exists(path))

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    headers = row_values(ws, 1)
    print("Row 1 headers/values:")
    for i, v in enumerate(headers, start=1):
