from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Detailed inspection of source and target area:")
for r in range(3, 16):
    b = ws[f"B{r}"].value
    e = ws[f"E{r}"].value
    print(f"Row {r}: B{r}={b!r} | E{r}={e!r}")

# Build expected filtered list from column B starting under header/data area
source_start_row = 4
source_end_row = ws.max_row
pk_values = []
for r in range(source_start_row, source_end_row + 1):
    val = ws[f"B{r}"].value
    if isinstance(val, str) and val.startswith("PK"):
        pk_values.append(val)

print("\nPK values extracted from column B:")
for i, v in enumerate(pk_values, start=1):
    print(i, v)
print("Count of PK values:", len(pk_values))

# Inspect target column E styles / occupancy
print("\nTarget column E inspection:")
for r in range(2, 16):
    cell = ws[f"E{r}"]
    print(f"E{r}: value={cell.value!r}, style_id={cell.style_id}, number_format={cell.number_format!r}")

# Determine intended target range based on example answers starting at E4
target_start_row = 4
target_end_row = target_start_row + len(pk_values) - 1
print(f"\nInferred target range for results: E{target_start_row}:E{target_end_row}")

# Check existing examples match expected prefix of output
existing_match = True
for idx, r in enumerate(range(target_start_row, min(target_end_row, ws.max_row) + 1), start=0):
    existing = ws[f"E{r}"].value
    expected = pk_values[idx]
    if existing not in (None, "") and existing != expected:
        existing_match = False
        print(f"Mismatch found at E{r}: existing={existing!r}, expected={expected!r}")
print("Existing filled target cells are consistent with inferred pattern:", existing_match)

# If everything looks consistent, perform the write now
if existing_match:
    print("\nWriting filtered PK values into target column E...")
    # Preserve style by writing only values
    for idx, val in enumerate(pk_values):
        r = target_start_row + idx
        before = ws[f"E{r}"].value
        ws[f"E{r}"] = val
        print(f"E{r}: {before!r} -> {val!r}")
    
    # Clear cells below the result range in the nearby target area if they contain stale data
    for r in range(target_end_row + 1, ws.max_row + 1):
        if ws[f"E{r}"].value not in (None, ""):
            print(f"Clearing stale value in E{r}: {ws[f'E{r}'].value!r}")
            ws[f"E{r}"] = None
    
    out_dir = "/sandbox/output/output_spreadsheet"
    os.makedirs(out_dir, exist_ok=True)
    out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
    wb.save(out_path)
    print("Saved to:", out_path)
    
    # Recalculate even though values are static, per instructions
    recalc_result = await recalculate(out_path)
    print("Recalculate:", recalc_result)
    
    # Reload and restore sheet names if recalc changed them
    wb_check = load_workbook(out_path)
    print("Sheet names after recalc:", wb_check.sheetnames)
    if wb_check.sheetnames != ["Sheet1"]:
        # rename first sheet back if necessary
        if len(wb_check.sheetnames) == 1:
            wb_check[wb_check.sheetnames[0]].title = "Sheet1"
            wb_check.save(out_path)
            print("Renamed sheet back to Sheet1")
        else:
            print("Unexpected multiple sheets after recalc; not renaming automatically")
    
    # Verify data_only values
    wb_verify = load_workbook(out_path, data_only=True)
    ws_verify = wb_verify["Sheet1"]
    print("\nVerification of target cells:")
    for r in range(4, 16):
        print(f"E{r}={ws_verify[f'E{r}'].value!r}")
    
    output_spreadsheet = out_path
    print("\nPrepared output file:", output_spreadsheet)
else:
