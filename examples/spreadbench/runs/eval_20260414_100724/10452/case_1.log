import os, json, math, statistics, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
print("Sheet names:", orig_sheetnames)

def visible_value(v):
    try:
        if hasattr(v, "text"):  # array formula object or similar
            return f"<{type(v).__name__}:{v.text}>"
    except Exception:
        pass
    return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find actual non-empty rows/cols a bit more carefully
    nonempty_rows = []
    nonempty_cols = set()
    for r in ws.iter_rows():
        row_has = False
        for c in r:
            if c.value not in (None, ""):
                row_has = True
                nonempty_cols.add(c.column)
        if row_has:
            nonempty_rows.append(r[0].row)
    if nonempty_rows:
        print(f"Non-empty rows: {min(nonempty_rows)} to {max(nonempty_rows)} (count {len(nonempty_rows)})")
    else:
        print("No non-empty rows")
    
    # Print first 10 rows with values
    top_n = min(ws.max_row, 10)
    print(f"Top {top_n} rows:")
    for r in range(1, top_n + 1):
        vals = [visible_value(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Print last 5 rows
    if ws.max_row > 10:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            vals = [visible_value(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
            print(r, vals)
    
    # Infer likely header row among first 5 rows
    best_header_row = None
    best_score = -1
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        score = sum(1 for v in vals if isinstance(v, str) and v.strip())
        if score > best_score:
            best_score = score
            best_header_row = r
    if best_header_row:
        headers = [ws.cell(best_header_row, c).value for c in range(1, ws.max_column + 1)]
        print(f"Likely header row: {best_header_row}")
        print("Headers:", headers)
    
    # Search for PK and formulas
    pk_hits = []
    formula_hits = []
    for row in ws.iter_rows():
        for cell in row:
            val = cell.value
            sval = None
            if isinstance(val, str):
                sval = val
            elif hasattr(val, "text"):
                sval = val.text
            if sval:
                if "PK" in sval:
                    pk_hits.append((cell.coordinate, sval))
                if sval.startswith("="):
                    formula_hits.append((cell.coordinate, sval))
    print("PK hits (up to 20):", pk_hits[:20])
    print("Formula cells (up to 20):", formula_hits[:20])

    # Print columns with many values to understand data extent
    col_nonempty_counts = []
    for c in range(1, ws.max_column + 1):
        count = sum(1 for r in range(1, ws.max_row + 1) if ws.cell(r, c).value not in (None, ""))
        header = ws.cell(best_header_row if best_header_row else 1, c).value
        col_nonempty_counts.append((get_column_letter(c), header, count))
    print("Column non-empty counts:", col_nonempty_counts)

# Search workbook globally for lookup-related text/formulas
lookup_related = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            val = visible_value(cell.value)
            if isinstance(val, str):
                t = val.upper()
                if any(k in t for k in ["LOOKUP", "VLOOKUP", "HLOOKUP", "INDEX", "MATCH", "RESULT", "PK"]):
                    lookup_related.append((ws.title, cell.coordinate, val))
print("\nGlobal lookup-related cells (up to 50):")
for item in lookup_related[:50]:
    print(item)

print("\nDone initial inspection.")
