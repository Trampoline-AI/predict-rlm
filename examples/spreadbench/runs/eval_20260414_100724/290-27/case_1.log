```repl
from openpyxl import load_workbook
from datetime import datetime
import re, os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Find true last non-empty row
last_row = 0
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
        last_row = r
        break

print("Sheet1 last non-empty row:", last_row)
print("Column count:", ws.max_column)

# Print all non-empty values in column B with types
b_nonempty = []
for r in range(1, last_row + 1):
    v = ws.cell(r, 2).value
    if v not in (None, ""):
        b_nonempty.append((r, v, type(v).__name__))
print("Non-empty column B count:", len(b_nonempty))
print("All non-empty column B values:")
for item in b_nonempty:
    print(item)

# Inspect row context around every string in B containing uppercase letters+digits
target_candidates = []
for r, v, t in b_nonempty:
    if isinstance(v, str) and re.fullmatch(r"[A-Z]{2,3}\s?\d+", v.strip()):
        target_candidates.append((r, v))
print("\nTarget candidate cells in B matching code pattern:", target_candidates)

print("\nNearby row context for target candidates:")
for r, v in target_candidates:
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"Row {r}: {row_vals}")

# Also inspect date rows in B to ensure they remain untouched
date_rows = [(r, v) for r, v, t in b_nonempty if isinstance(v, datetime)]
print("\nDate rows in column B:", date_rows)
for r, v in date_rows:
    print(f"Row {r} context:", [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Check if there are any other cells elsewhere containing possible example answers/formulas near these rows
for r, _ in target_candidates[:3]:
    lo, hi = max(1, r-1), min(last_row, r+1)
    print(f"\nRows {lo}-{hi} detailed:")
    for rr in range(lo, hi+1):
        vals = [ws.cell(rr, c).value for c in range(1, ws.max_column + 1)]
        print(rr, vals)

# Apply transformation in memory to identified target cells only
def transform_code(val):
    # remove leading 2-3 uppercase letters and optional following space, keep numeric tail
    m = re.fullmatch(r"([A-Z]{2,3})\s?(\d+)", val.strip())
    return m.group(2) if m else val

changes = []
for r, old in target_candidates:
    new = transform_code(old)
    if new != old:
        changes.append((r, old, new))
print("\nPlanned changes:", changes)

# Save modified workbook
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

for r, old, new in changes:
    ws.cell(r, 2).value = int(new) if new.isdigit() else new

wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != ["Sheet1"]:
    # rename first sheet back if necessary and preserve structure
    if len(wb_after.sheetnames) == 1:
        wb_after[wb_after.sheetnames[0]].title = "Sheet1"
        wb_after.save(out_path)
        print("Renamed sheet back to Sheet1")
    else:
        print("Unexpected sheet names; not renaming automatically.")

# Verify with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify["Sheet1"]

print("\nVerification of target cells in column B:")
for r, old, new in changes:
    print(f"B{r}: before={old!r}, after={wsv.cell(r,2).value!r}")

print("\nVerification of date cells unchanged:")
for r, old_dt in date_rows:
    print(f"B{r}: {wsv.cell(r,2).value!r}")
