from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Workbook:", input_path)
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

def nonempty_headers(ws, header_row=1):
    headers = row_values(ws, header_row, ws.max_column)
    return headers

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = nonempty_headers(ws, 1)
    print("Row 1 headers/values:", headers)
    
    # first 10 rows
    first_n = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, first_n + 1):
        print(f"R{r}:", row_values(ws, r, ws.max_column))
    
    # last 5 rows (avoid duplicates)
    print("Last rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(f"R{r}:", row_values(ws, r, ws.max_column))

# specifically inspect referenced sheets/cells if present
for sname in ["Input", "Output"]:
    if sname in wb.sheetnames:
        ws = wb[sname]
        print(f"\nDetailed check for sheet '{sname}':")
        for r in range(1, min(ws.max_row, 15) + 1):
            vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 8) + 1)]
            print(f"R{r} A:{vals[0] if len(vals)>=1 else None} B:{vals[1] if len(vals)>=2 else None} C:{vals[2] if len(vals)>=3 else None} D:{vals[3] if len(vals)>=4 else None} E:{vals[4] if len(vals)>=5 else None} F:{vals[5] if len(vals)>=6 else None} G:{vals[6] if len(vals)>=7 else None} H:{vals[7] if len(vals)>=8 else None}")
