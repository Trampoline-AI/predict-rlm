from openpyxl import load_workbook
import os

input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))

# Load workbook for editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws_in = wb["Input"]
ws_out = wb["Output"]

# Reconfirm target area before writing
print("Pre-write target area Output!A:B rows 10-20:")
for r in range(10, min(20, ws_out.max_row) + 1):
    print(r, ws_out.cell(r, 1).value, ws_out.cell(r, 2).value)

# Find qualifying source rows
qualifying_rows = []
for r in range(1, ws_in.max_row + 1):
    a = ws_in.cell(r, 1).value
    b = ws_in.cell(r, 2).value
    e = ws_in.cell(r, 5).value
    if isinstance(e, str) and e.strip().lower() == "yes":
        if a not in (None, "") and b not in (None, ""):
            qualifying_rows.append(r)

print("Qualifying input rows:", qualifying_rows)

# Exact target layout verified from existing sheet:
# Output row 10 is the header row; rows 11+ are data rows.
header_out_row = 10
data_start_row = 11

# Write header
ws_out.cell(header_out_row, 1).value = "=Input!A7"
ws_out.cell(header_out_row, 2).value = "=Input!B7"

# Write filtered formulas
for i, src_r in enumerate(qualifying_rows, start=data_start_row):
    ws_out.cell(i, 1).value = f"=Input!A{src_r}"
    ws_out.cell(i, 2).value = f"=Input!B{src_r}"

# Clear leftover old output below the new filtered range
last_used_output_row = max(ws_out.max_row, data_start_row + len(qualifying_rows) + 5)
clear_from = data_start_row + len(qualifying_rows)
for r in range(clear_from, last_used_output_row + 1):
    ws_out.cell(r, 1).value = None
    ws_out.cell(r, 2).value = None

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names and len(wb_post.sheetnames) == len(original_sheet_names):
    for idx, expected in enumerate(original_sheet_names):
        wb_post.worksheets[idx].title = expected
    wb_post.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

wsv = wb_verify["Output"]
end_row = data_start_row + len(qualifying_rows) - 1

print("Verified Output target range:")
for r in range(header_out_row, end_row + 1):
    print(f"Output R{r}: A={wsV.cell(r,1).value if False else wsv.cell(r,1).value!r}, B={wsv.cell(r,2).value!r}")

print("Verified cleared rows just below output:")
for r in range(end_row + 1, min(end_row + 4, wsv.max_row) + 1):
    print(f"Output R{r}: A={wsv.cell(r,1).value!r}, B={wsv.cell(r,2).value!r}")

# Keep path for submit
final_output_path = output_path
print("final_output_path:", final_output_path)
