from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Input spreadsheet:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

workbook_summary = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    
    # Also inspect row 2 in case headers are not on row 1
    if ws.max_row >= 2:
        print("Row 2 values:", row_values(ws, 2, ws.max_column))
    
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    
    print("\nFirst sample rows:")
    for r in first_rows:
        print(f"Row {r}: {row_values(ws, r, min(ws.max_column, 12))}")
    
    print("\nLast sample rows:")
    for r in last_rows:
        print(f"Row {r}: {row_values(ws, r, min(ws.max_column, 12))}")
    
    # Focus on columns G and K
    print("\nFocused inspection of columns G and K:")
    for r in first_rows:
        g = ws[f"G{r}"].value if ws.max_column >= 7 else None
        k = ws[f"K{r}"].value if ws.max_column >= 11 else None
        print(f"Row {r}: G={g!r}, K={k!r}")
    print("...")
    for r in last_rows:
        g = ws[f"G{r}"].value if ws.max_column >= 7 else None
        k = ws[f"K{r}"].value if ws.max_column >= 11 else None
        print(f"Row {r}: G={g!r}, K={k!r}")
    
    # Check if K contains formulas anywhere in populated range
    k_formulas = []
    if ws.max_column >= 11:
        for r in range(1, ws.max_row + 1):
            val = ws[f"K{r}"].value
            if isinstance(val, str) and val.startswith("="):
                k_formulas.append((r, val))
                if len(k_formulas) >= 10:
                    break
    print("Sample formulas in column K:", k_formulas if k_formulas else "None found")
    
    workbook_summary[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "headers_row1": headers,
    }

print("\nWorkbook summary keys:", list(workbook_summary.keys()))
