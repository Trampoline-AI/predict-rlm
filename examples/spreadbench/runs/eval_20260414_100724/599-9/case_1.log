from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from copy import copy
import os

# Reload fresh workbook from input
wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

# Target confirmed from inspection/example
ws = wb["Before"]

# Apply rule to all relevant rows on Before sheet:
# If G has a value, copy it to K; if G is blank, leave K unchanged.
updates = []
for r in range(2, ws.max_row + 1):  # skip header
    g_cell = ws[f"G{r}"]
    k_cell = ws[f"K{r}"]
    g_val = g_cell.value
    k_old = k_cell.value
    
    if g_val is not None and g_val != "":
        # Update K from G
        k_cell.value = g_val
        # Preserve date display pattern from G where applicable
        if g_cell.number_format:
            k_cell.number_format = g_cell.number_format
        updates.append((r, ws[f"B{r}"].value, g_val, k_old, k_cell.value))

print(f"Updated {len(updates)} rows in 'Before' column K from column G.")
print("Sample updates (first 10):")
for item in updates[:10]:
    print(item)
print("Last 5 updates:")
for item in updates[-5:]:
    print(item)

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheet_names:
    current_names = wb_after.sheetnames[:]
    if len(current_names) == len(original_sheet_names):
        for old_name, desired_name in zip(current_names, original_sheet_names):
            wb_after[old_name].title = desired_name
        wb_after.save(out_path)
        print("Renamed sheets back to original names:", original_sheet_names)
    else:
        print("Warning: sheet count changed unexpectedly; not renaming automatically.")

# Verify output values with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

before_verify = wb_verify["Before"]
after_verify = wb_verify["After"]

# Verify key rows mentioned by the example and rule
rows_to_check = [2, 3, 4, 5, 9, 14, 19, 20, 21]
print("\nVerification of target cells on 'Before':")
for r in rows_to_check:
    print(
        f"Row {r}: "
        f"B={before_verify[f'B{r}'].value!r}, "
        f"G={before_verify[f'G{r}'].value!r}, "
        f"K={before_verify[f'K{r}'].value!r}"
    )

# Compare Before K to example After K for actual data rows
mismatches = []
for r in range(1, min(before_verify.max_row, after_verify.max_row) + 1):
    if before_verify[f"K{r}"].value != after_verify[f"K{r}"].value:
        mismatches.append((r, before_verify[f"K{r}"].value, after_verify[f"K{r}"].value))

print(f"\nK-column mismatches between 'Before' output and reference 'After': {len(mismatches)}")
for mm in mismatches[:10]:
    print("Mismatch:", mm)

# Extra sanity checks
blank_when_shouldnt = []
for r in range(2, before_verify.max_row + 1):
    g = before_verify[f"G{r}"].value
    k = before_verify[f"K{r}"].value
    if g is not None and g != "" and k is None:
        blank_when_shouldnt.append(r)

print("Rows where G has data but K is blank after processing:", blank_when_shouldnt)
print("Done. Output file ready.")
