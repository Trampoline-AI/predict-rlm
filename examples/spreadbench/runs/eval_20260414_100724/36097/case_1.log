import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def nonempty_row_count(ws):
    count = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            count += 1
    return count

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column, "nonempty_rows:", nonempty_row_count(ws))
    
    # Print first few rows to identify headers/layout
    preview_cols = min(ws.max_column, 12)
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"Row {r}:", row_values(ws, r, preview_cols))
    
    # Infer likely header row as first row with at least 2 non-empty cells
    header_row = None
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, preview_cols)
        if sum(v is not None and str(v).strip() != "" for v in vals) >= 2:
            header_row = r
            break
    print("Likely header row:", header_row)
    if header_row:
        headers = row_values(ws, header_row, preview_cols)
        print("Headers/sample columns:", headers)
    
    # Print first 5 data-ish rows after header
    if header_row and header_row < ws.max_row:
        for r in range(header_row + 1, min(ws.max_row, header_row + 8) + 1):
            print(f"Data row {r}:", row_values(ws, r, preview_cols))
    
    # Print last 5 non-empty rows
    nonempty_rows = [r for r in range(1, ws.max_row + 1) if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1))]
    tail = nonempty_rows[-5:]
    print("Last non-empty rows:", tail)
    for r in tail:
        print(f"Tail row {r}:", row_values(ws, r, preview_cols))
    
    # Inspect columns A:I specifically, including formulas in H and formatting clue in I
    inspect_cols = min(ws.max_column, 9)
    print("A:I snapshot")
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = row_values(ws, r, inspect_cols)
        print(f"r{r}: {vals}")
    
    if ws.max_row > 15:
        for r in tail:
            vals = row_values(ws, r, inspect_cols)
            print(f"tail r{r}: {vals}")
    
    # Print existing formulas/values in H and nearby column I
    if ws.max_column >= 8:
        print("Column H/I detailed scan (first 20 rows and last 10 non-empty rows):")
        rows_to_show = list(range(1, min(ws.max_row, 20) + 1))
        rows_to_show += [r for r in nonempty_rows[-10:] if r not in rows_to_show]
        for r in rows_to_show:
            h = ws.cell(r, 8)
            i = ws.cell(r, 9) if ws.max_column >= 9 else None
