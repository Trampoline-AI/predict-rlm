from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from copy import copy
import os, json

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)
print("Merged ranges:", list(ws.merged_cells.ranges))
print("Column letters present:", [get_column_letter(c) for c in range(1, ws.max_column + 1)])
for c in range(1, ws.max_column + 1):
    dim = ws.column_dimensions[get_column_letter(c)]
    print(f"Col {get_column_letter(c)}: hidden={dim.hidden}, width={dim.width}")

print("\nDetailed target-area inspection:")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 9) + 1)]
    print(f"Row {r}: {vals}")

print("\nColumn H style/details:")
for r in range(1, ws.max_row + 1):
    cell = ws[f"H{r}"]
    print(
        f"H{r}: value={cell.value!r}, style_id={cell.style_id}, "
        f"numfmt={cell.number_format!r}, fill={cell.fill.fill_type}/{cell.fill.fgColor.rgb}, "
        f"font={cell.font.name}/{cell.font.sz}/bold={cell.font.bold}, align={cell.alignment.horizontal}"
    )

print("\nDoes column I exist?", ws.max_column >= 9)
if ws.max_column >= 9:
    for r in range(1, ws.max_row + 1):
        cell = ws[f"I{r}"]
        print(
            f"I{r}: value={cell.value!r}, style_id={cell.style_id}, "
            f"numfmt={cell.number_format!r}"
        )

# Identify data rows: rows after header until before total row
data_rows = []
for r in range(3, ws.max_row + 1):
    label = ws.cell(r, 1).value
    if isinstance(label, str) and label.strip().lower() == "total":
        total_row = r
        break
    if any(ws.cell(r, c).value is not None for c in range(1, 8)):
        data_rows.append(r)
else:
    total_row = None

print("Data rows:", data_rows, "Total row:", total_row)

# Prepare output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_path))

# Write formulas into H for all data rows, copying style from existing H3/H4 as needed
for r in data_rows:
    h = ws.cell(r, 8)
    # Preserve existing style by leaving style object as is; if blank style differs, copy from H3
    if h.style_id == 0 and ws["H3"].style_id != 0:
        h._style = copy(ws["H3"]._style)
        h.number_format = ws["H3"].number_format
        h.font = copy(ws["H3"].font)
        h.fill = copy(ws["H3"].fill)
        h.border = copy(ws["H3"].border)
        h.alignment = copy(ws["H3"].alignment)
        h.protection = copy(ws["H3"].protection)
    # Formula per instruction
    h.value = f'=IF(F{r}<0,E{r}+F{r},IF(F{r}<C{r},F{r},C{r}-E{r}))'

# Keep/create total formula in H total row if present
if total_row:
    ws.cell(total_row, 8).value = f"=SUM(H{data_rows[0]}:H{data_rows[-1]})"

wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_sheet_names = wb.sheetnames
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for idx, sname in enumerate(orig_sheet_names):
        wb_after.worksheets[idx].title = sname
    wb_after.save(out_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values[orig_sheet_names[0]]

print("\nVerification H cells:")
for r in data_rows + ([total_row] if total_row else []):
    print(
        f"Row {r}: formula={wsf.cell(r,8).value!r}, value={wsv.cell(r,8).value!r}, "
        f"C={wsv.cell(r,3).value!r}, E={wsv.cell(r,5).value!r}, F={wsv.cell(r,6).value!r}"
    )

# Save output path for submission
final_output_path = out_path
print("final_output_path:", final_output_path)
