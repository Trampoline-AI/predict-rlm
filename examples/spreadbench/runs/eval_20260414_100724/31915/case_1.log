import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Sheet names:", original_sheet_names)

def display_row(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

sheet_summaries = {}

for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    headers = display_row(ws, 1, max_col)
    sheet_summaries[ws.title] = {"max_row": max_row, "max_col": max_col, "headers": headers}
    
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"Dimensions: rows={max_row}, cols={max_col}")
    print("Headers (row 1):")
    for c in range(1, max_col + 1):
        print(f"  {get_column_letter(c)}1 = {ws.cell(1,c).value!r}")
    
    top_n = min(10, max_row)
    print(f"\nFirst {top_n} rows:")
    for r in range(1, top_n + 1):
        print(f"Row {r}: {display_row(ws, r, max_col)}")
    
    if max_row > 10:
        print(f"\nLast {min(5, max_row)} rows:")
        start = max(1, max_row - 4)
        for r in range(start, max_row + 1):
            print(f"Row {r}: {display_row(ws, r, max_col)}")
    
    # Look for blank or formula-bearing columns near used range
    print("\nColumn diagnostics:")
    for c in range(1, max_col + 1):
        col_letter = get_column_letter(c)
        header = ws.cell(1, c).value
        sample_vals = [ws.cell(r, c).value for r in range(2, min(max_row, 8)+1)]
        formulas = []
        for r in range(2, min(max_row, 15)+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, v))
        print(f"  Col {col_letter} header={header!r} sample={sample_vals[:5]}")
        if formulas:
            print(f"    formulas: {formulas[:5]}")
