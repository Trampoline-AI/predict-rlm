```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]

# Identify target sheet based on headers
target_ws = None
for ws in wb.worksheets:
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    if headers[:3] == ["serial", "price", "total"]:
        target_ws = ws
        break

if target_ws is None:
    raise ValueError("Could not find target sheet with headers ['serial', 'price', 'total'].")

ws = target_ws
print("Target sheet:", ws.title)
print("Target headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Determine actual data extent: rows where serial or price is present
data_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is not None or b is not None:
        data_rows.append(r)

first_data_row = min(data_rows)
last_data_row = max(data_rows)
print(f"Detected data rows: {first_data_row} to {last_data_row}")

print("\nCurrent target range values before modification:")
for r in range(first_data_row, last_data_row + 1):
    print(f"Row {r}: A{r}={ws[f'A{r}'].value!r}, B{r}={ws[f'B{r}'].value!r}, C{r}={ws[f'C{r}'].value!r}")

# Write formulas into column C for all relevant rows
for r in range(first_data_row, last_data_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is None and b is None:
        continue
    formula = f'=IF(COUNTIF($A${first_data_row}:A{r},A{r})=1,SUMIF($A${first_data_row}:$A${last_data_row},A{r},$B${first_data_row}:$B${last_data_row}),"")'
    ws.cell(r, 3).value = formula

print("\nFormulas written to target cells:")
for r in range(first_data_row, last_data_row + 1):
    print(f"C{r} -> {ws[f'C{r}'].value}")

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalculate changed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != original_sheet_names and len(wb_post.sheetnames) == len(original_sheet_names):
    print("Sheet names changed after recalc:", wb_post.sheetnames)
    for i, expected_name in enumerate(original_sheet_names):
        wb_post.worksheets[i].title = expected_name
    wb_post.save(output_path)
    print("Restored sheet names to:", original_sheet_names)
else:
    print("Sheet names after recalc:", wb_post.sheetnames)

# Verify formulas and evaluated values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[ws.title]

wb_values = load_workbook(output_path, data_only=True)
# pick sheet by original title, or fallback by index
if ws.title in wb_values.sheetnames:
    ws_values = wb_values[ws.title]
else:
    ws_values = wb_values.worksheets[original_sheet_names.index(ws.title)]

print("\nVerification of target cells after recalculation:")
verification_rows = []
for r in range(first_data_row, last_data_row + 1):
    formula_val = ws_formula[f"C{r}"].value
    cached_val = ws_values[f"C{r}"].value
    row_info = {
        "row": r,
        "serial": ws_values[f"A{r}"].value,
        "price": ws_values[f"B{r}"].value,
        "formula": formula_val,
        "value": cached_val,
    }
    verification_rows.append(row_info)
    print(row_info)

# Basic sanity checks
errors = []
for item in verification_rows:
    r = item["row"]
    serial = item["serial"]
    formula_val = item["formula"]
    value = item["value"]
    if serial is not None:
        if not (isinstance(formula_val, str) and formula_val.startswith("=")):
            errors.append(f"C{r} missing formula")
        # For first occurrences expected a number, later duplicates expected blank/""
        # Determine first occurrence based on serials up to current row
        prior_serials = [ws_values[f"A{k}"].value for k in range(first_data_row, r)]
        is_first = serial not in prior_serials
        if is_first and value in (None, ""):
            errors.append(f"C{r} should have total but is blank")
        if (not is_first) and value not in (None, ""):
            errors.append(f"C{r} should be blank for duplicate serial but has {value!r}")

print("\nVerification errors:", errors if errors else "None")
final_output_path = output_path
