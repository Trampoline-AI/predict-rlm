        col_i_vals.append(v)
    unique_i = {}
    for v in col_i_vals:
        key = str(v)
        unique_i[key] = unique_i.get(key, 0) + 1
    top_unique = sorted(unique_i.items(), key=lambda x: (-x[1], x[0]))[:20]
    print("Column I top unique counts:", top_unique)
    
    matching_rows = []
