import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    if ws.merged_cells.ranges:
        print("Merged ranges:", [str(rng) for rng in list(ws.merged_cells.ranges)[:20]])
    else:
        print("Merged ranges: none")
    
    # detect non-empty rows/cols more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    
    # print first 10 rows
    print("\nFirst 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"Row {r}: {row_values(ws, r)}")
    
    # print last 5 non-empty rows
    print("\nLast 5 non-empty rows:")
    for r in nonempty_rows[-5:]:
        print(f"Row {r}: {row_values(ws, r)}")
    
    # identify likely header rows (first 5 non-empty rows)
    print("\nPotential header rows (first 5 non-empty):")
    for r in nonempty_rows[:5]:
        vals = row_values(ws, r)
        print(f"Row {r}: {vals}")
    
    # formulas scan
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print(f"Formula cells count: {len(formulas)}")
    for item in formulas[:20]:
        r, c, v = item
        print(f"  {get_column_letter(c)}{r}: {v}")
