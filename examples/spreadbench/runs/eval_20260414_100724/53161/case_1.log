print("Columns:", [(c, get_column_letter(c)) for c in range(1, ws.max_column + 1)])

# Print all non-empty rows from 11 to 43 with coordinates for non-empty cells
for r in range(11, 44):
    vals = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
