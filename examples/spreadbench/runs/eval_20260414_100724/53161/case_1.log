    tl = ws[str(rng).split(":")[0]].value
    print(str(rng), "->", tl)

# Print the key grid areas as matrix-like output
def print_grid(r1, r2, c1, c2):
    header = ["   "] + [f"{get_column_letter(c):>8}" for c in range(c1, c2+1)]
    print("".join(header))
    for r in range(r1, r2+1):
        row = [f"{r:>3}"]
        for c in range(c1, c2+1):
            v = ws.cell(r, c).value
            row.append(f"{str(v)[:8]:>8}")
        print("".join(row))

print("\nTop categories table E:N (rows 2:10)")
