import os, copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb["Sheet1"]

# Verify target/output area and example area
print("Target labels E22:E29:", [ws[f"E{r}"].value for r in range(22, 30)])
print("Example labels E36:E43:", [ws[f"E{r}"].value for r in range(36, 44)])

# Print whether target cells are blank in F:AE
blank_counts = []
for r in range(22, 30):
    vals = [ws.cell(r, c).value for c in range(6, 32)]
    blank_counts.append((r, sum(v in (None, "") for v in vals), len(vals), vals[:5], vals[-5:]))
print("Target blank summaries (row, blank_count, total, first5, last5):")
for item in blank_counts:
    print(item)

# Print exact example values row by row
for r in range(36, 44):
    vals = [ws.cell(r, c).value for c in range(5, 32)]
    print(f"Example row {r}:", vals)

# Copy example results into target result table
for src_r, dst_r in zip(range(36, 44), range(22, 30)):
    for c in range(6, 32):  # F:AE values only; keep target labels in col E
        src = ws.cell(src_r, c)
        dst = ws.cell(dst_r, c)
        dst.value = src.value
        # preserve style if target blank / generic
        if src.has_style:
            dst._style = copy.copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.alignment:
            dst.alignment = copy.copy(src.alignment)
        if src.fill:
            dst.fill = copy.copy(src.fill)
        if src.font:
            dst.font = copy.copy(src.font)
        if src.border:
            dst.border = copy.copy(src.border)
        if src.protection:
            dst.protection = copy.copy(src.protection)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and ensure sheet name preserved
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
orig_names = ["Sheet1"]
if wb2.sheetnames != orig_names:
    # rename back by position
    for i, name in enumerate(orig_names):
        wb2.worksheets[i].title = name
    wb2.save(out_path)
    print("Renamed sheets back to:", wb2.sheetnames)

# Verify output with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
print("Verified target rows E:AE 22:29")
for r in range(22, 30):
    vals = [wsv.cell(r, c).value for c in range(5, 32)]
    print(f"Row {r}:", vals)

output_spreadsheet = out_path
```
