import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheet names:", original_sheetnames)

# Reconfirm structure and exact targets
print("Source headers C5:I5:", [ws.cell(5, c).value for c in range(3, 10)])
print("Target headers M5:S5:", [ws.cell(5, c).value for c in range(13, 20)])
print("Target brands L6:L19:", [ws.cell(r, 12).value for r in range(6, ws.max_row + 1)])

target_rows = [r for r in range(6, ws.max_row + 1) if ws.cell(r, 12).value not in (None, "")]
target_cols = [c for c in range(13, 20) if ws.cell(5, c).value not in (None, "")]
print("Target rows to fill:", target_rows)
print("Target cols to fill:", [(c, get_column_letter(c), ws.cell(5, c).value) for c in target_cols])

# Build expected mapping from source table
source_categories = {ws.cell(5, c).value: c for c in range(3, 10) if ws.cell(5, c).value not in (None, "")}
source_brands = {ws.cell(r, 2).value: r for r in range(6, ws.max_row + 1) if ws.cell(r, 2).value not in (None, "")}

expected = {}
for r in target_rows:
    brand = ws.cell(r, 12).value
    expected[r] = {}
    for c in target_cols:
        category = ws.cell(5, c).value
        src_r = source_brands.get(brand)
        src_c = source_categories.get(category)
        val = ws.cell(src_r, src_c).value if (src_r and src_c) else None
        expected[r][c] = val

print("Expected target values:")
for r in target_rows:
    print(r, ws.cell(r, 12).value, [expected[r][c] for c in target_cols])

# Print current target cells before writing
print("\nCurrent target range M6:S11 before writing:")
for r in target_rows:
    print(r, [ws.cell(r, c).value for c in target_cols])

# Write INDEX/MATCH formula into target cells
# Use OFFSET+COUNTBLANK only to preserve blanks correctly if possible in LibreOffice.
for r in target_rows:
    for c in target_cols:
        cell = ws.cell(r, c)
        current = cell.value
        if current in (None, ""):
            col_letter = get_column_letter(c)
            formula = (
                f'=IF(COUNTBLANK(OFFSET($B$6,'
                f'MATCH($L{r},$B$6:$B${ws.max_row},0)-1,'
                f'MATCH({col_letter}$5,$C$5:$I$5,0)))>0,"",'
                f'INDEX($C$6:$I${ws.max_row},'
                f'MATCH($L{r},$B$6:$B${ws.max_row},0),'
                f'MATCH({col_letter}$5,$C$5:$I$5,0)))'
            )
            cell.value = formula

# Save formula version
wb.save(output_path)
print("\nSaved formula version to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc and restore if changed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", original_sheetnames)
    while len(wb_after.sheetnames) > len(original_sheetnames):
        # Should not happen, but just report if it does
        print("Unexpected extra sheets:", wb_after.sheetnames)
        break
    for i, old_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
else:
    print("Sheet names preserved after recalc.")

# Verify formula results
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("\nVerified target range after formula recalc:")
formula_ok = True
mismatches = []
for r in target_rows:
    actual_row = []
    for c in target_cols:
        actual = wsv.cell(r, c).value
        exp = expected[r][c]
        actual_row.append(actual)

        exp_blank = exp in (None, "")
        act_blank = actual in (None, "")

        # Flag mismatches including blanks becoming 0
        if exp_blank:
            if not act_blank:
                mismatches.append((r, c, exp, actual))
                formula_ok = False
        else:
            if actual != exp:
                mismatches.append((r, c, exp, actual))
                formula_ok = False
    print(r, wsv.cell(r, 12).value, actual_row)

print("\nFormula mismatches:", mismatches[:20], "total:", len(mismatches))

# Fallback to literal values if formulas didn't verify exactly
if not formula_ok:
    print("\nFormula verification failed; applying Python-computed literal values fallback.")
    wb_fix = load_workbook(output_path)
    if wb_fix.sheetnames != original_sheetnames:
        for i, old_name in enumerate(original_sheetnames):
            if i < len(wb_fix.worksheets):
                wb_fix.worksheets[i].title = old_name
    wsf = wb_fix[original_sheetnames[0]]

    for r in target_rows:
        for c in target_cols:
            wsf.cell(r, c).value = expected[r][c]

    wb_fix.save(output_path)
    recalc_result_2 = await recalculate(output_path)
    print("Recalculate after fallback:", recalc_result_2)

    wb_fix2 = load_workbook(output_path)
    if wb_fix2.sheetnames != original_sheetnames:
        print("Restoring sheet names again after fallback recalc.")
        for i, old_name in enumerate(original_sheetnames):
            if i < len(wb_fix2.worksheets):
                wb_fix2.worksheets[i].title = old_name
        wb_fix2.save(output_path)

    wb_verify = load_workbook(output_path, data_only=True)
    wsv = wb_verify[original_sheetnames[0]]

    print("\nVerified target range after fallback:")
    final_mismatches = []
    for r in target_rows:
        actual_row = []
        for c in target_cols:
            actual = wsv.cell(r, c).value
            exp = expected[r][c]
            actual_row.append(actual)
            exp_blank = exp in (None, "")
            act_blank = actual in (None, "")
            if exp_blank:
                if not act_blank:
                    final_mismatches.append((r, c, exp, actual))
            else:
                if actual != exp:
                    final_mismatches.append((r, c, exp, actual))
        print(r, wsv.cell(r, 12).value, actual_row)
    print("Final mismatches:", final_mismatches)
else:
    print("\nFormula verification succeeded exactly.")

# Final explicit verification of exact target cells
print("\nFinal exact target cells M6:S11:")
wb_final_check = load_workbook(output_path, data_only=True)
ws_final = wb_final_check[original_sheetnames[0]]
for r in target_rows:
    entries = []
    for c in target_cols:
        entries.append(f"{get_column_letter(c)}{r}={ws_final.cell(r,c).value!r}")
    print(" | ".join(entries))

print("\nFinal sheet names:", wb_final_check.sheetnames)
print("Output ready:", output_path)

final_output_spreadsheet = output_path
```
