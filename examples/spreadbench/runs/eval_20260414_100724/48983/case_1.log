import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INPUT:", input_spreadsheet)
print("INSTRUCTION:\n", instruction)

wb = load_workbook(input_spreadsheet)
print("\nSheet names:", wb.sheetnames)

def sheet_used_range(ws):
    min_row = None
    max_row = 0
    min_col = None
    max_col = 0
    nonempty = 0
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value is not None:
                nonempty += 1
                row_has = True
                if min_row is None or cell.row < min_row:
                    min_row = cell.row
                if min_col is None or cell.column < min_col:
                    min_col = cell.column
                max_row = max(max_row, cell.row)
                max_col = max(max_col, cell.column)
        if row_has:
            pass
    return {
        "min_row": min_row, "max_row": max_row,
        "min_col": min_col, "max_col": max_col,
        "nonempty_cells": nonempty
    }

for s in wb.sheetnames:
    ws = wb[s]
    info = sheet_used_range(ws)
    print(f"\n=== SHEET: {s} ===")
    print(f"ws.max_row={ws.max_row}, ws.max_column={ws.max_column}, used={info}")
    
    # print row 1-15 and last 5 rows, across used columns
    start_col = info["min_col"] or 1
    end_col = info["max_col"] or ws.max_column
    headers = [f"{get_column_letter(c)}:{ws.cell(1,c).value}" for c in range(start_col, end_col+1)]
    print("Row 1 headers/values by col:", headers)
    
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(start_col, end_col+1)]
    
    top_rows = list(range(1, min(ws.max_row, 15)+1))
    print("Top rows:")
    for r in top_rows:
        print(r, row_vals(r))
    
    if ws.max_row > 15:
        print("Last 5 rows:")
        for r in range(max(1, ws.max_row-4), ws.max_row+1):
            print(r, row_vals(r))
    
    # Print formulas in used range (limited)
    formulas = []
    for r in range(1, ws.max_row+1):
        for c in range(1, ws.max_column+1):
            v = ws.cell(r,c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formulas[:50], f"(total {len(formulas)})")
