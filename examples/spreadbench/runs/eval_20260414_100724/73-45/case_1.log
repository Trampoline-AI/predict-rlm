def norm_target(t):
    t = t.replace("\\", "/")
    if t.startswith("/"):
        t = t[1:]
    while t.startswith("../"):
        t = t[3:]
    if t.startswith("xl/"):
        return t
    if t.startswith("worksheets/") or t.startswith("sharedStrings") or t.startswith("styles"):
        return "xl/" + t
    return "xl/" + t

