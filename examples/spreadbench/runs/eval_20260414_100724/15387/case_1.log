```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Using sheet:", ws.title)
print("Original sheet names:", original_sheetnames)

# Reconfirm relevant cells before writing
for coord in ["B1","C1","D1","E1","F1","B3","C3","D3","E3","F3","B12","A13","A14","A15"]:
    print(coord, "before ->", repr(ws[coord].value))

# Build robust non-array nth-match formulas for A13:A17
# Logic: return the nth customer name across B:F whose row-1 flag equals B12
customer_start_col = column_index_from_string("B")
customer_end_col = column_index_from_string("F")
input_cell = "$B$12"

def nth_match_formula(n):
    # Nested IF using cumulative COUNTIF prefixes:
    # =IF(COUNTIF($B$1:B$1,$B$12)>=n,B$3,IF(COUNTIF($B$1:C$1,$B$12)>=n,C$3,...,""))
    parts = []
    for c in range(customer_start_col, customer_end_col + 1):
        col = get_column_letter(c)
        prefix_range = f"$B$1:{col}$1"
        name_ref = f"{col}$3"
        parts.append(f'IF(COUNTIF({prefix_range},{input_cell})>={n},{name_ref},')
    formula = "=" + "".join(parts) + '""' + (")" * len(parts))
    return formula

target_rows = range(13, 18)  # A13:A17
for r in target_rows:
    formula = nth_match_formula(r - 12)
    ws[f"A{r}"] = formula
    print(f"A{r} formula -> {formula}")

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # Rename sheets positionally back to original names
    for i, expected_name in enumerate(original_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas exist in target cells
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Formulas in target cells:")
for r in target_rows:
    print(f"A{r} formula stored ->", ws_formula[f"A{r}"].value)

# Verify evaluated results
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("Evaluated target values:")
for r in target_rows:
    print(f"A{r} value ->", repr(ws_values[f"A{r}"].value))

# Additional sanity checks
expected_nonblank = {"A13", "A14"}
for coord in expected_nonblank:
    val = ws_values[coord].value
    if val is None or (isinstance(val, str) and val.strip() == ""):
        raise ValueError(f"{coord} is blank after recalculation, expected a value.")

print("Verified key outputs:")
print("A13:", ws_values["A13"].value)
print("A14:", ws_values["A14"].value)

output_spreadsheet = output_path
```
