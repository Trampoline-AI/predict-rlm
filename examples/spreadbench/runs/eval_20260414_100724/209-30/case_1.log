import os
from collections import Counter
from openpyxl import load_workbook

# Re-open fresh for modification after additional inspection
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Data to Import"]

# Determine true target range in column C
last_nonempty_c = None
for r in range(ws.max_row, 1, -1):
    v = ws.cell(r, 3).value
    if v not in (None, ""):
        last_nonempty_c = r
        break

print("Original sheet names:", orig_sheet_names)
print("Target sheet:", ws.title)
print("Target column:", "C (Location)")
print("Target data rows:", 2, "to", last_nonempty_c)

# Inspect distinct/sample values and transformation pattern
nonempty_values = []
for r in range(2, last_nonempty_c + 1):
    v = ws.cell(r, 3).value
    if v not in (None, ""):
        nonempty_values.append(v)

print("Non-empty value count in C:", len(nonempty_values))
print("Unique value count in C:", len(set(nonempty_values)))
print("Most common values:", Counter(nonempty_values).most_common(10))

sample_rows = [2, 3, 4, 5, 10, 100, 1000, last_nonempty_c]
sample_rows = [r for r in sample_rows if 2 <= r <= last_nonempty_c]
print("\nSample before-change values:")
for r in sample_rows:
    old = ws.cell(r, 3).value
    new = old[:-3] if isinstance(old, str) and len(old) >= 3 else old
    print(f"C{r}: {old!r} -> {new!r}")

# Perform in-place removal of last three characters for all populated string cells in C2:C[last_nonempty_c]
changed = 0
skipped_blank = 0
skipped_short_or_nonstr = 0

for r in range(2, last_nonempty_c + 1):
    cell = ws.cell(r, 3)
    v = cell.value
    if v in (None, ""):
        skipped_blank += 1
        continue
    if isinstance(v, str) and len(v) >= 3:
        cell.value = v[:-3]
        changed += 1
    else:
        skipped_short_or_nonstr += 1

print("\nModification stats:")
print("Changed cells:", changed)
print("Skipped blanks:", skipped_blank)
print("Skipped short/non-string:", skipped_short_or_nonstr)

# Save output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # Rename by position back to originals
    for i, desired in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = desired
    wb_after.save(out_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verification using data_only
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Data to Import"]

print("\nVerification of target cells:")
for r in sample_rows:
    print(f"C{r} =", repr(wsv.cell(r, 3).value))

# Verify blanks beyond last non-empty remain blank
tail_rows = [6067, 93193, 93197]
print("\nVerification of rows that should remain blank:")
for r in tail_rows:
    if r <= wsv.max_row:
        print(f"C{r} =", repr(wsv.cell(r, 3).value))

# Sanity checks
issues = []
for r in sample_rows:
    val = wsv.cell(r, 3).value
    if val in (None, ""):
        issues.append(f"C{r} unexpectedly blank")

print("\nSanity issues:", issues if issues else "None")

output_spreadsheet = out_path
print("\nPrepared output_spreadsheet:", output_spreadsheet)
