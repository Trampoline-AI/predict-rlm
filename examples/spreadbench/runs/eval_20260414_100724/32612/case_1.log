def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find non-empty rows count more reliably
    nonempty_rows = 0
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows += 1
    print("nonempty_rows:", nonempty_rows)
    
    # Print first 10 rows with headers/values
    first_n = min(ws.max_row, 10)
    print("\nFirst rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Print last 5 rows
    print("\nLast rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    
    # Candidate headers from first few rows
    print("\nCandidate headers by row:")
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        labeled = [f"{get_column_letter(c)}{r}={vals[c-1]!r}" for c in range(1, ws.max_column + 1)]
        print("row", r, labeled)

for ws in wb.worksheets:
    sheet_summary(ws)
