```repl
import os
from openpyxl import load_workbook

# Load workbook fresh
wb = load_workbook(input_spreadsheet)
orig_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine actual data extents again
date_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, 1).value not in (None, "")]
holiday_rows = [r for r in range(2, ws.max_row + 1) if any(ws.cell(r, c).value not in (None, "") for c in (8, 9, 10))]
holiday_row_start, holiday_row_end = min(holiday_rows), max(holiday_rows)
date_row_start, date_row_end = min(date_rows), max(date_rows)

print("Writing formulas to WORKDAY column E for rows:", date_row_start, "to", date_row_end)
print("Using holiday lookup range:", f"I{holiday_row_start}:J{holiday_row_end}")

# Write formulas to target cells only for rows with a date
for r in date_rows:
    current = ws.cell(r, 5).value
    if current in (None, ""):
        # If date blank -> blank, else if holiday match -> holiday type, else weekday abbreviation
        formula = (
            f'=IF(A{r}="","",'
            f'IFERROR(VLOOKUP(A{r},$I${holiday_row_start}:$J${holiday_row_end},2,FALSE),'
            f'CHOOSE(WEEKDAY(A{r},2),"Mon","Tue","Wed","Thu","Fri","Sat","Sun")))'
        )
        ws.cell(r, 5).value = formula

# Print a few formulas before saving
print("\nSample formulas written:")
for r in [2, 3, 44, 71, 75]:
    if r <= ws.max_row:
        print(f"E{r} ->", ws.cell(r, 5).value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc and restore if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_names:
    # rename sheets back by position
    for idx, expected in enumerate(orig_names):
        if idx < len(wb_after.worksheets):
            wb_after.worksheets[idx].title = expected
    wb_after.save(out_path)
    print("Renamed sheets back to:", orig_names)

# Verify using data_only workbook
wb_val = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_val.sheetnames)
ws_val = wb_val[orig_names[0]]

# Print target range samples
verify_rows = [2, 3, 4, 5, 44, 45, 71, 72, 73, 74, 75]
print("\nVerification samples (DATE -> WORKDAY):")
for r in verify_rows:
    if r <= ws_val.max_row:
        print(r, ws_val.cell(r, 1).value, "->", ws_val.cell(r, 5).value)

# Additional sanity checks
blank_targets = [r for r in date_rows if ws_val.cell(r, 5).value in (None, "")]
print("\nBlank target rows among populated DATE rows:", blank_targets[:20], "count:", len(blank_targets))

# Reload formula workbook too, to inspect exact formula if needed
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_names[0]]
print("\nFormula in E44:", ws_formula["E44"].value)

output_spreadsheet = out_path
