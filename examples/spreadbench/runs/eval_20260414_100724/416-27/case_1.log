```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)

# Print every row with coordinates and repr values to inspect exact blanks/content
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"Row {r:>2}: " + " | ".join(f"{get_column_letter(c)}{r}={vals[c-1]!r}" for c in range(1, ws.max_column + 1)))

# Analyze column A specifically
colA = [ws.cell(r, 1).value for r in range(1, ws.max_row + 1)]
nonempty_rows = []
blank_rows_between = []
for r, v in enumerate(colA, start=1):
    is_blank = (v is None) or (isinstance(v, str) and v == "")
    if not is_blank:
        nonempty_rows.append(r)

print("Non-empty rows in column A:", nonempty_rows)
if nonempty_rows:
    first_nonempty = nonempty_rows[0]
    last_nonempty = nonempty_rows[-1]
    print("First non-empty row in A:", first_nonempty, "value:", ws.cell(first_nonempty, 1).value)
    print("Last non-empty row in A:", last_nonempty, "value:", ws.cell(last_nonempty, 1).value)
    for r in range(first_nonempty, last_nonempty + 1):
        v = ws.cell(r, 1).value
        is_blank = (v is None) or (isinstance(v, str) and v == "")
        if is_blank:
            blank_rows_between.append(r)
    print("Blank rows in A between first and last non-empty:", blank_rows_between)

# Print row dimensions/hidden status just in case
for r in range(1, ws.max_row + 1):
    dim = ws.row_dimensions[r]
    if dim.hidden or dim.height is not None:
        print("Row dimension", r, "hidden=", dim.hidden, "height=", dim.height)

# Now perform the deletion if needed
if nonempty_rows and blank_rows_between:
    for r in reversed(blank_rows_between):
        ws.delete_rows(r, 1)
    print("Deleted rows:", blank_rows_between)
else:
    print("No deletions needed.")

# Save with same filename in output dir
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate and verify
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and verify sheet names unchanged; if changed, rename back
orig_sheetnames = wb.sheetnames[:]
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename positionally back to original names
    for ws_cur, orig_name in zip(wb2.worksheets, orig_sheetnames):
        ws_cur.title = orig_name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Final verification
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_sheetnames[0]]
print("Verified sheet:", wsv.title, "rows:", wsv.max_row, "cols:", wsv.max_column)
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    print(f"Final Row {r:>2}: " + " | ".join(f"{get_column_letter(c)}{r}={vals[c-1]!r}" for c in range(1, wsv.max_column + 1)))

# Keep output path in a variable for submission
final_output_path = out_path
