from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, re, textwrap

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols+1)]

# Inspect every sheet
for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1:", headers)
    if ws.max_row >= 2:
        print("Row 2:", row_values(ws, 2, ws.max_column))
    if ws.max_row >= 3:
        print("Row 3:", row_values(ws, 3, ws.max_column))
    
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))

# Search workbook text for likely target content
patterns = [r"Sub\s+Del_Blanks", r"macro", r"blank", r"Column A", r"Rows\.Count", r"SpecialCells", r"xlCellTypeBlanks"]
matches = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                for pat in patterns:
                    if re.search(pat, v, re.I):
                        matches.append((ws.title, cell.coordinate, v))
                        break

print("\nTEXT MATCHES:", len(matches))
for m in matches[:20]:
    sheet, coord, val = m
    print(f"{sheet} {coord}: {val[:300]!r}")
```
