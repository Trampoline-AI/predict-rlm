Code:
```repl
import os, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Re-open fresh for modification
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Inspect exact target range and infer expected pattern from existing sample answers
print("Original sheet names:", orig_sheet_names)
print("Target range A1:H4 before writing:")
for r in range(1, 5):
    print(f"Row {r}:", [ws.cell(r, c).value for c in range(1, 9)])

# Python sanity-check: determine per-animal descending ranks
labels = [ws.cell(1, c).value for c in range(1, 9)]
nums = [ws.cell(2, c).value for c in range(1, 9)]

positions_by_label = {}
for idx, (lab, num) in enumerate(zip(labels, nums), start=1):
    positions_by_label.setdefault(lab, []).append((idx, num))

expected = [""] * 8
for lab, items in positions_by_label.items():
    ranked = sorted(items, key=lambda t: t[1], reverse=True)
    for rank, (col_idx, num) in enumerate(ranked, start=1):
        if rank <= 2:
            expected[col_idx - 1] = f"{lab}{rank}"

print("Per-label sorted positions and values:")
for lab, items in positions_by_label.items():
    print(lab, sorted(items, key=lambda t: t[1], reverse=True))
print("Expected displayed row 4 (Python check):", expected)

# Write formulas across A4:H4
# Rank within same animal = 1 + count of same-animal values greater than current value.
# Only display if that rank is <= 2.
for c in range(1, 9):
    col = get_column_letter(c)
    formula = f'=IF(1+COUNTIFS($A$1:$H$1,{col}1,$A$2:$H$2,">"&{col}2)<=2,{col}1&(1+COUNTIFS($A$1:$H$1,{col}1,$A$2:$H$2,">"&{col}2)),"")'
    print(f"Writing {col}4 formula:", formula)
    ws.cell(4, c).value = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# If recalc changed sheet names, restore them once
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names and len(wb_post.sheetnames) == len(orig_sheet_names):
    for ws_obj, original_name in zip(wb_post.worksheets, orig_sheet_names):
        ws_obj.title = original_name
    wb_post.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verify with formulas visible
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula[orig_sheet_names[0]]
print("A4:H4 formulas after save:")
print([wsf.cell(4, c).value for c in range(1, 9)])

# Verify computed values after recalc
wb_verify_values = load_workbook(outfile, data_only=True)
print("Final sheet names:", wb_verify_values.sheetnames)
wsv = wb_verify_values[orig_sheet_names[0]]
final_vals = [wsv.cell(4, c).value for c in range(1, 9)]
print("A4:H4 values after recalc:", final_vals)

# Detailed target-cell verification
for c in range(1, 9):
    addr = f"{get_column_letter(c)}4"
    print(addr, "formula =", wsf[addr].value, "| value =", wsv[addr].value)

output_spreadsheet = outfile
