import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction preview:", instruction[:300], "...")

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def used_bounds(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # trim trailing fully empty rows/cols
    def row_has_data(r):
        return any(ws.cell(r, c).value is not None for c in range(1, max_col + 1))
    def col_has_data(c):
        return any(ws.cell(r, c).value is not None for r in range(1, max_row + 1))
    while max_row > 1 and not row_has_data(max_row):
        max_row -= 1
    while max_col > 1 and not col_has_data(max_col):
        max_col -= 1
    return max_row, max_col

for ws in wb.worksheets:
    ur, uc = used_bounds(ws)
    headers = [ws.cell(1, c).value for c in range(1, uc + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Reported max_row/max_col:", ws.max_row, ws.max_column)
    print("Trimmed used rows/cols:", ur, uc)
    print("Row 1 values / headers:", headers)
    
    # print first up to 10 rows and last 5 rows
    first_n = min(10, ur)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, uc + 1)]
        print(f"Row {r}: {vals}")
    if ur > 10:
        print("Last 5 rows:")
        for r in range(max(1, ur - 4), ur + 1):
            vals = [ws.cell(r, c).value for c in range(1, uc + 1)]
            print(f"Row {r}: {vals}")
    
    # specifically inspect A1:H6 because instruction references A1:H2 and row 4 target
