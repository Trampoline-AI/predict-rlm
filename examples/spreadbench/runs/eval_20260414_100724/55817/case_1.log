```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

# Load source workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Gather source data from column A (non-empty only)
source_vals = [ws.cell(r, 1).value for r in range(1, ws.max_row + 1) if ws.cell(r, 1).value is not None]
print("Non-empty source values in col A:", len(source_vals))
print("First 10 source values:", source_vals[:10])
print("Last 5 source values:", source_vals[-5:])

# Determine chunk size from existing headers B:H
headers = [ws.cell(1, c).value for c in range(2, 9)]
chunk_size = len(headers)
print("Headers B1:H1:", headers, "=> chunk_size:", chunk_size)

assert chunk_size == 7, f"Expected 7 target columns, found {chunk_size}"
assert len(source_vals) % chunk_size == 0, "Source values are not divisible into complete records"

records = [source_vals[i:i+chunk_size] for i in range(0, len(source_vals), chunk_size)]
print("Record count:", len(records))
for i, rec in enumerate(records, start=1):
    print(f"Record {i}:", rec)

# Show target area before writing
print("\nTarget area BEFORE writing (B1:H6):")
for r in range(1, 7):
    print(r, [ws.cell(r, c).value for c in range(2, 9)])

# Write transposed values starting at B2
start_row = 2
start_col = 2  # B
for i, rec in enumerate(records):
    for j, val in enumerate(rec):
        ws.cell(start_row + i, start_col + j).value = val

# Save output
os.makedirs(outdir, exist_ok=True)
wb.save(outfile)
print("\nSaved workbook to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring to", original_sheetnames)
    for ws_tmp, original_name in zip(wb_check.worksheets, original_sheetnames):
        ws_tmp.title = original_name
    wb_check.save(outfile)
else:
    print("Sheet names after recalc:", wb_check.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]

print("\nTarget area AFTER writing/recalc (B1:H6):")
for r in range(1, 7):
    row_vals = [wsv.cell(r, c).value for c in range(2, 9)]
    print(r, row_vals)

# Strong verification
problems = []
for i, rec in enumerate(records):
    for j, expected in enumerate(rec):
        rr = start_row + i
        cc = start_col + j
        actual = wsv.cell(rr, cc).value
        if isinstance(actual, str):
            actual = actual.strip()
        if isinstance(expected, str):
            expected_cmp = expected.strip()
        else:
            expected_cmp = expected
        if actual != expected_cmp:
            problems.append((rr, cc, expected_cmp, actual))

print("\nVerification mismatches:", len(problems))
if problems:
    for p in problems[:10]:
        print("Mismatch:", p)
else:
    print("All target cells B2:H6 match expected transposed values.")

output_spreadsheet = outfile
print("\nPrepared output file:", output_spreadsheet)
```
