from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 values / headers:", headers)
    
    # Find last non-empty row and column more accurately
    last_row = 0
    last_col = 0
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None for v in vals):
            last_row = r
            for c, v in enumerate(vals, start=1):
                if v is not None and c > last_col:
                    last_col = c
    print("Last non-empty row:", last_row, "Last non-empty col:", last_col, f"({get_column_letter(last_col) if last_col else 'N/A'})")
    
    # Print first 10 rows
    print("First rows:")
    for r in range(1, min(last_row, 10) + 1):
        print(r, row_values(ws, r, max(last_col, ws.max_column)))
    
    # Print last 5 non-empty rows
    if last_row > 10:
        print("Last rows:")
        for r in range(max(1, last_row - 4), last_row + 1):
            print(r, row_values(ws, r, max(last_col, ws.max_column)))
    
    # Print specific cells/ranges relevant to instruction
    print("Column A values (non-empty):")
    colA = []
    for r in range(1, last_row + 1):
        v = ws.cell(r, 1).value
        if v is not None:
            colA.append((r, v))
    print(colA[:20], "... total non-empty in A:", len(colA))
    if len(colA) > 20:
        print("Last 10 non-empty in A:", colA[-10:])
    
    print("Area around B2:H15:")
    for r in range(1, min(last_row, 15) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(max(last_col, 8), 8) + 1)]
        print(r, vals)

    if ws.merged_cells.ranges:
        print("Merged ranges:", list(ws.merged_cells.ranges))
    else:
        print("Merged ranges: none")
