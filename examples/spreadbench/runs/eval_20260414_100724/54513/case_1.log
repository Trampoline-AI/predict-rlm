from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)

print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def display(val):
    if hasattr(val, "text"):  # ArrayFormula etc.
        return f"<{type(val).__name__}: {val.text}>"
    return val

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Gather non-empty rows/cols more carefully
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                nonempty_cols.add(c)
        if row_has:
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    print("Non-empty columns:", [(c, get_column_letter(c), display(ws.cell(nonempty_rows[0], c).value) if nonempty_rows else None) for c in sorted(nonempty_cols)])
    
    # Print first 10 rows and last 5 non-empty rows
    rows_to_show = []
    rows_to_show.extend(nonempty_rows[:10])
    for r in nonempty_rows[-5:]:
        if r not in rows_to_show:
            rows_to_show.append(r)
    print("Sample rows:")
    for r in rows_to_show:
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # Print formulas
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
            elif hasattr(v, "text"):
                formulas.append((r, c, v.text))
    print("Formula cells:", formulas[:20], f"(total {len(formulas)})")
    
    # Print all non-empty cells if sheet is small
    if ws.max_row <= 20 and ws.max_column <= 10:
        print("All non-empty cells:")
        for r in range(1, ws.max_row + 1):
            for c in range(1, ws.max_column + 1):
                v = ws.cell(r, c).value
                if v not in (None, ""):
                    print(f"  {get_column_letter(c)}{r} = {display(v)}")
