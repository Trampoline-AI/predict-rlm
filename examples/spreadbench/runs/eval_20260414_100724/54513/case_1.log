from openpyxl.utils import get_column_letter
import os, shutil

path = input_spreadsheet

# Load workbook twice: formula view and data_only view
wb = load_workbook(path)
wb_vals = load_workbook(path, data_only=True)
ws = wb["Sheet1"]
ws_vals = wb_vals["Sheet1"]

# Inspect exact target area and relevant formatting
for coord in ["B4", "C4", "B5", "C5", "C7", "D7", "E7", "F7", "C8", "D8", "E8", "F8"]:
    c = ws[coord]
    cv = ws_vals[coord].value
    print(coord, "formula/raw=", c.value, "calculated=", cv, "number_format=", c.number_format)

# Also inspect surrounding row 8 columns B:F
print("Row 8 B:F raw:", [ws.cell(8, c).value for c in range(2, 7)])
print("Row 8 B:F calc:", [ws_vals.cell(8, c).value for c in range(2, 7)])

# Write formula into exact target cell F8 only if blank
if ws["F8"].value in (None, ""):
    ws["F8"] = "=C8*(1-E8)"
    # Apply a sensible number format; prefer matching MSRP cell if present
    ws["F8"].number_format = ws["C8"].number_format or '$#,##0.00'
    print("Wrote formula to F8:", ws["F8"].value, "with number format", ws["F8"].number_format)
else:
    print("F8 already had value:", ws["F8"].value)

# Save output
