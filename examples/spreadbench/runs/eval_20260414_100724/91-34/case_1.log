import os, json, math, statistics
from collections import Counter, defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_info = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print("SHEET:", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # find likely header row among first few rows
    candidate_rows = []
    for r in range(1, min(ws.max_row, 5)+1):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v not in (None, "") for v in vals)
        candidate_rows.append((r, nonempty, vals))
    print("Top candidate rows (row#, nonempty count):", [(r,n) for r,n,_ in candidate_rows])
    
    header_row = max(candidate_rows, key=lambda x: x[1])[0] if candidate_rows else 1
    headers = row_values(ws, header_row, ws.max_column)
    print("Chosen header row:", header_row)
    print("Headers:")
    for i, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)} ({i}): {h}")
    
    # print first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print("\nFirst rows:")
    for r in range(1, first_n+1):
        print(r, row_values(ws, r, ws.max_column))
    
    print("\nLast rows:")
    start_last = max(1, ws.max_row-4)
    for r in range(start_last, ws.max_row+1):
        print(r, row_values(ws, r, ws.max_column))
    
    sheet_info[ws.title] = {
        "header_row": header_row,
        "headers": headers,
        "max_row": ws.max_row,
        "max_column": ws.max_column,
    }

# Focus on columns mentioned in instruction, across all sheets
