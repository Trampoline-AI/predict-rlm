import os, shutil
from collections import defaultdict
from datetime import datetime, date
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

def norm_text(v):
    return "" if v is None else str(v).strip()

def norm_dob(v):
    if isinstance(v, datetime):
        return v.date().isoformat()
    if isinstance(v, date):
        return v.isoformat()
    return "" if v is None else str(v).strip()

# Re-open fresh workbook from input for actual modification
wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames[:]
ws2 = wb2["SwiftMD"]

# Confirm structure/target columns again
header_row = 2
headers = [ws2.cell(header_row, c).value for c in range(1, ws2.max_column + 1)]
header_to_col = {str(v).strip(): i for i, v in enumerate(headers, start=1) if v is not None}
print("Sheet names:", orig_sheet_names)
print("Header row:", header_row)
print("Relevant header mapping:", {k: header_to_col[k] for k in ["Last Name","First Name","Date Of Birth","Duplicate?","Relationship"]})

col_last = header_to_col["Last Name"]
col_first = header_to_col["First Name"]
col_dob = header_to_col["Date Of Birth"]
col_dup = header_to_col["Duplicate?"]
col_rel = header_to_col["Relationship"]

# Build groups
groups2 = defaultdict(list)
for r in range(header_row + 1, ws2.max_row + 1):
    rowrec = {
        "row": r,
        "last": ws2.cell(r, col_last).value,
        "first": ws2.cell(r, col_first).value,
        "dob": ws2.cell(r, col_dob).value,
        "dup": ws2.cell(r, col_dup).value,
        "rel": ws2.cell(r, col_rel).value,
    }
    key = (norm_text(rowrec["last"]), norm_text(rowrec["first"]), norm_dob(rowrec["dob"]))
    groups2[key].append(rowrec)

candidate_groups = []
rows_to_delete = []

for key, items in groups2.items():
    dup_yes_items = [x for x in items if norm_text(x["dup"]).lower() == "yes"]
    if len(dup_yes_items) >= 2:
        rels = [norm_text(x["rel"]).lower() for x in dup_yes_items]
        if all(rel != "employee" for rel in rels):
            # delete exactly one row from qualifying group
            delete_row = dup_yes_items[-1]["row"]
            candidate_groups.append({
                "key": key,
                "rows": [x["row"] for x in dup_yes_items],
                "relationships": [x["rel"] for x in dup_yes_items],
                "delete_row": delete_row,
            })
            rows_to_delete.append(delete_row)

print("Qualifying groups to delete one row from:")
for cg in candidate_groups:
    print(cg)

print("Rows to delete (descending):", sorted(rows_to_delete, reverse=True))
print("Original max_row:", ws2.max_row)

# Apply deletions bottom-up
for r in sorted(rows_to_delete, reverse=True):
    ws2.delete_rows(r, 1)

print("New max_row after deletion:", ws2.max_row)

# Save
wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename sheets positionally back to original names
    for ws_name_obj, orig_name in zip(wb_check.worksheets, orig_sheet_names):
        ws_name_obj.title = orig_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
wsv = wb_verify["SwiftMD"]

# Recompute groups after deletion
post_groups = defaultdict(list)
for r in range(header_row + 1, wsv.max_row + 1):
    key = (
        norm_text(wsv.cell(r, col_last).value),
        norm_text(wsv.cell(r, col_first).value),
        norm_dob(wsv.cell(r, col_dob).value),
    )
    post_groups[key].append({
        "row": r,
        "dup": wsv.cell(r, col_dup).value,
        "rel": wsv.cell(r, col_rel).value,
    })

print("\nVerification of affected groups:")
for cg in candidate_groups:
    key = cg["key"]
    remaining = post_groups.get(key, [])
    print("KEY:", key)
    print("  before rows:", cg["rows"], "relationships:", cg["relationships"], "deleted original row:", cg["delete_row"])
    print("  after count:", len(remaining), "after rows:", [x["row"] for x in remaining], "after relationships:", [x["rel"] for x in remaining])

# Also verify some non-qualifying examples mentioned in instruction were preserved
for key in [
    ("Doees", "Lisa", "1970-05-21"),
    ("Smith", "Antoinette", "1967-05-21"),
    ("Moon", "Justice", "2002-01-10"),
]:
    remaining = post_groups.get(key, [])
    print("NON-DELETE CHECK:", key, "count:", len(remaining), "relationships:", [x["rel"] for x in remaining], "rows:", [x["row"] for x in remaining])

output_spreadsheet = output_path
print("Prepared output_spreadsheet:", output_spreadsheet)
