from collections import defaultdict
from datetime import datetime

ws = wb["SwiftMD"]
header_row = sheet_info["SwiftMD"]["header_row"]
headers = sheet_info["SwiftMD"]["headers"]

# Map headers to columns
header_to_col = {str(v).strip(): i for i, v in enumerate(headers, start=1) if v is not None}
print("Header map:", header_to_col)

col_last = header_to_col["Last Name"]
col_first = header_to_col["First Name"]
col_dob = header_to_col["Date Of Birth"]
col_dup = header_to_col["Duplicate?"]
col_rel = header_to_col["Relationship"]

def norm_text(v):
    return "" if v is None else str(v).strip()

def norm_dob(v):
    if isinstance(v, datetime):
        return v.date().isoformat()
    if hasattr(v, "isoformat"):
        try:
            return v.isoformat()
        except:
            pass
    return str(v).strip() if v is not None else ""

groups = defaultdict(list)

for r in range(header_row + 1, ws.max_row + 1):
    last = ws.cell(r, col_last).value
    first = ws.cell(r, col_first).value
    dob = ws.cell(r, col_dob).value
    dup = ws.cell(r, col_dup).value
    rel = ws.cell(r, col_rel).value
    key = (norm_text(last), norm_text(first), norm_dob(dob))
    groups[key].append({
        "row": r,
        "last": last,
        "first": first,
        "dob": dob,
        "dup": dup,
        "rel": rel,
    })

# Show groups that actually have duplicate-marked rows or repeated identities
interesting = []
for key, items in groups.items():
    duplicate_yes_items = [x for x in items if norm_text(x["dup"]).lower() == "yes"]
    if len(items) > 1 or duplicate_yes_items:
        interesting.append((key, items, duplicate_yes_items))

print(f"Total identity groups: {len(groups)}")
print(f"Interesting groups (repeated and/or marked duplicate): {len(interesting)}")

for key, items, dup_yes_items in interesting:
    rels = [norm_text(x["rel"]) for x in items]
    dups = [norm_text(x["dup"]) for x in items]
    print("\nGROUP:", key)
    print(" total rows:", len(items), "rows:", [x["row"] for x in items])
    print(" duplicate? values:", dups)
    print(" relationships:", rels)
    for x in items:
        print("   ", x)

# Determine rows to delete per instruction:
# delete only one entry of a person (same last name, first name, dob) marked Yes in Duplicate?
# provided that the Relationship column for these duplicates is anything but Employee
rows_to_delete = []
candidate_groups = []

for key, items, dup_yes_items in interesting:
    if len(dup_yes_items) >= 2:
        rels_dup = [norm_text(x["rel"]).lower() for x in dup_yes_items]
        if all(rel != "employee" for rel in rels_dup):
            # delete one of the duplicate-marked rows; preserve the first, delete the second and onward?
            # instruction says delete only one entry, so for a pair delete one. For >2, delete len-1? No: says only one entry.
            # So we will delete exactly one row from the group.
            delete_row = dup_yes_items[-1]["row"]
            rows_to_delete.append(delete_row)
            candidate_groups.append((key, dup_yes_items, delete_row))

print("\nCandidate groups meeting deletion rule:")
for key, dup_yes_items, delete_row in candidate_groups:
    print("KEY:", key, "dup rows:", [x["row"] for x in dup_yes_items],
          "relationships:", [x["rel"] for x in dup_yes_items],
          "delete row:", delete_row)

print("Final rows_to_delete:", rows_to_delete)
