`=IFERROR(TRIM(LEFT(A1,FIND("FT",A1)-1)),A1)`

This is LibreOffice-compatible and dynamic. Then I’ll save to the required output path, recalculate, reload, verify the sheet name stayed the same, and print the target cells B1:B4 with both formulas and calculated results.
Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, filename)

# Load workbook normally for editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before writing target cells in column B:")
for r in range(1, ws.max_row + 1):
    print(f"Row {r}: A={ws.cell(r,1).value!r}, B={ws.cell(r,2).value!r}")

# Write formulas to column B for all non-empty rows in column A
target_rows = []
for r in range(1, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    if a_val is not None and str(a_val) != "":
        formula = f'=IFERROR(TRIM(LEFT(A{r},FIND("FT",A{r})-1)),A{r})'
        ws.cell(r, 2).value = formula
        target_rows.append(r)

print("Written formulas:")
for r in target_rows:
    print(f"B{r} = {ws.cell(r,2).value}")

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload to verify sheet names; restore if changed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed; restoring original names")
    for i, original_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Final sheet names:", wb_check.sheetnames)

# Verify formulas present in target cells
ws_formula = wb_check[original_sheet_names[0]]
print("Formulas in target cells:")
for r in target_rows:
    print(f"B{r} formula -> {ws_formula.cell(r,2).value}")

# Reload data_only to verify calculated results
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("Calculated values in target cells:")
for r in target_rows:
    print(f"B{r} value -> {ws_values.cell(r,2).value!r}")

output_spreadsheet = output_path
```
