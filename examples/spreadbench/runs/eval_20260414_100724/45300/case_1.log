        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    if nonempty_rows:
        print("First non-empty row:", nonempty_rows[0], "Last non-empty row:", nonempty_rows[-1], "Count non-empty:", len(nonempty_rows))
    else:
        print("No non-empty rows")
        continue
    
    print("Column letters and row 1 labels:")
