import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path:", input_path)
print("Exists:", os.path.exists(input_path), "Size:", os.path.getsize(input_path))

# Load workbook twice if needed later; for now normal mode for inspection
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def display_row(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    vals = [ws.cell(r, c).value for c in range(1, max_cols + 1)]
    return vals

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    headers = display_row(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row 2 values:", display_row(ws, 2, ws.max_column))
    
    # Print first 10 rows (or fewer)
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(f"  Row {r}: {display_row(ws, r, ws.max_column)}")
    
    # Print last 5 rows if applicable
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(f"  Row {r}: {display_row(ws, r, ws.max_column)}")
    
    # Explicitly inspect columns A:D since instruction references them
    print("Column letters present:", [get_column_letter(c) for c in range(1, ws.max_column + 1)])
    for col in range(1, min(4, ws.max_column) + 1):
        col_letter = get_column_letter(col)
        col_values_sample = [ws.cell(r, col).value for r in range(1, min(ws.max_row, 12) + 1)]
        print(f"Sample {col_letter} values:", col_values_sample)
    
    # If column D exists, inspect current contents/formulas there
    if ws.max_column >= 4:
        print("Current D column details (rows 1 to min(15,max_row)):")
        for r in range(1, min(15, ws.max_row) + 1):
            cell = ws.cell(r, 4)
            print(f"  D{r}: value={cell.value!r}, data_type={cell.data_type}")
