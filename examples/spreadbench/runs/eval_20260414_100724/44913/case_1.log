Now I should populate **all relevant rows in column D** with a formula that:
1. Finds the max amount for the current ID,
2. Shows the amount only when the current row’s amount equals that per-ID max,
3. Otherwise returns `""`,
4. Avoids `MAXIFS`.

Because the IDs are grouped contiguously in this sheet, I can use `MAX` on a dynamically constructed range with `INDEX + MATCH + COUNTIF`, which is LibreOffice-compatible and avoids array formulas. Then I’ll save, recalculate, reload, verify both formulas and cached results, and ensure the sheet name remains unchanged.
Code:
```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload clean workbook for writing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Before"]

print("Writing formulas to sheet:", ws.title)
print("Data rows:", ws.max_row, "Columns:", ws.max_column)
print("D1 before:", ws["D1"].value)

data_start = 2
data_end = ws.max_row

# Keep D1 blank/no header
ws["D1"] = None

# Write formula to all real data rows
for r in range(data_start, data_end + 1):
    a = f"A{r}"
    b = f"B{r}"
    formula = (
        f'=IF({b}=MAX('
        f'INDEX($B$2:$B${data_end},MATCH({a},$A$2:$A${data_end},0))'
        f':'
        f'INDEX($B$2:$B${data_end},MATCH({a},$A$2:$A${data_end},0)+COUNTIF($A$2:$A${data_end},{a})-1)'
        f'),{b},"")'
    )
    ws.cell(r, 4).value = formula

# Print a few formulas for inspection
for r in range(2, min(8, data_end) + 1):
    print(f"D{r} formula:", ws.cell(r, 4).value)

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and repair sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename back by position
    for i, original_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verify formulas are present
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Before"]
print("Verification - formulas in D2:D13:")
for r in range(2, data_end + 1):
    print(r, wsf.cell(r, 4).value)

# Verify cached values after recalculation
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Before"]
print("Verification - cached values in D1:D13:")
for r in range(1, data_end + 1):
    print(f"D{r} -> {wsv.cell(r, 4).value!r}")

# Also print row-wise A:D to confirm pattern
print("Final A:D rows:")
for r in range(1, data_end + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 5)])
```
