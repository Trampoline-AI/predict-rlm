from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from shutil import copyfile

input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
front = wb["Front"]
data = wb["Data"]

print("Original sheetnames:", original_sheetnames)
print("Target range: Front!B2:N12")
print("Current sample target cells before writing:")
for coord in ["B2", "C2", "D2", "B3", "C3", "D3", "N12"]:
    print(coord, "=", front[coord].value)

# Use a bounded future-proof range rather than full-column refs.
range_end = max(1000, data.max_row + 200)
a_rng = f"Data!$A$1:$A${range_end}"
f_rng = f"Data!$F$1:$F${range_end}"

# Write formulas into the exact target grid.
for r in range(2, front.max_row + 1):
    for c in range(2, front.max_column + 1):
        date_ref = f"{get_column_letter(c)}$1"
        agent_ref = f"$A{r}"
        formula = (
            f'=IF(COUNTIF({a_rng},{date_ref})=0,"",'
            f'IF(SUMPRODUCT(({a_rng}={agent_ref})*'
            f'(LOOKUP(ROW({a_rng}),ROW({a_rng})/(ISNUMBER({a_rng})),{a_rng})={date_ref}))=0,"",'
            f'SUMPRODUCT(({a_rng}={agent_ref})*'
            f'(LOOKUP(ROW({a_rng}),ROW({a_rng})/(ISNUMBER({a_rng})),{a_rng})={date_ref})*'
            f'({f_rng}))))'
        )
        front.cell(r, c).value = formula

wb.save(output_path)
print("Saved workbook to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# After recalc, LibreOffice may rename sheets; restore original names if needed.
wb_post = load_workbook(output_path)
print("Sheetnames after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for i, expected_name in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = expected_name
    wb_post.save(output_path)
    print("Restored sheetnames to:", original_sheetnames)

# Reload for verification
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
front_formula = wb_formula["Front"]
front_values = wb_values["Front"]

print("\nVerification: sample formulas and values")
for coord in ["B2", "C2", "D2", "B3", "C3", "D3", "B9", "C9", "N12"]:
    print(
        coord,
        "formula=", front_formula[coord].value,
        "value=", front_values[coord].value
    )

print("\nVerification: full target value grid Front!B2:N12")
for r in range(2, front_values.max_row + 1):
    row_vals = [front_values.cell(r, c).value for c in range(2, front_values.max_column + 1)]
    print(f"Row {r} ({front_values.cell(r,1).value}): {row_vals}")

# Basic sanity checks
issues = []

# Existing dates in B and C should produce values (including 0 where legitimate)
for r in range(2, front_values.max_row + 1):
    for c in [2, 3]:
        v = front_values.cell(r, c).value
        if v is None:
            issues.append(f"{get_column_letter(c)}{r} unexpectedly blank for existing date")

# Dates D:N do not currently exist in Data, so should be blank/None
for r in range(2, front_values.max_row + 1):
    for c in range(4, front_values.max_column + 1):
        v = front_values.cell(r, c).value
        if v not in (None, ""):
            issues.append(f"{get_column_letter(c)}{r} expected blank for missing date, found {v}")

print("\nSanity check issues:", issues if issues else "None")

final_output_spreadsheet = output_path
```
