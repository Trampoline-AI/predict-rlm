import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input:", path, os.path.exists(path))

wb = load_workbook(path)
orig_sheetnames = wb.sheetnames
print("Sheet names:", orig_sheetnames)

def sheet_nonempty_bounds(ws):
    max_r, max_c = ws.max_row, ws.max_column
    last_r = 0
    last_c = 0
    for r in ws.iter_rows():
        row_has = False
        for cell in r:
            if cell.value is not None:
                row_has = True
                if cell.column > last_c:
                    last_c = cell.column
        if row_has:
            last_r = cell.row
    return last_r, last_c

def row_values(ws, r, upto=None):
    upto = upto or ws.max_column
    vals = []
    for c in range(1, upto+1):
        vals.append(ws.cell(r, c).value)
    return vals

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    last_r, last_c = sheet_nonempty_bounds(ws)
    print("ws.max_row/max_col:", ws.max_row, ws.max_column, "nonempty bounds:", last_r, last_c)
    headers1 = row_values(ws, 1, min(max(last_c,1), 20))
    headers2 = row_values(ws, 2, min(max(last_c,1), 20)) if last_r >= 2 else []
    print("Row1:", headers1)
    if headers2:
        print("Row2:", headers2)
    sample_top = list(range(1, min(last_r, 10)+1))
    sample_bottom = list(range(max(1, last_r-4), last_r+1)) if last_r else []
    printed = set()
    print("-- Top sample rows --")
    for r in sample_top:
        printed.add(r)
        print(r, row_values(ws, r, min(max(last_c,1), 20)))
    print("-- Bottom sample rows --")
    for r in sample_bottom:
        if r not in printed:
            print(r, row_values(ws, r, min(max(last_c,1), 20)))
    # print formulas in used range
    formulas = []
    for r in range(1, min(last_r, 50)+1):
        for c in range(1, min(last_c, 20)+1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((ws.cell(r,c).coordinate, v))
    print("Formula cells in first 50x20 region:", formulas[:20], "count:", len(formulas))
