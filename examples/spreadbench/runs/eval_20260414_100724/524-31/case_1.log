from openpyxl import load_workbook
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["Exp-DB"]

# Build mapping from A:B
mapping = []
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a not in (None, "") and b not in (None, ""):
        mapping.append((r, str(a), str(b)))

print("Full mapping table (A:B):")
for r, pat, cat in mapping:
    print(f"{r:>2}: {pat!r} -> {cat!r}")

# Match helper: case-insensitive substring search, prefer longest pattern
def find_matches(desc):
    if desc in (None, ""):
        return []
    desc_u = str(desc).upper()
    hits = []
    for r, pat, cat in mapping:
        if pat.upper() in desc_u:
            hits.append((r, pat, cat, len(pat)))
    hits.sort(key=lambda x: (-x[3], x[0]))  # longest pattern first, then first mapping row
    return hits

results = []
unmatched = []
ambiguous = []

for r in range(1, ws.max_row + 1):
    desc = ws.cell(r, 4).value
    if desc not in (None, ""):
        hits = find_matches(desc)
        chosen = hits[0] if hits else None
        results.append((r, desc, chosen, hits[:5]))
        if not hits:
            unmatched.append((r, desc))
        elif len(hits) > 1:
            ambiguous.append((r, desc, hits[:5]))

print("\nFirst 15 computed matches:")
for r, desc, chosen, hits in results[:15]:
    print(f"Row {r}: D={desc!r}")
    print(f"   chosen={chosen}")
    print(f"   hits={hits}")

print("\nLast 10 computed matches:")
for r, desc, chosen, hits in results[-10:]:
    print(f"Row {r}: D={desc!r}")
    print(f"   chosen={chosen}")
    print(f"   hits={hits}")

print("\nUnmatched rows:", len(unmatched))
for item in unmatched:
    print(item)

print("\nAmbiguous rows:", len(ambiguous))
for item in ambiguous[:20]:
    print(item)

# If the matches look sensible, write them to E:F:G.
# E and G currently contain broken formulas, so replace them with resolved values.
for r, desc, chosen, hits in results:
    value = chosen[2] if chosen else None
    ws.cell(r, 5).value = value   # E
    ws.cell(r, 6).value = value   # F
    ws.cell(r, 7).value = value   # G

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved preliminary output to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload and verify sheet names and target cells
wb2 = load_workbook(out_path, data_only=False)
print("Post-recalc sheet names:", wb2.sheetnames)
if wb2.sheetnames != ["Exp-DB"]:
    # rename back if needed
    wb_fix = load_workbook(out_path)
    if len(wb_fix.worksheets) == 1:
        wb_fix.worksheets[0].title = "Exp-DB"
        wb_fix.save(out_path)
        print("Renamed sheet back to Exp-DB")
    wb2 = load_workbook(out_path, data_only=False)

wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Exp-DB"]

print("\nVerification of target cells E:F:G for first 12 rows and last 5 rows:")
rows_to_check = list(range(1, 13)) + list(range(ws.max_row - 4, ws.max_row + 1))
seen = set()
for r in rows_to_check:
    if r < 1 or r > ws.max_row or r in seen:
        continue
    seen.add(r)
    print(
        f"Row {r}: D={wsv.cell(r,4).value!r} | "
