from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, textwrap

print("INPUT:", input_spreadsheet)
print("INSTRUCTION:\n", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("SHEETS:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows))
    
    # Print first 10 rows and last 5 nonempty rows
    first_rows = nonempty_rows[:10]
    last_rows = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
    printed = set()
    for r in first_rows + last_rows:
        if r in printed:
            continue
        printed.add(r)
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}: {vals}")
    
    # Header candidates: first 3 nonempty rows
    print("Header candidates:")
    for r in nonempty_rows[:3]:
        vals = row_values(ws, r, ws.max_column)
        headers = {get_column_letter(i+1): vals[i] for i in range(len(vals))}
        print(f"  Row {r}: {headers}")

# Save objects for next iteration
inspected_wb = wb
