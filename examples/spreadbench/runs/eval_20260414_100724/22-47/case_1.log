from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string
import os
from pathlib import Path

# --- Load and inspect exact target/source again before modifying ---
src_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src_path))

wb = load_workbook(src_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["sheet1"]

print("Original sheet names:", orig_sheetnames)
print("Target columns by instruction/layout:")
for col in ["A","B","C","F","G","H","J"]:
    idx = column_index_from_string(col)
    print(f"  {col} -> index {idx}, header row 1 value = {ws.cell(1, idx).value!r}")

print("\nCurrent target area preview F:H and helper J (rows 1:15):")
for r in range(1, 16):
    print(r, {
        "F": ws.cell(r, 6).value,
        "G": ws.cell(r, 7).value,
        "H": ws.cell(r, 8).value,
        "J": ws.cell(r, 10).value,
    })

print("\nCurrent tail preview around stale output rows:")
for r in range(max(1, ws.max_row - 5), ws.max_row + 1):
    print(r, {
        "F": ws.cell(r, 6).value,
        "G": ws.cell(r, 7).value,
        "H": ws.cell(r, 8).value,
        "J": ws.cell(r, 10).value,
    })

# --- Extract source rows from repeated ranges in A:C ---
def norm_text(v):
    if v is None:
        return ""
    return str(v).strip()

def norm_key(v):
    return norm_text(v).upper()

source_rows = []
header_rows = []
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value

    # skip fully empty rows
    if all(v in (None, "") for v in (a, b, c)):
        continue

    # detect repeated headers
    if norm_key(a) == "ITEM" and norm_key(b) == "NAME" and norm_key(c) == "REF":
        header_rows.append(r)
        continue

    # valid data rows should have at least name/ref populated
    if norm_text(b) == "" or c in (None, ""):
        continue

    source_rows.append({
        "source_row": r,
        "item": a,
        "name": norm_text(b),
        "ref": c,
    })

print("\nDetected repeated header rows in A:C:", header_rows)
print("Extracted source row count:", len(source_rows))
print("Extracted source rows:")
for rec in source_rows:
    print(rec)

# --- Deduplicate by (B, C), preserve first occurrence ---
seen = set()
dedup_rows = []
for rec in source_rows:
    key = (norm_key(rec["name"]), rec["ref"])
    if key in seen:
        continue
    seen.add(key)
    dedup_rows.append(rec)

print("\nDeduplicated row count:", len(dedup_rows))
print("Deduplicated rows:")
for rec in dedup_rows:
    print(rec)

# --- Extract helper names from J, skipping header and duplicates ---
helper_names_raw = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 10).value
    txt = norm_text(v)
    if txt == "" or norm_key(txt) == "LIST":
        continue
    helper_names_raw.append(txt)

helper_names = []
helper_seen = set()
for name in helper_names_raw:
    k = norm_key(name)
    if k not in helper_seen:
        helper_seen.add(k)
        helper_names.append(name)

print("\nHelper names raw:", helper_names_raw)
print("Helper names deduped, preserved order:", helper_names)

# --- Build final output order ---
if helper_names:
    ordered = []
    added = set()

    # helper-listed names first, preserving source order within each name group
    helper_keys = [norm_key(x) for x in helper_names]
    for hk in helper_keys:
        for rec in dedup_rows:
            rec_key = (norm_key(rec["name"]), rec["ref"])
            if norm_key(rec["name"]) == hk and rec_key not in added:
                ordered.append(rec)
                added.add(rec_key)

    # remaining rows in original source order
    for rec in dedup_rows:
        rec_key = (norm_key(rec["name"]), rec["ref"])
        if rec_key not in added:
            ordered.append(rec)
            added.add(rec_key)

    ordering_mode = "helper-priority"
else:
    # alphabetical by NAME only, preserving original order among same-name ties
    ordered = sorted(
        dedup_rows,
        key=lambda rec: (norm_key(rec["name"]), rec["source_row"])
    )
    ordering_mode = "alphabetical-fallback"

print("\nOrdering mode used:", ordering_mode)
print("Final ordered output:")
for i, rec in enumerate(ordered, start=1):
    print(i, rec)

# --- Write output to F:H ---
# Preserve existing headers if present, but ensure correct headers
ws["F1"] = "ITEM"
ws["G1"] = "NAME"
ws["H1"] = "REF"

# Clear old output area values from rows 2:max_row
for r in range(2, ws.max_row + 1):
    ws.cell(r, 6).value = None
    ws.cell(r, 7).value = None
    ws.cell(r, 8).value = None

# Write fresh output
for i, rec in enumerate(ordered, start=2):
    ws.cell(i, 6).value = i - 1
    ws.cell(i, 7).value = rec["name"]
    ws.cell(i, 8).value = rec["ref"]

wb.save(out_path)
print("\nSaved workbook to:", out_path)

# --- Recalculate ---
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# --- Restore original sheet names if LibreOffice changed them ---
wb_after = load_workbook(out_path)
current_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != orig_sheetnames and len(current_names) == len(orig_sheetnames):
    for old_name, desired_name in zip(current_names, orig_sheetnames):
        if old_name != desired_name:
            wb_after[old_name].title = desired_name
    wb_after.save(out_path)
    print("Renamed sheets back to original:", orig_sheetnames)

# --- Verify output ---
verify_wb = load_workbook(out_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb["sheet1"]

print("\nVerified target range F:H:")
for r in range(1, len(ordered) + 3):
    print(r, [vws.cell(r, c).value for c in range(6, 9)])

print("\nCheck for blanks/errors in written rows:")
issues = []
for r in range(2, len(ordered) + 2):
    f = vws.cell(r, 6).value
    g = vws.cell(r, 7).value
    h = vws.cell(r, 8).value
    if f in (None, "") or g in (None, "") or h in (None, ""):
        issues.append((r, f, g, h))
print("Issues:", issues)

print("\nTail check around previous stale rows 190:195:")
for r in range(190, min(195, vws.max_row) + 1):
    print(r, [vws.cell(r, c).value for c in range(6, 9)])

final_output_spreadsheet = out_path
print("\nPrepared output path:", final_output_spreadsheet)
