```repl
import os, shutil
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load original workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
res = wb["Result"]
mr = wb["Master-RM"]

print("Original sheet names:", original_sheetnames)
print("Pre-write target cells:")
for coord in ["G10","H10","I10","J10","K10","L10"]:
    print(coord, "->", repr(res[coord].value))

# Build a robust formula pattern:
# - Match item in row 2 against Master-RM column A
# - Choose return column based on row 3 month
formula_template = (
    '=IFERROR('
    'IF({col}$3="Shrawan",'
    'INDEX(\'Master-RM\'!$I$1:$I$22,MATCH({col}$2,\'Master-RM\'!$A$1:$A$22,0)),'
    'IF({col}$3="Bhadra",'
    'INDEX(\'Master-RM\'!$K$1:$K$22,MATCH({col}$2,\'Master-RM\'!$A$1:$A$22,0)),'
    '""'
    ')'
    '),'
    '""'
    ')'
)

for col in ["G", "H", "I", "J", "K", "L"]:
    res[f"{col}10"] = formula_template.format(col=col)

# Save once before recalc
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# After recalc, reload and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames:
    # rename by position back to originals
    for ws, original_name in zip(wb_after.worksheets, original_sheetnames):
        ws.title = original_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verification: formulas
wb_formula = load_workbook(outfile, data_only=False)
res_formula = wb_formula["Result"]
print("\nFinal formulas in Result!G10:L10")
for coord in ["G10","H10","I10","J10","K10","L10"]:
    print(coord, "=", repr(res_formula[coord].value))

# Verification: cached/calculated values
wb_values = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_values.sheetnames)
res_values = wb_values["Result"]

print("\nCalculated values in Result!G10:L10")
for coord in ["G10","H10","I10","J10","K10","L10"]:
    print(coord, "=", res_values[coord].value)

# Also compute expected values directly from Master-RM for sanity
mr_values = wb_values["Master-RM"]
item_to_row = {}
for r in range(1, mr_values.max_row + 1):
    a = mr_values[f"A{r}"].value
    if a:
        item_to_row[str(a).strip()] = r

expected = {}
for coord in ["G10","H10","I10","J10","K10","L10"]:
    col = coord[0]
    item = res_values[f"{col}2"].value
    month = res_values[f"{col}3"].value
    row = item_to_row.get(item)
    val = None
    if row:
        if month == "Shrawan":
            val = mr_values[f"I{row}"].value
        elif month == "Bhadra":
            val = mr_values[f"K{row}"].value
    expected[coord] = val

print("\nExpected values by direct lookup:")
for coord, val in expected.items():
    print(coord, "expected", val, "actual", res_values[coord].value)

output_spreadsheet = outfile
