            if v not in (None, ""):
                selected_values.add(str(v).strip())

    mismatches = []
    results = []
    for r in range(6, 32):
        item = ws1v.cell(r, 2).value
        actual = ws1v.cell(r, 3).value
        formula = ws1f.cell(r, 3).value
        expected = item if str(item).strip() in selected_values else "New"
        results.append((r, item, actual, expected, formula))
        if actual is None or str(actual).strip() != str(expected).strip():
            mismatches.append((r, item, actual, expected, formula))

    return {
        "selected_date": selected_date,
        "date_col": date_col,
        "date_col_letter": get_column_letter(date_col) if date_col else None,
        "results": results,
        "mismatches": mismatches,
        "sheetnames": wbv.sheetnames,
    }

best_name = None
best_summary = None

for name, formula_template in candidates.items():
    wb = load_workbook(input_path)
    ws1 = wb["Sheet1"]

    for r in range(6, ws1.max_row + 1):
        item = ws1.cell(r, 2).value
