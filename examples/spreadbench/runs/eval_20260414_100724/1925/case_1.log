def restore_sheetnames(path, original_names):
    wb = load_workbook(path)
    changed = wb.sheetnames != original_names
    if changed:
        for ws, old_name in zip(wb.worksheets, original_names):
            ws.title = old_name
        wb.save(path)
    return changed

def verify_file(path):
    wbv = load_workbook(path, data_only=True)
    wbf = load_workbook(path, data_only=False)
    ws1v = wbv["Sheet1"]
    ws1f = wbf["Sheet1"]
    ws2v = wbv["Sheet2"]

    selected_date = ws1v["C5"].value
    date_col = None
    for c in range(3, ws2v.max_column + 1):
