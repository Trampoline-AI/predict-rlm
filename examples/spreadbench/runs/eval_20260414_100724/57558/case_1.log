from openpyxl import load_workbook
from datetime import datetime

wb = load_workbook(input_spreadsheet)
ws_rates = wb["RateHurdles"]
ws_dep = wb["Deposits"]

print("Target cells and current values:")
for r in range(2, ws_dep.max_row + 1):
    print(f"A{r}={ws_dep[f'A{r}'].value}, B{r}={ws_dep[f'B{r}'].value}, C{r}={ws_dep[f'C{r}'].value}, D{r}={ws_dep[f'D{r}'].value}")

# Build rate rows for inspection
rate_rows = []
for r in range(2, ws_rates.max_row + 1):
    row = {
        "row": r,
        "start": ws_rates.cell(r, 1).value,
        "end": ws_rates.cell(r, 2).value,
        "type": ws_rates.cell(r, 3).value,
        "salesperson": ws_rates.cell(r, 4).value,
        "rate": ws_rates.cell(r, 5).value,
    }
    if any(v is not None for v in row.values()):
        rate_rows.append(row)

print("\nMatching rate-table rows for each deposit row:")
for r in range(2, ws_dep.max_row + 1):
    dep_type = ws_dep.cell(r, 2).value
    dep_sales = ws_dep.cell(r, 3).value
    dep_date = ws_dep.cell(r, 4).value
    matches = []
    for rr in rate_rows:
        ok = (
            rr["type"] == dep_type and
            rr["salesperson"] == dep_sales and
            rr["start"] is not None and rr["end"] is not None and dep_date is not None and
            rr["start"] <= dep_date <= rr["end"]
        )
        if ok:
            matches.append(rr)
    print(f"Deposits row {r}: type={dep_type!r}, salesperson={dep_sales!r}, date={dep_date}")
    print(f"  Matches: {len(matches)}")
    for m in matches:
        print(f"   RateHurdles row {m['row']}: start={m['start'].date()}, end={m['end'].date()}, rate={m['rate']}")
    if matches:
        print(f"  First match rate (INDEX/MATCH behavior): {matches[0]['rate']}")
        print(f"  Last match rate (LOOKUP-style behavior): {matches[-1]['rate']}")
        print(f"  Sum of matched rates (SUMPRODUCT behavior): {sum(m['rate'] for m in matches)}")
