import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws_dep = wb["Deposits"]

# Write actual Excel/LibreOffice formulas into the existing target cells A2:A{max_row}
# Using bounded ranges based on the observed lookup table extent.
for r in range(2, ws_dep.max_row + 1):
    if any(ws_dep.cell(r, c).value is not None for c in range(2, 5)):  # only rows with deposit data
        formula = (
            f'=IFERROR(INDEX(RateHurdles!$E$2:$E$17,'
            f'MATCH(1,'
            f'(RateHurdles!$D$2:$D$17=C{r})*'
            f'(RateHurdles!$C$2:$C$17=B{r})*'
            f'(D{r}>=RateHurdles!$A$2:$A$17)*'
            f'(D{r}<=RateHurdles!$B$2:$B$17),0)'
            f'),"")'
        )
        print(f"Writing A{r}: {formula}")
        ws_dep.cell(r, 1).value = formula

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate formulas
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc; restore original sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # rename by position back to originals
    for i, expected in enumerate(orig_sheet_names):
        wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Deposits"]
print("Stored formulas in target cells:")
for r in range(2, wsf.max_row + 1):
    print(f"A{r} formula:", wsf[f"A{r}"].value)

# Verify calculated results
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Deposits"]
print("Calculated values in target cells:")
for r in range(2, wsv.max_row + 1):
    print(f"A{r} value:", wsv[f'A{r}'].value, "| inputs:", wsv[f'B{r}'].value, wsv[f'C{r}'].value, wsv[f'D{r}'].value)

output_spreadsheet = outfile
