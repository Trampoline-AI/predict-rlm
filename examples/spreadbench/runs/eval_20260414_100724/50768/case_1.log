```repl
import os
from collections import defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for precise inspection
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", orig_sheetnames)
print("Exact source area A3:C9:")
for r in range(3, 10):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

print("\nExact target/matrix area D12:H16 BEFORE writing:")
for r in range(12, 17):
    vals = [ws.cell(r, c).value for c in range(4, 9)]
    coords = [f"{get_column_letter(c)}{r}={vals[i]}" for i, c in enumerate(range(4, 9))]
    print(coords)

# Identify source rows dynamically from header row 3
headers = [ws.cell(3, c).value for c in range(1, ws.max_column + 1)]
print("\nHeader row 3:", headers)

id_col = None
impact_col = None
likelihood_col = None
for c, h in enumerate(headers, start=1):
    if h == "ID":
        id_col = c
    elif h == "Impact":
        impact_col = c
    elif h in ("Liklihood", "Likelihood"):
        likelihood_col = c

print("Detected columns:",
      "ID", id_col, "Impact", impact_col, "Likelihood", likelihood_col)

# Collect source data rows until first fully blank stretch / actual max row scan
source_rows = []
for r in range(4, ws.max_row + 1):
    rid = ws.cell(r, id_col).value if id_col else None
    imp = ws.cell(r, impact_col).value if impact_col else None
    lik = ws.cell(r, likelihood_col).value if likelihood_col else None
    if rid is None and imp is None and lik is None:
        continue
    # Only actual risk table rows: require all three present and numeric-like
    if rid is not None and imp is not None and lik is not None:
        source_rows.append((r, rid, imp, lik))

print("\nDetected source data rows:")
for item in source_rows:
    print(item)

# Build grouped mapping by (impact, likelihood)
groups = defaultdict(list)
for r, rid, imp, lik in source_rows:
    groups[(int(imp), int(lik))].append(str(rid))

print("\nGrouped IDs by (Impact, Likelihood):")
for key in sorted(groups):
    print(key, groups[key])

# Verify exact target cells from row/column labels already present
impact_labels = {}
for r in range(12, 15):
    impact_labels[r] = ws.cell(r, 5).value  # E column
likelihood_labels = {}
for c in range(6, 9):
    likelihood_labels[c] = ws.cell(15, c).value  # row 15

print("\nMatrix axis labels:")
print("Impact labels by row:", impact_labels)
print("Likelihood labels by column:", likelihood_labels)

# Write values into the existing matrix cells F12:H14
for r in range(12, 15):
    imp = ws.cell(r, 5).value
    for c in range(6, 9):
        lik = ws.cell(15, c).value
        cell = ws.cell(r, c)
        existing = cell.value
        new_val = ", ".join(groups.get((int(imp), int(lik)), []))
        print(f"Writing {cell.coordinate}: existing={existing!r}, impact={imp}, likelihood={lik}, new={new_val!r}")
        cell.value = new_val

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc reload:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    for i, old_name in enumerate(orig_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheetnames[0]]

print("\nExact target/matrix area D12:H16 AFTER writing/recalc:")
for r in range(12, 17):
    vals = [wsv.cell(r, c).value for c in range(4, 9)]
    coords = [f"{get_column_letter(c)}{r}={vals[i]!r}" for i, c in enumerate(range(4, 9))]
    print(coords)

target_values = {}
for r in range(12, 15):
    for c in range(6, 9):
        target_values[f"{get_column_letter(c)}{r}"] = wsv.cell(r, c).value

print("\nFinal target cells F12:H14:")
for k in sorted(target_values):
    print(k, "->", target_values[k])

final_output_path = output_path
