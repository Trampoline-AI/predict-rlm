import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(input_path), input_path)

wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
print("Sheet names:", orig_sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

def nonempty_bounds(ws):
    min_row = None
    max_row = 0
    min_col = None
    max_col = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                if min_row is None or cell.row < min_row:
                    min_row = cell.row
                if min_col is None or cell.column < min_col:
                    min_col = cell.column
                max_row = max(max_row, cell.row)
                max_col = max(max_col, cell.column)
    return min_row, max_row, min_col, max_col

sheet_info = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    min_row, max_row, min_col, max_col = nonempty_bounds(ws)
    sheet_info[sname] = (min_row, max_row, min_col, max_col)
    print(f"\n=== SHEET: {sname} ===")
    print("ws.max_row/max_column:", ws.max_row, ws.max_column)
    print("nonempty bounds:", (min_row, max_row, min_col, max_col))
    if min_row is None:
        print("Sheet is empty")
        continue
    
    # Print first 12 rows in used range
    display_cols = min(max_col or ws.max_column, 12)
    header_letters = [get_column_letter(c) for c in range(1, display_cols+1)]
    print("Columns shown:", header_letters)
    print("-- First rows --")
    for r in range(1, min(max_row, 12) + 1):
        vals = row_values(ws, r, display_cols)
        print(f"R{r}: {vals}")
    
    print("-- Last rows --")
    start_last = max(1, max_row - 4)
    for r in range(start_last, max_row + 1):
        vals = row_values(ws, r, display_cols)
        print(f"R{r}: {vals}")
    
    # Print formulas found in first 30 rows and first 15 cols
    formulas = []
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, min(ws.max_column, 15) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first 30x15 area:", formulas[:20], "count=", len(formulas))
    
    # Compact used-area preview (up to 20 rows x 12 cols)
    print("-- Compact grid preview --")
    for r in range(1, min(max_row, 20) + 1):
        vals = []
        for c in range(1, display_cols + 1):
            v = ws.cell(r, c).value
            vals.append("" if v is None else str(v))
        print(f"{r:>3} | " + " | ".join(vals))

print("\nStored sheet_info for later:", sheet_info)
