```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheet names:", orig_sheetnames)
print("Current F2:", ws["F2"].value)
print("Current target formulas/values before writing:")
for r in range(2, 14):
    print(r, [ws.cell(r, c).value for c in range(9, 13)])

# Write formulas into I2:L13
# Logic: return nth row from A2:D15 where either:
#   - A row equals F2, or
#   - A row is "Power (kW)" and next row's A equals F2
# This includes the section headers plus all matching rows.
for r in range(2, 14):
    nth = f"ROWS($I$2:I{r})"
    for c in range(9, 13):  # I:L
        col_index = c - 8   # I->1, J->2, K->3, L->4
        formula = (
            '=IFERROR('
            'INDEX($A$2:$D$15,'
            '_xlfn.AGGREGATE(15,6,'
            '(ROW($A$2:$A$15)-ROW($A$2)+1)/'
            '((($A$2:$A$15=$F$2)+(($A$2:$A$15="Power (kW)")*($A$3:$A$16=$F$2)))),'
            f'{nth}),'
            f'{col_index}'
            '),'
            '""'
            ')'
        )
        ws.cell(r, c).value = formula

# Save first
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Re-open after recalc and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename back in order
    for i, expected in enumerate(orig_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas exist
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula[orig_sheetnames[0]]
print("\nWritten formulas in I2:L6:")
for r in range(2, 7):
    print(r, [wsf.cell(r, c).value for c in range(9, 13)])

# Verify evaluated values
wb_val = load_workbook(outfile, data_only=True)
wsv = wb_val[orig_sheetnames[0]]
print("\nEvaluated target range I2:L13:")
for r in range(2, 14):
    vals = [wsv.cell(r, c).value for c in range(9, 13)]
    print(f"Row {r}:", vals)

# Also print compact check of nonblank rows in target
nonblank = []
for r in range(2, 14):
    vals = [wsv.cell(r, c).value for c in range(9, 13)]
    if any(v not in (None, "") for v in vals):
        nonblank.append((r, vals))
print("\nNonblank output rows:", nonblank[:20])

output_spreadsheet = outfile
