import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheet names:", orig_sheet_names)

inspection = {}

for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    inspection[ws.title] = {"max_row": max_row, "max_col": max_col, "headers": headers}
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers row 1:", headers)
    
    # print first 10 rows for cols A:J or to max_col if smaller
    show_cols = min(10, max_col)
    print("First rows (A:{}):".format(get_column_letter(show_cols)))
    for r in range(1, min(max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, show_cols + 1)]
        print(r, vals)
    
    # last 5 rows
    print("Last rows (A:{}):".format(get_column_letter(show_cols)))
    start_last = max(1, max_row - 4)
    for r in range(start_last, max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, show_cols + 1)]
        print(r, vals)
    
    # inspect column J specifically if present
    if max_col >= 10:
        print("Column J sample values/formulas:")
        for r in list(range(1, min(max_row, 10) + 1)) + list(range(max(1, max_row - 4), max_row + 1)):
            v = ws.cell(r, 10).value
            print(f"J{r}={v!r}")

# Keep workbook/inspection in memory for next iteration
print("\nInspection summary keys:", list(inspection.keys()))
