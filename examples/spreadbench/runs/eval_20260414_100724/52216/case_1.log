```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))
os.makedirs(os.path.dirname(output_path), exist_ok=True)

# Start clean from original input
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["INPUTS"]
src = wb["Sheet2"]

print("Original sheet names:", original_sheetnames)
print("Target cells before rewrite:")
for c in range(3, 8):
    coord = f"{get_column_letter(c)}16"
    print(coord, ws[coord].value)

# Confirm exact source lookup row(s)
selected_region = ws["A14"].value
expense = ws["A16"].value
print("Selected region:", selected_region)
print("Expense:", expense)

expected = None
for r in range(3, src.max_row + 1):
    if src.cell(r, 1).value == selected_region and src.cell(r, 2).value == expense:
        expected = [src.cell(r, c).value for c in range(3, 8)]
        print("Matched Sheet2 row:", r, expected)
        break

# Robust formula:
# row index inside Sheet2!C3:G20 is computed by SUMPRODUCT over the unique matching row
# column index is matched from year header C$3:G$3 against Sheet2 C1:G1
for c in range(3, 8):
    col = get_column_letter(c)
    formula = (
        f'=IFERROR('
        f'INDEX(Sheet2!$C$3:$G$20,'
        f'SUMPRODUCT((Sheet2!$A$3:$A$20=$A$14)*(Sheet2!$B$3:$B$20=$A16)*'
        f'(ROW(Sheet2!$A$3:$A$20)-ROW(Sheet2!$A$3)+1)),'
        f'MATCH({col}$3,Sheet2!$C$1:$G$1,0)'
        f'),0)'
    )
    ws.cell(16, c).value = formula

print("\nNew formulas written:")
for c in range(3, 8):
    coord = f"{get_column_letter(c)}16"
    print(coord, ws[coord].value)

wb.save(output_path)
print("\nSaved:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Restore sheet names if needed
wb_post = load_workbook(output_path)
if wb_post.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_post.sheetnames)
    for i, name in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = name
    wb_post.save(output_path)
    print("Restored sheet names:", original_sheetnames)
else:
    print("Sheet names preserved.")

# Verify target values after recalculation
wb_vals = load_workbook(output_path, data_only=True)
wsv = wb_vals["INPUTS"]

actual = []
print("\nVerified target cells (data_only):")
for c in range(3, 8):
    coord = f"{get_column_letter(c)}16"
    val = wsv[coord].value
    actual.append(val)
    print(coord, "=", val)

print("Expected:", expected)
print("Actual:  ", actual)

# Also verify exact target row/columns and neighboring labels
print("\nContext verification:")
for coord in ["A14", "A15", "A16", "C3", "D3", "E3", "F3", "G3"]:
    print(coord, "=", wsv[coord].value)

# Sanity check
ok = (expected == actual) and all(v is not None for v in actual)
print("\nMatch status:", ok)

final_output_spreadsheet = output_path
```
