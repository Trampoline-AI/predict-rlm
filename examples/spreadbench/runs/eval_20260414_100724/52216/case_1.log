import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook and inspect exact target/source details again
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["INPUTS"]
src = wb["Sheet2"]

print("Original sheet names:", original_sheetnames)
print("Current selector/input cells:")
for coord in ["A14", "A16", "C3", "D3", "E3", "F3", "G3"]:
    print(coord, "=", ws[coord].value)

print("\nExisting formulas in C16:G16 before change:")
for c in range(3, 8):
    coord = f"{get_column_letter(c)}16"
    print(coord, "=", ws[coord].value)

# Build expected values from source table for sanity check
source_rows = []
for r in range(3, src.max_row + 1):
    region = src.cell(r, 1).value
    expense = src.cell(r, 2).value
    vals = [src.cell(r, c).value for c in range(3, 8)]
    source_rows.append((r, region, expense, vals))

print("\nMatching source rows for Electricity:")
for r, region, expense, vals in source_rows:
    if expense == "Electricity":
        print(f"Sheet2 row {r}: region={region!r}, expense={expense!r}, years1to5={vals}")

# Correct dynamic formula:
# - matches selected region in $A$14
# - matches expense label in $A16
# - picks correct year column by matching C$3 / D$3 / ... against Sheet2 headers C1:G1
# This works when copied across C:G.
for c in range(3, 8):  # C:G
    col_letter = get_column_letter(c)
    formula = (
        f'=IFERROR('
        f'SUMPRODUCT('
        f'(Sheet2!$A$3:$A$20=$A$14)*'
        f'(Sheet2!$B$3:$B$20=$A16)*'
        f'INDEX(Sheet2!$C$3:$G$20,0,MATCH({col_letter}$3,Sheet2!$C$1:$G$1,0))'
        f'),0)'
    )
    ws.cell(16, c).value = formula

print("\nNew formulas written to C16:G16:")
for c in range(3, 8):
