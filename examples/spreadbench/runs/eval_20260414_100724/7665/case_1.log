```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

# Load and inspect exact source/target again before modifying
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Find actual last non-empty row in column H, ignoring header row 1
last_h = 1
for r in range(ws.max_row, 1, -1):
    v = ws[f"H{r}"].value
    if v not in (None, ""):
        last_h = r
        break

source_vals = [ws[f"H{r}"].value for r in range(2, last_h + 1) if ws[f"H{r}"].value not in (None, "")]
unique_sorted = sorted(set(source_vals))

print("Original sheet names:", orig_sheetnames)
print("Column H non-empty data rows: 2 to", last_h)
print("Source values:", source_vals)
print("Unique sorted source values:", unique_sorted)

print("Current target cells before writing:")
for c in range(17, 23):  # Q:V
    cell = ws.cell(2, c)
    print(cell.coordinate, "value=", cell.value)

# Write formulas into Q2:V2
source_range = f"$H$2:$H${last_h}"
ws["Q2"] = f"=MIN({source_range})"
for c in range(18, 23):  # R:V
    prev_col = get_column_letter(c - 1)
    coord = f"{get_column_letter(c)}2"
    ws[coord] = f'=IF({prev_col}2="","",IFERROR(SMALL({source_range},COUNTIF({source_range},"<="&{prev_col}2)+1),""))'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore sheet names if changed
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring to", orig_sheetnames)
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Final sheet names:", wb_check.sheetnames)

# Verify formulas
ws_formula = wb_check[orig_sheetnames[0]]
print("Target formulas after save:")
for c in range(17, 23):
    cell = ws_formula.cell(2, c)
    print(cell.coordinate, "formula=", cell.value)

# Verify cached values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]
verified_vals = [ws_values.cell(2, c).value for c in range(17, 23)]
print("Target cached values Q2:V2 after recalc:", verified_vals)

# Additional sanity check against expected unique sorted values
print("Expected unique sorted values:", unique_sorted)
print("Match expected?:", verified_vals == unique_sorted)
