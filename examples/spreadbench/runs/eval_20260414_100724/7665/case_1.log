print("Temp recalculated cached values Q2:V2:", vals)

# Expected values from source data
src_vals = [ws[f"H{r}"].value for r in range(2, last_h + 1) if ws[f"H{r}"].value not in (None, "")]
expected = sorted(set(src_vals))
print("Expected unique sorted:", expected)
print("Verification passed?", vals == expected)

final_output_spreadsheet = outfile
print("Ready to submit:", final_output_spreadsheet)
