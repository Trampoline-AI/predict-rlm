print("\nXML snippets from final workbook:")
for coord in ["Q2","R2","S2","T2","U2","V2"]:
    m = re.search(rf'<c[^>]*r="{coord}"[^>]*>.*?</c>', xml, re.S)
    snippet = m.group(0) if m else "NOT FOUND"
    print(coord, snippet[:220])

# Verify formulas on a temporary recalculated copy
