ws = wb[orig_sheetnames[0]]

# Determine last non-empty row in H
last_h = 1
for r in range(ws.max_row, 1, -1):
    v = ws[f"H{r}"].value
    if v not in (None, ""):
        last_h = r
        break

source_range = f"$H$2:$H${last_h}"

# Exact formula pattern across Q2:V2
ws["Q2"] = f"=MIN({source_range})"
for c in range(18, 23):  # R:V
    prev_col = get_column_letter(c - 1)
    coord = f"{get_column_letter(c)}2"
    ws[coord] = f'=IF({prev_col}2="","",IFERROR(SMALL({source_range},COUNTIF({source_range},"<="&{prev_col}2)+1),""))'

wb.save(outfile)
print("Rewrote final workbook with formulas:", outfile)

# Verify final workbook truly contains formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
print("Final workbook cell values/types:")
for coord in ["Q2","R2","S2","T2","U2","V2"]:
    cell = ws_formula[coord]
    print(coord, cell.value, cell.data_type)

with zipfile.ZipFile(outfile, "r") as z:
