from openpyxl import load_workbook
from openpyxl.styles import Alignment
from collections import Counter
import os

# Load workbook again for modification
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Determine real data extent and inspect ITEM values in column B excluding header
item_rows = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 2).value
    if v not in (None, ""):
        item_rows.append((r, str(v).strip()))

print("Data rows with ITEM values:", item_rows)

counts = Counter(v for _, v in item_rows)
print("Computed counts:", counts)

target_order = ["A006", "A004", "A005"]
print("Target order and counts:", [(item, counts.get(item, 0)) for item in target_order])

# Verify current target cells before writing
for cell_ref in ["I3", "J3", "I4", "J4", "I5", "J5", "I6", "J6"]:
    print(f"Before {cell_ref} =", ws[cell_ref].value)

# Write headers and values starting at I3
ws["I3"] = "ITEM"
ws["J3"] = "Qty"

start_row = 4
for idx, item in enumerate(target_order, start=start_row):
    ws.cell(idx, 9).value = item   # column I
    ws.cell(idx, 10).value = counts.get(item, 0)  # column J

# Apply left alignment to the entire answer range
left_align = Alignment(horizontal="left")
for r in range(3, 3 + 1 + len(target_order)):  # rows 3 to 6
    for c in range(9, 11):  # I:J
        ws.cell(r, c).alignment = left_align

# Save to output path with same filename
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed; restoring original names")
    for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names to:", wb_after.sheetnames)

# Verification reload with data_only for values
verify_wb = load_workbook(output_path, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[original_sheetnames[0]]

# Print every target cell/range mentioned in the instruction
for r in range(3, 7):
    print(f"Row {r} -> I={vws.cell(r,9).value!r}, J={vws.cell(r,10).value!r}")

# Also verify alignment from non-data_only workbook
style_wb = load_workbook(output_path)
sws = style_wb[original_sheetnames[0]]
for r in range(3, 7):
    print(
        f"Alignment row {r}:",
        sws.cell(r, 9).alignment.horizontal,
        sws.cell(r, 10).alignment.horizontal
    )

# Keep output_path available for submission next turn
final_output_spreadsheet = output_path
