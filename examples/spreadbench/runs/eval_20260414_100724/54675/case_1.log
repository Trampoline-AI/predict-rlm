import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb["Sheet1"]

# Determine true used range by scanning for non-empty rows/cols
last_nonempty_row = 0
last_nonempty_col = 0
for r in range(1, ws.max_row + 1):
    row_has_data = False
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v not in (None, ""):
            row_has_data = True
            last_nonempty_col = max(last_nonempty_col, c)
    if row_has_data:
        last_nonempty_row = r

print("True used range last row:", last_nonempty_row)
print("True used range last col:", last_nonempty_col)

# Inspect relevant rows where A=4 and B contains the target
target = "Gary Stoddard"
matching_rows_contains = []
matching_rows_exact = []
occurrence_total = 0

for r in range(2, last_nonempty_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a == 4 and isinstance(b, str):
        if b == target:
            matching_rows_exact.append((r, a, b))
        if target in b:
            matching_rows_contains.append((r, a, b))
            occurrence_total += b.count(target)

print("Exact-match rows count:", len(matching_rows_exact))
print("Contains rows count:", len(matching_rows_contains))
print("Total substring occurrences across matching rows:", occurrence_total)

print("\nFirst up to 10 contains-match rows:")
for item in matching_rows_contains[:10]:
    print(item)

print("\nLast up to 5 contains-match rows:")
for item in matching_rows_contains[-5:]:
    print(item)

# Show if any cell contains the target more than once
multi_occurrence_rows = [(r,a,b,b.count(target)) for (r,a,b) in matching_rows_contains if b.count(target) > 1]
print("\nRows with more than one occurrence in the same cell:", len(multi_occurrence_rows))
for item in multi_occurrence_rows[:10]:
    print(item)

# Decide formula: count cells containing target when A=4
# Use bounded ranges for LibreOffice safety.
formula_contains = f'=COUNTIFS(B2:B{last_nonempty_row},"*{target}*",A2:A{last_nonempty_row},4)'
formula_occurrences = (
    f'=SUMPRODUCT((A2:A{last_nonempty_row}=4)*'
    f'((LEN(B2:B{last_nonempty_row})-LEN(SUBSTITUTE(B2:B{last_nonempty_row},"{target}","")))/LEN("{target}")))'
)

print("\nCurrent F3:", ws["F3"].value)
print("Proposed contains formula:", formula_contains)
print("Alternative total-occurrences formula:", formula_occurrences)

# Since the instruction asks to count entries where the name appears with other names,
# update F3 to the contains-based COUNTIFS formula.
ws["F3"] = formula_contains

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
original_sheet_names = ["Sheet1"]
if wb_after.sheetnames != original_sheet_names and len(wb_after.sheetnames) == len(original_sheet_names):
    for ws_obj, original_name in zip(wb_after.worksheets, original_sheet_names):
        ws_obj.title = original_name
    wb_after.save(output_path)
    print("Renamed sheets back to original names:", original_sheet_names)

# Verify output
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula["Sheet1"]
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values["Sheet1"]

print("\nVerification:")
print("Formula now in F3:", wsf["F3"].value)
print("Cached value in F3:", wsv["F3"].value)
print("Expected contains count from Python:", len(matching_rows_contains))
print("Expected exact count from Python:", len(matching_rows_exact))
print("Expected total occurrence count from Python:", occurrence_total)

output_spreadsheet = output_path
