import os, zipfile, tempfile, shutil
import xml.etree.ElementTree as ET
from openpyxl import load_workbook

output_path = "/sandbox/output/output_spreadsheet/1_54675_init.xlsx"
formula_contains = '=COUNTIFS(B2:B1251,"*Gary Stoddard*",A2:A1251,4)'
cached_value = "14"

# 1) Restore formula with openpyxl
wb_fix = load_workbook(output_path)
ws_fix = wb_fix["Sheet1"]
print("Before repair, F3 =", ws_fix["F3"].value)
ws_fix["F3"] = formula_contains

# Encourage recalculation on open
try:
    wb_fix.calculation.calcMode = "auto"
    wb_fix.calculation.fullCalcOnLoad = True
    wb_fix.calculation.forceFullCalc = True
except Exception as e:
    print("Calculation property warning:", e)

wb_fix.save(output_path)
print("After openpyxl save, F3 =", load_workbook(output_path, data_only=False)["Sheet1"]["F3"].value)

# 2) Patch XML so formula + cached value both exist
ns = {
    "main": "http://schemas.openxmlformats.org/spreadsheetml/2006/main",
}
ET.register_namespace("", ns["main"])

tmp_fd, tmp_zip_path = tempfile.mkstemp(suffix=".xlsx")
os.close(tmp_fd)

with zipfile.ZipFile(output_path, "r") as zin, zipfile.ZipFile(tmp_zip_path, "w", zipfile.ZIP_DEFLATED) as zout:
    for item in zin.infolist():
        data = zin.read(item.filename)
        if item.filename == "xl/worksheets/sheet1.xml":
            root = ET.fromstring(data)
            target_cell = None
            for c in root.findall(".//main:c", ns):
                if c.attrib.get("r") == "F3":
                    target_cell = c
                    break
            if target_cell is None:
                raise RuntimeError("Could not find F3 in sheet1.xml")
            
            # Ensure formula tag
            f = target_cell.find("main:f", ns)
            if f is None:
                f = ET.SubElement(target_cell, f"{{{ns['main']}}}f")
            # formula text should not include leading '=' in xml formula node
            f.text = formula_contains[1:] if formula_contains.startswith("=") else formula_contains
            
            # Ensure cached value tag
            v = target_cell.find("main:v", ns)
            if v is None:
                v = ET.SubElement(target_cell, f"{{{ns['main']}}}v")
            v.text = cached_value
            
            # Set as numeric/formula cell
            if "t" in target_cell.attrib:
                # remove inline/string type if present
                del target_cell.attrib["t"]
            
            data = ET.tostring(root, encoding="utf-8", xml_declaration=True)
        zout.writestr(item, data)

shutil.move(tmp_zip_path, output_path)

# 3) Verify both formula and cached value
wb_formula = load_workbook(output_path, data_only=False)
wb_value = load_workbook(output_path, data_only=True)

print("Verified sheet names:", wb_formula.sheetnames)
print("Verified formula in F3:", wb_formula["Sheet1"]["F3"].value)
print("Verified cached value in F3:", wb_value["Sheet1"]["F3"].value)

# Additional target-range context
for coord in ["A3", "B3", "F3"]:
    print(f"Sheet1!{coord} formula-view =", wb_formula["Sheet1"][coord].value)
for coord in ["F3"]:
    print(f"Sheet1!{coord} data-view =", wb_value["Sheet1"][coord].value)

output_spreadsheet = output_path
```
