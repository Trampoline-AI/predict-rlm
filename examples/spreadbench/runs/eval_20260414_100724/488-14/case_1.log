import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input spreadsheet:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}, dimensions={ws.dimensions}")
    
    # Tables
    try:
        table_names = list(ws.tables.keys())
    except Exception:
        table_names = []
    print("Tables:", table_names)
    if table_names:
        for tn in table_names:
            tbl = ws.tables[tn]
            print(f"  Table {tn}: ref={tbl.ref}")
    
    # Header candidates: first 3 rows
    preview_rows = min(ws.max_row, 3)
    for r in range(1, preview_rows + 1):
        print(f"Row {r}:", row_values(ws, r, min(ws.max_column, 12)))
    
    # First 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"  r{r}:", row_values(ws, r, min(ws.max_column, 12)))
    
    # Last 5 rows
    if ws.max_row > 10:
        print("Last rows:")
        start = max(1, ws.max_row - 4)
        for r in range(start, ws.max_row + 1):
            print(f"  r{r}:", row_values(ws, r, min(ws.max_column, 12)))

# Search workbook for text related to desired results / sort / frequency
hits = []
keywords = ["Desired Results", "desired", "result", "frequency", "sort"]
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                low = v.lower()
                if any(k.lower() in low for k in keywords):
                    hits.append((ws.title, cell.coordinate, v))
print("\nKeyword hits:")
for h in hits[:100]:
    print(h)
print("Total hits:", len(hits))
