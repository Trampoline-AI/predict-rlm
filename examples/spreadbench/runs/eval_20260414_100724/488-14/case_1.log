```repl
import os
from collections import Counter
from openpyxl import load_workbook

# Reload fresh workbook for clean manipulation
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]

print("Original sheet names:", orig_sheet_names)

# Inspect exact non-empty cells / columns to verify target area
for ws in wb.worksheets:
    print(f"\n--- Inspecting sheet: {ws.title} ---")
    nonempty = []
    formula_cells = []
    col_nonempty_counts = {}
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                nonempty.append((cell.coordinate, cell.value))
                col_nonempty_counts[cell.column] = col_nonempty_counts.get(cell.column, 0) + 1
                if isinstance(cell.value, str) and cell.value.startswith("="):
                    formula_cells.append((cell.coordinate, cell.value))
    print("Non-empty cell count:", len(nonempty))
    print("First 15 non-empty cells:", nonempty[:15])
    print("Last 10 non-empty cells:", nonempty[-10:])
    print("Non-empty counts by column:", {k: v for k, v in sorted(col_nonempty_counts.items())})
    print("Formula cells:", formula_cells[:10], "total", len(formula_cells))

ws = wb["Sheet1"]
ws_desired = wb["Desired Results"]

# Determine actual data extent in Sheet1 column A
last_nonblank_a = 0
for r in range(ws.max_row, 0, -1):
    if ws.cell(r, 1).value not in (None, ""):
        last_nonblank_a = r
        break

print("\nTarget sheet:", ws.title)
print("Target column/cells to write: Sheet1!A2:A{}".format(last_nonblank_a))
print("Current header A1:", ws["A1"].value)
print("Current values A1:A15:", [ws.cell(r, 1).value for r in range(1, min(15, last_nonblank_a)+1)])
print("Desired Results A1:A15:", [ws_desired.cell(r, 1).value for r in range(1, min(15, ws_desired.max_row)+1)])

# Treat A1 as header, sort A2:A(last_nonblank) by frequency descending
header = ws["A1"].value
data_vals = [ws.cell(r, 1).value for r in range(2, last_nonblank_a + 1) if ws.cell(r, 1).value not in (None, "")]
print("Data row count excluding header:", len(data_vals))

counts = Counter(data_vals)
print("Frequencies:", counts)

# Preserve first appearance order for tie-breaking (safe/general)
first_pos = {}
for idx, val in enumerate(data_vals, start=2):
    if val not in first_pos:
        first_pos[val] = idx

sorted_unique = [k for k, v in sorted(counts.items(), key=lambda kv: (-kv[1], first_pos[kv[0]]))]
sorted_data = []
for k in sorted_unique:
    sorted_data.extend([k] * counts[k])

print("Sorted unique order:", sorted_unique)
print("First 20 sorted output values incl header:", [header] + sorted_data[:19])
print("Last 10 sorted output values:", sorted_data[-10:])

# Write sorted values back into Sheet1 column A, preserving header
ws["A1"] = header
for i, val in enumerate(sorted_data, start=2):
    ws.cell(i, 1).value = val

# If there were extra stale values below data extent in col A, clear them (none expected, but safe)
for r in range(2 + len(sorted_data), ws.max_row + 1):
    if r > last_nonblank_a and ws.cell(r, 1).value not in (None, ""):
        ws.cell(r, 1).value = None

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed; restoring original names...")
    for i, old_name in enumerate(orig_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = old_name
    wb_check.save(out_path)
    wb_check = load_workbook(out_path)
    print("Restored sheet names:", wb_check.sheetnames)

# Verification with formulas/data_only reloads
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

vws = wb_verify["Sheet1"]
vdes = wb_verify["Desired Results"]

# Print and compare target range
sheet1_vals = [vws.cell(r, 1).value for r in range(1, last_nonblank_a + 1)]
desired_vals = [vdes.cell(r, 1).value for r in range(1, ws_desired.max_row + 1)]

print("\nVerification target range Sheet1!A1:A15:", sheet1_vals[:15])
print("Verification target range Sheet1 last 10:", sheet1_vals[-10:])
print("Desired Results A1:A15:", desired_vals[:15])
print("Desired Results last 10:", desired_vals[-10:])

print("Exact match with Desired Results?:", sheet1_vals == desired_vals)
print("Any blanks in target range that should not be blank?:", any(v in (None, "") for v in sheet1_vals[:last_nonblank_a]))

output_spreadsheet = out_path
