import os, json, textwrap, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction full text:\n", instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find actual non-empty rows/cols roughly
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
            for c, v in enumerate(vals, start=1):
                if v is not None and v != "":
                    nonempty_cols.add(c)
    if nonempty_rows:
        print(f"Non-empty row span: {min(nonempty_rows)}:{max(nonempty_rows)}")
    if nonempty_cols:
        print(f"Non-empty col span: {get_column_letter(min(nonempty_cols))}:{get_column_letter(max(nonempty_cols))}")
    
    # Print first 10 rows and last 5 rows, trimmed to actual used columns
    max_used_col = max(nonempty_cols) if nonempty_cols else ws.max_column
    print("\nFirst rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, max_used_col))
    
    print("\nLast rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, max_used_col))
    
    # Print formulas present
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print(f"\nFormula cells count: {len(formulas)}")
    for item in formulas[:20]:
        r, c, v = item
        print(f"  {get_column_letter(c)}{r}: {v}")
    if len(formulas) > 20:
        print("  ...")
