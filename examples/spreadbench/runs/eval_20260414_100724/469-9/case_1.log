```repl
import os
from copy import copy
from openpyxl import load_workbook

# Re-open fresh from input for clean write workflow
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Worksheet:", ws.title, "max_row:", ws.max_row, "max_column:", ws.max_column)

# Final inspection: infer sign meaning using balance deltas
print("\nBalance delta inspection (rows 2-6):")
for r in range(2, min(ws.max_row, 6) + 1):
    amt = ws[f"C{r}"].value
    bal = ws[f"F{r}"].value
    next_bal = ws[f"F{r+1}"].value if r + 1 <= ws.max_row else None
    delta_to_next = None if bal is None or next_bal is None else next_bal - bal
    print(f"Row {r}: Amount={amt!r}, Balance={bal!r}, NextBalance-Balance={delta_to_next!r}")

print("\nTarget cells before writing:")
for r in range(1, ws.max_row + 1):
    if r <= 10 or r > ws.max_row - 3:
        print(f"Row {r}: H={ws[f'H{r}'].value!r}, I={ws[f'I{r}'].value!r}")

# Write headers in H and I
ws["H1"] = "Debits"
ws["I1"] = "Credits"

# Copy header style from existing header cells if present
for target in ("H1", "I1"):
    ws[target]._style = copy(ws["A1"]._style)
    ws[target].font = copy(ws["A1"].font)
    ws[target].fill = copy(ws["A1"].fill)
    ws[target].border = copy(ws["A1"].border)
    ws[target].alignment = copy(ws["A1"].alignment)
    ws[target].number_format = ws["A1"].number_format
    ws[target].protection = copy(ws["A1"].protection)

# Use Amount column formatting for numeric cells
amount_num_format = ws["C2"].number_format if ws.max_row >= 2 else "General"

written = []
for r in range(2, ws.max_row + 1):
    cval = ws[f"C{r}"].value
    
    # Clear targets first only for relevant data rows
    ws[f"H{r}"] = None
    ws[f"I{r}"] = None
    
    if isinstance(cval, (int, float)) and cval != 0:
        if cval > 0:
            ws[f"H{r}"] = abs(cval)
            ws[f"H{r}"].number_format = amount_num_format
            written.append((r, "H", abs(cval)))
        elif cval < 0:
            ws[f"I{r}"] = abs(cval)
            ws[f"I{r}"].number_format = amount_num_format
            written.append((r, "I", abs(cval)))

# Save
wb.save(outfile)
print("\nSaved to:", outfile)
print("Written entries:", written)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Check sheet names after recalc; rename back if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename sheets back by position
    for idx, original_name in enumerate(original_sheet_names):
        wb_after.worksheets[idx].title = original_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_sheet_names)

# Verify with data_only
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[original_sheet_names[0]]

print("\nVerified target range H1:I10:")
for r in range(1, min(vws.max_row, 10) + 1):
    print(f"Row {r}: H={vws[f'H{r}'].value!r}, I={vws[f'I{r}'].value!r}")

# Sanity checks
blank_issues = []
for r in range(2, vws.max_row + 1):
    amt = vws[f"C{r}"].value
    h = vws[f"H{r}"].value
    i = vws[f"I{r}"].value
    if isinstance(amt, (int, float)) and amt > 0 and h in (None, ""):
        blank_issues.append((r, "expected debit in H", amt, h, i))
    if isinstance(amt, (int, float)) and amt < 0 and i in (None, ""):
        blank_issues.append((r, "expected credit in I", amt, h, i))

print("\nVerification issues:", blank_issues)
output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
