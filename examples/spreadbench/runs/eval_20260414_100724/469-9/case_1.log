import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:")
    for i, v in enumerate(headers, start=1):
        print(f"  {get_column_letter(i)}1: {v!r}")
    
    # Find non-empty rows to better understand true used range
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("First non-empty rows:", nonempty_rows[:10])
    print("Last non-empty rows:", nonempty_rows[-10:])
    
    sample_top = nonempty_rows[:10]
    sample_bottom = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
    print("\nTop sample rows:")
    for r in sample_top:
        print(f"Row {r}: {row_values(ws, r, min(ws.max_column, 12))}")
    
    print("\nBottom sample rows:")
    for r in sample_bottom:
        print(f"Row {r}: {row_values(ws, r, min(ws.max_column, 12))}")
    
    # Specific inspection of columns C, H, I because instruction references them
    print("\nInspecting columns C, H, I for first 15 non-empty rows:")
    for r in nonempty_rows[:15]:
        c = ws[f"C{r}"].value if ws.max_column >= 3 else None
        h = ws[f"H{r}"].value if ws.max_column >= 8 else None
        i = ws[f"I{r}"].value if ws.max_column >= 9 else None
        print(f"Row {r}: C={c!r}, H={h!r}, I={i!r}")
    
    # Inspect existing formulas in H/I if any
    existing_hi = []
    for r in nonempty_rows:
        for col in ("H", "I"):
            if ws.max_column >= (8 if col=="H" else 9):
                val = ws[f"{col}{r}"].value
