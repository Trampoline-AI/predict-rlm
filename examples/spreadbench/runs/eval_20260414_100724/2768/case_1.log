from openpyxl import load_workbook
from collections import defaultdict

wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

print("Target header check:", ws1["H1"].value, "at H1")
print("\nSheet1 A:H all used rows")
for r in range(1, ws1.max_row + 1):
    vals = [ws1.cell(r, c).value for c in range(1, 9)]
    print(f"r{r}: {vals}")

print("\nSheet2 A:D all used rows")
for r in range(1, ws2.max_row + 1):
    vals = [ws2.cell(r, c).value for c in range(1, 5)]
    if any(v is not None for v in vals):
        print(f"r{r}: {vals}")

print("\nExisting H column values:")
for r in range(2, ws1.max_row + 1):
    print(r, ws1[f"H{r}"].value)

# Simulate likely desired allocation logic in Python:
# total incoming by (Order No, Item code, Item)
incoming = defaultdict(float)
for r in range(2, ws2.max_row + 1):
    order_no = ws2.cell(r, 1).value
    item_code = ws2.cell(r, 2).value
    item = ws2.cell(r, 3).value
    qty = ws2.cell(r, 4).value
    if order_no is not None and item_code is not None and item is not None and qty is not None:
        incoming[(order_no, item_code, item)] += float(qty)

print("\nIncoming totals by (Order No, Item code, Item):")
for k, v in sorted(incoming.items()):
    print(k, v)

allocated_so_far = defaultdict(float)
sim_results = {}
for r in range(2, ws1.max_row + 1):
    key = (ws1.cell(r,1).value, ws1.cell(r,4).value, ws1.cell(r,5).value)
    order_qty = ws1.cell(r,7).value or 0
    available = incoming.get(key, 0.0)
    prior = allocated_so_far[key]
    alloc = max(0.0, min(float(order_qty), available - prior))
    allocated_so_far[key] += alloc
    sim_results[r] = alloc

print("\nSimulated allocation by row (row, key, qty, simulated, existing H):")
for r in range(2, ws1.max_row + 1):
    key = (ws1.cell(r,1).value, ws1.cell(r,4).value, ws1.cell(r,5).value)
    print(r, key, ws1.cell(r,7).value, sim_results[r], ws1.cell(r,8).value)
