import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:\n", instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_nonempty_bounds(ws):
    min_row = min_col = None
    max_row = max_col = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                r, c = cell.row, cell.column
                if min_row is None or r < min_row: min_row = r
                if min_col is None or c < min_col: min_col = c
                if r > max_row: max_row = r
                if c > max_col: max_col = c
    return min_row, min_col, max_row, max_col

for ws in wb.worksheets:
    print("\n" + "="*80)
    print("Sheet:", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    bounds = sheet_nonempty_bounds(ws)
    print("nonempty bounds:", bounds)
    
    # collect first 10 rows and last 5 rows with visible columns up to nonempty max_col or 12 cols minimum
    _, _, _, max_col = bounds if bounds[0] is not None else (None, None, None, 0)
    max_col = max(max_col or 0, min(ws.max_column, 12))
    headers = [ws.cell(1, c).value for c in range(1, max_col+1)]
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, max_col+1)]
        print("Row 2:", row2)
    
    sample_first = list(range(1, min(ws.max_row, 10)+1))
    sample_last = list(range(max(1, ws.max_row-4), ws.max_row+1))
    sample_rows = []
    seen = set()
    for r in sample_first + sample_last:
        if r not in seen:
            seen.add(r)
            sample_rows.append(r)
    print("Sample rows:")
    for r in sample_rows:
        vals = [ws.cell(r, c).value for c in range(1, max_col+1)]
        print(f"Row {r}: {vals}")
    
    # formulas scan
    formulas = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formulas.append((cell.coordinate, cell.value))
    print("Formula count:", len(formulas))
    if formulas[:20]:
        print("First formulas:", formulas[:20])

    # merged ranges if any
    if ws.merged_cells.ranges:
        print("Merged ranges:", list(ws.merged_cells.ranges)[:20])
