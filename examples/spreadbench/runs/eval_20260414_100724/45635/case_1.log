Since rows 5:7 mirror rows 1:3 by label, I can use one copyable formula with `INDEX/MATCH` against column A labels. Then I’ll save, recalculate, reload, and verify that B5:E7 evaluates to the expected nonblank values.
Code:
```repl
import os
from openpyxl import load_workbook

# Reload cleanly
wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Target range before writing:")
for r in range(5, 8):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Write formulas into B5:E7
# Formula logic:
# - find this row's corresponding top-row value by matching labels in col A
# - if it equals the max of the top three rows in that column, assign 6/count_of_max_ties
# - else 0
for r in range(5, 8):
    for c in range(2, 6):  # B:E
        col_letter = ws.cell(1, c).column_letter
        formula = (
            f'=IF(INDEX({col_letter}$1:{col_letter}$3,'
            f'MATCH($A{r},$A$1:$A$3,0))=MAX({col_letter}$1:{col_letter}$3),'
            f'6/COUNTIF({col_letter}$1:{col_letter}$3,MAX({col_letter}$1:{col_letter}$3)),0)'
        )
        ws.cell(r, c).value = formula

print("\nFormulas written to target range:")
for r in range(5, 8):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Save to output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename sheets back by position
    for i, orig_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(out_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas and computed values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]
print("\nVerified formulas in B5:E7:")
for r in range(5, 8):
    print(r, [ws_formula.cell(r, c).value for c in range(2, 6)])

wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]
print("\nComputed values in A5:E7 after recalc:")
for r in range(5, 8):
    print(r, [ws_values.cell(r, c).value for c in range(1, 6)])

# Basic sanity check
target_values = {(r, c): ws_values.cell(r, c).value for r in range(5, 8) for c in range(2, 6)}
print("\nAny blank target cells?", [(r, c, v) for (r, c), v in target_values.items() if v in (None, "")])

expected_preview = {
    "B5:E7": [
        [ws_values["B5"].value, ws_values["C5"].value, ws_values["D5"].value, ws_values["E5"].value],
        [ws_values["B6"].value, ws_values["C6"].value, ws_values["D6"].value, ws_values["E6"].value],
        [ws_values["B7"].value, ws_values["C7"].value, ws_values["D7"].value, ws_values["E7"].value],
    ]
}
print("Target preview:", expected_preview)

output_spreadsheet = out_path
