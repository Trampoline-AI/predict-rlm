Code:
```repl
import os
from openpyxl import load_workbook
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter

# Load workbook
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Identify source and target layout
source_start = 5
source_end = max(
    r for r in range(source_start, ws.max_row + 1)
    if ws[f"C{r}"].value not in (None, "")
)
target_start = 5
target_end = source_end  # fill down alongside available source rows

print("Original sheetnames:", original_sheetnames)
print("Source rows:", source_start, "to", source_end)
print("Target rows:", target_start, "to", target_end)

# Show source rows that should match
expected_rows = []
for r in range(source_start, source_end + 1):
    qty = ws[f"I{r}"].value
    if qty not in (None, "") and not (isinstance(qty, str) and qty.strip() == ""):
        expected_rows.append(r)
print("Expected matching source rows:", expected_rows)

# Helper column J: visually hidden via number format, but used for MATCH
# J[r] = running count of non-empty quantity rows, blank otherwise
for r in range(source_start, source_end + 1):
    cell = ws[f"J{r}"]
    cell.value = f'=IF(TRIM($I{r}&"")<>"",COUNTIF($I$5:I{r},"<>"),"")'
    cell.number_format = ';;;'

# Map target columns to source columns
col_map = {
    "L": "C",  # CODE PRODUCT
    "M": "D",  # PRODUCT
    "N": "E",  # TAX
    "O": "F",  # UNIT PRICE
    "P": "G",  # PRICE TABLE
    "Q": "H",  # COMMERCIAL DISCOUNT
    "R": "I",  # QUANTITY UNITS
}

# Write formulas into frame 2
for r in range(target_start, target_end + 1):
    k = r - target_start + 1  # 1,2,3,...
    for tgt_col, src_col in col_map.items():
        ws[f"{tgt_col}{r}"] = (
            f'=IFERROR(INDEX(${src_col}$5:${src_col}${source_end},'
            f'MATCH({k},$J$5:$J${source_end},0)),"")'
        )

# Apply requested alignment:
# - Product names in M left aligned
# - Output values in O:R right aligned
for r in range(target_start, target_end + 1):
    ws[f"M{r}"].alignment = Alignment(horizontal="left", vertical=ws[f"M{r}"].alignment.vertical or "center")
    for col in ["O", "P", "Q", "R"]:
        ws[f"{col}{r}"].alignment = Alignment(horizontal="right", vertical=ws[f"{col}{r}"].alignment.vertical or "center")

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if changed by recalculation
wb_after = load_workbook(out_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # Rename sheets back by position
    for i, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(out_path)
    print("Restored sheet names to:", original_sheetnames)
else:
    print("Sheet names preserved.")

# Verification: formulas
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]

print("\nTarget formulas L:R rows 5:10")
for r in range(5, min(10, target_end) + 1):
    print(
        r,
        {c: ws_formula[f"{c}{r}"].value for c in ["L","M","N","O","P","Q","R"]},
        "align M:", ws_formula[f"M{r}"].alignment.horizontal,
        "align O:R:", {c: ws_formula[f"{c}{r}"].alignment.horizontal for c in ["O","P","Q","R"]}
    )

# Verification: calculated values
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerified output values in L:R for all target rows")
verified = []
for r in range(target_start, target_end + 1):
    vals = {c: ws_values[f"{c}{r}"].value for c in ["L","M","N","O","P","Q","R"]}
    verified.append((r, vals))
    print(r, vals)

# Compare first expected outputs against source
expected_records = []
for r in expected_rows:
    expected_records.append({
        "L": ws_values[f"C{r}"].value,
        "M": ws_values[f"D{r}"].value,
        "N": ws_values[f"E{r}"].value,
        "O": ws_values[f"F{r}"].value,
        "P": ws_values[f"G{r}"].value,
        "Q": ws_values[f"H{r}"].value,
        "R": ws_values[f"I{r}"].value,
    })

actual_nonblank = []
for r in range(target_start, target_end + 1):
    row_vals = {c: ws_values[f"{c}{r}"].value for c in ["L","M","N","O","P","Q","R"]}
    if any(v not in (None, "") for v in row_vals.values()):
        actual_nonblank.append(row_vals)

print("\nExpected filtered records:", expected_records)
print("Actual nonblank target records:", actual_nonblank)
print("Match status:", expected_records == actual_nonblank)

output_spreadsheet = out_path
```
