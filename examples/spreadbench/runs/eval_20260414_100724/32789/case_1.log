    print("Final rows 8:15 C:D:")
    for r in range(8, min(15, wsfinal.max_row) + 1):
        print(r, wsfinal[f"C{r}"].value, wsfinal[f"D{r}"].value)

final_output_path = str(output_path)
print("\nPrepared output:", final_output_path)
