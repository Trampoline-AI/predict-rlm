        wsfb.cell(r, 4).value = None
    wsfb_parent_names = wb_fb.sheetnames[:]
    wb_fb.save(output_path)
    print("Saved fallback values.")

    recalc_result2 = await recalculate(str(output_path))
    print("Recalculate after fallback:", recalc_result2)

    wb_final = load_workbook(output_path, data_only=True)
    # restore sheet names if needed
    if wb_final.sheetnames != original_sheetnames:
        wb_fix = load_workbook(output_path)
        if len(wb_fix.sheetnames) == len(original_sheetnames):
            for i, nm in enumerate(original_sheetnames):
                wb_fix.worksheets[i].title = nm
            wb_fix.save(output_path)
    wb_final = load_workbook(output_path, data_only=True)
    wsfinal = wb_final[original_sheetnames[0]]
    print("\nFinal D4:D7 after fallback:")
    for r in range(4, 8):
