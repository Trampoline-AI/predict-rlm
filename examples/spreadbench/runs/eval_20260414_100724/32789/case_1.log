from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string, get_column_letter
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

# Load fresh workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Determine true last lookup row in BD and true sheet last row for clearing
bd_col = column_index_from_string("BD")
last_lookup_row = None
for r in range(ws.max_row, 3, -1):
    if ws.cell(r, bd_col).value not in (None, ""):
        last_lookup_row = r
        break
if last_lookup_row is None:
    last_lookup_row = ws.max_row

print("Original sheet names:", original_sheetnames)
print("Target sheet:", ws.title)
print("Current D4:D7 before change:")
for r in range(4, 8):
    print(r, ws[f"D{r}"].value, ws[f"D{r}"].number_format)

print("Will use lookup rows 4 to", last_lookup_row)
print("Will clear C:D from row 8 to", ws.max_row)

# Write corrected formula only to D4:D7, matching date + primary header + secondary header
# Primary header is B2 ("CASE REPLIES"), secondary header comes from D3 ("Goal %")
for r in range(4, 8):
    formula = (
        f'=IFERROR('
        f'INDEX($BE$4:$BR${last_lookup_row},'
        f'MATCH($A{r},$BD$4:$BD${last_lookup_row},0),'
        f'SUMPRODUCT(($BE$2:$BR$2=$B$2)*($BE$3:$BR$3=D$3)*(COLUMN($BE$2:$BR$2)-COLUMN($BE$2)+1))'
        f'),"-")'
    )
    ws[f"D{r}"] = formula
    ws[f"D{r}"].number_format = "0"

# Clear any values below row 7 on columns C:D
for r in range(8, ws.max_row + 1):
    ws.cell(r, 3).value = None  # C
    ws.cell(r, 4).value = None  # D

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# After recalc, restore original sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
current_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != original_sheetnames:
    # Rename by position if count is unchanged
    if len(current_names) == len(original_sheetnames):
        for i, expected_name in enumerate(original_sheetnames):
            wb_after.worksheets[i].title = expected_name
        wb_after.save(output_path)
        print("Restored sheet names to:", original_sheetnames)
    else:
        print("Warning: sheet name count changed unexpectedly.")

# Verify formulas in normal mode
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula[original_sheetnames[0]]
print("\nFormulas now in D4:D7:")
for r in range(4, 8):
    print(f"D{r} =", wsf[f"D{r}"].value, "| fmt =", wsf[f"D{r}"].number_format)

# Verify calculated values in data_only mode
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

# Compute expected values in Python for sanity check
# Find target lookup column based on B2 and D3
target_primary = ws["B2"].value
target_secondary = ws["D3"].value
target_lookup_col = None
for c in range(column_index_from_string("BE"), column_index_from_string("BR") + 1):
    if ws.cell(2, c).value == target_primary and ws.cell(3, c).value == target_secondary:
        target_lookup_col = c
        break

print("\nResolved lookup target:")
print("Primary header:", target_primary)
print("Secondary header:", target_secondary)
print("Lookup column:", get_column_letter(target_lookup_col) if target_lookup_col else None)

expected = {}
for r in range(4, 8):
    date_val = ws[f"A{r}"].value
    match_row = None
    for rr in range(4, last_lookup_row + 1):
        if ws.cell(rr, bd_col).value == date_val:
            match_row = rr
            break
    expected[r] = ws.cell(match_row, target_lookup_col).value if (match_row and target_lookup_col) else None

print("\nVerification of D4:D7 (data_only):")
needs_fallback = False
for r in range(4, 8):
    val = wsv[f"D{r}"].value
    print(f"Row {r}: A{r}={wsv[f'A{r}'].value!r}, D{r}={val!r}, expected={expected[r]!r}")
    if val in (None, ""):
        needs_fallback = True

print("\nVerification that C:D below row 7 are cleared (rows 8:15):")
for r in range(8, min(15, wsv.max_row) + 1):
    print(r, wsv[f"C{r}"].value, wsv[f"D{r}"].value)

# Fallback to literal values if formula didn't recalculate properly
if needs_fallback:
    print("\nFormula evaluation incomplete; applying Python fallback for D4:D7.")
    wb_fb = load_workbook(output_path)
    wsfb = wb_fb[original_sheetnames[0]]
    for r in range(4, 8):
        wsfb[f"D{r}"] = expected[r] if expected[r] is not None else "-"
        wsfb[f"D{r}"].number_format = "0"
    # ensure C:D below row 7 are still blank
    for r in range(8, wsfb.max_row + 1):
