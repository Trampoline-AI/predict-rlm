Code:
```repl
from openpyxl import load_workbook
from openpyxl.worksheet.formula import ArrayFormula
from openpyxl.utils import get_column_letter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Target sheet:", ws.title)
print("Target column appears to be B based on existing formulas.")
print("Headers A:D:", [ws.cell(1, c).value for c in range(1, 5)])

print("\nInspect existing B formulas/values:")
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if isinstance(b, ArrayFormula):
        b_repr = f"ArrayFormula text={b.text!r} ref={b.ref!r}"
    else:
        b_repr = repr(b)
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    print(f"Row {r}: A={a!r}, B={b_repr}, C={c!r}, D={d!r}")

# Build lookup map from C:D and expected values for A lookups
lookup = {}
for r in range(2, ws.max_row + 1):
    key = ws.cell(r, 3).value
    val = ws.cell(r, 4).value
    if key not in (None, ""):
        lookup[key] = val

print("\nSanity-check expected lookup results for column A:")
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    expected = lookup.get(a, "")
    print(f"Row {r}: A={a!r} -> expected B={expected!r}")

# Save modified workbook with formulas in B
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))

# Use bounded ranges to actual data extent for better Calc compatibility
last_row = ws.max_row
for r in range(2, last_row + 1):
    a = ws.cell(r, 1).value
    if a not in (None, ""):
        ws.cell(r, 2).value = f'=IFERROR(INDEX($D$2:$D${last_row},MATCH(A{r},$C$2:$C${last_row},0)),"")'
    else:
        ws.cell(r, 2).value = None

wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names unchanged
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_names = wb.sheetnames
if wb_after.sheetnames != orig_names:
    # Rename back by position
    for i, name in enumerate(orig_names):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)
    print("Renamed sheets back to original:", orig_names)

# Verify formulas and values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_names[0]]
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_names[0]]

print("\nVerification of target cells B2:B19:")
for r in range(2, last_row + 1):
    formula = ws_formula.cell(r, 2).value
    value = ws_values.cell(r, 2).value
    expected = lookup.get(ws_values.cell(r, 1).value, "")
    print(f"Row {r}: formula={formula!r}, value={value!r}, expected={expected!r}")

# Additional compact check for blanks where no match exists
issues = []
for r in range(2, last_row + 1):
    a = ws_values.cell(r, 1).value
    value = ws_values.cell(r, 2).value
    expected = lookup.get(a, "")
    normalized_value = "" if value is None else value
    if normalized_value != expected:
        issues.append((r, a, value, expected))

print("\nIssue count:", len(issues))
print("Issues sample:", issues[:10])

final_output_path = out_path
