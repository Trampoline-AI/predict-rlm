Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Determine actual used ranges
last_req_row = 0
for r in range(ws.max_row, 1, -1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_req_row = r
        break

last_src_row = 0
for r in range(ws.max_row, 1, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(7, 10)):
        last_src_row = r
        break

print("Original sheet names:", orig_sheetnames)
print("Requested table rows: 3 to", last_req_row)
print("Source table rows: 3 to", last_src_row)

# Show target cells before writing
print("\nBefore writing, target range C3:C{}:".format(last_req_row))
for r in range(3, last_req_row + 1):
    print(f"C{r} before -> {ws.cell(r, 3).value!r}")

# Fill only blank target cells in column C
written = []
for r in range(3, last_req_row + 1):
    stock = ws.cell(r, 1).value
    year = ws.cell(r, 2).value
    ccell = ws.cell(r, 3)
    if stock is None and year is None:
        continue
    if ccell.value in (None, ""):
        formula = f'=SUMIFS($I$3:$I${last_src_row},$H$3:$H${last_src_row},A{r},$G$3:$G${last_src_row},B{r})'
        ccell.value = formula
        written.append((r, formula))

print("\nWritten formulas:")
for r, formula in written:
    print(f"C{r} = {formula}")

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # Rename by position back to original names
    for i, name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)
    print("Restored sheet names to:", wb_after.sheetnames)
else:
    print("Sheet names preserved after recalc.")

# Verify formulas/text in normal workbook
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]

print("\nFormula verification for cells written:")
for r, _ in written:
    print(f"C{r} formula now -> {ws_formula[f'C{r}'].value!r}")

# Verify calculated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("\nVerified output values A:C rows 3-{}:".format(last_req_row))
for r in range(3, last_req_row + 1):
    a = ws_values[f"A{r}"].value
    b = ws_values[f"B{r}"].value
    c = ws_values[f"C{r}"].value
    print(f"Row {r}: A={a!r}, B={b!r}, C={c!r}")

# Extra sanity check for blanks in target cells that should now have a result
problems = []
for r in range(3, last_req_row + 1):
    if ws_values[f"A{r}"].value is not None or ws_values[f"B{r}"].value is not None:
        if ws_values[f"C{r}"].value is None:
            problems.append(r)

print("\nRows with unexpected blank C after recalc:", problems)
output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
