from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Target header cells:")
for coord in ["A2","B2","C2","G2","H2","I2"]:
    print(coord, "->", ws[coord].value)

print("\nCurrent requested table rows with raw C values/types:")
for r in range(3, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    print(f"Row {r}: A={a!r}, B={b!r}, C={c!r}, C_type={type(c).__name__}")

# Build mapping from source table G:I
source_map = {}
duplicates = {}
for r in range(3, ws.max_row + 1):
    year = ws[f"G{r}"].value
    stock = ws[f"H{r}"].value
    logv = ws[f"I{r}"].value
    if year is None and stock is None and (logv is None or logv == ""):
        continue
    key = (stock, year)
    duplicates.setdefault(key, []).append((r, logv))
    source_map[key] = logv

print("\nSource mapping samples / duplicates check:")
for key, vals in duplicates.items():
    if len(vals) > 1:
        print("DUPLICATE", key, vals)
print("Total source keys:", len(source_map))

print("\nComputed match for each requested row (from G:I):")
for r in range(3, ws.max_row + 1):
    key = (ws[f"A{r}"].value, ws[f"B{r}"].value)
    mapped = source_map.get(key, "<<NO MATCH>>")
    existing = ws[f"C{r}"].value
    print(f"Row {r} key={key} existing_C={existing!r} mapped={mapped!r}")

# Check if there are formulas anywhere in C column
