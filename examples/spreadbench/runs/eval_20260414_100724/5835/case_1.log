import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)

print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows), 
          "first non-empty row:", nonempty_rows[0] if nonempty_rows else None,
          "last non-empty row:", nonempty_rows[-1] if nonempty_rows else None)
    
    # Print first 10 rows with coordinates for context
    print("First up to 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}:", vals)
    
    print("Last up to 5 rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}:", vals)
    
    # Print column letters + row1/row2 headers
    headers1 = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    headers2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)] if ws.max_row >= 2 else []
    print("Columns:", [(get_column_letter(c), headers1[c-1], headers2[c-1] if headers2 else None) for c in range(1, ws.max_column+1)])
    
    # Print cells in columns A:I for all non-empty rows if sheet small enough
    if ws.max_row <= 30 and ws.max_column <= 12:
        print("Detailed grid:")
        for r in range(1, ws.max_row + 1):
            row = []
            for c in range(1, ws.max_column + 1):
                v = ws.cell(r, c).value
                row.append(f"{get_column_letter(c)}{r}={v!r}")
            print(" | ".join(row))
