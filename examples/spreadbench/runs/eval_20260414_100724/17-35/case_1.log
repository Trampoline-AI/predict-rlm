from openpyxl import load_workbook
from copy import copy
from datetime import datetime
import os

infile = input_spreadsheet
orig_wb = load_workbook(infile)
orig_sheetnames = orig_wb.sheetnames[:]
ws = orig_wb[orig_sheetnames[0]]

# Confirm exact target/source layout
print("Sheet:", ws.title)
print("Source headers A5:E5:", [ws.cell(5, c).value for c in range(1, 6)])
print("Target headers I5:M5:", [ws.cell(5, c).value for c in range(9, 14)])
print("Criteria I2/J2:", ws["I2"].value, ws["J2"].value)

start_date = ws["I2"].value
end_date = ws["J2"].value

# Normalize criteria if datetimes
def norm_dt(v):
    if isinstance(v, datetime):
        return v
    return v

start_date = norm_dt(start_date)
end_date = norm_dt(end_date)

# Inspect matching and non-matching rows
matches = []
nonmatches = []
for r in range(6, ws.max_row + 1):
    row_vals = [ws.cell(r, c).value for c in range(1, 6)]
    if all(v is None for v in row_vals):
        continue
    d = ws.cell(r, 1).value
    ok = d is not None and start_date <= d <= end_date
    if ok:
        matches.append((r, row_vals))
    else:
        nonmatches.append((r, row_vals))

print("Matched rows:", len(matches))
print("First 5 matched rows:")
for item in matches[:5]:
    print(item)
print("Last 5 matched rows:")
for item in matches[-5:]:
    print(item)

print("First 5 non-matching rows:")
for item in nonmatches[:5]:
    print(item)

# Inspect source vs target styles for a sample row
sample_r = matches[0][0] if matches else 6
print("Sample source row styles A:E for row", sample_r)
for c in range(1, 6):
    cell = ws.cell(sample_r, c)
    print(cell.coordinate, cell.value, cell.number_format, cell.style_id)

print("Current target area I6:M10 before writing:")
for r in range(6, min(10, ws.max_row) + 1):
    print(r, [ws.cell(r, c).value for c in range(9, 14)])

# Write filtered output starting at I6, preserving formatting from source A:E
dest_start_row = 6
dest_cols = range(9, 14)  # I:M
src_cols = range(1, 6)    # A:E

out_row = dest_start_row
for src_r, row_vals in matches:
    # copy values + styles + formats + hyperlink/comment if any
    for src_c, dst_c in zip(src_cols, dest_cols):
        src_cell = ws.cell(src_r, src_c)
        dst_cell = ws.cell(out_row, dst_c)
        dst_cell.value = src_cell.value
        dst_cell._style = copy(src_cell._style)
        if src_cell.number_format:
            dst_cell.number_format = src_cell.number_format
        if src_cell.font:
            dst_cell.font = copy(src_cell.font)
        if src_cell.fill:
            dst_cell.fill = copy(src_cell.fill)
        if src_cell.border:
            dst_cell.border = copy(src_cell.border)
        if src_cell.alignment:
            dst_cell.alignment = copy(src_cell.alignment)
        if src_cell.protection:
            dst_cell.protection = copy(src_cell.protection)
        if src_cell.has_style:
            pass
        if src_cell.hyperlink:
            dst_cell._hyperlink = copy(src_cell.hyperlink)
        else:
            dst_cell._hyperlink = None
        if src_cell.comment:
            dst_cell.comment = copy(src_cell.comment)
        else:
            dst_cell.comment = None

    # copy row height if set
    src_dim = ws.row_dimensions[src_r]
    if src_dim.height is not None:
        ws.row_dimensions[out_row].height = src_dim.height
    out_row += 1

last_written_row = out_row - 1
print("Last written output row:", last_written_row)

# Clear leftover cells below output area to end of original data region
for r in range(last_written_row + 1, ws.max_row + 1):
    for c in dest_cols:
        cell = ws.cell(r, c)
        cell.value = None
        cell._hyperlink = None
        cell.comment = None
        # keep plain default style in cleared cells
        cell._style = copy(ws.cell(6, c)._style) if ws.cell(6, c).style_id != 0 else copy(cell._style)

# Save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
orig_wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Reload and restore sheet names if needed
chk_wb = load_workbook(outfile)
print("Sheet names after recalc:", chk_wb.sheetnames)
if chk_wb.sheetnames != orig_sheetnames:
    for idx, name in enumerate(orig_sheetnames):
        chk_wb.worksheets[idx].title = name
    chk_wb.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only=True
verify_wb = load_workbook(outfile, data_only=True)
vws = verify_wb[orig_sheetnames[0]]

print("Verification:")
print("Sheet names:", verify_wb.sheetnames)
print("I2/J2:", vws["I2"].value, vws["J2"].value)
print("Headers I5:M5:", [vws.cell(5, c).value for c in range(9, 14)])
print("First 10 output rows I:M:")
for r in range(6, min(last_written_row, 15) + 1):
    print(r, [vws.cell(r, c).value for c in range(9, 14)])

print("Last 5 output rows I:M:")
for r in range(max(6, last_written_row - 4), last_written_row + 1):
    print(r, [vws.cell(r, c).value for c in range(9, 14)])

# Check first empty row after output
next_row_vals = [vws.cell(last_written_row + 1, c).value for c in range(9, 14)] if last_written_row + 1 <= vws.max_row else None
print("Row after last output:", last_written_row + 1, next_row_vals)

# Style/format verification by loading non-data_only
style_wb = load_workbook(outfile)
sws = style_wb[orig_sheetnames[0]]
print("Format check source A:E vs target I:M for first output row:")
for src_c, dst_c in zip(src_cols, dest_cols):
    sc = sws.cell(matches[0][0], src_c)
    dc = sws.cell(6, dst_c)
    print(
        sc.coordinate, "->", dc.coordinate,
        "vals:", sc.value, dc.value,
        "fmt:", sc.number_format, dc.number_format,
        "style_ids:", sc.style_id, dc.style_id
    )

output_spreadsheet = outfile
print("Prepared output_spreadsheet =", output_spreadsheet)
