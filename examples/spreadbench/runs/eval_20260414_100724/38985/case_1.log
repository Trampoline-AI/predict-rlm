Code:
```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outpath = os.path.join(outdir, filename)

# Reload fresh workbook from input for modification
wb2 = load_workbook(infile)
original_sheetnames = wb2.sheetnames[:]
ws = wb2["Sheet1"]

# Build mapping from Table 2 (L:N), flatten Value1/Value2 pairs per duplicate name
mapping = {}
for r in range(7, ws.max_row + 1):
    name = ws[f"L{r}"].value
    v1 = ws[f"M{r}"].value
    v2 = ws[f"N{r}"].value
    if name not in (None, "", "…", "….."):
        mapping.setdefault(name, [])
        # only append actual data values
        if v1 not in (None, "", "…", "….."):
            mapping[name].append(v1)
        if v2 not in (None, "", "…", "….."):
            mapping[name].append(v2)

print("Flattened mapping to write:", mapping)

# Target range is D:I based on existing layout/header
target_start_col = 4  # D
target_end_col = 9    # I
changes = []

for r in range(7, ws.max_row + 1):
    name = ws[f"C{r}"].value
    if name in (None, "", "…", "….."):
        continue
    
    values = mapping.get(name, [])
    width = target_end_col - target_start_col + 1
    
    # Fill available values across D:I and clear remainder
    for offset in range(width):
        c = target_start_col + offset
        cell = ws.cell(r, c)
        desired = values[offset] if offset < len(values) else None
        current = cell.value
        
        if current != desired:
            changes.append((cell.coordinate, current, desired))
            cell.value = desired

print(f"Total cell changes made: {len(changes)}")
for coord, old, new in changes:
    print(f"{coord}: {old!r} -> {new!r}")

# Save
wb2.save(outpath)
print("Saved to:", outpath)

# Recalculate
recalc_result = await recalculate(outpath)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_check = load_workbook(outpath)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "restoring to", original_sheetnames)
    # rename by position
    for i, expected in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outpath)
    wb_check = load_workbook(outpath)

print("Final sheet names:", wb_check.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(outpath, data_only=True)
wsv = wb_verify["Sheet1"]

print("\nVerified target range C:I rows 6:11 (data_only):")
for r in range(6, 12):
    vals = []
    for c in range(3, 10):
        vals.append(f"{get_column_letter(c)}{r}={wsv.cell(r, c).value!r}")
    print(" | ".join(vals))

# Explicit verification of relevant rows
expected_rows = {}
for r in range(7, ws.max_row + 1):
    name = wsv[f"C{r}"].value
    if name not in (None, "", "…", "….."):
        expected = mapping.get(name, [])
        actual = [wsv.cell(r, c).value for c in range(target_start_col, target_end_col + 1)]
        expected_padded = expected + [None] * ((target_end_col - target_start_col + 1) - len(expected))
        expected_padded = expected_padded[:(target_end_col - target_start_col + 1)]
        expected_rows[r] = (name, expected_padded, actual)

print("\nRow-by-row verification:")
all_ok = True
for r, (name, expected_padded, actual) in expected_rows.items():
    ok = actual == expected_padded
    all_ok = all_ok and ok
    print(f"Row {r} name={name!r} expected={expected_padded} actual={actual} ok={ok}")

print("\nOverall verification passed:", all_ok)
```
