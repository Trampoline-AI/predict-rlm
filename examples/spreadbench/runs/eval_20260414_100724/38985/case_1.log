import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(path), path)

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def visible_value(v):
    try:
        if hasattr(v, "text"):
            return f"<FormulaObj text={v.text}>"
    except Exception:
        pass
    return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # find non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    nonempty_cols = []
    for c in range(1, ws.max_column + 1):
        vals = [ws.cell(r, c).value for r in range(1, ws.max_row + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_cols.append(c)
    print("Non-empty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("Non-empty cols:", [f"{get_column_letter(c)}" for c in nonempty_cols])
    
    # print first 10 rows with coordinates
    print("\nFirst up to 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        row = []
        for c in range(1, ws.max_column + 1):
            v = visible_value(ws.cell(r, c).value)
            row.append(f"{get_column_letter(c)}{r}={v!r}")
        print(" | ".join(row))
    
    # print last 5 non-empty rows
    print("\nLast up to 5 non-empty rows:")
    for r in nonempty_rows[-5:]:
        row = []
        for c in range(1, ws.max_column + 1):
            v = visible_value(ws.cell(r, c).value)
            row.append(f"{get_column_letter(c)}{r}={v!r}")
        print(" | ".join(row))
