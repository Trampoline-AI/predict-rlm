import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

def nonempty_row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = [ws.cell(r, c).value for c in range(1, max_cols + 1)]
    return vals

def preview_sheet(ws, first_n=10, last_n=5):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    print("merged ranges:", list(ws.merged_cells.ranges)[:10])

    # Find row counts with any data
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        row_vals = nonempty_row_values(ws, r)
        if any(v is not None and v != "" for v in row_vals):
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows), "first/last nonempty rows:",
          (nonempty_rows[:5], nonempty_rows[-5:] if nonempty_rows else []))

    # Print inferred headers from first few nonempty rows
    for r in nonempty_rows[:3]:
        vals = nonempty_row_values(ws, r)
        print(f"Row {r}:", vals)

    # Print first few rows
    print("\nFirst rows preview:")
    for r in range(1, min(ws.max_row, first_n) + 1):
        print(f"Row {r}: {nonempty_row_values(ws, r)}")

    # Print last few rows
    print("\nLast rows preview:")
    start_last = max(1, ws.max_row - last_n + 1)
    for r in range(start_last, ws.max_row + 1):
        print(f"Row {r}: {nonempty_row_values(ws, r)}")

    # Print coordinate grid for A1:H15 or available range
    print("\nDetailed A1:H15 area:")
    max_r = min(15, ws.max_row)
    max_c = min(8, ws.max_column)
    header = ["   "] + [get_column_letter(c) for c in range(1, max_c + 1)]
    print(header)
    for r in range(1, max_r + 1):
        row = [str(r)]
        for c in range(1, max_c + 1):
            v = ws.cell(r, c).value
            row.append(v)
        print(row)

for ws in wb.worksheets:
    preview_sheet(ws)

# Specific inspection mentioned by instruction
for ws in wb.worksheets:
    print(f"\nSpecific cell check in {ws.title}:")
    for coord in ["A1","B1","B2","C1","C2","D1","D2","D3","E1","E2"]:
        cell = ws[coord]
        print(coord, "value=", cell.value, "data_type=", cell.data_type)
