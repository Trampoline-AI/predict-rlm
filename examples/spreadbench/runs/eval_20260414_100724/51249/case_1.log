import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import column_index_from_string

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheets:", original_sheet_names)
print("Target column D index:", column_index_from_string("D"))

# Identify exact target rows: column C says "Result:"
target_rows = []
for r in range(1, ws.max_row + 1):
    if ws.cell(r, 3).value == "Result:":
        target_rows.append(r)

print("Target rows where column C == 'Result:':", target_rows)

# Requested fill color RGB 226-239-218
fill = PatternFill(start_color="FFE2EFDA", end_color="FFE2EFDA", fill_type="solid")

# Write formulas into each target D cell
for r in target_rows:
    b_curr = f"B{r}"
    b_next = f"B{r+1}"
    d_cell = ws[f"D{r}"]
    old_value = d_cell.value
    formula = (
        f'=IF(AND({b_curr}="Description A",{b_next}="Description B"),"Multiple",'
        f'IF(AND({b_curr}="Description A",OR({b_next}="",ISBLANK({b_next}))),"Single A",'
        f'IF(AND({b_curr}="Description B",OR({b_next}="",ISBLANK({b_next}))),"Single B","")))'
    )
    print(f"Row {r}: before D{r}={old_value!r}, B{r}={ws[b_curr].value!r}, B{r+1}={ws[b_next].value!r}")
    print(f"Row {r}: formula -> {formula}")
    d_cell.value = formula
    d_cell.fill = fill

# Save initial output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalc changed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_post.sheetnames)
    # Rename positionally back to originals
    for i, expected_name in enumerate(original_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = expected_name
    wb_post.save(output_path)
    print("Restored sheet names to:", wb_post.sheetnames)
else:
    print("Sheet names preserved after recalc.")

# Verify formulas and recalculated values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("\nVerification of target cells:")
for r in target_rows:
    formula_val = ws_formula[f"D{r}"].value
    data_val = ws_values[f"D{r}"].value
    fill_rgb = ws_formula[f"D{r}"].fill.start_color.rgb
    print(
        f"D{r}: formula={formula_val!r}, value={data_val!r}, fill_rgb={fill_rgb}, "
        f"B{r}={ws_values[f'B{r}'].value!r}, B{r+1}={ws_values[f'B{r+1}'].value!r}"
    )
    assert data_val not in (None, ""), f"D{r} should not be blank"
    assert fill_rgb in ("FFE2EFDA", "00E2EFDA"), f"Unexpected fill for D{r}: {fill_rgb}"

print("Final sheet names:", wb_values.sheetnames)
print("Output ready:", output_path)
```
