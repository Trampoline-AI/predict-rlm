import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from datetime import datetime, time

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sample Data"]

# Confirm target area again briefly
print("Original sheet names:", original_sheetnames)
print("Target headers:", [ws.cell(11, c).value for c in range(6, 11)])
print("Target dates:", [ws.cell(r, 6).value for r in range(12, 17)])

# Determine actual source data extent from A:D
source_start_row = 4
source_end_row = 0
for r in range(ws.max_row, source_start_row - 1, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 5)):
        source_end_row = r
        break
print("Source data rows:", source_start_row, "to", source_end_row)

# Determine target rows in column F beneath the Date header
target_date_rows = []
r = 12
while r <= ws.max_row and ws.cell(r, 6).value not in (None, ""):
    target_date_rows.append(r)
    r += 1
print("Target date rows:", target_date_rows)

# Write formulas into G:J where a next date exists
# Cumulative subtraction pattern:
# sum from current start onward - sum after next window end
# plus product condition based on header row
for r in target_date_rows:
    next_date = ws.cell(r + 1, 6).value if r + 1 <= ws.max_row else None
    for c in range(7, 11):
        coord = f"{get_column_letter(c)}{r}"
        header_ref = f"{get_column_letter(c)}$11"
        if next_date not in (None, ""):
            formula = (
                f'=IF($F{r+1}="","",'
                f'SUMPRODUCT((($A${source_start_row}:$A${source_end_row}+$B${source_start_row}:$B${source_end_row})>=($F{r}+$F$1))'
                f'*($C${source_start_row}:$C${source_end_row}={header_ref})'
                f'*$D${source_start_row}:$D${source_end_row})'
                f'-SUMPRODUCT((($A${source_start_row}:$A${source_end_row}+$B${source_start_row}:$B${source_end_row})>($F{r+1}+$F$2))'
                f'*($C${source_start_row}:$C${source_end_row}={header_ref})'
                f'*$D${source_start_row}:$D${source_end_row}))'
            )
            ws[coord] = formula
        else:
            ws[coord] = None

# Change formatting of G12:J15 from accounting to currency
currency_format = '"$"#,##0.00'
for r in range(12, 16):
    for c in range(7, 11):
        ws.cell(r, c).number_format = currency_format

# Leave final row blank when no next date exists
for c in range(7, 11):
    ws.cell(16, c).value = None

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename by position to restore original names
    for idx, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas and displayed values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sample Data"]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sample Data"]

print("\nWritten formulas in G12:J16")
for r in range(12, 17):
    print(
        r,
        [ws_formula.cell(r, c).value for c in range(7, 11)],
        [ws_formula.cell(r, c).number_format for c in range(7, 11)]
    )

print("\nCalculated values in G12:J16")
for r in range(12, 17):
    print(r, [ws_values.cell(r, c).value for c in range(7, 11)])

# Compute expected values in Python for sanity-check
transactions = []
for r in range(source_start_row, source_end_row + 1):
    d = ws_values.cell(r, 1).value
    t = ws_values.cell(r, 2).value
    p = ws_values.cell(r, 3).value
    s = ws_values.cell(r, 4).value
    if d is None or t is None or p in (None, "") or s in (None, ""):
        continue
    d0 = d.date() if hasattr(d, "date") else d
    dt = datetime.combine(d0, t)
    transactions.append((dt, p, float(s)))

headers = [ws_values.cell(11, c).value for c in range(7, 11)]
print("\nExpected vs actual for rows with next date:")
for r in range(12, 16):
    cur = ws_values.cell(r, 6).value
