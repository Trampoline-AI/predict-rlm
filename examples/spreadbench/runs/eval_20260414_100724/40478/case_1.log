        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            a = ws.cell(r, 1).value
            b = ws.cell(r, 2).value if ws.max_column >= 2 else None
            print(f"Row {r}: A={a!r} | B={b!r}")
    
    # Identify non-empty rows in A/B
