Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook normally for writing
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheetnames:", original_sheetnames)
print("Before writing, column B values:")
for r in range(1, ws.max_row + 1):
    print(f"Row {r}: A={ws.cell(r,1).value!r}, B={ws.cell(r,2).value!r}")

# Write formula in column B for every non-empty A row
for r in range(1, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    if a_val not in (None, ""):
        formula = f'=TRIM(MID(A{r},FIND(" ",A{r},FIND(" ",A{r})+1)+1,FIND("-",A{r})-FIND(" ",A{r},FIND(" ",A{r})+1)-1))'
        ws.cell(r, 2).value = formula

print("\nAfter writing formulas in column B:")
for r in range(1, ws.max_row + 1):
    print(f"B{r} formula/value -> {ws.cell(r,2).value!r}")

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if changed
wb_check = load_workbook(outfile)
print("Sheetnames after recalc reload:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for old_name, desired_name in zip(wb_check.sheetnames[:], original_sheetnames):
        if old_name != desired_name:
            wb_check[old_name].title = desired_name
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify with data_only=True
wb_values = load_workbook(outfile, data_only=True)
print("Verified sheetnames:", wb_values.sheetnames)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerified target cells in column B:")
for r in range(1, ws_values.max_row + 1):
    print(f"Row {r}: A={ws_values.cell(r,1).value!r}, B={ws_values.cell(r,2).value!r}")

output_spreadsheet = outfile
```
