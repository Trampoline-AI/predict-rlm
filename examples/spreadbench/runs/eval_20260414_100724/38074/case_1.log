from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
import shutil

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Fresh inspection load
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Instruction:", instruction)
print("Original sheet names:", orig_sheetnames)
print("Sheet dimensions:", ws.max_row, ws.max_column)

# Identify actual data extent based on non-empty rows in col A/B-ish area
last_data_row = 1
for r in range(2, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 8)):
        last_data_row = r
print("Detected last data row for main table:", last_data_row)

# Print relevant headers and rows
headers = {get_column_letter(c): ws.cell(1, c).value for c in range(1, ws.max_column + 1)}
print("Headers by column:", headers)

print("\nRelevant data rows A:G:")
for r in range(1, last_data_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 8)]
    print(f"R{r} A:G -> {vals}")

print("\nTarget / criteria area J:K")
for r in range(1, 6):
    print(f"R{r} J={ws[f'J{r}'].value!r}, K={ws[f'K{r}'].value!r}, K_number_format={ws[f'K{r}'].number_format!r}")

# Compute expected values in Python for sanity-check
criteria_rows = []
for r in range(2, 6):
    crit = ws[f"J{r}"].value
    if crit not in (None, ""):
        total = 0
        matching_rows = []
        for rr in range(2, last_data_row + 1):
            if ws[f"A{rr}"].value == crit:  # case-sensitive Python comparison
                b = ws[f"B{rr}"].value or 0
                c = ws[f"C{rr}"].value or 0
                e = ws[f"E{rr}"].value or 0
                g = ws[f"G{rr}"].value or 0
                row_profit = b - c - e - g
                total += row_profit
                matching_rows.append((rr, ws[f"A{rr}"].value, b, c, e, g, row_profit))
        criteria_rows.append((r, crit, total, matching_rows))

print("\nPython sanity-check totals by J criteria:")
for r, crit, total, matches in criteria_rows:
    print(f"J{r}={crit!r} -> expected total {total}")
    print("  matches:", matches)

# Write formulas to K2:K5
# Case-sensitive vectorized operation via SUMPRODUCT + EXACT
# N(range) converts blanks to 0 and numbers to themselves
for r in range(2, 6):
    if ws[f"J{r}"].value not in (None, ""):
        formula = f'=SUMPRODUCT(--EXACT($A$2:$A${last_data_row},J{r}),N($B$2:$B${last_data_row})-N($C$2:$C${last_data_row})-N($E$2:$E${last_data_row})-N($G$2:$G${last_data_row}))'
        ws[f"K{r}"] = formula
        ws[f"K{r}"].number_format = "0"

print("\nWritten formulas:")
for r in range(2, 6):
    print(f"K{r} formula -> {ws[f'K{r}'].value!r}, format={ws[f'K{r}'].number_format!r}")

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    for i, expected_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected_name
    wb_after.save(output_path)
    print("Renamed sheets back to original names:", orig_sheetnames)
else:
    print("No sheet rename needed.")

# Verify formulas still present
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
print("\nVerification - formulas in K2:K5")
for r in range(2, 6):
    print(f"K{r}: formula={ws_formula[f'K{r}'].value!r}, format={ws_formula[f'K{r}'].number_format!r}")

# Verify cached values
wb_values = load_workbook(output_path, data_only=True)
