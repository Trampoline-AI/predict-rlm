print(f"\nGenerated total outputs: {len(generated)}")
print(f"Existing Sheet3 outputs (excluding header): {len(sheet3_vals)-1}")

# Compare generated vs existing
existing_set = sheet3_vals[1:]
missing_from_sheet3 = [x for x in generated if x not in existing_set]
extra_in_sheet3 = [x for x in existing_set if x not in generated]

print("\n=== COMPARISON ===")
