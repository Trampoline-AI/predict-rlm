from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, textwrap

print("Instruction:")
print(instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_info(ws, sample_n=8):
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # print merged ranges if any
    if ws.merged_cells.ranges:
        print("Merged ranges:", list(ws.merged_cells.ranges)[:10])
    else:
        print("Merged ranges: none")
    
    # detect non-empty rows/cols roughly
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:")
    for c, v in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}1 = {v!r}")
    
    # print first 10 rows
    first_rows = min(ws.max_row, sample_n)
    print(f"\nFirst {first_rows} rows:")
    for r in range(1, first_rows + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast rows {start_last} to {ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")

for ws in wb.worksheets:
    sheet_info(ws)

# Look for likely relevant columns / example text across sheets
search_terms = ["Entry", "Output", "U4_ComponentPropertyForm", "Header"]
print("\nSearching workbook for relevant terms...")
for ws in wb.worksheets:
    hits = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                for term in search_terms:
                    if term.lower() in v.lower():
                        hits.append((r, c, v))
                        break
    print(f"{ws.title}: {len(hits)} hits")
    for hit in hits[:20]:
        r, c, v = hit
        print(f"  {get_column_letter(c)}{r}: {v!r}")

# Save workbook object for later iterations
orig_sheetnames = wb.sheetnames
