```repl
from openpyxl import load_workbook
from collections import OrderedDict
import os
from shutil import copyfile

# Load workbook fresh
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
s1 = wb["Sheet1"]
s2 = wb["Sheet2"]
s3 = wb["Sheet3"]

# Reconfirm target area
print("Target sheet/column verification:")
print("Sheet3 header A1 =", s3["A1"].value)
print("Sheet1 header A1 =", s1["A1"].value)
print("Sheet2 headers =", [s2.cell(1, c).value for c in range(1, s2.max_column + 1)])

# Build Sheet2 mapping: header -> non-empty field names
sheet2_map = OrderedDict()
for c in range(1, s2.max_column + 1):
    hdr = s2.cell(1, c).value
    vals = []
    for r in range(2, s2.max_row + 1):
        v = s2.cell(r, c).value
        if v not in (None, ""):
            vals.append(str(v).strip())
    sheet2_map[str(hdr).strip()] = vals

# Read Sheet1 entries
sheet1_entries = []
for r in range(2, s1.max_row + 1):
    v = s1.cell(r, 1).value
    if v not in (None, ""):
        sheet1_entries.append((r, str(v).strip()))

# Generate outputs in the exact observed pattern:
# loop Sheet2 headers left->right, then matching Sheet1 entries top->bottom
generated = []
match_summary = []
for hdr, suffixes in sheet2_map.items():
    matching_rows = [(r, entry) for r, entry in sheet1_entries if hdr in entry]
    if matching_rows:
        match_summary.append((hdr, len(matching_rows), len(suffixes), len(matching_rows) * len(suffixes)))
    for r, entry in matching_rows:
        for suffix in suffixes:
            generated.append(entry + suffix)

print("\nGeneration summary:")
for hdr, n_entries, n_suffixes, total in match_summary:
    print(f"  {hdr}: {n_entries} matching Sheet1 rows x {n_suffixes} non-empty Sheet2 rows = {total}")
print("Total generated outputs:", len(generated))

# Print sample generated rows
print("\nFirst 12 generated outputs:")
for i, x in enumerate(generated[:12], start=2):
    print(f"A{i}: {x}")
print("\nLast 12 generated outputs:")
start_idx = max(0, len(generated) - 12)
for i, x in enumerate(generated[start_idx:], start=2 + start_idx):
    print(f"A{i}: {x}")

# Show current Sheet3 before overwrite
print("\nCurrent Sheet3 existing rows:", s3.max_row)
print("Current Sheet3 first 8 data rows:")
for r in range(1, min(s3.max_row, 9) + 1):
    print(f"A{r}: {s3.cell(r,1).value!r}")
print("Current Sheet3 last 5 rows:")
for r in range(max(1, s3.max_row - 4), s3.max_row + 1):
    print(f"A{r}: {s3.cell(r,1).value!r}")

# Write into existing Sheet3 column A under Output
s3["A1"] = "Output"

# Clear existing data rows in column A below header, enough to avoid leftovers
clear_to = max(s3.max_row, len(generated) + 5)
for r in range(2, clear_to + 1):
    s3.cell(r, 1).value = None

# Fill new outputs
for idx, value in enumerate(generated, start=2):
    s3.cell(idx, 1).value = value

# Save to output path with same filename
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload, restore sheet names if recalc changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring to", orig_sheetnames)
    for ws, orig_name in zip(wb_after.worksheets, orig_sheetnames):
        ws.title = orig_name
    wb_after.save(output_path)
    wb_after = load_workbook(output_path)

print("Final sheet names:", wb_after.sheetnames)

# Verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
vs3 = wb_verify["Sheet3"]

print("\nVerification:")
print("Sheet3 A1 =", vs3["A1"].value)
print("Expected output count:", len(generated))
nonblank_rows = []
for r in range(2, len(generated) + 2):
    val = vs3.cell(r, 1).value
    if val not in (None, ""):
        nonblank_rows.append((r, val))
print("Verified nonblank output rows in target range:", len(nonblank_rows))

# Compare exact values
mismatches = []
for i, expected in enumerate(generated, start=2):
    actual = vs3.cell(i, 1).value
    if actual != expected:
        mismatches.append((i, expected, actual))

print("Mismatch count:", len(mismatches))
if mismatches:
    for rownum, exp, act in mismatches[:10]:
        print(f"  Row {rownum}: expected={exp!r} actual={act!r}")

print("\nVerified first 10 target cells:")
for r in range(1, min(len(generated) + 1, 11) + 0):
    print(f"A{r}: {vs3.cell(r,1).value!r}")

print("\nVerified last 10 target cells:")
start_r = max(1, len(generated) + 2 - 10)
for r in range(start_r, len(generated) + 2):
    print(f"A{r}: {vs3.cell(r,1).value!r}")

# Keep output_path available for submission
final_output_spreadsheet = output_path
print("\nReady to submit:", final_output_spreadsheet)
