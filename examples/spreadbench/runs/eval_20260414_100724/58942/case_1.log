wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_spreadsheet)
print("Instruction:", instruction)
print("Original sheet names:", orig_sheet_names)

def nonempty_bounds(ws):
    min_row = min_col = None
    max_row = max_col = None
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                if min_row is None or cell.row < min_row:
                    min_row = cell.row
                if min_col is None or cell.column < min_col:
                    min_col = cell.column
                if max_row is None or cell.row > max_row:
                    max_row = cell.row
                if max_col is None or cell.column > max_col:
                    max_col = cell.column
    return min_row, min_col, max_row, max_col

def row_values(ws, r, max_col=None):
    if max_col is None:
        max_col = ws.max_column
    vals = []
    for c in range(1, max_col + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

for ws in wb.worksheets:
    print("\n=== SHEET ===", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    bounds = nonempty_bounds(ws)
    print("nonempty_bounds (min_row, min_col, max_row, max_col):", bounds)
    if bounds[0] is not None:
        mr1, mc1, mr2, mc2 = bounds
        header_preview_cols = min(max(ws.max_column, mc2), 10)
        print("Row 1:", row_values(ws, 1, header_preview_cols))
        if ws.max_row >= 2:
            print("Row 2:", row_values(ws, 2, header_preview_cols))
        if ws.max_row >= 3:
            print("Row 3:", row_values(ws, 3, header_preview_cols))

        # first 10 rows
        first_end = min(ws.max_row, 10)
        print(f"First {first_end} rows (A:J or up to max col):")
        sample_cols = min(ws.max_column, 10)
        for r in range(1, first_end + 1):
            print(f"R{r}:", row_values(ws, r, sample_cols))

        # last 5 rows
        if ws.max_row > 10:
            print("Last 5 rows:")
            for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
                print(f"R{r}:", row_values(ws, r, sample_cols))

        # specific range E1:F6 requested in instruction
        print("Specific range E1:F6:")
        for r in range(1, 7):
            print(f"R{r} E:F ->", [ws.cell(r, 5).value, ws.cell(r, 6).value])

        # nearby target area A:F, first 15 rows, including formulas
