from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from copy import copy
from datetime import datetime, date
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

def norm_date(v):
    if v is None or v == "":
        return None
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    return v

# Load and inspect the exact relevant ranges
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Using sheet:", ws.title)
print("Headers A:F:", [ws.cell(1, c).value for c in range(1, 7)])
print("Source E1:F6:")
for r in range(1, 7):
    print(r, ws.cell(r, 5).value, ws.cell(r, 6).value)
print("Target area before write A2:C11:")
for r in range(2, 12):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

# Identify actual source rows in E:F and target rows in A
source_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 5).value not in (None, "") or ws.cell(r, 6).value not in (None, ""):
        source_rows.append(r)

target_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 1).value not in (None, ""):
        target_rows.append(r)

print("Detected source rows:", source_rows)
print("Detected target rows:", target_rows)

# Build date -> value mapping from source data
source_map = {}
for r in source_rows:
    d = ws.cell(r, 5).value
    v = ws.cell(r, 6).value
    nd = norm_date(d)
    if nd is not None:
        source_map[nd] = v

print("Source mapping:", source_map)

# Fill B:C aligned to timeline in A
for r in target_rows:
    timeline_val = ws.cell(r, 1).value
    nd = norm_date(timeline_val)

    b_cell = ws.cell(r, 2)
    c_cell = ws.cell(r, 3)

    if nd in source_map:
        # Write matched date and value
        b_cell.value = timeline_val
        b_cell.number_format = ws.cell(r, 1).number_format
        c_cell.value = source_map[nd]
    else:
        # Clear non-matching rows in target output area
        b_cell.value = None
        c_cell.value = None

print("Target area after write, before save A2:C11:")
for r in range(2, 12):
    print(r, [ws.cell(r, c).value for c in range(1, 4)])

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_post.sheetnames, "-> restoring to", orig_sheet_names)
    for i, name in enumerate(orig_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = name
    wb_post.save(output_path)
else:
    print("Sheet names preserved:", wb_post.sheetnames)

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

print("Verified target area A2:C11:")
for r in range(2, 12):
    row_vals = [wsv.cell(r, c).value for c in range(1, 4)]
    print(r, row_vals)

# Store output path for submission next turn
final_output_spreadsheet = output_path
print("final_output_spreadsheet =", final_output_spreadsheet)
