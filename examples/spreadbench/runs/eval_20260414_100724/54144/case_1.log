import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path, os.path.exists(input_path))

wb = load_workbook(input_path)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws, sample_first=10, sample_last=5, max_cols=20):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # row counts with any non-empty data
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows))
    
    # print first few rows
    rows_to_show = list(range(1, min(ws.max_row, sample_first) + 1))
    if ws.max_row > sample_first:
        rows_to_show += list(range(max(1, ws.max_row - sample_last + 1), ws.max_row + 1))
    rows_to_show = sorted(set(rows_to_show))
    
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols) + 1)]
        print(f"Row {r}: {vals}")
        
for s in wb.sheetnames:
    sheet_summary(wb[s], sample_first=10, sample_last=5, max_cols=15)

# More focused inspection of Data and Report if present
for s in ["Data", "Report"]:
    if s in wb.sheetnames:
        ws = wb[s]
        print(f"\nFocused headers for {s}:")
        for c in range(1, ws.max_column + 1):
            print(c, get_column_letter(c), ws.cell(1, c).value)
