import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
data_ws = wb["Data"]
report_ws = wb["Report"]

# Determine actual data extent on Data sheet
data_start_row = 3
data_end_row = max(
    r for r in range(1, data_ws.max_row + 1)
    if any(data_ws.cell(r, c).value not in (None, "") for c in range(1, data_ws.max_column + 1))
)
report_end_row = max(
    r for r in range(1, report_ws.max_row + 1)
    if any(report_ws.cell(r, c).value not in (None, "") for c in range(1, report_ws.max_column + 1))
)

print("Original sheet names:", original_sheetnames)
print("Data rows used in formulas:", data_start_row, "to", data_end_row)
print("Report rows considered:", 3, "to", report_end_row)

# Show target cells before writing
print("\nTarget cells before writing:")
for r in range(3, report_end_row + 1):
    print(f"D{r} -> {report_ws[f'D{r}'].value!r}")

# Write formulas only into blank target cells in Report!D
written = []
for r in range(3, report_end_row + 1):
    target = report_ws.cell(r, 4)  # column D
    if target.value in (None, ""):
        formula = (
            f'=ROUND(SUMPRODUCT('
            f'(Data!$A${data_start_row}:$A${data_end_row}=A{r})*'
            f'(Data!$B${data_start_row}:$B${data_end_row}=B{r})*'
            f'(ISNUMBER(SEARCH(","&Data!$C${data_start_row}:$C${data_end_row}&",",'
            f'","&SUBSTITUTE(C{r}," ","")&",")))*'
            f'Data!$D${data_start_row}:$D${data_end_row}'
            f'),2)'
        )
        target.value = formula
        written.append((r, formula))

print("\nFormulas written:")
for r, formula in written:
    print(f"D{r} = {formula}")

# Save and recalculate
wb.save(output_path)
print("\nSaved to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # rename by position back to original
    for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheetnames)
else:
    print("Sheet names preserved.")

# Verify formulas / values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
report_formula = wb_formula["Report"]
report_values = wb_values["Report"]

print("\nVerification of Report!D3:D10")
problems = []
for r in range(3, report_end_row + 1):
    formula_or_value = report_formula.cell(r, 4).value
    cached_value = report_values.cell(r, 4).value
    print(f"Row {r}: formula/value={formula_or_value!r} | cached={cached_value!r}")
    if cached_value in (None, ""):
        problems.append(r)

# Fallback to Python-computed literal values if any formula did not evaluate
if problems:
    print("\nFormula verification failed for rows:", problems)
    print("Falling back to Python-computed literal values for those rows.")

    wb_fix = load_workbook(output_path)
    data_ws = wb_fix["Data"]
    report_ws = wb_fix["Report"]

    # Build Data records
    records = []
    for rr in range(data_start_row, data_end_row + 1):
        vals = [data_ws.cell(rr, c).value for c in range(1, 5)]
        if any(v not in (None, "") for v in vals):
            records.append({
                "date": data_ws.cell(rr, 1).value,
                "supplier": data_ws.cell(rr, 2).value,
                "truck": str(data_ws.cell(rr, 3).value).strip() if data_ws.cell(rr, 3).value is not None else "",
                "qty": data_ws.cell(rr, 4).value or 0,
            })

    def parse_trucks(v):
        if v is None:
            return []
        return [p.strip() for p in str(v).split(",") if p.strip()]

    for r in problems:
        rep_date = report_ws.cell(r, 1).value
        rep_supplier = report_ws.cell(r, 2).value
        rep_trucks = set(parse_trucks(report_ws.cell(r, 3).value))
        total = round(sum(
            rec["qty"] for rec in records
            if rec["date"] == rep_date and rec["supplier"] == rep_supplier and rec["truck"] in rep_trucks
        ), 2)
        report_ws.cell(r, 4).value = total
        print(f"Fallback wrote D{r} = {total}")

    wb_fix.save(output_path)

    # verify again
    wb_check = load_workbook(output_path, data_only=True)
    report_check = wb_check["Report"]
    print("\nPost-fallback verification:")
    for r in range(3, report_end_row + 1):
        print(f"D{r} -> {report_check.cell(r, 4).value!r}")

# Final concise target-range print
wb_final = load_workbook(output_path, data_only=True)
report_final = wb_final["Report"]
print("\nFinal target values Report!D3:D10:")
for r in range(3, report_end_row + 1):
    print(f"D{r} = {report_final.cell(r, 4).value!r}")
