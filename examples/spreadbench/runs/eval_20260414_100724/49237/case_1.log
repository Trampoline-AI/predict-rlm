from openpyxl import load_workbook
import os, shutil

# Reload both formula view and cached-value view for deeper inspection
wb_formula = load_workbook(input_spreadsheet, data_only=False)
wb_values = load_workbook(input_spreadsheet, data_only=True)
wsf = wb_formula[wb_formula.sheetnames[0]]
wsv = wb_values[wb_values.sheetnames[0]]

print("Instruction target check:")
for coord in ["B3","B7","E18","E19","E20","E5","E7","E9","F6","F7","F8","F10","E11","E12","E13","E20"]:
    print(
        coord,
        "| formula/raw:", wsf[coord].value,
        "| cached/data_only:", wsv[coord].value
    )

print("\nRelevant nearby block E5:F12 (formula/raw):")
for r in range(5, 13):
    print(r, [wsf.cell(r, c).value for c in range(5, 7)])

# Prepare output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, out_path)

# Modify only the exact target cell F7 after confirming current formula
wb_out = load_workbook(out_path)
ws = wb_out[wb_out.sheetnames[0]]
print("\nBefore change F7:", ws["F7"].value)

# Use F10 (not F7 itself) to avoid circular reference.
# If F10 has text, take its first character and append a period; otherwise blank.
ws["F7"] = '=IF(TRIM(F10)="","",LEFT(TRIM(F10),1)&".")'

print("After change F7 formula:", ws["F7"].value)

original_sheetnames = wb_out.sheetnames[:]
wb_out.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Check if sheet names changed; restore if needed
wb_post = load_workbook(out_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames:
    # rename back by position
    for ws_obj, orig_name in zip(wb_post.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_post.save(out_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify with formula view and data_only view
verify_formula = load_workbook(out_path, data_only=False)
verify_values = load_workbook(out_path, data_only=True)
wvf = verify_formula[original_sheetnames[0]]
wvv = verify_values[original_sheetnames[0]]

print("\nVERIFICATION")
for coord in ["E5","E7","E9","F10","F7"]:
    print(
        coord,
        "| formula/raw:", wvf[coord].value,
        "| data_only:", wvv[coord].value
    )

output_spreadsheet = out_path
```
