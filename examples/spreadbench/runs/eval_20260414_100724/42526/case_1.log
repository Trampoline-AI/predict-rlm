```repl
import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load and inspect thoroughly
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
print("Original sheet names:", orig_sheetnames)

ws = wb[orig_sheetnames[0]]
print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)

headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
print("Headers:", headers)

print("\nAll data rows:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

print("\nCurrent target area B2:C16 before writing:")
for r in range(2, 17):
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    print(f"Row {r}: A={ws[f'A{r}'].value}, B={b!r}, C={c!r}")

# Identify actual data extent in column A (rows with numeric values under header)
data_rows = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if v is not None and v != "":
        data_rows.append(r)

print("\nDetected data rows:", data_rows)
start_row, end_row = min(data_rows), max(data_rows)
print("Using range A%d:A%d" % (start_row, end_row))

# Write formulas and formatting
gray_fill = PatternFill(start_color="A6A6A6", end_color="A6A6A6", fill_type="solid")
score_numfmt = "0.###########"  # 0 decimals for integers, 1 if only 1 needed, up to 11 otherwise

for r in data_rows:
    # proportional score around zero, anchored to max positive and min negative
    score_formula = (
        f'=IF(A{r}=0,0,IF(A{r}>0,A{r}/MAX($A${start_row}:$A${end_row})*5,'
        f'A{r}/ABS(MIN($A${start_row}:$A${end_row}))*5))'
    )
    rank_formula = f'=RANK(B{r},$B${start_row}:$B${end_row},0)'
    ws[f"B{r}"] = score_formula
    ws[f"C{r}"] = rank_formula
    ws[f"B{r}"].fill = gray_fill
    ws[f"B{r}"].number_format = score_numfmt
    ws[f"C{r}"].number_format = "0"

print("\nWritten formulas:")
for r in data_rows:
    print(f"Row {r}: B{r}={ws[f'B{r}'].value}, C{r}={ws[f'C{r}'].value}")

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open and fix sheet names if recalculate changed them
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    # rename sheets back by position
    for i, orig_name in enumerate(orig_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = orig_name
    wb_post.save(outfile)
    print("Renamed sheets back to:", wb_post.sheetnames)

# Verify with formulas visible
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula[orig_sheetnames[0]]

print("\nVerification - formulas and formats in target cells:")
for r in data_rows:
    print(
        f"Row {r}: A={wsf[f'A{r}'].value}, "
        f"B_formula={wsf[f'B{r}'].value}, B_numfmt={wsf[f'B{r}'].number_format}, "
        f"C_formula={wsf[f'C{r}'].value}, "
        f"B_fill={wsf[f'B{r}'].fill.fill_type}/{wsf[f'B{r}'].fill.start_color.rgb}"
    )

# Verify cached calculated values
wb_verify_vals = load_workbook(outfile, data_only=True)
wsv = wb_verify_vals[orig_sheetnames[0]]

print("\nVerification - calculated values B2:C16:")
verification_ok = True
for r in data_rows:
    a = wsv[f"A{r}"].value
    b = wsv[f"B{r}"].value
    c = wsv[f"C{r}"].value
    print(f"Row {r}: A={a}, B={b}, C={c}")
    if b is None or c is None:
        verification_ok = False

print("Verification OK:", verification_ok)

output_spreadsheet = outfile
