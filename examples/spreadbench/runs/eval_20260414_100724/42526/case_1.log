import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

path = input_spreadsheet
wb = load_workbook(path)
print("\nWorkbook sheets:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # find a practical used range by scanning for non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    if nonempty_rows:
        print("non-empty row span:", min(nonempty_rows), "to", max(nonempty_rows), "count", len(nonempty_rows))
    else:
        print("No non-empty rows")
        return
    
    # print first 10 rows and last 5 non-empty rows
    rows_to_show = []
    rows_to_show.extend(nonempty_rows[:10])
    for r in nonempty_rows[-5:]:
        if r not in rows_to_show:
            rows_to_show.append(r)
    print("Rows to show:", rows_to_show)
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # Candidate header rows among first few rows
    print("Candidate headers:")
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Header candidate row {r}: {vals}")
    
    # Print column letters and row1 values
    print("Column mapping:")
    for c in range(1, ws.max_column + 1):
        print(f"{get_column_letter(c)}: {ws.cell(1,c).value}")

for ws in wb.worksheets:
    sheet_info(ws)
