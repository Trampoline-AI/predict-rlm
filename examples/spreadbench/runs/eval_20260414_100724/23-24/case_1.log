```repl
import os
from copy import copy
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload fresh workbook for editing
wb_edit = load_workbook(input_path)
original_sheet_names = wb_edit.sheetnames[:]
ws = wb_edit[original_sheet_names[0]]

# Find true extents
last_AE = 0
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 6)):
        last_AE = r
        break

last_I = 0
for r in range(ws.max_row, 0, -1):
    if ws.cell(r, 9).value not in (None, ""):
        last_I = r
        break

print("Before edit - last_AE:", last_AE, "last_I:", last_I)

# Build lookup set from column I
colI_set = {
    ws.cell(r, 9).value
    for r in range(1, last_I + 1)
    if ws.cell(r, 9).value not in (None, "")
}

# Gather source rows A:E and whether they are kept
source_rows = []
kept_rows = []
removed_rows = []

for r in range(1, last_AE + 1):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    styles = [copy(ws.cell(r, c)._style) for c in range(1, 6)]
    fills = [copy(ws.cell(r, c).fill) for c in range(1, 6)]
    fonts = [copy(ws.cell(r, c).font) for c in range(1, 6)]
    borders = [copy(ws.cell(r, c).border) for c in range(1, 6)]
    aligns = [copy(ws.cell(r, c).alignment) for c in range(1, 6)]
    protections = [copy(ws.cell(r, c).protection) for c in range(1, 6)]
    numfmts = [ws.cell(r, c).number_format for c in range(1, 6)]
    row_record = {
        "row": r,
        "vals": vals,
        "styles": styles,
        "fills": fills,
        "fonts": fonts,
        "borders": borders,
        "aligns": aligns,
        "protections": protections,
        "numfmts": numfmts,
    }
    source_rows.append(row_record)
    a = vals[0]
    if a not in (None, "") and a in colI_set:
        removed_rows.append(row_record)
    else:
        kept_rows.append(row_record)

print("Rows in A:E:", len(source_rows))
print("Rows removed:", len(removed_rows))
print("Rows kept:", len(kept_rows))
print("First 10 removed words:", [r["vals"][0] for r in removed_rows[:10]])
print("First 10 kept words:", [r["vals"][0] for r in kept_rows[:10]])

# Rewrite compacted A:E at the top, preserving basic formatting from source rows
for out_r, rec in enumerate(kept_rows, start=1):
    for c in range(1, 6):
        cell = ws.cell(out_r, c)
        cell.value = rec["vals"][c - 1]
        cell._style = copy(rec["styles"][c - 1])
        cell.fill = copy(rec["fills"][c - 1])
        cell.font = copy(rec["fonts"][c - 1])
        cell.border = copy(rec["borders"][c - 1])
        cell.alignment = copy(rec["aligns"][c - 1])
        cell.protection = copy(rec["protections"][c - 1])
        cell.number_format = rec["numfmts"][c - 1]

# Clear the remainder of A:E below the compacted block
for r in range(len(kept_rows) + 1, last_AE + 1):
    for c in range(1, 6):
        ws.cell(r, c).value = None

# Save edited workbook
wb_edit.save(output_path)
print("Saved edited workbook to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# After recalc, restore original sheet names if LibreOffice changed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_post.sheetnames)
    for idx, original_name in enumerate(original_sheet_names):
        wb_post.worksheets[idx].title = original_name
    wb_post.save(output_path)
    print("Restored sheet names to:", wb_post.sheetnames)
else:
    print("Sheet names preserved:", wb_post.sheetnames)

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

# Verify counts and remaining matches
verify_last_A = 0
for r in range(wsv.max_row, 0, -1):
    if wsv.cell(r, 1).value not in (None, ""):
        verify_last_A = r
        break

verify_last_I = 0
for r in range(wsv.max_row, 0, -1):
    if wsv.cell(r, 9).value not in (None, ""):
        verify_last_I = r
        break

verify_I_set = {
    wsv.cell(r, 9).value
    for r in range(1, verify_last_I + 1)
    if wsv.cell(r, 9).value not in (None, "")
}
remaining_matches = []
for r in range(1, verify_last_A + 1):
    a = wsv.cell(r, 1).value
    if a not in (None, "") and a in verify_I_set:
        remaining_matches.append((r, a))

print("\nVERIFICATION")
print("Sheet names:", wb_verify.sheetnames)
print("verify_last_A:", verify_last_A, "expected kept:", len(kept_rows))
print("verify_last_I:", verify_last_I)
print("remaining matches in A vs I:", len(remaining_matches))
print("First remaining matches (should be empty):", remaining_matches[:10])

print("\nFirst 12 rows A:I after edit:")
for r in range(1, min(12, wsv.max_row) + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 10)])

print("\nRows around new end of A block:")
for r in range(max(1, len(kept_rows) - 5), min(wsv.max_row, len(kept_rows) + 5) + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 10)])

print("\nLast 5 non-empty I rows:")
for r in range(max(1, verify_last_I - 4), verify_last_I + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 10)])

final_output_spreadsheet = output_path
print("\nPrepared output file:", final_output_spreadsheet)
