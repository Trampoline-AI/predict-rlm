import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_c = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_c + 1)]

sheet_summaries = {}
for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    
    # find last non-empty row more accurately
    last_nonempty = 0
    for r in range(ws.max_row, 0, -1):
        vals = row_values(ws, r, ws.max_column)
        if any(v is not None and v != "" for v in vals):
            last_nonempty = r
            break
    print("Last non-empty row:", last_nonempty)
    
    first_n = min(last_nonempty, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    if last_nonempty > 10:
        print("Last 5 non-empty rows:")
        for r in range(max(1, last_nonempty - 4), last_nonempty + 1):
            print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # specifically inspect A:I because instruction references A and I, and B:E to delete
    print("Relevant columns A:I samples:")
    for r in range(1, min(last_nonempty, 15) + 1):
        vals = [ws[f"{col}{r}"].value for col in "ABCDEFGHI"]
        print(r, vals)
    if last_nonempty > 15:
        print("Relevant columns A:I last 5 rows:")
        for r in range(max(1, last_nonempty - 4), last_nonempty + 1):
            vals = [ws[f"{col}{r}"].value for col in "ABCDEFGHI"]
            print(r, vals)
    
    # Count non-empty cells in columns A and I
    colA = [ws[f"A{r}"].value for r in range(1, last_nonempty + 1)]
    colI = [ws[f"I{r}"].value for r in range(1, last_nonempty + 1)] if ws.max_column >= 9 else []
    print("Non-empty count col A:", sum(v is not None and v != "" for v in colA))
    print("Non-empty count col I:", sum(v is not None and v != "" for v in colI))
    sheet_summaries[ws.title] = {"last_nonempty": last_nonempty, "headers": headers}

print("\nInspection done.")
