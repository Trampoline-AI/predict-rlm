from openpyxl import load_workbook
from openpyxl.utils.cell import range_boundaries
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook and inspect exact target again before writing
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet two"]

sup_ref = ws.tables["Suppliers2"].ref
items_ref = ws.tables["Items2"].ref
print("Original sheetnames:", original_sheetnames)
print("Suppliers2 ref:", sup_ref)
print("Items2 ref:", items_ref)

min_col, min_row, max_col, max_row = range_boundaries(sup_ref)
print("Suppliers2 boundaries:", (min_col, min_row, max_col, max_row))

# Target column should be E (5), rows 2:max_row of Suppliers2
target_col = 5
target_start = min_row + 1
target_end = max_row
print("Target range:", f"E{target_start}:E{target_end}")
print("Header in E1:", ws["E1"].value)

print("\nCurrent sample formulas/values in target before writing:")
for r in list(range(2, 8)) + list(range(max(2, target_end-3), target_end+1)):
    print(r, "G=", ws[f"G{r}"].value, "E=", ws[f"E{r}"].value)

# Write corrected formulas into E2:E279
# Use direct bounded range instead of broken structured reference
for r in range(target_start, target_end + 1):
    ws.cell(r, target_col).value = f'=IFERROR(VLOOKUP(G{r},$B$2:$C${target_end},2,FALSE),"")'

# Save
wb.save(output_path)
print("\nSaved initial output to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheetnames)
else:
    print("Sheet names after recalc:", wb_after.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet two"]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet two"]

print("\nVerification samples after recalc:")
sample_rows = list(range(2, 10)) + [50, 100, 150, 200, 250, 276, 277, 278, 279]
for r in sample_rows:
    print(
