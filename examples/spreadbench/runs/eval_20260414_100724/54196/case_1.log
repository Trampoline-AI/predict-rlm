def norm_num(v):
    if v is None:
        return None
    s = str(v).strip()
    if s == "":
        return None
    # preserve digit strings as plain digits
    if re.fullmatch(r"\d+(\.0+)?", s):
        s = s.split(".")[0]
    return s

