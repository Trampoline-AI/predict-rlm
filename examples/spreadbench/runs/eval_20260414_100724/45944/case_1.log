from openpyxl import load_workbook
from openpyxl.utils.cell import range_boundaries
import os, shutil

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load and inspect exact target cells before modifying
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheetnames:", orig_sheetnames)
print("Current target formulas before change:")
for addr in ["G11","G12","G13","G20","G21","G22"]:
    print(addr, "->", ws[addr].value)

# Confirm table refs
for tname in ["Table2", "Table3"]:
    print(tname, "ref =", ws.tables[tname].ref)

# Build formulas for the two target table blocks
# Table2 ref A10:B13 => data rows 11:13
# Table3 ref A19:B22 => data rows 20:22
targets = [
    ("Table2", 11, 13, "$A$11:$A$13", "$B$11:$B$13"),
    ("Table3", 20, 22, "$A$20:$A$22", "$B$20:$B$22"),
]

for table_name, start_row, end_row, name_range, date_range in targets:
    print(f"\nWriting formulas for {table_name}, rows {start_row}:{end_row}")
    for r in range(start_row, end_row + 1):
        formula = f'=IF(COUNTIFS({name_range},D{r},{date_range},">="&E{r})>0,TRUE(),FALSE())'
        ws[f"G{r}"] = formula
        print(f"G{r} = {formula}")

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if recalc changed them
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != orig_sheetnames:
    print("Restoring original sheet names...")
    # Rename sheets back in order
    for ws_obj, old_name in zip(wb_after.worksheets, orig_sheetnames):
        ws_obj.title = old_name
    wb_after.save(output_path)
    print("Sheetnames restored to:", wb_after.sheetnames)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nVerified formulas in target cells:")
for addr in ["G11","G12","G13","G20","G21","G22"]:
    print(addr, "formula ->", wsf[addr].value)

# Verify evaluated values
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Sheet1"]
print("\nEvaluated values in target cells after recalc:")
for addr in ["G11","G12","G13","G20","G21","G22"]:
    print(addr, "value ->", wsv[addr].value)

# Also print relevant source rows for sanity check
print("\nSanity check rows 10:13")
for r in range(10, 14):
    print(r, [wsv.cell(r, c).value for c in range(1, 8)])

print("\nSanity check rows 19:22")
for r in range(19, 23):
    print(r, [wsv.cell(r, c).value for c in range(1, 8)])

final_output_path = output_path
