I’ll use a classic non-array LOOKUP formula that finds the last prior matching serial number in column B and returns the corresponding prior weight from column D.
Code:
```repl
import os, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# First, confirm expected outputs in Python
wb_in = load_workbook(input_path)
ws_in = wb_in[wb_in.sheetnames[0]]

prev_weight = {}
expected = {}
for r in range(4, ws_in.max_row + 1):
    serial = ws_in[f"B{r}"].value
    weight = ws_in[f"D{r}"].value
    if serial is None and weight is None:
        continue
    if serial in prev_weight:
        expected[r] = prev_weight[serial] - weight
    else:
        expected[r] = 0
    prev_weight[serial] = weight

print("Expected Amount Used by Python:")
for r in range(4, ws_in.max_row + 1):
    print(r, ws_in[f"B{r}"].value, ws_in[f"D{r}"].value, "=>", expected.get(r))

# Create output workbook and write formulas in column E
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Header check / target confirmation
print("Target header E3:", ws["E3"].value)
print("Current E4:E16 before writing:", [ws[f"E{r}"].value for r in range(4, ws.max_row + 1)])

# Write formulas for all populated data rows
for r in range(4, ws.max_row + 1):
    serial = ws[f"B{r}"].value
    datev = ws[f"C{r}"].value
    weight = ws[f"D{r}"].value
    if serial is None and datev is None and weight is None:
        continue
    if r == 4:
        ws[f"E{r}"] = 0
    else:
        # First occurrence of serial up to current row => 0
        # Else previous matching weight minus current weight
        formula = f'=IF(COUNTIF($B$4:B{r},{get_column_letter(2)}{r})=1,0,LOOKUP(2,1/($B$4:B{r-1}={get_column_letter(2)}{r}),$D$4:D{r-1})-D{r})'
        ws[f"E{r}"] = formula

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalc:", recalc_result)

# Reload after recalc, restore sheet names if needed
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    # Rename sheets back to originals by position
    for i, name in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = name
    wb_post.save(output_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("Verification of E4:E16:")
verification = []
for r in range(4, ws_values.max_row + 1):
    formula = ws_formula[f"E{r}"].value
    value = ws_values[f"E{r}"].value
    verification.append((r, ws_values[f"B{r}"].value, ws_values[f"D{r}"].value, formula, value, expected.get(r)))
    print((r, ws_values[f"B{r}"].value, ws_values[f"D{r}"].value, formula, value, expected.get(r)))

output_spreadsheet = output_path
```
