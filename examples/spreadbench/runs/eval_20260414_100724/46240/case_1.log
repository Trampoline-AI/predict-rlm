Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally (with formulas)
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheetnames:", original_sheetnames)
print("Target sheet:", ws.title)
print("Target column J header:", ws["J1"].value)

# Show current target formulas before modification
print("\nCurrent J formulas before change:")
for r in range(2, ws.max_row + 1):
    print(r, "H=", ws[f"H{r}"].value, "J=", ws[f"J{r}"].value)

# Replace J formulas for all existing data rows
for r in range(2, ws.max_row + 1):
    # Only write where the row appears to contain data
    row_has_data = any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1))
    if not row_has_data:
        continue
    # Logic:
    # N/A -> N/A
    # blank -> No
    # Yes -> Yes
    # date/number -> Yes
    # anything else -> No
    ws[f"J{r}"] = f'=IF(H{r}="N/A","N/A",IF(H{r}="","No",IF(H{r}="Yes","Yes",IF(ISNUMBER(H{r}),"Yes","No"))))'

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for idx, expected in enumerate(original_sheetnames):
        if idx < len(wb_after.worksheets):
            wb_after.worksheets[idx].title = expected
    wb_after.save(output_path)
    print("Restored sheetnames to:", original_sheetnames)

# Verify formulas
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula["Sheet1"]
print("\nVerified formulas in J:")
for r in range(2, wsf.max_row + 1):
    print(f"J{r} formula:", wsf[f'J{r}'].value)

# Verify cached values after recalculation
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values["Sheet1"]
print("\nVerified computed values in H/J:")
for r in range(2, wsv.max_row + 1):
    print(f"Row {r}: H={wsv[f'H{r}'].value!r}, J={wsv[f'J{r}'].value!r}")

output_spreadsheet = output_path
```
