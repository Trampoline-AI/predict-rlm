from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load original workbook
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
raw = wb["Raw Data"]
nums = wb["Numbers"]
manual = wb["Manual Result"]

print("Original sheet names:", orig_sheetnames)
print("Numbers sheet current size:", nums.max_row, nums.max_column)
print("Current Numbers A:F row 1:", [nums.cell(1, c).value for c in range(1, 7)])

# Extract only whole numbers from Raw Data A:F, scanning columns A->F, top->bottom
whole_numbers = []
source_positions = []
for c in range(1, 7):
    for r in range(1, raw.max_row + 1):
        v = raw.cell(r, c).value
        if isinstance(v, (int, float)) and not isinstance(v, bool):
            if float(v).is_integer():
                whole_numbers.append(int(v))
                source_positions.append((r, c, int(v)))

print("Extracted whole number count:", len(whole_numbers))
print("First 20 extracted:", whole_numbers[:20])
print("Last 10 extracted:", whole_numbers[-10:])

# Chunk into rows of max 6 numbers
rows_out = [whole_numbers[i:i+6] for i in range(0, len(whole_numbers), 6)]
print("Output row count:", len(rows_out))
for i, rowvals in enumerate(rows_out, start=1):
    print(f"Planned Numbers row {i}: {rowvals}")

# Clear a reasonable target area in Numbers A:F first, preserving sheet structure
clear_rows = max(nums.max_row, len(rows_out))
for r in range(1, clear_rows + 1):
    for c in range(1, 7):
        nums.cell(r, c).value = None

# Write output into Numbers A:F
for r_idx, rowvals in enumerate(rows_out, start=1):
    for c_idx in range(1, 7):
        nums.cell(r_idx, c_idx).value = rowvals[c_idx - 1] if c_idx <= len(rowvals) else None

# Print written target area before save
print("\nWritten Numbers A:F preview before save:")
for r in range(1, len(rows_out) + 1):
    print(r, [nums.cell(r, c).value for c in range(1, 7)])

# Compare in-memory with Manual Result A:F
expected = []
for r in range(1, manual.max_row + 1):
    vals = [manual.cell(r, c).value for c in range(1, 7)]
    if any(v is not None for v in vals):
        expected.append(vals)

print("\nManual Result expected A:F rows:")
for i, vals in enumerate(expected, start=1):
    print(i, vals)

comparison_ok = True
for i in range(max(len(rows_out), len(expected))):
    out_vals = [nums.cell(i+1, c).value for c in range(1, 7)]
    exp_vals = expected[i] if i < len(expected) else [None]*6
    if out_vals != exp_vals:
        comparison_ok = False
        print("Mismatch before save at row", i+1, "written=", out_vals, "expected=", exp_vals)
print("Pre-save comparison matches Manual Result A:F?", comparison_ok)

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculate and ensure original sheet names preserved
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc; renaming back.")
    # rename sheets positionally back to the originals
    for idx, desired_name in enumerate(orig_sheetnames):
        wb_after.worksheets[idx].title = desired_name
    wb_after.save(output_path)
    print("Restored sheet names:", wb_after.sheetnames)
else:
    print("Sheet names preserved.")

# Verification reload with data_only=True
verify_wb = load_workbook(output_path, data_only=True)
print("Verified workbook sheet names:", verify_wb.sheetnames)

verify_nums = verify_wb["Numbers"]
verify_manual = verify_wb["Manual Result"]

print("\nVerified Numbers A:F rows:")
verified_rows = []
for r in range(1, len(rows_out) + 1):
    vals = [verify_nums.cell(r, c).value for c in range(1, 7)]
    verified_rows.append(vals)
    print(r, vals)

# Compare verified output to expected/manual
verify_ok = True
for i, exp_vals in enumerate(expected, start=1):
    got = [verify_nums.cell(i, c).value for c in range(1, 7)]
    if got != exp_vals:
        verify_ok = False
        print("Verification mismatch at row", i, "got=", got, "expected=", exp_vals)

# Additional sanity checks: no unexpected blanks in filled positions
for r_idx, rowvals in enumerate(rows_out, start=1):
    got = [verify_nums.cell(r_idx, c).value for c in range(1, 7)]
    for c_idx, expected_val in enumerate(rowvals, start=1):
        if got[c_idx - 1] in (None, ""):
            verify_ok = False
            print(f"Unexpected blank at Numbers!{get_column_letter(c_idx)}{r_idx}; expected {expected_val}")

print("\nVerification matches Manual Result A:F?", verify_ok)
print("Final output path:", output_path)
