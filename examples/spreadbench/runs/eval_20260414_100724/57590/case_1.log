from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Workbook:", input_spreadsheet)
print("Sheets:", orig_sheet_names)

def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for sname in wb.sheetnames:
    ws = wb[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    headers = row_vals(ws, 1, ws.max_column)
    print("Row1 headers:", headers)
    if ws.max_row >= 2:
        print("Row2:", row_vals(ws, 2, ws.max_column))
    
    top_end = min(ws.max_row, 10)
    print(f"Top rows 1-{top_end}:")
    for r in range(1, top_end + 1):
        print(r, row_vals(ws, r, min(ws.max_column, 12)))
    
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}-{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_vals(ws, r, min(ws.max_column, 12)))
    
    # Specific cells/ranges mentioned or likely relevant
    for coord in ["A26", "B26", "C2", "I2", "K2"]:
        print(f"{coord} =", ws[coord].value)
    
    print("Row 26 values A:K:", [ws.cell(26, c).value for c in range(1, min(ws.max_column, 11) + 1)])
    
    # Print formulas/non-empty values in B20:B30 and nearby source cols
    print("B20:B30 / A20:A30 / C20:C30 / I20:I30 / K20:K30")
    for r in range(20, min(ws.max_row, 30) + 1):
        print(
            r,
            "A", ws.cell(r, 1).value,
            "B", ws.cell(r, 2).value,
            "C", ws.cell(r, 3).value,
            "I", ws.cell(r, 9).value,
            "K", ws.cell(r, 11).value if ws.max_column >= 11 else None,
        )
