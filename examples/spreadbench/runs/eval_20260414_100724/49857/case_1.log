from openpyxl import load_workbook
import os
from shutil import copyfile

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook and identify target sheet/rows
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sub CO's"]

# Determine actual data rows: row 3 is header, data starts at 4
data_start_row = 4
last_data_row = 0
for r in range(ws.max_row, data_start_row - 1, -1):
    row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v is not None for v in row_vals):
        last_data_row = r
        break

print("Original sheet names:", original_sheetnames)
print("Target sheet:", ws.title)
print("Writing formulas to G rows", data_start_row, "through", last_data_row)

# Show current G values before modifying
before = []
for r in range(data_start_row, last_data_row + 1):
    before.append((r, ws[f"F{r}"].value, ws[f"G{r}"].value))
print("Before (row, F, G):", before)

# Write formulas into the existing target cells in column G
for r in range(data_start_row, last_data_row + 1):
    # Only write for actual populated rows
    if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
        ws[f"G{r}"] = f'=IF(UPPER(F{r})="YES",COUNTIF($F$4:F{r},"YES"),0)'

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc; restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename sheets back in order
    for i, old_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = old_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formulas and computed values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sub CO's"]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sub CO's"]

print("\nVerification of target cells G4:G10:")
verification = []
for r in range(data_start_row, last_data_row + 1):
    formula = ws_formula[f"G{r}"].value
    value = ws_values[f"G{r}"].value
    fval = ws_values[f"F{r}"].value
    verification.append((r, fval, formula, value))
    print(f"Row {r}: F={fval!r}, formula={formula!r}, value={value!r}")

# Basic sanity check
expected_nonblank = all(ws_formula[f"G{r}"].value is not None for r in range(data_start_row, last_data_row + 1))
print("All target formulas populated:", expected_nonblank)

output_spreadsheet = output_path
