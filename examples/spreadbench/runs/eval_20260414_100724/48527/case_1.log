```repl
import os
from collections import Counter
from openpyxl import load_workbook

# Re-open fresh workbook for editing
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
original_sheet_names = wb.sheetnames[:]

print("Using sheet:", ws.title)
print("Target column is D based on header:", ws["D1"].value)

def unique_text_among_three(vals):
    # Keep non-empty values as strings for comparison
    cleaned = [v for v in vals if v is not None and str(v) != ""]
    if len(cleaned) != 3:
        return None
    counts = Counter(cleaned)
    # Find the item occurring once, only when another occurs twice
    if sorted(counts.values()) == [1, 2]:
        for item, cnt in counts.items():
            if cnt == 1:
                return item
    return None

print("Before writing:")
for r in range(2, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])

# Fill only blank target cells in column D, preserving existing plausible examples
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    result = unique_text_among_three([a, b, c])
    if (d is None or d == "") and result is not None:
        ws.cell(r, 4).value = result

print("After writing, before save:")
for r in range(2, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 5)])

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names and len(wb_check.sheetnames) == len(original_sheet_names):
    for ws_obj, original_name in zip(wb_check.worksheets, original_sheet_names):
        ws_obj.title = original_name
    wb_check.save(out_path)
    print("Restored original sheet names:", original_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]
print("Verified target cells D2:D5:")
verified = {}
for r in range(2, wsv.max_row + 1):
    verified[f"D{r}"] = wsv.cell(r, 4).value
print(verified)

output_spreadsheet = out_path
```
