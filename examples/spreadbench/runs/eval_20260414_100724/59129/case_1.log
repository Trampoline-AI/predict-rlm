import os, shutil, calendar
from datetime import datetime
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheet_names)
print("Target cells to modify: E2:P2 on Sheet1")
print("Existing formulas/values in E2:P2 before change:")
for c in range(5, 17):
    cell = ws.cell(2, c)
    v = cell.value
    if hasattr(v, "text"):  # ArrayFormula
        print(cell.coordinate, "ArrayFormula:", v.text)
    else:
        print(cell.coordinate, v)

# Build corrected SUMPRODUCT formulas.
# Logic: active at end of month if:
# - hire date is before the first day of next month
# - and term date is blank OR term date is on/after the first day of next month
#
# This excludes employees terminated before month-end from future headcount.
for c in range(5, 17):
    col_letter = get_column_letter(c)
    formula = (
        f'=SUMPRODUCT(--($A$2:$A$22<DATE(YEAR({col_letter}$1),MONTH({col_letter}$1)+1,1)),'
        f'--((($B$2:$B$22="")+($B$2:$B$22>=DATE(YEAR({col_letter}$1),MONTH({col_letter}$1)+1,1)))>0))'
    )
    ws.cell(2, c).value = formula

print("\nFormulas written to E2:P2:")
for c in range(5, 17):
    print(ws.cell(2, c).coordinate, ws.cell(2, c).value)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # rename back by position
    for i, orig_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Sheet names restored to:", original_sheet_names)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]

print("\nVerification - formulas in E2:P2:")
for c in range(5, 17):
    print(ws_formula.cell(2, c).coordinate, ws_formula.cell(2, c).value)

# Verify cached values after recalc
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification - cached values in E2:P2:")
vals = []
for c in range(5, 17):
    coord = ws_values.cell(2, c).coordinate
    val = ws_values.cell(2, c).value
    vals.append(val)
    print(coord, val)

# Sanity-check against Python-computed expected values
def first_of_next_month(dt):
    y = dt.year + (1 if dt.month == 12 else 0)
    m = 1 if dt.month == 12 else dt.month + 1
    return datetime(y, m, 1)

emp_rows = []
for r in range(2, ws_values.max_row + 1):
    hire = ws_values.cell(r, 1).value
    term = ws_values.cell(r, 2).value
    if isinstance(hire, datetime):
        emp_rows.append((r, hire, term))

expected = []
for c in range(5, 17):
    month_start = ws_values.cell(1, c).value
    cutoff = first_of_next_month(month_start)
    count = 0
    for r, hire, term in emp_rows:
        if hire < cutoff and (term is None or term >= cutoff):
            count += 1
    expected.append(count)

print("\nPython expected month-end headcount E:P:", expected)
print("Nonblank cached values?", [v is not None for v in vals])

