def sheet_summary(ws):
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # headers from first 3 rows to detect where data/header might be
    for r in range(1, min(4, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"{r}: {vals}")
    # last 5 rows
    print("Last rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"{r}: {vals}")

    # find formulas
    formula_cells = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((ws.cell(r, c).coordinate, v))
    print("Formula cell count:", len(formula_cells))
    for coord, formula in formula_cells[:20]:
        print(coord, formula)
    if len(formula_cells) > 20:
        print("...")

for ws in wb.worksheets:
    sheet_summary(ws)
