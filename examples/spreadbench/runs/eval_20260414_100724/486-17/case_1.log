    print(f"A{r} =", ws.cell(r, 1).value, "| B{r} currently =", ws.cell(r, 2).value)

def reformat_date_code(val):
    if val in (None, ""):
        return None
    s = str(val).strip()
    # Keep digits only
    digits = "".join(ch for ch in s if ch.isdigit())
    if digits == "":
        return None
    
    # Expected format is 0yyyymmdd (9 digits), but be tolerant of already-trimmed 8 digits
    if len(digits) == 9 and digits.startswith("0"):
        digits = digits[1:]
    elif len(digits) > 8 and digits.startswith("0"):
        # Fallback: if extra leading zeroes exist, trim one and then validate
        digits = digits[1:]
    
    if len(digits) != 8:
        # Return original trimmed string if unexpected format
        return s
    
    yyyy = digits[0:4]
    mm = digits[4:6]
    dd = digits[6:8]
    return f"{yyyy} {mm} {dd}"

# Write output to column B starting at B2, no header
written = 0
skipped_blank = 0
examples = []

for r in range(2, last_row_a + 1):
    src = ws.cell(r, 1).value
    tgt_cell = ws.cell(r, 2)
    
    if src in (None, ""):
        # preserve empty rows
        skipped_blank += 1
        if tgt_cell.value not in (None, ""):
            tgt_cell.value = None
        continue
    
    new_val = reformat_date_code(src)
    tgt_cell.value = new_val
    written += 1
    if len(examples) < 8:
        examples.append((r, src, new_val))

print("Rows written to column B:", written)
print("Blank source rows skipped:", skipped_blank)
