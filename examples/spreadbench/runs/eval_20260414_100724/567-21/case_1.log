```repl
import os
import re
from datetime import datetime, date
from collections import defaultdict
from openpyxl import load_workbook

# Reload fresh from input
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Working sheet:", ws.title)
print("Original max_row/max_col:", ws.max_row, ws.max_column)

# Check for existing formulas in used range
formula_cells = []
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
    for cell in row:
        if isinstance(cell.value, str) and cell.value.startswith("="):
            formula_cells.append(cell.coordinate)
print("Formula cells found:", formula_cells[:10], "count=", len(formula_cells))

# Detect first non-empty row
first_data_row = None
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    if any(v not in (None, "") for v in vals):
        first_data_row = r
        break

print("First data row:", first_data_row)

def date_key(v):
    """Normalize dates for comparison. Supports datetime/date and strings like YYYY/MM or YYYY-MM."""
    if v in (None, ""):
        return None
    if isinstance(v, datetime):
        return (v.year, v.month, v.day)
    if isinstance(v, date):
        return (v.year, v.month, v.day)
    s = str(v).strip()
    m = re.fullmatch(r"(\d{4})[/-](\d{1,2})(?:[/-](\d{1,2}))?", s)
    if m:
        y = int(m.group(1))
        mo = int(m.group(2))
        d = int(m.group(3) or 1)
        return (y, mo, d)
    # fallback: try ISO-ish datetime strings
    try:
        dt = datetime.fromisoformat(s.replace("/", "-"))
        return (dt.year, dt.month, dt.day)
    except Exception:
        return None

# Read data rows
records = []
for r in range(first_data_row, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    rec = {
        "row": r,
        "values": vals,
        "A": vals[0],
        "B": vals[1],
        "E": vals[4] if len(vals) >= 5 else None,
        "E_key": date_key(vals[4] if len(vals) >= 5 else None),
    }
    records.append(rec)

print("Total data records read:", len(records))

# Compute max date per (A,B) among nonblank E
max_date_by_key = {}
group_members = defaultdict(list)
for rec in records:
    key = (rec["A"], rec["B"])
    group_members[key].append((rec["row"], rec["E"], rec["E_key"]))
    if rec["E_key"] is not None:
        if key not in max_date_by_key or rec["E_key"] > max_date_by_key[key]:
            max_date_by_key[key] = rec["E_key"]

# Determine kept rows
kept_records = []
dropped_blank_e = []
dropped_older = []

for rec in records:
    key = (rec["A"], rec["B"])
    if rec["E_key"] is None:
        dropped_blank_e.append(rec["row"])
    elif rec["E_key"] == max_date_by_key.get(key):
        kept_records.append(rec)
    else:
        dropped_older.append(rec["row"])

print("Unique (A,B) groups:", len(group_members))
print("Rows kept:", len(kept_records))
print("Rows dropped for blank E:", len(dropped_blank_e), dropped_blank_e)
print("Rows dropped for older E:", len(dropped_older), dropped_older)

print("\nGroup summaries:")
for key in sorted(group_members.keys(), key=lambda x: (str(x[0]), str(x[1]))):
    items = group_members[key]
    print(
        key,
        "all=",
        [(r, ek) for r, _, ek in items],
        "max=",
        max_date_by_key.get(key),
        "kept=",
        [rec["row"] for rec in kept_records if (rec["A"], rec["B"]) == key],
    )

# Rewrite kept rows in-place starting at first_data_row
original_last_row = ws.max_row
for i, rec in enumerate(kept_records, start=first_data_row):
    for c, v in enumerate(rec["values"], start=1):
        ws.cell(i, c).value = v

# Delete remaining leftover rows in one block
rows_to_delete = len(records) - len(kept_records)
delete_start = first_data_row + len(kept_records)
print("\nDelete start row:", delete_start, "rows_to_delete:", rows_to_delete)
if rows_to_delete > 0:
    ws.delete_rows(delete_start, rows_to_delete)

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Ensure sheet names preserved after recalc
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    print("Renaming sheets back to original names...")
    # rename by position
    for i, expected_name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected_name
    wb_check.save(output_path)
    print("Sheet names restored:", load_workbook(output_path).sheetnames)
else:
    print("Sheet names already preserved.")

# Verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[orig_sheetnames[0]]

print("\nVERIFICATION")
print("Verified sheet names:", wb_verify.sheetnames)
print("Verified max_row/max_col:", wsv.max_row, wsv.max_column)

# Print all remaining rows (small sheet)
remaining = []
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    remaining.append(vals)
    print(r, {"A": wsv.cell(r,1).value, "B": wsv.cell(r,2).value, "E": wsv.cell(r,5).value, "full": vals})

# Check data rows after blank top rows
verified_first_data_row = None
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    if any(v not in (None, "") for v in vals):
        verified_first_data_row = r
        break

verify_records = []
for r in range(verified_first_data_row, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    verify_records.append({
        "row": r,
        "A": vals[0],
        "B": vals[1],
        "E": vals[4] if len(vals) >= 5 else None,
        "E_key": date_key(vals[4] if len(vals) >= 5 else None),
        "values": vals,
    })

blank_e_remaining = [rec["row"] for rec in verify_records if rec["E_key"] is None]
verify_groups = defaultdict(list)
for rec in verify_records:
    verify_groups[(rec["A"], rec["B"])].append(rec["E_key"])

group_consistency = {}
for key, ekeys in verify_groups.items():
    uniq = sorted(set(ekeys))
    group_consistency[key] = uniq

print("Verified first data row:", verified_first_data_row)
print("Remaining data row count:", len(verify_records))
print("Blank E rows remaining:", blank_e_remaining)
print("Group E values after filtering:", group_consistency)

expected_kept_values = [rec["values"] for rec in kept_records]
actual_values = [rec["values"] for rec in verify_records]
print("Expected kept row count:", len(expected_kept_values))
print("Actual kept row count:", len(actual_values))
print("Exact row-content match:", expected_kept_values == actual_values)

# Store for possible submit next turn
final_output_path = output_path
```
