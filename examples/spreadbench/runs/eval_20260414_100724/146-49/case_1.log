from openpyxl import load_workbook
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Rebuild pairs cleanly from input workbook
wb2 = load_workbook(input_path)
orig_sheet_names = wb2.sheetnames[:]
ws = wb2[orig_sheet_names[0]]

# Collect dictionary words from column A
words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        words.append(v.strip())

word_set = set(words)

pairs = set()
for s_word in word_set:
    if "S" not in s_word:
        continue
    for vowel in "AEIOU":
        candidate = s_word.replace("S", vowel)
        if candidate != s_word and candidate in word_set:
            pairs.add((candidate, s_word))

pairs_sorted = sorted(pairs, key=lambda t: (t[0].upper(), t[1].upper(), t[0], t[1]))
print("Pairs to write:", len(pairs_sorted))
print("First 10 pairs:", pairs_sorted[:10])
print("Last 10 pairs:", pairs_sorted[-10:])

# Show current target cells before overwrite
print("Current G1:H10 before writing:")
for r in range(1, min(10, ws.max_row) + 1):
    print(r, ws.cell(r, 7).value, ws.cell(r, 8).value)

# Write final sorted output directly to G:H starting at row 1 (final state required by instruction)
for i, (left_word, right_word) in enumerate(pairs_sorted, start=1):
    ws.cell(i, 7).value = left_word
    ws.cell(i, 8).value = right_word

# Clear stale values below the result range in G:H
for r in range(len(pairs_sorted) + 1, ws.max_row + 1):
    if ws.cell(r, 7).value is not None or ws.cell(r, 8).value is not None:
        ws.cell(r, 7).value = None
        ws.cell(r, 8).value = None

wb2.save(output_path)
print("Saved to:", output_path, "exists:", os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# After recalc, ensure sheet names still match originals
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # rename sheets back by position
    for idx, original_name in enumerate(orig_sheet_names):
        wb_after.worksheets[idx].title = original_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify output after recalculation using data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

print("Verified G1:H15:")
for r in range(1, min(15, len(pairs_sorted)) + 1):
    print(r, wsv.cell(r, 7).value, wsv.cell(r, 8).value)

start_last = max(1, len(pairs_sorted) - 4)
print(f"Verified last rows G{start_last}:H{len(pairs_sorted)}:")
for r in range(start_last, len(pairs_sorted) + 1):
    print(r, wsv.cell(r, 7).value, wsv.cell(r, 8).value)

# Confirm everything below result range is blank for a sample
sample_blank_rows = list(range(len(pairs_sorted) + 1, min(ws.max_row, len(pairs_sorted) + 6) + 1))
print("Sample rows after result range should be blank in G:H:")
for r in sample_blank_rows:
    print(r, wsv.cell(r, 7).value, wsv.cell(r, 8).value)

# Sanity checks
nonblank_pairs = []
r = 1
while r <= ws.max_row:
    g = wsv.cell(r, 7).value
    h = wsv.cell(r, 8).value
    if g is None and h is None:
        break
    nonblank_pairs.append((g, h))
    r += 1

print("Nonblank output rows found from top:", len(nonblank_pairs))
print("Matches expected count:", len(nonblank_pairs) == len(pairs_sorted))
print("Output already sorted case-insensitively:", nonblank_pairs == sorted(nonblank_pairs, key=lambda t: (str(t[0]).upper(), str(t[1]).upper(), str(t[0]), str(t[1]))))
print("Example pair present:", ("KAGOULE", "KAGOULS") in nonblank_pairs)
print("Any blanks within output rows:", any((a is None or b is None or str(a).strip()=="" or str(b).strip()=="") for a,b in nonblank_pairs))
