from collections import Counter, defaultdict

ws = wb[wb.sheetnames[0]]

# Inspect actual populated words in column A
words = []
rows_with_words = []
for r in range(1, ws.max_row + 1):
    val = ws.cell(r, 1).value
    if isinstance(val, str) and val.strip():
        words.append(val.strip())
        rows_with_words.append(r)

print("Non-empty words in column A:", len(words))
print("Unique words in column A:", len(set(words)))
dupes = [w for w, cnt in Counter(words).items() if cnt > 1]
print("Duplicate word count:", len(dupes))
print("First 10 duplicate words:", dupes[:10])

# Find where the example words appear in column A
for target in ["KAGOULE", "KAGOULS"]:
    matches = [r for r in rows_with_words if ws.cell(r, 1).value == target]
    print(target, "rows:", matches[:20], "count:", len(matches))

# Build exploratory candidate pairs:
# For each S-word, replace all S with a single vowel and see if that candidate exists.
word_set = set(words)
pairs = set()
pairs_by_vowel = defaultdict(list)

for s_word in word_set:
    if "S" not in s_word:
        continue
    for v in "AEIOU":
        candidate = s_word.replace("S", v)
        if candidate != s_word and candidate in word_set:
            pairs.add((candidate, s_word))
            pairs_by_vowel[v].append((candidate, s_word))

pairs_sorted = sorted(pairs, key=lambda t: (t[0].upper(), t[1].upper()))

print("Total candidate pairs:", len(pairs_sorted))
for v in "AEIOU":
    print(v, len(pairs_by_vowel[v]))
print("First 20 pairs:", pairs_sorted[:20])
print("Last 20 pairs:", pairs_sorted[-20:])

# Verify the example pair is included
print(("KAGOULE", "KAGOULS") in pairs)

# Show a few pairs where there are multiple S's, if any
multi_s_pairs = [(a,b) for (a,b) in pairs_sorted if b.count("S") > 1]
print("Pairs with multiple S in S-word:", len(multi_s_pairs))
print("Examples multi-S:", multi_s_pairs[:20])
```
