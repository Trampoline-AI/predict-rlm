Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Headers before write:", ws["A1"].value, ws["C1"].value, ws["E1"].value)
print("Current D32 before write:", ws["D32"].value)
print("Current D61 before write:", ws["D61"].value)

# Write formulas in D2:D69
# Logic:
# If next day's date exists and its day number is 1, count rows in same month/year with C=1.
# Otherwise return blank.
for r in range(2, 70):
    formula = (
        f'=IF(AND(A{r+1}<>"",DAY(A{r+1})=1),'
        f'COUNTIFS($A$2:$A$69,">="&DATE(YEAR(A{r}),MONTH(A{r}),1),'
        f'$A$2:$A$69,"<"&DATE(YEAR(A{r}),MONTH(A{r})+1,1),'
        f'$C$2:$C$69,1),"")'
    )
    ws.cell(r, 4).value = formula

# Preserve headers as-is (explicitly do nothing except verify)
assert ws["A1"].value == "Date"
assert ws["C1"].value == "Occurence"
assert ws["E1"].value == "Rolling month sum"

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_post = load_workbook(output_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != original_sheet_names:
    # Rename by position back to original
    for i, name in enumerate(original_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = name
    wb_post.save(output_path)
    print("Restored sheet names to:", wb_post.sheetnames)

# Verification: formulas
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]
print("Sample formulas written:")
for r in [2, 31, 32, 33, 60, 61, 62, 69]:
    print(f"D{r} formula:", ws_formula[f"D{r}"].value)

# Verification: computed values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("Headers after recalc:", ws_values["A1"].value, ws_values["C1"].value, ws_values["E1"].value)

# Show all nonblank values in D2:D69
nonblank_d = []
for r in range(2, 70):
    val = ws_values[f"D{r}"].value
    if val not in (None, ""):
        nonblank_d.append((r, val))
print("Nonblank computed D values:", nonblank_d)

# Also compute expected month-end counts in Python as a sanity check
from collections import Counter

# Read actual dates and occurrences
dates = {}
occ = {}
for r in range(2, 70):
    dates[r] = ws_values[f"A{r}"].value
    occ[r] = ws_values[f"C{r}"].value

month_counts = Counter()
for r in range(2, 70):
    d = dates[r]
    if d is not None and occ[r] == 1:
        month_counts[(d.year, d.month)] += 1

expected = []
for r in range(2, 70):
    d = dates[r]
    next_d = ws_values[f"A{r+1}"].value if r + 1 <= 70 else None
    if d is not None and next_d is not None and getattr(next_d, "day", None) == 1:
        expected.append((r, month_counts[(d.year, d.month)]))
print("Expected nonblank D values by Python check:", expected)

# Print key targets
for r in [32, 61]:
    print(f"A{r}={ws_values[f'A{r}'].value}, A{r+1}={ws_values[f'A{r+1}'].value}, C{r}={ws_values[f'C{r}'].value}, D{r}={ws_values[f'D{r}'].value}")

final_output_spreadsheet = output_path
