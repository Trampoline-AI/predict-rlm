import os
from collections import OrderedDict
from openpyxl import load_workbook

# Load workbook again for editing
wb = load_workbook(input_spreadsheet)
ws = wb["merge"]
original_sheet_names = wb.sheetnames[:]

# Determine actual populated source rows in A:D
source_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    d = ws.cell(r, 4).value
    if a is None and b is None and c is None and d is None:
        continue
    source_rows.append((r, a, b, c, d))

print("Populated source row count:", len(source_rows))
print("First 10 populated source rows:", source_rows[:10])
print("Last 5 populated source rows:", source_rows[-5:])

# Aggregate by columns A, B, C; sum D
agg = OrderedDict()
for r, a, b, c, d in source_rows:
    key = (a, b, c)
    if key not in agg:
        agg[key] = 0
    agg[key] += 0 if d is None else d

aggregated_rows = [(k[0], k[1], k[2], total) for k, total in agg.items()]
print("Unique grouped rows:", len(aggregated_rows))
print("Aggregated result preview:", aggregated_rows)

# Inspect current target area before writing
print("Current target G1:J10 before write:")
for r in range(1, 11):
    print(r, [ws.cell(r, c).value for c in range(7, 11)])

# Write output starting at G2, preserving existing headers in G1:J1
start_row = 2
start_col = 7  # G

# Clear previous output area from G2:Jmax_row
for r in range(2, ws.max_row + 1):
    for c in range(7, 11):
        ws.cell(r, c).value = None

# Write aggregated rows
for i, row_vals in enumerate(aggregated_rows, start=start_row):
    for j, val in enumerate(row_vals, start=start_col):
        ws.cell(i, j).value = val

print("Target G1:J10 after write, before save:")
for r in range(1, 11):
    print(r, [ws.cell(r, c).value for c in range(7, 11)])

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb_check = load_workbook(out_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    for idx, old_name in enumerate(original_sheet_names):
        if idx < len(wb_check.worksheets):
            wb_check.worksheets[idx].title = old_name
    wb_check.save(out_path)
    print("Restored sheet names to:", original_sheet_names)

# Verification using data_only=True
wb_verify = load_workbook(out_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("Verified target cells G1:J10:")
for r in range(1, 11):
    print(r, [wsv.cell(r, c).value for c in range(7, 11)])

# Also verify no unintended extra output below result rows
print("Rows after expected output (next 5 rows):")
for r in range(start_row + len(aggregated_rows), start_row + len(aggregated_rows) + 5):
    print(r, [wsv.cell(r, c).value for c in range(7, 11)])

output_spreadsheet = out_path
print("Final output path ready:", output_spreadsheet)
```
