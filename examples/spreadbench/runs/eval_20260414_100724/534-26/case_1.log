from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

path = input_spreadsheet
wb = load_workbook(path)

print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def sheet_nonempty_bounds(ws):
    max_row, max_col = ws.max_row, ws.max_column
    # find actual non-empty rows and cols
    nonempty_rows = []
    nonempty_cols = set()
    for r in ws.iter_rows(1, max_row, 1, max_col):
        row_has = False
        for cell in r:
            if cell.value is not None:
                if isinstance(cell.value, str):
                    if cell.value.strip() == "":
                        continue
                row_has = True
                nonempty_cols.add(cell.column)
        nonempty_rows.append(row_has)
    first_row = next((i+1 for i,v in enumerate(nonempty_rows) if v), None)
    last_row = next((i+1 for i,v in reversed(list(enumerate(nonempty_rows))) if v), None)
    first_col = min(nonempty_cols) if nonempty_cols else None
    last_col = max(nonempty_cols) if nonempty_cols else None
    return first_row, last_row, first_col, last_col

for ws in wb.worksheets:
    first_row, last_row, first_col, last_col = sheet_nonempty_bounds(ws)
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    print(f"nonempty bounds rows {first_row}-{last_row}, cols {first_col}-{last_col}")
    
    # header candidates: first 3 rows
    for hr in range(1, min(4, ws.max_row+1)):
        vals = [ws.cell(hr, c).value for c in range(1, min(ws.max_column, 15)+1)]
        print(f"Row {hr} first 15 cells:", vals)
    
    # first 10 rows sample
    print("\nFirst up to 10 rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"R{r}: {vals}")
    
    # last 5 rows sample
    print("\nLast up to 5 rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 12)+1)]
        print(f"R{r}: {vals}")
    
    # column summary first 20 columns
    print("\nColumn summary (first 20 columns):")
    for c in range(1, min(ws.max_column, 20)+1):
        letter = get_column_letter(c)
        sample = [ws.cell(r, c).value for r in range(1, min(ws.max_row, 6)+1)]
        print(f"{letter}: {sample}")
