from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
from datetime import datetime
import os

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))
os.makedirs(outdir, exist_ok=True)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]

src = wb["Sheet1"]
dst = wb["Result"]

# Inspect exact target range before writing
print("Before write:")
print("Sheet1 row1:", [src.cell(1, c).value for c in range(1, src.max_column + 1)])
print("Result row1:", [dst.cell(1, c).value for c in range(1, dst.max_column + 1)])

src_headers = [src.cell(1, c).value for c in range(1, src.max_column + 1)]
dst_headers_existing = [dst.cell(1, c).value for c in range(1, dst.max_column + 1)]

# Infer cutoff from existing example output in Result if present
existing_result_dates = [v for v in dst_headers_existing[8:] if isinstance(v, datetime)]
if existing_result_dates:
    cutoff = min(existing_result_dates)
else:
    now = datetime.now()
    cutoff = datetime(now.year, now.month, 1)

print("Cutoff inferred for keeping date columns >=", cutoff)

# Determine which source columns to keep:
# - first 8 columns always kept
# - date columns kept if >= cutoff
keep_cols = []
removed_cols = []

for c in range(1, src.max_column + 1):
    val = src.cell(1, c).value
    if c <= 8:
        keep_cols.append(c)
    elif isinstance(val, datetime):
        if val >= cutoff:
            keep_cols.append(c)
        else:
            removed_cols.append(c)
    else:
        # if a non-date unexpectedly appears after col 8, preserve it
        keep_cols.append(c)

print("Kept source columns:", [(c, get_column_letter(c), src.cell(1, c).value) for c in keep_cols])
print("Removed source columns:", [(c, get_column_letter(c), src.cell(1, c).value) for c in removed_cols])

# Clear current destination used range values
for r in range(1, dst.max_row + 1):
    for c in range(1, dst.max_column + 1):
        dst.cell(r, c).value = None

# Copy kept columns from Sheet1 into Result starting at column 1
for new_c, old_c in enumerate(keep_cols, start=1):
    # copy column width if present
    old_letter = get_column_letter(old_c)
    new_letter = get_column_letter(new_c)
    if old_letter in src.column_dimensions:
        dst.column_dimensions[new_letter].width = src.column_dimensions[old_letter].width

    for r in range(1, src.max_row + 1):
        s = src.cell(r, old_c)
        d = dst.cell(r, new_c)
        d.value = s.value
        if s.has_style:
            d.font = copy(s.font)
            d.fill = copy(s.fill)
            d.border = copy(s.border)
            d.alignment = copy(s.alignment)
            d.number_format = s.number_format
            d.protection = copy(s.protection)
        if s.hyperlink:
            d._hyperlink = copy(s.hyperlink)
        if s.comment:
            d.comment = copy(s.comment)

# Save initial output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate as required
recalc_status = await recalculate(outfile)
print("Recalculate status:", recalc_status)

# Reload and ensure sheet names remain the same
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames:
    # rename back by position
    for ws_obj, orig_name in zip(wb2.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb2.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verification reload
wbv = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wbv.sheetnames)

res = wbv["Result"]
result_values = [res.cell(1, c).value for c in range(1, len(keep_cols) + 1)]
print("Verified Result row1:", result_values)

# Also show exact target range with coordinates
print("Verified Result target cells:")
for c in range(1, len(keep_cols) + 1):
    print(f"{get_column_letter(c)}1 -> {res.cell(1, c).value!r}")

# Basic sanity checks
all_nonblank = all(v is not None for v in result_values)
print("All target cells nonblank?", all_nonblank)
print("Output column count:", len(result_values))

output_spreadsheet = outfile
