from openpyxl import load_workbook
from datetime import datetime, timedelta
import os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Inspect rows 1-25, cols A:F:")
for r in range(1, min(ws.max_row, 25) + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    print(r, vals)

print("\nFormulas / values in F column rows 1-10:")
for r in range(1, 11):
    print(f"F{r} =", ws[f"F{r}"].value)

# Collect actual dates from column A (skip header/non-dates)
dates_in_a = []
rows_with_dates = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, datetime):
        dates_in_a.append(v.date())
        rows_with_dates.append((r, v.date()))
print("\nRows with dates in A:", rows_with_dates)

if dates_in_a:
    min_d, max_d = min(dates_in_a), max(dates_in_a)
    full_range = []
    cur = min_d
    while cur <= max_d:
        full_range.append(cur)
        cur += timedelta(days=1)
    missing = [d for d in full_range if d not in set(dates_in_a)]
    print("Min date:", min_d, "Max date:", max_d)
    print("Missing dates:", missing)
    print("Missing count:", len(missing))

# Inspect current C values and number format
print("\nCurrent target column C rows 1-20:")
for r in range(1, 21):
    cell = ws.cell(r, 3)
    print(r, cell.coordinate, cell.value, "fmt=", cell.number_format)

# Determine a date number format to reuse
date_fmt = None
for coord in ["A2", "C2", "A3", "C3"]:
    val = ws[coord].value
    if isinstance(val, datetime):
        date_fmt = ws[coord].number_format
        print("Using date format from", coord, "->", date_fmt)
        break

# Write results into existing column C, starting at row 2
# Preserve any already-correct values; fill blanks or incorrect remainder.
missing_datetimes = [datetime.combine(d, datetime.min.time()) for d in missing]
for i, dt in enumerate(missing_datetimes, start=2):
    cell = ws.cell(i, 3)
    current = cell.value
    if current != dt:
        cell.value = dt
    if date_fmt:
        cell.number_format = date_fmt

# Clear any leftover old values below the needed output range in column C
last_needed_row = 1 + len(missing_datetimes)
for r in range(last_needed_row + 1, ws.max_row + 1):
    cell = ws.cell(r, 3)
    if cell.value not in (None, ""):
        # only clear below the result area if it's part of output region and not header
        cell.value = None

out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))
wb.save(out_path)
print("\nSaved to:", out_path)
