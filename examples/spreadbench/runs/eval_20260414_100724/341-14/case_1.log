print("Sheets:", orig_sheetnames)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # collect non-empty row stats
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("nonempty_rows_count:", len(nonempty_rows), 
          "first_nonempty:", nonempty_rows[:5], 
          "last_nonempty:", nonempty_rows[-5:] if nonempty_rows else [])
    
    # print first few rows raw
    first_n = min(ws.max_row, 10)
    print("\nFirst rows:")
    for r in range(1, first_n + 1):
        row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, row)
    
    # print last 5 rows raw
    start_last = max(1, ws.max_row - 4)
    print("\nLast rows:")
    for r in range(start_last, ws.max_row + 1):
        row = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, row)

for s in wb.sheetnames:
    sheet_summary(wb[s])

# More targeted inspection for likely source/target sheets
