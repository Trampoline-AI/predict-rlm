I’ll write that into `G4:G8`, add an autofilter covering the actual data range `A1:C9493`, save to the output directory, recalculate, reload, verify formulas and computed values, and confirm the sheet name remains `raw 1`.
Code:
```repl
from openpyxl import load_workbook
import os
from collections import Counter

# Load workbook
infile = input_spreadsheet
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["raw 1"]

# Determine actual last data row in A:C
last_row = 1
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 4)):
        last_row = r
        break

print("Original sheetnames:", orig_sheetnames)
print("Detected last data row in A:C:", last_row)

# Show current target cells before writing
print("Before writing G4:G8:")
for r in range(4, 9):
    print(f"F{r}={ws[f'F{r}'].value!r}, G{r}={ws[f'G{r}'].value!r}")
print("Current AutoFilter ref:", ws.auto_filter.ref)

# Write formulas to G4:G8
# Count rows where A matches F-row and (B>0 OR C<0)
for r in range(4, 9):
    formula = (
        f"=COUNTIFS($A$2:$A${last_row},F{r},$B$2:$B${last_row},\">0\")"
        f"+COUNTIFS($A$2:$A${last_row},F{r},$C$2:$C${last_row},\"<0\")"
        f"-COUNTIFS($A$2:$A${last_row},F{r},$B$2:$B${last_row},\">0\",$C$2:$C${last_row},\"<0\")"
    )
    ws[f"G{r}"] = formula

# Add filter to the data table for headers A1:C1
ws.auto_filter.ref = f"A1:C{last_row}"

# Save output
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_post = load_workbook(outfile)
current_names = wb_post.sheetnames[:]
print("Sheetnames after recalc reload:", current_names)

if current_names != orig_sheetnames and len(current_names) == len(orig_sheetnames):
    for i, desired in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = desired
    wb_post.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
print("Verified formulas in G4:G8:")
for r in range(4, 9):
    print(f"G{r} formula -> {ws_formula[f'G{r}'].value}")

print("Verified AutoFilter ref:", ws_formula.auto_filter.ref)

# Verify computed values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("Computed values in G4:G8 after recalc:")
for r in range(4, 9):
    print(f"F{r}={ws_values[f'F{r}'].value!r}, G{r}={ws_values[f'G{r}'].value!r}")

# Independent Python check for sanity
counts = Counter()
for r in range(2, last_row + 1):
    cls = ws_values.cell(r, 1).value
    b = ws_values.cell(r, 2).value
    c = ws_values.cell(r, 3).value
    b = 0 if b in (None, "") else b
    c = 0 if c in (None, "") else c
    if (b > 0) or (c < 0):
        counts[cls] += 1

print("Python-checked expected counts for F4:F8:")
for r in range(4, 9):
    cls = ws_values[f"F{r}"].value
    print(f"{cls}: expected={counts[cls]}, sheet_value={ws_values[f'G{r}'].value!r}")

output_spreadsheet = outfile
```
