from openpyxl import load_workbook
from collections import Counter
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["raw 1"]

# Inspect data distribution in A:C to confirm formula logic
count_total = 0
count_b_pos = count_b_zero = count_b_neg = 0
count_c_pos = count_c_zero = count_c_neg = 0
weird_examples = []
class_counter = Counter()
nonzero_by_class_general = Counter()
nonzero_by_class_existingpattern = Counter()

for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    count_total += 1
    class_counter[a] += 1
    
    # normalize blanks
    b_num = 0 if b in (None, "") else b
    c_num = 0 if c in (None, "") else c
    
    if b_num > 0:
        count_b_pos += 1
    elif b_num == 0:
        count_b_zero += 1
    else:
        count_b_neg += 1
        
    if c_num > 0:
        count_c_pos += 1
    elif c_num == 0:
        count_c_zero += 1
    else:
        count_c_neg += 1
    
    general_nonzero = (b_num != 0) or (c_num != 0)
    existing_pattern = ((b_num > 0 and c_num < 0) or
                        (b_num > 0 and c_num == 0) or
                        (b_num == 0 and c_num < 0))
    
    if general_nonzero:
        nonzero_by_class_general[a] += 1
    if existing_pattern:
        nonzero_by_class_existingpattern[a] += 1
    
    if (b_num < 0) or (c_num > 0):
        if len(weird_examples) < 20:
            weird_examples.append((r, a, b_num, c_num))

print("Total data rows:", count_total)
print("B stats: pos/zero/neg =", count_b_pos, count_b_zero, count_b_neg)
print("C stats: pos/zero/neg =", count_c_pos, count_c_zero, count_c_neg)
print("Any rows with B<0 or C>0? sample:", weird_examples[:10])

print("Classes in F4:F8 and expected counts:")
for r in range(4, 9):
    cls = ws[f"F{r}"].value
    print(
        r, cls,
        "general_nonzero=", nonzero_by_class_general[cls],
        "existing_pattern=", nonzero_by_class_existingpattern[cls],
        "total_rows=", class_counter[cls]
    )

# Also print current formulas/values one more time
for r in range(4, 9):
