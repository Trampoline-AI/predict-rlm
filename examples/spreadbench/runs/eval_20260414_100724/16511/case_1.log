from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Workbook:", input_path)
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

inspection = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    
    # Also inspect row 2 in case headers start there
    if ws.max_row >= 2:
        print("Row 2:", row_values(ws, 2, ws.max_column))
    
    # First 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Find non-empty rows count more precisely
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first/last:", (nonempty_rows[0], nonempty_rows[-1]) if nonempty_rows else None)
    
    # Search for relevant headers / cells
    keywords = ["album", "track", "song", "title", "name", "number", "no"]
    matches = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                low = v.strip().lower()
                if any(k in low for k in keywords):
                    matches.append((r, c, get_column_letter(c), v))
    print("Keyword matches in first 20 rows:", matches[:50])
    
    # Print existing formulas in used range (first 20 rows)
    formulas = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first 20 rows:", formulas[:50])
    
    inspection[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "headers": headers,
        "keyword_matches": matches,
        "formulas": formulas,
    }

print("\nInspection summary keys:", inspection.keys())
```
