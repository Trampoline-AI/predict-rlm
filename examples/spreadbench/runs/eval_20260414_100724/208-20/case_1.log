from openpyxl import load_workbook
from pathlib import Path
import os, shutil

wb = load_workbook(input_spreadsheet)
ws = wb["Q"]

def rng_vals(ws, r, c1, c2):
    return [ws.cell(r, c).value for c in range(c1, c2 + 1)]

# Compact inspection of exact target ranges
print("Sheet names:", wb.sheetnames)
print("Target actual range: A3:F37")
print("Reference expected range: I3:N37")
print("Headers row 2 A:F:", rng_vals(ws, 2, 1, 6))
print("Headers row 2 I:N:", rng_vals(ws, 2, 9, 14))

# Show rows where actual differs from expected
diffs = []
for r in range(3, 38):
    left = rng_vals(ws, r, 1, 6)
    right = rng_vals(ws, r, 9, 14)
    if left != right:
        diffs.append((r, left, right))

print(f"Rows differing between actual and expected: {len(diffs)}")
for r, left, right in diffs[:12]:
    print(f"Row {r} actual={left} expected={right}")

# Show expected group endpoints / sort keys
print("\nExpected rows with nonblank R DAYS (M):")
for r in range(3, 38):
    if ws.cell(r, 13).value not in (None, ""):
        print(r, rng_vals(ws, r, 9, 14))

# Apply transformation: copy expected values I:N into actual A:F, values only
for r in range(3, 38):
    for offset in range(6):  # I:N -> A:F
        ws.cell(r, 1 + offset).value = ws.cell(r, 9 + offset).value

# Save output
infile = Path(input_spreadsheet)
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / infile.name
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(str(outfile))
print("Recalculate result:", recalc_result)

# Reload after recalc, repair sheet names if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames:
    # rename sheets positionally back to original names
    for i, orig_name in enumerate(wb.sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", wb.sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Q"]

mismatches = []
blank_problem = []
for r in range(3, 38):
    left = rng_vals(wsv, r, 1, 6)
    right = rng_vals(wsv, r, 9, 14)
    if left != right:
        mismatches.append((r, left, right))
    # sanity-check key target cells should match reference exactly
    for c_left, c_right in zip(range(1, 7), range(9, 15)):
