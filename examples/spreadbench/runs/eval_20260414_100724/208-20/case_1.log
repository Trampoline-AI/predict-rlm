from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Instruction:")
print(instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("\nWorkbook sheets:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

def nonempty_count(vals):
    return sum(v not in (None, "") for v in vals)

for ws in wb.worksheets:
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find likely header row among first 10 rows by highest non-empty count
    header_candidates = []
    for r in range(1, min(10, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        header_candidates.append((r, nonempty_count(vals), vals))
    header_candidates_sorted = sorted(header_candidates, key=lambda x: (-x[1], x[0]))
    guessed_header_row = header_candidates_sorted[0][0]
    print("Header candidates (row, nonempty_count):", [(r,cnt) for r,cnt,_ in header_candidates])
    print("Guessed header row:", guessed_header_row)
    
    headers = row_values(ws, guessed_header_row, ws.max_column)
    header_map = {get_column_letter(i+1): headers[i] for i in range(len(headers))}
    print("Headers by column:")
    print(header_map)
    
    # Print first 10 rows
    print("\nFirst 10 rows:")
    for r in range(1, min(10, ws.max_row) + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # Print last 5 rows
    print("\nLast 5 rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    
    # Look specifically for R DAYS header
    target_cols = []
    for c in range(1, ws.max_column + 1):
        v = ws.cell(guessed_header_row, c).value
        if isinstance(v, str) and "R DAYS" in v.upper():
            target_cols.append(c)
    print("Columns matching 'R DAYS' in guessed header row:", [(get_column_letter(c), ws.cell(guessed_header_row, c).value) for c in target_cols])
    
    # Also scan first 10 rows for any R DAYS occurrence
    found_any = []
    for r in range(1, min(10, ws.max_row) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and "R DAYS" in v.upper():
                found_any.append((r, c, v))
    print("Any 'R DAYS' found in first 10 rows:", [(r, get_column_letter(c), v) for r,c,v in found_any])
    
    # Print columns A:L for rows around guessed header + first several data rows
    print("\nRows around header and first data area (A:L):")
