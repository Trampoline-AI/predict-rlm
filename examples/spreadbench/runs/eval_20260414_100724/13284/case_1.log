from openpyxl.worksheet.formula import ArrayFormula
from openpyxl.utils import get_column_letter
import os
from collections import Counter

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
base = wb["Base"]
streets = wb["Streets"]

print("Original sheet names:", wb.sheetnames)
print("Target write range should be Base!E2:E{}".format(base.max_row))
print("Base column headers:", [base.cell(1,c).value for c in range(1, base.max_column+1)])
print("Streets column headers:", [streets.cell(1,c).value for c in range(1, streets.max_column+1)])

# Compact inspection of unique street names
base_streets = [base.cell(r,3).value for r in range(2, base.max_row+1) if base.cell(r,3).value is not None]
streets_streets = [streets.cell(r,2).value for r in range(2, streets.max_row+1) if streets.cell(r,2).value is not None]
print("\nUnique Base street names:", sorted(set(base_streets)))
print("Unique Streets street names:", sorted(set(streets_streets)))

def norm_street(s):
    if s is None:
        return None
    return " ".join(str(s).strip().split()).casefold()

# Build lookup rows, only where both start/end are populated per instruction
street_rows = []
for r in range(2, streets.max_row + 1):
    st = streets.cell(r,2).value
    start = streets.cell(r,3).value
    end = streets.cell(r,4).value
    assistant = streets.cell(r,6).value
    if st is not None and start is not None and end is not None:
        street_rows.append({
            "row": r,
            "street": st,
            "street_norm": norm_street(st),
            "start": float(start),
            "end": float(end),
            "assistant": assistant if assistant is not None else ""
        })

print("\nEligible Streets rows (with both Start and End populated):", len(street_rows))
for item in street_rows[:10]:
    print(item)
if len(street_rows) > 10:
