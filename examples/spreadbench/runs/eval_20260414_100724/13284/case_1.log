from openpyxl import load_workbook
from openpyxl.worksheet.formula import ArrayFormula
import os
from collections import defaultdict

wb = load_workbook(input_spreadsheet)
base = wb["Base"]
streets = wb["Streets"]

def cell_display(v):
    if isinstance(v, ArrayFormula):
        try:
            return f"ArrayFormula(text={v.text!r}, ref={v.ref!r})"
        except Exception:
            return f"ArrayFormula({v!r})"
    return repr(v)

print("Base headers:", [base.cell(1,c).value for c in range(1, base.max_column+1)])
print("Streets headers:", [streets.cell(1,c).value for c in range(1, streets.max_column+1)])

print("\nInspect Base rows 2:max with C,D,E,F:")
for r in range(2, base.max_row + 1):
    print(r, {
        "C_logradouro": base.cell(r,3).value,
        "D_number": base.cell(r,4).value,
        "E_assistente_existing": cell_display(base.cell(r,5).value),
        "F_correct_result": base.cell(r,6).value,
    })

print("\nInspect Streets relevant rows B:F:")
for r in range(2, streets.max_row + 1):
    print(r, {
        "B_street": streets.cell(r,2).value,
        "C_start": streets.cell(r,3).value,
        "D_end": streets.cell(r,4).value,
        "F_assistente": streets.cell(r,6).value,
    })

def norm_street(s):
    if s is None:
        return None
    return " ".join(str(s).strip().split()).casefold()

street_rows = []
for r in range(2, streets.max_row + 1):
    st = streets.cell(r,2).value
    start = streets.cell(r,3).value
    end = streets.cell(r,4).value
    assistant = streets.cell(r,6).value
    street_rows.append((r, st, start, end, assistant))

def find_match(logradouro, number):
    matches = []
    for r, st, start, end, assistant in street_rows:
        if start is None or end is None:
            continue
        if norm_street(logradouro) == norm_street(st):
            try:
                num = float(number)
                lo = float(start)
                hi = float(end)
            except Exception:
                continue
            if lo <= num <= hi:
                matches.append((r, assistant, lo, hi, st))
    return matches

print("\nComputed candidate matches for each Base row:")
computed = {}
for r in range(2, base.max_row + 1):
    logradouro = base.cell(r,3).value
    number = base.cell(r,4).value
    matches = find_match(logradouro, number)
    computed[r] = matches[0][1] if matches else ""
    print(f"Row {r}: street={logradouro!r}, number={number!r}, computed={computed[r]!r}, matches={matches}")

print("\nCompare computed vs sample 'Correct result' in F:")
for r in range(2, base.max_row + 1):
    sample = base.cell(r,6).value
