    for item in street_rows[-5:]:
        print(item)

# Compute results
results = {}
mismatch_examples = []
for r in range(2, base.max_row + 1):
    street_name = base.cell(r,3).value
    num = base.cell(r,4).value
    result = ""
    matched_rows = []
    if street_name is not None and num not in (None, ""):
        try:
            numf = float(num)
            for rec in street_rows:
                if norm_street(street_name) == rec["street_norm"] and rec["start"] <= numf <= rec["end"]:
                    matched_rows.append(rec)
        except Exception:
            matched_rows = []
    if matched_rows:
        # If multiple, keep first in sheet order
        result = matched_rows[0]["assistant"] or ""
    results[r] = result
    
    sample = base.cell(r,6).value
    if sample not in (None, "") and sample != result:
        mismatch_examples.append((r, street_name, num, result, sample, [m["row"] for m in matched_rows]))

print("\nComputed results for all Base rows:")
for r in range(2, base.max_row + 1):
    print(f"Row {r}: Base!C={base.cell(r,3).value!r}, D={base.cell(r,4).value!r} -> E={results[r]!r}, sample F={base.cell(r,6).value!r}")

print("\nNonblank sample mismatches vs computed:", len(mismatch_examples))
for item in mismatch_examples[:10]:
