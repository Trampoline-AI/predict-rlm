import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Final focused inspection before modification
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]
original_sheet_names = wb.sheetnames[:]

print('Original sheet names:', original_sheet_names)
print('Focused rows 9-12, cols A-K before modification:')
for r in range(9, 13):
    vals = [ws.cell(r, c).value for c in range(1, 12)]
    print(f'Row {r}:', vals)

substring_target_rows = []
for r in range(2, ws.max_row + 1):
    e = ws[f'E{r}'].value
    if isinstance(e, str) and 'Georgia Its Tax' in e:
        substring_target_rows.append(r)

print('Rows where column E contains "Georgia Its Tax":', substring_target_rows)
for r in substring_target_rows:
    ecell = ws[f'E{r}']
    fcell = ws[f'F{r}']
    hcell = ws[f'H{r}']
    print(
        f'Before row {r}: E={ecell.value!r}, F={fcell.value!r}, '
        f'H={hcell.value!r}, H_fill={hcell.fill.fill_type}/{hcell.fill.start_color.rgb}'
    )

# Modify workbook
output_dir = '/sandbox/output/output_spreadsheet'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))

wb = load_workbook(input_spreadsheet)
ws = wb[original_sheet_names[0]]

def is_whole_number(val):
    if val is None or isinstance(val, bool):
        return False
    if isinstance(val, int):
        return True
    if isinstance(val, float):
        return val.is_integer()
    try:
        return float(val).is_integer()
    except Exception:
        return False

modified_rows = []
for r in range(2, ws.max_row + 1):
    ecell = ws[f'E{r}']
    fcell = ws[f'F{r}']
    if isinstance(ecell.value, str) and 'Georgia Its Tax' in ecell.value:
        new_text = 'Georgia WH Tax' if is_whole_number(fcell.value) else 'Georgia Sales Tax'
        ecell.value = new_text
        modified_rows.append((r, fcell.value, new_text))

# Clear all used rows in column H: value and fill
for r in range(1, ws.max_row + 1):
    hcell = ws[f'H{r}']
    hcell.value = None
    hcell.fill = PatternFill(fill_type=None)

wb.save(output_path)
print('Saved modified workbook to:', output_path)
print('Modified rows:', modified_rows)

recalc_result = await recalculate(output_path)
print('Recalculate result:', recalc_result)

# Restore original sheet names if needed
wb_post = load_workbook(output_path)
post_names = wb_post.sheetnames[:]
print('Sheet names after recalc:', post_names)
if post_names != original_sheet_names:
    for idx, original_name in enumerate(original_sheet_names):
        if idx < len(wb_post.worksheets):
            wb_post.worksheets[idx].title = original_name
    wb_post.save(output_path)
    print('Restored sheet names to:', original_sheet_names)

# Verify values
verify_wb = load_workbook(output_path, data_only=True)
verify_ws = verify_wb[original_sheet_names[0]]
print('\nVerification rows for targets and column H:')
for r, amt, expected in modified_rows:
    print(f'Row {r}: E={verify_ws[f"E{r}"].value!r}, F={verify_ws[f"F{r}"].value!r}, H={verify_ws[f"H{r}"].value!r}, expected={expected!r}')

# Verify styles from standard load
style_wb = load_workbook(output_path)
style_ws = style_wb[original_sheet_names[0]]
for r, amt, expected in modified_rows:
    hcell = style_ws[f'H{r}']
    print(f'Row {r} H style after save: fill_type={hcell.fill.fill_type}, start_color={hcell.fill.start_color.rgb}, value={hcell.value!r}')

nonblank_h = []
filled_h = []
for r in range(1, style_ws.max_row + 1):
    hcell = style_ws[f'H{r}']
    if hcell.value not in (None, ''):
        nonblank_h.append((r, hcell.value))
    if hcell.fill.fill_type not in (None, ''):
        filled_h.append((r, hcell.fill.fill_type, hcell.fill.start_color.rgb))
print('Nonblank H cells:', nonblank_h)
print('Cells in H still having fill:', filled_h)

output_spreadsheet = output_path
