import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]

opp = wb["Opportunities"]
data_ws = wb["Data"]

# Determine actual populated opportunity rows (skip header; avoid filling empty rows)
target_rows = []
for r in range(2, opp.max_row + 1):
    row_vals = [opp.cell(r, c).value for c in range(1, 8)]
    if any(v is not None for v in row_vals[:5]):  # relevant business columns A:E
        target_rows.append(r)

print("Target rows to fill in Opportunities!G:", target_rows)

# Verify current values before writing
for r in target_rows:
    print(f"Before: D{r}={opp[f'D{r}'].value!r}, E{r}={opp[f'E{r}'].value!r}, G{r}={opp[f'G{r}'].value!r}")

# Write formulas to column G only for relevant rows
for r in target_rows:
    formula = f'=IF(OR(D{r}="",E{r}=""),"",E{r}*VLOOKUP(D{r},Data!$A$1:$B$6,2,FALSE))'
    opp[f"G{r}"] = formula
    # Match revenue formatting if available
    opp[f"G{r}"].number_format = opp[f"E{r}"].number_format

# Print written formulas
for r in target_rows:
    print(f"Written G{r}: {opp[f'G{r}'].value}")

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if changed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    for i, original_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = original_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheetnames)
else:
    print("Sheet names preserved.")

# Verification: reload with formulas and with cached values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)

print("Verified final sheet names:", wb_values.sheetnames)

opp_formula = wb_formula["Opportunities"]
opp_values = wb_values["Opportunities"]

print("\nFinal verification of target cells in Opportunities column G:")
for r in target_rows:
    print(
        f"Row {r}: "
        f"D{r}={opp_values[f'D{r}'].value!r}, "
        f"E{r}={opp_values[f'E{r}'].value!r}, "
        f"G{r}_formula={opp_formula[f'G{r}'].value!r}, "
        f"G{r}_value={opp_values[f'G{r}'].value!r}"
    )

# Basic checks
assert "Opportunities" in wb_values.sheetnames
assert "Data" in wb_values.sheetnames
for r in target_rows:
    assert opp_formula[f"G{r}"].value is not None

final_output_spreadsheet = output_path
