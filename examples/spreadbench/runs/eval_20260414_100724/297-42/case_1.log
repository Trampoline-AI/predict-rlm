orig_sheetnames = wb.sheetnames[:]

print("Original sheet names:", orig_sheetnames)

def values(ws, r, ncols=None):
    ncols = ncols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, ncols + 1)]

# Concise inspection for all sheets
sheet_info = {}
for s in wb.sheetnames:
    ws = wb[s]
    headers = values(ws, 1, ws.max_column)
    nonempty_data_rows = 0
    first_data = None
    last_data = None
    for r in range(2, ws.max_row + 1):
        row = values(ws, r, ws.max_column)
        if any(v not in (None, "") for v in row):
            nonempty_data_rows += 1
            if first_data is None:
                first_data = (r, row)
            last_data = (r, row)
    sheet_info[s] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
        "nonempty_data_rows": nonempty_data_rows,
        "first_data": first_data,
        "last_data": last_data,
    }
    print(f"\n{s}: rows={ws.max_row}, cols={ws.max_column}, nonempty_data_rows={nonempty_data_rows}")
