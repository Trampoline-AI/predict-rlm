from openpyxl import load_workbook
from copy import copy
import os

# Inspect whether source sheets use meaningful cell formatting
wb_chk = load_workbook(input_spreadsheet)
src_ws = wb_chk["sindh"]
cmb_ws = wb_chk["combined"]

print("Source style/format inspection from sindh row 2:")
for col in range(1, 8):  # A:G covers interesting fields
    sc = src_ws.cell(2, col)
    print(col, src_ws.cell(1, col).value, "value=", sc.value, "number_format=", sc.number_format, "style_id=", sc.style_id)

print("\nCurrent combined template/header styles:")
for col in range(1, min(15, cmb_ws.max_column) + 1):
    cc = cmb_ws.cell(1, col)
    print(col, cc.value, "number_format=", cc.number_format, "style_id=", cc.style_id)

# Check the already-written output formatting
out_path = "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)
wb_out = load_workbook(out_path)
ws_out = wb_out["combined"]

print("\nAlready-written combined row 2 styles/formats:")
for col in range(1, 8):
    c = ws_out.cell(2, col)
    print(col, ws_out.cell(1, col).value, "value=", c.value, "number_format=", c.number_format, "style_id=", c.style_id)

# Rebuild combined with copied styles from source rows mapped by header names
orig_sheetnames = wb_out.sheetnames[:]
combined = wb_out["combined"]
target_headers = [combined.cell(1, c).value for c in range(1, combined.max_column + 1)]
target_headers_norm = [str(h).strip() if h is not None else "" for h in target_headers]

# Clear existing data rows only
if combined.max_row > 1:
    for r in range(2, combined.max_row + 1):
        for c in range(1, combined.max_column + 1):
            cell = combined.cell(r, c)
            cell.value = None
            # reset style to default by assigning style from an empty new cell is messy;
            # we'll overwrite styles for used rows below.

write_row = 2
copied_counts = {}

for s in wb_out.sheetnames:
    if s == "combined":
        continue
    ws = wb_out[s]
    src_headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    src_map = {str(h).strip() if h is not None else "": i + 1 for i, h in enumerate(src_headers)}

    cnt = 0
    for r in range(2, ws.max_row + 1):
        if not any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            continue

        for out_c, th in enumerate(target_headers_norm, start=1):
            src_c = src_map.get(th)
            dest = combined.cell(write_row, out_c)
            if src_c:
                src = ws.cell(r, src_c)
                dest.value = src.value
                if src.has_style:
                    dest._style = copy(src._style)
                if src.number_format:
                    dest.number_format = src.number_format
                if src.font:
                    dest.font = copy(src.font)
                if src.fill:
                    dest.fill = copy(src.fill)
                if src.border:
                    dest.border = copy(src.border)
                if src.alignment:
                    dest.alignment = copy(src.alignment)
                if src.protection:
                    dest.protection = copy(src.protection)
            else:
                dest.value = None
        write_row += 1
        cnt += 1
    copied_counts[s] = cnt

# Save
wb_out.save(out_path)
print("\nRewrote combined with styles copied. Counts:", copied_counts, "Total rows:", write_row - 2)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if needed
wb_post = load_workbook(out_path)
if wb_post.sheetnames != orig_sheetnames and len(wb_post.sheetnames) == len(orig_sheetnames):
    for cur_name, orig_name in zip(wb_post.sheetnames, orig_sheetnames):
        wb_post[cur_name].title = orig_name
    wb_post.save(out_path)
