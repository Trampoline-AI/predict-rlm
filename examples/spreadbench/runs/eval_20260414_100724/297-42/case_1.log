    print(col, vws.cell(1, col).value, "value=", c.value, "number_format=", c.number_format, "style_id=", c.style_id)

print("\nKey cells:")
for addr in ["A2", "B2", "O2", f"A{vws.max_row}", f"O{vws.max_row}"]:
    print(addr, "=", vws[addr].value)

final_output_spreadsheet = out_path
