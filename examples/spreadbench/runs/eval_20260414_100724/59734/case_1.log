    # detect non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print(f"nonempty row count={len(nonempty_rows)}; first rows={nonempty_rows[:10]} last rows={nonempty_rows[-10:] if nonempty_rows else []}")
    
    # print first 10 rows with coordinates
    print("\nFirst up to 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        row = {}
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                row[f"{get_column_letter(c)}{r}"] = display_val(v)
        print(row)
    
    # find likely header row among first 5 rows: row with most non-empty string-like cells
    best_row = None
    best_score = -1
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        score = sum(1 for v in vals if isinstance(v, str) and v.strip() != "")
        if score > best_score:
            best_score = score
            best_row = r
    print(f"\nLikely header row: {best_row}")
    headers = [ws.cell(best_row, c).value for c in range(1, ws.max_column + 1)] if best_row else []
    print("Headers:", {get_column_letter(i+1): display_val(h) for i,h in enumerate(headers)})
    
    # sample data rows after header
    if best_row and ws.max_row > best_row:
        print("\nSample rows after header (first 5):")
        for r in range(best_row + 1, min(ws.max_row, best_row + 5) + 1):
            vals = [display_val(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
            print(f"Row {r}: {vals}")
        
        print("\nLast 5 non-empty rows:")
        last_rows = nonempty_rows[-5:]
        for r in last_rows:
            vals = [display_val(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
            print(f"Row {r}: {vals}")
    
    # print formula cells in first 20 rows
    formula_cells = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("\nFormula cells in first 20 rows:", formula_cells[:20], f"(total shown {len(formula_cells[:20])})")
