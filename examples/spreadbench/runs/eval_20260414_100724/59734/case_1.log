# Helper to restore original sheet names if recalculate/localization changed them
def restore_sheet_names_if_needed(path, original_names):
    wb_tmp = load_workbook(path)
    changed = wb_tmp.sheetnames != original_names
    if changed and len(wb_tmp.sheetnames) == len(original_names):
        for ws_obj, orig_name in zip(wb_tmp.worksheets, original_names):
            ws_obj.title = orig_name
        wb_tmp.save(path)
    return changed

# Helper to verify output values after recalc
def read_b_values(path):
    wb_data = load_workbook(path, data_only=True)
    ws_data = wb_data[orig_sheet_names[0]]
    vals = {}
    for r in range(2, max_row + 1):
        vals[r] = ws_data.cell(r, 2).value
