    ws2 = wb2["Sheet1"]
    formula_attempt_2 = {}
    for r in range(2, max_row + 1):
        formula = (
            f'=IFERROR(XLOOKUP(1,($S$2:$S${max_row}=A{r})*($O$2:$O${max_row}=F{r})*($P$2:$P${max_row}=G{r}),$V$2:$V${max_row},""),"")'
        )
        ws2.cell(r, 2).value = formula
