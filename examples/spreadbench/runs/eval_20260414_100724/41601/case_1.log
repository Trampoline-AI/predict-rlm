from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Students"]

print("Before modification, target cells in Students!A:E")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    print(f"R{r}: {vals}")

# Determine rows needing output based on non-empty names in column A
target_rows = []
for r in range(2, ws.max_row + 1):
    name = ws.cell(r, 1).value
    if name not in (None, ""):
        target_rows.append(r)

print("Target rows:", target_rows)
print("Existing formulas/values in column E before change:")
for r in target_rows:
    print(f"E{r} =", ws.cell(r, 5).value)

# Write dynamic formula in existing Age column E
for r in target_rows:
    formula = f'=IF(A{r}="","",INDIRECT("\'"&A{r}&"\'!C2"))'
    ws.cell(r, 5).value = formula

print("\nFormulas written to column E:")
for r in target_rows:
    print(f"E{r} =", ws.cell(r, 5).value)

wb.save(outfile)
print("\nSaved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open after recalc, repair any sheet-name changes if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc; restoring original names.")
    for i, expected in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    wb_after = load_workbook(outfile)
    print("Sheet names after restoration:", wb_after.sheetnames)

# Verify calculated results with data_only=True
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Students"]

print("\nVerification of Students!A:E after recalc (data_only=True):")
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 6)]
    print(f"R{r}: {vals}")

print("\nExact target cell verification:")
verification = {}
for r in target_rows:
    verification[f"E{r}"] = wsv.cell(r, 5).value
print(verification)

# Keep path in variable for submission
final_output_path = outfile
