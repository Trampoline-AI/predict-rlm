from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

wb = load_workbook(input_spreadsheet)
print("Workbook loaded:", input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def sheet_nonempty_bounds(ws):
    max_r, max_c = ws.max_row, ws.max_column
    # determine practical last non-empty row/col
    last_row = 0
    last_col = 0
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value not in (None, ""):
                row_has = True
                if cell.column > last_col:
                    last_col = cell.column
        if row_has:
            last_row = row[0].row
    return last_row or max_r, last_col or max_c

for sname in wb.sheetnames:
    ws = wb[sname]
    last_row, last_col = sheet_nonempty_bounds(ws)
    headers = []
    if last_row >= 1:
        for c in range(1, min(last_col, 20) + 1):
            headers.append(ws.cell(1, c).value)
    print(f"\n--- Sheet: {sname} ---")
    print("max_row/max_col:", ws.max_row, ws.max_column, "practical_last_row/col:", last_row, last_col)
    print("Row 1 headers/values:", headers)
    
    # first 10 rows, up to 10 cols
    print("First rows:")
    for r in range(1, min(last_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(last_col, 10) + 1)]
        print(f"R{r}: {vals}")
    
    # last 5 rows if different
    if last_row > 10:
        print("Last rows:")
        for r in range(max(1, last_row - 4), last_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, min(last_col, 10) + 1)]
            print(f"R{r}: {vals}")

# Focus on likely target sheet
if "Students" in wb.sheetnames:
    ws = wb["Students"]
    print("\n=== Detailed inspection: Students sheet ===")
    # print columns A-F and formulas/values for first 20 rows
    for r in range(1, min(ws.max_row, 20) + 1):
        row_desc = []
        for c in range(1, min(ws.max_column, 6) + 1):
            cell = ws.cell(r, c)
            row_desc.append(f"{get_column_letter(c)}{r}={cell.value!r}")
        print(" | ".join(row_desc))
else:
    print("\nNo sheet literally named 'Students' found.")
