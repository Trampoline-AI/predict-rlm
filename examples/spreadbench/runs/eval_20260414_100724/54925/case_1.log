import os, shutil
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Load workbook for editing
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Target sheet:", ws.title)
print("max_row/max_col:", ws.max_row, ws.max_column)

# Show exact current target area and referenced cells
print("Referenced cells:",
      {"M3": ws["M3"].value, "N3": ws["N3"].value, "N4": ws["N4"].value})

for ref in ["Q1","Q2","Q3","Q4","Q5","Q6","Q7","Q8","Q9","Q10"]:
    v = ws[ref].value
    if hasattr(v, "text"):
        print(ref, "ArrayFormula:", v.text, "ref=", getattr(v, "ref", None))
    else:
        print(ref, "value:", v)

# Compute matches from actual data
h_target = ws["M3"].value
k_targets = {ws["N3"].value, ws["N4"].value}

matches = []
for r in range(2, 41):  # exact referenced range in instruction/formula
    h = ws[f"H{r}"].value
    k = ws[f"K{r}"].value
    b = ws[f"B{r}"].value
    if h == h_target and k in k_targets:
        matches.append((r, b, h, k))

print("Computed matches (row, B, H, K):", matches)
print("Match count:", len(matches))

# Exact target output range: column Q, starting Q2 based on existing formula pattern (Q1 would be blank)
yellow_fill = PatternFill(start_color="FFFFFF00", end_color="FFFFFF00", fill_type="solid")
green_fill  = PatternFill(start_color="FF00FF00", end_color="FF00FF00", fill_type="solid")
clear_fill = PatternFill(fill_type=None)

# Clear old output in Q1:Q40 (values + fill) because it currently contains broken array formulas
for r in range(1, 41):
    cell = ws[f"Q{r}"]
    cell.value = None
    cell.fill = clear_fill

# Preserve the original pattern: Q1 blank, write results from Q2 downward
start_row = 2
for idx, (src_row, bval, hval, kval) in enumerate(matches, start=start_row):
    cell = ws[f"Q{idx}"]
    cell.value = bval
    if kval == ws["N3"].value:      # TM
        cell.fill = yellow_fill
    elif kval == ws["N4"].value:    # HD
        cell.fill = green_fill

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_post = load_workbook(outfile)
if wb_post.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_post.sheetnames, "-> restoring", orig_sheet_names)
    for i, s in enumerate(orig_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = s
    wb_post.save(outfile)

# Verification: values with data_only, fills with normal load
wb_val = load_workbook(outfile, data_only=True)
ws_val = wb_val[orig_sheet_names[0]]

wb_fmt = load_workbook(outfile, data_only=False)
ws_fmt = wb_fmt[orig_sheet_names[0]]

print("\nVerified target cells in column Q:")
for r in range(1, 41):
    val = ws_val[f"Q{r}"].value
    fill = ws_fmt[f"Q{r}"].fill
    color = None
    if fill and fill.fill_type == "solid":
        color = fill.start_color.rgb
    if val is not None or r <= start_row + len(matches):
        print(f"Q{r}: value={val!r}, fill={color}")

# Sanity checks
written_vals = [ws_val[f"Q{r}"].value for r in range(2, 41) if ws_val[f"Q{r}"].value is not None]
expected_vals = [m[1] for m in matches]
print("\nExpected values:", expected_vals)
print("Written values :", written_vals)
print("Match:", expected_vals == written_vals)
print("Sheet names final:", wb_fmt.sheetnames)

output_spreadsheet = outfile
