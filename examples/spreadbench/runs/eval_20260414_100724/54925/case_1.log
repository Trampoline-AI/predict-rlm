    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # detect likely used rows/cols
    used_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            used_rows.append(r)
    used_cols = []
    for c in range(1, ws.max_column + 1):
        vals = [ws.cell(r, c).value for r in range(1, ws.max_row + 1)]
        if any(v is not None for v in vals):
            used_cols.append(c)
    print("Used row span:", (min(used_rows), max(used_rows)) if used_rows else None)
    print("Used cols:", [f"{get_column_letter(c)}" for c in used_cols])
    
    # print first 10 rows and last 5 rows, bounded by non-empty rows if possible
    sample_rows = []
    if used_rows:
        first_rows = list(range(1, min(ws.max_row, 10) + 1))
        last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
        sample_rows = []
        seen = set()
        for r in first_rows + last_rows:
            if r not in seen:
                sample_rows.append(r)
                seen.add(r)
        for r in sample_rows:
            row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}: {row_vals}")
    
    # headers from first few rows
    for hdr_row in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(hdr_row, c).value for c in range(1, ws.max_column + 1)]
        print(f"Potential header row {hdr_row}: {vals}")

    # print specific referenced cells if they exist
    refs = ["M3", "N3", "N4"]
    for ref in refs:
        try:
            print(f"{ws.title}!{ref} =", ws[ref].value)
        except Exception as e:
            print(f"{ws.title}!{ref} error:", e)

    # print columns B,H,K,M,N around rows 1:40
    for col in ["B", "H", "K", "M", "N"]:
        vals = [ws[f"{col}{r}"].value for r in range(1, min(ws.max_row, 40)+1)]
        nonempty = [(r, v) for r, v in enumerate(vals, start=1) if v is not None]
        print(f"{ws.title} col {col} nonempty rows 1:40 ->", nonempty[:15], "... total", len(nonempty))
    
    # inspect B1:B20 formulas/values
    for r in range(1, min(ws.max_row, 20)+1):
        v = ws[f"B{r}"].value
        if v is not None:
            print(f"{ws.title}!B{r} = {v!r}")

print("\nInspection complete.")
