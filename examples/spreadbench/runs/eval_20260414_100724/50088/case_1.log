from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
print("Input path:", input_path)
print("Sheet names:", wb.sheetnames)

def display_value(v):
    try:
        s = str(v)
    except Exception:
        s = repr(v)
    if len(s) > 80:
        s = s[:77] + "..."
    return s

workbook_summary = {}

for ws in wb.worksheets:
    max_row, max_col = ws.max_row, ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    workbook_summary[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers": headers,
    }
    print(f"\n=== Sheet: {ws.title} ===")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers row 1:", headers)
    
    sample_top_end = min(max_row, 10)
    print("Top rows:")
    for r in range(1, sample_top_end + 1):
        vals = [display_value(ws.cell(r, c).value) for c in range(1, max_col + 1)]
        print(f"Row {r}: {vals}")
    
    if max_row > 10:
        print("Bottom rows:")
        start = max(1, max_row - 4)
        for r in range(start, max_row + 1):
            vals = [display_value(ws.cell(r, c).value) for c in range(1, max_col + 1)]
            print(f"Row {r}: {vals}")

# Search for Expected Answer and formulas
print("\n=== Search for 'Expected Answer' and formulas ===")
matches = []
formula_cells = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                if "Expected Answer" in v:
                    matches.append((ws.title, cell.coordinate, v))
                if v.startswith("="):
                    formula_cells.append((ws.title, cell.coordinate, v))
print("Expected Answer matches:", matches[:20])
print("Number of formula cells:", len(formula_cells))
print("First 50 formula cells:")
for item in formula_cells[:50]:
    print(item)

# Also inspect columns A and B specifically on all sheets
print("\n=== Column A/B inspection ===")
for ws in wb.worksheets:
    print(f"\nSheet {ws.title}:")
    for r in range(1, min(ws.max_row, 15) + 1):
        a = ws[f"A{r}"].value
        b = ws[f"B{r}"].value
        c = ws[f"C{r}"].value if ws.max_column >= 3 else None
        d = ws[f"D{r}"].value if ws.max_column >= 4 else None
        print(f"Row {r}: A={display_value(a)}, B={display_value(b)}, C={display_value(c)}, D={display_value(d)}")
