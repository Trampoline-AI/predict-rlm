```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Here"]

print("Original sheet names:", original_sheet_names)
print("Target sheet:", ws.title)
print("Target column J header:", ws["J1"].value)
print("Current sample J2:J6 before writing:")
for r in range(2, 7):
    print(r, "I=", ws.cell(r, 9).value, "J=", ws.cell(r, 10).value)

# Write formulas to Outcome column J for all rows in the existing used range
# Logic:
# - blank I => blank
# - if there are two delimiters " - ", extract between first and second
# - otherwise extract text before first delimiter
for r in range(2, ws.max_row + 1):
    formula = (
        f'=IF(I{r}="","",'
        f'IFERROR('
        f'MID(I{r},FIND(" - ",I{r})+3,FIND(" - ",I{r},FIND(" - ",I{r})+3)-FIND(" - ",I{r})-3),'
        f'LEFT(I{r},FIND(" - ",I{r})-1)'
        f'))'
    )
    ws.cell(r, 10).value = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # Rename by position back to original names
    for idx, orig_name in enumerate(original_sheet_names):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(output_path)
    print("Sheet names restored to:", original_sheet_names)
else:
    print("Sheet names preserved after recalc.")

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify["Here"]

print("Verification of target cells J2:J10:")
for r in range(2, 11):
    print(
        f"Row {r}: "
        f"I={wsv.cell(r,9).value!r}, "
        f"J={wsv.cell(r,10).value!r}"
    )

print("Focused verification of expected filled rows J2:J6:")
for r in range(2, 7):
    jv = wsv.cell(r, 10).value
    print(f"Row {r}: J={jv!r}")

# Also inspect formulas as written
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Here"]
print("Written formulas J2:J6:")
for r in range(2, 7):
    print(r, wsf.cell(r, 10).value)

final_output_path = output_path
