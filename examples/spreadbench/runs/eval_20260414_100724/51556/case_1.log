```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Build a LibreOffice-friendly formula:
# For each matrix row, sum matching columns for the requested size in P[row],
# but only if that row's improvement rating in M matches S2.
num_terms = []
den_terms = []
for r in range(3, 9):
    num_terms.append(f'(SUMPRODUCT((B$2:L$2=P2)*($B${r}:$L${r}))*($M${r}=$S$2))')
    den_terms.append(f'(SUMPRODUCT((B$2:L$2=P2)*(--ISNUMBER($B${r}:$L${r})))*($M${r}=$S$2))')

base_formula = f'=IFERROR(({" + ".join(num_terms)})/({" + ".join(den_terms)}),"")'
print("Base formula for Q2:")
print(base_formula)

yellow_fill = PatternFill(start_color="FFFFFF00", end_color="FFFFFF00", fill_type="solid")

# Write formulas to Q2:Q6, adjusting only the P-row reference per row
for row in range(2, 7):
    f = base_formula.replace("P2", f"P{row}")
    print(f"Writing {f} to Q{row}; previous value={ws[f'Q{row}'].value}, previous fill={ws[f'Q{row}'].fill.fgColor.rgb}")
    ws[f"Q{row}"] = f
    ws[f"Q{row}"].fill = yellow_fill

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheet_names:
    # restore by position
    for i, expected in enumerate(orig_sheet_names):
        if i < len(wb2.worksheets):
            wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Restored sheet names to:", wb2.sheetnames)

# Verify formulas
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]

print("\nFormula verification Q2:Q6")
for row in range(2, 7):
    print(f"Q{row} formula:", wsf[f"Q{row}"].value, "| fill:", wsf[f"Q{row}"].fill.fill_type, wsf[f"Q{row}"].fill.fgColor.rgb)

# Verify cached values after recalc
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]

print("\nData-only verification Q2:Q6 with drivers P/S")
for row in range(2, 7):
    print(f"Row {row}: P={wsv[f'P{row}'].value}, S2={wsv['S2'].value}, Q={wsv[f'Q{row}'].value}")

# Also print expected values from Python sanity-check
print("\nExpected values by Python sanity-check for S2='B':")
expected = {2: None, 3: 82, 4: None, 5: None, 6: 117}
for row in range(2, 7):
    print(f"Q{row} expected ~ {expected[row]}")

output_spreadsheet = outfile
print("\nPrepared output_spreadsheet =", output_spreadsheet)
