import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Load source workbook
src_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src_path))

wb = load_workbook(src_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheet_names)
print("Target header Q1:", ws["Q1"].value)
print("Existing target cells before write:", {f"Q{r}": ws[f"Q{r}"].value for r in range(2, ws.max_row + 1)})

# Determine actual data rows
data_rows = []
for r in range(2, ws.max_row + 1):
    golfer = ws.cell(r, 1).value
    scores = [ws.cell(r, c).value for c in range(2, 15)]  # B:N
    if golfer is not None and any(v is not None and v != "" for v in scores):
        data_rows.append(r)

print("Data rows to populate:", data_rows)

# Compute expected values in Python for verification / fallback
expected = {}
for r in data_rows:
    vals = [ws.cell(r, c).value for c in range(2, 15)]
    nums = [v for v in vals if isinstance(v, (int, float))]
    last4 = nums[-4:] if nums else []
    expected[r] = (sum(last4) / len(last4)) if last4 else None
    print(f"Row {r} golfer={ws.cell(r,1).value} scores={vals} -> expected last4 avg={expected[r]}")

# Write formulas into exact target cells Q2:Qn
# Formula logic:
# - COUNT(B:N)=0 => blank
# - otherwise find the column position of the 4th-latest nonblank (or fewer if <4)
# - average numeric cells at/after that threshold
for r in data_rows:
    formula = (
        f'=IF(COUNT(B{r}:N{r})=0,"",'
        f'SUMPRODUCT(B{r}:N{r},--(COLUMN(B{r}:N{r})>=LARGE((B{r}:N{r}<>"")*COLUMN(B{r}:N{r}),MIN(4,COUNT(B{r}:N{r})))))/MIN(4,COUNT(B{r}:N{r})))'
    )
    ws[f"Q{r}"] = formula
    # Match nearby formatting where possible
    ws[f"Q{r}"]._style = copy(ws[f"P{r}"]._style)
    ws[f"Q{r}"].number_format = ws[f"P{r}"].number_format or "0.00"

print("Written formulas:")
for r in data_rows:
    print(f"Q{r} = {ws[f'Q{r}'].value}")

# Save initial output
wb.save(out_path)
print("Saved workbook to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if LibreOffice changed them
wb_check = load_workbook(out_path)
current_sheet_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_sheet_names)
if current_sheet_names != original_sheet_names and len(current_sheet_names) == len(original_sheet_names):
    for idx, original_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = original_name
    wb_check.save(out_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formula results
wb_formula = load_workbook(out_path)
wb_values = load_workbook(out_path, data_only=True)
wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

verification = {}
formula_failed = False
for r in data_rows:
    q_formula = wsf[f"Q{r}"].value
    q_value = wsv[f"Q{r}"].value
    verification[r] = {"formula": q_formula, "value": q_value, "expected": expected[r]}
    if q_value is None or (isinstance(q_value, str) and q_value.startswith("#")):
        formula_failed = True

print("Verification after formula recalc:")
for r, info in verification.items():
    print(f"Row {r}: formula={info['formula']!r}, value={info['value']!r}, expected={info['expected']!r}")

# Fallback to literal values if formula evaluation failed
if formula_failed:
    print("Formula evaluation failed in at least one target cell; falling back to literal values.")
    wb_fallback = load_workbook(out_path)
    ws_fb = wb_fallback["Sheet1"]
    for r in data_rows:
        ws_fb[f"Q{r}"] = expected[r]
        ws_fb[f"Q{r}"]._style = copy(ws_fb[f"P{r}"]._style)
        ws_fb[f"Q{r}"].number_format = ws_fb[f"P{r}"].number_format or "0.00"
    wb_fallback.save(out_path)
    print("Saved fallback literal values.")

    recalc_result2 = await recalculate(out_path)
    print("Recalculate after fallback:", recalc_result2)

    wb_post = load_workbook(out_path)
    if wb_post.sheetnames != original_sheet_names and len(wb_post.sheetnames) == len(original_sheet_names):
        for idx, original_name in enumerate(original_sheet_names):
            wb_post.worksheets[idx].title = original_name
        wb_post.save(out_path)
        print("Restored sheet names again:", original_sheet_names)

    wb_values2 = load_workbook(out_path, data_only=True)
    wsv2 = wb_values2["Sheet1"]
    print("Verification after fallback:")
    for r in data_rows:
        print(f"Q{r} value={wsv2[f'Q{r}'].value!r}, expected={expected[r]!r}")

# Final explicit target-range verification
final_values_wb = load_workbook(out_path, data_only=True)
final_ws = final_values_wb["Sheet1"]
print("Final target cells Q2:Q5:")
for r in data_rows:
    print(f"Q{r} -> {final_ws[f'Q{r}'].value!r}")

# Keep output path available for submission next turn
output_spreadsheet_path = out_path
print("Ready to submit:", output_spreadsheet_path)
