from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    if ws.merged_cells.ranges:
        print("Merged ranges:", [str(r) for r in list(ws.merged_cells.ranges)[:10]])
    else:
        print("Merged ranges: none")
    
    # detect non-empty rows and cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            nonempty_rows.append(r)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    
    # show columns letters
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    headers3 = row_values(ws, 3, ws.max_column) if ws.max_row >= 3 else []
    print("Row 1:", headers1)
    if headers2: print("Row 2:", headers2)
    if headers3: print("Row 3:", headers3)
    
    top_rows = list(range(1, min(ws.max_row, 10) + 1))
    bottom_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("\nTop sample rows:")
    for r in top_rows:
        print(r, row_values(ws, r, ws.max_column))
    print("\nBottom sample rows:")
    for r in bottom_rows:
        print(r, row_values(ws, r, ws.max_column))
    
    # print focused area around B9:B13 and neighboring columns
