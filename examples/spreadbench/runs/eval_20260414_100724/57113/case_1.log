```repl
import os, re, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload original workbook
wb = load_workbook(input_spreadsheet)
orig_names = wb.sheetnames[:]
ws = wb[orig_names[0]]

def find_last_nonempty_row(ws):
    for r in range(ws.max_row, 0, -1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            return r
    return 1

last_row = find_last_nonempty_row(ws)

# Inspect hashtag counts from actual tweet text
hashtag_pattern = re.compile(r'#([^\s#]+)')
tweet_rows = []
max_hashtags = 0
for r in range(2, last_row + 1):
    tweet = ws.cell(r, 1).value
    if tweet not in (None, ""):
        tags = hashtag_pattern.findall(str(tweet))
        tweet_rows.append((r, tweet, tags))
        max_hashtags = max(max_hashtags, len(tags))

print("Rows with tweet data and parsed hashtags:")
for r, tweet, tags in tweet_rows:
    print(f"Row {r}: tweet={tweet!r} -> hashtags={tags}")

print("Max hashtags in any row:", max_hashtags)

# Print current target area before modification
target_end_col = 1 + max(max_hashtags, ws.max_column - 1)
print("Current target cells before writing:")
for r in range(1, last_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, target_end_col + 1)]
    print(f"Row {r}: {vals}")

# Write formulas starting at column B.
# Formula logic:
# - nth hashtag is driven by COLUMN()-1, so B=1st, C=2nd, D=3rd, ...
# - extract from column A directly
# - start after the # sign (+1)
# - return blank if that hashtag does not exist
for r in range(2, last_row + 1):
    if ws.cell(r, 1).value in (None, ""):
        continue
    for c in range(2, 2 + max_hashtags):
        formula = (
            f'=IFERROR(TRIM(LEFT(SUBSTITUTE('
            f'MID($A{r},FIND(CHAR(1),SUBSTITUTE($A{r},"#",CHAR(1),COLUMN()-1))+1,LEN($A{r})),'
            f'" ",REPT(" ",100)),100)),"")'
        )
        ws.cell(r, c).value = formula

# Keep header row unchanged; do not modify row 1.
# Save to output path with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved workbook to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(out_path)
current_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != orig_names and len(current_names) == len(orig_names):
    for idx, old_name in enumerate(orig_names):
        wb_after[current_names[idx]].title = old_name
    wb_after.save(out_path)
    print("Restored original sheet names:", orig_names)

# Verify using data_only
wb_verify = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_names[0]]

print("Verification of target cells after recalculation:")
for r in range(1, last_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, 2 + max_hashtags)]
    print(f"Row {r}: {vals}")

# Also print formulas from the saved workbook for the target cells
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_names[0]]
print("Stored formulas in target range:")
for r in range(2, last_row + 1):
    details = []
    for c in range(2, 2 + max_hashtags):
        details.append(f"{get_column_letter(c)}{r}={wsf.cell(r,c).value}")
    print(" | ".join(details))

output_spreadsheet = out_path
print("Prepared output_spreadsheet:", output_spreadsheet)
