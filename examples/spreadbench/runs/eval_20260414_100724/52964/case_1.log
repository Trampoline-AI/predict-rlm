Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load and inspect exact target extents before writing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

def last_nonempty_row_in_col(ws, col_idx):
    for r in range(ws.max_row, 0, -1):
        if ws.cell(r, col_idx).value not in (None, ""):
            return r
    return 1

last_a = last_nonempty_row_in_col(ws, 1)   # A
last_q = last_nonempty_row_in_col(ws, 17)  # Q
last_u = last_nonempty_row_in_col(ws, 21)  # U
last_y = last_nonempty_row_in_col(ws, 25)  # Y
lookup_last = max(last_q, last_u, last_y)

target_rows = [r for r in range(2, last_a + 1) if ws.cell(r, 1).value not in (None, "")]
print("Original sheet names:", orig_sheetnames)
print("last_a:", last_a, "last_q:", last_q, "last_u:", last_u, "last_y:", last_y, "lookup_last:", lookup_last)
print("Target rows:", target_rows)
print("Before write: C2:C15, D2:D15")
for r in target_rows:
    print(r, "A=", ws[f"A{r}"].value, "C=", ws[f"C{r}"].value, "D=", ws[f"D{r}"].value)

# Write formulas only into blank C cells for rows with MRNs in A
# Using INDEX/MATCH to match workbook style and guard blank death dates.
for r in target_rows:
    if ws[f"C{r}"].value in (None, ""):
        formula = (
            f'=IFERROR('
            f'IF(INDEX($Y$2:$Y${lookup_last},MATCH($A{r},$Q$2:$Q${lookup_last},0))="",'
            f'"",'
            f'INDEX($Y$2:$Y${lookup_last},MATCH($A{r},$Q$2:$Q${lookup_last},0))'
            f'-INDEX($U$2:$U${lookup_last},MATCH($A{r},$Q$2:$Q${lookup_last},0))'
            f'),'
            f'"")'
        )
        ws[f"C{r}"] = formula

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames:
    # rename by position back to original
    for i, name in enumerate(orig_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = name
    wb_check.save(outfile)
    print("Restored sheet names:", wb_check.sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

print("\nVerification: target cells in column C")
for r in target_rows:
    print(
        f"Row {r}:",
        "A=", ws_values[f"A{r}"].value,
        "formula=", ws_formula[f"C{r}"].value,
        "value=", ws_values[f"C{r}"].value,
        "U=", ws_values[f"U{r}"].value if r <= ws_values.max_row else None,
        "Y=", ws_values[f"Y{r}"].value if r <= ws_values.max_row else None,
    )

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
