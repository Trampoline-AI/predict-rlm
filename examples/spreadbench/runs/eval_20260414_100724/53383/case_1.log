import os, json, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Input path:", path)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Detect non-empty rows/cols more carefully
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    if nonempty_rows:
        print("Non-empty row range:", min(nonempty_rows), "to", max(nonempty_rows), "count:", len(nonempty_rows))
    else:
        print("No non-empty rows")
        return
    
    # Print first several rows with coordinates
    first_rows = nonempty_rows[:10]
    last_rows = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
    rows_to_show = first_rows + [r for r in last_rows if r not in first_rows]
    
    # Header guess = first non-empty row
    header_row = nonempty_rows[0]
    headers = [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]
    print("Header row guess:", header_row)
    print("Headers:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}{header_row}: {h!r}")
    
    print("\nSample rows:")
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # Print formulas if any in used range
    formula_cells = []
    for r in nonempty_rows:
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((ws.cell(r, c).coordinate, v))
    print("Formula cells found:", len(formula_cells))
    for coord, formula in formula_cells[:20]:
        print(f"  {coord}: {formula}")
    if len(formula_cells) > 20:
        print("  ...")
    
    # Print a focused preview of columns A-D for all non-empty rows if sheet is small
    if len(nonempty_rows) <= 30:
        print("\nFocused A:D preview:")
        for r in nonempty_rows:
            vals = [ws.cell(r, c).value for c in range(1, min(4, ws.max_column) + 1)]
            print(f"  {r}: {vals}")

for ws in wb.worksheets:
    sheet_summary(ws)
