```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws1 = wb["worksheet 1"]
ws2 = wb["worksheet2"]

print("Original sheet names:", original_sheetnames)

# Inspect exact target area and current values
print("\nTarget/output area inspection:")
for r in range(2, ws2.max_row + 1):
    print(f"Row {r}: A={ws2[f'A{r}'].value!r}, B={ws2[f'B{r}'].value!r}, C={ws2[f'C{r}'].value!r}")

# Determine data ranges more carefully
def last_nonempty_row(ws, cols=None):
    cols = cols or range(1, ws.max_column + 1)
    last = 0
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in cols):
            last = r
    return last

src_last = last_nonempty_row(ws1, cols=[1, 2])
tgt_last = last_nonempty_row(ws2, cols=[1, 2, 3])

print("\nDetected ranges:")
print("worksheet 1 last non-empty row:", src_last)
print("worksheet2 last non-empty row:", tgt_last)

# Headers appear on row 2; data starts on row 3
src_start = 3
tgt_start = 3

# Print source lookup range values explicitly
print("\nSource lookup values from worksheet 1:")
for r in range(src_start, src_last + 1):
    print(f"  A{r}={ws1[f'A{r}'].value!r}, B{r}={ws1[f'B{r}'].value!r}")

# Fill only blank target cells in column C where rows have data
written = []
for r in range(tgt_start, tgt_last + 1):
    a = ws2[f"A{r}"].value
    b = ws2[f"B{r}"].value
    c = ws2[f"C{r}"].value
    
    if a in (None, "") and b in (None, ""):
        continue
    
    # Preserve existing example answers / nonblank outputs
    if c not in (None, ""):
        continue
    
    formula = (
        f'=IF(A{r}="","",'
        f'IFERROR('
        f'IF(TRIM(B{r})=TRIM(VLOOKUP(A{r},\'worksheet 1\'!$A${src_start}:$B${src_last},2,FALSE)),"Matched","Not Matched"),'
        f'"Not Matched"))'
    )
    ws2[f"C{r}"] = formula
    written.append((f"C{r}", formula))

print("\nFormulas written:")
for coord, formula in written:
    print(coord, "->", formula)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc reload:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename by position back to originals
    for ws, original_name in zip(wb_after.worksheets, original_sheetnames):
        ws.title = original_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", original_sheetnames)

# Verification with formulas visible
wb_verify_formula = load_workbook(output_path, data_only=False)
ws2f = wb_verify_formula["worksheet2"]

print("\nVerification - formula view C2:C6:")
for r in range(2, min(6, ws2f.max_row) + 1):
    print(f"C{r}: {ws2f[f'C{r}'].value!r}")

# Verification with calculated values
wb_verify_values = load_workbook(output_path, data_only=True)
ws2v = wb_verify_values["worksheet2"]

print("\nVerification - calculated values A:C rows 2-6:")
for r in range(2, min(6, ws2v.max_row) + 1):
    vals = [ws2v.cell(r, c).value for c in range(1, 4)]
    print(f"Row {r}: {vals}")

# Store output path for submission
final_output_path = output_path
print("\nReady to submit:", final_output_path)
```
