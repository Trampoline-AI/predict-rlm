import os, json, re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INPUT:", input_spreadsheet)
print("INSTRUCTION:\n", instruction)

wb = load_workbook(input_spreadsheet)
print("\nSHEETS:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for s in wb.sheetnames:
    ws = wb[s]
    print(f"\n=== SHEET: {s} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row 2 values:", row_values(ws, 2, ws.max_column))
    
    # first 10 rows
    first_n = min(10, ws.max_row)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Specific cells/ranges of interest
    print("\nKey cell checks:")
    for coord in ["A13", "B13", "I13"]:
        if ws.max_row >= 13 and ws.max_column >= 9:
            print(coord, "=", ws[coord].value)
        elif coord[0] != "I" or ws.max_column >= 9:
            try:
                print(coord, "=", ws[coord].value)
            except Exception as e:
                print(coord, "unavailable:", e)
    
    # Print A,B,I columns around row 13 if they exist
    if ws.max_row >= 1:
        print("\nRows around 13 for cols A,B,I:")
        for r in range(max(1, 13-5), min(ws.max_row, 13+5) + 1):
            vals = {}
            vals["A"] = ws.cell(r, 1).value
            vals["B"] = ws.cell(r, 2).value if ws.max_column >= 2 else None
            vals["I"] = ws.cell(r, 9).value if ws.max_column >= 9 else None
            print(r, vals)

# Search formulas and array formulas
print("\n=== FORMULA SEARCH ===")
formula_hits = []
for s in wb.sheetnames:
    ws = wb[s]
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                text = v.upper()
                if ("SUMIF" in text or "SUMPRODUCT" in text or "$I" in text or "I:" in text or "A13" in text):
                    formula_hits.append((s, cell.coordinate, v))
            else:
                # catch array formula objects or other formula-like objects
                if hasattr(v, "text"):
                    formula_text = v.text
                    up = str(formula_text).upper()
                    if ("SUMIF" in up or "SUMPRODUCT" in up or "$I" in up or "I:" in up or "A13" in up):
                        formula_hits.append((s, cell.coordinate, f"[ARRAY]{formula_text}"))

print("Relevant formula hits count:", len(formula_hits))
for hit in formula_hits[:50]:
    print(hit)

# Also print all non-empty cells in row 13 for each sheet to locate intended target
print("\n=== ROW 13 NON-EMPTY CELLS ===")
for s in wb.sheetnames:
    ws = wb[s]
    if ws.max_row >= 13:
        vals = []
        for c in range(1, ws.max_column + 1):
            v = ws.cell(13, c).value
            if v not in (None, ""):
                vals.append((get_column_letter(c), v))
        print(s, vals)

# Persist workbook object and path info for next iteration
input_wb = wb
