wb_values = load_workbook(input_spreadsheet, data_only=True)
wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

print("Target cell before change:")
print("A13 =", wsf["A13"].value)
print("B13 formula =", wsf["B13"].value)
print("B13 cached value =", wsv["B13"].value)

b14v = wsf["B14"].value
