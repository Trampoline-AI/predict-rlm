print("B14 formula/object =", b14_formula_text)
print("B14 cached value =", wsv["B14"].value)

# Compute expected result in Python for sanity check
target_text = str(wsf["A13"].value or "")
matches = []
expected_sum = 0
for r in range(4, 11):
    note = wsf.cell(r, 9).value  # col I
    base = wsf.cell(r, 2).value  # col B
    note_str = "" if note is None else str(note)
    has_text = target_text.lower() in note_str.lower()
    has_digit = any(ch.isdigit() for ch in note_str)
    if has_text:
        matches.append((r, note_str, base, has_digit))
    if has_text and not has_digit and isinstance(base, (int, float)):
        expected_sum += base

print("\nRows matching text in A13:")
for item in matches:
    print(item)
print("Expected sum with NO digits in col I =", expected_sum)

# Build a LibreOffice-friendly formula for B13
digitless_expr = "$I$4:$I$10"
for d in "0123456789":
    digitless_expr = f'SUBSTITUTE({digitless_expr},"{d}","")'

new_formula = (
    f'=SUMPRODUCT($B$4:$B$10*--ISNUMBER(SEARCH(A13,$I$4:$I$10))*'
    f'--(LEN($I$4:$I$10)=LEN({digitless_expr})))'
)

print("\nWriting new formula to B13:")
