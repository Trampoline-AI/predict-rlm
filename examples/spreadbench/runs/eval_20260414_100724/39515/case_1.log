from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

# Compact inspection of relevant columns and expected outputs
month_headers = [ws.cell(1, c).value for c in range(3, 15)]  # C:N
print("Month headers C:N:", month_headers)

summary = []
for r in range(2, ws.max_row + 1):
    month_avail = ws.cell(r, 1).value
    year_avail = ws.cell(r, 2).value
    jan_val = ws.cell(r, 3).value
    current_formula = ws.cell(r, 15).value
    
    # current month lookup position
    normalized_headers = [str(h).strip().upper() if h is not None else "" for h in month_headers]
    m = str(month_avail).strip().upper() if month_avail is not None else ""
    idx = normalized_headers.index(m) + 3 if m in normalized_headers else None
    month_val = ws.cell(r, idx).value if idx else None
    
    expected = jan_val if year_avail == 2022 else month_val
    summary.append((r, month_avail, year_avail, jan_val, month_val, expected, current_formula))

print("Row | Month | Year | JAN | Value at Month | Expected O | Existing O formula")
for item in summary:
    print(item)

# If this inspection looks right, perform the update
for r in range(2, ws.max_row + 1):
    # Use a formula so workbook stays dynamic
    # 2022 rows => JAN value
    # otherwise => month in A
    ws.cell(r, 15).value = f'=IF($B{r}=2022,INDEX($C{r}:$N{r},MATCH("JAN",$C$1:$N$1,0)),INDEX($C{r}:$N{r},MATCH(UPPER($A{r}),$C$1:$N$1,0)))'

# Save
import os
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Reload after recalc and verify sheet name(s)
wb2 = load_workbook(out_path)
print("Post-recalc sheet names:", wb2.sheetnames)
if wb2.sheetnames != ["Sheet1"]:
    # restore original name if changed
    wb2[wb2.sheetnames[0]].title = "Sheet1"
    wb2.save(out_path)
    print("Renamed sheet back to Sheet1 and re-saved.")

# Verify cached values
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Sheet1"]
print("Verified O2:O13 cached values:")
for r in range(2, wsv.max_row + 1):
    print(r, "A", wsv.cell(r,1).value, "B", wsv.cell(r,2).value, "O", wsv.cell(r,15).value)

# Also verify formulas in regular load
wbf = load_workbook(out_path, data_only=False)
wsf = wbf["Sheet1"]
print("Verified formulas in O2:O13:")
for r in range(2, wsf.max_row + 1):
    print(r, wsf.cell(r,15).value)

final_output_path = out_path
