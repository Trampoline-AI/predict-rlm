```repl
from openpyxl import load_workbook
from copy import copy
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]  # first sheet must receive result

print("Working on sheet:", ws.title)
print("Original sheet names:", orig_sheet_names)
print("DATA!I1:", ws["I1"].value, "DATA!I2:", ws["I2"].value)

max_col = ws.max_column
max_row = ws.max_row

def row_vals(ws, r):
    return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]

def row_is_blank(ws, r):
    return all(ws.cell(r, c).value in (None, "") for c in range(1, ws.max_column + 1))

header_pattern = tuple(ws.cell(1, c).value for c in range(1, 6))
header_rows = []
for r in range(1, max_row + 1):
    if tuple(ws.cell(r, c).value for c in range(1, 6)) == header_pattern:
        header_rows.append(r)

print("Detected header rows:", header_rows)
segments = []
for i, hr in enumerate(header_rows):
    end = header_rows[i+1] - 1 if i + 1 < len(header_rows) else max_row
    # determine segment id(s) from nonblank rows in column B below header
    ids = []
    for r in range(hr + 1, end + 1):
        b = ws.cell(r, 2).value
        if b not in (None, "") and b not in ids:
            ids.append(b)
    segments.append({"header_row": hr, "end_row": end, "ids": ids})

print("Segments:")
for seg in segments:
    print(seg)

target_id = ws["I2"].value
if isinstance(target_id, str):
    target_id = target_id.strip()
if target_id == "":
    target_id = None

print("Target ID from I2:", target_id)

# Decide which segments should be cleaned
if target_id is None:
    clean_flags = [True] * len(segments)
else:
    clean_flags = [target_id in seg["ids"] for seg in segments]

print("Clean flags by segment:", clean_flags)

# Capture original rows (values + style) so we can rebuild precisely
row_snapshots = []
for r in range(1, max_row + 1):
    snap = []
    for c in range(1, max_col + 1):
        cell = ws.cell(r, c)
        snap.append({
            "value": cell.value,
            "style": copy(cell._style),
            "number_format": cell.number_format,
            "font": copy(cell.font),
            "fill": copy(cell.fill),
            "border": copy(cell.border),
            "alignment": copy(cell.alignment),
            "protection": copy(cell.protection),
        })
    row_snapshots.append(snap)

def snapshot_blank(snap):
    return all(cell["value"] in (None, "") for cell in snap)

# Build output rows for DATA
new_rows = []

for idx, seg in enumerate(segments):
    hr = seg["header_row"]
    end = seg["end_row"]
    seg_rows = row_snapshots[hr-1:end]  # inclusive
    header_snap = seg_rows[0]
    body_snaps = seg_rows[1:]
    
    should_clean = clean_flags[idx]
    
    if should_clean:
        # Remove blank rows within segment body
        kept_body = [snap for snap in body_snaps if not snapshot_blank(snap)]
        new_rows.append(header_snap)
        new_rows.extend(kept_body)
        # Keep one blank row between segments, but none after last segment
        if idx < len(segments) - 1:
            blank_template = None
            for snap in body_snaps:
                if snapshot_blank(snap):
                    blank_template = snap
                    break
            if blank_template is None:
                # synthesize a blank row with default styles if no blank row existed
                blank_template = []
                for c in range(1, max_col + 1):
                    cell = ws.cell(1, c)
                    blank_template.append({
                        "value": None,
                        "style": copy(cell._style),
                        "number_format": cell.number_format,
                        "font": copy(cell.font),
                        "fill": copy(cell.fill),
                        "border": copy(cell.border),
                        "alignment": copy(cell.alignment),
                        "protection": copy(cell.protection),
                    })
            new_rows.append(blank_template)
    else:
        # Leave segment exactly as-is
        new_rows.extend(seg_rows)

# Rewrite first sheet from new_rows and clear remaining old rows
for r_idx, snap_row in enumerate(new_rows, start=1):
    for c_idx, cell_data in enumerate(snap_row, start=1):
        cell = ws.cell(r_idx, c_idx)
        cell.value = cell_data["value"]
        cell._style = copy(cell_data["style"])
        cell.number_format = cell_data["number_format"]
        cell.font = copy(cell_data["font"])
        cell.fill = copy(cell_data["fill"])
        cell.border = copy(cell_data["border"])
        cell.alignment = copy(cell_data["alignment"])
        cell.protection = copy(cell_data["protection"])

# Clear leftover rows below rewritten data
for r in range(len(new_rows) + 1, max_row + 1):
    for c in range(1, max_col + 1):
        cell = ws.cell(r, c)
        cell.value = None

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheet_names)
    for i, sname in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = sname
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Final sheet names:", wb_check.sheetnames)

# Verification: reload data_only and print target sheet rows
wb_data = load_workbook(output_path, data_only=True)
wsv = wb_data[orig_sheet_names[0]]

print("\nVerified DATA sheet after modification:")
print("max_row:", wsv.max_row, "max_col:", wsv.max_column)
print("I1:", wsv["I1"].value, "I2:", wsv["I2"].value)

# print all meaningful rows in DATA plus a few trailing rows
for r in range(1, wsv.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    if any(v not in (None, "") for v in vals) or r <= len(new_rows) + 2:
        print(r, vals)

# store output path for submission
final_output_spreadsheet = output_path
