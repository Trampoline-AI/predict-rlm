from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

input_path = input_spreadsheet
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames
print("Workbook:", input_path)
print("Sheets:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        vals.append(ws.cell(r, c).value)
    return vals

def nonempty_cols(ws, max_scan_rows=5):
    cols = []
    for c in range(1, ws.max_column + 1):
        seen = False
        vals = []
        for r in range(1, min(ws.max_row, max_scan_rows) + 1):
            v = ws.cell(r, c).value
            vals.append(v)
            if v not in (None, ""):
                seen = True
        if seen:
            cols.append((get_column_letter(c), vals))
    return cols

for sname in wb.sheetnames:
    ws = wb[sname]
    print("\n=== SHEET:", sname, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    print("I2:", ws["I2"].value)
    print("Row 1:", row_values(ws, 1, min(ws.max_column, 12)))
    if ws.max_row >= 2:
        print("Row 2:", row_values(ws, 2, min(ws.max_column, 12)))
    if ws.max_row >= 3:
        print("Row 3:", row_values(ws, 3, min(ws.max_column, 12)))
    print("Non-empty columns from first 5 rows:")
    nec = nonempty_cols(ws, 5)
    print(nec[:20])

    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("First rows sample:")
    for r in first_rows:
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    print("Last rows sample:")
    for r in last_rows:
        print(r, row_values(ws, r, min(ws.max_column, 12)))

    # Print a compact scan of columns A:I with row numbers and whether row is fully blank
    print("Compact A:I scan for first 20 rows:")
    for r in range(1, min(ws.max_row, 20) + 1):
        vals = row_values(ws, r, min(ws.max_column, 9))
        blank = all(v in (None, "") for v in vals)
        print(r, vals, "FULL_BLANK" if blank else "")
