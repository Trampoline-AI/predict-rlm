import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Inspect current target/formula state
print("Before write:")
print("Sheet1!A2 =", repr(ws1["A2"].value))
print("Sheet1!C2 =", repr(ws1["C2"].value))

# Compute expected total in Python for verification
target_key = ws1["A2"].value
py_sum = 0
matching_rows = []
for r in range(2, min(363, ws2.max_row) + 1):
    a_val = ws2.cell(r, 1).value   # col A
    r_val = ws2.cell(r, 18).value  # col R
    if a_val == target_key:
        num = r_val if isinstance(r_val, (int, float)) and r_val is not None else 0
        py_sum += num
        if len(matching_rows) < 10:
            matching_rows.append((r, a_val, r_val))

print("Python-computed matching sum for A2:", py_sum)
print("Sample matching rows:", matching_rows)

# Write requested formula to exact target cell
formula = "=SUMIF(Sheet2!$A$2:$A$363,A2,Sheet2!$R$2:$R$363)"
ws1["C2"] = formula
print("Written formula to Sheet1!C2:", ws1["C2"].value)

# Save output
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc to verify values
wb_check = load_workbook(outfile, data_only=False)
print("Sheet names after recalc reload:", wb_check.sheetnames)

# Restore sheet names if recalc changed them
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed; restoring original names.")
    for old_name, desired_name in zip(wb_check.sheetnames, original_sheetnames):
        wb_check[old_name].title = desired_name
    wb_check.save(outfile)
    wb_check = load_workbook(outfile, data_only=False)
    print("Restored sheet names:", wb_check.sheetnames)

wb_values = load_workbook(outfile, data_only=True)
ws1_vals = wb_values["Sheet1"]

print("Verification:")
print("Formula in Sheet1!C2 =", load_workbook(outfile, data_only=False)["Sheet1"]["C2"].value)
print("Evaluated Sheet1!C2 =", ws1_vals["C2"].value)
print("Expected Python sum =", py_sum)
print("Sheet1!A2 =", repr(ws1_vals["A2"].value))
print("All sheet names present:", wb_values.sheetnames)

output_spreadsheet = outfile
