from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

sheet_info = {}

for sname in wb.sheetnames:
    ws = wb[sname]
    headers = row_values(ws, 1)
    sheet_info[sname] = {"rows": ws.max_row, "cols": ws.max_column, "headers": headers}
    print(f"\n--- Sheet: {sname} ---")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    print("Headers row 1:", headers)
    
    first_n = min(10, ws.max_row)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r))
    
    last_start = max(1, ws.max_row - 4)
    print("Last 5 rows:")
    for r in range(last_start, ws.max_row + 1):
        print(r, row_values(ws, r))

# Inspect referenced sheets/cells assuming first two sheets correspond to "sheet 1" and "sheet 2"
ws1 = wb[wb.sheetnames[0]]
ws2 = wb[wb.sheetnames[1]]

print("\n=== Target inspection ===")
print("Assumed sheet 1:", ws1.title)
print("Assumed sheet 2:", ws2.title)
print("sheet1!A2 =", ws1["A2"].value)
print("sheet1!C2 current value =", ws1["C2"].value)

# Print formulas/values near target area
for r in range(1, min(ws1.max_row, 8) + 1):
    print(f"sheet1 row {r}: A={ws1[f'A{r}'].value}, B={ws1[f'B{r}'].value if ws1.max_column>=2 else None}, C={ws1[f'C{r}'].value if ws1.max_column>=3 else None}")

# Inspect relevant columns/range in sheet2
print("\nSheet2 relevant columns A and R, rows 1-10:")
for r in range(1, min(10, ws2.max_row) + 1):
    a = ws2.cell(r, 1).value
    rcol = ws2.cell(r, 18).value  # R
    print(f"row {r}: A={a!r}, R={rcol!r}")

print("\nSheet2 rows 359-363 for A and R:")
for r in range(359, min(363, ws2.max_row) + 1):
