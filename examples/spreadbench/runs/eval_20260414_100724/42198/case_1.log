from openpyxl import load_workbook
import os

output_path = final_output_path

# Inspect final saved workbook again for formula presence
wb_check_formula = load_workbook(output_path, data_only=False)
wsf = wb_check_formula["Sheet1"]

stored = {f"C{r}": wsf[f"C{r}"].value for r in range(2, 8)}
print("Current stored C2:C7 values with data_only=False:", stored)

need_restore = not all(isinstance(v, str) and v.startswith("=") for v in stored.values())
print("Need to restore formulas?", need_restore)

if need_restore:
    for r in range(2, 8):
        wsf[f"C{r}"] = (
            f'=IF(COUNTIFS($A$2:A{r},"Potato",$B$2:B{r},FALSE)>0,"Worst",'
            f'IF(COUNTIFS($A$2:A{r},"Tomato",$B$2:B{r},FALSE)>0,"Ignore",'
            f'IF(COUNTIFS($A$2:A{r},"Pickle",$B$2:B{r},FALSE)>0,"Bad","Good")))'
        )
    wsf.parent.save(output_path)
    print("Formulas restored and workbook re-saved.")

# Final verification of stored formulas
wb_final_formula = load_workbook(output_path, data_only=False)
ws_final_formula = wb_final_formula["Sheet1"]
print("Final stored formulas in C2:C7:")
for r in range(2, 8):
    print(f"C{r}: {ws_final_formula[f'C{r}'].value}")

# Keep path for submission
