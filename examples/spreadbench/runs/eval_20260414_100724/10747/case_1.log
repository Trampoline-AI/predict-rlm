from openpyxl import load_workbook
import os, shutil

# Inspect evaluated values first
wb_formula = load_workbook(input_spreadsheet)
wb_values = load_workbook(input_spreadsheet, data_only=True)
wsf = wb_formula[wb_formula.sheetnames[0]]
wsv = wb_values[wb_values.sheetnames[0]]

print("Original sheet names:", wb_formula.sheetnames)
print("Current K6 formula:", wsf["K6"].value)
print("Evaluated source rows A:C and target criteria I3/J3:")
for r in range(3, 9):
    print(
        r,
        "A", wsv[f"A{r}"].value,
        "B", wsv[f"B{r}"].value,
        "C(formula/raw)", wsf[f"C{r}"].value,
        "C(value)", wsv[f"C{r}"].value,
    )
print("Criteria:", "I3=", wsv["I3"].value, "J3=", wsv["J3"].value)
print("Existing example outputs:",
      "K3 raw/value =", wsf["K3"].value, "/", wsv["K3"].value,
      "K4 raw/value =", wsf["K4"].value, "/", wsv["K4"].value)

# Compute expected result in Python for sanity check
year_crit = wsv["I3"].value
share_crit = wsv["J3"].value
expected = 0
matches = []
for r in range(3, 9):
    a = wsv[f"A{r}"].value
    b = wsv[f"B{r}"].value
    c = wsv[f"C{r}"].value
    if a == year_crit and b == share_crit:
        expected += c if c is not None else 0
        matches.append((r, a, b, c))
print("Matching rows for I3/J3:", matches)
print("Expected sum:", expected)

# Write fixed workbook
infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
shutil.copy(infile, outfile)

wb_out = load_workbook(outfile)
orig_sheetnames = wb_out.sheetnames[:]
ws = wb_out[orig_sheetnames[0]]

# Replace only the wrong target cell K6
ws["K6"] = "=SUMIFS($C$3:$C$8,$A$3:$A$8,$I$3,$B$3:$B$8,$J$3)"

print("Written K6 formula:", ws["K6"].value)
wb_out.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names preserved
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    # rename back if needed
    for i, orig_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv2 = wb_verify[orig_sheetnames[0]]
wb_verify_formula = load_workbook(outfile)
wsf2 = wb_verify_formula[orig_sheetnames[0]]

print("Verification target cells:")
for ref in ["I3", "J3", "K3", "K4", "K6"]:
    print(ref, "raw=", wsf2[ref].value, "value=", wsv2[ref].value)

print("K6 should equal expected:", expected, "; actual:", wsv2["K6"].value)

output_spreadsheet = outfile
