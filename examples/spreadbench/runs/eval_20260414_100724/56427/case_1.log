import os, re
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Reload clean workbook
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

max_row = ws.max_row
max_col = ws.max_column

# Detect requested fill color; fallback to likely intended Excel light green
color_matches = re.findall(r'#([0-9A-Fa-f]{6})', instruction)
fill_rgb = color_matches[0].upper() if color_matches else "E2EFDA"
print("Using fill color:", fill_rgb)

# Identify start rows where column B == 1
start_rows = [r for r in range(2, max_row + 1) if ws.cell(r, 2).value == 1]
print("Start rows:", start_rows)

# Write formulas to all output columns to the right of G so the full result is available
# Logic:
# - Only meaningful on rows where B=1 (we only write on those rows)
# - Stop after number of runners in C
# - Preserve blanks as blanks
# - Convert numeric-looking text to numeric values for formatting
for r in start_rows:
    for c in range(8, max_col + 1):  # H onward
        formula = (
            f'=IF(COLUMN()-7>$C{r},"",'
            f'IF(ROW()+COLUMN()-9>ROWS($G$2:$G${max_row}),"",'
            f'IF(INDEX($G$2:$G${max_row},ROW()+COLUMN()-9)="","",'
            f'VALUE(INDEX($G$2:$G${max_row},ROW()+COLUMN()-9))))'
        )
        ws.cell(r, c).value = formula
        ws.cell(r, c).number_format = '0.############'

# Shade H2:S28
fill = PatternFill(fill_type="solid", start_color="FF" + fill_rgb, end_color="FF" + fill_rgb)
for r in range(2, min(28, max_row) + 1):
    for c in range(8, min(19, max_col) + 1):  # H:S
        ws.cell(r, c).fill = fill
        ws.cell(r, c).number_format = '0.############'

# Center-align all cells to the right of column G
for r in range(1, max_row + 1):
    for c in range(8, max_col + 1):
        cell = ws.cell(r, c)
        new_alignment = copy(cell.alignment)
        new_alignment.horizontal = "center"
        cell.alignment = new_alignment

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalc/localization changed them
wb_post = load_workbook(out_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names:
    for i, old_name in enumerate(orig_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = old_name
    wb_post.save(out_path)
    print("Restored sheet names:", wb_post.sheetnames)

# Verification workbook (values)
wb_values = load_workbook(out_path, data_only=True)
print("Verified sheet names:", wb_values.sheetnames)
ws_values = wb_values[orig_sheet_names[0]]

# Verification workbook (formulas/styles)
wb_formulas = load_workbook(out_path, data_only=False)
ws_formulas = wb_formulas[orig_sheet_names[0]]

# Print target results
for r in start_rows:
    c_count = ws_values.cell(r, 3).value
    vals_h_u = [ws_values.cell(r, c).value for c in range(8, 22)]  # H:U
    print(f"Row {r} C={c_count} H:U values ->", vals_h_u)

# Print sample formulas to confirm formulaic solution
for r in start_rows:
    print(f"Row {r} H:M formulas ->", [ws_formulas.cell(r, c).value for c in range(8, 14)])

# Explicit check of row 15 full result through U
print("Row 15 H:U formula cells ->", [ws_formulas.cell(15, c).value for c in range(8, 22)])
print("Row 15 H:U cached values ->", [ws_values.cell(15, c).value for c in range(8, 22)])

# Check fill / formatting / alignment in requested range and beyond
for coord in ["H2", "S28", "H15", "U15", "BE1"]:
    cell = ws_formulas[coord]
    print(
        coord,
        {
            "value": cell.value,
            "fill": cell.fill.fgColor.rgb,
            "number_format": cell.number_format,
            "align": cell.alignment.horizontal,
        }
    )

output_spreadsheet = out_path
print("Prepared output file:", output_spreadsheet)
