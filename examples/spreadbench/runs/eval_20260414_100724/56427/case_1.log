from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Reload fresh workbook from input
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Determine requested fill color from instruction
color_matches = re.findall(r'#([0-9A-Fa-f]{6})', instruction)
if color_matches:
    fill_rgb = color_matches[0].upper()
else:
    # Fallback based on the visible preview; common Excel light green
    fill_rgb = "E2EFDA"
print("Using fill color:", fill_rgb)

max_row = ws.max_row
max_col = ws.max_column
g_col = 7
first_out_col = 8  # H
last_out_col = max_col  # use all existing output headers so the "full result" is populated

# Identify start rows where Runner (B) = 1
start_rows = [r for r in range(2, max_row + 1) if ws.cell(r, 2).value == 1]
print("Start rows (B=1):", start_rows)

# Write formulas on the start rows across all output columns
# Formula logic:
# - blank unless B=1
# - blank after the number of runners in C
# - blank if requested index would exceed source range
# - blank if source G cell is blank
# - otherwise return numeric value from source so whole numbers can display without decimals
for r in start_rows:
    for c in range(first_out_col, last_out_col + 1):
        cell = ws.cell(r, c)
        formula = (
            f'=IF(OR($B{r}<>1,COLUMN()-7>$C{r},ROW()+COLUMN()-9>ROWS($G$2:$G${max_row})),'
            f'"",'
            f'IF(INDEX($G$2:$G${max_row},ROW()+COLUMN()-9)="","",VALUE(INDEX($G$2:$G${max_row},ROW()+COLUMN()-9))))'
        )
        cell.value = formula
        # number format to remove decimals for whole numbers, keep decimals otherwise
        cell.number_format = '0.############'

# Apply fill to H2:S28
fill = PatternFill(fill_type="solid", start_color="FF" + fill_rgb, end_color="FF" + fill_rgb)
for r in range(2, min(28, max_row) + 1):
    for c in range(8, min(19, max_col) + 1):  # H:S
        ws.cell(r, c).fill = fill
        ws.cell(r, c).number_format = '0.############'

# Center align all cells to the right of column G
for r in range(1, max_row + 1):
    for c in range(8, max_col + 1):
        cell = ws.cell(r, c)
        a = copy(cell.alignment)
        cell.alignment = a.copy(horizontal="center")

# Save output
