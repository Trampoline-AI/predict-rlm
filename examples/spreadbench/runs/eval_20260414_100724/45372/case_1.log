def sheet_info(ws):
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Headers from row 1
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}1 -> {h!r}")
    
    # First 10 rows
    first_n = min(ws.max_row, 10)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {row_vals}")
    
    # Last 5 rows (dedup if overlap)
    start_last = max(1, ws.max_row - 4)
    if start_last > first_n:
        print(f"\nLast {ws.max_row - start_last + 1} rows:")
        for r in range(start_last, ws.max_row + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}: {row_vals}")
    
    # Inspect target area A:E for rows 1:15 or actual max_row
