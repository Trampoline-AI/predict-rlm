from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os
from copy import copy

input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))

# Load workbook for editing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Pre-write check: target cells E2:E15")
for r in range(2, 16):
    print(
        r,
        {
            "A": ws[f"A{r}"].value,
            "B": ws[f"B{r}"].value,
            "C": ws[f"C{r}"].value,
            "E_before": ws[f"E{r}"].value,
        }
    )

# Apply formulas to data area
# Rule inferred from examples: before 09:45 use B, at/after 09:45 use C.
# If chosen value is 0 or blank, leave blank.
for r in range(2, 15):  # rows 2:14, row 15 is total
    a = ws[f"A{r}"].value
    if a is None:
        # keep empty rows empty
        ws[f"E{r}"] = None
    else:
        ws[f"E{r}"] = (
            f'=IF(A{r}="","",'
            f'IF(A{r}<TIME(9,45,0),'
            f'IF(OR(B{r}="",B{r}=0),"",B{r}),'
            f'IF(OR(C{r}="",C{r}=0),"",C{r})))'
        )

# Total row
ws["E15"] = "=SUM(E2:E14)"

# Apply requested fill color #FFC000 to E2:E15, preserving all other formatting
target_fill = PatternFill(fill_type="solid", start_color="FFFFC000", end_color="FFFFC000")
for r in range(2, 16):
    ws[f"E{r}"].fill = copy(target_fill)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheet_names)
    for idx, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[idx].title = old_name
    wb_check.save(output_path)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]

print("\nFormulas/entered values in E2:E15 after save:")
for r in range(2, 16):
    cell = wsf[f"E{r}"]
    print(
        f"E{r}",
        {
            "formula_or_value": cell.value,
            "fill_type": cell.fill.fill_type,
            "fill_start": cell.fill.start_color.value,
            "fill_end": cell.fill.end_color.value,
        }
    )

# Verify evaluated results
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Sheet1"]

print("\nEvaluated values in E2:E15 after recalc:")
for r in range(2, 16):
    print(
        f"E{r}",
        {
            "A": wsv[f"A{r}"].value,
            "B": wsv[f"B{r}"].value,
            "C": wsv[f"C{r}"].value,
            "E_value": wsv[f"E{r}"].value,
        }
    )

output_spreadsheet = output_path
print("\nPrepared output file:", output_spreadsheet)
