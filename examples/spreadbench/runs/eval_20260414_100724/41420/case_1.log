Code:
```repl
import os
from openpyxl import load_workbook

# Re-open original workbook for writing formulas
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

def first_digit_formula(a_ref):
    expr = '""'
    for d in range(9, -1, -1):
        expr = f'IF(ISNUMBER(FIND("{d}",{a_ref}&"")),{d},{expr})'
    return "=" + expr

def next_digit_formula(a_ref, prev_ref):
    expr = '""'
    for d in range(9, 0, -1):
        has_d = f'ISNUMBER(FIND("{d}",{a_ref}&""))'
        expr = f'IF({prev_ref}<{d},IF({has_d},{d},{expr}),{expr})'
    return f'=IF({prev_ref}="","",{expr})'

# Write formulas to the exact target range C2:G8
for r in range(2, 9):
    a_ref = f"$A{r}"
    ws[f"C{r}"] = first_digit_formula(a_ref)
    ws[f"D{r}"] = next_digit_formula(a_ref, f"C{r}")
    ws[f"E{r}"] = next_digit_formula(a_ref, f"D{r}")
    ws[f"F{r}"] = next_digit_formula(a_ref, f"E{r}")
    ws[f"G{r}"] = next_digit_formula(a_ref, f"F{r}")

print("Written formulas C2:G8:")
for r in range(2, 9):
    print(r, [ws.cell(r, c).value for c in range(3, 8)])

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Re-open and restore sheet names if recalculation changed them
wb_post = load_workbook(out_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names and len(wb_post.sheetnames) == len(orig_sheet_names):
    for i, name in enumerate(orig_sheet_names):
        wb_post.worksheets[i].title = name
    wb_post.save(out_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify formulas persisted
wb_formula = load_workbook(out_path, data_only=False)
wsf = wb_formula[orig_sheet_names[0]]
print("\nVerified formulas in C2:G8:")
for r in range(2, 9):
    print(r, [wsf.cell(r, c).value for c in range(3, 8)])

# Verify evaluated values
wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values[orig_sheet_names[0]]
print("\nEvaluated values in A2:G8 after recalc:")
for r in range(2, 9):
