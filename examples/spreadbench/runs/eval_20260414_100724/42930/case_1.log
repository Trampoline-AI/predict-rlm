```repl
from openpyxl import load_workbook
import os
from collections import defaultdict

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Identify actual data rows from columns A:B
data_rows = []
for r in range(2, ws.max_row + 1):
    year = ws.cell(r, 1).value
    subd = ws.cell(r, 2).value
    if year not in (None, "") or subd not in (None, ""):
        data_rows.append(r)

# Build earliest year + first appearance mapping
earliest = {}
first_row = {}
for r in data_rows:
    year = ws.cell(r, 1).value
    subd = ws.cell(r, 2).value
    if subd in (None, ""):
        continue
    if subd not in first_row:
        first_row[subd] = r
    try:
        year_num = int(year)
    except Exception:
        continue
    earliest[subd] = min(year_num, earliest.get(subd, year_num))

# Sort subdivisions by earliest year, then first appearance
ordered_subdivisions = sorted(earliest.keys(), key=lambda s: (earliest[s], first_row[s]))
rank_map = {subd: i + 1 for i, subd in enumerate(ordered_subdivisions)}

print("Ordered subdivisions:", ordered_subdivisions)
print("Rank map:", rank_map)

# Print current target cells before writing
before_vals = [(r, ws.cell(r, 2).value, ws.cell(r, 3).value) for r in data_rows]
print("Before writing C values:", before_vals)

# Fill target column C for all data rows
for r in data_rows:
    subd = ws.cell(r, 2).value
    if subd in rank_map:
        ws.cell(r, 3).value = rank_map[subd]

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open normally and restore sheet names if LibreOffice changed them
wb_post = load_workbook(output_path)
current_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", current_names)
if current_names != orig_sheet_names and len(current_names) == len(orig_sheet_names):
    for idx, expected_name in enumerate(orig_sheet_names):
        wb_post.worksheets[idx].title = expected_name
    wb_post.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify output with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheet_names[0]]

verified = [(r, wsv.cell(r, 1).value, wsv.cell(r, 2).value, wsv.cell(r, 3).value) for r in data_rows]
print("Verified target cells A:C for data rows:")
for row in verified:
    print(row)

# Extra sanity check against intended example mapping in E:F
example_pairs = []
for r in range(2, wsv.max_row + 1):
    e = wsv.cell(r, 5).value
    f = wsv.cell(r, 6).value
    if e not in (None, "") and f not in (None, ""):
        example_pairs.append((e, f, rank_map.get(e)))
print("Example E:F compared to assigned map (subdivision, example_num, assigned_num):", example_pairs)

output_spreadsheet = output_path
```
