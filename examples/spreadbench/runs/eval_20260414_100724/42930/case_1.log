from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from collections import defaultdict
import os, json

input_path = input_spreadsheet
wb = load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Print every row since the sheet is small and we need full inspection
print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(r, vals)

# Determine true data rows for columns A:B
data_rows = []
for r in range(2, ws.max_row + 1):
    year = ws.cell(r, 1).value
    subd = ws.cell(r, 2).value
    if year not in (None, "") or subd not in (None, ""):
        data_rows.append(r)
print("Data rows based on A:B:", data_rows[0], "to", data_rows[-1], "count:", len(data_rows))

# Compute earliest year and first appearance per subdivision
earliest = {}
first_row = {}
rows_by_subd = defaultdict(list)
for r in data_rows:
    year = ws.cell(r, 1).value
    subd = ws.cell(r, 2).value
