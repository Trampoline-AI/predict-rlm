order_firstappearance_tiebreak = sorted(earliest.items(), key=lambda kv: (kv[1], first_row[kv[0]]))
print("Order by earliest year, alpha tie-break:", order_alpha_tiebreak)
print("Order by earliest year, first-appearance tie-break:", order_firstappearance_tiebreak)

# Inspect example mapping in E:F
