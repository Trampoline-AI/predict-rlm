from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Input path:", input_path)
print("Sheet names:", orig_sheet_names)

def display_val(v):
    if v is None:
        return None
    s = str(v)
    return s if len(s) <= 60 else s[:57] + "..."

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find first non-empty rows for header candidates
    nonempty_rows = []
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("First non-empty rows among top 10:", nonempty_rows)
    
    for r in nonempty_rows[:3]:
        vals = [display_val(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # Assume first non-empty row is likely header; print headers with letters
    if nonempty_rows:
        hdr_row = nonempty_rows[0]
        headers = [ws.cell(hdr_row, c).value for c in range(1, ws.max_column + 1)]
        print("Header row candidate:", hdr_row)
        print("Headers:", [(get_column_letter(c), display_val(headers[c-1])) for c in range(1, ws.max_column + 1)])
    
    # Print first 10 rows and last 5 rows with row numbers
    first_n = list(range(1, min(ws.max_row, 10) + 1))
    last_n = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    seen = []
    for r in first_n + [x for x in last_n if x not in first_n]:
        vals = [display_val(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        seen.append((r, vals))
    print("Sample rows:")
    for r, vals in seen:
        print(f"  Row {r}:", vals)
    
    # Look for blank header columns and any formulas in first 20 rows
    formula_cells = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append(f"{get_column_letter(c)}{r}={v}")
    print("Formulas in first 20 rows:", formula_cells[:20], "count:", len(formula_cells))
