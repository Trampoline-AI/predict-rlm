import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load and inspect the exact target area
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Sheet names before:", wb.sheetnames)
print("Relevant range A4:K7 before:")
for r in range(4, 8):
    print(r, [ws.cell(r, c).value for c in range(1, 12)])

# Determine target columns from the sample row 4: output starts at D and spans through the sample length
sample_source = ws["A4"].value
sample_outputs = []
for c in range(4, ws.max_column + 1):
    sample_outputs.append(ws.cell(4, c).value)
print("Sample source A4:", sample_source)
print("Sample outputs D4:K4:", sample_outputs)

# Exact target range inferred from sample: columns D:K
start_col = 4  # D
end_col = ws.max_column  # K in this file

# Fill formulas for rows that have source text in column A and blank/unset target cells.
# Preserve existing sample answers in row 4.
for r in range(5, ws.max_row + 1):
    source_val = ws.cell(r, 1).value
    if source_val is None or source_val == "":
        continue
    for c in range(start_col, end_col + 1):
        cell = ws.cell(r, c)
        # Only fill blanks; don't overwrite any existing plausible content
        if cell.value in (None, ""):
            col_letter = get_column_letter(c)
            # In D-row: first char, E-row: second char, etc.
            # Use COLUMNS($D5:D5) pattern so it increments across columns.
            cell.value = f'=IF(COLUMNS($D{r}:{col_letter}{r})<=LEN($A{r}),MID($A{r},COLUMNS($D{r}:{col_letter}{r}),1),"")'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and fix sheet names if changed
wb2 = load_workbook(outfile)
print("Sheet names after recalc/reload:", wb2.sheetnames)
if wb2.sheetnames != original_sheetnames:
    # rename sheets back by position
    for idx, expected_name in enumerate(original_sheetnames):
        wb2.worksheets[idx].title = expected_name
    wb2.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify formulas and computed values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Formulas in target cells row 5-7:")
for r in range(5, 8):
    print(r, [ws_formula.cell(r, c).value for c in range(4, 12)])

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("Computed values A4:K7 after recalc:")
for r in range(4, 8):
    print(r, [ws_values.cell(r, c).value for c in range(1, 12)])

# Basic verification summary
verification = {}
for r in range(5, 8):
    src = ws_values.cell(r, 1).value or ""
    out = [ws_values.cell(r, c).value for c in range(4, 12)]
    verification[r] = {"src": src, "out": out, "expected_prefix": list(src)}
print("Verification summary:", verification)

result_path = outfile
