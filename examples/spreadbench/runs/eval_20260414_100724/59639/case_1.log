import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # gather non-empty row/col extents
    nonempty_rows = set()
    nonempty_cols = set()
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                nonempty_rows.add(cell.row)
                nonempty_cols.add(cell.column)
    print("nonempty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("nonempty col range:", (min(nonempty_cols), max(nonempty_cols)) if nonempty_cols else None)
    headers = []
    if ws.max_row >= 1:
        for c in range(1, ws.max_column + 1):
            headers.append(ws.cell(1, c).value)
    print("Row1 headers/values:", headers)
    
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    
    # first 10 rows
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    print("First rows:")
    for r in first_rows:
        print(r, row_vals(r))
    # last 5 rows (dedup)
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    print("Last rows:")
    for r in last_rows:
        print(r, row_vals(r))
    
    # print formulas and non-empty cells in compact form
    formulas = []
    nonempty = []
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                nonempty.append((cell.coordinate, cell.value))
                if isinstance(cell.value, str) and cell.value.startswith("="):
                    formulas.append((cell.coordinate, cell.value))
    print("Total non-empty cells:", len(nonempty))
    print("Formula cells:", formulas[:50])
    print("First 50 non-empty cells:", nonempty[:50])

for ws in wb.worksheets:
    sheet_summary(ws)
