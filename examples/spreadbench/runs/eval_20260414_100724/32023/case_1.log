Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Target column/header:", ws["B1"].value)
print("Reference date cell C3 formula:", ws["C3"].value)

# Confirm current target cells before writing
print("\nPre-write B4:B19 values:")
for r in range(4, ws.max_row + 1):
    print(r, ws[f"A{r}"].value, "->", ws[f"B{r}"].value)

# Write formulas to employee rows only
written = []
for r in range(4, ws.max_row + 1):
    name = ws[f"A{r}"].value
    if name not in (None, ""):
        formula = (
            f'=IF($A{r}="","",'
            f'IF($C$3="","",'
            f'IF(AND($K{r}<>"",$C$3>=$K{r}),$L{r},'
            f'IF(AND($I{r}<>"",$C$3>=$I{r}),$J{r},'
            f'IF(AND($G{r}<>"",$C$3>=$G{r}),$H{r},'
            f'IF(AND($E{r}<>"",$C$3>=$E{r}),$F{r},'
            f'IF(AND($D{r}<>"",$C$3>=$D{r}),$D$1,""))))))'
        )
        ws[f"B{r}"] = formula
        written.append((r, formula))

print("\nWritten formulas (sample):")
for r, f in written[:5] + written[-3:]:
    print(f"B{r} = {f}")

# Save output with same filename
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
out_path = out_dir / Path(input_spreadsheet).name
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(str(out_path))
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for i, expected in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = expected
    wb_after.save(out_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verify formulas and evaluated values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]

wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerification:")
print("C3 formula:", ws_formula["C3"].value)
print("C3 evaluated:", ws_values["C3"].value)

print("\nTarget cells B4:B19 formula/value:")
for r in range(4, ws_formula.max_row + 1):
    if ws_formula[f"A{r}"].value not in (None, ""):
        print(
            f"Row {r}:",
            ws_formula[f"A{r}"].value,
            "| formula =", ws_formula[f"B{r}"].value,
            "| value =", ws_values[f"B{r}"].value
        )

# Extra spot checks from instruction examples
print("\nExample rows spot-check:")
for r in [14, 17, 19]:
    print(
        f"Row {r} / {ws_formula[f'A{r}'].value}:",
        "dates:",
        ws_formula[f"I{r}"].value,
        ws_formula[f"K{r}"].value,
        "| formula:", ws_formula[f"B{r}"].value,
        "| evaluated:", ws_values[f"B{r}"].value
    )

# Keep path for submit
output_file = str(out_path)
print("\nOutput file ready:", output_file)
