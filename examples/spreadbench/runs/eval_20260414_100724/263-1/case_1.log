import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input spreadsheet:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
print("Original sheet names:", orig_sheet_names)

def sheet_preview(ws, max_cols=20, sample_first=10, sample_last=5):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # detect non-empty bounds more carefully
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                if isinstance(v, str) and v == "":
                    continue
                row_has = True
                nonempty_cols.add(c)
        if row_has:
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    print("Non-empty rows first/last:", nonempty_rows[:10], nonempty_rows[-10:] if nonempty_rows else [])
    print("Non-empty cols:", [(c, get_column_letter(c)) for c in sorted(nonempty_cols)[:max_cols]])
    
    # header candidates first 5 rows
    print("Top 8 rows preview:")
    for r in range(1, min(ws.max_row, 8) + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols) + 1)]
        print(f"Row {r}: {vals}")
    
    # determine likely header row among first 5 nonempty rows
    header_candidates = []
    for r in range(1, min(ws.max_row, 5) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        strings = sum(isinstance(v, str) for v in vals if v not in (None, ""))
        header_candidates.append((r, nonempty, strings, vals[:max_cols]))
    print("Header candidates:", header_candidates)
    
    # print first sample rows and last sample rows among non-empty rows
    show_rows = []
    show_rows.extend(nonempty_rows[:sample_first])
    for r in nonempty_rows[-sample_last:]:
        if r not in show_rows:
            show_rows.append(r)
    print("Sample non-empty rows:")
    for r in show_rows:
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, max_cols) + 1)]
        print(f"Row {r}: {vals}")
    
    # print formulas if any in first 30x20 area
    formulas = []
    for r in range(1, min(ws.max_row, 30) + 1):
        for c in range(1, min(ws.max_column, max_cols) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first area:", formulas[:50])

for ws in wb.worksheets:
    sheet_preview(ws)
```
