import os
from openpyxl import load_workbook

# Reload clean workbook
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

input_filename = os.path.basename(input_spreadsheet)
output_path = os.path.join("/sandbox/output/output_spreadsheet", input_filename)

# Determine true last data row from columns A:C
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 4)):
        last_data_row = r
        break

print("Detected last source data row:", last_data_row)

# Identify target output rows based on non-empty material names in column G below header
target_rows = []
for r in range(2, ws.max_row + 1):
    gval = ws.cell(r, 7).value
    if gval not in (None, ""):
        target_rows.append(r)
    elif target_rows:
        # stop at first blank after contiguous block of output materials
        break

print("Target output rows:", target_rows)
print("Before writing G:I target area:")
for r in target_rows:
    print(r, [ws.cell(r, c).value for c in range(7, 10)])

# Write formulas to make totals dynamic for all listed materials
for r in target_rows:
    formula = f'=SUMPRODUCT(($A$2:$A${last_data_row}=G{r})*$B$2:$B${last_data_row}*$C$2:$C${last_data_row})'
    ws.cell(r, 8).value = formula
    # preserve/add unit if missing
    if ws.cell(r, 9).value in (None, ""):
        ws.cell(r, 9).value = "sqf"

print("\nWritten formulas:")
for r in target_rows:
    print(f"H{r} =", ws.cell(r, 8).value)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalc changed them
wb_post = load_workbook(output_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != orig_sheet_names and len(post_names) == len(orig_sheet_names):
    for idx, expected_name in enumerate(orig_sheet_names):
        wb_post.worksheets[idx].title = expected_name
    wb_post.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verification with formulas visible
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula[orig_sheet_names[0]]
print("\nVerification (formulas):")
for r in target_rows:
    print(f"Row {r} G:I ->", [wsf.cell(r, c).value for c in range(7, 10)])

# Verification with calculated values
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values[orig_sheet_names[0]]
print("\nVerification (calculated values):")
for r in target_rows:
    print(f"Row {r} G:I ->", [wsv.cell(r, c).value for c in range(7, 10)])

# Additional sanity checks
issues = []
for r in target_rows:
    material = wsv.cell(r, 7).value
    total = wsv.cell(r, 8).value
    unit = wsv.cell(r, 9).value
    if material in (None, ""):
        issues.append(f"G{r} blank unexpectedly")
    if total in (None, ""):
        issues.append(f"H{r} blank after recalc")
    if isinstance(unit, str) and unit != unit.strip():
        issues.append(f"I{r} has whitespace issue")
    if unit not in ("sqf",):
        issues.append(f"I{r} unexpected unit {unit!r}")

print("\nIssues:", issues if issues else "None")
