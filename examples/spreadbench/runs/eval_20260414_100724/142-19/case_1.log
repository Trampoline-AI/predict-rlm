```repl
import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"] if "Sheet1" in wb.sheetnames else wb[wb.sheetnames[0]]

# Detect contiguous non-blank blocks in A:B
blocks = []
in_block = False
start = None
for r in range(1, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    nonblank = any(v not in (None, "") for v in (a, b))
    if nonblank and not in_block:
        start = r
        in_block = True
    elif not nonblank and in_block:
        blocks.append((start, r - 1))
        in_block = False
if in_block:
    blocks.append((start, ws.max_row))

print("Blocks to sort:", blocks)

# Natural sort key for identifiers like 'A 37', 'D 14'
def sort_key(val):
    s = "" if val is None else str(val).strip()
    m = re.match(r"^(.*?)(\d+)$", s)
    if m:
        prefix = m.group(1).strip()
        num = int(m.group(2))
        return (prefix, num, s)
    return (s, float("inf"), s)

# Show pre-sort sample
for i, (s, e) in enumerate(blocks, start=1):
    data = [(ws.cell(r, 1).value, ws.cell(r, 2).value) for r in range(s + 1, e + 1)]
    print(f"\nPre-sort block {i} rows {s+1}:{e}")
    print("First 5:", data[:5])
    print("Last 5:", data[-5:])

# Sort each block independently, excluding its header row
for s, e in blocks:
    header_a = ws.cell(s, 1).value
    header_b = ws.cell(s, 2).value
    data_rows = []
    for r in range(s + 1, e + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        data_rows.append(row_vals)

    sorted_rows = sorted(data_rows, key=lambda row: sort_key(row[0]))

    # Write sorted rows back in place
    for idx, row_vals in enumerate(sorted_rows, start=s + 1):
        for c, v in enumerate(row_vals, start=1):
            ws.cell(idx, c).value = v

    # Reassert header untouched
    ws.cell(s, 1).value = header_a
    ws.cell(s, 2).value = header_b

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for ws_obj, orig_name in zip(wb_check.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheetnames)
else:
    print("Sheet names after recalc:", wb_check.sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify["Sheet1"] if "Sheet1" in wb_verify.sheetnames else wb_verify[wb_verify.sheetnames[0]]

print("\nVerification of sorted target ranges:")
for i, (s, e) in enumerate(blocks, start=1):
    data = [(r, wsv.cell(r, 1).value, wsv.cell(r, 2).value) for r in range(s + 1, e + 1)]
    print(f"\nBlock {i} rows {s}:{e}")
    print("Header:", (s, wsv.cell(s, 1).value, wsv.cell(s, 2).value))
    print("First 6 data rows:", data[:6])
    print("Last 6 data rows:", data[-6:])

# Also print every row for each target block since the ranges are modest
for i, (s, e) in enumerate(blocks, start=1):
    print(f"\nFull sorted block {i}:")
    for r in range(s, e + 1):
        print(r, [wsv.cell(r, c).value for c in range(1, 3)])

final_output_spreadsheet = output_path
```
