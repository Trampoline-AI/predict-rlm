import os
from datetime import datetime
from openpyxl import load_workbook
from openpyxl.styles import numbers

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Data"]

print("Original sheet names:", original_sheetnames)
print("Target sheet:", ws.title)
print("Target output column: U (index 21)")
print("Existing header U8:", ws["U8"].value)

# Build exact Excel-2010-compatible formula for each data row
date_choices = ",".join([
    "DATE(2015,6,1)",
    "DATE(2015,7,1)",
    "DATE(2015,8,1)",
    "DATE(2015,9,1)",
    "DATE(2015,10,1)",
    "DATE(2015,11,1)",
    "DATE(2015,12,1)",
    "DATE(2016,1,1)",
    "DATE(2016,2,1)",
    "DATE(2016,3,1)",
    "DATE(2016,4,1)",
    "DATE(2016,5,1)",
])

written = []
for r in range(9, ws.max_row + 1):
    # Only write to actual data rows
    if all(ws.cell(r, c).value in (None, "") for c in range(7, 21)):
        continue
    formula = (
        f'=IF(COUNTIF(I{r}:T{r},">0")=0,"",'
        f'CHOOSE(LOOKUP(2,1/(I{r}:T{r}>0),COLUMN(I{r}:T{r}))-COLUMN(I{r})+1,{date_choices}))'
    )
    ws[f"U{r}"] = formula
    ws[f"U{r}"].number_format = "m/d/yy"
    written.append((r, formula))

print("\nFormulas written to U:")
for r, formula in written:
    print(f"U{r} = {formula}")

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc; restore sheet names if needed
wb_after = load_workbook(outfile)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # rename by position back to original
    for idx, orig_name in enumerate(original_sheetnames):
        if idx < len(wb_after.worksheets):
            wb_after.worksheets[idx].title = orig_name
    wb_after.save(outfile)
    print("Restored sheet names to:", wb_after.sheetnames)
else:
    print("Sheet names preserved after recalc.")

# Verification workbook with formulas visible
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Data"]

# Verification workbook with cached values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Data"]

print("\nVerifying target cells U9:U18")
for r in range(9, ws_values.max_row + 1):
    if all(ws_values.cell(r, c).value in (None, "") for c in range(7, 21)):
        continue
    print(
        f"Row {r}: formula={ws_formula[f'U{r}'].value!r}, "
        f"value={ws_values[f'U{r}'].value!r}, "
        f"numfmt={ws_formula[f'U{r}'].number_format!r}"
    )

# Python sanity-check expected results
month_map = {
    9: (2015, 6), 10: (2015, 7), 11: (2015, 8), 12: (2015, 9),
    13: (2015, 10), 14: (2015, 11), 15: (2015, 12), 16: (2016, 1),
    17: (2016, 2), 18: (2016, 3), 19: (2016, 4), 20: (2016, 5),
}
expected = {}
for r in range(9, ws.max_row + 1):
    if all(ws.cell(r, c).value in (None, "") for c in range(7, 21)):
        continue
    last_col = None
    for c in range(9, 21):
        v = ws.cell(r, c).value
        if isinstance(v, (int, float)) and v > 0:
            last_col = c
    if last_col is None:
        expected[r] = None
    else:
        y, m = month_map[last_col]
        expected[r] = datetime(y, m, 1)

print("\nPython-expected last-sale dates:")
for r in sorted(expected):
    print(f"Row {r}: expected={expected[r]!r}, actual={ws_values[f'U{r}'].value!r}")

# Basic pass/fail summary
issues = []
for r, exp in expected.items():
    actual = ws_values[f"U{r}"].value
    if exp is None:
        if actual not in (None, ""):
            issues.append((r, exp, actual))
    else:
        if actual is None:
            issues.append((r, exp, actual))
        elif hasattr(actual, "year"):
            if (actual.year, actual.month, actual.day) != (exp.year, exp.month, exp.day):
                issues.append((r, exp, actual))

print("\nVerification issues:", issues if issues else "None")
print("Output file ready:", outfile)
