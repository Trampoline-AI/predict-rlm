Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, filename)

# Reload original workbook for modification
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Target header check:")
print("D1 =", ws["D1"].value)
print("F1 =", ws["F1"].value)

# Print current target cells before writing
print("\nBefore writing:")
for r in range(2, ws.max_row + 1):
    print(f"Row {r}: D{r}={ws[f'D{r}'].value!r}, F{r}={ws[f'F{r}'].value!r}")

# Write formula to all relevant rows (where D has data)
for r in range(2, ws.max_row + 1):
    d_val = ws[f"D{r}"].value
    f_cell = ws[f"F{r}"]
    if d_val not in (None, ""):
        # Extract BA/MA based on text contained in FY20 Lane
        f_cell.value = f'=IF(ISNUMBER(SEARCH("BA",D{r})),"BA",IF(ISNUMBER(SEARCH("MA",D{r})),"MA",""))'

print("\nFormulas written:")
for r in range(2, ws.max_row + 1):
    print(f"F{r} formula = {ws[f'F{r}'].value!r}")

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for idx, desired in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = desired
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheetnames)

# Verify formulas and cached results
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)

ws_formula = wb_formula[original_sheetnames[0]]
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target cells F2:F{}".format(ws_formula.max_row))
verification = []
for r in range(2, ws_formula.max_row + 1):
    formula = ws_formula[f"F{r}"].value
    value = ws_values[f"F{r}"].value
    d_val = ws_values[f"D{r}"].value
    verification.append((r, d_val, formula, value))
    print(f"Row {r}: D{r}={d_val!r}, F{r} formula={formula!r}, cached value={value!r}")

# Basic sanity checks
all_ok = True
for r, d_val, formula, value in verification:
    expected = None
    if d_val is not None:
        text = str(d_val)
        if "BA" in text:
            expected = "BA"
        elif "MA" in text:
            expected = "MA"
        else:
            expected = ""
    if value != expected:
        all_ok = False
        print(f"Mismatch at row {r}: expected {expected!r}, got {value!r}")

print("\nAll verification checks passed:", all_ok)
final_output_path = output_path
```
