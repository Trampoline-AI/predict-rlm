```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for modification
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["imported Data"]

print("Target sheet:", ws.title)
print("Before deletion, max_row:", ws.max_row)

def should_delete(val):
    # blank / empty string
    if val is None:
        return True
    if isinstance(val, str):
        s = val.strip()
        if s == "":
            return True
        try:
            num = float(s.replace(",", ""))
        except Exception:
            return False
        return -1 <= num <= 1
    if isinstance(val, (int, float)):
        return -1 <= float(val) <= 1
    return False

rows_to_delete = []
for r in range(2, ws.max_row + 1):  # preserve header row
    val = ws.cell(r, 3).value  # Column C
    if should_delete(val):
        rows_to_delete.append((r, val))

print("Rows marked for deletion (row, colC):", rows_to_delete)

# Delete from bottom to top
for r, _ in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

print("After deletion, max_row:", ws.max_row)
print("Remaining rows:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate altered them
wb2 = load_workbook(output_path)
current_sheet_names = wb2.sheetnames[:]
print("Sheet names after recalc:", current_sheet_names)

if current_sheet_names != original_sheet_names and len(current_sheet_names) == len(original_sheet_names):
    for i, orig_name in enumerate(original_sheet_names):
        wb2.worksheets[i].title = orig_name
    wb2.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify[original_sheet_names[0]]

print("Final verified rows in target sheet:")
for r in range(1, vws.max_row + 1):
    print(r, [vws.cell(r, c).value for c in range(1, vws.max_column + 1)])

# Keep output path for submission
final_output_path = output_path
```
