import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(input_path), input_path)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
print("Original sheet names:", original_sheetnames)

def get_used_bounds(ws):
    min_row = None
    max_row = 0
    min_col = None
    max_col = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value not in (None, ""):
                if min_row is None or cell.row < min_row:
                    min_row = cell.row
                if min_col is None or cell.column < min_col:
                    min_col = cell.column
                if cell.row > max_row:
                    max_row = cell.row
                if cell.column > max_col:
                    max_col = cell.column
    return min_row, max_row, min_col, max_col

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"openpyxl max_row={ws.max_row}, max_column={ws.max_column}")
    min_row, max_row, min_col, max_col = get_used_bounds(ws)
    print(f"Used bounds: rows {min_row}-{max_row}, cols {min_col}-{max_col}")
    if min_row is None:
        print("Sheet is empty")
        continue
    
    # Candidate headers from first few rows
    for hr in range(min_row, min(min_row+3, max_row)+1):
        vals = [ws.cell(hr, c).value for c in range(min_col, max_col+1)]
        print(f"Candidate header row {hr}: {vals}")
    
    # First 10 used rows
    first_rows = list(range(min_row, min(max_row, min_row+9)+1))
    # Last 5 used rows
    last_rows = list(range(max(min_row, max_row-4), max_row+1))
    rows_to_show = []
    seen = set()
    for r in first_rows + last_rows:
        if r not in seen:
            rows_to_show.append(r)
            seen.add(r)
    print("Sample rows:")
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(min_col, max_col+1)]
        print(f"Row {r}: {vals}")
    
    # Print all non-empty cells if sheet is small
    nonempty = []
    formulas = []
    for r in range(min_row, max_row+1):
        for c in range(min_col, max_col+1):
            cell = ws.cell(r, c)
            if cell.value not in (None, ""):
                nonempty.append((cell.coordinate, cell.value))
                if isinstance(cell.value, str) and cell.value.startswith("="):
                    formulas.append((cell.coordinate, cell.value))
    print(f"Non-empty cell count in used range: {len(nonempty)}")
    if len(nonempty) <= 80:
        print("All non-empty cells:")
        for coord, val in nonempty:
            print(f"  {coord} = {val!r}")
    else:
        print("First 40 non-empty cells:")
        for coord, val in nonempty[:40]:
            print(f"  {coord} = {val!r}")
    
    print(f"Formula cell count: {len(formulas)}")
    for coord, formula in formulas[:20]:
        print(f"  Formula {coord}: {formula}")
