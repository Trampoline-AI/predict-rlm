import os
from collections import Counter
from openpyxl import load_workbook

output_path = final_output_path  # from prior step
print("Fixing formulas in:", output_path)

# Python sanity-check counts from source text
wb_in = load_workbook(output_path, data_only=False)
orig_sheetnames = wb_in.sheetnames[:]
ws = wb_in[orig_sheetnames[0]]
text = ws["D5"].value or ""
counts = Counter(ch.lower() for ch in str(text) if ch.isalpha())
print("Source text:", text)
print("Python counts sample:", {k: counts.get(k, 0) for k in list("abcdefghij")})

# Rewrite formulas correctly
for r in range(7, 33):
    ws[f"E{r}"] = f'=LEN(LOWER($D$5))-LEN(SUBSTITUTE(LOWER($D$5),LOWER(D{r}),""))'

# Save and recalc
wb_in.save(output_path)
print("Saved corrected formulas.")

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if needed
wb_chk = load_workbook(output_path)
print("Sheet names after recalc:", wb_chk.sheetnames)
if wb_chk.sheetnames != orig_sheetnames:
    for i, nm in enumerate(orig_sheetnames):
        wb_chk.worksheets[i].title = nm
    wb_chk.save(output_path)
    print("Restored sheet names:", wb_chk.sheetnames)

# Verify formulas + cached values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

all_ok = True
verification_rows = []
for r in range(7, 33):
    letter = str(ws_values[f"D{r}"].value).strip().lower()
    formula = ws_formula[f"E{r}"].value
    value = ws_values[f"E{r}"].value
    expected = counts.get(letter, 0)
    verification_rows.append((r, letter, formula, value, expected))
    if value is None or value != expected:
        all_ok = False

for row in verification_rows:
    r, letter, formula, value, expected = row
    print(f"Row {r}: {letter} | formula={formula!r} | value={value!r} | expected={expected}")

print("Verification all_ok =", all_ok)

final_output_path = output_path
```
