import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load source workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

# Find matching rows and inspect before writing
matching_rows = []
for r in range(2, ws.max_row + 1):
    if ws[f"A{r}"].value == "Government" and ws[f"B{r}"].value == "Germany" and ws[f"C{r}"].value == "Carretera":
        matching_rows.append(r)

print("Matching rows:", matching_rows)
print("Before write:", {f"Q{r}": ws[f"Q{r}"].value for r in matching_rows})

# Write Volkswagen into Q for all matching rows
changed = []
for r in matching_rows:
    old = ws[f"Q{r}"].value
    if old != "Volkswagen":
        ws[f"Q{r}"] = "Volkswagen"
        changed.append((r, old, "Volkswagen"))

print("Rows changed:", changed)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheet_names:
    for i, original_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Final verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Final sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

verified = {f"Q{r}": wsv[f"Q{r}"].value for r in matching_rows}
print("Verified target cells:", verified)

# Extra sanity checks
all_ok = all(str(wsv[f"Q{r}"].value).strip() == "Volkswagen" for r in matching_rows)
print("All matching rows populated correctly:", all_ok)

# Also show a few neighboring values for context
for r in matching_rows:
    print(r, {
        "A": wsv[f"A{r}"].value,
        "B": wsv[f"B{r}"].value,
        "C": wsv[f"C{r}"].value,
        "Q": wsv[f"Q{r}"].value,
    })

final_output_path = output_path
