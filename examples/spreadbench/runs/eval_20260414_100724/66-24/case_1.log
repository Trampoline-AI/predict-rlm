```repl
import os
from copy import copy
from datetime import datetime, timedelta
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load fresh workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
src = wb["Imported Data"]
dst = wb["Items Older than 30 days"]

# Determine valid source dates and matching rows
valid_rows = []
for r in range(2, src.max_row + 1):
    v = src.cell(r, 5).value
    if isinstance(v, datetime):
        valid_rows.append((r, v))

max_date = max(v for _, v in valid_rows)
cutoff = max_date - timedelta(days=30)
matching_rows = [r for r, d in valid_rows if d < cutoff]

print("Original sheet names:", original_sheet_names)
print("Source max_row/max_column:", src.max_row, src.max_column)
print("Destination before write max_row/max_column:", dst.max_row, dst.max_column)
print("Max date:", max_date)
print("Cutoff:", cutoff)
print("Matching source rows:", matching_rows)

# We'll copy exactly the source used columns (A:T = 20 columns here)
copy_cols = src.max_column
output_rows = [1] + matching_rows  # include header row

# Clear destination area A:copy_cols for existing rows up to current max_row,
# so stale values won't remain if workbook is reused
for r in range(1, dst.max_row + 1):
    for c in range(1, copy_cols + 1):
        cell = dst.cell(r, c)
        cell.value = None
        cell._style = copy(src.cell(1, c)._style) if r == 1 else copy(cell._style)
        if r == 1:
            cell.number_format = src.cell(1, c).number_format

# Copy header + matching rows with styles
dest_r = 1
for src_r in output_rows:
    # preserve row height
    if src.row_dimensions[src_r].height is not None:
        dst.row_dimensions[dest_r].height = src.row_dimensions[src_r].height
    for c in range(1, copy_cols + 1):
        s = src.cell(src_r, c)
        d = dst.cell(dest_r, c)
        d.value = s.value
        d.font = copy(s.font)
        d.fill = copy(s.fill)
        d.border = copy(s.border)
        d.alignment = copy(s.alignment)
        d.number_format = s.number_format
        d.protection = copy(s.protection)
        d._style = copy(s._style)
    dest_r += 1

# Copy source column widths for copied columns
for c in range(1, copy_cols + 1):
    col_letter = get_column_letter(c)
    if src.column_dimensions[col_letter].width is not None:
        dst.column_dimensions[col_letter].width = src.column_dimensions[col_letter].width

print("Preview destination rows before deleting column Z:")
for r in range(1, len(output_rows) + 1):
    print(r, [dst.cell(r, c).value for c in range(1, copy_cols + 1)])
    print(f"  E{r} number_format:", dst.cell(r, 5).number_format)

# Confirm current sheet 2 and delete column Z there
sheet2 = wb[wb.sheetnames[1]]
print("Sheet 2 before deleting Z:", sheet2.title, "max_column:", sheet2.max_column)
print("Z1 before delete:", sheet2["Z1"].value)
print("Z2 before delete:", sheet2["Z2"].value)

sheet2.delete_cols(26, 1)

print("Sheet 2 after deleting Z max_column:", sheet2.max_column)
if sheet2.max_column >= 26:
    print("New Z1 after delete:", sheet2["Z1"].value)
else:
    print("Column Z removed; max_column is now", sheet2.max_column)

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(output_path)
current_sheet_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_sheet_names)

if current_sheet_names != original_sheet_names and len(current_sheet_names) == len(original_sheet_names):
    for idx, original_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = original_name
    wb_check.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verification reloads
wb_verify = load_workbook(output_path)
wb_verify_data = load_workbook(output_path, data_only=True)

print("Final sheet names:", wb_verify.sheetnames)

dst_verify = wb_verify["Items Older than 30 days"]
dst_verify_data = wb_verify_data["Items Older than 30 days"]

# Verify target rows
rows_to_check = len(output_rows)
print("Verified destination rows A:T:")
for r in range(1, rows_to_check + 1):
    vals = [dst_verify_data.cell(r, c).value for c in range(1, copy_cols + 1)]
    print(r, vals)

print("Destination date cells/style verification:")
for r in range(1, rows_to_check + 1):
    cell_formula_view = dst_verify.cell(r, 5)
    cell_data_view = dst_verify_data.cell(r, 5)
    print(
        f"E{r}: value={cell_data_view.value!r}, "
        f"number_format={cell_formula_view.number_format!r}, "
        f"style_id={cell_formula_view.style_id}"
    )

print("Sheet 2 final max_column:", dst_verify.max_column)
print("Expected 25 after deleting original Z.")
print("Headers/values around Y/Z check:")
for c in range(max(1, dst_verify.max_column - 1), dst_verify.max_column + 1):
    print(get_column_letter(c), dst_verify.cell(1, c).value)

result_output_spreadsheet = output_path
