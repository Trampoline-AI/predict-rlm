```repl
from openpyxl import load_workbook
from datetime import datetime
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Volym P5_P6_2023"]
zws = wb["ZORD"]

# Build material -> unique joined dates from ZORD column C ("Valid to"), preserving source order
date_map = {}
for r in range(2, zws.max_row + 1):
    material = zws.cell(r, 1).value
    dt = zws.cell(r, 3).value
    if material in (None, ""):
        continue
    if material not in date_map:
        date_map[material] = []
    if dt not in date_map[material]:
        date_map[material].append(dt)

def fmt_date(dt):
    if isinstance(dt, datetime):
        return dt.strftime("%d/%m/%Y")
    if dt in (None, ""):
        return ""
    # fallback if already text/date-like
    return str(dt)

written = []
for r in range(2, ws.max_row + 1):
    material = ws.cell(r, 1).value
    if material in (None, ""):
        continue
    joined = ",".join(fmt_date(d) for d in date_map.get(material, []) if fmt_date(d) != "")
    cell = ws.cell(r, 9)  # Column I
    # Print current value before overwriting
    old_val = cell.value
    cell.value = joined
    cell.number_format = "@"
    written.append((f"I{r}", material, str(old_val), joined))

print("About to write these Column I values:")
for item in written:
    print(item)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(output_path)
current_sheetnames = wb_check.sheetnames[:]
print("Sheet names after recalc reload:", current_sheetnames)

if current_sheetnames != original_sheetnames and len(current_sheetnames) == len(original_sheetnames):
    for idx, expected_name in enumerate(original_sheetnames):
        wb_check.worksheets[idx].title = expected_name
    wb_check.save(output_path)
    print("Restored original sheet names:", original_sheetnames)

# Verify output values
wb_verify_formula = load_workbook(output_path, data_only=False)
wb_verify_data = load_workbook(output_path, data_only=True)

print("\nVerification - target Column I values:")
wsf = wb_verify_formula["Volym P5_P6_2023"]
wsd = wb_verify_data["Volym P5_P6_2023"]

for r in range(1, wsf.max_row + 1):
    if r == 1 or wsf.cell(r, 1).value not in (None, ""):
        print({
            "row": r,
            "material": wsf.cell(r, 1).value,
            "I_formula_view": wsf.cell(r, 9).value,
            "I_data_view": wsd.cell(r, 9).value,
            "I_number_format": wsf.cell(r, 9).number_format,
        })

# Additional explicit verification of the key example row mentioned in the instruction
print("\nKey check I2:", wsd["I2"].value)
```
