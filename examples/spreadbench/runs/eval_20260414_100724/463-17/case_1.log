import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Re-open fresh workbook for source inspection and editing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Using sheet:", ws.title)

# Inspect source rows in A:B and target column D
source_rows = []
for r in range(2, ws.max_row + 1):
    company = ws.cell(r, 1).value
    count = ws.cell(r, 2).value
    if company is not None and company != "":
        source_rows.append((r, company, count))

print("Source rows from A:B:")
for item in source_rows:
    print(item)

print("\nCurrent D cells and whether any formulas exist:")
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 4).value
    if v is not None and v != "":
        print(f"D{r} = {v!r}, formula={isinstance(v, str) and v.startswith('=')}")

# Build repeated list
expanded = []
for r, company, count in source_rows:
    try:
        n = int(count)
    except Exception as e:
        raise ValueError(f"Invalid count at row {r}: {count!r}") from e
    if n < 0:
        raise ValueError(f"Negative count at row {r}: {n}")
    expanded.extend([company] * n)

print("\nTotal repeated names expected:", len(expanded))
print("First 15 expected entries:", expanded[:15])
print("Last 10 expected entries:", expanded[-10:])

target_start_row = 2
target_end_row = target_start_row + len(expanded) - 1
print(f"Target output range in column D: D{target_start_row}:D{target_end_row}")

# Write output into D2 downward
for i, name in enumerate(expanded, start=target_start_row):
    ws.cell(i, 4).value = name

# Clear any old trailing values in D below the target range if present
for r in range(target_end_row + 1, ws.max_row + 1):
    if ws.cell(r, 4).value not in (None, ""):
        ws.cell(r, 4).value = None

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload, restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for old_name, new_name in zip(orig_sheet_names, wb_after.sheetnames):
        if old_name != new_name:
            wb_after[new_name].title = old_name
    wb_after.save(output_path)
    print("Renamed sheets back to original:", orig_sheet_names)

# Verify with data_only read
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify[orig_sheet_names[0]]

verified = [vws.cell(r, 4).value for r in range(target_start_row, target_end_row + 1)]
print("Verified target range size:", len(verified))
print("Verified first 15 D values:", verified[:15])
print("Verified last 10 D values:", verified[-10:])

# Sanity checks
mismatches = []
for idx, expected in enumerate(expanded, start=target_start_row):
    actual = vws.cell(idx, 4).value
    if actual != expected:
        mismatches.append((idx, expected, actual))
        if len(mismatches) >= 10:
            break

print("Mismatch sample:", mismatches)
print("D1 header:", vws["D1"].value)

# Save final path variable for submission
final_output_spreadsheet = output_path
print("Final output ready:", final_output_spreadsheet)
