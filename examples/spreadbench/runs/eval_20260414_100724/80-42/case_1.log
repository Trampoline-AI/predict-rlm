from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)

print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def cell_display(v):
    if v is None:
        return None
    return v

def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [cell_display(ws.cell(r, c).value) for c in range(1, mc+1)]

def nonempty_count(vals):
    return sum(v not in (None, "") for v in vals)

def find_probable_header_row(ws, scan_rows=10):
    best_r = 1
    best_score = -1
    for r in range(1, min(scan_rows, ws.max_row) + 1):
        vals = row_vals(ws, r, ws.max_column)
        # favor rows with several strings / nonempty cells
        score = 0
        for v in vals:
            if isinstance(v, str) and v.strip():
                score += 2
            elif v not in (None, ""):
                score += 1
        if score > best_score:
            best_score = score
            best_r = r
    return best_r

def fill_sig(cell):
    f = cell.fill
    if not f:
        return None
    return {
        "fill_type": f.fill_type,
        "start": f.start_color.rgb if f.start_color else None,
        "end": f.end_color.rgb if f.end_color else None,
        "fg": getattr(f.fgColor, "rgb", None) if getattr(f, "fgColor", None) else None,
        "pattern": f.patternType,
    }

