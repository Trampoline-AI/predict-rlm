        print(f"Row {r}: {vals}")
    
    # Inspect key columns K and Z specifically
    if ws.max_column >= 11:
        print("\nColumn K sample values:")
        for r in rows_to_show:
            print(f"  K{r} = {ws.cell(r, 11).value}")
    if ws.max_column >= 26:
        print("\nColumn Z sample values/formulas:")
        for r in rows_to_show:
            print(f"  Z{r} = {ws.cell(r, 26).value}")
        
        nonempty_z = []
