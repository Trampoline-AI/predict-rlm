    for c, v in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}: {v}")
    
    # Sample first 10 rows and last 5 rows, columns A:Z if available
    end_col = min(ws.max_column, 26)
    sample_rows = list(range(1, min(ws.max_row, 10) + 1))
    tail_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in sample_rows + tail_rows:
        if r not in seen:
            rows_to_show.append(r)
            seen.add(r)
    
    print(f"\nSample rows (A:{get_column_letter(end_col)}):")
