import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally for editing
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

def row_has_data_ax(ws, r):
    return any(ws.cell(r, c).value not in (None, "") for c in range(1, 25))  # A:X

def to_number(v):
    if isinstance(v, (int, float)):
        return float(v)
    if isinstance(v, str):
        s = v.strip()
        if s == "":
            return None
        try:
            return float(s)
        except:
            return None
    return None

# Identify actual data rows from row 5 onward only
data_rows = [r for r in range(5, ws.max_row + 1) if row_has_data_ax(ws, r)]

# Build contiguous blocks (groups)
blocks = []
if data_rows:
    start = prev = data_rows[0]
    for r in data_rows[1:]:
        if r == prev + 1:
            prev = r
        else:
            blocks.append((start, prev))
            start = prev = r
    blocks.append((start, prev))

print("Detected data rows:", data_rows)
print("Detected groups:", blocks)

# Compute decisions
decisions = {}  # row -> Y/N
block_summaries = []

for start, end in blocks:
    rows = list(range(start, end + 1))
    k_vals = [to_number(ws.cell(r, 11).value) for r in rows]  # column K
    names = [ws.cell(r, 1).value for r in rows]
    
    numeric_vals = [v for v in k_vals if v is not None]
    if len(rows) == 1:
        # alone in group/category block
        decisions[rows[0]] = "Y"
    else:
        if not numeric_vals:
            # defensive fallback: if no numeric K values, mark none? but this case shouldn't happen.
            # mark Y for all to avoid blanks; however not expected here.
            for r in rows:
                decisions[r] = "Y"
        else:
            max_k = max(numeric_vals)
            for r, kv in zip(rows, k_vals):
                decisions[r] = "Y" if kv == max_k else "N"
    
    block_summaries.append({
        "block": (start, end),
        "names": names,
        "k_vals": k_vals,
        "z_vals": [decisions[r] for r in rows],
    })

print("\nFull group analysis:")
for summary in block_summaries:
    print(summary)

# Show existing Z values before writing for target rows
existing = [(r, ws.cell(r, 26).value) for r in data_rows]
print("\nExisting Z values before write:", existing)

# Write to column Z only for actual data rows
for r in data_rows:
    ws.cell(r, 26).value = decisions[r]

# Verify in-memory values before save
written_preview = [(r, ws.cell(r, 1).value, ws.cell(r, 11).value, ws.cell(r, 26).value) for r in data_rows]
print("\nWritten in-memory preview (row, name, K, Z):")
for item in written_preview:
    print(item)

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open after recalc and restore original sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed; restoring original names...")
    for i, orig in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig
    wb_after.save(output_path)
    print("Restored sheet names:", wb_after.sheetnames)

# Verify output values after recalculation using data_only=True
wb_verify = load_workbook(output_path, data_only=True)
ws_verify = wb_verify[original_sheetnames[0]]

verified = [(r, ws_verify.cell(r, 1).value, ws_verify.cell(r, 11).value, ws_verify.cell(r, 26).value) for r in data_rows]
print("\nVerified output (row, name, K, Z):")
for item in verified:
    print(item)

# Sanity checks
missing = [r for r in data_rows if ws_verify.cell(r, 26).value in (None, "")]
unexpected_rows_with_z = [(r, ws_verify.cell(r, 26).value) for r in range(1, ws_verify.max_row + 1)
                          if r not in data_rows and ws_verify.cell(r, 26).value not in (None, "")]
print("\nMissing target Z values on data rows:", missing)
print("Unexpected non-empty Z outside data rows (first 20):", unexpected_rows_with_z[:20])

# Keep output_path available for submission
final_output_spreadsheet = output_path
print("\nPrepared output file:", final_output_spreadsheet)
```
