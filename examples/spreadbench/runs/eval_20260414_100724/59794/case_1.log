from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
from openpyxl.styles import PatternFill
from copy import copy
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheetnames:", orig_sheetnames)
print("Initial dimensions:", ws.dimensions)

# Inspect target/header styling before writing
for coord in ["C1", "C2", "K2", "C3", "K3"]:
    cell = ws[coord]
    print(f"{coord}: value={cell.value!r}, style_id={cell.style_id}, fill={cell.fill.fill_type}/{cell.fill.start_color.rgb}, font={cell.font.name}/{cell.font.sz}")

print("Column widths before:",
      {col: ws.column_dimensions[col].width for col in ["A","C","D","E","F","G","H","I","J","K"]})

# Determine actual data rows and max split width
data_rows = []
max_segments = 0
row_parts = {}
for r in range(3, ws.max_row + 1):
    val = ws.cell(r, 1).value
    if val is not None and val != "":
        parts = str(val).split("/")  # preserve slash-separated segments exactly
        row_parts[r] = parts
        data_rows.append(r)
        max_segments = max(max_segments, len(parts))

print("Data rows:", data_rows)
for r in data_rows:
    print(f"Row {r} segment count={len(row_parts[r])}, parts={row_parts[r]}")

start_col = 3  # C
existing_target_cols = ws.max_column - start_col + 1
required_last_col = start_col + max_segments - 1
print("Existing max_column:", ws.max_column, "Required last column:", required_last_col, get_column_letter(required_last_col))

# Add/format new columns if needed
if required_last_col > ws.max_column:
    old_last_col = ws.max_column
    template_col = old_last_col  # copy from rightmost existing target col
    for new_c in range(old_last_col + 1, required_last_col + 1):
        new_letter = get_column_letter(new_c)
        template_letter = get_column_letter(template_col)

        # Copy column width
        ws.column_dimensions[new_letter].width = ws.column_dimensions[template_letter].width

        # Copy styles for existing rows
        for r in range(1, ws.max_row + 1):
            src = ws.cell(r, template_col)
            dst = ws.cell(r, new_c)
            if src.has_style:
                dst._style = copy(src._style)
            if src.font:
                dst.font = copy(src.font)
            if src.fill:
                dst.fill = copy(src.fill)
            if src.border:
                dst.border = copy(src.border)
            if src.alignment:
                dst.alignment = copy(src.alignment)
            if src.number_format:
                dst.number_format = src.number_format
            if src.protection:
                dst.protection = copy(src.protection)

        # Header row 2 text
        ws.cell(2, new_c).value = f"Column{new_c - start_col + 1}"

    # Extend merged title row from C1:K1 to C1:last
    merged_ranges = list(ws.merged_cells.ranges)
    target_old_merge = None
    for mr in merged_ranges:
        if str(mr) == "C1:K1":
            target_old_merge = mr
            break
    if target_old_merge:
        ws.unmerge_cells(str(target_old_merge))
        ws.merge_cells(start_row=1, start_column=3, end_row=1, end_column=required_last_col)

print("Dimensions after expansion:", ws.dimensions)
print("Column widths after:",
      {get_column_letter(c): ws.column_dimensions[get_column_letter(c)].width for c in range(3, required_last_col+1)})

# Fill color requested
output_fill = PatternFill(start_color="FFE2EFDA", end_color="FFE2EFDA", fill_type="solid")

# Write outputs into C onward; clear only relevant target cells for data rows before writing
for r in data_rows:
    parts = row_parts[r]
    # clear current target cells across full required range
    for c in range(start_col, required_last_col + 1):
        ws.cell(r, c).value = None
        # preserve style but reset fill first so verification is clean
        existing = ws.cell(r, c)
        # keep style, just replace fill after writing populated cells

    for idx, part in enumerate(parts, start=0):
        c = start_col + idx
        ws.cell(r, c).value = part
        ws.cell(r, c).fill = copy(output_fill)

# Also apply fill to headers of any newly created columns? Instruction is about output cells, so keep to data cells only.

# Print target region preview before save
print("\nPreview after writing:")
for r in data_rows:
    vals = [ws.cell(r, c).value for c in range(start_col, required_last_col + 1)]
    print(f"Row {r} {get_column_letter(start_col)}:{get_column_letter(required_last_col)} -> {vals}")

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_after = load_workbook(out_path)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames and len(wb_after.sheetnames) == len(orig_sheetnames):
    for i, expected in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = expected
    wb_after.save(out_path)
    print("Renamed sheets back to original:", orig_sheetnames)

# Verify with data_only reload
verify_wb = load_workbook(out_path, data_only=True)
print("Verified sheetnames:", verify_wb.sheetnames)
vws = verify_wb[orig_sheetnames[0]]

print("\nVerification headers row 2:")
print([vws.cell(2, c).value for c in range(1, required_last_col + 1)])

print("\nVerification target cells:")
for r in data_rows:
    vals = [vws.cell(r, c).value for c in range(start_col, required_last_col + 1)]
    print(f"Row {r}: {vals}")

# Verify fills with normal workbook
style_wb = load_workbook(out_path)
sws = style_wb[orig_sheetnames[0]]
print("\nVerification fills on target cells:")
for r in data_rows:
    fills = [sws.cell(r, c).fill.start_color.rgb for c in range(start_col, required_last_col + 1)]
    print(f"Row {r} fills: {fills}")

output_spreadsheet = out_path
print("\nPrepared output_spreadsheet:", output_spreadsheet)
