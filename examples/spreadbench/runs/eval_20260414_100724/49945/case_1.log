import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target/output area before writing
print("Original sheetnames:", original_sheetnames)
print("F3:G11 before writing:")
for r in range(3, 12):
    print(r, ws[f"F{r}"].value, ws[f"G{r}"].value)

# Find all non-empty lookup model rows in column F starting at row 4
target_rows = []
for r in range(4, ws.max_row + 1):
    if ws[f"F{r}"].value not in (None, ""):
        target_rows.append(r)

print("Target rows in column F:", target_rows)

# Write formulas in column G for each listed model in column F
for r in target_rows:
    formula = f'=SUMIF($C$4:$C$11,F{r},$D$4:$D$11)'
    ws[f"G{r}"] = formula
    print(f"Wrote {formula} to G{r}")

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_after = load_workbook(outfile)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # Rename sheets back by position
    for i, original_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = original_name
    wb_after.save(outfile)
    print("Restored original sheet names:", original_sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target cells:")
for r in target_rows:
    print(
        f"Row {r}:",
        "Model=", ws_values[f"F{r}"].value,
        "Formula=", ws_formula[f'G{r}'].value,
        "Value=", ws_values[f"G{r}"].value
    )

output_spreadsheet = outfile
