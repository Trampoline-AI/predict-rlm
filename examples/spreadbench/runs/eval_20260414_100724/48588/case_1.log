Code:
```repl
from openpyxl import load_workbook
import os, shutil

# Re-open and inspect all relevant rows in detail
wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

last_nonempty = 0
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
        last_nonempty = r
        break

print("Sheet:", ws.title)
print("Target headers:", ws["A1"].value, "|", ws["B1"].value)
print("Detailed A/B rows:")
for r in range(1, last_nonempty + 1):
    print(r, ws.cell(r,1).value, ws.cell(r,2).value)

# Identify exact target rows: non-empty product in col A with blank col B
target_rows = [
    r for r in range(2, last_nonempty + 1)
    if ws.cell(r,1).value not in (None, "") and ws.cell(r,2).value in (None, "")
]
print("Target rows needing output:", target_rows[:20], "count=", len(target_rows))
print("First target row:", target_rows[0] if target_rows else None, "Last target row:", target_rows[-1] if target_rows else None)

# Apply formula only to blanks in column B
# Pattern:
# - if first time product appears up to current row => next ID = MAX(previous B)+1
# - else repeat the ID from its earlier occurrence
for r in target_rows:
    formula = f'=IF(COUNTIF($A$2:A{r},A{r})=1,MAX($B$1:B{r-1})+1,INDEX($B$1:B{r-1},MATCH(A{r},$A$1:A{r-1},0)))'
    ws.cell(r, 2).value = formula

# Print formulas written
print("\nFormulas written:")
for r in target_rows[:10]:
    print(f"B{r} =", ws.cell(r,2).value)
if len(target_rows) > 10:
    print("...")
    for r in target_rows[-5:]:
        print(f"B{r} =", ws.cell(r,2).value)

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc; restore sheet names if needed
wb_after = load_workbook(out_path)
print("Sheet names after recalc:", wb_after.sheetnames)
orig_sheet_names = ['Sheet1']
if wb_after.sheetnames != orig_sheet_names and len(wb_after.sheetnames) == len(orig_sheet_names):
    for old_name, desired_name in zip(wb_after.sheetnames, orig_sheet_names):
        if old_name != desired_name:
            wb_after[old_name].title = desired_name
    wb_after.save(out_path)
    print("Restored sheet names to:", wb_after.sheetnames)

# Verify with data_only=True
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_sheet_names[0]]

print("\nVerification of target cells:")
for r in target_rows:
    print(f"Row {r}: A{r}={wsv.cell(r,1).value!r}, B{r}={wsv.cell(r,2).value!r}")

# Also compare a sample of repeated products to ensure consistent IDs
print("\nSample full verification rows 2:20")
for r in range(2, min(20, last_nonempty) + 1):
    print(r, wsv.cell(r,1).value, wsv.cell(r,2).value)

output_spreadsheet = out_path
```
