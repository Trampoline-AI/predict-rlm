import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Load workbook
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

# Constants from instruction
TARGET_BG_VALUES = {
    "OCOGS - Spares - Transfer Price Overhead",
    "OFSS - ORCL Consulting Prod Cost I/C",
}
TARGET_AY_VALUES = {"BOA_033E", "BOA_011G"}
RESULT_IF_AY_MATCH = "OCOGS - Spares - Transfer Price Overhead"
RESULT_OTHERWISE = "OFSS - ORCL Consulting Prod Cost I/C"
blue_fill = PatternFill(start_color="FF0070C0", end_color="FF0070C0", fill_type="solid")

# Pre-check exact target cells/columns
print("Target columns/cells check:")
for c in ["AY", "BF", "BG", "BL", "BN"]:
    print(c, "row1=", ws[f"{c}1"].value, "row2=", ws[f"{c}2"].value)
print("Non-empty BN cells before write:", sum(1 for r in range(2, ws.max_row + 1) if ws[f"BN{r}"].value not in (None, "")))

# Determine rows to update
rows_to_update = []
bf_comparison = []
for r in range(2, ws.max_row + 1):
    ay = ws[f"AY{r}"].value
    bg = ws[f"BG{r}"].value
    bl = ws[f"BL{r}"].value
    bf = ws[f"BF{r}"].value
    bn_before = ws[f"BN{r}"].value
    
    cond1 = bl == "LAG"
    cond2 = bg in TARGET_BG_VALUES
    
    if cond1 and cond2:
        bn_value = RESULT_IF_AY_MATCH if ay in TARGET_AY_VALUES else RESULT_OTHERWISE
        rows_to_update.append({
            "row": r,
            "AY": ay,
            "BG": bg,
            "BL": bl,
            "BF": bf,
            "BN_before": bn_before,
            "BN_after": bn_value,
        })
        if bf not in (None, ""):
            bf_comparison.append((r, bf, bn_value, bf == bn_value))

print("\nRows that meet first two conditions and will get BN populated:", len(rows_to_update))
for item in rows_to_update:
    print(item)

print("\nComparison against existing example/helper column BF:")
print("rows compared:", len(bf_comparison))
print("mismatches:", [x for x in bf_comparison if not x[3]])

# Write BN and color BL
for item in rows_to_update:
    r = item["row"]
    ws[f"BN{r}"] = item["BN_after"]
    # Only fill BL when BL is LAG and BN is populated
    if ws[f"BL{r}"].value == "LAG" and ws[f"BN{r}"].value not in (None, ""):
        ws[f"BL{r}"].fill = blue_fill

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_check = load_workbook(output_path)
current_sheet_names = wb_check.sheetnames[:]
print("Sheet names after recalc reload:", current_sheet_names)

if current_sheet_names != orig_sheet_names and len(current_sheet_names) == len(orig_sheet_names):
    for i, old_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Restored original sheet names:", orig_sheet_names)

# Verification reloads
wb_verify = load_workbook(output_path)
ws_verify = wb_verify[orig_sheet_names[0]]

wb_verify_data = load_workbook(output_path, data_only=True)
ws_verify_data = wb_verify_data[orig_sheet_names[0]]

# Verify exact target cells/ranges
print("\nVERIFICATION OF TARGET CELLS:")
blank_bn_rows = []
bad_fill_rows = []

for item in rows_to_update:
    r = item["row"]
    bn_val = ws_verify_data[f"BN{r}"].value
    bl_val = ws_verify[f"BL{r}"].value
    fill_rgb = ws_verify[f"BL{r}"].fill.start_color.rgb
    print({
        "row": r,
        "AY": ws_verify_data[f"AY{r}"].value,
        "BG": ws_verify_data[f"BG{r}"].value,
        "BL": bl_val,
        "BN": bn_val,
        "BL_fill_rgb": fill_rgb,
    })
    if bn_val in (None, ""):
        blank_bn_rows.append(r)
    if not (bl_val == "LAG" and bn_val not in (None, "") and fill_rgb in ("FF0070C0", "0070C0")):
        bad_fill_rows.append((r, fill_rgb, bl_val, bn_val))

print("\nSummary:")
print("Updated row count:", len(rows_to_update))
print("Blank BN rows after save/recalc:", blank_bn_rows)
print("Bad fill rows:", bad_fill_rows)
print("Final sheet names:", load_workbook(output_path).sheetnames)
