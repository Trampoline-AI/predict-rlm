from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
from openpyxl.styles import PatternFill
import os

in_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(in_path))

# Fresh load for writing
wb = load_workbook(in_path)
ws = wb["Data"]
original_sheetnames = wb.sheetnames[:]

ad_col = column_index_from_string("AD")
ao_col = column_index_from_string("AO")

# Determine rows to populate: any row with meaningful data in the main source area
target_rows = []
for r in range(14, ws.max_row + 1):
    if any(ws[f"{col}{r}"].value not in (None, "") for col in ["I", "J", "L", "M", "N", "O", "P", "W"]):
        target_rows.append(r)

print("Target rows:", target_rows)

# Write formulas into AD:AO
for r in target_rows:
    for c in range(ad_col, ao_col + 1):
        col = get_column_letter(c)
        # Use DATE instead of EDATE for better compatibility
        formula = (
            f'=IF(OR({col}$9="",$L{r}="",NOT(ISNUMBER($J{r}))),"",'
            f'IF({col}$9<$L{r},"",'
            f'$W{r}'
            f'*IF($M{r}="",1,1+$M{r})'
            f'*IF(AND($N{r}<>"",{col}$9>=DATE(YEAR($L{r}),MONTH($L{r})+$J{r},1)),1+$N{r},1)'
            f'*IF(AND($O{r}<>"",{col}$9>=DATE(YEAR($L{r}),MONTH($L{r})+2*$J{r},1)),1+$O{r},1)'
            f'*IF(AND($P{r}<>"",{col}$9>=DATE(YEAR($L{r}),MONTH($L{r})+3*$J{r},1)),1+$P{r},1)'
            f'))'
        )
        cell = ws.cell(r, c)
        cell.value = formula
        cell.fill = PatternFill(fill_type=None)  # remove yellow fill
        cell.number_format = ws[f"W{r}"].number_format

wb.save(out_path)
print("Saved:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore sheet names if recalc changed them
wb_after = load_workbook(out_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed:", wb_after.sheetnames, "->", original_sheetnames)
    for i, name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(out_path)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verify cached values
wbv = load_workbook(out_path, data_only=True)
wsv = wbv["Data"]

print("\nRow 9 dates AD:AO (data_only):")
for c in range(ad_col, ao_col + 1):
    print(get_column_letter(c), wsv.cell(9, c).value)

print("\nSample verified values AD:AO rows 14:18:")
for r in range(14, 19):
    vals = [wsv.cell(r, c).value for c in range(ad_col, ao_col + 1)]
    print(f"R{r}:", vals)

# Verify formulas + fill in normal workbook
wbf = load_workbook(out_path)
wsf = wbf["Data"]

print("\nSample formulas AD:AO rows 14:16:")
for r in range(14, 17):
    vals = [wsf.cell(r, c).value for c in range(ad_col, ao_col + 1)]
    print(f"R{r}:", vals)

print("\nSample fills AD:AF rows 14:16:")
for r in range(14, 17):
    info = []
    for c in range(ad_col, ad_col + 3):
        cell = wsf.cell(r, c)
        info.append((f"{get_column_letter(c)}{r}", cell.fill.fill_type, cell.fill.fgColor.rgb))
    print(info)

output_spreadsheet = out_path
