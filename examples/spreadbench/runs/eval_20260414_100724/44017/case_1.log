from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string, get_column_letter

out_path = "/sandbox/output/output_spreadsheet/1_44017_init.xlsx"

wb_formula = load_workbook(out_path)
wsf = wb_formula["Data"]

wb_values = load_workbook(out_path, data_only=True)
wsv = wb_values["Data"]

ad_col = column_index_from_string("AD")
ao_col = column_index_from_string("AO")

issues = {
    "missing_formula": [],
    "missing_value_when_expected": [],
    "error_like_value": [],
    "yellow_fill": [],
}

def is_yellow(cell):
    fills = [
        getattr(cell.fill.fgColor, "rgb", None),
        getattr(cell.fill.start_color, "rgb", None),
        getattr(cell.fill.end_color, "rgb", None),
    ]
    fills = [x.upper() for x in fills if isinstance(x, str)]
    return any(x in {"FFFFFF00", "FFFF00"} for x in fills)

for r in range(14, wsf.max_row + 1):
    L = wsf[f"L{r}"].value
    W = wsf[f"W{r}"].value
    Jv = wsv[f"J{r}"].value  # cached numeric freq if available
    # Only audit rows that look like actual customer rows
    row_is_relevant = any(wsf[f"{col}{r}"].value not in (None, "") for col in ["I","J","L","M","N","O","P","W"])
    if not row_is_relevant:
        continue

    for c in range(ad_col, ao_col + 1):
        col = get_column_letter(c)
        formula_cell = wsf.cell(r, c)
        value_cell = wsv.cell(r, c)
        month_date = wsv.cell(9, c).value

        if not (isinstance(formula_cell.value, str) and formula_cell.value.startswith("=")):
            issues["missing_formula"].append(f"{col}{r}")

        if is_yellow(formula_cell):
            issues["yellow_fill"].append(f"{col}{r}")

        val = value_cell.value
        if isinstance(val, str) and val.startswith("#"):
            issues["error_like_value"].append(f"{col}{r}={val}")

        expected = (
            month_date is not None and
            L is not None and
            W is not None and
            isinstance(Jv, (int, float)) and
            month_date >= L
        )
        if expected and val is None:
            issues["missing_value_when_expected"].append(f"{col}{r}")

print("Output file:", out_path)
print("Sheet names (formula wb):", wb_formula.sheetnames)
print("Sheet names (value wb):", wb_values.sheetnames)

print("\nIssue counts:")
for k, v in issues.items():
    print(k, len(v))

for k, v in issues.items():
    if v:
        print(f"\n{k} examples:", v[:20])

print("\nRepresentative rows 19:23 with source data and AD:AO values")
for r in range(19, 24):
    src = {col: wsf[f"{col}{r}"].value for col in ["I","J","K","L","M","N","O","P","W"]}
    vals = [wsv.cell(r, c).value for c in range(ad_col, ao_col + 1)]
    print(f"Row {r} source:", src)
    print(f"Row {r} AD:AO:", vals)

output_spreadsheet = out_path
print("\nReady to submit:", output_spreadsheet)
