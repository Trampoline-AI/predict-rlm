import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load and inspect exact target extent
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Determine actual relevant extent from column B
last_nonempty_b = 2
for r in range(ws.max_row, 2, -1):
    v = ws.cell(r, 2).value
    if v is not None and str(v).strip() != "":
        last_nonempty_b = r
        break

print("Original sheet names:", original_sheetnames)
print("Worksheet:", ws.title)
print("ws.max_row:", ws.max_row, "last_nonempty_b:", last_nonempty_b)
print("B2:", ws["B2"].value)
print("Current A3:A12 and B3:B12 before writing:")
for r in range(3, min(last_nonempty_b, 12) + 1):
    print(r, "A=", ws.cell(r, 1).value, "B=", ws.cell(r, 2).value)

# Write formula starting at A3 through the relevant data extent
for r in range(3, last_nonempty_b + 1):
    ws.cell(r, 1).value = f'=IF(B{r}="","",$B$2&"-02-"&TEXT(COUNTIF($B$3:B{r},"<>")+9,"000"))'

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore sheet names if changed
wb_after = load_workbook(outfile)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # rename by position back to originals
    for i, name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = name
    wb_after.save(outfile)
    print("Restored sheet names to:", wb_after.sheetnames)
else:
    print("Sheet names preserved after recalc.")

# Verify formulas and cached results
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]

wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target cells A3:A36 (or to last_nonempty_b):")
for r in range(3, last_nonempty_b + 1):
    b = ws_values.cell(r, 2).value
    a_formula = ws_formula.cell(r, 1).value
    a_value = ws_values.cell(r, 1).value
    if r <= 15 or r >= last_nonempty_b - 5:
        print(f"Row {r}: B={b!r}, A_formula={a_formula!r}, A_value={a_value!r}")

# Focus on rows matching the sample/example rows
