```repl
import os
from copy import copy
from collections import OrderedDict
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load original workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Build aggregated unique records from A:D, preserving first appearance order
agg = OrderedDict()
last_data_row_ad = 1
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 5)]
    if any(v is not None for v in vals):
        last_data_row_ad = r
    idv = ws.cell(r, 1).value
    if idv is None:
        continue
    name = ws.cell(r, 2).value
    dt = ws.cell(r, 3).value
    amt = ws.cell(r, 4).value or 0
    try:
        amt_num = float(amt)
    except Exception:
        amt_num = 0.0
    if idv not in agg:
        agg[idv] = {"name": name, "dt": dt, "sum_amt": 0.0}
    agg[idv]["sum_amt"] += amt_num

records = [(idv, rec["name"], rec["dt"], int(round(rec["sum_amt"]))) for idv, rec in agg.items()]
print("Aggregated records to write:", records)
print("Last non-empty A:D row before write:", last_data_row_ad)
print("Merged ranges before write:", [str(r) for r in ws.merged_cells.ranges])

# Unmerge only merged cells that intersect A:D (none expected, but check explicitly)
to_unmerge = []
for mr in ws.merged_cells.ranges:
    if mr.min_col <= 4:  # any overlap with A:D
        to_unmerge.append(str(mr))
for rng in to_unmerge:
    ws.unmerge_cells(rng)
print("Merged ranges unmerged in A:D:", to_unmerge)

# Formatting helpers
def set_black_not_bold(cell):
    f = copy(cell.font)
    f.bold = False
    f.color = "FF000000"
    cell.font = f

# Keep a consistent date display format in C; use explicit format per instruction intent
date_fmt = "m/dd/yyyy hh:ss"
int_fmt = "0"

# Apply table-wide font styling in A:D
for r in range(1, ws.max_row + 1):
    for c in range(1, 5):
        set_black_not_bold(ws.cell(r, c))

# Rewrite compacted unique records into rows 2...
out_start = 2
for i, (idv, name, dt, amt) in enumerate(records, start=out_start):
    ws.cell(i, 1).value = idv
    ws.cell(i, 2).value = name
    ws.cell(i, 3).value = dt
    ws.cell(i, 4).value = amt
    
    set_black_not_bold(ws.cell(i, 1))
    set_black_not_bold(ws.cell(i, 2))
    set_black_not_bold(ws.cell(i, 3))
    set_black_not_bold(ws.cell(i, 4))
    
    ws.cell(i, 3).number_format = date_fmt
    ws.cell(i, 4).number_format = int_fmt

# Clear leftover A:D rows only; do not touch other columns
clear_from = out_start + len(records)
for r in range(clear_from, last_data_row_ad + 1):
    for c in range(1, 5):
        ws.cell(r, c).value = None
        set_black_not_bold(ws.cell(r, c))
        if c == 3:
            ws.cell(r, c).number_format = date_fmt
        elif c == 4:
            ws.cell(r, c).number_format = int_fmt

# Also ensure header A:D not bold/black as requested
for c in range(1, 5):
    set_black_not_bold(ws.cell(1, c))

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and repair sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # Rename by position to original names
    for idx, name in enumerate(orig_sheetnames):
        wb_check.worksheets[idx].title = name
    wb_check.save(outfile)
    wb_check = load_workbook(outfile)

print("Sheet names after final save:", wb_check.sheetnames)

# Verification with formulas/data cached
wb_data = load_workbook(outfile, data_only=True)
wsf = wb_check[orig_sheetnames[0]]
wsv = wb_data[orig_sheetnames[0]]

print("Merged ranges after final save:", [str(r) for r in wsf.merged_cells.ranges])

# Verify target area A:H rows 1:9
print("\nVerification snapshot A:H rows 1:9 (formula workbook values):")
for r in range(1, min(9, wsf.max_row) + 1):
    rowvals = [wsf.cell(r, c).value for c in range(1, 9)]
    print(f"Row {r}: {rowvals}")

print("\nVerification snapshot A:H rows 1:9 (data_only values):")
for r in range(1, min(9, wsv.max_row) + 1):
    rowvals = [wsv.cell(r, c).value for c in range(1, 9)]
    print(f"Row {r}: {rowvals}")

# Detailed checks for target cells
targets = ["A2","B2","C2","D2","A3","D3","A4","D4","A5","D5","A6","D6","A7","D7","A8","D8","F2","F6","H2","H6"]
print("\nDetailed target cell verification:")
for coord in targets:
    c_formula = wsf[coord]
    c_value = wsv[coord]
    print(
        coord,
        "stored=", repr(c_formula.value),
        "data_only=", repr(c_value.value),
        "numfmt=", repr(c_formula.number_format),
        "bold=", c_formula.font.bold,
        "font_color=", getattr(c_formula.font.color, "rgb", None) if c_formula.font.color else None
    )

output_spreadsheet = outfile
print("\nPrepared output_spreadsheet:", output_spreadsheet)
