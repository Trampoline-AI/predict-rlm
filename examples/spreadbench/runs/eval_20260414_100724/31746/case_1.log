def display(val):
    if val is None:
        return None
    s = str(val)
    return s if len(s) <= 80 else s[:77] + "..."

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # detect non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in row_vals):
            nonempty_rows.append(r)
    print(f"Non-empty row count: {len(nonempty_rows)}; first/last non-empty rows: {nonempty_rows[:5]} ... {nonempty_rows[-5:] if nonempty_rows else []}")
    
    # print first 10 rows with coordinates and values
    print("\nFirst up to 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # print last 5 rows
    print("\nLast up to 5 rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # try identify candidate header row among first 5 rows
    print("\nCandidate headers in first 5 rows:")
    for r in range(1, min(5, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        nonempty = [(get_column_letter(c), display(v)) for c, v in enumerate(vals, start=1) if v not in (None, "")]
        print(f"Row {r} non-empty: {nonempty}")
    
    # print formulas found in first 20 rows / all columns
    formulas = []
    for r in range(1, min(ws.max_row, 50) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print(f"\nFormulas found in first 50 rows: {formulas[:20]} (total {len(formulas)})")
