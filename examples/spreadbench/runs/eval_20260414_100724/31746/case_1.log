Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload fresh workbook for editing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Derive month columns and weights from headers D:P
month_cols = []
for c in range(4, 17):  # D:P
    hdr = ws.cell(2, c).value
    if isinstance(hdr, str) and hdr.startswith("Month "):
        month_num = int(hdr.split()[1])
        weight = 81 - (month_num - 1)
        month_cols.append((c, month_num, weight))
print("Derived month weights:", [(get_column_letter(c), m, w) for c, m, w in month_cols])

# Inspect existing target cells before writing
print("\nCurrent Q3:Q38 before update:")
for r in range(3, 39):
    print(f"Q{r} -> {ws[f'Q{r}'].value!r}")

# Build expected formulas and python verification totals
python_row_totals = {}
for r in range(3, 38):
    total = 0.0
    for c, month_num, weight in month_cols:
        v = ws.cell(r, c).value
        try:
            num = float(v)
        except (TypeError, ValueError):
            num = 0.0
        total += num * weight
    python_row_totals[r] = total

python_grand_total = sum(python_row_totals.values())
print("\nPython-computed sample totals:")
for r in [15, 16, 17, 24, 34, 37]:
    print(f"Row {r}: {python_row_totals[r]}")
print("Python grand total:", python_grand_total)

# Fill/update Q3:Q37 with formulas where missing/non-formula
for r in range(3, 38):
    formula = "=" + "+".join(f"{get_column_letter(c)}{r}*{weight}" for c, _, weight in month_cols)
    cell = ws.cell(r, 17)  # Q
    # keep existing formulas if present; fill blanks / non-formulas
    if not (isinstance(cell.value, str) and cell.value.startswith("=")):
        cell.value = formula
    # ensure not bold
    f = copy(cell.font)
    f.bold = False
    cell.font = f

# Grand total in Q38
ws["Q38"] = "=SUM(Q3:Q37)"
f = copy(ws["Q38"].font)
f.bold = False
ws["Q38"].font = f

# Save once
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if LibreOffice renamed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_post.sheetnames, "-> restoring", orig_sheet_names)
    # rename by position
    for i, orig_name in enumerate(orig_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = orig_name
    wb_post.save(output_path)
else:
    print("Sheet names preserved:", wb_post.sheetnames)

# Verify with data_only
wb_val = load_workbook(output_path, data_only=True)
ws_val = wb_val[orig_sheet_names[0]]

q_values = {r: ws_val[f"Q{r}"].value for r in range(3, 39)}
none_rows = [r for r, v in q_values.items() if v is None]

print("\nVerification after recalc (data_only):")
for r in range(3, 39):
    print(f"Q{r} = {q_values[r]!r}")

print("Rows with None in Q after recalc:", none_rows)

# Fallback: if formulas did not evaluate, write literal values directly
if none_rows:
    print("\nFallback triggered: writing literal numeric values.")
    wb_fix = load_workbook(output_path)
    ws_fix = wb_fix[orig_sheet_names[0]]
    for r in range(3, 38):
        ws_fix[f"Q{r}"] = python_row_totals[r]
        f = copy(ws_fix[f"Q{r}"].font)
        f.bold = False
        ws_fix[f"Q{r}"].font = f
    ws_fix["Q38"] = python_grand_total
    f = copy(ws_fix["Q38"].font)
    f.bold = False
    ws_fix["Q38"].font = f
    wb_fix.save(output_path)

    wb_val = load_workbook(output_path, data_only=True)
    ws_val = wb_val[orig_sheet_names[0]]
    q_values = {r: ws_val[f"Q{r}"].value for r in range(3, 39)}
    print("\nVerification after fallback literals:")
    for r in range(3, 39):
        print(f"Q{r} = {q_values[r]!r}")

# Final checks
wb_check = load_workbook(output_path)
ws_check = wb_check[orig_sheet_names[0]]
bold_issues = [f"Q{r}" for r in range(3, 39) if ws_check[f"Q{r}"].font.bold]
print("\nBold issues in target cells:", bold_issues)
print("Final sheet names:", wb_check.sheetnames)

final_output_spreadsheet = output_path
```
