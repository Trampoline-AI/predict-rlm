from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string
import os, shutil

print("Full instruction:\n", instruction)

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("\nRelevant headers / target-area inspection:")
for c in range(1, ws.max_column + 1):
    cell = ws.cell(1, c)
    print(f"{get_column_letter(c)}1 -> {cell.value!r}, number_format={cell.number_format!r}")

print("\nInspect rows 2:10 for columns A:H:")
for r in range(2, 11):
    vals = [ws.cell(r, c).value for c in range(1, 9)]
    print(f"Row {r}: {vals}")

print("\nCurrent H column values/formulas (rows 2:15):")
for r in range(2, 16):
    cell = ws[f"H{r}"]
    print(f"H{r}: value={cell.value!r}, number_format={cell.number_format!r}")

print("\nCurrent existing formulas in E/F/H for rows 2:10:")
for r in range(2, 11):
    print(
        r,
        "E=", ws[f"E{r}"].value,
        "F=", ws[f"F{r}"].value,
        "H=", ws[f"H{r}"].value
    )

# Determine rows that actually have input data
data_rows = []
for r in range(2, ws.max_row + 1):
    year = ws.cell(r, 1).value
    deposit = ws.cell(r, 2).value
    eff = ws.cell(r, 3).value
    if year is not None and (deposit is not None or eff is not None):
        data_rows.append(r)

print("\nRows with actual deposit/efficiency data:", data_rows)

# Apply formulas to H only for data rows; preserve blanks elsewhere
if data_rows:
    first = data_rows[0]
    if ws[f"H{first}"].value in (None, ""):
        ws[f"H{first}"] = f"=(B{first})*(1+C{first})"
    for r in data_rows[1:]:
        if ws[f"H{r}"].value in (None, ""):
            ws[f"H{r}"] = f"=(H{r-1}+B{r})*(1+C{r})"

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
orig_sheetnames = wb.sheetnames[:]
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # Rename in order to original names
    for ws_cur, orig_name in zip(wb2.worksheets, orig_sheetnames):
        ws_cur.title = orig_name
    wb2.save(out_path)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify with data_only
wbd = load_workbook(out_path, data_only=True)
wsd = wbd[orig_sheetnames[0]]

print("\nVerification of target cells H2:H10 (data_only):")
for r in range(2, 11):
    print(f"H{r} -> {wsd[f'H{r}'].value!r}")

print("\nVerification of formulas H2:H10:")
wbf = load_workbook(out_path, data_only=False)
wsf = wbf[orig_sheetnames[0]]
for r in range(2, 11):
    print(f"H{r} formula/value -> {wsf[f'H{r}'].value!r}")

output_spreadsheet = out_path
print("\nPrepared output_spreadsheet =", output_spreadsheet)
