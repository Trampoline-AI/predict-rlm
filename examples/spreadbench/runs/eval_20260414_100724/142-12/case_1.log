from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
orig_sheet_names = wb.sheetnames
print("Workbook:", path)
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    header_map = {get_column_letter(i): headers[i-1] for i in range(1, ws.max_column+1)}
    print("Row 1 headers by column letter:")
    print(header_map)
    
    # print first 10 rows
    first_n = min(10, ws.max_row)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}: {vals}")
    
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"\nLast {ws.max_row - start_last + 1} rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        print(f"Row {r}: {vals}")
    
    # inspect referenced cells and nearby area for F/J
