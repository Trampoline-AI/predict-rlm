from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, math

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load and inspect target rows carefully before writing
wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

def is_whole_number(val):
    if val is None:
        return False
    if isinstance(val, bool):
        return False
    if isinstance(val, int):
        return True
    if isinstance(val, float):
        return math.isfinite(val) and val.is_integer()
    try:
        f = float(val)
        return math.isfinite(f) and f.is_integer()
    except Exception:
        return False

creamery_rows = []
matching_rows = []
for r in range(1, ws.max_row + 1):
    f_val = ws[f"F{r}"].value
    j_val = ws[f"J{r}"].value
    if f_val == "Marble Slab Creamery":
        creamery_rows.append((r, f_val, j_val, is_whole_number(j_val)))
        if is_whole_number(j_val):
            matching_rows.append(r)

print("All rows with F == 'Marble Slab Creamery':")
for item in creamery_rows:
    print(item)

print("Rows matching BOTH conditions:", matching_rows)

# Apply updates only where needed
changed_rows = []
for r in matching_rows:
    cell = ws[f"F{r}"]
    if cell.value != "Georgia State WH":
        cell.value = "Georgia State WH"
        changed_rows.append(r)

print("Changed rows:", changed_rows)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Re-open after recalc and restore original sheet names if needed
wb_after = load_workbook(outfile)
if wb_after.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    for i, orig_name in enumerate(original_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    print("Restored sheet names to:", wb_after.sheetnames)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verify using data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

print("Verification of changed rows (F and J):")
for r in matching_rows:
    print(f"Row {r}: F{r}={wsv[f'F{r}'].value!r}, J{r}={wsv[f'J{r}'].value!r}")

print("Verification of example cells:")
for ref in ["F10", "J10", "F13", "J13"]:
    print(ref, "=", wsv[ref].value)

# Extra sanity check: print all rows 1:max_row for F/J summary
print("Final F/J summary:")
for r in range(1, wsv.max_row + 1):
    print(r, wsv[f"F{r}"].value, wsv[f"J{r}"].value)
