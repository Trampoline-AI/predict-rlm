import os, json, math
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook path:", path)
print("Sheet names:", wb.sheetnames)

def sheet_nonempty_bounds(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    last_nonempty_row = 0
    last_nonempty_col = 0
    for r in range(1, max_row + 1):
        row_has = False
        for c in range(1, max_col + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                last_nonempty_col = max(last_nonempty_col, c)
        if row_has:
            last_nonempty_row = r
    return last_nonempty_row, last_nonempty_col

for sname in wb.sheetnames:
    ws = wb[sname]
    last_row, last_col = sheet_nonempty_bounds(ws)
    print("\n" + "="*80)
    print(f"Sheet: {sname}")
    print(f"ws.max_row={ws.max_row}, ws.max_column={ws.max_column}, last_nonempty_row={last_row}, last_nonempty_col={last_col}")
    
    # headers: first row values across used columns
    headers = [ws.cell(1, c).value for c in range(1, max(last_col, ws.max_column) + 1)]
    print("Row 1 / headers:", headers)
    
    # specific cells relevant to instruction
    print("A1:", ws["A1"].value, "B1:", ws["B1"].value, "C1:", ws["C1"].value)
    
    # sample first 10 rows
    first_n = min(last_row if last_row else ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, max(3, last_col) + 1)]
        print(f"Row {r}:", vals)
    
    # sample last 5 rows
    if last_row > 10:
        start = max(1, last_row - 4)
        print(f"Last rows {start}-{last_row}:")
        for r in range(start, last_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, max(3, last_col) + 1)]
            print(f"Row {r}:", vals)
    
    # inspect column B values and formulas in nearby cells
    print("Column B sample values:")
    for r in range(1, min(last_row, 10) + 1):
        print(f"B{r}={ws.cell(r,2).value!r}")
    if last_row > 10:
        for r in range(max(1, last_row - 4), last_row + 1):
            print(f"B{r}={ws.cell(r,2).value!r}")
