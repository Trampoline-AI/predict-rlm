    b=True,
    i=ws["P2"].font.i,
    color=ws["P2"].font.color.rgb if ws["P2"].font.color and hasattr(ws["P2"].font.color, "rgb") else None,
)
ws["P2"].alignment = Alignment(horizontal="center", vertical="top", wrap_text=ws["O2"].alignment.wrap_text)

# Data rows P3:P... : dynamic actual whole-years age
for r in range(3, last_data_row + 1):
    ws[f"P{r}"] = f'=IF(OR($B$1="",C{r}=""),"",YEAR($B$1)-YEAR(C{r})-IF(DATE(YEAR($B$1),MONTH(C{r}),DAY(C{r}))>$B$1,1,0))'
    ws[f"P{r}"].fill = copy(ws[f"O{r}"].fill)
