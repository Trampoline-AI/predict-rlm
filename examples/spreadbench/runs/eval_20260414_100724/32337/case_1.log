import zipfile, os, xml.etree.ElementTree as ET, re
from openpyxl import load_workbook

output_path = final_output_spreadsheet
print("Patching file:", output_path)

# First inspect workbook internals to identify worksheet xml
with zipfile.ZipFile(output_path, "r") as z:
    names = z.namelist()
    print("Worksheet files:", [n for n in names if n.startswith("xl/worksheets/")])
    sheet_xml_path = "xl/worksheets/sheet1.xml"
    xml_text = z.read(sheet_xml_path).decode("utf-8")
    for coord in ["E3", "E12", "P3", "P12"]:
        m = re.search(rf'<c[^>]*r="{coord}"[^>]*>.*?</c>', xml_text)
        print(f"\nCurrent XML for {coord}:")
        print(m.group(0) if m else "NOT FOUND")

# Cached values currently present in the workbook
wb_vals = load_workbook(output_path, data_only=True)
ws_vals = wb_vals["Sheet1"]
last_data_row = 15
e_cached = {r: ws_vals[f"E{r}"].value for r in range(3, last_data_row + 1)}
p_cached = {r: ws_vals[f"P{r}"].value for r in range(3, last_data_row + 1)}
print("Cached E values:", e_cached)
print("Cached P values:", p_cached)

# Patch XML directly to restore formulas plus cached values
NS = {"main": "http://schemas.openxmlformats.org/spreadsheetml/2006/main"}
ET.register_namespace("", NS["main"])

with zipfile.ZipFile(output_path, "r") as zin:
    files = {name: zin.read(name) for name in zin.namelist()}

root = ET.fromstring(files[sheet_xml_path])
sheetData = root.find("main:sheetData", NS)

# helper to find/create row and cell
def get_or_create_row(row_num):
    for row in sheetData.findall("main:row", NS):
        if int(row.attrib.get("r")) == row_num:
            return row
    row = ET.Element(f'{{{NS["main"]}}}row', {"r": str(row_num)})
    # insert in row order
    inserted = False
    rows = sheetData.findall("main:row", NS)
    for i, existing in enumerate(rows):
        if int(existing.attrib.get("r")) > row_num:
            sheetData.insert(i, row)
            inserted = True
            break
    if not inserted:
        sheetData.append(row)
    return row

def col_letters(coord):
    return re.match(r"([A-Z]+)(\d+)", coord).group(1)

def col_to_num(col):
    n = 0
    for ch in col:
        n = n * 26 + (ord(ch) - 64)
    return n

def get_or_create_cell(row_elem, coord):
    for c in row_elem.findall("main:c", NS):
        if c.attrib.get("r") == coord:
            return c
    cell = ET.Element(f'{{{NS["main"]}}}c', {"r": coord})
    target_col_num = col_to_num(col_letters(coord))
    inserted = False
    cells = row_elem.findall("main:c", NS)
    for i, existing in enumerate(cells):
        ex_col = col_to_num(col_letters(existing.attrib.get("r")))
        if ex_col > target_col_num:
            row_elem.insert(i, cell)
            inserted = True
            break
    if not inserted:
        row_elem.append(cell)
    return cell

def set_formula_cell(coord, formula_text, cached_value, style_from_existing=True):
    row_num = int(re.match(r"[A-Z]+(\d+)", coord).group(1))
    row_elem = get_or_create_row(row_num)
    cell = get_or_create_cell(row_elem, coord)

    # preserve style id if present
    style_id = cell.attrib.get("s")

    # clear children
    for child in list(cell):
        cell.remove(child)

    # set type
    if isinstance(cached_value, str):
        cell.attrib["t"] = "str"
    else:
        cell.attrib.pop("t", None)

    if style_id is not None:
        cell.attrib["s"] = style_id

    f = ET.SubElement(cell, f'{{{NS["main"]}}}f')
    f.text = formula_text.lstrip("=")

    v = ET.SubElement(cell, f'{{{NS["main"]}}}v')
    v.text = "" if cached_value is None else str(cached_value)

for r in range(3, last_data_row + 1):
    e_formula = f'IF(O{r}="","",IFERROR(VLOOKUP(O{r},$H$3:$I$11,2,TRUE),""))'
    p_formula = f'IF(OR($B$1="",C{r}=""),"",YEAR($B$1)-YEAR(C{r})-IF(DATE(YEAR($B$1),MONTH(C{r}),DAY(C{r}))>$B$1,1,0))'
    set_formula_cell(f"E{r}", e_formula, e_cached[r])
    set_formula_cell(f"P{r}", p_formula, p_cached[r])

# update dimension if needed
dimension = root.find("main:dimension", NS)
if dimension is not None:
    dimension.attrib["ref"] = "A1:P15"

patched_xml = ET.tostring(root, encoding="utf-8", xml_declaration=True)

with zipfile.ZipFile(output_path, "w", zipfile.ZIP_DEFLATED) as zout:
    for name, data in files.items():
        if name == sheet_xml_path:
            zout.writestr(name, patched_xml)
        else:
            zout.writestr(name, data)

print("Patched formulas back into sheet XML.")

# Verify formulas and cached values after patch
wb_formula = load_workbook(output_path, data_only=False)
wb_data = load_workbook(output_path, data_only=True)
wsf = wb_formula["Sheet1"]
wsd = wb_data["Sheet1"]

for r in [3,4,5,12,13,14,15]:
    print(
        r,
        "E_formula=", wsf[f"E{r}"].value,
        "E_value=", wsd[f"E{r}"].value,
        "P_formula=", wsf[f"P{r}"].value,
        "P_value=", wsd[f"P{r}"].value,
    )

print("Header P2:", wsf["P2"].value, "| data_only:", wsd["P2"].value)
print("Sheet names:", wb_formula.sheetnames)
```
