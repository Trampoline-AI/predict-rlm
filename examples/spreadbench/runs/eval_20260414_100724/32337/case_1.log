original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine last relevant data row from non-empty DOB values in column C
last_data_row = 2
for r in range(3, ws.max_row + 1):
    if ws[f"C{r}"].value not in (None, ""):
        last_data_row = r

# Determine lookup table bounds in H:I (rows with both H and I populated)
lookup_rows = []
for r in range(3, ws.max_row + 1):
    if ws[f"H{r}"].value not in (None, "") and ws[f"I{r}"].value not in (None, ""):
        lookup_rows.append(r)

lookup_start = min(lookup_rows)
lookup_end = max(lookup_rows)

print("Target sheet:", ws.title)
print("Target Expected Result range:", f"E3:E{last_data_row}")
print("Target Actual Age header/data range:", f"P2:P{last_data_row}")
print("Lookup range:", f"H{lookup_start}:I{lookup_end}")

# Print current values in exact target areas before modifying
print("Current E values before write:", [ws[f"E{r}"].value for r in range(3, last_data_row + 1)])
print("Current O formulas before write:", [ws[f"O{r}"].value for r in range(3, min(last_data_row, 8) + 1)])
print("Current P2 before write:", ws["P2"].value)

# Write formulas in Expected Result column E for all data rows
for r in range(3, last_data_row + 1):
    # Dynamic approximate lookup from rounded age in O into H:I
    ws[f"E{r}"] = f'=IF(O{r}="","",IFERROR(VLOOKUP(O{r},$H${lookup_start}:$I${lookup_end},2,TRUE),""))'

# Add Actual Age header in P2
ws["P2"] = "Actual Age"

# Copy style patterns from O to P row-by-row, then adjust requested formatting
for r in range(2, last_data_row + 1):
    src = ws[f"O{r}"]
    dst = ws[f"P{r}"]
    dst.fill = copy(src.fill)
    dst.border = copy(src.border)
    dst.protection = copy(src.protection)
    dst.number_format = copy(src.number_format)
    dst.font = copy(src.font)
    dst.alignment = copy(src.alignment)

# Header formatting for P2: bold, centered, top-aligned, matching fill from O2
