```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm the relevant region and target cells
print("Original sheet names:", original_sheetnames)
print("Relevant source rows A/I:")
for r in range(1, 8):
    print(r, ws[f"A{r}"].value, ws[f"I{r}"].value)

print("Current output area A11:A16 before writing:")
for r in range(11, 17):
    print(r, ws[f"A{r}"].value)

# Determine data rows: contiguous branch list from row 2 until blank in column A
data_start = 2
data_end = data_start - 1
r = data_start
while r <= ws.max_row and ws.cell(r, 1).value not in (None, ""):
    data_end = r
    r += 1

print("Detected branch data rows:", data_start, "to", data_end)

# Determine the tick marker from non-empty values in column I within data rows
tick_values = []
for r in range(data_start, data_end + 1):
    v = ws.cell(r, 9).value
    if v not in (None, "") and v not in tick_values:
        tick_values.append(v)
print("Distinct non-empty tick values in I:", tick_values)

tick_mark = tick_values[0] if tick_values else "ü"
print("Using tick mark:", repr(tick_mark))

# Exact target cells: output list under the existing label/header in A11:A12, starting A13
output_start_row = 13
output_end_row = output_start_row + (data_end - data_start)  # enough rows for all branches

print("Writing output formulas to:", [f"A{r}" for r in range(output_start_row, output_end_row + 1)])

# Helper column J (hidden)
ws["J1"] = 0
for r in range(data_start, data_end + 1):
    # Sequence only unchecked rows
    ws[f"J{r}"] = f'=IF($I{r}="{tick_mark}","",MAX($J$1:J{r-1})+1)'
ws.column_dimensions["J"].hidden = True

# Write formulas to list unchecked branches in A13 downward
for r in range(output_start_row, output_end_row + 1):
    formula = f'=IFERROR(INDEX($A${data_start}:$A${data_end},MATCH(ROWS($A${output_start_row}:A{r}),$J${data_start}:$J${data_end},0)),"")'
    ws[f"A{r}"] = formula

# Preserve labels above
ws["A11"] = ws["A11"].value or "Branches not checked"
ws["A12"] = ws["A12"].value or "branch"

print("Formulas written:")
for r in range(data_start, data_end + 1):
    print(f"J{r} =", ws[f'J{r}'].value)
for r in range(output_start_row, output_end_row + 1):
    print(f"A{r} =", ws[f'A{r}'].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# After recalc, sheet names may have changed; fix if needed
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # Rename positionally back to original names
    for i, name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = name
    wb_after.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("Verified output area A11:A18 after recalc (data_only):")
for r in range(11, 19):
    print(r, repr(wsv[f"A{r}"].value))

print("Verified helper values J1:J7 after recalc (data_only):")
for r in range(1, 8):
    print(r, repr(wsv[f"J{r}"].value))

# Also print the source A/I values for sanity
print("Source A/I values for sanity:")
for r in range(data_start, data_end + 1):
    print(r, repr(wsv[f"A{r}"].value), repr(wsv[f"I{r}"].value))

output_spreadsheet = outfile
```
