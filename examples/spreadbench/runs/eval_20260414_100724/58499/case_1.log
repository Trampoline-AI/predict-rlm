import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)

print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def cell_display(v):
    if v is None:
        return None
    return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find last non-empty row/col more robustly
    last_row = 0
    last_col = 0
    for row in ws.iter_rows():
        row_has = False
        for c in row:
            if c.value not in (None, ""):
                row_has = True
                last_col = max(last_col, c.column)
        if row_has:
            last_row = max(last_row, row[0].row)
    print(f"Detected last non-empty row={last_row}, last non-empty col={last_col} ({get_column_letter(last_col) if last_col else 'N/A'})")
    
    headers = [ws.cell(1, c).value for c in range(1, max(ws.max_column, last_col) + 1)]
    print("Row 1 headers:", headers)
    
    # Print first 10 rows
    first_n = min(last_row if last_row else ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, max(last_col, ws.max_column) + 1)]
        print(f"Row {r}: {vals}")
    
    # Print last 5 rows
    if last_row:
        start = max(1, last_row - 4)
        print(f"Last rows {start}:{last_row}:")
        for r in range(start, last_row + 1):
            vals = [ws.cell(r, c).value for c in range(1, max(last_col, ws.max_column) + 1)]
            print(f"Row {r}: {vals}")
    
    # Inspect columns A and I specifically
    print("Column A header:", ws["A1"].value)
    print("Column I header:", ws["I1"].value if ws.max_column >= 9 else None)
    
    sample_ai = []
    for r in range(1, min(last_row if last_row else ws.max_row, 15) + 1):
        sample_ai.append((r, ws.cell(r, 1).value, ws.cell(r, 9).value if ws.max_column >= 9 else None))
    print("Sample (row, A, I):", sample_ai)
    
    if last_row:
        tail_ai = []
        for r in range(max(1, last_row - 9), last_row + 1):
            tail_ai.append((r, ws.cell(r, 1).value, ws.cell(r, 9).value if ws.max_column >= 9 else None))
        print("Tail (row, A, I):", tail_ai)
    
    # Look for formulas in used range
    formulas = []
    for r in range(1, min(last_row if last_row else ws.max_row, 30) + 1):
        for c in range(1, max(last_col, ws.max_column) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((ws.cell(r,c).coordinate, v))
    print("Formulas in first 30 rows:", formulas[:20], f"(total found: {len(formulas)})")
    
