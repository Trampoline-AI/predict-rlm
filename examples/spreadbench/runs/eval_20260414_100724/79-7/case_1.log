import os, json, math, statistics
from collections import Counter, defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

workbook_summary = {}
quote_hits = defaultdict(list)

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 / headers:", headers)
    
    # Sample first 10 rows
    first_rows = []
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, ws.max_column)
        first_rows.append(vals)
    print("First rows:")
    for i, vals in enumerate(first_rows, start=1):
        print(f"  Row {i}: {vals}")
    
    # Sample last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(f"  Row {r}: {row_values(ws, r, ws.max_column)}")
    
    # Scan for cells containing double quotes
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and '"' in v:
                quote_hits[ws.title].append((r, c, v))
    
    workbook_summary[ws.title] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "headers": headers,
        "quote_count": len(quote_hits[ws.title]),
    }
    print(f'Cells containing double quotes: {len(quote_hits[ws.title])}')
    for hit in quote_hits[ws.title][:20]:
        r, c, v = hit
        print(f"  {get_column_letter(c)}{r}: {v!r}")

print("\nWorkbook summary:")
print(json.dumps(workbook_summary, indent=2, default=str))

total_quotes = sum(len(v) for v in quote_hits.values())
print("\nTotal cells with double quotes in workbook:", total_quotes)
```
