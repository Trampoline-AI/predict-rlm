```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Reload original workbook for editing
wb_edit = load_workbook(input_path)
original_sheet_names = wb_edit.sheetnames[:]

# Track changes
changes = []
for ws in wb_edit.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and '"' in v:
                new_v = v.replace('"', "")
                changes.append((ws.title, cell.coordinate, v, new_v))
                cell.value = new_v

print("Planned changes:")
for item in changes:
    print(item)

wb_edit.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas/caches
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and ensure sheet names preserved
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)

if wb_post.sheetnames != original_sheet_names:
    # Rename sheets back by position
    for idx, expected_name in enumerate(original_sheet_names):
        wb_post.worksheets[idx].title = expected_name
    wb_post.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

for ws in wb_verify.worksheets:
    print(f"Verification for sheet: {ws.title}")
    for coord in ["A1", "A2", "A3", "A4"]:
        print(coord, "->", ws[coord].value)

# Additional scan to ensure no double quotes remain
remaining_quotes = []
for ws in wb_verify.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and '"' in cell.value:
                remaining_quotes.append((ws.title, cell.coordinate, cell.value))

print("Remaining cells with double quotes:", remaining_quotes)

final_output_path = output_path
```
