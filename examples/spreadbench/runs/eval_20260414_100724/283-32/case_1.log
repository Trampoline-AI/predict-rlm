        vals = []
        for c in range(1, min(last_col if last_col else ws.max_column, 12) + 1):
            vals.append(f"{get_column_letter(c)}{r}={ws.cell(r,c).value!r}")
        print("Row", r, ":", vals)
    
    # infer header row candidates (1 and 2)
    for hdr_row in [1, 2]:
