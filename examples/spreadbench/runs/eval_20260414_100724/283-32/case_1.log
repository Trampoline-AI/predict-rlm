for r, vals in rows1:
    print(r, vals)

print("\nSheet2 data rows (row_number -> values):")
for r, vals in rows2:
    print(r, vals)

vals1 = [vals for _, vals in rows1]
vals2 = [vals for _, vals in rows2]

c1 = Counter(vals1)
c2 = Counter(vals2)

subtracts = list((c1 - c2).elements())  # present in sheet1 not in sheet2
adds = list((c2 - c1).elements())       # present in sheet2 not in sheet1

print("\nExact full-row multiset differences:")
print("Subtracts (Sheet1 not in Sheet2):", len(subtracts))
for i, row in enumerate(subtracts, 1):
