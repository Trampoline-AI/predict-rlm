import os
from collections import Counter
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
ws3 = wb["Sheet3"]
ws4 = wb["Sheet4"]

def get_data_values(ws, start_row=9, end_col=7):
    vals = []
    for r in range(start_row, ws.max_row + 1):
        row = tuple(ws.cell(r, c).value for c in range(1, end_col + 1))
        if any(v is not None for v in row):
            vals.append(row)
    return vals

vals1 = get_data_values(ws1)
vals2 = get_data_values(ws2)

c1 = Counter(vals1)
c2 = Counter(vals2)

subtracts = list((c1 - c2).elements())   # in Sheet1 but not in Sheet2
adds = list((c2 - c1).elements())        # in Sheet2 but not in Sheet1

print("Exact subtract rows:", len(subtracts))
for row in subtracts:
    print("Sheet3 row to write:", row)

print("Exact add rows:", len(adds))
for row in adds:
    print("Sheet4 row to write:", row)

# Clear existing content in Sheet3/Sheet4 across used area A:G
for ws in (ws3, ws4):
    maxr = max(ws.max_row, 1)
    for r in range(1, maxr + 1):
        for c in range(1, 8):
            ws.cell(r, c).value = None

# Write outputs starting at row 1, no headers
for out_r, row in enumerate(subtracts, start=1):
    for c, v in enumerate(row, start=1):
        ws3.cell(out_r, c).value = v

for out_r, row in enumerate(adds, start=1):
    for c, v in enumerate(row, start=1):
        ws4.cell(out_r, c).value = v

wb.save(outfile)
print("Saved to:", outfile)

# recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for ws, orig_name in zip(wb_check.worksheets, orig_sheetnames):
        ws.title = orig_name
    wb_check.save(outfile)
    print("Restored original sheet names:", orig_sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

for sname in ["Sheet3", "Sheet4"]:
    ws = wb_verify[sname]
    print(f"\nVerification for {sname}: max_row={ws.max_row}, max_col={ws.max_column}")
    # print first 5 rows A:G
    for r in range(1, 6):
        vals = [ws.cell(r, c).value for c in range(1, 8)]
        print(sname, "row", r, vals)

# store output path for submit
final_output_spreadsheet = outfile
