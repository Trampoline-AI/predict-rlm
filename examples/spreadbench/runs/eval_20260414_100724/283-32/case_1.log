from collections import Counter
from datetime import datetime

wb = load_workbook(input_spreadsheet)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

def get_data_rows(ws, start_row=9, end_col=7):
    rows = []
    for r in range(start_row, ws.max_row + 1):
        vals = tuple(ws.cell(r, c).value for c in range(1, end_col + 1))
        # include only rows with at least one non-empty cell
        if any(v is not None for v in vals):
            rows.append((r, vals))
    return rows

rows1 = get_data_rows(ws1)
rows2 = get_data_rows(ws2)

print("Data row counts:")
print("Sheet1:", len(rows1), "Sheet2:", len(rows2))

# Show all rows with indices for both sheets to allow spot-checking
