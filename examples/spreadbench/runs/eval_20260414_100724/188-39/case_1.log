import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

sheet_summaries = {}

for s in wb.sheetnames:
    ws = wb[s]
    print("\n" + "="*80)
    print(f"Sheet: {s}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # Find non-empty rows/cols rough
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row range:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    
    # Print first 10 rows, limited columns
    max_cols_to_show = min(ws.max_column, 12)
    print(f"First up to 10 rows (first {max_cols_to_show} cols):")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(r, row_values(ws, r, max_cols_to_show))
    
    print(f"Last up to 5 rows (first {max_cols_to_show} cols):")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, max_cols_to_show))
    
    # Candidate header rows among first 5 rows: choose one with most text entries
    candidate_info = []
    for r in range(1, min(6, ws.max_row + 1)):
        vals = row_values(ws, r, ws.max_column)
        textish = sum(1 for v in vals if isinstance(v, str) and v.strip() != "")
        nonempty = sum(1 for v in vals if v not in (None, ""))
        candidate_info.append((r, textish, nonempty, vals[:12]))
    print("Candidate header rows (row, text_count, nonempty_count, first12):")
    for item in candidate_info:
        print(item)
    
    # Print formulas in first 15 rows
    formula_cells = []
    for r in range(1, min(ws.max_row, 15) + 1):
        for c in range(1, min(ws.max_column, 15) + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells in first 15x15:", formula_cells[:20], "count=", len(formula_cells))
    
    sheet_summaries[s] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "first_rows": [row_values(ws, r, max_cols_to_show) for r in range(1, min(ws.max_row, 10)+1)],
    }

print("\nDone inspection.")
