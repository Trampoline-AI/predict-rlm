import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Alignment

# Reload clean workbook from input
infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]

wsm = wb["main sheet"]
wsr = wb["result"]

# Read source headers and build location -> source row mapping
src_headers = [wsm.cell(1, c).value for c in range(1, wsm.max_column + 1)]
header_idx = {h: i + 1 for i, h in enumerate(src_headers)}

print("Source headers:", src_headers)
print("Result headers:", [wsr.cell(1, c).value for c in range(1, wsr.max_column + 1)])
print("Writing to columns B:D on sheet 'result' for rows with non-empty location in column A.")

allowed_designations = {"Branch Manager", "Branch Credit Manager"}

source_by_location = {}
for r in range(2, wsm.max_row + 1):
    loc = wsm.cell(r, header_idx["Location"]).value
    if loc not in (None, ""):
        source_by_location[str(loc).strip()] = {
            "name": wsm.cell(r, header_idx["Name of employee"]).value,
            "contact": wsm.cell(r, header_idx["Contact no"]).value,
            "mail": wsm.cell(r, header_idx["Mail id"]).value,
            "designation": wsm.cell(r, header_idx["Designation"]).value,
            "row": r,
        }

# Print current target cells before modification
print("\nBefore writing, current result!B2:D12:")
for r in range(2, wsr.max_row + 1):
    if wsr.cell(r, 1).value not in (None, ""):
        print(f"Row {r}, location={wsr.cell(r,1).value!r}, values={ [wsr.cell(r,c).value for c in range(2,5)] }")

# Write outputs
rows_written = []
for r in range(2, wsr.max_row + 1):
    location = wsr.cell(r, 1).value
    if location in (None, ""):
        continue
    
    key = str(location).strip()
    src = source_by_location.get(key)

    if src and src["designation"] in allowed_designations:
        b_val = "" if src["name"] is None else str(src["name"]).strip()
        c_raw = src["contact"]
        c_val = "" if c_raw is None else str(c_raw).strip()
        d_val = "" if src["mail"] is None else str(src["mail"]).strip()
    else:
        b_val = "N/A"
        c_val = "N/A"
        d_val = "N/A"

    for col, val in [(2, b_val), (3, c_val), (4, d_val)]:
        cell = wsr.cell(r, col)
        cell.value = val
        new_alignment = copy(cell.alignment)
        new_alignment.horizontal = "left"
        cell.alignment = new_alignment

    rows_written.append((r, key, b_val, c_val, d_val))

print("\nRows written:")
for item in rows_written:
    print(item)

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalc changed them
wb_check = load_workbook(outfile)
current_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != original_sheet_names:
    print("Sheet names changed after recalc; restoring original names.")
    for i, expected_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = expected_name
    wb_check.save(outfile)
    print("Restored sheet names:", load_workbook(outfile).sheetnames)

# Verification reloads
wb_vals = load_workbook(outfile, data_only=True)
wb_fmt = load_workbook(outfile, data_only=False)

print("\nVerification of target range result!B2:D12:")
ws_vals = wb_vals["result"]
ws_fmt = wb_fmt["result"]

for r in range(2, ws_vals.max_row + 1):
    if ws_vals.cell(r, 1).value in (None, ""):
        continue
    vals = [ws_vals.cell(r, c).value for c in range(2, 5)]
    aligns = [ws_fmt.cell(r, c).alignment.horizontal for c in range(2, 5)]
    print(f"Row {r} loc={ws_vals.cell(r,1).value!r} -> {vals} | align={aligns}")

# Sanity checks
issues = []
for r in range(2, ws_vals.max_row + 1):
    if ws_vals.cell(r, 1).value in (None, ""):
        continue
    for c in range(2, 5):
        v = ws_vals.cell(r, c).value
        if v in (None, ""):
            issues.append(f"Blank target cell {ws_vals.cell(r,c).coordinate}")
        if ws_fmt.cell(r, c).alignment.horizontal != "left":
            issues.append(f"Not left-aligned: {ws_fmt.cell(r,c).coordinate}")

print("\nSanity issues:", issues if issues else "None")

output_spreadsheet = outfile
print("\nPrepared output file:", output_spreadsheet)
