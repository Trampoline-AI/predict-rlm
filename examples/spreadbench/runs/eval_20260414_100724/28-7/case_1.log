import os, re, shutil
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Load workbook again for final inspection + modification
wb = load_workbook(input_spreadsheet)
print("Original sheet names:", wb.sheetnames)

pattern_400 = re.compile(r"^400-.*$", re.IGNORECASE)
pattern_400_a = re.compile(r"^400-.*-A$", re.IGNORECASE)

# Inspect relevant area carefully
for ws in wb.worksheets:
    print(f"\nInspecting sheet: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    print("Relevant cells in column A and row samples:")
    for r in range(1, ws.max_row + 1):
        a = ws.cell(r, 1).value
        b = ws.cell(r, 2).value
        c = ws.cell(r, 3).value
        e = ws.cell(r, 5).value
        if r <= 10 or r >= ws.max_row - 4 or (isinstance(a, str) and pattern_400.match(a.strip())) or e is not None:
            print(f"R{r}: A={a!r}, B={b!r}, C={c!r}, E={e!r}")

# Identify deletion ranges in column A
deletion_plan = []
for ws in wb.worksheets:
    matches = []
    for r in range(1, ws.max_row + 1):
        val = ws.cell(r, 1).value
        s = val.strip() if isinstance(val, str) else None
        if s and pattern_400.match(s):
            matches.append((r, s))
    print(f"\n400-pattern rows on {ws.title}: {matches}")

    for idx, (r, s) in enumerate(matches):
        if pattern_400_a.match(s):
            next_match_row = matches[idx + 1][0] if idx + 1 < len(matches) else None
            if next_match_row is not None and next_match_row > r:
                deletion_plan.append((ws.title, r, next_match_row - 1, s, matches[idx + 1][1]))
            else:
                # As instructed: if no following 400- part exists, do not delete
                print(f"No following 400- row after {ws.title}!A{r}={s}; no deletion for this marker.")

print("\nDeletion plan:")
for item in deletion_plan:
    print(item)

# Save copy to output path first
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
shutil.copy2(input_spreadsheet, output_path)

# Apply deletions on output workbook, deleting from bottom upward per sheet
out_wb = load_workbook(output_path)
original_sheet_names = out_wb.sheetnames[:]

for ws in out_wb.worksheets:
    sheet_ranges = [(start, end) for title, start, end, start_val, next_val in deletion_plan if title == ws.title]
    for start, end in sorted(sheet_ranges, reverse=True):
        count = end - start + 1
        print(f"Deleting rows {start}:{end} ({count} rows) on sheet {ws.title}")
        ws.delete_rows(start, count)

out_wb.save(output_path)
print("Saved modified workbook to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculation changed them
post_wb = load_workbook(output_path)
if post_wb.sheetnames != original_sheet_names:
    print("Sheet names changed after recalculation:", post_wb.sheetnames, "-> restoring", original_sheet_names)
    # rename by position, preserving count
    if len(post_wb.sheetnames) == len(original_sheet_names):
        for i, desired in enumerate(original_sheet_names):
            post_wb.worksheets[i].title = desired
        post_wb.save(output_path)
    else:
        print("Warning: sheet count changed unexpectedly; not expected here.")
else:
    print("Sheet names preserved after recalculation.")

# Verification: reload values and print target area
verify_wb = load_workbook(output_path, data_only=True)
print("\nVerification sheet names:", verify_wb.sheetnames)

for ws in verify_wb.worksheets:
    print(f"\nVerified sheet: {ws.title}, rows={ws.max_row}, cols={ws.max_column}")
    # Print all rows because small sheet
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 5) + 1)]
        print(f"R{r}: {vals}")

    remaining_400 = []
    for r in range(1, ws.max_row + 1):
        val = ws.cell(r, 1).value
        if isinstance(val, str) and pattern_400.match(val.strip()):
            remaining_400.append((r, val.strip()))
    print("Remaining 400-pattern rows:", remaining_400)

final_output_path = output_path
