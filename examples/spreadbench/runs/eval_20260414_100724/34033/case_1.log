original_sheetnames = wb.sheetnames[:]
filename = os.path.basename(input_path)

print("Workbook:", input_path)
print("Sheets:", original_sheetnames)

def row_values(ws, r, max_c=None):
    if max_c is None:
        max_c = ws.max_column
    vals = []
    for c in range(1, max_c + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

def nonempty_extent(ws):
    min_r = None
    max_r = 0
    min_c = None
    max_c = 0
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                if min_r is None or cell.row < min_r:
                    min_r = cell.row
                if min_c is None or cell.column < min_c:
                    min_c = cell.column
                max_r = max(max_r, cell.row)
                max_c = max(max_c, cell.column)
    return min_r, max_r, min_c, max_c

inspection = {}

for ws in wb.worksheets:
    min_r, max_r, min_c, max_c = nonempty_extent(ws)
    inspection[ws.title] = {"min_r": min_r, "max_r": max_r, "min_c": min_c, "max_c": max_c}
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"ws.max_row={ws.max_row}, ws.max_column={ws.max_column}, nonempty extent rows {min_r}-{max_r}, cols {min_c}-{max_c}")
    if ws.merged_cells.ranges:
        print("Merged ranges:", [str(x) for x in list(ws.merged_cells.ranges)[:10]])
    else:
        print("Merged ranges: none")
    
    # Print top 15 rows x first up to 12 cols to capture notes/header layout
    preview_cols = min(max(ws.max_column, 1), 12)
    print(f"Top preview rows 1-15, cols 1-{preview_cols}:")
    for r in range(1, min(ws.max_row, 15) + 1):
        vals = row_values(ws, r, preview_cols)
        print(f"R{r}: {vals}")
    
    # Guess headers from first 5 rows by choosing row with most text/non-empty
    candidate_rows = []
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = row_values(ws, r, preview_cols)
        nonempty = sum(v is not None and v != "" for v in vals)
        textish = sum(isinstance(v, str) for v in vals if v not in (None, ""))
        candidate_rows.append((r, nonempty, textish, vals))
    candidate_rows_sorted = sorted(candidate_rows, key=lambda x: (x[1], x[2]), reverse=True)
    if candidate_rows_sorted:
        hdr_r = candidate_rows_sorted[0][0]
        print(f"Likely header row candidate: {hdr_r} -> {candidate_rows_sorted[0][3]}")
    
    # first 10 and last 5 rows within nonempty extent
    if min_r is not None:
        print("Sample first rows in nonempty extent:")
        for r in range(min_r, min(max_r, min_r + 9) + 1):
            vals = row_values(ws, r, min(max_c, 12))
            print(f"R{r}: {vals}")
        print("Sample last rows in nonempty extent:")
        start_last = max(min_r, max_r - 4)
        for r in range(start_last, max_r + 1):
            vals = row_values(ws, r, min(max_c, 12))
            print(f"R{r}: {vals}")
    
    # Formula cells
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str) and v.startswith("="):
                formula_cells.append((cell.coordinate, v))
    print(f"Formula cells count: {len(formula_cells)}")
    if formula_cells:
        print("First up to 15 formulas:")
        for coord, formula in formula_cells[:15]:
            print(coord, "=>", formula)
    
    # Comments
    comments = []
    for row in ws.iter_rows():
        for cell in row:
            if cell.comment is not None:
                comments.append((cell.coordinate, cell.comment.text[:200]))
    print(f"Comments count: {len(comments)}")
    for coord, text in comments[:10]:
        print(f"Comment {coord}: {text}")
