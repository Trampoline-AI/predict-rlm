Code:
```repl
import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
print("Original sheet names:", original_sheetnames)

sh1 = wb["SH1"]
rp1 = wb["RP1"]
merging = wb["merging"]


def normalize_id(v):
    if v is None:
        return None
    s = str(v).strip()
    return s if s else None


def build_qty_map(ws):
    m = {}
    for r in range(2, ws.max_row + 1):
        item_id = normalize_id(ws.cell(r, 2).value)
        qty = ws.cell(r, 3).value
        if item_id is not None:
            m[item_id] = qty
    return m


sh1_map = build_qty_map(sh1)
rp1_map = build_qty_map(rp1)
print("SH1 ID->QTY:", sh1_map)
print("RP1 ID->QTY:", rp1_map)

print("\nTarget area before writing (merging!A1:D11 or used rows):")
for r in range(1, merging.max_row + 1):
    vals = [merging.cell(r, c).value for c in range(1, 5)]
    print(r, vals)

# Write formulas into columns C and D for all relevant rows.
# Use COUNTIF+VLOOKUP so missing IDs return '-' and blanks also return '-'.
for r in range(2, merging.max_row + 1):
    id_val = normalize_id(merging.cell(r, 2).value)
    if id_val is None:
        continue
    formula_c = (
        f'=IF(COUNTIF(SH1!$B$2:$B${sh1.max_row},$B{r})=0,"-",'
        f'IF(VLOOKUP($B{r},SH1!$B$2:$C${sh1.max_row},2,0)="","-",'
        f'VLOOKUP($B{r},SH1!$B$2:$C${sh1.max_row},2,0)))'
    )
    formula_d = (
        f'=IF(COUNTIF(RP1!$B$2:$B${rp1.max_row},$B{r})=0,"-",'
        f'IF(VLOOKUP($B{r},RP1!$B$2:$C${rp1.max_row},2,0)="","-",'
        f'VLOOKUP($B{r},RP1!$B$2:$C${rp1.max_row},2,0)))'
    )
    merging.cell(r, 3).value = formula_c
    merging.cell(r, 4).value = formula_d

print("\nFormulas written to target cells:")
for r in range(2, merging.max_row + 1):
    if normalize_id(merging.cell(r, 2).value) is None:
        continue
    print(f"Row {r} ID={merging.cell(r,2).value!r} | C{r}={merging.cell(r,3).value} | D{r}={merging.cell(r,4).value}")

wb.save(output_path)
print("\nSaved formula version to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open and restore sheet names if LibreOffice changed them.
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for i, expected_name in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = expected_name
    wb_post.save(output_path)
    print("Renamed sheets back to original names:", original_sheetnames)
else:
    print("No sheet rename needed.")

# Verify calculated values.
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
merge_formula = wb_formula["merging"]
merge_values = wb_values["merging"]

print("\nVerification of target cells after recalc:")
issues = []
for r in range(2, merge_values.max_row + 1):
    item_id = normalize_id(merge_values.cell(r, 2).value)
    if item_id is None:
        continue
    expected_c = sh1_map.get(item_id, "-")
    expected_d = rp1_map.get(item_id, "-")
    if expected_c in (None, ""):
        expected_c = "-"
    if expected_d in (None, ""):
        expected_d = "-"

    formula_c = merge_formula.cell(r, 3).value
    formula_d = merge_formula.cell(r, 4).value
    value_c = merge_values.cell(r, 3).value
    value_d = merge_values.cell(r, 4).value
    print(
        f"Row {r} ID={item_id!r}: "
        f"C{r} formula={formula_c!r}, value={value_c!r}, expected={expected_c!r}; "
        f"D{r} formula={formula_d!r}, value={value_d!r}, expected={expected_d!r}"
    )

    bad_c = value_c is None or (isinstance(value_c, str) and (value_c.strip() == "" or value_c.startswith("#")))
    bad_d = value_d is None or (isinstance(value_d, str) and (value_d.strip() == "" or value_d.startswith("#")))
    if bad_c or bad_d:
        issues.append(r)

# Fallback: if any formula results failed, write literal values.
if issues:
    print("\nFormula verification found issues in rows:", issues)
    print("Falling back to static values in the same target cells.")
    wb_fix = load_workbook(output_path)
    mfix = wb_fix["merging"]
    for r in range(2, mfix.max_row + 1):
        item_id = normalize_id(mfix.cell(r, 2).value)
        if item_id is None:
            continue
        val_c = sh1_map.get(item_id, "-")
        val_d = rp1_map.get(item_id, "-")
        if val_c in (None, ""):
            val_c = "-"
        if val_d in (None, ""):
            val_d = "-"
        mfix.cell(r, 3).value = val_c
        mfix.cell(r, 4).value = val_d
    wb_fix.save(output_path)
    print("Saved fallback static-value version.")

    recalc_result2 = await recalculate(output_path)
    print("Recalculate after fallback:", recalc_result2)

    wb_post2 = load_workbook(output_path)
    if wb_post2.sheetnames != original_sheetnames and len(wb_post2.sheetnames) == len(original_sheetnames):
        for i, expected_name in enumerate(original_sheetnames):
            wb_post2.worksheets[i].title = expected_name
        wb_post2.save(output_path)
        print("Renamed sheets back again after fallback.")

    wb_values = load_workbook(output_path, data_only=True)
    merge_values = wb_values["merging"]

print("\nFinal target range values (merging!C:D):")
for r in range(1, merge_values.max_row + 1):
    print(f"Row {r}: B={merge_values.cell(r,2).value!r}, C={merge_values.cell(r,3).value!r}, D={merge_values.cell(r,4).value!r}")

print("\nOutput file ready:", output_path)
