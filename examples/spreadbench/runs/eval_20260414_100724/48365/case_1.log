```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws_dash = wb["Dashboard"]
ws_data = wb["Data"]

# Determine actual data extent
last_data_row = 0
for r in range(ws_data.max_row, 0, -1):
    if any(ws_data.cell(r, c).value is not None for c in range(1, ws_data.max_column + 1)):
        last_data_row = r
        break

print("Original sheet names:", orig_sheetnames)
print("Target cell before write:", "Dashboard!C4 =", ws_dash["C4"].value)
print("Data range rows:", 2, "to", last_data_row)

# Build a LibreOffice-friendly formula for up to 3 region selections with All support.
# Product in C2; selections in C11:C13; amounts in Data!C; region in Data!B.
formula = (
    f'=IF(COUNTIF($C$11:$C$13,"All")>0,'
    f'SUMIF(Data!$A$2:$A${last_data_row},$C$2,Data!$C$2:$C${last_data_row}),'
    f'SUMIFS(Data!$C$2:$C${last_data_row},Data!$A$2:$A${last_data_row},$C$2,Data!$B$2:$B${last_data_row},$C$11)'
    f'+IF(OR($C$12="",$C$12=$C$11),0,SUMIFS(Data!$C$2:$C${last_data_row},Data!$A$2:$A${last_data_row},$C$2,Data!$B$2:$B${last_data_row},$C$12))'
    f'+IF(OR($C$13="",$C$13=$C$11,$C$13=$C$12),0,SUMIFS(Data!$C$2:$C${last_data_row},Data!$A$2:$A${last_data_row},$C$2,Data!$B$2:$B${last_data_row},$C$13))'
    f')'
)

ws_dash["C4"] = formula
print("Written formula to Dashboard!C4:")
print(ws_dash["C4"].value)

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames)
    # rename by position back to originals
    for i, target_name in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = target_name
    wb_check.save(outfile)
    print("Restored sheet names to:", wb_check.sheetnames)
else:
    print("Sheet names unchanged after recalc.")

# Verify with formula view and data_only view
wb_formula = load_workbook(outfile, data_only=False)
wb_value = load_workbook(outfile, data_only=True)

print("Final sheet names:", wb_formula.sheetnames)

f_ws = wb_formula["Dashboard"]
v_ws = wb_value["Dashboard"]

print("Verify target cells/range:")
for coord in ["C2", "C3", "C11", "C12", "C13", "C4"]:
    print(
        coord,
        "formula_view=", f_ws[coord].value,
        "data_view=", v_ws[coord].value
    )

# Sanity-check expected value in Python for current selections
product = f_ws["C2"].value
selected_regions = [f_ws[c].value for c in ["C11", "C12", "C13"] if f_ws[c].value not in (None, "")]
all_selected = "All" in selected_regions

py_total = 0
seen_regions = set()
for r in range(2, last_data_row + 1):
    prod = wb_formula["Data"].cell(r, 1).value
    region = wb_formula["Data"].cell(r, 2).value
    amt = wb_formula["Data"].cell(r, 3).value
    if prod != product:
        continue
    if all_selected:
        py_total += amt or 0
    else:
        if region in selected_regions:
            py_total += amt or 0

print("Current selections:", selected_regions)
print("Python expected total:", py_total)
print("Recalculated Dashboard!C4 value:", v_ws["C4"].value)
```
