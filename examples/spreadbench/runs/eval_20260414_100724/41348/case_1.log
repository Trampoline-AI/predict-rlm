```repl
from openpyxl import load_workbook
from collections import defaultdict
import os
from shutil import copyfile

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook fresh
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Working on sheet:", ws.title, "max_row:", ws.max_row, "max_col:", ws.max_column)
print("Target header Q1:", ws["Q1"].value)

# Determine actual data rows (exclude fully blank rows; header is row 1)
data_rows = []
for r in range(2, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 17)):  # A:P contain source data
        data_rows.append(r)

print("Data rows detected:", data_rows)

# Print current target cells before modification
print("\nBefore modification (rows 2:max_row, H/I/J/L/P/Q):")
for r in data_rows:
    print(
        r,
        {
            "H_ProjectID": ws.cell(r, 8).value,
            "I_Linked": ws.cell(r, 9).value,
            "J_BudgetID": ws.cell(r, 10).value,
            "L_BudgetType": ws.cell(r, 12).value,
            "P_TechRevenue": ws.cell(r, 16).value,
            "Q_Current": ws.cell(r, 17).value,
        }
    )

# Group rows by project ID (column H) for rows linked to budget
project_rows = defaultdict(list)
for r in data_rows:
    project_id = ws.cell(r, 8).value   # H
    linked = ws.cell(r, 9).value       # I
    if str(linked).strip().upper() == "Y" and project_id not in (None, ""):
        project_rows[project_id].append(r)

# Determine whether each project includes technology
project_has_tech = {}
for project_id, rows in project_rows.items():
    has_tech = False
    for r in rows:
        budget_type = ws.cell(r, 12).value  # L
        tech_revenue = ws.cell(r, 16).value # P
        bt = str(budget_type).strip().lower() if budget_type is not None else ""
        try:
            tech_rev_num = float(tech_revenue) if tech_revenue not in (None, "") else 0.0
        except Exception:
            tech_rev_num = 0.0
        if bt == "technology" or tech_rev_num > 0:
            has_tech = True
            break
    project_has_tech[project_id] = has_tech

print("\nComputed project_has_tech mapping:")
for k, v in project_has_tech.items():
    print(k, "=>", v)

# Write Q values
written = []
for r in data_rows:
    linked = ws.cell(r, 9).value
    project_id = ws.cell(r, 8).value
    if str(linked).strip().upper() != "Y" or project_id in (None, ""):
        new_val = "N"
    else:
        new_val = "Y" if project_has_tech.get(project_id, False) else "N"
    ws.cell(r, 17).value = new_val
    written.append((r, new_val))

print("\nWritten Q values:")
print(written)

# Save
wb.save(output_path)
print("\nSaved to:", output_path, "exists:", os.path.exists(output_path))

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(output_path)
current_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != original_sheet_names and len(current_names) == len(original_sheet_names):
    for idx, old_name in enumerate(original_sheet_names):
        wb_check.worksheets[idx].title = old_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify output with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

print("\nVerification of target cells Q2:Q{}".format(ws.max_row))
verification_rows = []
for r in data_rows:
    verification_rows.append(
        (
            r,
            wsv.cell(r, 8).value,   # H
            wsv.cell(r, 9).value,   # I
            wsv.cell(r, 12).value,  # L
            wsv.cell(r, 17).value,  # Q
        )
    )
for item in verification_rows:
    print(item)

# Sanity checks
blanks = [r for r in data_rows if wsv.cell(r, 17).value in (None, "")]
print("Blank Q rows after verification:", blanks)

final_output_path = output_path
print("Final output path ready:", final_output_path)
```
