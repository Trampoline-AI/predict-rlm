orig_sheet_names = wb.sheetnames
print("\nSheet names:", orig_sheet_names)

def cell_display(v):
    try:
        if v is None:
            return None
        return str(v)
    except Exception as e:
        return f"<unprintable {type(v).__name__}: {e}>"

sheet_summaries = {}
for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    sheet_summaries[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers": headers,
    }
    print(f"\n=== Sheet: {ws.title} ===")
    print(f"Rows: {max_row}, Cols: {max_col}")
    print("Headers row 1:")
    for c in range(1, max_col + 1):
        print(f"  {get_column_letter(c)}: {cell_display(ws.cell(1, c).value)}")
    
    # first 10 rows
    first_n = min(max_row, 10)
    print(f"\nFirst {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [cell_display(ws.cell(r, c).value) for c in range(1, max_col + 1)]
        print(f"Row {r}: {row_vals}")
    
    # last 5 rows
    start_last = max(1, max_row - 4)
    print(f"\nLast rows {start_last} to {max_row}:")
    for r in range(start_last, max_row + 1):
        row_vals = [cell_display(ws.cell(r, c).value) for c in range(1, max_col + 1)]
        print(f"Row {r}: {row_vals}")
    
    # inspect H/L/Q specifically if present
    inspect_cols = [8, 12, 17]
    if max_col >= max(inspect_cols):
        print("\nSpecific columns H, L, Q around first 15 rows:")
        for r in range(1, min(max_row, 15) + 1):
            vals = {}
            for c in inspect_cols:
                cell = ws.cell(r, c)
                vals[f"{get_column_letter(c)}{r}"] = cell_display(cell.value)
            print(vals)
        
        print("\nSpecific columns H, L, Q in last 10 rows:")
        for r in range(max(1, max_row - 9), max_row + 1):
            vals = {}
            for c in inspect_cols:
                cell = ws.cell(r, c)
                vals[f"{get_column_letter(c)}{r}"] = cell_display(cell.value)
