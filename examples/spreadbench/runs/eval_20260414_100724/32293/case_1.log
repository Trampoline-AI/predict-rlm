from openpyxl import load_workbook
import os

# Load workbook normally to write formulas
wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Print current target area including any pre-existing formulas/values
print("Before writing:")
for coord in ["A14","A15","A16","A17","B14","B15","B16","B17"]:
    print(coord, repr(ws[coord].value))

# Write INDEX/MATCH formulas into the exact target cells B14:B17
# This uses the existing lookup table in A1:B4 and each row's own key in column A.
for r in range(14, 18):
    ws[f"B{r}"] = f'=INDEX($B$1:$B$4,MATCH(A{r},$A$1:$A$4,0))'

print("\nAfter writing formulas:")
for r in range(14, 18):
    print(f"B{r}", ws[f"B{r}"].value)

# Save to output with same filename
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc to ensure sheet names still match original
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names:
    # restore original sheet names by position
    for i, old_name in enumerate(original_sheet_names):
        wb_post.worksheets[i].title = old_name
    wb_post.save(output_path)
    print("Restored sheet names:", load_workbook(output_path).sheetnames)

# Verify formulas remain and cached results are present
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
print("\nStored formulas in B14:B17:")
for r in range(14, 18):
    print(f"B{r} formula:", ws_formula[f'B{r}'].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]
print("\nVerified values in target cells:")
for r in range(14, 18):
    print(f"A{r}={ws_values[f'A{r}'].value!r}, B{r}={ws_values[f'B{r}'].value!r}")

# Keep path for submission
final_output_spreadsheet = output_path
