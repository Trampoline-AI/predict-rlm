Plan:
1. Modify the existing values in place on `Sheet1` only.
2. Treat residual balancing as:
   - `residual < 0` → add `abs(residual)` across unit1→unit5
   - `residual > 0` → subtract `residual` across unit5→unit1
3. Never change unit cells that are `0`.
4. Respect bounds during the operation:
   - additions cannot exceed row 21 max
   - subtractions cannot go below row 20 min
5. Set column `I` to `0` for the processed data rows.
6. Save to the output directory, recalculate, reload, verify the target cells/ranges, and print the results.
Code:
```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Exact target ranges identified from inspection
unit_cols = list(range(2, 7))   # B:F
residual_col = 9                # I
min_row = 20
max_row_constraints = 21
data_rows = [r for r in range(2, ws.max_row + 1) if ws.cell(r, residual_col).value is not None]

mins = [ws.cell(min_row, c).value for c in unit_cols]
maxs = [ws.cell(max_row_constraints, c).value for c in unit_cols]

print("Processing sheet:", ws.title)
print("Data rows:", data_rows)
print("Min constraints B:F:", mins)
print("Max constraints B:F:", maxs)

before_after = []

for r in data_rows:
    residual = ws.cell(r, residual_col).value
    units = [ws.cell(r, c).value for c in unit_cols]
    original_units = units[:]
    remaining = abs(residual)

    if not isinstance(residual, (int, float)):
        continue

    # residual < 0 => add from unit1 to unit5
    if residual < 0:
        for idx in range(len(unit_cols)):
            cur = units[idx]
            if cur in (None, 0):
                continue
            room = max(0, maxs[idx] - cur)
            if room <= 0:
                continue
            delta = min(room, remaining)
            units[idx] = cur + delta
            remaining -= delta
            if remaining == 0:
                break

    # residual > 0 => subtract from unit5 to unit1
    elif residual > 0:
        for idx in range(len(unit_cols) - 1, -1, -1):
            cur = units[idx]
            if cur in (None, 0):
                continue
            room = max(0, cur - mins[idx])
            if room <= 0:
                continue
            delta = min(room, remaining)
            units[idx] = cur - delta
            remaining -= delta
            if remaining == 0:
                break

    # Write adjusted units back in place
    for c, val in zip(unit_cols, units):
        ws.cell(r, c).value = val

    # As instructed, set Column I values to 0 at the end
    ws.cell(r, residual_col).value = 0

    before_after.append({
        "row": r,
        "original_units": original_units,
        "residual": residual,
        "new_units": units,
        "unresolved_remaining": remaining
    })

# Save first
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc to check for sheet renaming
wb_check = load_workbook(outfile)
if wb_check.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheetnames)
    if len(wb_check.sheetnames) == len(original_sheetnames):
        for ws_old, desired in zip(wb_check.worksheets, original_sheetnames):
            ws_old.title = desired
        wb_check.save(outfile)
    else:
        print("Unexpected sheet count mismatch; leaving as-is")
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verification with data_only
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify[original_sheetnames[0]]

print("\nVerification summary (all processed rows):")
all_ok = True
for item in before_after:
    r = item["row"]
    new_units = [wsv.cell(r, c).value for c in unit_cols]
    new_resid = wsv.cell(r, residual_col).value

    # Check bounds only for changed/nonzero values in the operational sense
    bounds_ok = True
    for idx, v in enumerate(new_units):
        if v not in (None, 0):
            # sanity-check numeric plausibility
            if not isinstance(v, (int, float)):
                bounds_ok = False
            # for final sanity, values should at least not violate minimums on decreased cells
            # and not exceed maximums on increased cells, but we simply report actual values here

    unresolved_ok = (item["unresolved_remaining"] == 0)
    resid_ok = (new_resid == 0)

    print(
        f"Row {r}: residual {item['residual']} -> 0, "
        f"{item['original_units']} -> {new_units}, "
        f"remaining={item['unresolved_remaining']}, "
        f"colI={new_resid}"
    )

    if not (unresolved_ok and resid_ok and bounds_ok):
        all_ok = False

print("\nTarget range spot-checks:")
print("B2:F18 and I2:I18 after write:")
for r in data_rows:
    print(r, [wsv.cell(r, c).value for c in unit_cols], wsv.cell(r, residual_col).value)

print("\nOverall verification status:", all_ok)
print("Output file ready:", outfile)
