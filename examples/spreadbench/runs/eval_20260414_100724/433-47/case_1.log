from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title)
print("Dimensions:", ws.max_row, ws.max_column)

# Print all rows to inspect exact data extent and targets
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
    print(f"Row {r}: {vals}")

print("\nTarget columns:")
for c in range(1, ws.max_column + 1):
    print(c, get_column_letter(c), ws.cell(1, c).value)

# Identify actual data rows with residuals
data_rows = []
for r in range(2, ws.max_row + 1):
    residual = ws.cell(r, 9).value
    unit_vals = [ws.cell(r, c).value for c in range(2, 7)]
    if residual is not None and any(v is not None for v in unit_vals):
        data_rows.append(r)

print("\nData rows with residuals:", data_rows)

mins = [ws.cell(20, c).value for c in range(2, 7)]
maxs = [ws.cell(21, c).value for c in range(2, 7)]
print("Min constraints B:F:", mins)
print("Max constraints B:F:", maxs)

# Capacity diagnostics
print("\nPer-row capacity diagnostics:")
for r in data_rows:
    units = [ws.cell(r, c).value for c in range(2, 7)]
    residual = ws.cell(r, 9).value
    add_caps = []
    sub_caps = []
    for i, val in enumerate(units):
        add_caps.append(None if val == 0 else maxs[i] - val)
        sub_caps.append(None if val == 0 else val - mins[i])
    print(
        f"Row {r}: units={units}, residual={residual}, "
        f"add_caps(unit1->5)={add_caps}, total_add={sum(x for x in add_caps if isinstance(x,(int,float)))}, "
        f"sub_caps(unit5->1 view)={sub_caps}, total_sub={sum(x for x in sub_caps if isinstance(x,(int,float)))}"
    )
