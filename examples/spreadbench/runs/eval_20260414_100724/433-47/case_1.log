from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
wb = load_workbook(path)

print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers/values:", headers)
    
    # detect first 10 non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    print("First non-empty rows:", nonempty_rows[:10])
    print("Last non-empty rows:", nonempty_rows[-10:])
    
    sample_first = nonempty_rows[:10]
    sample_last = nonempty_rows[-5:] if len(nonempty_rows) > 5 else []
    print("\nFirst sample rows:")
    for r in sample_first:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(r, vals)
    if sample_last:
        print("\nLast sample rows:")
        for r in sample_last:
            vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(r, vals)
    
    # print formulas found in first 20 rows
    formulas = []
    for r in range(1, min(ws.max_row, 50) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print("Formulas in first 50 rows:", formulas[:20], "count:", len(formulas))

for ws in wb.worksheets:
    sheet_summary(ws)
