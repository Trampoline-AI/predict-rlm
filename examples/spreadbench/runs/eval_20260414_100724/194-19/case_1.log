import os
from datetime import datetime
from openpyxl import load_workbook

# Reload clean input workbook
wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames[:]
ws1 = wb[orig_sheet_names[0]]
ws2 = wb[orig_sheet_names[1]]

def norm_text(x):
    return str(x).strip() if x is not None else ""

def norm_date(x):
    if isinstance(x, datetime):
        return x.date()
    return x

# Build exact lookup from Sheet2 using (date, meet, race)
sheet2_lookup = {}
duplicate_keys = []
for r in range(2, ws2.max_row + 1):
    key = (
        norm_date(ws2.cell(r, 2).value),   # Date
        norm_text(ws2.cell(r, 4).value),   # Track
        ws2.cell(r, 8).value               # Race#
    )
    top = ws2.cell(r, 9).value            # Top
    nums_raw = [ws2.cell(r, c).value for c in range(10, ws2.max_column + 1)]  # J onward
    nums = [x for x in nums_raw if x not in (None, "")]
    if key in sheet2_lookup:
        duplicate_keys.append((key, sheet2_lookup[key]["row"], r))
    sheet2_lookup[key] = {"row": r, "top": top, "nums": nums}

print("Original sheet names:", orig_sheet_names)
print("Sheet2 lookup size:", len(sheet2_lookup))
print("Duplicate exact keys in Sheet2:", len(duplicate_keys))

# Inspect current target cells before writing
print("\nPre-write sample rows (Sheet1 cols D,G,H,I,J):")
for r in list(range(2, 16)) + list(range(max(2, ws1.max_row - 4), ws1.max_row + 1)):
    print(
        r,
        {
            "Meet": ws1.cell(r, 4).value,
            "Race#": ws1.cell(r, 7).value,
            "H_before": ws1.cell(r, 8).value,
            "I_before": ws1.cell(r, 9).value,
            "Tab": ws1.cell(r, 10).value,
        }
    )

# Compute/write values
rows_processed = 0
rows_with_match = 0
rows_missing_match = []
h_changed = 0
i_changed = 0
i_nonblank_after = 0

for r in range(2, ws1.max_row + 1):
    row_id = ws1.cell(r, 1).value
    meet = ws1.cell(r, 4).value
    race = ws1.cell(r, 7).value
    tab = ws1.cell(r, 10).value

    # Only process actual data rows
    if row_id in (None, "") and meet in (None, "") and race in (None, "") and tab in (None, ""):
        continue

    rows_processed += 1
    key = (norm_date(ws1.cell(r, 2).value), norm_text(meet), race)
    src = sheet2_lookup.get(key)
    if not src:
        rows_missing_match.append((r, key))
        continue

    rows_with_match += 1

    # Column H = Top from Sheet2 col I
    new_h = src["top"]
    old_h = ws1.cell(r, 8).value
    if old_h != new_h:
        ws1.cell(r, 8).value = new_h
        h_changed += 1

    # Column I = position of Tab within Sheet2 J:M (or further right if present)
    nums = src["nums"]
    new_i = None
    if tab in nums:
        new_i = nums.index(tab) + 1

    old_i = ws1.cell(r, 9).value
    if old_i != new_i:
        ws1.cell(r, 9).value = new_i
        i_changed += 1
    if new_i not in (None, ""):
        i_nonblank_after += 1

print("\nWrite summary:")
print("Rows processed:", rows_processed)
print("Rows with exact source match:", rows_with_match)
print("Rows missing exact source match:", len(rows_missing_match))
print("H cells changed:", h_changed)
print("I cells changed:", i_changed)
print("Expected nonblank I count after write:", i_nonblank_after)
print("Missing match examples:", rows_missing_match[:10])

# Save output
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalc altered them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != orig_sheet_names:
    print("Sheet names changed after recalc:", wb_post.sheetnames)
    for i, expected_name in enumerate(orig_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = expected_name
    wb_post.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)
else:
    print("Sheet names preserved after recalc.")

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws1 = wb_verify[orig_sheet_names[0]]
vws2 = wb_verify[orig_sheet_names[1]]

# Rebuild source lookup from original input for verification
