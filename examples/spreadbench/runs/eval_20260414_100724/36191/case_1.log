import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load current output if it exists, otherwise start from input
path_to_edit = output_path if os.path.exists(output_path) else input_path
wb = load_workbook(path_to_edit)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before fix:")
print("B2:", ws["B2"].value)
print("B3:", ws["B3"].value)
print("C2:", ws["C2"].value)
print("C3:", ws["C3"].value)

# Correct formula: take everything up to the second space
correct_formula_c3 = '=LEFT(B3,FIND(" ",B3,FIND(" ",B3)+1)-1)'
ws["C3"] = correct_formula_c3

print("Written C3 formula:", ws["C3"].value)

wb.save(output_path)
print("Saved fixed workbook to:", output_path)

recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalculation changed them
wb_post = load_workbook(output_path)
if wb_post.sheetnames != original_sheet_names:
    print("Restoring sheet names:", wb_post.sheetnames, "->", original_sheet_names)
    for i, expected in enumerate(original_sheet_names):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = expected
    wb_post.save(output_path)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
wsf = wb_formula["Sheet1"]
print("Formula view:")
print("C2:", wsf["C2"].value)
print("C3:", wsf["C3"].value)

# Verify computed values
wb_values = load_workbook(output_path, data_only=True)
wsv = wb_values["Sheet1"]
print("Computed values after recalc:")
print("C2:", repr(wsv["C2"].value))
print("C3:", repr(wsv["C3"].value))

output_spreadsheet = output_path
```
