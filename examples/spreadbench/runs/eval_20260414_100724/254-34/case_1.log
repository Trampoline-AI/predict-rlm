import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def cell_fill_info(cell):
    fill = cell.fill
    if fill is None:
        return None
    fg = getattr(fill.fgColor, "rgb", None)
    typ = fill.fill_type
    return {"fill_type": typ, "fgColor": fg}

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row1 headers/values:", headers)
    sample_first = []
    for r in range(1, min(ws.max_row, 10) + 1):
        sample_first.append([ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
    print("First rows:")
    for row in sample_first:
        print(row)
    print("Last rows:")
    start = max(1, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        print([ws.cell(r, c).value for c in range(1, ws.max_column + 1)])
    
    # Print non-default fills
    filled = []
    for row in ws.iter_rows():
        for cell in row:
            info = cell_fill_info(cell)
            if info and info["fill_type"] is not None:
                # skip pure default no-fill cases
                if info["fill_type"] != None:
                    filled.append((cell.coordinate, cell.value, info))
    print("Cells with non-empty fill count:", len(filled))
    for item in filled[:50]:
        print(item)
