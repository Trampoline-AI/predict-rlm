Code:
```repl
import os
from itertools import combinations
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
before = wb["Before"]
after = wb["After"]

# Determine the one valid combination from the Before sheet values
values = [before.cell(r, 1).value for r in range(1, before.max_row + 1)]
low, high = 994108, 994112
valid = []
for k in range(1, len(values) + 1):
    for idxs in combinations(range(len(values)), k):
        s = sum(values[i] for i in idxs)
        if low <= s <= high:
            valid.append((s, [i + 1 for i in idxs]))

print("Valid combinations found:", valid)
assert len(valid) == 1, f"Expected exactly one valid combination, got {len(valid)}"

combo_sum, combo_rows = valid[0]
print("Using sum:", combo_sum, "rows:", combo_rows)

# Print current target cells before modification
print("Before!C2 before:", before["C2"].value)
for r in combo_rows:
    c = before.cell(r, 1)
    print("Before target pre-write:", c.coordinate, c.value, c.fill.fill_type, getattr(c.fill.fgColor, "rgb", None))

# Apply green fill to the combination cells on Before
green_fill = PatternFill(fill_type="solid", start_color="FF00FF00", end_color="FF00FF00")
for r in combo_rows:
    before.cell(r, 1).fill = green_fill

# Put the one valid combination numerical value in C2 on Before sheet
before["C2"] = combo_sum

# Delete Sheet3 if present
if "Sheet3" in wb.sheetnames:
    del wb["Sheet3"]

# Save output
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc altered them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != [s for s in original_sheetnames if s != "Sheet3"]:
    desired = [s for s in original_sheetnames if s != "Sheet3"]
    if len(wb_post.sheetnames) == len(desired):
        for ws, desired_name in zip(wb_post.worksheets, desired):
            ws.title = desired_name
        wb_post.save(output_path)
        print("Renamed sheets back to:", desired)
    else:
        print("Unexpected sheet count after recalc; leaving as-is.")

# Verification reloads
wb_verify = load_workbook(output_path)
wb_verify_vals = load_workbook(output_path, data_only=True)

print("Final sheet names:", wb_verify.sheetnames)
print("Before!C2 verified value:", wb_verify_vals["Before"]["C2"].value)

verified_before = wb_verify["Before"]
for r in combo_rows:
    c = verified_before.cell(r, 1)
    print("Verified fill:", c.coordinate, c.value, c.fill.fill_type, getattr(c.fill.fgColor, "rgb", None))

# Sanity checks
assert "Sheet3" not in wb_verify.sheetnames, "Sheet3 was not deleted"
assert wb_verify_vals["Before"]["C2"].value == combo_sum, "Before!C2 does not contain expected sum"

for r in combo_rows:
    c = verified_before.cell(r, 1)
    assert c.fill.fill_type == "solid", f"{c.coordinate} not solid-filled"
    assert getattr(c.fill.fgColor, "rgb", None) == "FF00FF00", f"{c.coordinate} fill is not green"

print("All verification checks passed.")
```
