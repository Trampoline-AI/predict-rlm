from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Input:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Original sheet names:", wb.sheetnames)

def display(v):
    try:
        if hasattr(v, "text"):
            return f"<formula_obj:{v.text}>"
    except Exception:
        pass
    return v

for ws in wb.worksheets:
    print("\n--- SHEET ---")
    print("Title:", ws.title)
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    headers = [display(ws.cell(1, c).value) for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:", headers)
    
    sample_first_end = min(ws.max_row, 10)
    print("First rows:")
    for r in range(1, sample_first_end + 1):
        row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    
    if ws.max_row > 10:
        print("Last 5 rows:")
        start_last = max(1, ws.max_row - 4)
        for r in range(start_last, ws.max_row + 1):
            row_vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
            print(f"Row {r}:", row_vals)

    print("Specific cells:")
    for coord in ["A1", "B2", "A2", "B1", "C1", "C2"]:
        print(coord, "=", display(ws[coord].value))
