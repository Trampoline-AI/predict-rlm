Code:
```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load and modify
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

a1 = ws["A1"].value
b2_before = ws["B2"].value
print("Before write:", {"sheet": ws.title, "A1": a1, "B2": b2_before})

text = "" if a1 is None else str(a1).upper()
mapping = {
    "4OZARK": 1,
    "3TALL": 2,
    "1JASPER": 3,
    "2GWOOD": 4,
    "5DAWSON": 5,
    "8CPARK": 6,
}

result = None
for key, val in mapping.items():
    if key in text:
        result = val
        break

print("Matched result:", result)

if result is None:
    raise ValueError(f"No mapping matched A1 value: {a1!r}")

ws["B2"] = result

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalculation and restore sheet names if needed
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    for i, expected in enumerate(original_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]

print("Verification target cells:")
print("A1 =", wsv["A1"].value)
print("B2 =", wsv["B2"].value)

output_spreadsheet = outfile
```
