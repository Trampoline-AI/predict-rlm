import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

def is_zero(val):
    if val == 0:
        return True
    if isinstance(val, float) and abs(val) < 1e-12:
        return True
    if isinstance(val, str) and val.strip() == "0":
        return True
    return False

def is_blank_cell(v):
    return v is None or (isinstance(v, str) and v.strip() == "")

def is_blank_row(ws, r):
    return all(is_blank_cell(ws.cell(r, c).value) for c in range(1, ws.max_column + 1))

def is_br1_sales(ref):
    return isinstance(ref, str) and "BR1 Sales" in ref

# Load workbook and inspect target/formula cells again before editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Original size:", ws.max_row, "rows x", ws.max_column, "cols")
print("Existing helper row 137:", [ws.cell(137, c).value for c in range(1, ws.max_column + 1)])

# Find target row and compute total of D where E == 0
target_rows = []
total_zero_sum = 0.0

for r in range(2, ws.max_row + 1):
    ref = ws.cell(r, 3).value
    amt = ws.cell(r, 4).value
    matchv = ws.cell(r, 5).value
    if is_br1_sales(ref):
        target_rows.append(r)
    if is_zero(matchv) and isinstance(amt, (int, float)):
        total_zero_sum += float(amt)

total_zero_sum = round(total_zero_sum, 2)
print("Target BR1 Sales rows:", target_rows)
print("Computed sum of Column D where Column E = 0:", total_zero_sum)

if not target_rows:
    raise RuntimeError("No row found where Column C contains 'BR1 Sales'.")

target_row = target_rows[0]
print(f"Before update, target row {target_row}:", [ws.cell(target_row, c).value for c in range(1, ws.max_column + 1)])
print(f"Current D{target_row}:", ws.cell(target_row, 4).value)

# Write the computed total into Column D on the BR1 Sales row
ws.cell(target_row, 4).value = total_zero_sum
print(f"Updated D{target_row} to:", ws.cell(target_row, 4).value)

# Delete blank rows and all zero-match rows except the BR1 Sales row, bottom-up
rows_deleted = []
for r in range(ws.max_row, 1, -1):
    ref = ws.cell(r, 3).value
    matchv = ws.cell(r, 5).value
    if is_blank_row(ws, r):
        rows_deleted.append((r, "blank"))
        ws.delete_rows(r, 1)
    elif is_zero(matchv) and not is_br1_sales(ref):
        rows_deleted.append((r, "E=0 non-BR1"))
        ws.delete_rows(r, 1)

print("Deleted rows count:", len(rows_deleted))
print("First deleted rows sample:", rows_deleted[:10])

# If Total Zero helper row still exists, update its formula to the current used range
total_zero_row = None
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 3).value == "Total Zero":
        total_zero_row = r
        break

if total_zero_row:
    formula = f"=SUMIFS(D2:D{total_zero_row-1},E2:E{total_zero_row-1},0)"
    print(f"Updating helper formula in D{total_zero_row} to:", formula)
    ws.cell(total_zero_row, 4).value = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Restore original sheet names if recalculate changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalculation:", wb_check.sheetnames)
    for i, desired_name in enumerate(original_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = desired_name
    wb_check.save(output_path)
    print("Restored sheet names to:", original_sheet_names)
else:
    print("Sheet names preserved after recalculation.")

# Verification: reload both formula view and cached values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)

wsf = wb_formula[original_sheet_names[0]]
wsv = wb_values[original_sheet_names[0]]

print("Verified sheet names (formula wb):", wb_formula.sheetnames)
print("Final size:", wsf.max_row, "rows x", wsf.max_column, "cols")

# Print all final rows since there should be very few
print("Final rows (formula view):")
for r in range(1, wsf.max_row + 1):
    print(r, [wsf.cell(r, c).value for c in range(1, wsf.max_column + 1)])

# Locate BR1 Sales row after deletion and verify target D cell
final_br1_row = None
for r in range(2, wsf.max_row + 1):
    if is_br1_sales(wsf.cell(r, 3).value):
        final_br1_row = r
        break

print("Final BR1 Sales row:", final_br1_row)
if final_br1_row is not None:
    print("BR1 row formula view:", [wsf.cell(final_br1_row, c).value for c in range(1, wsf.max_column + 1)])
    print("BR1 row data_only view:", [wsv.cell(final_br1_row, c).value for c in range(1, wsv.max_column + 1)])
    print(f"Target cell D{final_br1_row} formula view:", wsf.cell(final_br1_row, 4).value)
    print(f"Target cell D{final_br1_row} data_only view:", wsv.cell(final_br1_row, 4).value)

# Verify helper total row if present
final_total_row = None
for r in range(2, wsf.max_row + 1):
    if wsf.cell(r, 3).value == "Total Zero":
        final_total_row = r
        break

print("Final Total Zero row:", final_total_row)
if final_total_row is not None:
    print("Total Zero row formula view:", [wsf.cell(final_total_row, c).value for c in range(1, wsf.max_column + 1)])
    print("Total Zero row data_only view:", [wsv.cell(final_total_row, c).value for c in range(1, wsv.max_column + 1)])
    print(f"D{final_total_row} formula:", wsf.cell(final_total_row, 4).value)
    print(f"D{final_total_row} cached value:", wsv.cell(final_total_row, 4).value)

# Sanity checks
remaining_zero_non_br1 = []
remaining_blank_rows = []
for r in range(2, wsf.max_row + 1):
    ref = wsf.cell(r, 3).value
    matchv = wsf.cell(r, 5).value
    if is_blank_row(wsf, r):
        remaining_blank_rows.append(r)
    if is_zero(matchv) and not is_br1_sales(ref):
        remaining_zero_non_br1.append(r)

print("Remaining zero rows that are NOT BR1 Sales:", remaining_zero_non_br1)
print("Remaining blank rows:", remaining_blank_rows)

output_spreadsheet = output_path
print("Prepared output_spreadsheet:", output_spreadsheet)
