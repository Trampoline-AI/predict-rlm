import os
from collections import defaultdict
from copy import copy
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Instruction summary check:")
print(instruction)
print("\nUsing sheet:", ws.title)
print("Sheet size:", ws.max_row, "rows x", ws.max_column, "cols")

# Inspect source records in A:E
source_rows = []
print("\nSource rows from A:E:")
for r in range(2, ws.max_row + 1):
    row = [ws.cell(r, c).value for c in range(1, 6)]
    if any(v is not None for v in row):
        rec = {
            "row": r,
            "date": row[0],
            "brand": row[1],
            "batch": row[2],
            "origin": row[3],
            "quantity": row[4],
        }
        source_rows.append(rec)
        print(rec)

# Inspect current target area H:L before writing
print("\nCurrent target area H:L before writing:")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(8, 13)]
    if any(v is not None for v in vals):
        print(f"Row {r} H:L -> {vals}")

# Compute latest date per brand
latest_date_by_brand = {}
for rec in source_rows:
    brand = rec["brand"]
    dt = rec["date"]
    if brand is None or dt is None:
        continue
    if brand not in latest_date_by_brand or dt > latest_date_by_brand[brand]:
        latest_date_by_brand[brand] = dt

print("\nLatest date per brand:")
for brand, dt in latest_date_by_brand.items():
    print(brand, "->", dt)

# Preserve brand order by first appearance in source
brand_order = []
seen = set()
for rec in source_rows:
    b = rec["brand"]
    if b not in seen and b in latest_date_by_brand:
        seen.add(b)
        brand_order.append(b)

# Consolidate rows on each brand's latest date
output_records = []
for brand in brand_order:
    latest_dt = latest_date_by_brand[brand]
    matches = [rec for rec in source_rows if rec["brand"] == brand and rec["date"] == latest_dt]
    total_qty = sum((rec["quantity"] or 0) for rec in matches)
    batch_values = [rec["batch"] for rec in matches if rec["batch"] not in (None, "")]
    origin_values = [rec["origin"] for rec in matches if rec["origin"] not in (None, "")]
    batches_unique = list(dict.fromkeys(batch_values))
    origins_unique = list(dict.fromkeys(origin_values))
    out = {
        "date": latest_dt,
        "brand": brand,
        "batch": batches_unique[0] if batches_unique else None,
        "origin": origins_unique[0] if origins_unique else None,
        "quantity": total_qty,
        "matched_rows": [m["row"] for m in matches],
        "distinct_batches": batches_unique,
        "distinct_origins": origins_unique,
        "duplicate_count": len(matches),
    }
    output_records.append(out)

print("\nComputed consolidated output records:")
for rec in output_records:
    print(rec)

# Write into existing output area H:L
# Clear previous output rows first (rows 2..max_row in columns H:L)
for r in range(2, ws.max_row + 1):
    for c in range(8, 13):
        ws.cell(r, c).value = None

# Ensure headers exist in H1:L1 to match expected output location
headers = ["date", "brand", "batch", "origin", "quantity"]
for idx, header in enumerate(headers, start=8):
    ws.cell(1, idx).value = header

# Write output rows starting H2
start_row = 2
for i, rec in enumerate(output_records, start=start_row):
    ws.cell(i, 8).value = rec["date"]
    ws.cell(i, 9).value = rec["brand"]
    ws.cell(i, 10).value = rec["batch"]
    ws.cell(i, 11).value = rec["origin"]
    ws.cell(i, 12).value = rec["quantity"]
    # preserve number/date formats from source columns if available
    ws.cell(i, 8).number_format = ws.cell(2, 1).number_format
    ws.cell(i, 12).number_format = ws.cell(2, 5).number_format

print("\nTarget area H:L after writing, before save:")
for r in range(1, max(ws.max_row, start_row + len(output_records) - 1) + 1):
    vals = [ws.cell(r, c).value for c in range(8, 13)]
    if any(v is not None for v in vals):
        print(f"Row {r} H:L -> {vals}")

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if changed
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheet_names)
    for i, original_name in enumerate(original_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Verify with data_only
wb_verify = load_workbook(output_path, data_only=True)
ws_verify = wb_verify[original_sheet_names[0]]

print("\nVerified target cells/range H:L after save/recalc:")
for r in range(1, ws_verify.max_row + 1):
    vals = [ws_verify.cell(r, c).value for c in range(8, 13)]
    if any(v is not None for v in vals):
        print(f"Row {r} H:L -> {vals}")

# Explicit verification of intended output rows
print("\nExplicit intended output rows:")
for idx in range(start_row, start_row + len(output_records)):
    vals = [ws_verify.cell(idx, c).value for c in range(8, 13)]
    print(f"Row {idx}: {vals}")

# Basic validation
issues = []
for idx in range(start_row, start_row + len(output_records)):
    vals = [ws_verify.cell(idx, c).value for c in range(8, 13)]
    if any(v is None for v in vals):
        issues.append((idx, vals))

print("\nValidation issues:", issues if issues else "None")
print("Final output path ready:", output_path)
