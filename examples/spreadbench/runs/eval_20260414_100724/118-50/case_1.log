import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INPUT FILE:", input_spreadsheet)
print("FULL INSTRUCTION:\n", instruction)

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("\nSHEET NAMES:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

def nonempty_rows(ws):
    rows = []
    for r in range(1, ws.max_row + 1):
        vals = row_values(ws, r)
        if any(v is not None and v != "" for v in vals):
            rows.append(r)
    return rows

for sname in wb.sheetnames:
    ws = wb[sname]
    ner = nonempty_rows(ws)
    print("\n" + "="*80)
    print(f"SHEET: {sname}")
    print(f"ws.max_row={ws.max_row}, ws.max_column={ws.max_column}, nonempty_rows={len(ner)}")
    
    headers1 = row_values(ws, 1, ws.max_column)
    headers2 = row_values(ws, 2, ws.max_column) if ws.max_row >= 2 else []
    print("Row 1:", headers1)
    print("Row 2:", headers2)
    print("Column letters:", [get_column_letter(c) for c in range(1, ws.max_column + 1)])
    
    # Sample first 10 non-empty rows
    print("\nFirst up to 10 non-empty rows:")
    for r in ner[:10]:
        print(f"Row {r}: {row_values(ws, r, ws.max_column)}")
    
    # Sample last 5 non-empty rows
    print("\nLast up to 5 non-empty rows:")
    for r in ner[-5:]:
        print(f"Row {r}: {row_values(ws, r, ws.max_column)}")
    
    # Focus on column A and nearby columns
    print("\nColumn A sample with A:C:")
    for r in ner[:10]:
        vals = [ws.cell(r, c).value for c in range(1, min(3, ws.max_column) + 1)]
        print(f"Row {r}: {vals}")
    
    print("\nLast rows A:C:")
    for r in ner[-5:]:
        vals = [ws.cell(r, c).value for c in range(1, min(3, ws.max_column) + 1)]
        print(f"Row {r}: {vals}")

# keep objects for later iterations
inspection_wb = wb
