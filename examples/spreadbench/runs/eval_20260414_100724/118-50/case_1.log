```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

# Fresh load
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

def move_5th_to_front(word):
    if not isinstance(word, str):
        return None
    word = word.strip()
    if len(word) < 5:
        return None
    return word[4] + word[:4] + word[5:]

# Read source words from column A
source_words = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        source_words.append(v.strip())

print("Loaded source words:", len(source_words), "unique:", len(set(source_words)))

# 1) Sort column A alphabetically
sorted_words = sorted(source_words)
for r, word in enumerate(sorted_words, start=1):
    ws.cell(r, 1).value = word

# Keep rows beyond data empty if any
for r in range(len(sorted_words) + 1, ws.max_row + 1):
    ws.cell(r, 1).value = None

# 2) Build pairs from sorted words so within-group order is alphabetical by original
word_set = set(sorted_words)
requested_order = ["ING", "ERS", "ATE", "EST", "ONE", "IER", "ILY"]

grouped = defaultdict(list)
for w in sorted_words:
    t = move_5th_to_front(w)
    if t in word_set and w[-3:] == t[-3:] and w[-3:] in requested_order:
        grouped[w[-3:]].append((w, t))

result_pairs = []
for ending in requested_order:
    result_pairs.extend(grouped.get(ending, []))

print("Total result pairs:", len(result_pairs))
for ending in requested_order:
    print(ending, grouped.get(ending, []))

# 3) Clear existing output area C:D fully
for r in range(1, ws.max_row + 1):
    ws.cell(r, 3).value = None
    ws.cell(r, 4).value = None

# 4) Write results in C:D following the existing example pattern on-sheet:
#    column C = original word, column D = transformed word
for r, (original, transformed) in enumerate(result_pairs, start=1):
    ws.cell(r, 3).value = original
    ws.cell(r, 4).value = transformed

# Save
wb.save(outfile)
print("Saved initial output to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculation changed them
wb_post = load_workbook(outfile)
current_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", current_names)
if current_names != orig_sheet_names:
    for i, orig_name in enumerate(orig_sheet_names):
        wb_post.worksheets[i].title = orig_name
    wb_post.save(outfile)
    print("Restored original sheet names:", orig_sheet_names)

# Verification reload
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
vws = wb_verify["Sheet1"]

# Verify column A sorted
a_vals = []
for r in range(1, vws.max_row + 1):
    v = vws.cell(r, 1).value
    if isinstance(v, str) and v.strip():
        a_vals.append(v.strip())
print("Column A sorted verification:", a_vals == sorted(a_vals), "count:", len(a_vals))
print("First 15 in sorted A:", a_vals[:15])

# Verify target cells/range
written_cd = []
for r in range(1, len(result_pairs) + 1):
    c = vws.cell(r, 3).value
    d = vws.cell(r, 4).value
    written_cd.append((r, c, d))
print("Written C:D rows:")
for item in written_cd:
    print(item)

# Sanity checks
blank_targets = [row for row, c, d in written_cd if c in (None, "") or d in (None, "")]
print("Blank target rows among intended outputs:", blank_targets)

# store for submit
output_spreadsheet_path = outfile
