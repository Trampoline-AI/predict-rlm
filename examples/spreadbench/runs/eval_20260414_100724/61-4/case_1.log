from copy import copy
import os

# Load source workbook
wb = load_workbook(input_spreadsheet)
input_ws = wb["input"]
output_ws = wb["output"]
original_sheetnames = wb.sheetnames[:]

# Build source rows from input A:H
source_rows = []
for r in range(2, input_ws.max_row + 1):
    vals = [input_ws.cell(r, c).value for c in range(1, 9)]
    if any(v is not None and v != "" for v in vals):
        source_rows.append({
            "sheet_row": r,
            "date": input_ws.cell(r, 1).value,
            "stock": input_ws.cell(r, 2).value,
            "open": input_ws.cell(r, 3).value,
            "high": input_ws.cell(r, 4).value,
            "low": input_ws.cell(r, 5).value,
            "close": input_ws.cell(r, 6).value,
            "volume": input_ws.cell(r, 7).value,
            "change": input_ws.cell(r, 8).value,
        })

# Compute row-by-row example-equivalent output (with blanks for merged-following rows)
computed_by_input_row = {}
i = 0
while i < len(source_rows):
    cur = source_rows[i]
    stock = cur["stock"]
    ch = cur["change"]
    if isinstance(ch, (int, float)) and ch < 0:
        j = i
        run = []
        while j < len(source_rows):
            rr = source_rows[j]
            rr_ch = rr["change"]
            if rr["stock"] == stock and isinstance(rr_ch, (int, float)) and rr_ch < 0:
                run.append(rr)
                j += 1
            else:
                break
        if len(run) >= 2:
            merged = [
                run[0]["date"],              # most recent/top row date
                run[0]["stock"],
                run[-1]["open"],             # earliest/bottom row open
                max(x["high"] for x in run),
                min(x["low"] for x in run),
                run[0]["close"],             # most recent/top row close
                sum(x["volume"] for x in run),
            ]
            computed_by_input_row[run[0]["sheet_row"]] = merged
            for extra in run[1:]:
                computed_by_input_row[extra["sheet_row"]] = [None] * 7
            i = j
            continue
        else:
            computed_by_input_row[cur["sheet_row"]] = [
                cur["date"], cur["stock"], cur["open"], cur["high"],
                cur["low"], cur["close"], cur["volume"]
            ]
            i += 1
            continue
    else:
        computed_by_input_row[cur["sheet_row"]] = [
            cur["date"], cur["stock"], cur["open"], cur["high"],
            cur["low"], cur["close"], cur["volume"]
        ]
        i += 1

# Compact rows for output sheet (nonblank only), using K:Q header pattern
