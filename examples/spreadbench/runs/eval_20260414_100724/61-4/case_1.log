# Write compacted results to output A:G
for r_idx, row_vals in enumerate(compacted_rows, start=1):
    for c_idx, val in enumerate(row_vals, start=1):
        cell = output_ws.cell(r_idx, c_idx)
        cell.value = val
        # Apply header style to row 1
