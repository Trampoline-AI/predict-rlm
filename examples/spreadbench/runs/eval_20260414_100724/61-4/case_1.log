        compacted_rows.append(vals)

print("Compacted output row count including header:", len(compacted_rows))
for idx, row in enumerate(compacted_rows, start=1):
    print(f"Planned output row {idx}: {row}")

# Inspect existing target cells before overwrite
print("\nExisting output sheet A:G before write:")
for r in range(1, output_ws.max_row + 1):
    vals = [output_ws.cell(r, c).value for c in range(1, 8)]
    if any(v is not None and v != "" for v in vals):
        print(f"Row {r}: {vals}")

# Preserve basic styles from input K:Q where convenient
# Header style from input K1:Q1
header_styles = []
for c in range(11, 18):
    src = input_ws.cell(1, c)
    header_styles.append({
        "font": copy(src.font),
        "fill": copy(src.fill),
        "border": copy(src.border),
        "alignment": copy(src.alignment),
        "number_format": src.number_format,
        "protection": copy(src.protection),
    })

# Clear old output used area A:G (extend enough to remove leftovers)
clear_to_row = max(output_ws.max_row, len(compacted_rows) + 20)
for r in range(1, clear_to_row + 1):
