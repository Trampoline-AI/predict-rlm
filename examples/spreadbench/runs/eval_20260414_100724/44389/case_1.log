from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

print("Inspect target columns O and P")
for r in range(1, ws.max_row + 1):
    o = ws[f"O{r}"].value
    p = ws[f"P{r}"].value
    if isinstance(o, ArrayFormula):
        o_text = o.text
    else:
        o_text = o
    print(f"Row {r}: O={o_text!r} ({type(o).__name__}), P={p!r}")

print("\nDetailed row data B:N plus headers for each data row")
headers = [ws.cell(1, c).value for c in range(2, 15)]  # B:N
