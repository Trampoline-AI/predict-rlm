from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def display(val):
    if val is None:
        return None
    s = str(val)
    if len(s) > 60:
        s = s[:57] + "..."
    return s

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # detect non-empty rows/cols more carefully
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            nonempty_rows.append(r)
    nonempty_cols = []
    for c in range(1, ws.max_column + 1):
        if any(ws.cell(r, c).value not in (None, "") for r in range(1, ws.max_row + 1)):
            nonempty_cols.append(c)
    print("Non-empty row span:", (min(nonempty_rows), max(nonempty_rows)) if nonempty_rows else None)
    print("Non-empty cols:", [f"{get_column_letter(c)}" for c in nonempty_cols])
    
    # print row 1-10 and last 5 non-empty rows
    sample_rows = list(range(1, min(ws.max_row, 10) + 1))
    if nonempty_rows:
        tail_rows = nonempty_rows[-5:]
        for r in tail_rows:
            if r not in sample_rows:
                sample_rows.append(r)
    sample_rows = sorted(sample_rows)
    
    for r in sample_rows:
        vals = [display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # headers guess: first 3 rows
    for hr in range(1, min(4, ws.max_row + 1)):
        print(f"Potential headers row {hr}:",
              {get_column_letter(c): display(ws.cell(hr, c).value) for c in range(1, ws.max_column + 1)})
    
    # print formulas present in first 15 rows
    formulas = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
