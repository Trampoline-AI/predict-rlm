import os
from openpyxl import load_workbook

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
wsA = wb["A"]
wsB = wb["B"]

# Compute the result date per instruction
first_yes_na_row = None
for r in range(3, wsA.max_row + 1):
    val = wsA.cell(r, 16).value  # column P
    if val in ("Yes", "NA"):
        first_yes_na_row = r
        break

if first_yes_na_row is None:
    result_date = wsA["F3"].value
    source_desc = "Fallback: no Yes/NA in A!P, using A!F3"
else:
    prior_100_row = None
    for r in range(first_yes_na_row - 1, 2, -1):
        if wsA.cell(r, 12).value == 100:  # column L
            prior_100_row = r
            break
    if prior_100_row is None:
        result_date = wsA["F3"].value
        source_desc = f"No 100 above first Yes/NA row {first_yes_na_row}; fallback to A!F3"
    else:
        result_date = wsA.cell(prior_100_row, 6).value  # column F
        source_desc = f"First Yes/NA at A!P{first_yes_na_row}; nearest prior 100 at A!L{prior_100_row}; date from A!F{prior_100_row}"

# Find matching row in B based on A!F1 against B!C:C
lookup_name = wsA["F1"].value
target_row = None
for r in range(2, wsB.max_row + 1):
    if wsB.cell(r, 3).value == lookup_name:  # column C
        target_row = r
        break

print("Computed details:")
print(" lookup_name:", lookup_name)
print(" first_yes_na_row:", first_yes_na_row)
print(" result_date:", result_date)
print(" source_desc:", source_desc)
print(" target_row in B:", target_row)
print(" B!F4 before:", wsB["F4"].value, "format:", wsB["F4"].number_format)

# Write only if match found; instruction/data indicates target should be F4
if target_row is not None:
    target_cell = wsB.cell(target_row, 6)  # column F
    target_cell.value = result_date
    if not target_cell.number_format or target_cell.number_format == "General":
        target_cell.number_format = "d-mmm-yy"
else:
    raise ValueError(f"No match for {lookup_name!r} found in B column C")

# Ensure A is active when saved
wb.active = wb.sheetnames.index("A")

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and repair sheet names if recalc changed them
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)

if wb_post.sheetnames != original_sheetnames:
    # Rename by position back to originals
    for i, orig_name in enumerate(original_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = orig_name
    wb_post.active = original_sheetnames.index("A")
    wb_post.save(outfile)
    print("Renamed sheets back to:", original_sheetnames)

# Verification reload
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
print("Verified active sheet title:", wb_verify.worksheets[wb_verify.active.index].title if hasattr(wb_verify.active, "index") else wb_verify.active.title)

wsA_v = wb_verify["A"]
wsB_v = wb_verify["B"]

print("Verification values:")
print(" A!F1 =", wsA_v["F1"].value)
print(" A!F3 =", wsA_v["F3"].value)
if first_yes_na_row is not None:
    print(f" A!P{first_yes_na_row} =", wsA_v.cell(first_yes_na_row, 16).value)
print(f" B!C{target_row} =", wsB_v.cell(target_row, 3).value)
print(f" B!F{target_row} =", wsB_v.cell(target_row, 6).value)
print(" B!F2:F6 =", [wsB_v.cell(r, 6).value for r in range(2, min(6, wsB_v.max_row) + 1)])

# Sanity checks
assert "A" in wb_verify.sheetnames and "B" in wb_verify.sheetnames
assert target_row == 4, f"Expected target row 4, got {target_row}"
assert wsB_v["F4"].value is not None, "B!F4 should not be blank"
