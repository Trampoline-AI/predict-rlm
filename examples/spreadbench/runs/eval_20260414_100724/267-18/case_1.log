```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

def is_yellow_rgb(rgb):
    if not rgb:
        return False
    rgb = str(rgb).upper()
    return rgb in {"FFFFFF00", "FFFF00"} or rgb.endswith("FFFF00")

def cell_is_yellow(cell):
    fill = cell.fill
    if fill is None or fill.fill_type != "solid":
        return False
    vals = [
        getattr(fill.fgColor, "rgb", None),
        getattr(fill.start_color, "rgb", None),
    ]
    return any(is_yellow_rgb(v) for v in vals)

def row_is_yellow(ws, r):
    # treat the row as yellow if any cell in the row has a solid yellow fill
    # (in this file the whole row is yellow)
    yellow_cells = []
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        if cell_is_yellow(cell):
            yellow_cells.append(f"{get_column_letter(c)}{r}")
    return yellow_cells

print("Original sheetnames:", original_sheetnames)
print("Before change:")
for r in range(1, ws.max_row + 1):
    yellow_cells = row_is_yellow(ws, r)
    print(f"Row {r}: yellow_cells={yellow_cells}, G{r}={ws[f'G{r}'].value}")

modified = []
for r in range(1, ws.max_row + 1):
    yellow_cells = row_is_yellow(ws, r)
    gcell = ws.cell(r, 7)
    formula = gcell.value
    if yellow_cells and isinstance(formula, str) and formula.startswith("="):
        # avoid double prefixing
        if '"//["' in formula or "'//[" in formula or '//[' in formula.split('=')[1][:40]:
            print(f"Skipping G{r}: already appears prefixed.")
            continue
        
        new_formula = formula
        if '"["' in new_formula:
            new_formula = new_formula.replace('"["', '"//["', 1)
        elif "'['" in new_formula:
            new_formula = new_formula.replace("'['", "'//['", 1)
        else:
            # fallback: if somehow the literal [ is embedded differently, prefix the first [
            idx = new_formula.find('[')
            if idx != -1:
                new_formula = new_formula[:idx] + '//' + new_formula[idx:]
        
        if new_formula != formula:
            print(f"Modifying G{r}")
            print(" old:", formula)
            print(" new:", new_formula)
            gcell.value = new_formula
            modified.append(f"G{r}")
        else:
            print(f"No change pattern found for G{r}; leaving as is.")

wb.save(output_path)
print("Saved to:", output_path)
print("Modified cells:", modified)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if changed
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for i, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Restored sheetnames to:", original_sheetnames)

# Verify formulas
wb_verify_formula = load_workbook(output_path, data_only=False)
wsf = wb_verify_formula[original_sheetnames[0]]
print("Verified formulas:")
for r in range(1, wsf.max_row + 1):
    print(f"G{r} formula:", wsf[f"G{r}"].value)

# Verify cached values after recalculation
wb_verify_values = load_workbook(output_path, data_only=True)
wsv = wb_verify_values[original_sheetnames[0]]
print("Verified cached values:")
for r in range(1, wsv.max_row + 1):
    print(f"G{r} value:", wsv[f"G{r}"].value)

output_spreadsheet = output_path
print("Prepared output file:", output_spreadsheet)
```
