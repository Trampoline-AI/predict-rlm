from openpyxl import load_workbook
import os

# Use the saved path from the previous step if available
output_path = final_output_path if 'final_output_path' in globals() else "/sandbox/output/output_spreadsheet/" + os.path.basename(input_spreadsheet)

wb_check = load_workbook(output_path, data_only=True)
print("Output path:", output_path)
print("Sheet names:", wb_check.sheetnames)

ws1c = wb_check["Sheet1"]
ws2c = wb_check["Sheet2"]

# Build source lookup from Sheet1
source = {}
years = []
for c in range(12, ws1c.max_column + 1):  # L onward
    y = ws1c.cell(1, c).value
    if y is not None:
        years.append((c, y))

for r in range(3, ws1c.max_row + 1):
    state = ws1c.cell(r, 2).value
    if state is None:
        continue
    for c, year in years:
        source[(str(state).strip(), year)] = ws1c.cell(r, c).value

# Verify target range
nonblank = 0
blank_rows = []
mismatches = []

for r in range(3, ws2c.max_row + 1):
    state = ws2c.cell(r, 1).value
    year = ws2c.cell(r, 2).value
    clazz = ws2c.cell(r, 3).value
    val = ws2c.cell(r, 4).value
    
    if state is None and year is None and clazz is None:
        continue
    
    if val is None or val == "":
        blank_rows.append(r)
        continue
    
    nonblank += 1
    expected = source.get((str(state).strip(), year))
    if expected != val:
        # Allow tiny float noise
        if not (isinstance(expected, (int, float)) and isinstance(val, (int, float)) and abs(expected - val) < 1e-12):
            mismatches.append((r, state, year, expected, val))

print("Total populated target rows:", ws2c.max_row - 2)
print("Nonblank values in D:", nonblank)
print("Blank target rows:", blank_rows[:10], "count=", len(blank_rows))
print("Mismatch count:", len(mismatches))
print("First mismatches:", mismatches[:5])

print("\nSample verified rows:")
for r in [3, 4, 5, 54, 55, 100, 101, 104]:
    print(
        f"R{r}: state={ws2c.cell(r,1).value}, year={ws2c.cell(r,2).value}, "
        f"units={ws2c.cell(r,4).value}"
    )
