from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

print("Sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)
print("Headers:", [ws.cell(1,c).value for c in range(1, ws.max_column+1)])

# Focused inspection on C, I, M for all non-empty rows
records = []
for r in range(2, ws.max_row + 1):
    c_val = ws[f"C{r}"].value
    i_val = ws[f"I{r}"].value
    m_val = ws[f"M{r}"].value
    m_fill = ws[f"M{r}"].fill
    fill_info = None
    if m_fill and m_fill.fill_type:
        fill_info = (m_fill.fill_type, m_fill.fgColor.rgb, m_fill.start_color.rgb, m_fill.end_color.rgb)
    if any(v is not None for v in [c_val, i_val, m_val]):
        records.append((r, c_val, i_val, m_val, fill_info))

print("Total relevant rows:", len(records))
print("\nFirst 10 records (row, C=A_Name, I=Entry Time, M=Max, M_fill):")
for rec in records[:10]:
    print(rec)

print("\nLast 10 records:")
for rec in records[-10:]:
    print(rec)

# Print any formulas in column M
m_formulas = []
for r in range(1, ws.max_row + 1):
    v = ws[f"M{r}"].value
    if isinstance(v, str) and v.startswith("="):
        m_formulas.append((r, v))
print("\nExisting formulas in M:", m_formulas if m_formulas else "None")

# Group summary by A_Name to verify pattern
from collections import defaultdict
groups = defaultdict(list)
for r, c_val, i_val, m_val, fill_info in records:
    groups[c_val].append((r, i_val, m_val))

print("\nPer-name summary:")
for name in sorted(groups, key=lambda x: (str(x) if x is not None else "")):
    vals = groups[name]
    times = [t for _, t, _ in vals if t is not None]
    max_time = max(times) if times else None
    print(f"Name={name!r}, rows={len(vals)}, max_time={max_time}")
    for item in vals[:5]:
