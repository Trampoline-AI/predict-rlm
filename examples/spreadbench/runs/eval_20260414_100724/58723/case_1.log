import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook normally
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Determine true data rows based on columns C and I (and generally any non-empty row after header)
data_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 3).value is not None or ws.cell(r, 9).value is not None:
        data_rows.append(r)

first_data_row = min(data_rows) if data_rows else 2
last_data_row = max(data_rows) if data_rows else 1

print("Original sheet names:", orig_sheetnames)
print("Target sheet:", ws.title)
print("Data rows:", first_data_row, "to", last_data_row)
print("Header M1:", ws["M1"].value)
print("Before write, sample M values:")
for r in list(range(first_data_row, min(first_data_row+5, last_data_row+1))) + list(range(max(first_data_row, last_data_row-4), last_data_row+1)):
    print(r, "C=", ws[f"C{r}"].value, "I=", ws[f"I{r}"].value, "M=", ws[f"M{r}"].value)

# Write Excel-2013-compatible formula to ALL relevant rows in column M
for r in data_rows:
    formula = f'=IF(C{r}="","",IF(COUNTIFS($C${first_data_row}:$C${last_data_row},C{r},$I${first_data_row}:$I${last_data_row},">"&I{r})>0,"Not Latest","Latest"))'
    ws[f"M{r}"] = formula

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(outfile)
current_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", current_names)

if current_names != orig_sheetnames and len(current_names) == len(orig_sheetnames):
    for idx, orig_name in enumerate(orig_sheetnames):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verification: formulas present in normal load
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula[orig_sheetnames[0]]
print("\nFormula verification for M2:M6:")
for r in range(first_data_row, min(first_data_row + 5, last_data_row + 1)):
    print(f"M{r} =", wsf[f"M{r}"].value)

# Verification: cached values after recalc
wb_verify_values = load_workbook(outfile, data_only=True)
# Use original name if present, else first sheet
verify_sheet_name = orig_sheetnames[0] if orig_sheetnames[0] in wb_verify_values.sheetnames else wb_verify_values.sheetnames[0]
wsv = wb_verify_values[verify_sheet_name]

print("\nVerified output values (first 10 rows):")
for r in range(first_data_row, min(first_data_row + 10, last_data_row + 1)):
    print(r, "C=", wsv[f"C{r}"].value, "I=", wsv[f"I{r}"].value, "M=", wsv[f"M{r}"].value)

print("\nVerified output values (last 10 rows):")
for r in range(max(first_data_row, last_data_row - 9), last_data_row + 1):
    print(r, "C=", wsv[f"C{r}"].value, "I=", wsv[f"I{r}"].value, "M=", wsv[f"M{r}"].value)

# Sanity check for blanks/errors in target range
bad_rows = []
for r in data_rows:
    mv = wsv[f"M{r}"].value
    if mv in (None, ""):
        bad_rows.append((r, wsf[f"M{r}"].value))
print("\nRows with blank cached M after recalc:", bad_rows[:10], "count=", len(bad_rows))

# Keep path for submission
output_spreadsheet = outfile
