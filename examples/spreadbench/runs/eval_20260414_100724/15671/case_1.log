from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook loaded:", path)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # headers from first row
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    
    # non-empty counts by first few columns
    for c in range(1, min(ws.max_column, 6) + 1):
        vals = [ws.cell(r, c).value for r in range(1, ws.max_row + 1)]
        nonempty = sum(v not in (None, "") for v in vals)
        print(f"Col {get_column_letter(c)} non-empty:", nonempty)
    
    # sample first 10 rows
    print("\nFirst 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 6) + 1)]
        print(r, row_vals)
    
    # sample last 5 rows
    print("\nLast 5 rows:")
    for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, min(ws.max_column, 6) + 1)]
        print(r, row_vals)
    
    # detailed A/B inspection
    print("\nDetailed column A/B inspection (first 12 rows):")
    for r in range(1, min(ws.max_row, 12) + 1):
        a = ws[f"A{r}"]
        b = ws[f"B{r}"] if ws.max_column >= 2 else None
        print({
            "row": r,
            "A_value": a.value,
            "A_data_type": a.data_type,
            "A_number_format": a.number_format,
            "B_value": None if b is None else b.value,
            "B_data_type": None if b is None else b.data_type,
            "B_number_format": None if b is None else b.number_format,
        })
    
    print("\nDetailed column A/B inspection (last 8 rows):")
    for r in range(max(1, ws.max_row - 7), ws.max_row + 1):
        a = ws[f"A{r}"]
        b = ws[f"B{r}"] if ws.max_column >= 2 else None
        print({
            "row": r,
            "A_value": a.value,
            "A_data_type": a.data_type,
            "A_number_format": a.number_format,
            "B_value": None if b is None else b.value,
            "B_data_type": None if b is None else b.data_type,
            "B_number_format": None if b is None else b.number_format,
        })

