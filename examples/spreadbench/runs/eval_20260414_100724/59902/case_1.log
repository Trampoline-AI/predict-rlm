from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)
print("\nInput file:", input_spreadsheet)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("\nSheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc + 1)]

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_column={ws.max_column}")
    
    # Find likely header row among first few rows by non-empty count
    header_candidates = []
    for r in range(1, min(5, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        nonempty = sum(v is not None and v != "" for v in vals)
        header_candidates.append((r, nonempty, vals))
    print("Top row candidates (row, nonempty_count):", [(r, n) for r, n, _ in header_candidates])
    
    # Print first 10 rows
    print("\nFirst up to 10 rows:")
    for r in range(1, min(10, ws.max_row) + 1):
        print(f"Row {r}: {row_values(ws, r)}")
    
    # Print last 5 rows
    print("\nLast up to 5 rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(f"Row {r}: {row_values(ws, r)}")

# Inspect columns A:J with coordinates for first 35 rows on all sheets
for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Detailed A:J inspection for sheet {ws.title}")
    max_c = min(10, ws.max_column)
    headers = [f"{get_column_letter(c)}" for c in range(1, max_c + 1)]
    print("Cols:", headers)
    for r in range(1, min(35, ws.max_row) + 1):
        vals = []
        for c in range(1, max_c + 1):
            cell = ws.cell(r, c)
            vals.append(f"{get_column_letter(c)}{r}={cell.value!r}")
        print(" | ".join(vals))

# Specifically inspect formulas in used range
for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Formula cells in sheet {ws.title}:")
    found = 0
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                print(cell.coordinate, "->", cell.value)
                found += 1
    print("Total formula cells:", found)
