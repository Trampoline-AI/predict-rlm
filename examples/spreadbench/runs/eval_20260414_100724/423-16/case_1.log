def cell_fill_info(cell):
    fill = cell.fill
    if fill is None:
        return None
    return {
        "fill_type": fill.fill_type,
        "fgColor_type": fill.fgColor.type,
        "fgColor_rgb": fill.fgColor.rgb,
        "fgColor_indexed": fill.fgColor.indexed,
        "start_color_type": fill.start_color.type,
        "start_color_rgb": fill.start_color.rgb,
        "start_color_indexed": fill.start_color.indexed,
    }

def row_values(ws, r, max_cols=None):
