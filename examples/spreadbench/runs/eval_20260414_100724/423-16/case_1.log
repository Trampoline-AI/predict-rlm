from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws_test = wb["Test"]
ws_master = wb["master"]

def norm_fill(cell):
    f = cell.fill
    if not f or not f.fill_type:
        return None
    # Prefer start_color then fgColor
    for color in (f.start_color, f.fgColor):
        t = getattr(color, "type", None)
        if t == "rgb":
            rgb = getattr(color, "rgb", None)
            return rgb
        if t == "indexed":
            return f"INDEXED:{getattr(color,'indexed',None)}"
        if t == "theme":
            return f"THEME:{getattr(color,'theme',None)}"
    return "UNKNOWN"

print("Merged ranges Test:", list(ws_test.merged_cells.ranges))
print("Merged ranges master:", list(ws_master.merged_cells.ranges))

print("\nAll non-empty Test!A cells with normalized fill:")
test_a_info = []
for r in range(1, ws_test.max_row + 1):
    cell = ws_test.cell(r, 1)
    if cell.value is not None:
        info = (r, cell.value, norm_fill(cell), cell.border.left.style, cell.border.right.style, cell.border.top.style, cell.border.bottom.style)
        test_a_info.append(info)
        print(info)

yellow_values = []
yellow_rows = []
for r, val, fill, bl, br, bt, bb in test_a_info:
    if fill in ("FFFFFF00", "FFFF00"):
        yellow_rows.append(r)
        yellow_values.append(val)

print("\nExact yellow rgb cells in Test!A:A")
print("Rows:", yellow_rows)
print("Values:", yellow_values)

print("\nCurrent master row 1 values/styles:")
master_vals = []
for c in range(1, max(ws_master.max_column, 20) + 1):
    cell = ws_master.cell(1, c)
    if c <= ws_master.max_column or cell.value is not None or norm_fill(cell) is not None:
        info = (c, get_column_letter(c), cell.value, norm_fill(cell),
                cell.border.left.style, cell.border.right.style, cell.border.top.style, cell.border.bottom.style)
        master_vals.append(info)
        print(info)

existing_master_values = [ws_master.cell(1, c).value for c in range(1, ws_master.max_column + 1)]
print("\nComparison:")
print("Existing master row1:", existing_master_values)
print("Yellow source values:", yellow_values)
print("Same sequence prefix?:", existing_master_values[:len(yellow_values)] == yellow_values)
print("Yellow values already in master row1?:", [v in existing_master_values for v in yellow_values])
