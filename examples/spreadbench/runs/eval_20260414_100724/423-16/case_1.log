```repl
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Border, Side
from openpyxl.utils import get_column_letter
from copy import copy
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
original_sheetnames = wb.sheetnames[:]
ws_test = wb["Test"]
ws_master = wb["master"]

def is_yellow_fill(cell):
    fill = cell.fill
    if not fill or not fill.fill_type:
        return False
    for color in (fill.start_color, fill.fgColor):
        if getattr(color, "type", None) == "rgb":
            rgb = getattr(color, "rgb", None)
            if isinstance(rgb, str) and rgb.upper().endswith("FFFF00"):
                return True
    return False

# Gather yellow-filled, non-blank cells from Test!A:A
source_cells = []
for r in range(1, ws_test.max_row + 1):
    c = ws_test.cell(r, 1)
    if is_yellow_fill(c) and c.value not in (None, ""):
        source_cells.append((r, c.value))

print("Source yellow cells found:", len(source_cells))
print(source_cells)

source_values = [v for _, v in source_cells]
target_count = len(source_values)
existing_max_col = ws_master.max_column
clear_to_col = max(existing_max_col, target_count)

# Clear existing target row 1 across used range so no leftover placeholders remain
for col in range(1, clear_to_col + 1):
    cell = ws_master.cell(1, col)
    cell.value = None
    cell.fill = PatternFill(fill_type=None)
    cell.border = Border()

# Desired formatting
yellow_fill = PatternFill(fill_type="solid", start_color="FFFFFF00", end_color="FFFFFF00")
thin_side = Side(style="thin", color="000000")
all_thin_border = Border(left=thin_side, right=thin_side, top=thin_side, bottom=thin_side)

# Write transposed values horizontally into master row 1
for idx, value in enumerate(source_values, start=1):
    cell = ws_master.cell(1, idx)
    cell.value = value
    cell.fill = yellow_fill
    cell.border = all_thin_border

# Explicitly clear any cells after the written range that may have had previous content/styles
for col in range(target_count + 1, clear_to_col + 1):
    cell = ws_master.cell(1, col)
    cell.value = None
    cell.fill = PatternFill(fill_type=None)
    cell.border = Border()

# Save
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
output_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    if len(wb_check.sheetnames) == len(original_sheetnames):
        for ws, orig_name in zip(wb_check.worksheets, original_sheetnames):
            ws.title = orig_name
        wb_check.save(output_path)
        print("Restored original sheet names:", original_sheetnames)
    else:
        print("Warning: sheet count changed unexpectedly; not renaming automatically.")
else:
    print("Sheet names preserved.")

# Verification reload
wb_verify = load_workbook(output_path, data_only=True)
wb_verify_style = load_workbook(output_path)
print("Verified sheet names:", wb_verify.sheetnames)

wsv = wb_verify["master"]
wsv_style = wb_verify_style["master"]

print("Final master row 1 target cells:")
verification = []
for col in range(1, target_count + 1):
    cell_val = wsv.cell(1, col).value
    cell_style = wsv_style.cell(1, col)
    fill_rgb = None
    for color in (cell_style.fill.start_color, cell_style.fill.fgColor):
        if getattr(color, "type", None) == "rgb":
            fill_rgb = getattr(color, "rgb", None)
            if fill_rgb:
                break
    info = {
        "cell": f"{get_column_letter(col)}1",
        "value": cell_val,
        "fill": fill_rgb,
        "left": cell_style.border.left.style,
        "right": cell_style.border.right.style,
        "top": cell_style.border.top.style,
        "bottom": cell_style.border.bottom.style,
    }
    verification.append(info)
    print(info)

# Check there are no blanks in the written target range
blank_targets = [x["cell"] for x in verification if x["value"] in (None, "")]
print("Blank target cells in written range:", blank_targets)

# Check cells just beyond the target range are blank/cleared
post_range_checks = []
for col in range(target_count + 1, max(target_count + 3, clear_to_col) + 1):
    v = wsv.cell(1, col).value
    post_range_checks.append((f"{get_column_letter(col)}1", v))
print("Cells after written range:", post_range_checks[:10])

print("Output path ready for submission:", output_path)
```
