input_path = input_spreadsheet
wb = load_workbook(input_path)
print("Workbook:", input_path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

for ws in wb.worksheets:
    print("\n--- SHEET:", ws.title, "---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    # find a plausible header row among first 5 rows: row with most non-empty cells
    nonempty_counts = []
    for r in range(1, min(6, ws.max_row + 1)):
        vals = row_values(ws, r, min(ws.max_column, 20))
        nonempty = sum(v not in (None, "") for v in vals)
        nonempty_counts.append((r, nonempty, vals))
    print("Top-row nonempty counts:", [(r, n) for r, n, _ in nonempty_counts])
    for r, n, vals in nonempty_counts:
        print(f"Row {r} sample:", vals)
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"R{r}:", row_values(ws, r, min(ws.max_column, 15)))
    # last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(f"R{r}:", row_values(ws, r, min(ws.max_column, 15)))

# specific inspection for Summary
