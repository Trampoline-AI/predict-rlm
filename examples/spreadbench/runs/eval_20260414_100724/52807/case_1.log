from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook normally
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Summary"]
data_ws = wb["Data"]

data_last_row = data_ws.max_row

# Identify target rows based on populated GL account column C
target_rows = [r for r in range(6, ws.max_row + 1) if ws.cell(r, 3).value not in (None, "")]
target_cols = list(range(8, 17))  # H:P

print("Target rows:", target_rows)
print("Target cols:", [get_column_letter(c) for c in target_cols])

# Print current state before writing
print("\nBefore writing H6:P9:")
for r in target_rows:
    print([f"{ws.cell(r,c).coordinate}={ws.cell(r,c).value}" for c in target_cols])

# Write combined formula into H:P
for r in target_rows:
    for c in target_cols:
        col_letter = get_column_letter(c)
        formula = (
            f'=IF(COUNTIFS(Data!$A$2:$A${data_last_row},Summary!$C{r},'
            f'Data!$D$2:$D${data_last_row},Summary!{col_letter}$5)>0,'
            f'SUMIFS(Data!$C$2:$C${data_last_row},Data!$A$2:$A${data_last_row},Summary!$C{r},'
            f'Data!$D$2:$D${data_last_row},Summary!{col_letter}$5),'
            f'SUM(Summary!$E{r}:$G{r})/(12-Summary!$D$3))'
        )
        ws.cell(r, c).value = formula

        # Preserve style from G-column actual cell in same row
        src = ws.cell(r, 7)
        tgt = ws.cell(r, c)
        tgt._style = copy(src._style)
        tgt.number_format = src.number_format
        tgt.font = copy(src.font)
        tgt.fill = copy(src.fill)
        tgt.border = copy(src.border)
        tgt.alignment = copy(src.alignment)
        tgt.protection = copy(src.protection)

# Print written formulas
print("\nWritten formulas H6:P9:")
for r in target_rows:
    print([f"{ws.cell(r,c).coordinate}={ws.cell(r,c).value}" for c in target_cols])

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc, restore sheet names if needed
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    # rename by position back to originals
    for i, expected in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected
    wb_after.save(output_path)
    print("Restored sheet names to:", wb_after.sheetnames)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)

wsf = wb_formula["Summary"]
wsv = wb_values["Summary"]

print("\nVerification - formulas in H6:P9:")
for r in target_rows:
    print([f"{wsf.cell(r,c).coordinate}={wsf.cell(r,c).value}" for c in target_cols])

print("\nVerification - evaluated values in H6:P9:")
for r in target_rows:
    vals = [wsv.cell(r,c).value for c in target_cols]
    print(f"Row {r}:", vals)

print("\nVerification - totals Q6:Q9:")
for r in target_rows:
    print(
        f"Q{r} formula={wsf[f'Q{r}'].value} | value={wsv[f'Q{r}'].value}"
    )

# Basic sanity checks
problems = []
for r in target_rows:
    for c in target_cols:
        v = wsv.cell(r, c).value
        if v in (None, ""):
            problems.append(wsv.cell(r, c).coordinate)

print("\nBlank target cells after recalc:", problems if problems else "None")

output_spreadsheet = output_path
print("\nPrepared output file:", output_spreadsheet)
