from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook normally
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

print("Original sheet names:", original_sheet_names)
print("Target column check: C =", ws["C2"].value)
print("Source column check: B =", ws["B2"].value)

print("\nCurrent target/source rows before writing:")
for r in range(3, ws.max_row + 1):
    print(f"Row {r}: B{r}={ws[f'B{r}'].value!r} | C{r}={ws[f'C{r}'].value!r}")

# Write formulas only to blank cells in Column C where Column B has data
written = []
for r in range(3, ws.max_row + 1):
    src = ws.cell(r, 2).value  # column B
    tgt = ws.cell(r, 3).value  # column C
    if src not in (None, "") and tgt in (None, ""):
        formula = f'=IFERROR(MID(B{r},SEARCH("955",B{r}),10),IFERROR(MID(B{r},SEARCH("CHK",B{r}),10),""))'
        ws.cell(r, 3).value = formula
        written.append((r, formula))

print("\nFormulas written:")
for item in written:
    print(item)

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheet_names:
    # rename sheets back by position
    for i, orig_name in enumerate(original_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Verification: formula view
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]

print("\nVerification - formulas/values in target column C:")
for r in range(3, ws_formula.max_row + 1):
    print(f"Row {r}: B{r}={ws_formula[f'B{r}'].value!r} | C{r}={ws_formula[f'C{r}'].value!r}")

# Verification: evaluated values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("\nVerification - evaluated values in C3:C8:")
for r in range(3, ws_values.max_row + 1):
    print(f"C{r} -> {ws_values[f'C{r}'].value!r}")

# Keep path for submit
final_output_spreadsheet = output_path
