Code:
```repl
import os
import re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

def clean_preserve_numeric_and_decimal(value):
    # Preserve true numeric values exactly as-is
    if isinstance(value, (int, float)) and not isinstance(value, bool):
        return value
    # Clean text by keeping digits and decimal points only
    if isinstance(value, str):
        cleaned = re.sub(r"[^0-9.]", "", value)
        return cleaned
    return value

# Load and inspect target again before modification
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original target values:")
before = {}
for c in range(1, 9):
    coord = f"{get_column_letter(c)}1"
    val = ws[coord].value
    before[coord] = val
    print(coord, repr(val), type(val).__name__)

# Apply transformation to A1:H1
changes = {}
for c in range(1, 9):
    coord = f"{get_column_letter(c)}1"
    old_val = ws[coord].value
    new_val = clean_preserve_numeric_and_decimal(old_val)
    ws[coord] = new_val
    changes[coord] = (old_val, new_val)

print("\nApplied changes:")
for coord, (old_val, new_val) in changes.items():
    print(coord, "=>", repr(old_val), "->", repr(new_val))

# Save
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalculation and ensure sheet names match original
wb_post = load_workbook(output_path)
post_sheetnames = wb_post.sheetnames[:]
print("Sheet names after recalc reload:", post_sheetnames)

if post_sheetnames != orig_sheetnames:
    # Rename sheets back to original order/names if LibreOffice changed them
    if len(post_sheetnames) == len(orig_sheetnames):
        for ws_obj, original_name in zip(wb_post.worksheets, orig_sheetnames):
            ws_obj.title = original_name
        wb_post.save(output_path)
        print("Renamed sheets back to original names:", orig_sheetnames)
    else:
        print("Warning: sheet count changed unexpectedly.")

# Verification reloads
wb_verify = load_workbook(output_path, data_only=False)
ws_verify = wb_verify["Sheet1"]
wb_verify_values = load_workbook(output_path, data_only=True)
ws_verify_values = wb_verify_values["Sheet1"]

print("\nVerified final formulas/raw values in Sheet1!A1:H1:")
for c in range(1, 9):
    coord = f"{get_column_letter(c)}1"
    print(coord, repr(ws_verify[coord].value), type(ws_verify[coord].value).__name__)

print("\nVerified data_only values in Sheet1!A1:H1:")
for c in range(1, 9):
    coord = f"{get_column_letter(c)}1"
    print(coord, repr(ws_verify_values[coord].value), type(ws_verify_values[coord].value).__name__)

# Keep for submission
final_output_path = output_path
```
