import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws_whp = wb["WHP"]
ws_data = wb["WHP DATA"]

# Build lookup from WHP DATA by scanning rows that look like site rows:
# column B = site name, columns C:E = EEG, Dis, LTU
lookup = {}
source_rows_used = {}

for r in range(1, ws_data.max_row + 1):
    site = ws_data.cell(r, 2).value
    vals = [ws_data.cell(r, c).value for c in range(3, 6)]
    if (
        isinstance(site, str)
        and site.strip() not in ("", "Total", "Go Live 1/3/18", "Local London Partnership", "Central London Forward")
        and any(v is not None for v in vals)
    ):
        lookup[site.strip()] = tuple(vals)
        source_rows_used[site.strip()] = r

print("Source lookup built:")
for k in sorted(lookup):
    print(k, "->", lookup[k], "from row", source_rows_used[k])

# Inspect target rows again before writing
print("\nTarget rows before writing:")
target_rows = []
for r in range(7, ws_whp.max_row + 1):
    site = ws_whp.cell(r, 3).value
    label = ws_whp.cell(r, 4).value
    if site not in (None, ""):
        rowvals = [ws_whp.cell(r, c).value for c in range(3, 9)]
        print(f"row {r}: {rowvals}")
        target_rows.append(r)

# Fill missing E:G values based on matching site name
changes = []
for r in target_rows:
    site = ws_whp.cell(r, 3).value
    if isinstance(site, str):
        site_key = site.strip()
        if site_key in lookup:
            src_vals = lookup[site_key]  # EEG, Dis, LTU
            for i, col in enumerate(range(5, 8)):  # E:G
                cell = ws_whp.cell(r, col)
                old = cell.value
                new = src_vals[i]
                if old in (None, ""):
                    cell.value = new
                    changes.append((f"{get_column_letter(col)}{r}", old, new, site_key))
                else:
                    # Preserve existing plausible value; just report it
                    changes.append((f"{get_column_letter(col)}{r}", old, f"(preserved; source={new})", site_key))
        else:
            print(f"WARNING: site {site_key!r} not found in WHP DATA")

print("\nChanges / preservation log:")
for item in changes:
    print(item)

# Ensure H column formula exists for target rows
for r in target_rows:
    h = ws_whp.cell(r, 8)
    if h.value in (None, ""):
        h.value = f"=SUM(E{r}:G{r})"
        print(f"Set H{r} formula to {h.value}")
    else:
        print(f"Preserved H{r}: {h.value}")

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if needed
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed; restoring...")
    for i, orig_name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = orig_name
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)

# Verification with formulas cached
wb_verify = load_workbook(outfile, data_only=False)
wb_verify_vals = load_workbook(outfile, data_only=True)

print("\nFinal verification of target cells/formulas:")
for r in target_rows:
    formula_row = [wb_verify["WHP"].cell(r, c).value for c in range(3, 9)]
    value_row = [wb_verify_vals["WHP"].cell(r, c).value for c in range(3, 9)]
    print(f"Row {r} formulas/raw : {formula_row}")
    print(f"Row {r} data_only     : {value_row}")

print("\nExplicit target cell check:")
for coord in ["E7", "F7", "G7", "H7", "E8", "F8", "G8", "H8"]:
    raw = wb_verify["WHP"][coord].value
    val = wb_verify_vals["WHP"][coord].value
    print(coord, "raw=", raw, "cached=", val)

output_spreadsheet = outfile
