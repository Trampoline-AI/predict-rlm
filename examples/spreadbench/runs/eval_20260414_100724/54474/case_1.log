import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

wb = load_workbook(input_spreadsheet)
print("\nWorkbook loaded from:", input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def sheet_info(ws, sample_first=8, sample_last=5):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Header rows: inspect first 3 rows
    for r in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # Non-empty columns summary from row 1
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1 with letters:")
    print([(get_column_letter(c), headers[c-1]) for c in range(1, ws.max_column + 1)])
    
    # first rows
    print(f"First {min(sample_first, ws.max_row)} rows:")
    for r in range(1, min(sample_first, ws.max_row) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"{r}: {vals}")
    
    # last rows
    start_last = max(1, ws.max_row - sample_last + 1)
    print(f"Last rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"{r}: {vals}")

for ws in wb.worksheets:
    sheet_info(ws)

# Extra focused inspection for sheets containing WHP in name
for ws in wb.worksheets:
    if "whp" in ws.title.lower():
        print(f"\nFocused inspection for {ws.title}:")
        # Find rows with many non-empty cells near top
        for r in range(1, min(ws.max_row, 15) + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            nonempty = sum(v not in (None, "") for v in row_vals)
            print(f"row {r} nonempty={nonempty} vals={row_vals}")
