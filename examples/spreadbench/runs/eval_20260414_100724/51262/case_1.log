```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Confirm target cells before modification
print("Original formulas:")
for coord in ["F6", "G6", "H6"]:
    print(coord, ws[coord].value)

# Replace broken formulas with a range-aware formula
# Logic:
# - month start: DATE(YEAR(F5),MONTH(F5),1)
# - next month start: DATE(YEAR(F5),MONTH(F5)+1,1)
# - criteria membership: COUNTIF($F$10:$F$14,$C$6:$C$13)>0
for col in ["F", "G", "H"]:
    formula = (
        f'=SUMPRODUCT('
        f'($B$6:$B$13>=DATE(YEAR({col}5),MONTH({col}5),1))*'
        f'($B$6:$B$13<DATE(YEAR({col}5),MONTH({col}5)+1,1))*'
        f'(--(COUNTIF($F$10:$F$14,$C$6:$C$13)>0))*'
        f'$D$6:$D$13)'
    )
    ws[f"{col}6"] = formula

print("\nWritten formulas:")
for coord in ["F6", "G6", "H6"]:
    print(coord, ws[coord].value)

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheetnames:
    # rename by position back to original names
    for i, orig_name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas view
wb_formula = load_workbook(outfile)
ws_formula = wb_formula["Sheet1"]

print("\nVerified formulas after save/recalc:")
for coord in ["F6", "G6", "H6"]:
    print(coord, ws_formula[coord].value)

# Verify computed values
