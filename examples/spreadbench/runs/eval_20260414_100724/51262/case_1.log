        crit = ws.cell(r, 3).value
        val = ws.cell(r, 4).value
        if d is not None and start <= d < end and crit in crit_set:
            total += val or 0
            matching_rows.append((r, d, crit, val))
    expected[col] = (total, matching_rows)

print("\nExpected totals by month from Python:")
