import os, zipfile, shutil, tempfile
import xml.etree.ElementTree as ET
from openpyxl import load_workbook

outfile = output_spreadsheet_path

# Correct formulas and cached values
formula_map = {
    "F6": '=SUMPRODUCT(($B$6:$B$13>=DATE(YEAR(F5),MONTH(F5),1))*($B$6:$B$13<DATE(YEAR(F5),MONTH(F5)+1,1))*(--(COUNTIF($F$10:$F$14,$C$6:$C$13)>0))*$D$6:$D$13)',
    "G6": '=SUMPRODUCT(($B$6:$B$13>=DATE(YEAR(G5),MONTH(G5),1))*($B$6:$B$13<DATE(YEAR(G5),MONTH(G5)+1,1))*(--(COUNTIF($F$10:$F$14,$C$6:$C$13)>0))*$D$6:$D$13)',
    "H6": '=SUMPRODUCT(($B$6:$B$13>=DATE(YEAR(H5),MONTH(H5),1))*($B$6:$B$13<DATE(YEAR(H5),MONTH(H5)+1,1))*(--(COUNTIF($F$10:$F$14,$C$6:$C$13)>0))*$D$6:$D$13)',
}
cached_values = {"F6": "30", "G6": "20", "H6": "0"}

# Patch sheet XML directly so formulas + cached results both exist
ns = {"main": "http://schemas.openxmlformats.org/spreadsheetml/2006/main"}
ET.register_namespace("", ns["main"])

with zipfile.ZipFile(outfile, "r") as zin:
    files = {name: zin.read(name) for name in zin.namelist()}

sheet_xml_path = "xl/worksheets/sheet1.xml"
root = ET.fromstring(files[sheet_xml_path])

for coord, formula in formula_map.items():
    cell = root.find(f'.//main:c[@r="{coord}"]', ns)
    if cell is None:
        raise RuntimeError(f"Could not find cell {coord} in sheet XML")
    # formula cells should not be typed as numeric literals
    if "t" in cell.attrib:
        del cell.attrib["t"]
    # remove existing children
    for child in list(cell):
        cell.remove(child)
    # add formula and cached value
    f_el = ET.SubElement(cell, f'{{{ns["main"]}}}f')
    f_el.text = formula[1:] if formula.startswith("=") else formula
    v_el = ET.SubElement(cell, f'{{{ns["main"]}}}v')
    v_el.text = cached_values[coord]

files[sheet_xml_path] = ET.tostring(root, encoding="utf-8", xml_declaration=False)

tmpfile = outfile + ".tmp"
with zipfile.ZipFile(tmpfile, "w", zipfile.ZIP_DEFLATED) as zout:
    for name, data in files.items():
        zout.writestr(name, data)

os.replace(tmpfile, outfile)
print("Patched workbook XML to restore formulas with cached values.")

# Verify again
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)

print("Sheet names:", wb_formula.sheetnames)
wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

print("\nVerification of target cells:")
for coord in ["F6", "G6", "H6"]:
    print(coord, "formula_view=", wsf[coord].value, "data_only=", wsv[coord].value)

# Final XML spot-check
with zipfile.ZipFile(outfile, "r") as zf:
    sheet_xml = zf.read(sheet_xml_path).decode("utf-8", errors="ignore")
for coord in ["F6", "G6", "H6"]:
    start = sheet_xml.find(f'<c r="{coord}"')
    snippet = sheet_xml[start:start+350] if start != -1 else "NOT FOUND"
    print(f"\nXML snippet for {coord}:\n{snippet}")

# Keep submit path ready
output_spreadsheet_path = outfile
print("\nReady to submit:", output_spreadsheet_path)
```
