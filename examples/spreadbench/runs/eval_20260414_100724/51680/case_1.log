```repl
from openpyxl import load_workbook
from pathlib import Path
import os

# Load workbook
wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
ws = wb[original_sheet_names[0]]

# Determine exact target headers and compute expected strings
headers = []
for c in range(1, 7):  # A:F
    h = ws.cell(1, c).value
    h = h.strip() if isinstance(h, str) else h
    headers.append(h)

print("Using headers A:F:", headers)
print("Target output column:", ws.cell(1, 7).coordinate, ws.cell(1, 7).value)

changes = []
for r in range(2, ws.max_row + 1):
    selected = []
    for c in range(1, 7):
        v = ws.cell(r, c).value
        if isinstance(v, str) and v.strip().upper() == "Y":
            selected.append(headers[c-1])
    expected = ", ".join(selected)
    current = ws.cell(r, 7).value
    if current != expected:
        changes.append((r, current, expected))
    ws.cell(r, 7).value = expected

print("Rows updated/corrected:", len(changes))
for item in changes:
    print(f"Row {item[0]}: {item[1]!r} -> {item[2]!r}")

# Save to output path with same filename
out_dir = Path("/sandbox/output/output_spreadsheet")
out_dir.mkdir(parents=True, exist_ok=True)
output_path = str(out_dir / Path(input_spreadsheet).name)
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalc changed them
wb_check = load_workbook(output_path)
current_sheet_names = wb_check.sheetnames[:]
print("Sheet names after recalc:", current_sheet_names)

if current_sheet_names != original_sheet_names and len(current_sheet_names) == len(original_sheet_names):
    for i, old_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = old_name
    wb_check.save(output_path)
    print("Renamed sheets back to original names:", original_sheet_names)

# Verify using data_only workbook
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheet_names[0]]

verification = []
for r in range(2, wsv.max_row + 1):
    selected = []
    for c in range(1, 7):
        v = wsv.cell(r, c).value
        if isinstance(v, str) and v.strip().upper() == "Y":
            h = wsv.cell(1, c).value
            h = h.strip() if isinstance(h, str) else h
            selected.append(h)
    expected = ", ".join(selected)
    actual = wsv.cell(r, 7).value
    verification.append((r, actual, expected, actual == expected))

print("Verification G2:G14")
for row in verification:
    print(f"G{row[0]} = {row[1]!r} | expected {row[2]!r} | ok={row[3]}")

all_ok = all(x[3] for x in verification) and wb_verify.sheetnames == original_sheet_names
print("All verification checks passed:", all_ok)

# keep for submission
final_output_spreadsheet = output_path
```
