from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Font, Border, Alignment
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
ws = wb[wb.sheetnames[0]]

headers = [ws.cell(1, c).value for c in range(1, 7)]
headers_trimmed = [h.strip() if isinstance(h, str) else h for h in headers]
print("A:F headers raw:", headers)
print("A:F headers trimmed:", headers_trimmed)

def expected_join_for_row(r):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    chosen = []
    for c, v in enumerate(vals, start=1):
        if isinstance(v, str) and v.strip().upper() == "Y":
            chosen.append(headers_trimmed[c-1])
    return ", ".join(chosen)

print("\nRow-by-row current vs expected for G:")
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(1, 7)]
    current = ws.cell(r, 7).value
    expected = expected_join_for_row(r)
    status = "MATCH" if current == expected else ("BLANK" if current in (None, "") else "DIFF")
    print(f"Row {r}: A:F={vals} | G current={current!r} | expected={expected!r} | {status}")

print("\nColumn G style inspection rows 1:14")
for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 7)
