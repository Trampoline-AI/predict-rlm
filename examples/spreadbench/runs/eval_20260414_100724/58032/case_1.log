def cell_style_summary(cell):
    f = cell.font
    fill = cell.fill
    b = cell.border
    fill_color = None
    if fill and fill.fill_type:
        fill_color = fill.fgColor.rgb or fill.fgColor.indexed or fill.fgColor.type
    border_summary = {
        side: getattr(getattr(b, side), 'style', None)
        for side in ['left', 'right', 'top', 'bottom']
    }
    return {
        "value": cell.value,
        "font_name": f.name,
        "bold": f.bold,
        "italic": f.italic,
        "fill_type": fill.fill_type,
        "fill_color": fill_color,
        "border": border_summary,
    }

