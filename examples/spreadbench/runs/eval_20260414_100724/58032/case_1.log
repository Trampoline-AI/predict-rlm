import os
from copy import copy
from collections import Counter
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Border, Side

# Load and inspect exact target ranges
wb = load_workbook(input_spreadsheet)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", orig_sheetnames)
print("Sheet1 size:", ws.max_row, "rows x", ws.max_column, "cols")
print("Current gridlines:", ws.sheet_view.showGridLines)

left_rows = []
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 2).value not in (None, "") or ws.cell(r, 3).value not in (None, ""):
        left_rows.append(r)

right_rows = []
for r in range(2, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in (8, 9, 10)):
        right_rows.append(r)

print("Rows needing formulas in A based on B/C:", left_rows[:10], "...", left_rows[-5:], "count=", len(left_rows))
print("Lookup rows in H:J:", right_rows, "count=", len(right_rows))

lookup_last_row = max(right_rows) if right_rows else 2
print("Lookup range chosen:", f"H2:J{lookup_last_row}")

# Show a compact preview of relevant rows
print("\nPreview left-side rows (first 8 and last 5):")
preview_rows = left_rows[:8] + [r for r in left_rows[-5:] if r not in left_rows[:8]]
for r in preview_rows:
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

print("\nPreview lookup rows (all, since manageable):")
for r in right_rows:
    print(r, [ws.cell(r, c).value for c in range(8, 11)])

# Build Python lookup to understand expected results and detect duplicate keys
lookup = {}
pairs = []
for r in right_rows:
    name = ws.cell(r, 8).value
    title = ws.cell(r, 9).value
    dept = ws.cell(r, 10).value
    key = (title, dept)
    pairs.append(key)
    if title not in (None, "") and dept not in (None, "") and name not in (None, "") and key not in lookup:
        lookup[key] = name

dupes = [k for k, cnt in Counter(pairs).items() if cnt > 1 and k != (None, None)]
print("\nDuplicate lookup keys:", dupes)

expected_matches = []
expected_unmatched = []
for r in left_rows:
    key = (ws.cell(r, 2).value, ws.cell(r, 3).value)
    if key in lookup:
        expected_matches.append((r, lookup[key]))
    else:
        expected_unmatched.append(r)

print("Expected matched rows count:", len(expected_matches))
print("First expected matches:", expected_matches[:10])
print("Expected unmatched rows count:", len(expected_unmatched))
print("First unmatched rows:", expected_unmatched[:10])

# Pre-modification target checks
print("\nBefore modification target cells:")
for coord in ["A2", "A3", "D2", "D3"]:
    cell = ws[coord]
    fill_rgb = cell.fill.fgColor.rgb if cell.fill and cell.fill.fill_type else None
    print(coord, "value=", cell.value, "fill=", fill_rgb, "font=", cell.font.name)

# Apply requested formatting
thin = Side(style="thin", color="FF000000")
header_border = Border(left=thin, right=thin, top=thin, bottom=thin)
gray_fill = PatternFill(fill_type="solid", fgColor="FFCCCCCC")
formula_fill = PatternFill(fill_type="solid", fgColor="FFFCD5B4")

# Use Arial across used range while preserving other font attributes
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(r, c)
        new_font = copy(cell.font)
        new_font.name = "Arial"
        cell.font = new_font

# Row 1 titles: bold, italic, bordered
for c in range(1, ws.max_column + 1):
    cell = ws.cell(1, c)
    new_font = copy(cell.font)
    new_font.name = "Arial"
    new_font.bold = True
    new_font.italic = True
    cell.font = new_font
    cell.border = header_border

# Column D fill from D2 downward through used rows
for r in range(2, ws.max_row + 1):
    ws.cell(r, 4).fill = gray_fill

# Write formulas in column A for all relevant left-side rows
# Formula: return Name from H based on matching Title in I and Department Code in J
for r in left_rows:
    formula = (
        f'=IF(OR(B{r}="",C{r}=""),"",'
        f'IFERROR(INDEX($H$2:$H${lookup_last_row},'
        f'SUMPRODUCT(($I$2:$I${lookup_last_row}=B{r})*($J$2:$J${lookup_last_row}=C{r})*ROW($H$2:$H${lookup_last_row}))'
        f'-ROW($H$2)+1),""))'
    )
    ws.cell(r, 1).value = formula
    ws.cell(r, 1).fill = formula_fill

# Keep Arial font on formula cells explicitly
for r in left_rows:
    cell = ws.cell(r, 1)
    new_font = copy(cell.font)
    new_font.name = "Arial"
    cell.font = new_font

# Hide gridlines
ws.sheet_view.showGridLines = False

# Save output
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Ensure sheet names preserved after recalc
wb_post = load_workbook(out_path)
print("Sheet names after recalc/reload:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    mapping = list(zip(wb_post.sheetnames, orig_sheetnames))
    print("Renaming sheets back:", mapping)
    for actual, expected in mapping:
        wb_post[actual].title = expected
    wb_post.save(out_path)
    wb_post = load_workbook(out_path)
print("Final sheet names:", wb_post.sheetnames)

# Verification with cached values
wb_val = load_workbook(out_path, data_only=True)
ws_val = wb_val["Sheet1"]

print("\nVerification:")
print("Gridlines shown:", ws_val.sheet_view.showGridLines)
print("A2 formula cached value:", ws_val["A2"].value)
print("Sample verified row outputs (first 10 left rows and last 5):")
verify_rows = left_rows[:10] + [r for r in left_rows[-5:] if r not in left_rows[:10]]
for r in verify_rows:
    print(
        r,
        {
            "A_cached": ws_val.cell(r, 1).value,
            "B": ws_val.cell(r, 2).value,
            "C": ws_val.cell(r, 3).value,
            "D_fill_expected": "CCCCCC",
        }
    )

# Also inspect formula strings/styles from non-data_only workbook
ws_chk = wb_post["Sheet1"]
print("\nFormula/style checks:")
for coord in ["A2", "A3", f"A{left_rows[-1]}", "D2", f"D{ws.max_row}", "A1", "D1", "I1", "J1"]:
    cell = ws_chk[coord]
    fill_rgb = cell.fill.fgColor.rgb if cell.fill and cell.fill.fill_type else None
    print(
        coord,
        {
            "value": cell.value,
            "fill": fill_rgb,
            "font_name": cell.font.name,
            "bold": cell.font.bold,
            "italic": cell.font.italic,
            "border": {
                "left": cell.border.left.style,
                "right": cell.border.right.style,
                "top": cell.border.top.style,
                "bottom": cell.border.bottom.style,
            },
        }
    )

# Keep output path for submission
final_output_spreadsheet = out_path
print("\nPrepared output file:", final_output_spreadsheet)
