from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook normally
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Cumulative"]

# Identify and print target cells before modification
print("Target cells before write:")
for r in range(2, 12):
    print(f"I{r}:", ws[f"I{r}"].value, " | year in G:", ws[f"G{r}"].value)

# Write formulas only into the designated output cells in column I, preserving formatting
for r in range(2, 12):
    year_cell = f"G{r}"
    target = ws[f"I{r}"]
    target.value = f'=COUNTIFS($G$14:$G$185,{year_cell},$J$14:$J$185,"Open")'

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    # rename sheets by position back to originals
    for idx, name in enumerate(orig_sheetnames):
        wb_check.worksheets[idx].title = name
    wb_check.save(output_path)
    wb_check = load_workbook(output_path)

print("Final sheet names:", wb_check.sheetnames)

# Verify formulas in target cells
ws_formula = wb_check["Cumulative"]
print("\nFormulas now in I2:I11:")
for r in range(2, 12):
    print(f"I{r}:", ws_formula[f"I{r}"].value)

# Verify formatting in column I preserved
print("\nStyle verification for I2:I11:")
for r in range(2, 12):
    c = ws_formula[f"I{r}"]
    print(
        c.coordinate,
        "style_id=", c.style_id,
        "fill=", c.fill.fill_type, c.fill.fgColor.rgb,
        "bold=", c.font.bold,
        "align=", c.alignment.horizontal
    )

# Load data_only workbook to verify evaluated results
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Cumulative"]

print("\nEvaluated values in I2:I11:")
evaluated = {}
for r in range(2, 12):
    yr = ws_values[f"G{r}"].value
    val = ws_values[f"I{r}"].value
    evaluated[r] = (yr, val)
    print(f"Row {r}: Year={yr}, I{r}={val}")

# Also compute expected open counts directly from source data for sanity check
expected = {}
for r in range(14, 186):
    y = ws_values[f"G{r}"].value
    status = ws_values[f"J{r}"].value
    if y not in (None, ""):
        expected.setdefault(y, 0)
        if isinstance(status, str) and status.strip().lower() == "open":
            expected[y] += 1

print("\nExpected open counts from source rows 14:185:")
for y in sorted(expected):
    print(y, expected[y])

print("\nComparison of written results vs expected:")
for r in range(2, 12):
    year = ws_values[f"G{r}"].value
    print(f"Year {year}: formula result={ws_values[f'I{r}'].value}, expected={expected.get(year, 0)}")
