def row_values(ws, r, start=1, end=None):
    if end is None:
        end = ws.max_column
    vals = []
    for c in range(start, end + 1):
        vals.append(ws.cell(r, c).value)
    return vals

for ws in wb.worksheets:
    print("\n=== SHEET:", ws.title, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Find likely header row among first 15 rows by non-empty count
    best_rows = []
    for r in range(1, min(15, ws.max_row) + 1):
        vals = row_values(ws, r)
        nonempty = sum(v is not None and v != "" for v in vals)
        best_rows.append((r, nonempty, vals[:min(12, ws.max_column)]))
    print("Top candidate header-ish rows (row, nonempty, first 12 vals):")
    for item in best_rows:
