```repl
import os
import re
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

numeric_re = re.compile(r'^\d+$')

def is_pure_numeric_value(v):
    if v is None or v == "":
        return False
    if isinstance(v, bool):
        return False
    if isinstance(v, (int, float)):
        return True
    if isinstance(v, str):
        return bool(numeric_re.fullmatch(v.strip()))
    return False

# Load and inspect again right before modification
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Data"]

start_col, end_col = 21, 35  # U:AI
header_row = 2

# Find last actual data row within U:AI below headers
last_data_row = header_row
for r in range(header_row + 1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(start_col, end_col + 1)]
    if any(v is not None and v != "" for v in vals):
        last_data_row = r

print("Original sheetnames:", original_sheetnames)
print("Target range determined:", f"{get_column_letter(start_col)}{header_row+1}:{get_column_letter(end_col)}{last_data_row}")
print("Header row values:", [ws.cell(header_row, c).value for c in range(start_col, end_col + 1)])

# Print a few target cells before change
print("\nSample before change:")
for r in list(range(3, min(8, last_data_row + 1))) + list(range(max(3, last_data_row - 2), last_data_row + 1)):
    print(r, [ws.cell(r, c).value for c in range(start_col, end_col + 1)])

modified = 0
preserved_numeric = 0
preserved_blank = 0
modified_cells = []

for r in range(header_row + 1, last_data_row + 1):
    for c in range(start_col, end_col + 1):
        cell = ws.cell(r, c)
        v = cell.value
        if v is None or v == "":
            preserved_blank += 1
            continue
        if is_pure_numeric_value(v):
            preserved_numeric += 1
            continue
        if len(modified_cells) < 30:
            modified_cells.append((cell.coordinate, v))
        cell.value = 0
        modified += 1

print("\nCounts before save:")
print("modified -> 0:", modified)
print("preserved numeric:", preserved_numeric)
print("preserved blank:", preserved_blank)
print("Example modified cells:", modified_cells[:15])

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check if recalculate renamed sheets; if so, restore original names
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    if len(wb_after.sheetnames) == len(original_sheetnames):
        for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
            ws_obj.title = orig_name
        wb_after.save(output_path)
        print("Restored original sheet names:", original_sheetnames)
    else:
        print("Warning: sheetname count changed unexpectedly")

# Verify output values after recalc
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheetnames:", wb_verify.sheetnames)
wsv = wb_verify["Data"]

bad_cells = []
nonzero_cells = []
none_cells = []

for r in range(header_row + 1, last_data_row + 1):
    for c in range(start_col, end_col + 1):
        coord = f"{get_column_letter(c)}{r}"
        v = wsv.cell(r, c).value
        if v is None:
            none_cells.append(coord)
        elif v != 0:
            nonzero_cells.append((coord, v))

print("\nVerification summary:")
print("None cells in target area:", len(none_cells), none_cells[:10])
print("Non-zero cells in target area:", len(nonzero_cells), nonzero_cells[:10])

print("\nSample after change (data_only):")
for r in list(range(3, min(8, last_data_row + 1))) + list(range(max(3, last_data_row - 2), last_data_row + 1)):
    print(r, [wsv.cell(r, c).value for c in range(start_col, end_col + 1)])

# Also verify blank rows below data remain blank
print("\nRows below target data area (should remain blank in U:AI):")
for r in range(last_data_row + 1, ws.max_row + 1):
    vals = [wsv.cell(r, c).value for c in range(start_col, end_col + 1)]
    print(r, vals)

final_output_spreadsheet = output_path
print("\nPrepared output:", final_output_spreadsheet)
