from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import re, os

wb = load_workbook(input_spreadsheet)
ws = wb["Data"]

print("Sheet title:", ws.title)
print("max_row/max_col:", ws.max_row, ws.max_column)

# Show exact non-empty coordinates by row/column bounds
nonempty_cells = []
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        v = ws.cell(r, c).value
        if v is not None:
            nonempty_cells.append((r, c, v))

rows = sorted(set(r for r, c, v in nonempty_cells))
cols = sorted(set(c for r, c, v in nonempty_cells))
print("Non-empty row range:", rows[:5], "...", rows[-5:], "count=", len(rows))
print("Non-empty col range:", [(c, get_column_letter(c)) for c in cols], "count=", len(cols))

print("\nNon-empty columns with row 2 headers:")
for c in cols:
    print(c, get_column_letter(c), "header row2 =", ws.cell(2, c).value)

# Print rows 1-23 but only non-empty columns U:AI area if that's the active block
start_c, end_c = min(cols), max(cols)
print(f"\nInspecting rows 1:{ws.max_row}, cols {get_column_letter(start_c)}:{get_column_letter(end_c)}")
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(start_c, end_c + 1)]
    if any(v is not None for v in vals):
        print(f"Row {r}: {vals}")

# Classify cells in data area below headers
numeric_re = re.compile(r'^\d+$')  # pure digits only
stats = {"blank": 0, "pure_digits_str": 0, "numeric_type": 0, "non_numeric": 0}
examples = {"pure_digits_str": [], "numeric_type": [], "non_numeric": []}

for r in range(3, ws.max_row + 1):
    for c in range(start_c, end_c + 1):
        v = ws.cell(r, c).value
        if v is None or v == "":
            stats["blank"] += 1
        elif isinstance(v, (int, float)) and not isinstance(v, bool):
            stats["numeric_type"] += 1
            if len(examples["numeric_type"]) < 10:
                examples["numeric_type"].append((f"{get_column_letter(c)}{r}", v, type(v).__name__))
        elif isinstance(v, str) and numeric_re.fullmatch(v.strip()):
            stats["pure_digits_str"] += 1
            if len(examples["pure_digits_str"]) < 10:
                examples["pure_digits_str"].append((f"{get_column_letter(c)}{r}", v))
        else:
            stats["non_numeric"] += 1
            if len(examples["non_numeric"]) < 20:
                examples["non_numeric"].append((f"{get_column_letter(c)}{r}", v))

print("\nClassification stats for data area rows 3:end:")
