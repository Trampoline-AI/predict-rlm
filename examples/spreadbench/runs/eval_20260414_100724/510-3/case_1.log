```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, re, shutil

# Paths
infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Load original workbook
wb = load_workbook(infile, data_only=False)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Data"]

print("Original sheet names:", orig_sheet_names)
print("Target sheet:", ws.title, "rows:", ws.max_row, "cols:", ws.max_column)

# Helper to strip hidden bidi chars
def clean_text(v):
    if v is None:
        return None
    s = str(v)
    for ch in ("\u202d", "\u202c", "\u200e", "\u200f", "\ufeff"):
        s = s.replace(ch, "")
    return s.strip()

# Inspect target cells before modification
print("\nBefore modification - sample D:H rows:")
sample_rows = list(range(1, min(ws.max_row, 8) + 1)) + list(range(max(2, ws.max_row - 4), ws.max_row + 1))
seen = set()
for r in sample_rows:
    if r in seen:
        continue
    seen.add(r)
    print(f"R{r}:", [ws.cell(r, c).value for c in range(4, 9)])

# Capture existing number formats for D:G to preserve exactly
numfmts = {}
for c in range(4, 8):
    numfmts[c] = {r: ws.cell(r, c).number_format for r in range(1, ws.max_row + 1)}

# Ensure headers are correct and not bold
headers = {4: "Data", 5: "Year", 6: "Month", 7: "Day", 8: "Sum"}
for c, hdr in headers.items():
    ws.cell(1, c).value = hdr
    # keep existing style but explicitly ensure not bold per instruction
    ws.cell(1, c).font = ws.cell(1, c).font.copy(bold=False)

# Parse and rewrite rows 2:max_row
parsed_rows = []
for r in range(2, ws.max_row + 1):
    raw_d = ws.cell(r, 4).value
    cleaned_d = clean_text(raw_d)
    m = re.fullmatch(r"(\d{2})/(\d{2})/(\d{2})", cleaned_d or "")
    if not m:
        raise ValueError(f"Could not parse Data!D{r}: raw={raw_d!r}, cleaned={cleaned_d!r}")
    y, mo, d = map(int, m.groups())
    total = y * 365 + mo * 12 + d

    # Rewrite values in place to preserve styles/layout
    ws.cell(r, 4).value = f"{y:02d}/{mo:02d}/{d:02d}"  # clean text version
    ws.cell(r, 5).value = y
    ws.cell(r, 6).value = mo
    ws.cell(r, 7).value = d
    ws.cell(r, 8).value = total

    parsed_rows.append((r, y, mo, d, total))

# Restore exact number formats in D:G
for c in range(4, 8):
    for r in range(1, ws.max_row + 1):
        ws.cell(r, c).number_format = numfmts[c][r]

# H is also General in source; keep it that way for consistency
for r in range(1, ws.max_row + 1):
    ws.cell(r, 8).number_format = ws.cell(r, 8).number_format or "General"

# Save
wb.save(outfile)
print("\nSaved modified workbook to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_post = load_workbook(outfile, data_only=False)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names:
    # Rename sheets positionally back to original names
    for ws_post, orig_name in zip(wb_post.worksheets, orig_sheet_names):
        ws_post.title = orig_name
    wb_post.save(outfile)
    print("Restored original sheet names and re-saved.")
else:
    print("Sheet names unchanged after recalc.")

# Verification reloads
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)
wsf = wb_formula["Data"]
wsv = wb_values["Data"]

print("\nVerification - target headers D:H:")
print([wsf.cell(1, c).value for c in range(4, 9)])
print("Header bold flags:", [wsf.cell(1, c).font.bold for c in range(4, 9)])

print("\nVerification - sample rows D:H (formula workbook):")
rows_to_check = list(range(2, min(wsf.max_row, 10) + 1)) + list(range(max(2, wsf.max_row - 4), wsf.max_row + 1))
seen = set()
for r in rows_to_check:
    if r in seen:
        continue
    seen.add(r)
    vals = [wsf.cell(r, c).value for c in range(4, 9)]
    print(f"R{r}: {vals}")

print("\nVerification - sample rows D:H (data_only workbook):")
seen = set()
for r in rows_to_check:
    if r in seen:
        continue
    seen.add(r)
    vals = [wsv.cell(r, c).value for c in range(4, 9)]
    print(f"R{r}: {vals}")

# Strong verification across all data rows
problems = []
for r in range(2, wsv.max_row + 1):
    d_txt = wsv.cell(r, 4).value
    y = wsv.cell(r, 5).value
    mo = wsv.cell(r, 6).value
    d = wsv.cell(r, 7).value
    total = wsv.cell(r, 8).value

    if any(v is None for v in (d_txt, y, mo, d, total)):
        problems.append((r, "None found", d_txt, y, mo, d, total))
        continue

    exp = int(y) * 365 + int(mo) * 12 + int(d)
    if total != exp:
        problems.append((r, "Sum mismatch", d_txt, y, mo, d, total, exp))

print("\nTotal parsed rows:", len(parsed_rows))
print("Verification problems:", len(problems))
if problems[:10]:
    print("Problem samples:", problems[:10])

# Print exact target cell values requested by instruction context
print("\nExact target cell checks:")
for coord in ["D2","E2","F2","G2","H2","D10","E10","F10","G10","H10",f"D{wsv.max_row}",f"E{wsv.max_row}",f"F{wsv.max_row}",f"G{wsv.max_row}",f"H{wsv.max_row}"]:
    print(coord, "=", wsv[coord].value)

output_spreadsheet = outfile
print("\nPrepared output_spreadsheet:", output_spreadsheet)
