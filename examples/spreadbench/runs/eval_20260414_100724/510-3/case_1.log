def sheet_used_range(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # scan for actual non-empty bounds
    last_row = 0
    last_col = 0
    for row in ws.iter_rows():
        row_has = False
        for cell in row:
            if cell.value is not None:
                row_has = True
                last_col = max(last_col, cell.column)
        if row_has:
            last_row = row[0].row
    return last_row or max_row, last_col or max_col

