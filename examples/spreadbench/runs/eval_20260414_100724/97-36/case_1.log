import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Workbook:", input_spreadsheet)
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

# Inspect each sheet
inspection = {}
for ws in wb.worksheets:
    info = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "first_rows": [],
        "last_rows": [],
    }
    print(f"\n=== Sheet: {ws.title} ===")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    
    # Print first 10 rows
    first_n = min(10, ws.max_row)
    print("First rows:")
    for r in range(1, first_n + 1):
        vals = row_values(ws, r, ws.max_column)
        info["first_rows"].append(vals)
        print(f"Row {r}: {vals}")
    
    # Print last 5 rows (avoid duplicates)
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = row_values(ws, r, ws.max_column)
        info["last_rows"].append((r, vals))
        print(f"Row {r}: {vals}")
    
    inspection[ws.title] = info

# Search for "domestic" case-insensitive across workbook and specifically in column A
matches = []
matches_col_a = []
for ws in wb.worksheets:
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and "domestic" in v.lower():
                matches.append((ws.title, r, c, v))
                if c == 1:
                    matches_col_a.append((ws.title, r, c, v))

print("\nAll matches for 'domestic':")
for m in matches[:50]:
    print(m)
print("Total matches:", len(matches))

print("\nMatches in column A only:")
for m in matches_col_a[:50]:
    print(m)
print("Total matches in column A:", len(matches_col_a))

# Earliest match in workbook reading order
earliest = matches[0] if matches else None
earliest_a = matches_col_a[0] if matches_col_a else None
print("\nEarliest match anywhere:", earliest)
print("Earliest match in column A:", earliest_a)

# Print nearby context for earliest relevant matches
for label, m in [("anywhere", earliest), ("column_A", earliest_a)]:
    if m:
        sheet, r, c, v = m
        ws = wb[sheet]
        print(f"\nContext around earliest {label} match: {m}")
        for rr in range(max(1, r-3), min(ws.max_row, r+3) + 1):
            vals = row_values(ws, rr, ws.max_column)
            marker = " <-- match row" if rr == r else ""
            print(f"Row {rr}: {vals}{marker}")
