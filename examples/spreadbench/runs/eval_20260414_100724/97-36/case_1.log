import os
from openpyxl import load_workbook

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

search_text = "domestic"

# Reload fresh workbook for modification
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]

# Find earliest match in row-major workbook order
found = None
for ws in wb.worksheets:
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and search_text.lower() in v.lower():
                found = (ws.title, r, c, v)
                break
        if found:
            break
    if found:
        break

print("Found match:", found)

if found is None:
    raise ValueError(f"No cell contains substring {search_text!r}")

sheet_name, found_row, found_col, found_value = found
ws = wb[sheet_name]

# Print exact target area before modification
print(f"Before deletion: sheet={sheet_name}, max_row={ws.max_row}, max_col={ws.max_column}")
for rr in range(max(1, found_row - 3), min(ws.max_row, found_row + 3) + 1):
    print("Pre", rr, [ws.cell(rr, cc).value for cc in range(1, ws.max_column + 1)])

# Delete all rows above the found row
rows_to_delete = found_row - 1
if rows_to_delete > 0:
    ws.delete_rows(1, rows_to_delete)

print(f"Deleted rows 1:{rows_to_delete}" if rows_to_delete > 0 else "No rows deleted (match already in row 1)")
print(f"After deletion (in-memory): max_row={ws.max_row}, max_col={ws.max_column}")
for rr in range(1, min(5, ws.max_row) + 1):
    print("Post", rr, [ws.cell(rr, cc).value for cc in range(1, ws.max_column + 1)])
for rr in range(max(1, ws.max_row - 4), ws.max_row + 1):
    print("Post tail", rr, [ws.cell(rr, cc).value for cc in range(1, ws.max_column + 1)])

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate as required
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheet_names:
    # Rename back by position
    if len(wb_check.sheetnames) == len(original_sheet_names):
        for i, expected_name in enumerate(original_sheet_names):
            wb_check.worksheets[i].title = expected_name
        wb_check.save(output_path)
        print("Renamed sheets back to original names:", original_sheet_names)
    else:
        raise ValueError(f"Sheet count changed after recalc: {wb_check.sheetnames} vs {original_sheet_names}")

# Verification with data_only
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

vws = wb_verify[sheet_name]
print(f"Verified dimensions: {vws.max_row} rows x {vws.max_column} cols")

# Print all remaining rows since sheet is small
remaining_rows = []
for r in range(1, vws.max_row + 1):
    vals = [vws.cell(r, c).value for c in range(1, vws.max_column + 1)]
    remaining_rows.append(vals)
    print(f"Verified row {r}: {vals}")

# Key target verification
print("Target A1:", vws["A1"].value)
assert isinstance(vws["A1"].value, str) and search_text in vws["A1"].value.lower(), "A1 should contain the domestic row after deletion"

# Store for submission
final_output_path = output_path
