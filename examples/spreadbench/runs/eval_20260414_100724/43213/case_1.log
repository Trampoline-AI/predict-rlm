import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook normally for editing
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Blad1"]

# Determine true last non-empty row based on data in the sheet
last_nonempty_row = 0
for r in range(ws.max_row, 0, -1):
    if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
        last_nonempty_row = r
        break

print("Original sheetnames:", original_sheetnames)
print("Writing running average formulas in column B, rows 11 to", last_nonempty_row)

# Print current target area before modification
for r in range(11, last_nonempty_row + 1):
    print(f"Before row {r}: A{r}={ws[f'A{r}'].value!r}, B{r}={ws[f'B{r}'].value!r}")

# Fill formulas in existing Average column
for r in range(11, last_nonempty_row + 1):
    if ws[f"A{r}"].value is not None:
        ws[f"B{r}"] = f"=ROUND(AVERAGE($A$11:A{r}),3)"
        ws[f"B{r}"].number_format = "0.000"

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # Rename sheets positionally back to original names
    for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas exist
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("Formulas written in target cells:")
for r in range(11, last_nonempty_row + 1):
    print(f"B{r} formula:", ws_formula[f"B{r}"].value)

# Verify computed values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("Verified recalculated values:")
for r in range(11, last_nonempty_row + 1):
    print(f"B{r} value:", ws_values[f"B{r}"].value)

# Basic sanity checks
verification = {}
for r in range(11, last_nonempty_row + 1):
    verification[f"B{r}"] = ws_values[f"B{r}"].value
print("Verification summary:", verification)

final_output_path = output_path
