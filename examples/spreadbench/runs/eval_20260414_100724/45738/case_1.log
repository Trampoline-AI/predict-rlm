```repl
import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

# Re-open and do final compact inspection before writing
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Sheet dimensions:", ws.title, ws.max_row, ws.max_column)
print("Target headers E4:AB4:", [(get_column_letter(c), ws.cell(4, c).value) for c in range(5, 29)])

# Show formula templates from lower rows to confirm intended pattern
for r in [27, 28, 39]:
    vals = []
    for c in [5, 6, 17, 24, 27, 28]:
        v = ws.cell(r, c).value
        vals.append((f"{get_column_letter(c)}{r}", v))
    print(f"Template row {r} sample:", vals)

print("Pre-write examples in target area:")
for r in range(6, 11):
    nonempty = {get_column_letter(c): ws.cell(r, c).value for c in range(5, 29) if ws.cell(r, c).value not in (None, "")}
    print(f"r{r}:", nonempty)

print("Style check before write:",
      "E6 numfmt", ws["E6"].number_format,
      "E6 align", (ws["E6"].alignment.horizontal, ws["E6"].alignment.vertical),
      "L6 numfmt", ws["L6"].number_format)

# Write "-" in row 5 across E:AB
for c in range(5, 29):
    ws.cell(5, c).value = "-"

# Write formulas in E6:AB25
# Logic:
# - Use maturity month-end as the payment anchor.
# - Monthly header is a payment month if:
#     header <= maturity month-end
#     and months difference between header and maturity month-end is a multiple of 12/frequency.
# - If payment month is maturity month => principal + interest
# - Else => interest
# - Else => "-"
for r in range(6, 26):
    for c in range(5, 29):
        col = get_column_letter(c)
        formula = (
            f'=IF(AND({col}$4<=EOMONTH($D{r},0),'
            f'MOD((YEAR(EOMONTH($D{r},0))-YEAR({col}$4))*12+MONTH(EOMONTH($D{r},0))-MONTH({col}$4),12/$C{r})=0),'
            f'IF({col}$4=EOMONTH($D{r},0),$A{r}+$B{r},$B{r}),"-")'
        )
        ws.cell(r, c).value = formula
        # center align while preserving other formatting by copying current alignment and changing only horiz/vert
        old_alignment = ws.cell(r, c).alignment
        ws.cell(r, c).alignment = copy(old_alignment)
        ws.cell(r, c).alignment = Alignment(
            horizontal="center",
            vertical="center",
            text_rotation=old_alignment.text_rotation,
            wrap_text=old_alignment.wrap_text,
            shrink_to_fit=old_alignment.shrink_to_fit,
            indent=old_alignment.indent,
        )

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# After recalc, restore original sheet names if changed
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheet_names:
    # Rename sheets back by position
    for idx, orig_name in enumerate(orig_sheet_names):
        wb_post.worksheets[idx].title = orig_name
    wb_post.save(output_path)
    print("Renamed sheets back to:", orig_sheet_names)
else:
    print("Sheet names unchanged.")

# Verify output values after recalculation
wbv = load_workbook(output_path, data_only=True)
wsv = wbv[orig_sheet_names[0]]

print("Verified sheet names:", wbv.sheetnames)

# Verify row 5
print("Verified E5:AB5:", {get_column_letter(c): wsv.cell(5, c).value for c in range(5, 29)})

# Verify representative rows
for r in [6, 7, 9, 13, 17, 22, 25]:
    row_vals = {get_column_letter(c): wsv.cell(r, c).value for c in range(5, 29)}
    non_dash = {k: v for k, v in row_vals.items() if v != "-"}
    print(f"Row {r} non-dash values:", non_dash)

# Print a few exact formula strings from the saved file (not data_only)
wbf = load_workbook(output_path, data_only=False)
wsf = wbf[orig_sheet_names[0]]
for coord in ["E6", "L6", "X6", "O7", "AA7", "F13", "L13", "R13", "E22", "I22", "O22"]:
    print(coord, "formula/value:", wsf[coord].value)

# Verify alignment of a few cells
for coord in ["E6", "L6", "AB25"]:
    a = wsf[coord].alignment
    print(coord, "alignment:", a.horizontal, a.vertical)

# Basic sanity checks for blanks/errors in target range
none_cells = []
for r in range(5, 26):
    for c in range(5, 29):
        if wsv.cell(r, c).value is None:
            none_cells.append(f"{get_column_letter(c)}{r}")
print("None cells in E5:AB25:", none_cells[:20], "count=", len(none_cells))
print("Output exists:", os.path.exists(output_path), "size=", os.path.getsize(output_path))
