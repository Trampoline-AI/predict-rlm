import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path:", input_path, "exists:", os.path.exists(input_path))

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def row_values(ws, r, start=1, end=None):
    end = end or ws.max_column
    return [ws.cell(r, c).value for c in range(start, end+1)]

for s in wb.sheetnames:
    ws = wb[s]
    headers1 = row_values(ws, 1, 1, min(ws.max_column, 12))
    headers2 = row_values(ws, 2, 1, min(ws.max_column, 12))
    print(f"\nSheet '{s}': rows={ws.max_row}, cols={ws.max_column}")
    print("Row1 first cols:", headers1)
    print("Row2 first cols:", headers2)

    # print first 10 and last 5 rows, capped to first 12 cols for visibility
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    seen = []
    for r in first_rows + last_rows:
        if r not in seen:
            seen.append(r)
    for r in seen:
        vals = row_values(ws, r, 1, min(ws.max_column, 12))
        print(f"r{r}: {vals}")

# Inspect likely target sheet in more detail: first sheet
