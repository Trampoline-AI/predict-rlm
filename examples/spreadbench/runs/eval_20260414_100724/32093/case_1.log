import os
from openpyxl import load_workbook

# Re-inspect the exact target area before writing
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Target sheet:", ws.title)
print("Rows to process:", ws.max_row)
print("Headers A:H:", [ws.cell(1, c).value for c in range(1, 9)])

print("\nCurrent B:H rows 2:last before writing:")
for r in range(2, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(2, 9)]
    print(f"Row {r}: {vals}")

# Write formula to existing output column F for all populated data rows
for r in range(2, ws.max_row + 1):
    # Only process rows that actually have record data
    if any(ws.cell(r, c).value not in (None, "") for c in range(1, 6)):
        formula = f'=IF(COUNTA(C{r}:E{r})=0,B{r},IF(COUNTA(C{r}:E{r})>1,"ERROR",IF(C{r}<>"",C{r},IF(D{r}<>"",D{r},E{r}))))'
        ws.cell(r, 6).value = formula

# Save with same filename in output directory
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Check for sheet-name changes after recalculation
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != wb.sheetnames:
    # rename back to original names in order
    for s, original_name in zip(wb_after.worksheets, wb.sheetnames):
        s.title = original_name
    wb_after.save(output_path)
    print("Renamed sheets back to:", wb.sheetnames)

# Verify formulas and evaluated results
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nVerification of F2:F15:")
verification = []
for r in range(2, ws_values.max_row + 1):
    formula = ws_formula.cell(r, 6).value
    value = ws_values.cell(r, 6).value
    row_context = [ws_values.cell(r, c).value for c in range(2, 6)]  # B:E
    verification.append((r, row_context, formula, value))
    print(f"Row {r} | B:E={row_context} | Formula={formula} | Evaluated F={value}")

# Keep path for submit
final_output_path = output_path
