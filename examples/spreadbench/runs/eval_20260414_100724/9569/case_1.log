```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Confirm structure
header_row = 8
contract_col = column_index_from_string("B")
start_m = column_index_from_string("E")
end_m = column_index_from_string("AN")
target_col = column_index_from_string("AO")

print("Original sheet names:", orig_sheetnames)
print("Using sheet:", ws.title)
print("Header row:", header_row)
print("Target header AO8:", ws.cell(header_row, target_col).value)
print("Source month columns:", get_column_letter(start_m), "to", get_column_letter(end_m))

data_rows = [r for r in range(header_row + 1, ws.max_row + 1) if ws.cell(r, contract_col).value not in (None, "")]
print("Data rows to fill:", len(data_rows), "from", data_rows[0], "to", data_rows[-1])

# Build a non-array nested IF formula that returns the first non-zero value in E:AN
month_letters = [get_column_letter(c) for c in range(start_m, end_m + 1)]

def earliest_nonzero_formula(row_num):
    expr = '""'
    for col_letter in reversed(month_letters):
        expr = f'IF({col_letter}{row_num}<>0,{col_letter}{row_num},{expr})'
    return f'={expr}'

# Optional Python expectation for verification
def python_first_nonzero(row_num):
    for c in range(start_m, end_m + 1):
        v = ws.cell(row_num, c).value
        if isinstance(v, (int, float)) and v != 0:
            return v
    return None

# Write formulas into AO for all populated rows
sample_formulas = []
for r in data_rows:
    formula = earliest_nonzero_formula(r)
    ws.cell(r, target_col).value = formula
    if len(sample_formulas) < 5:
        sample_formulas.append((r, formula))

print("Sample formulas written:")
for item in sample_formulas:
    print(item)

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculation changed them
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc; restoring originals.")
    for i, original_name in enumerate(orig_sheetnames):
        wb_post.worksheets[i].title = original_name
    wb_post.save(output_path)
    print("Restored sheet names and saved.")
else:
    print("Sheet names unchanged after recalc.")

# Reload for verification
wb_formula = load_workbook(output_path, data_only=False)
wb_values = load_workbook(output_path, data_only=True)
ws_formula = wb_formula[orig_sheetnames[0]]
ws_values = wb_values[orig_sheetnames[0]]

# Verify formulas exist in target cells
print("\nVerification: formula cells in AO")
for r in data_rows[:5] + data_rows[-5:]:
    print(f"AO{r} formula:", ws_formula.cell(r, target_col).value)

# Verify evaluated values against Python expectations
mismatches = []
blank_results = []
for r in data_rows:
    expected = python_first_nonzero(r)
    actual = ws_values.cell(r, target_col).value
    if actual in (None, ""):
        blank_results.append((r, ws.cell(r, contract_col).value, expected))
    else:
        try:
            if expected is None:
                pass
            elif abs(float(actual) - float(expected)) > 1e-9:
                mismatches.append((r, ws.cell(r, contract_col).value, expected, actual))
        except Exception:
            mismatches.append((r, ws.cell(r, contract_col).value, expected, actual))

print("\nVerification summary:")
print("Blank AO results after recalc:", len(blank_results))
print("Mismatches vs Python expectation:", len(mismatches))

print("\nSample evaluated AO values:")
for r in data_rows[:10]:
    print(
        r,
        ws_values.cell(r, contract_col).value,
        "AO=", ws_values.cell(r, target_col).value,
        "expected=", python_first_nonzero(r)
    )

print("\nLast 5 evaluated AO values:")
for r in data_rows[-5:]:
    print(
        r,
        ws_values.cell(r, contract_col).value,
        "AO=", ws_values.cell(r, target_col).value,
        "expected=", python_first_nonzero(r)
    )

if blank_results[:10]:
    print("\nFirst blank results:", blank_results[:10])
if mismatches[:10]:
    print("\nFirst mismatches:", mismatches[:10])

# Keep output path for submission
final_output_spreadsheet = output_path
print("\nPrepared output file:", final_output_spreadsheet)
