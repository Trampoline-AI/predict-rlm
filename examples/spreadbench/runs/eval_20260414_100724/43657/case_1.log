```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheet names:", original_sheetnames)
print("Target sheet:", ws.title)

# Detect green assignment rows dynamically in C:G
GREEN_RGB = "FF92D050"

def get_rgb(cell):
    try:
        return cell.fill.start_color.rgb
    except Exception:
        return None

green_rows = []
for r in range(1, ws.max_row + 1):
    vals = [ws.cell(r, c).value for c in range(3, 8)]  # C:G
    rgbs = [get_rgb(ws.cell(r, c)) for c in range(3, 8)]
    if any(v is not None for v in vals) and any(rgb == GREEN_RGB for rgb in rgbs):
        green_rows.append(r)

print("Detected green rows in C:G:", green_rows)

# Identify name rows in column L and exact target cells in K
name_rows = []
for r in range(1, ws.max_row + 1):
    if ws[f"L{r}"].value not in (None, ""):
        name_rows.append(r)

print("Rows with names in L:", name_rows)
print("Current K/L target area before writing:")
for r in name_rows:
    kval = ws[f"K{r}"].value
    if isinstance(kval, ArrayFormula):
        kval = kval.text
    print(f"Row {r}: K{r}={kval!r}, L{r}={ws[f'L{r}'].value!r}")

# Build formulas that sum across all green-highlighted assignment rows
for r in name_rows:
    pieces = [f'SUMPRODUCT(--ISNUMBER(SEARCH($L{r},$C${gr}:$G${gr})))' for gr in green_rows]
    formula = "=" + "+".join(pieces) if pieces else "=0"
    ws[f"K{r}"] = formula

print("\nFormulas written:")
for r in name_rows:
    print(f"K{r} -> {ws[f'K{r}'].value}")

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc reload:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for i, expected in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification: formulas
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]

# Verification: evaluated values
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nVerification of target cells K/L:")
for r in name_rows:
    print(
        f"Row {r}: L{r}={ws_values[f'L{r}'].value!r}, "
        f"K{r} formula={ws_formula[f'K{r}'].value!r}, "
        f"K{r} value={ws_values[f'K{r}'].value!r}"
    )

# Python sanity-check counts to compare against formula results
def python_count(name):
    if name is None:
        return None
    name_l = str(name).lower()
    count = 0
    for gr in green_rows:
        for c in range(3, 8):  # C:G
            val = ws_values.cell(gr, c).value
            if val is not None and name_l in str(val).lower():
                count += 1
    return count

print("\nPython sanity-check counts:")
for r in name_rows:
    nm = ws_values[f"L{r}"].value
    pyc = python_count(nm)
    exc = ws_values[f"K{r}"].value
    print(f"{nm!r}: python={pyc}, sheet={exc}")

output_spreadsheet = outfile
print("\nPrepared output file:", output_spreadsheet)
