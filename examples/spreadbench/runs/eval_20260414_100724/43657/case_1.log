from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

GREEN_RGB = "FF92D050"

def rgb_of(cell):
    try:
        return cell.fill.start_color.rgb
    except Exception:
        return None

# Rebuild from the ORIGINAL input so we don't carry over bad recalculated values
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheetnames:", original_sheetnames)
print("Working sheet:", ws.title)

# Reconfirm target names and target cells
name_rows = [r for r in range(1, ws.max_row + 1) if ws[f"L{r}"].value not in (None, "")]
print("Name rows in L:", name_rows)
for r in name_rows:
    kval = ws[f"K{r}"].value
    if isinstance(kval, ArrayFormula):
        kval = kval.text
    print(f"Before write row {r}: K{r}={kval!r}, L{r}={ws[f'L{r}'].value!r}")

# Detect exact green-filled non-empty cells in C:G
green_cells = []
green_rows = []
for r in range(1, ws.max_row + 1):
    row_green_cells = []
    for c in range(3, 8):  # C:G
        cell = ws.cell(r, c)
        if cell.value not in (None, "") and rgb_of(cell) == GREEN_RGB:
            row_green_cells.append(cell.coordinate)
    if row_green_cells:
        green_rows.append(r)
        green_cells.extend(row_green_cells)

print("Detected green rows:", green_rows)
print("Detected green cells:", green_cells)

# Write scalar-only formulas to K, one per name row
for r in name_rows:
    parts = [f'IF(ISNUMBER(SEARCH($L{r},${coord})),1,0)' for coord in green_cells]
    formula = "=" + "+".join(parts) if parts else "=0"
    ws[f"K{r}"] = formula

print("\nFormulas written to K:")
for r in name_rows:
    print(f"K{r} -> {ws[f'K{r}'].value}")

# Save before recalc
wb.save(outfile)
print("\nSaved pre-recalc file:", outfile)

# Quick check that formulas exist before recalc
wb_pre = load_workbook(outfile, data_only=False)
ws_pre = wb_pre[original_sheetnames[0]]
print("\nPre-recalc verification:")
for r in name_rows:
    print(f"K{r} formula pre-recalc: {ws_pre[f'K{r}'].value!r}")

# Recalculate
recalc_result = await recalculate(outfile)
print("\nRecalculate result:", recalc_result)

# Reload, repair sheet names if needed
wb_post = load_workbook(outfile, data_only=False)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheetnames and len(wb_post.sheetnames) == len(original_sheetnames):
    for i, expected in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = expected
    wb_post.save(outfile)
    print("Restored sheet names:", original_sheetnames)

# Verify formulas and values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[original_sheetnames[0]]

print("\nPost-recalc verification of K/L:")
for r in name_rows:
    print(
        f"Row {r}: L{r}={ws_values[f'L{r}'].value!r}, "
        f"K{r} formula={ws_formula[f'K{r}'].value!r}, "
        f"K{r} value={ws_values[f'K{r}'].value!r}"
    )

# Python sanity check against the original workbook contents
def py_count(name):
    count = 0
    for coord in green_cells:
        v = ws[coord].value
        if v is not None and str(name).lower() in str(v).lower():
            count += 1
    return count

print("\nPython sanity-check counts:")
all_ok = True
for r in name_rows:
    name = ws_values[f"L{r}"].value
    pyv = py_count(name)
    xlv = ws_values[f"K{r}"].value
    print(f"{name!r}: python={pyv}, sheet={xlv}")
    if xlv != pyv:
        all_ok = False

print("\nAll verified correct?", all_ok)

output_spreadsheet = outfile
