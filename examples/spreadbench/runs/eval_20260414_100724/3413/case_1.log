import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, filename)

# Load workbook normally
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm exact target/result rows by checking E/F criteria
target_rows = []
for r in range(3, ws.max_row + 1):
    e_val = ws.cell(r, 5).value  # E
    f_val = ws.cell(r, 6).value  # F
    if e_val is not None or f_val is not None:
        target_rows.append(r)

print("Target rows based on E/F criteria:", target_rows)
print("Pre-write G values:", {f"G{r}": ws[f"G{r}"].value for r in target_rows})

# Determine source data extent in A:C (rows with dept or ru or total)
source_start = 3
source_end = 0
for r in range(ws.max_row, source_start - 1, -1):
    if any(ws.cell(r, c).value is not None for c in range(1, 4)):
        source_end = r
        break

print("Source data rows:", source_start, "to", source_end)

# Write formulas into G for all relevant result rows
for r in target_rows:
    formula = (
        f'=IF(COUNTIFS($A${source_start}:$A${source_end},E{r},'
        f'$B${source_start}:$B${source_end},F{r})>0,'
        f'SUMIFS($C${source_start}:$C${source_end},$A${source_start}:$A${source_end},E{r},'
        f'$B${source_start}:$B${source_end},F{r}),'
        f'SUMIFS($C${source_start}:$C${source_end},$A${source_start}:$A${source_end},E{r}))'
    )
    ws[f"G{r}"] = formula
    print(f"Wrote G{r} =", formula)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc to check sheet names; restore if changed
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheet_names:
    # rename sheets back by position
    for i, orig_name in enumerate(orig_sheet_names):
        wb_check.worksheets[i].title = orig_name
    wb_check.save(output_path)
    print("Restored sheet names to:", orig_sheet_names)

# Verify formulas and computed values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
print("Stored formulas in G3:G6:")
for r in target_rows:
    print(f"G{r} formula:", ws_formula[f"G{r}"].value)

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]
verified = {f"G{r}": ws_values[f"G{r}"].value for r in target_rows}
print("Verified cached values:", verified)

# Additional sanity checks against expected logic
for r in target_rows:
    e_val = ws_values[f"E{r}"].value
    f_val = ws_values[f"F{r}"].value
    g_val = ws_values[f"G{r}"].value
    print(f"Row {r}: Dept={e_val!r}, RU={f_val!r}, Total={g_val!r}")

final_output_path = output_path
