from openpyxl import load_workbook
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload clean workbook for modification
wb2 = load_workbook(input_path)
original_sheet_names = wb2.sheetnames[:]
ws = wb2[original_sheet_names[0]]

print("Before modification:")
print(" Sheet:", ws.title)
print(" max_row:", ws.max_row, "max_col:", ws.max_column)
print(" Header row:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print(" Sample B2:B6 before:", [ws.cell(r, 2).value for r in range(2, min(ws.max_row, 6) + 1)])

# Determine rows to keep/delete based on column B starting with H or A
rows_to_keep = [1]  # always keep header
rows_to_delete = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 2).value
    s = "" if v is None else str(v)
    if s.startswith("H") or s.startswith("A"):
        rows_to_keep.append(r)
    else:
        rows_to_delete.append(r)

print("Rows to keep (including header):", len(rows_to_keep))
print("Rows to delete:", len(rows_to_delete))
print("First 10 rows to delete:", rows_to_delete[:10])
print("Last 10 rows to delete:", rows_to_delete[-10:])

# Perform deletion directly on worksheet
if ws.max_row > 1:
    ws.delete_rows(2, ws.max_row - 1)

print("After deletion, in-memory max_row:", ws.max_row)
print("Remaining rows preview:")
for r in range(1, min(ws.max_row, 5) + 1):
    print(f" Row {r}:", [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Save output
wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reopen after recalc and restore sheet names if needed
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names:
    print("Restoring original sheet names...")
    for i, original_name in enumerate(original_sheet_names):
        wb_post.worksheets[i].title = original_name
    wb_post.save(output_path)
    wb_post = load_workbook(output_path)

print("Final sheet names:", wb_post.sheetnames)

# Verification with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names (data_only):", wb_verify.sheetnames)
vws = wb_verify[original_sheet_names[0]]
print("Verified max_row:", vws.max_row, "max_col:", vws.max_column)
print("Verified header row:", [vws.cell(1, c).value for c in range(1, vws.max_column + 1)])

# Print exact target range/current values after modification
for r in range(1, min(vws.max_row, 6) + 1):
    print(f"Verified Row {r}:", [vws.cell(r, c).value for c in range(1, vws.max_column + 1)])

# Sanity check: no remaining data rows with values
remaining_data_rows = []
for r in range(2, vws.max_row + 1):
    row_vals = [vws.cell(r, c).value for c in range(1, vws.max_column + 1)]
    if any(val not in (None, "") for val in row_vals):
        remaining_data_rows.append((r, row_vals[:3]))

print("Remaining non-empty data rows after deletion:", len(remaining_data_rows))
print("Sample remaining non-empty rows:", remaining_data_rows[:10])

final_output_spreadsheet = output_path
print("Prepared final_output_spreadsheet:", final_output_spreadsheet)
```
