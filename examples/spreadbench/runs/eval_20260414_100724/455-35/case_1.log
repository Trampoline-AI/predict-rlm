from collections import Counter, defaultdict

ws = wb[orig_sheet_names[0]]

# Inspect column B thoroughly
start_char_counts = Counter()
value_counts = Counter()
samples_by_char = defaultdict(list)

for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 2).value
    s = "" if v is None else str(v)
    first = s[:1]
    start_char_counts[first] += 1
    value_counts[s] += 1
    if len(samples_by_char[first]) < 5:
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        samples_by_char[first].append((r, row_vals))

print("Column B total data rows:", ws.max_row - 1)
print("Distinct first characters in column B:", start_char_counts.most_common(15))
print("Distinct full values in column B (top 20):", value_counts.most_common(20))

for ch in ['H', 'A', '', 'R', 'N']:
    print(f"\nSample rows where column B starts with {ch!r}:")
    for item in samples_by_char.get(ch, []):
        print(item)

keep_rows = []
delete_rows = []
for r in range(2, ws.max_row + 1):
    v = ws.cell(r, 2).value
    s = "" if v is None else str(v)
    if s.startswith("H") or s.startswith("A"):
        keep_rows.append(r)
    else:
        delete_rows.append(r)

print("\nRows to keep based on column B starting with H or A:", len(keep_rows))
print("Rows to delete:", len(delete_rows))
print("First 10 keep row numbers:", keep_rows[:10])
print("First 10 delete row numbers:", delete_rows[:10])
print("Last 10 keep row numbers:", keep_rows[-10:])
print("Last 10 delete row numbers:", delete_rows[-10:])
```
