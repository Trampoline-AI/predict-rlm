from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

input_path = input_spreadsheet
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Input:", input_path)
print("Sheet names:", orig_sheet_names)

def sheet_preview(ws, n_first=8, n_last=5):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"max_row={max_row}, max_col={max_col}")
    print("Headers:", headers)
    
    # Print first rows
    first_rows = list(range(1, min(max_row, n_first) + 1))
    last_rows = list(range(max(1, max_row - n_last + 1), max_row + 1))
    rows_to_show = []
    for r in first_rows + last_rows:
        if r not in rows_to_show:
            rows_to_show.append(r)
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(f"Row {r}: {vals}")
    
    # Column B inspection
    print("Column B sample/current values:")
    for r in rows_to_show[:10]:
        if r <= max_row:
            print(f"  B{r}={ws.cell(r, 2).value!r}")

for ws in wb.worksheets:
    sheet_preview(ws)
```
