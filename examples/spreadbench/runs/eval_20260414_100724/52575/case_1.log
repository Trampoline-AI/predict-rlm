import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load original workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet2"]

# Verify target range before writing
print("Pre-write check: F1:F15")
for r in range(1, 16):
    print(f"F{r} -> {ws[f'F{r}'].value!r}")

last_row = ws.max_row
print("Writing formulas to F2:F{}".format(last_row))

# Keep F1 blank; write formulas in F2:Flast_row
# Logic:
# - Current employee/week has at least one Sick Day and one Overtime anywhere in the sheet
# - Current row is the start of a new employee/week run relative to prior row
for r in range(2, last_row + 1):
    if r == 2:
        start_condition = "TRUE"
    else:
        start_condition = f'OR(B{r}<>B{r-1},E{r}<>E{r-1})'
    formula = (
        f'=IF(AND('
        f'COUNTIFS($B$2:$B${last_row},B{r},$E$2:$E${last_row},E{r},$C$2:$C${last_row},"Sick Day")>0,'
        f'COUNTIFS($B$2:$B${last_row},B{r},$E$2:$E${last_row},E{r},$D$2:$D${last_row},"Overtime")>0,'
        f'{start_condition}'
        f'),"y","")'
    )
    ws[f"F{r}"] = formula

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    for i, orig_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names to:", original_sheetnames)

# Verify formulas exist
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet2"]
print("\nFormula check F2:F10")
for r in range(2, 11):
    print(f"F{r} formula -> {ws_formula[f'F{r}'].value}")

# Verify calculated values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet2"]

print("\nVerified values in target range F2:F92 (non-blanks only):")
nonblank = []
for r in range(2, last_row + 1):
    v = ws_values[f"F{r}"].value
    if v not in (None, ""):
        nonblank.append((r, v, ws_values[f"B{r}"].value, ws_values[f"E{r}"].value))
print(nonblank)

# Also print expected key rows and neighboring blanks
check_rows = [2,3,14,15,44,45,65,66,74,75]
print("\nKey verification rows:")
for r in check_rows:
    print(
        r,
        {
            "B": ws_values[f"B{r}"].value,
            "C": ws_values[f"C{r}"].value,
            "D": ws_values[f"D{r}"].value,
            "E": ws_values[f"E{r}"].value,
            "F": ws_values[f"F{r}"].value,
        }
    )

# Basic sanity assertions
assert "Sheet2" in wb_values.sheetnames
assert ws_values["F1"].value is None
assert [r for r, v, emp, week in nonblank] == [2, 14, 44, 65], nonblank

