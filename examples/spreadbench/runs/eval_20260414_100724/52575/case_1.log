from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Reload cleanly
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet2"]

# Verify target area candidates explicitly
print("Current values in potential target column F, rows 1:15:")
for r in range(1, 16):
    print(f"F{r} =", ws[f"F{r}"].value)

print("\nRows 13:45 to inspect ordering / repeated weeks:")
for r in range(13, 46):
    vals = [ws.cell(r, c).value for c in range(1, 6)]
    print(r, vals)

# Compute contiguous blocks by employee + week as they appear in sheet order
blocks = []
start = 2
for r in range(2, ws.max_row + 1):
    emp = ws.cell(r, 2).value
    week = ws.cell(r, 5).value
    prev_emp = ws.cell(r-1, 2).value if r > 2 else None
    prev_week = ws.cell(r-1, 5).value if r > 2 else None
    
    is_new_block = (r == 2) or (emp != prev_emp) or (week != prev_week)
    if is_new_block:
        blocks.append({"start": r, "emp": emp, "week": week, "rows": []})
    blocks[-1]["rows"].append(r)

# Summarize each contiguous block, but evaluate two ways:
# 1) within the contiguous block only
# 2) across all rows for same employee+week in entire sheet
all_rows = []
for r in range(2, ws.max_row + 1):
    all_rows.append({
        "row": r,
        "emp": ws.cell(r, 2).value,
        "week": ws.cell(r, 5).value,
        "abs": ws.cell(r, 3).value,
        "atts": ws.cell(r, 4).value,
    })

def has_flags(records):
    has_sick = any(isinstance(x["abs"], str) and x["abs"].strip().lower() == "sick day" for x in records)
    has_ot = any(isinstance(x["atts"], str) and x["atts"].strip().lower() == "overtime" for x in records)
    return has_sick, has_ot, has_sick and has_ot

print("\nContiguous block summaries:")
for b in blocks:
    recs_block = [x for x in all_rows if x["row"] in b["rows"]]
    recs_global = [x for x in all_rows if x["emp"] == b["emp"] and x["week"] == b["week"]]
    block_has = has_flags(recs_block)
    global_has = has_flags(recs_global)
    print({
        "start": b["start"],
        "end": b["rows"][-1],
        "emp": b["emp"],
        "week": b["week"],
        "nrows": len(b["rows"]),
        "block_mark_y": block_has[2],
        "global_emp_week_mark_y": global_has[2],
    })

# Show only rows that would get "y" under each interpretation
print("\nStarts that would get y if evaluated by contiguous block only:")
print([b["start"] for b in blocks if has_flags([x for x in all_rows if x["row"] in b["rows"]])[2]])

print("Starts that would get y if evaluated by employee+week across whole sheet:")
print([b["start"] for b in blocks if has_flags([x for x in all_rows if x["emp"] == b["emp"] and x["week"] == b["week"]])[2]])
