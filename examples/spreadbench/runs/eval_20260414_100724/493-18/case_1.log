Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook and inspect exact target area again before modifying
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before modification:")
print("Sheet:", ws.title)
print("AutoFilter ref:", ws.auto_filter.ref)
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, 7)])

def norm(v):
    if v is None:
        return None
    if isinstance(v, str):
        v = v.strip()
        return v if v != "" else None
    return str(v).strip()

# Build filter set from nonblank F values, excluding header row
filter_values = []
filter_set = set()
for r in range(2, ws.max_row + 1):
    fv = norm(ws.cell(r, 6).value)
    if fv is not None:
        filter_values.append(fv)
        filter_set.add(fv)

# Determine kept rows from A:C where A appears in F
kept_records = []
match_debug = []
for r in range(2, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    b_val = ws.cell(r, 2).value
    c_val = ws.cell(r, 3).value
    a_norm = norm(a_val)
    is_match = a_norm in filter_set if a_norm is not None else False
    match_debug.append((r, a_val, is_match))
    if is_match:
        kept_records.append((a_val, b_val, c_val))

print("Column F nonblank filter values:", filter_values)
print("Match decisions by row:", match_debug)
print("Kept records:", kept_records)

# Write compacted kept records upward into A:C starting at row 2
target_start_row = 2
for i, record in enumerate(kept_records, start=target_start_row):
    for c, value in enumerate(record, start=1):
        ws.cell(i, c).value = value

# Clear remaining A:C rows after the kept block; do not touch other columns
clear_start = target_start_row + len(kept_records)
for r in range(clear_start, ws.max_row + 1):
    for c in range(1, 4):
        ws.cell(r, c).value = None

# Preserve autofilter reference exactly as original if it existed
original_autofilter = ws.auto_filter.ref
ws.auto_filter.ref = original_autofilter

wb.save(output_path)
print("Saved to:", output_path)

# Recalculate as required
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
current_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", current_names)
if current_names != original_sheet_names and len(current_names) == len(original_sheet_names):
    for idx, orig_name in enumerate(original_sheet_names):
        wb_after.worksheets[idx].title = orig_name
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheet_names)

# Final verification using data_only=True
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("\nAfter modification verification:")
print("Verified sheet names:", wb_verify.sheetnames)
print("Verified AutoFilter ref:", wsv.auto_filter.ref)
for r in range(1, wsv.max_row + 1):
    print(r, [wsv.cell(r, c).value for c in range(1, 7)])

# Store output path for submission in next step
final_output_spreadsheet = output_path
print("final_output_spreadsheet =", final_output_spreadsheet)
```
