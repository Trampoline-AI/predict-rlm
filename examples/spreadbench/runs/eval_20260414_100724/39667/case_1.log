from openpyxl import load_workbook
from openpyxl.styles import PatternFill
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, filename)

# Load original workbook
wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb["Pay Items"]

print("Original sheet names:", orig_sheet_names)
print("Target table ref:", ws.tables["Table2"].ref)
print("Lookup source rows 3:17, target rows 20:26")

# Print current values/formulas in target range before modification
print("\nBefore modification A20:C26:")
for r in range(20, 27):
    print(r, {"A": ws[f"A{r}"].value, "B": ws[f"B{r}"].value, "C": ws[f"C{r}"].value})

# Apply formulas and fill
yellow_fill = PatternFill(start_color="FFF2CC", end_color="FFF2CC", fill_type="solid")

for r in range(20, 27):
    # Formula for Pay Item Number in column A
    ws[f"A{r}"] = f'=IF(C{r}="","",IFERROR(INDEX($A$3:$A$17,MATCH(C{r},$C$3:$C$17,0)),""))'
    # Formula for UOM in column B
    ws[f"B{r}"] = f'=IF(C{r}="","",IFERROR(INDEX($B$3:$B$17,MATCH(C{r},$C$3:$C$17,0)),""))'
    # Requested fill color in A & B
    ws[f"A{r}"].fill = yellow_fill
    ws[f"B{r}"].fill = yellow_fill

print("\nAfter writing formulas A20:B26:")
for r in range(20, 27):
    print(r, {"A": ws[f"A{r}"].value, "B": ws[f"B{r}"].value, "C": ws[f"C{r}"].value})

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open after recalc, fix any sheet renaming
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    # Rename sheets back by position
    for i, orig_name in enumerate(orig_sheet_names):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
    print("Renamed sheets back to original:", orig_sheet_names)

# Verification with formulas visible
wb_verify = load_workbook(output_path, data_only=False)
ws_vf = wb_verify["Pay Items"]
print("\nVerification - stored formulas A20:B26:")
for r in range(20, 27):
    print(
        r,
        {
            "A_formula": ws_vf[f"A{r}"].value,
            "B_formula": ws_vf[f"B{r}"].value,
            "C_value": ws_vf[f"C{r}"].value,
            "A_fill": ws_vf[f"A{r}"].fill.start_color.rgb,
            "B_fill": ws_vf[f"B{r}"].fill.start_color.rgb,
        },
    )

# Verification with calculated values
wb_data = load_workbook(output_path, data_only=True)
ws_data = wb_data["Pay Items"]
print("\nVerification - calculated values A20:C26:")
for r in range(20, 27):
    print(
        r,
        {
            "A": ws_data[f"A{r}"].value,
            "B": ws_data[f"B{r}"].value,
            "C": ws_data[f"C{r}"].value,
        },
    )

# Basic sanity checks
issues = []
for r in range(20, 27):
    desc = ws_data[f"C{r}"].value
    a_val = ws_data[f"A{r}"].value
    b_val = ws_data[f"B{r}"].value
    if desc in (None, ""):
        # blank search should yield blank output
        if a_val not in (None, "") or b_val not in (None, ""):
            issues.append((r, "blank description but outputs not blank", a_val, b_val))
    else:
        # entered descriptions should now have looked-up values if found in source
        if r in (20, 21) and (a_val in (None, "") or b_val in (None, "")):
