```repl
import os, shutil
from collections import defaultdict
from datetime import datetime, date
from openpyxl import load_workbook

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook
wb = load_workbook(infile)
orig_sheet_names = wb.sheetnames[:]
ws = wb["data"]

# Determine exact last used row on data sheet
last_used = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
        last_used = r

print("Original sheet names:", orig_sheet_names)
print("data max_row/max_col:", ws.max_row, ws.max_column, "last_used:", last_used)

# Print target and relevant cells before change
for coord in ["M3", "N5", "O3"]:
    print(f"Before {coord} =", ws[coord].value)

print("Relevant area M1:O6 before:")
for r in range(1, 7):
    print(r, [ws.cell(r, c).value for c in range(13, 16)])

# Compute expected answer in Python using cached values from K
wbv = load_workbook(infile, data_only=True)
wsv = wbv["data"]

m3 = str(ws["M3"].value or "").strip().lower()
n5 = ws["N5"].value

def n5_to_text(v):
    if isinstance(v, datetime):
        return f"{v.month}-{v.day}-{str(v.year)[-2:]}"
    if isinstance(v, date):
        return f"{v.month}-{v.day}-{str(v.year)[-2:]}"
    return str(v).strip()

target_date_text = n5_to_text(n5)
print("Mechanic criterion M3:", m3)
print("Date criterion N5 raw:", n5, "-> match text:", target_date_text)

matches = []
py_total = 0.0
for r in range(2, last_used + 1):
    a = ws.cell(r, 1).value
    c = str(ws.cell(r, 3).value or "").strip().lower()
    k = wsv.cell(r, 11).value
    a_text = str(a).strip() if a is not None else ""
    try:
        kval = float(k)
    except (TypeError, ValueError):
        kval = 0.0
    if a_text == target_date_text and m3 in c:
        py_total += kval
        matches.append((r, a_text, c, kval))

print("Matched rows for criteria:")
for item in matches:
    print(item)
print("Python total:", py_total, "Rounded 6:", round(py_total, 6))

# Write formula only to O3
formula = f'=ROUND(SUMPRODUCT(($A$2:$A${last_used}=TEXT($N$5,"m-d-yy"))*(ISNUMBER(SEARCH($M$3,$C$2:$C${last_used})))*($K$2:$K${last_used})),6)'
ws["O3"] = formula
print("Written formula to O3:", ws["O3"].value)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheet_names:
    for i, expected in enumerate(orig_sheet_names):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = expected
    wb_after.save(outfile)
    print("Renamed sheets back to:", orig_sheet_names)

# Verify with data_only
wb_verify_formula = load_workbook(outfile)
ws_verify_formula = wb_verify_formula["data"]
wb_verify = load_workbook(outfile, data_only=True)
ws_verify = wb_verify["data"]

print("Verification cells after save/recalc:")
for coord in ["M3", "N5", "O3"]:
    print(
        coord,
        "formula_mode=", ws_verify_formula[coord].value,
        "| data_only=", ws_verify[coord].value
    )

print("Relevant area M1:O6 after:")
for r in range(1, 7):
    print(r, [ws_verify_formula.cell(r, c).value for c in range(13, 16)])

# Keep output path for submission
output_path = outfile
print("Final output path:", output_path)
