wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames
print("Sheet names:", original_sheet_names)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    vals = [ws.cell(r, c).value for c in range(1, max_cols + 1)]
    return vals

def nonempty_headers(ws, header_row=1):
    return [ws.cell(header_row, c).value for c in range(1, ws.max_column + 1)]

# Global sheet summary
for s in wb.sheetnames:
    ws = wb[s]
    headers1 = nonempty_headers(ws, 1)
    headers5 = nonempty_headers(ws, 5) if ws.max_row >= 5 else []
    print(f"\n--- Sheet {s} ---")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    print("row1:", headers1)
    if headers5:
        print("row5:", headers5)

target_sheets = ["99250", "99251", "99252"]
for s in target_sheets:
    print(f"\n================ TARGET SHEET {s} ================")
    if s not in wb.sheetnames:
        print("Sheet missing!")
        continue
    ws = wb[s]
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    
    # Print first 10 rows
    first_end = min(ws.max_row, 10)
    print(f"First rows 1:{first_end}")
    for r in range(1, first_end + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))
    
    # Print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}:{ws.max_row}")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 8)))
    
    # Explicit current values for referenced area
    print("Cell F5:", ws["F5"].value)
    print("Column F values from row 6 onward (non-empty / first 20 occurrences):")
    f_samples = []
    for r in range(6, ws.max_row + 1):
        v = ws.cell(r, 6).value
        if v not in (None, ""):
            f_samples.append((r, v))
    print("Total non-empty F rows from 6+:", len(f_samples))
    print("First 20:", f_samples[:20])
    print("Last 10:", f_samples[-10:])
    
    # Match rows for likely deletion phrase
    matches = []
    accepted = []
    for r in range(6, ws.max_row + 1):
        v = ws.cell(r, 6).value
        if isinstance(v, str):
            vl = v.strip().lower()
            if "to be processed" in vl:
                matches.append((r, v))
            if "accepted" in vl:
                accepted.append((r, v))
    print("Rows where F contains 'to be processed':", matches[:50], "count=", len(matches))
    print("Rows where F contains 'accepted':", accepted[:50], "count=", len(accepted))
