```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os
from datetime import datetime

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
data_ws = wb["Data"]
trans_ws = wb["Transpose"]

# Reconfirm structure and exact target columns/rows
print("Original sheet names:", orig_sheetnames)
print("Data dims:", data_ws.max_row, data_ws.max_column)
print("Transpose dims before write:", trans_ws.max_row, trans_ws.max_column)
print("Transpose row 1:", [trans_ws.cell(1,c).value for c in range(1,4)])
print("Transpose row 2:", [trans_ws.cell(2,c).value for c in range(1,4)])
print("Transpose sample rows 3-6 before write:")
for r in range(3, 7):
    print(r, [trans_ws.cell(r,c).value for c in range(1,4)])

# Identify item rows and date columns from Data
item_rows = []
for r in range(7, data_ws.max_row + 1):
    row_vals = [data_ws.cell(r, c).value for c in range(1, data_ws.max_column + 1)]
    if any(v is not None and v != "" for v in row_vals):
        item_rows.append(r)

date_cols = []
for c in range(1, data_ws.max_column + 1):
    v = data_ws.cell(6, c).value
    if isinstance(v, datetime):
        date_cols.append(c)

print("Item rows:", item_rows)
print("Date cols:", [(get_column_letter(c), data_ws.cell(6,c).value) for c in date_cols[:5]], "...", [(get_column_letter(c), data_ws.cell(6,c).value) for c in date_cols[-5:]])
print("Counts -> items:", len(item_rows), "dates:", len(date_cols), "expected output rows:", len(item_rows) * len(date_cols))

# Build transposed records
records = []
for r in item_rows:
    item = data_ws.cell(r, 1).value
    for c in date_cols:
        dt = data_ws.cell(6, c).value
        qty = data_ws.cell(r, c).value
        records.append((item, dt, qty))

start_row = 3
end_row = start_row + len(records) - 1
print("Target write range: A{}:C{}".format(start_row, end_row))
print("First 5 generated records:", records[:5])
print("Last 5 generated records:", records[-5:])

# Capture sample styles from existing Transpose rows if present
style_A = copy(trans_ws["A3"]._style) if trans_ws["A3"].value is not None or trans_ws["A3"].has_style else copy(trans_ws["A2"]._style)
style_B = copy(trans_ws["B3"]._style) if trans_ws["B3"].value is not None or trans_ws["B3"].has_style else copy(trans_ws["B2"]._style)
style_C = copy(trans_ws["C3"]._style) if trans_ws["C3"].value is not None or trans_ws["C3"].has_style else copy(trans_ws["C2"]._style)
numfmt_A = trans_ws["A3"].number_format
numfmt_B = trans_ws["B3"].number_format
numfmt_C = trans_ws["C3"].number_format
print("Sample formats:", {"A3": numfmt_A, "B3": numfmt_B, "C3": numfmt_C})

# Clear previous/sample target area values in columns A:C from row 3 downward through max(existing, needed)
clear_to = max(trans_ws.max_row, end_row)
for r in range(start_row, clear_to + 1):
    for c in range(1, 4):
        trans_ws.cell(r, c).value = None

# Write records
for idx, (item, dt, qty) in enumerate(records, start=start_row):
    trans_ws.cell(idx, 1).value = item
    trans_ws.cell(idx, 2).value = dt
    trans_ws.cell(idx, 3).value = qty
    
    trans_ws.cell(idx, 1)._style = copy(style_A)
    trans_ws.cell(idx, 2)._style = copy(style_B)
    trans_ws.cell(idx, 3)._style = copy(style_C)

    if numfmt_A:
        trans_ws.cell(idx, 1).number_format = numfmt_A
    if numfmt_B:
        trans_ws.cell(idx, 2).number_format = numfmt_B
    if numfmt_C:
        trans_ws.cell(idx, 3).number_format = numfmt_C

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames:
    # rename by position to original names
    for i, s in enumerate(wb2.worksheets):
        s.title = orig_sheetnames[i]
    wb2.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verification using data_only after recalc
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb["Transpose"]

# Verify exact target cells/range samples
print("Verify headers row 2:", [vws.cell(2,c).value for c in range(1,4)])

check_rows = [3, 4, 5, end_row-2, end_row-1, end_row]
print("Verify sample target rows:")
for r in check_rows:
    print(r, [vws.cell(r,c).value for c in range(1,4)])

# Sanity checks
blank_targets = []
for r in [3, 44, 45, 46, end_row]:
    rowvals = [vws.cell(r,c).value for c in range(1,4)]
    if any(v is None for v in rowvals):
        blank_targets.append((r, rowvals))
print("Blank target sample rows:", blank_targets)

print("Final Transpose max_row/max_col:", vws.max_row, vws.max_column)

# Also verify against expected generated data at a few positions
expected_checks = {
    3: records[0],
    4: records[1],
    46: records[43],
    47: records[44],
    end_row: records[-1],
}
mismatches = []
for r, expected in expected_checks.items():
    actual = tuple(vws.cell(r,c).value for c in range(1,4))
    if actual != expected:
        mismatches.append((r, expected, actual))
print("Verification mismatches:", mismatches)

output_spreadsheet = outfile
print("Prepared output_spreadsheet:", output_spreadsheet)
```
