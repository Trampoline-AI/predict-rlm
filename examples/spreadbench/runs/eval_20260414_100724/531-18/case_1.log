    print(c, l, repr(v))

# Item rows in Data
item_rows = []
for r in range(7, data_ws.max_row+1):
    row = vals(data_ws, r, 1, data_ws.max_column)
    if any(v is not None and v != "" for v in row):
        item_rows.append(r)
print("\nData item row count:", len(item_rows), "rows:", item_rows[:5], "...", item_rows[-5:])

# Date columns = header cells in row 6 that are datetimes
date_cols = []
for c in range(1, data_ws.max_column+1):
