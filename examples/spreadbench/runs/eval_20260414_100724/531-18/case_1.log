from openpyxl.utils import get_column_letter
import os

wb = load_workbook(input_spreadsheet)
data_ws = wb["Data"]
trans_ws = wb["Transpose"]

def vals(ws, r, c1=1, c2=None):
    if c2 is None:
        c2 = ws.max_column
    return [ws.cell(r, c).value for c in range(c1, c2+1)]

# Find actual non-empty columns in Data row 6 (headers)
data_headers = [(c, get_column_letter(c), data_ws.cell(6, c).value) for c in range(1, data_ws.max_column+1)]
