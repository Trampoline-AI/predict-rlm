        date_cols.append(c)
print("Date column count:", len(date_cols))
print("Date columns:", [(get_column_letter(c), data_ws.cell(6,c).value) for c in date_cols])

expected_rows = len(item_rows) * len(date_cols)
print("Expected transposed data rows (without header rows):", expected_rows)
print("Expected last output row if starting at row 3:", expected_rows + 2)

# Inspect Transpose fully but compactly
print("\nTranspose dimensions:", trans_ws.max_row, trans_ws.max_column)
print("Transpose rows 1-12:")
for r in range(1, min(12, trans_ws.max_row)+1):
    print(r, vals(trans_ws, r, 1, 3))

print("\nTranspose last 12 rows:")
for r in range(max(1, trans_ws.max_row-11), trans_ws.max_row+1):
    print(r, vals(trans_ws, r, 1, 3))

# Count non-empty output rows in transpose starting row 3
transpose_nonempty_rows = []
for r in range(3, trans_ws.max_row+1):
    row = vals(trans_ws, r, 1, 3)
    if any(v is not None and v != "" for v in row):
        transpose_nonempty_rows.append((r, row))
print("\nTranspose non-empty data row count:", len(transpose_nonempty_rows))
print("First 5 transpose data rows:", transpose_nonempty_rows[:5])
print("Last 5 transpose data rows:", transpose_nonempty_rows[-5:])

# Check formulas in transpose target area
formula_cells = []
for r in range(1, trans_ws.max_row+1):
    for c in range(1, min(3, trans_ws.max_column)+1):
        v = trans_ws.cell(r, c).value
        if isinstance(v, str) and v.startswith("="):
            formula_cells.append((trans_ws.cell(r,c).coordinate, v))
print("\nTranspose formulas:", formula_cells[:20], "count=", len(formula_cells))

# Compare transpose contents against transposition from Data for a sample
generated = []
for r in item_rows:
    item = data_ws.cell(r, 1).value
    for c in date_cols:
        dt = data_ws.cell(6, c).value
        qty = data_ws.cell(r, c).value
        generated.append((item, dt, qty))
print("\nGenerated first 8:", generated[:8])
print("Generated last 8:", generated[-8:])

# Compare exact match with existing transpose rows
existing = [tuple(vals(trans_ws, r, 1, 3)) for r, _ in transpose_nonempty_rows]
print("Existing matches generated exactly?", existing == generated)
if existing != generated:
    # show first mismatch
    n = min(len(existing), len(generated))
    for i in range(n):
        if existing[i] != generated[i]:
            print("First mismatch at position", i, "sheet row", i+3)
            print("Existing:", existing[i])
