from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook loaded:", os.path.basename(input_spreadsheet))
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

def nonempty_header_candidates(ws, top_n=5):
    out = []
    for r in range(1, min(ws.max_row, top_n) + 1):
        vals = row_values(ws, r)
        nonempty = sum(v is not None and v != "" for v in vals)
        out.append((r, nonempty, vals))
    return out

for sname in wb.sheetnames:
    ws = wb[sname]
    print("\n" + "="*80)
    print(f"Sheet: {sname}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    
    print("Top header candidates (first 5 rows):")
    for r, nonempty, vals in nonempty_header_candidates(ws, top_n=5):
        print(f"  Row {r} nonempty={nonempty}: {vals}")
    
    # pick a reasonable display width
    max_cols_display = min(ws.max_column, 12)
    headers = row_values(ws, 1, max_cols_display)
    print(f"Row 1 headers/values first {max_cols_display} cols:", headers)
    
    print("First up to 10 rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"  Row {r}: {row_values(ws, r, max_cols_display)}")
    
    print("Last up to 5 rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(f"  Row {r}: {row_values(ws, r, max_cols_display)}")

# Focused inspection of relevant sheets
for sname in ["Data", "Transpose"]:
    if sname in wb.sheetnames:
        ws = wb[sname]
        print("\n" + "#"*80)
        print(f"Focused inspection: {sname}")
        print(f"max_row={ws.max_row}, max_col={ws.max_column}")
        
        # print column letters + first two rows
        cols_display = min(ws.max_column, 15)
        letters = [get_column_letter(c) for c in range(1, cols_display + 1)]
        print("Columns:", letters)
        print("Row 1:", row_values(ws, 1, cols_display))
        if ws.max_row >= 2:
            print("Row 2:", row_values(ws, 2, cols_display))
        
        # find cells containing ITEM/DATE/QTY in first 10 rows x first 15 cols
        hits = []
        for r in range(1, min(ws.max_row, 10) + 1):
            for c in range(1, min(ws.max_column, 15) + 1):
                v = ws.cell(r, c).value
                if isinstance(v, str) and v.strip().upper() in {"ITEM", "DATE", "QTY"}:
                    hits.append((ws.cell(r,c).coordinate, v))
        print("Header-like hits for ITEM/DATE/QTY:", hits)
        
        # print formulas / existing values in used range small window
        print("Cells with formulas in first 20 rows x first 15 cols:")
        formulas = []
        for r in range(1, min(ws.max_row, 20) + 1):
            for c in range(1, min(ws.max_column, 15) + 1):
