if wb_after.sheetnames != original_sheetnames:
    current_names = wb_after.sheetnames[:]
    if len(current_names) == len(original_sheetnames):
        for old, new in zip(current_names, original_sheetnames):
            if old != new:
                wb_after[old].title = new
        wb_after.save(output_path)
        print("Restored sheet names to:", original_sheetnames)
