for r in range(2, ws_in.max_row + 1):
    item = ws_in.cell(r, 1).value       # A ITEM
    brands = ws_in.cell(r, 3).value     # C BRANDS
    type_ = ws_in.cell(r, 5).value      # E TYPE
    origin = ws_in.cell(r, 6).value     # F ORIGIN
    short_origin = mapping.get(origin, origin)

    ws_out.cell(r, 1).value = item
