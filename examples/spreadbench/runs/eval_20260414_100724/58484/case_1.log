from openpyxl import load_workbook
from openpyxl.styles import Border, Side, Font, Alignment
from copy import copy
from pathlib import Path
import os

infile = input_spreadsheet
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / Path(infile).name

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine actual last non-empty row in D:H
last_row = 0
for r in range(1, ws.max_row + 1):
    if any(ws.cell(r, c).value not in (None, "") for c in range(4, 9)):
        last_row = r
print("Detected last data row:", last_row)

# 1) Ensure row 4 headings are bold, wrapped, and bottom-bordered (matching existing pattern)
thin = Side(style="thin")
for coord in ["D4", "E4", "F4", "H4"]:
    cell = ws[coord]
    f = copy(cell.font)
    f.bold = True
    cell.font = f

    a = copy(cell.alignment)
    a.wrap_text = True
    cell.alignment = a

    b = copy(cell.border)
    b.bottom = thin
    cell.border = b

# 2) Ensure wrap text on row 4 text cells
for c in range(4, 9):
    cell = ws.cell(4, c)
    if cell.value not in (None, ""):
        a = copy(cell.alignment)
        a.wrap_text = True
        cell.alignment = a

# 3) Ensure column G has no values and no borders
for r in range(1, ws.max_row + 1):
    g = ws.cell(r, 7)
    g.value = None
    g.border = Border()

# 4) Insert formula in H5:Hlast_row
# Logic:
# - Current row must be a transfer row: D=row operator 5551234, E is destination staff member
# - It must be the LAST transfer row in its contiguous transfer block
# - Count transfer rows since the most recent incoming row (D<>5551234 and E=5551234)
for r in range(5, last_row + 1):
    formula = (
        f'=IF(AND($D{r}=5551234,$E{r}<>5551234,'
        f'NOT(AND($D{r+1}=5551234,$E{r+1}<>5551234))),'
        f'SUMPRODUCT(($D$5:D{r}=5551234)*($E$5:E{r}<>5551234)*'
        f'(ROW($D$5:D{r})>=LOOKUP(2,1/((($D$5:D{r}<>5551234)*($E$5:E{r}=5551234))),ROW($D$5:D{r})))),"")'
    )
    ws[f"H{r}"] = formula

# Preserve header H4 text
ws["H4"] = "Expected Result"

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(str(outfile))
print("Recalculate result:", recalc_result)

# Reload after recalc; restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for i, expected in enumerate(orig_sheetnames):
        wb_check.worksheets[i].title = expected
    wb_check.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verify formulas and evaluated values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula["Sheet1"]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values["Sheet1"]

