Code:
```repl
import os
from openpyxl import load_workbook
from numbers import Number

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

ref_value = ws["G2"].value
target_before = ws["H2"].value

print("Reference G2:", ref_value)
print("Current H2 before write:", target_before)

matches = []
total = 0

for r in range(1, ws.max_row + 1):
    a_val = ws.cell(r, 1).value
    b_val = ws.cell(r, 2).value
    row_match = (a_val == ref_value) or (b_val == ref_value)
    if row_match:
        contribs = []
        row_sum = 0
        for c in range(3, 6):  # C:E
            v = ws.cell(r, c).value
            if isinstance(v, Number) and not isinstance(v, bool):
                row_sum += v
                contribs.append((c, v))
            else:
                contribs.append((c, v))
        total += row_sum
        matches.append({
            "row": r,
            "A": a_val,
            "B": b_val,
            "C": ws.cell(r, 3).value,
            "D": ws.cell(r, 4).value,
            "E": ws.cell(r, 5).value,
            "row_sum_numeric_only": row_sum
        })

print("Matching rows and contributions:")
for m in matches:
    print(m)

print("Computed total to place in H2:", total)

ws["H2"] = total

print("H2 after write (in-memory):", ws["H2"].value)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and fix sheet names if recalculate changed them
wb_check = load_workbook(outfile)
print("Sheet names after recalc reload:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheetnames:
    # rename by position back to original names
    for i, expected_name in enumerate(original_sheetnames):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = expected_name
    wb_check.save(outfile)
    print("Renamed sheets back to original:", original_sheetnames)

# Verify with data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
ws_verify = wb_verify[original_sheetnames[0]]

print("Verification target cells:")
print("G2 =", ws_verify["G2"].value)
print("H2 =", ws_verify["H2"].value)

assert ws_verify["H2"].value is not None, "H2 is blank after save/recalc"
assert ws_verify["H2"].value == total, f"Expected H2={total}, got {ws_verify['H2'].value}"

output_spreadsheet = outfile
print("Ready to submit:", output_spreadsheet)
```
