    if ws_rates_f.cell(r, 2).value == "INNSA PT" and ws_rates_f.cell(r, 5).value == "20DC":
        print(r, [ws_rates_f.cell(r, c).value for c in range(1, 9)])

# Count usage by destination/equipment to understand full scope
ctr = Counter()
for r in range(2, ws_rates_f.max_row + 1):
    ctr[(ws_rates_f.cell(r, 4).value, ws_rates_f.cell(r, 5).value)] += 1
print("\nCounts in Sea Freight by (destination, equipment):")
for k, v in sorted(ctr.items()):
