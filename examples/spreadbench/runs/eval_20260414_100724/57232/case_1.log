import os, shutil

# Reload both formula-view and data-only versions
wb_formula = load_workbook(input_spreadsheet)
wb_data = load_workbook(input_spreadsheet, data_only=True)

ws_rates_f = wb_formula["Sea Freight Rates"]
ws_vol_f = wb_formula["Volume"]
ws_vol_d = wb_data["Volume"]

print("Check formula-vs-cached values on suspicious source cells:")
