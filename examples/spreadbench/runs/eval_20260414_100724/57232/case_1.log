from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        vals.append(ws.cell(r, c).value)
    return vals

inspection = {}

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    headers = row_values(ws, 1, ws.max_column)
    print("Header row 1:", headers)
    if ws.max_row >= 2:
        row2 = row_values(ws, 2, ws.max_column)
        print("Row 2:", row2)
    # first 10 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        print(f"R{r}:", row_values(ws, r, ws.max_column))
    # last 5 rows
    if ws.max_row > 10:
        print("Last rows:")
        for r in range(max(1, ws.max_row - 4), ws.max_row + 1):
            print(f"R{r}:", row_values(ws, r, ws.max_column))
    
    # scan formulas / errors / non-empty headers
    formulas = []
    errors = []
    nonempty_counts = []
    for c in range(1, ws.max_column + 1):
        cnt = 0
        for r in range(1, ws.max_row + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                cnt += 1
            if isinstance(v, str) and v.startswith("="):
                if len(formulas) < 20:
                    formulas.append((ws.cell(r, c).coordinate, v))
            if isinstance(v, str) and v.startswith("#"):
                if len(errors) < 20:
                    errors.append((ws.cell(r, c).coordinate, v))
        nonempty_counts.append((get_column_letter(c), cnt, ws.cell(1, c).value))
    print("Non-empty count by col:", nonempty_counts)
    print("Sample formulas:", formulas[:10])
    print("Sample errors:", errors[:10])
    inspection[ws.title] = {
        "rows": ws.max_row,
        "cols": ws.max_column,
        "headers": headers,
        "formulas": formulas,
        "errors": errors,
        "nonempty_counts": nonempty_counts,
    }

# Store for later
wb_inspection = inspection
