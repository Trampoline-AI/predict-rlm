# Build robust lookup from data_only workbook.
# Rule: use the LAST non-empty matching row, since the duplicate later row appears to override the earlier one.
dest_headers = {c: ws_vol_f.cell(2, c).value for c in range(4, 7)}
lookup = {}
source_row_used = {}
for r in range(3, ws_vol_d.max_row + 1):
