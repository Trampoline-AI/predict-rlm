    matches = []
    for r in range(1, ws.max_row + 1):
        a = ws.cell(r, 1).value
        if isinstance(a, str) and a.startswith("**"):
            # determine last non-empty column in this row
            last_col = 0
            for c in range(ws.max_column, 0, -1):
                v = ws.cell(r, c).value
                if v not in (None, ""):
                    last_col = c
                    break
            row_vals = [ws.cell(r, c).value for c in range(1, last_col + 1)] if last_col else []
            matches.append((r, last_col, row_vals))
    print("\nImported Data rows where Column A starts with '**':")
