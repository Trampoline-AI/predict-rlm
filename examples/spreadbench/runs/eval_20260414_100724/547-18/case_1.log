```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

# Load workbook
wb = load_workbook(infile)
original_sheet_names = wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

# Use actual existing sheet names
src_name = "imported Data"
dst_name = "summary Limits"
src = wb[src_name]
dst = wb[dst_name]

# Reconfirm target data before writing
matches = []
for r in range(1, src.max_row + 1):
    a = src.cell(r, 1).value
    if isinstance(a, str) and a.startswith("**"):
        last_col = 0
        for c in range(src.max_column, 0, -1):
            if src.cell(r, c).value not in (None, ""):
                last_col = c
                break
        matches.append((r, last_col, [src.cell(r, c).value for c in range(1, last_col + 1)]))

print("Matched rows from source:")
for r, last_col, vals in matches:
    print(f"  row {r}, A:{get_column_letter(last_col)} -> {vals}")

# Inspect destination before writing
print("\nDestination sheet before writing:")
for r in range(1, max(dst.max_row, 5) + 1):
    vals = [dst.cell(r, c).value for c in range(1, max(dst.max_column, 4) + 1)]
    print(f"  row {r}: {vals}")

# Since destination is effectively empty, write header + matched rows from top.
# First determine header last used column
header_last_col = 0
for c in range(src.max_column, 0, -1):
    if src.cell(1, c).value not in (None, ""):
        header_last_col = c
        break
print("\nHeader last used col:", header_last_col, get_column_letter(header_last_col))

# Clear only the area we'll use if needed (safe because sheet is empty, but avoids stray cells)
for r in range(1, dst.max_row + 1):
    for c in range(1, max(dst.max_column, header_last_col) + 1):
        if dst.cell(r, c).value is not None:
            dst.cell(r, c).value = None

def copy_cell(src_cell, dst_cell):
    dst_cell.value = src_cell.value
    if src_cell.has_style:
        dst_cell.font = copy(src_cell.font)
        dst_cell.fill = copy(src_cell.fill)
        dst_cell.border = copy(src_cell.border)
        dst_cell.alignment = copy(src_cell.alignment)
        dst_cell.number_format = src_cell.number_format
        dst_cell.protection = copy(src_cell.protection)
    if src_cell.hyperlink:
        dst_cell._hyperlink = copy(src_cell.hyperlink)
    if src_cell.comment:
        dst_cell.comment = copy(src_cell.comment)

# Copy header row to destination row 1
for c in range(1, header_last_col + 1):
    copy_cell(src.cell(1, c), dst.cell(1, c))

# Copy matched rows to destination starting row 2
out_row = 2
for src_row, last_col, _ in matches:
    for c in range(1, last_col + 1):
        copy_cell(src.cell(src_row, c), dst.cell(out_row, c))
    out_row += 1

# Copy column widths for used columns to make pasted table match better
for c in range(1, header_last_col + 1):
    letter = get_column_letter(c)
    if letter in src.column_dimensions:
        dst.column_dimensions[letter].width = src.column_dimensions[letter].width

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# After recalc, reload and ensure sheet names preserved
wb2 = load_workbook(outfile)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != original_sheet_names:
    print("Sheet names changed; restoring original names...")
    # rename by position to original names
    for i, expected in enumerate(original_sheet_names):
        wb2.worksheets[i].title = expected
    wb2.save(outfile)
    print("Restored sheet names:", wb2.sheetnames)

# Verification with formulas/values
wb_check = load_workbook(outfile, data_only=True)
print("\nVerification sheet names:", wb_check.sheetnames)
src_check = wb_check[src_name]
dst_check = wb_check[dst_name]

print("\nVerified destination values:")
for r in range(1, 6):
    vals = [dst_check.cell(r, c).value for c in range(1, 5)]
    print(f"  row {r}: {vals}")

# Store path for submission
final_output_path = outfile
print("\nFinal output path prepared:", final_output_path)
