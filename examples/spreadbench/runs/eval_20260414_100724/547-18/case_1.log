    # find actual non-empty rows and cols
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("First non-empty row:", nonempty_rows[0], "Last non-empty row:", nonempty_rows[-1])
    
    # first sample rows
    print(f"\nFirst {sample_first} rows:")
    for r in range(1, min(ws.max_row, sample_first) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {row_vals}")
    
    # last sample rows
    start_last = max(1, ws.max_row - sample_last + 1)
    print(f"\nLast {sample_last} rows:")
    for r in range(start_last, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {row_vals}")

for s in wb.sheetnames:
