import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Load workbook and inspect exact target formulas before modifying
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Original sheet names:", original_sheetnames)
print("Existing formulas in D2:D13 before change:")
for r in range(2, 14):
    print(f"D{r} -> {ws[f'D{r}'].value!r}, A{r} -> {ws[f'A{r}'].value!r}")

# Modify the exact target cells in existing column D
for r in range(2, 14):
    ws[f"D{r}"] = f'=IF(A{r}="","",IF(A{r}=0,1,0))'

print("\nFormulas in D2:D13 after change (before save):")
for r in range(2, 14):
    print(f"D{r} -> {ws[f'D{r}'].value!r}")

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
