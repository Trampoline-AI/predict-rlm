for r in range(2, 14):
    verified_values[f"D{r}"] = ws_values[f"D{r}"].value
    print(f"A{r}={ws_values[f'A{r}'].value!r} => D{r}={ws_values[f'D{r}'].value!r}")

# Focus on cells mentioned in instruction
