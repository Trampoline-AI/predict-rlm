if wb_check.sheetnames != original_sheetnames:
    # rename sheets back by position
    for old_name, ws_obj in zip(original_sheetnames, wb_check.worksheets):
        ws_obj.title = old_name
    wb_check.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verification: formula strings
