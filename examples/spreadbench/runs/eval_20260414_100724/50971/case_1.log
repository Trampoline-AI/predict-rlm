from openpyxl import load_workbook
from collections import OrderedDict
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Build mapping from column A -> list of associated column B values, preserving first-seen order
mapping = OrderedDict()
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is None and b is None:
        continue
    if a not in mapping:
        mapping[a] = []
    mapping[a].append(b)

unique_keys = list(mapping.keys())
max_output_cols = 5  # G:K per the example/instruction
start_row = 3

print("Original sheetnames:", original_sheetnames)
print("Unique keys/count:", len(unique_keys))
for k, vals in mapping.items():
    print(k, vals)

# Write F column (unique values) and E formulas, and G:K extracted values
last_data_row = ws.max_row
for i, key in enumerate(unique_keys, start=start_row):
    vals = mapping[key]
    ws.cell(i, 6).value = key  # F
    ws.cell(i, 5).value = f"=COUNTIF($A$2:$A${last_data_row},F{i})"  # E
    
    padded = vals[:max_output_cols] + [None] * max(0, max_output_cols - len(vals[:max_output_cols]))
    for offset, val in enumerate(padded, start=0):
        ws.cell(i, 7 + offset).value = val  # G:K

# Clear any leftover cells beneath the output area in E:K
for r in range(start_row + len(unique_keys), ws.max_row + 1):
    for c in range(5, 12):  # E:K
        # Only clear the designed output region below the actual unique list
        if r <= 14 or ws.cell(r, c).value is not None:
            ws.cell(r, c).value = None

# Save initial output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Restored original sheet names:", original_sheetnames)

# Verify formulas/values in normal workbook
wb_verify = load_workbook(output_path)
wsv = wb_verify[original_sheetnames[0]]
print("\nNormal workbook verification E3:K13")
for r in range(3, 14):
    row_vals = [wsv.cell(r, c).value for c in range(5, 12)]
    print(r, row_vals)

# Verify calculated values in data_only workbook
wb_data = load_workbook(output_path, data_only=True)
wsd = wb_data[original_sheetnames[0]]

print("\nData-only verification E3:K13")
for r in range(3, 14):
    row_vals = [wsd.cell(r, c).value for c in range(5, 12)]
    print(r, row_vals)

# Specific target checks
targets = ["F3", "E3", "G3", "G8", "G9", "G10", "G11", "H11", "G12", "G13"]
print("\nSpecific target cells:")
for ref in targets:
    print(ref, "formula/raw=", wsv[ref].value, "data_only=", wsd[ref].value)

# Check F3 is no longer an array formula object
print("\nF3 raw type after save:", type(wsv["F3"].value), "value:", wsv["F3"].value)

output_spreadsheet = output_path
