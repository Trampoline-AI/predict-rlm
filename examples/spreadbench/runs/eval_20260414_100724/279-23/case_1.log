Code:
```repl
from openpyxl import load_workbook
from pathlib import Path
import os
import re

input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook for editing
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Before modification, sample B values:")
for r in list(range(1, 13)) + list(range(17, 27)):
    print(f"B{r} = {ws[f'B{r}'].value!r}")

pattern = re.compile(r"\(([^()]*)\)")

changed = []
unchanged = []
blank_preserved = []

for r in range(1, ws.max_row + 1):
    cell = ws.cell(r, 2)  # Column B
    v = cell.value

    if v in (None, ""):
        blank_preserved.append(r)
        continue

    if isinstance(v, str):
        m = pattern.search(v)
        if m:
            new_v = m.group(1)
            if new_v != v:
                cell.value = new_v
                changed.append((r, v, new_v))
            else:
                unchanged.append((r, v))
        else:
            unchanged.append((r, v))
    else:
        unchanged.append((r, v))

print("\nChanged rows in column B:")
for item in changed:
    print(item)

print("\nBlank rows preserved:", blank_preserved)
print("Unchanged sample:", unchanged[:10])

wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate even though values are static, per instructions
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheet_names:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", original_sheet_names)
    for i, expected_name in enumerate(original_sheet_names):
        wb_check.worksheets[i].title = expected_name
    wb_check.save(output_path)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# Final verification using data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[original_sheet_names[0]]

print("\nVerification of target cells in column B:")
for r in range(1, ws.max_row + 1):
    print(f"B{r} = {wsv.cell(r, 2).value!r}")

# Sanity checks
assert wsv["B3"].value == "tig"
assert wsv["B5"].value == "tib"
assert wsv["B13"].value in (None, "")
assert wsv["B17"].value == "tig"
assert wsv["B19"].value == "tib"

final_output_path = str(output_path)
print("\nFinal output path ready for submission:", final_output_path)
```
