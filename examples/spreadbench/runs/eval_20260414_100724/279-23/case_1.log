    # Find non-empty rows
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("First non-empty row:", nonempty_rows[0], "Last non-empty row:", nonempty_rows[-1])
    
    # Sample first 10 non-empty rows
    print("\nFirst up to 10 non-empty rows:")
    for r in nonempty_rows[:10]:
        print(f"Row {r}:", row_values(ws, r, ws.max_column))
    
    # Sample last 5 non-empty rows
    print("\nLast up to 5 non-empty rows:")
    for r in nonempty_rows[-5:]:
        print(f"Row {r}:", row_values(ws, r, ws.max_column))
    
    # Specific inspection of column B
    print("\nColumn B inspection (first 20 rows or until max_row):")
    b_samples = []
    for r in range(1, min(ws.max_row, 20) + 1):
        cell = ws.cell(r, 2)
        b_samples.append((r, cell.value, cell.data_type))
    for item in b_samples:
        print(item)
    
    print("\nColumn B inspection (last 10 non-empty rows with B values/status):")
    last_rows = nonempty_rows[-10:] if nonempty_rows else []
    for r in last_rows:
        cell = ws.cell(r, 2)
        print(f"B{r} = {cell.value!r}, type={cell.data_type}")
    
    # Rows where column B is non-empty and contains parentheses, first few
    paren_rows = []
    no_paren_rows = []
    blank_b_rows = []
    formula_b_rows = []
    for r in range(1, ws.max_row + 1):
        cell = ws.cell(r, 2)
