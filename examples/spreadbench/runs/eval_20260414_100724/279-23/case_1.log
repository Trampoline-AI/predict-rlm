        if isinstance(v, str) and "(" in v and ")" in v:
            paren_rows.append((r, v))
        elif v in (None, ""):
            blank_b_rows.append(r)
        elif isinstance(v, str):
            no_paren_rows.append((r, v))
        if isinstance(v, str) and v.startswith("="):
            formula_b_rows.append((r, v))
    
    print(f"\nRows in column B with parentheses: {len(paren_rows)}")
