from openpyxl import load_workbook
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter
import os, re, shutil

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, os.path.basename(infile))
os.makedirs(outdir, exist_ok=True)

def norm(s):
    if s is None:
        return None
    s = str(s).strip()
    s = s.replace("'", "").replace(".", "")
    s = re.sub(r"\s+", " ", s)
    return s.upper()

# Inspect exact target area and relevant lookup rows
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws3 = wb["Sheet3"]

print("Original sheet names:", orig_sheetnames)
print("Current target formulas/values in Sheet1!G2:I7:")
for r in range(2, 8):
    print(r, [ws1.cell(r, c).value for c in range(7, 10)])

# Build lookup mapping from Sheet3 for verification/fallback
lookup = {}
for r in range(2, ws3.max_row + 1):
    key = norm(ws3.cell(r, 1).value)
    if key and key not in lookup:
        lookup[key] = (
            ws3.cell(r, 2).value,
            ws3.cell(r, 3).value,
            ws3.cell(r, 4).value,
            r
        )

print("\nRelevant Sheet3 lookup matches for Sheet1 names:")
for r in range(2, 8):
    name = ws1.cell(r, 6).value
    print(f"Row {r} name={name!r} ->", lookup.get(norm(name)))

# Write robust formulas into same target cells
# Use INDEX/MATCH with normalized comparison on the lookup range,
# so Sheet3 itself does not need to be altered.
for r in range(2, 8):
    rowref = f"F{r}"
    formulas = {
        7: f'=IFERROR(INDEX(Sheet3!$B$2:$B$300,MATCH(1,INDEX((TRIM(SUBSTITUTE(SUBSTITUTE(Sheet3!$A$2:$A$300,"\'",""),".",""))=TRIM(SUBSTITUTE(SUBSTITUTE({rowref},"\'",""),".","")))*1,0),0)),"")',
        8: f'=IFERROR(INDEX(Sheet3!$C$2:$C$300,MATCH(1,INDEX((TRIM(SUBSTITUTE(SUBSTITUTE(Sheet3!$A$2:$A$300,"\'",""),".",""))=TRIM(SUBSTITUTE(SUBSTITUTE({rowref},"\'",""),".","")))*1,0),0)),"")',
        9: f'=IFERROR(INDEX(Sheet3!$D$2:$D$300,MATCH(1,INDEX((TRIM(SUBSTITUTE(SUBSTITUTE(Sheet3!$A$2:$A$300,"\'",""),".",""))=TRIM(SUBSTITUTE(SUBSTITUTE({rowref},"\'",""),".","")))*1,0),0)),"")',
    }
    for c, formula in formulas.items():
        cell = ws1.cell(r, c)
        cell.value = formula
        cell.number_format = "@"
        cell.alignment = Alignment(horizontal="left")

print("\nNew formulas written to Sheet1!G2:I7:")
for r in range(2, 8):
    print(r, [ws1.cell(r, c).value for c in range(7, 10)])

wb.save(outfile)
print("\nSaved first pass to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Ensure sheet names remain original after recalc
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    for idx, old_name in enumerate(orig_sheetnames):
        if idx < len(wb_after.worksheets):
            wb_after.worksheets[idx].title = old_name
    wb_after.save(outfile)
else:
    print("Sheet names preserved after recalc.")

# Verify formula results
wbv = load_workbook(outfile, data_only=True)
ws1v = wbv["Sheet1"]

verified = True
print("\nVerified Sheet1!G2:I7 values after recalculation:")
for r in range(2, 8):
    vals = [ws1v.cell(r, c).value for c in range(7, 10)]
    expected = lookup.get(norm(ws1v.cell(r, 6).value if ws1v.cell(r, 6).value is not None else ws1.cell(r, 6).value))
    print("Row", r, "values", vals, "expected", expected[:3] if expected else None)
    if any(v is None for v in vals):
        verified = False

# Fallback to literal values if formulas did not recalc cleanly
if not verified:
    print("\nFormula verification failed or returned blanks; falling back to Python-computed literal values.")
    wb_fix = load_workbook(outfile)
    ws1_fix = wb_fix["Sheet1"]
    for r in range(2, 8):
        key = norm(ws1_fix.cell(r, 6).value)
        if key in lookup:
            b, cval, d, src_row = lookup[key]
            ws1_fix.cell(r, 7).value = b
            ws1_fix.cell(r, 8).value = cval
            ws1_fix.cell(r, 9).value = d
            for cc in range(7, 10):
                ws1_fix.cell(r, cc).number_format = "@"
                ws1_fix.cell(r, cc).alignment = Alignment(horizontal="left")
        else:
            for cc in range(7, 10):
