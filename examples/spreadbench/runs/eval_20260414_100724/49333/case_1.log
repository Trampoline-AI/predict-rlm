                ws1_fix.cell(r, cc).alignment = Alignment(horizontal="left")
    wb_fix.save(outfile)
    recalc_result2 = await recalculate(outfile)
    print("Recalculate result after fallback:", recalc_result2)

    wbv2 = load_workbook(outfile, data_only=True)
    ws1v2 = wbv2["Sheet1"]
    print("\nFinal verified Sheet1!G2:I7 values:")
    for r in range(2, 8):
        print(r, [ws1v2.cell(r, c).value for c in range(7, 10)])

output_spreadsheet = outfile
