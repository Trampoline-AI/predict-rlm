def normalize_num(v):
    if v is None or v == "" or v == " ":
        return None
    if isinstance(v, bool):
        return None
    if isinstance(v, (int, float)):
        return float(v)
    try:
        s = str(v).strip()
        if s == "":
            return None
        return float(s)
    except Exception:
        return None

# Identify exact target rows from CA labels
target_rows = []
for r in range(2, ws.max_row + 1):
    ca_val = ws[f"CA{r}"].value
    if isinstance(ca_val, str) and ca_val.strip().startswith("Triple Score #"):
        target_rows.append(r)

print("Target Triple Score rows:", target_rows)

# Build AF:AG mapping (position -> full name)
pos_to_name = {}
for r in range(2, ws.max_row + 1):
    af = ws[f"AF{r}"].value
    ag = ws[f"AG{r}"].value
    ag_num = normalize_num(ag)
    if af not in (None, "", " ") and ag_num is not None:
        pos_to_name[int(ag_num)] = af

print("Sample AF:AG mapping:", list(pos_to_name.items())[:10])

# Collect valid Triple Scores from source T2:T600, excluding zeros/blanks
source_scores = []
for r in range(2, min(600, ws.max_row) + 1):
    t_val = normalize_num(ws[f"T{r}"].value)
    if t_val is not None and t_val > 0:
        # preserve integer appearance when possible
        score_out = int(t_val) if float(t_val).is_integer() else float(t_val)
        source_scores.append((r, score_out))

# Sort like the intended formula behavior:
# largest score first, and for ties smallest row first
source_scores.sort(key=lambda x: (-float(x[1]), x[0]))
print("Valid Triple Score source rows:", source_scores)

# Write corrected values into CB:CE
for idx, r in enumerate(target_rows):
    if idx < len(source_scores):
        src_row, score = source_scores[idx]
        position = int(math.ceil(src_row / 21.0))
        full_name = pos_to_name.get(position, "")
        ws[f"CB{r}"] = score
        ws[f"CC{r}"] = src_row
        ws[f"CD{r}"] = position
        ws[f"CE{r}"] = full_name
    else:
        ws[f"CB{r}"] = ""
        ws[f"CC{r}"] = ""
        ws[f"CD{r}"] = ""
        ws[f"CE{r}"] = ""

# Save initial output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate as required
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and repair sheet names if LibreOffice changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    # rename sheets in order
    for i, orig_name in enumerate(orig_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = orig_name
    wb_after.save(output_path)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verification using data_only
wb_verify = load_workbook(output_path, data_only=True)
wsv = wb_verify[orig_sheetnames[0]]

print("\nVerification of target rows (CA:CE):")
for r in target_rows:
    print(r, {
        "CA": wsv[f"CA{r}"].value,
        "CB": wsv[f"CB{r}"].value,
        "CC": wsv[f"CC{r}"].value,
        "CD": wsv[f"CD{r}"].value,
        "CE": wsv[f"CE{r}"].value,
    })

# Focused checks for first filled rows and first blank row after results
filled_rows = target_rows[:len(source_scores)]
blank_rows = target_rows[len(source_scores):]

print("\nFilled row checks:")
for r in filled_rows:
    vals = [wsv[f"{col}{r}"].value for col in ["CB","CC","CD","CE"]]
    print(r, vals)

print("\nFirst 5 blank row checks:")
for r in blank_rows[:5]:
    vals = [wsv[f"{col}{r}"].value for col in ["CB","CC","CD","CE"]]
    print(r, vals)

output_spreadsheet = output_path
