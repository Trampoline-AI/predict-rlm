from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import math, os, shutil

path = input_spreadsheet
wb = load_workbook(path)
ws = wb[wb.sheetnames[0]]

# Inspect exact target/source cells and infer pattern from existing example
for coord in ["A1","B1","C1","A2","B2","C2"]:
    cell = ws[coord]
    print(coord, "value=", cell.value, "data_type=", cell.data_type, "number_format=", cell.number_format)

def td_to_hours(td):
    return td.total_seconds() / 3600

for r in range(1, ws.max_row + 1):
    b = ws.cell(r, 2).value
    c = ws.cell(r, 3).value
    if b is not None:
        hours = td_to_hours(b)
        print(f"Row {r}: B{r} hours={hours}, ceil={math.ceil(hours)}, existing C{r}={c}")

# Prepare output path
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(path))

# Fill only blank target cells in column C, preserving existing example answer
for r in range(1, ws.max_row + 1):
    source = ws.cell(r, 2).value
    target = ws.cell(r, 3)
    if source is not None and (target.value is None or target.value == ""):
        # Write Excel formula to keep workbook dynamic
        target.value = f"=ROUNDUP(B{r}*24,0)"
        target.number_format = "General"
        print(f"Writing formula to C{r}: {target.value}")

wb.save(out_path)
print("Saved to", out_path)

# Recalculate
result = await recalculate(out_path)
print("Recalculate:", result)

# Reload, restore sheet names if needed
orig_names = wb.sheetnames[:]
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_names:
    # rename in order if same count
    if len(wb2.sheetnames) == len(orig_names):
        for ws_obj, name in zip(wb2.worksheets, orig_names):
            ws_obj.title = name
        wb2.save(out_path)
        print("Restored original sheet names:", orig_names)

# Verify with data_only
wbv = load_workbook(out_path, data_only=True)
wsv = wbv[orig_names[0]]
for coord in ["B1","C1","B2","C2"]:
    cell = wsv[coord]
    print("Verified", coord, "=", cell.value)

# Also inspect stored formula workbook for C2
wbf = load_workbook(out_path, data_only=False)
print("Stored formula/value in C2:", wbf[orig_names[0]]["C2"].value, "format:", wbf[orig_names[0]]["C2"].number_format)

output_spreadsheet = out_path
```
