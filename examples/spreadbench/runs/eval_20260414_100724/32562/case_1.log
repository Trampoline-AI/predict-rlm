import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Reload fresh workbook for writing
wb_write = load_workbook(input_path)
original_sheet_names = wb_write.sheetnames[:]
ws = wb_write["Sheet2"]

# Determine true last data row in column A
last_data_row = 1
for r in range(ws.max_row, 1, -1):
    v = ws.cell(r, 1).value
    if v is not None and v != "":
        last_data_row = r
        break

print("Original sheet names:", original_sheet_names)
print("Target sheet:", ws.title)
print("Target column:", "B")
print("Header B1:", ws["B1"].value)
print("Last data row in column A:", last_data_row)

print("\nExisting formulas/values in B before modification:")
for r in range(2, last_data_row + 1):
    print(f"Row {r}: A={ws.cell(r,1).value!r}, B(before)={ws.cell(r,2).value!r}")

# Replace broken formulas in Column B with correct total-count formulas
for r in range(2, last_data_row + 1):
    a_val = ws.cell(r, 1).value
    if a_val is None or a_val == "":
        # Leave truly empty data rows blank
        ws.cell(r, 2).value = None
    else:
        ws.cell(r, 2).value = f'=COUNTIF($A$2:$A${last_data_row},A{r})'

wb_write.save(output_path)
print("\nSaved workbook to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open after recalc and restore sheet names if needed
wb_post = load_workbook(output_path)
print("Sheet names after recalc:", wb_post.sheetnames)
if wb_post.sheetnames != original_sheet_names:
    # Rename sheets back to original names by position
    for idx, original_name in enumerate(original_sheet_names):
        wb_post.worksheets[idx].title = original_name
    wb_post.save(output_path)
    print("Restored sheet names to:", original_sheet_names)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]

print("\nVerified formulas in target cells:")
for r in range(2, last_data_row + 1):
    print(f"B{r} formula: {ws_formula.cell(r,2).value}")

# Verify cached values after recalculation
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("\nVerified computed values in target cells:")
verified = []
for r in range(2, last_data_row + 1):
    a = ws_values.cell(r, 1).value
    b = ws_values.cell(r, 2).value
    verified.append((r, a, b))
    print(f"Row {r}: A={a!r}, B={b!r}")

# Focus on duplicates / sanity check
print("\nDuplicate-item sanity check:")
for r, a, b in verified:
    if a in (374, 321):
        print(f"Row {r}: item={a}, count={b}")

# Check for blanks/errors in target output
bad_rows = [(r, a, b) for r, a, b in verified if a not in (None, "") and b in (None, "")]
print("\nRows with missing output values:", bad_rows)
print("Output file ready:", output_path)
