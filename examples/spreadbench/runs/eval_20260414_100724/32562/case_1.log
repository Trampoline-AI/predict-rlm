from collections import Counter, defaultdict

ws = wb[wb.sheetnames[0]]

# Gather actual data rows
data_rows = []
for r in range(2, ws.max_row + 1):
    a = ws.cell(r, 1).value
    b = ws.cell(r, 2).value
    if a is not None and a != "":
        data_rows.append((r, a, b))

items = [a for _, a, _ in data_rows]
total_counts = Counter(items)

running_counts = []
seen = defaultdict(int)
for r, a, b in data_rows:
    seen[a] += 1
    running_counts.append((r, a, seen[a], total_counts[a]))

print("Distinct items:", len(total_counts))
print("Items with duplicates only:", {k: v for k, v in total_counts.items() if v > 1})

print("\nComparison of possible intended outputs:")
print("row | item | current_formula | running_occurrence | total_count")
for r, a, current_running, total in running_counts:
    print(f"{r:>3} | {a!r:>4} | {ws.cell(r,2).value!r:>24} | {current_running:>18} | {total:>11}")

# Show what formulas would be if writing total-count or running-occurrence formulas
print("\nCandidate formulas for first few data rows:")
for r in range(2, min(ws.max_row, 8) + 1):
    print(
        f"Row {r}: total='=COUNTIF($A$2:$A${ws.max_row},A{r})', "
        f"running='=COUNTIF($A$2:A{r},A{r})'"
    )
