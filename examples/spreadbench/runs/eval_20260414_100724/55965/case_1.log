import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

wb = load_workbook(input_spreadsheet)
sheet_names = wb.sheetnames
print("Workbook:", input_spreadsheet)
print("Sheets:", sheet_names)

def row_values(ws, r, max_cols=None):
    if max_cols is None:
        max_cols = ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols + 1)]

def nonempty_bounds(ws):
    max_r = ws.max_row
    max_c = ws.max_column
    # scan to find actual last non-empty row/col
    last_r = 0
    last_c = 0
    for r in range(1, max_r + 1):
        row_has = False
        for c in range(1, max_c + 1):
            v = ws.cell(r, c).value
            if v is not None and v != "":
                row_has = True
                last_c = max(last_c, c)
        if row_has:
            last_r = r
    return last_r, last_c

for s in sheet_names:
    ws = wb[s]
    last_r, last_c = nonempty_bounds(ws)
    print(f"\n=== Sheet: {s} ===")
    print(f"openpyxl max_row={ws.max_row}, max_col={ws.max_column}, actual last non-empty row={last_r}, col={last_c} ({get_column_letter(last_c) if last_c else 'N/A'})")
    headers = row_values(ws, 1, min(max(last_c, ws.max_column), 20))
    print("Row 1 / headers-ish:", headers)
    
    # first 10 rows up to first 16 cols
    max_print_cols = min(max(last_c, ws.max_column), 16)
    print("First rows:")
    for r in range(1, min(last_r, 10) + 1):
        print(r, row_values(ws, r, max_print_cols))
    
    print("Last rows:")
    start_last = max(1, last_r - 4)
    for r in range(start_last, last_r + 1):
        print(r, row_values(ws, r, max_print_cols))

# Focused inspection of Sheet1 and candidate target range
if "Sheet1" in wb.sheetnames:
    ws = wb["Sheet1"]
    print("\n=== Focus: Sheet1 columns A:P ===")
    for r in range(1, min(ws.max_row, 20) + 1):
        vals = [ws.cell(r, c).value for c in range(1, 17)]
        print(r, vals)
    
    print("\nSheet1 specific columns E and G:P for first 20 rows:")
    for r in range(1, min(ws.max_row, 20) + 1):
        e = ws.cell(r, 5).value
        gp = [ws.cell(r, c).value for c in range(7, 17)]
        print(f"Row {r}: E={e!r}, G:P={gp}")

# Inspect formulas / existing values in G:P if any
if "Sheet1" in wb.sheetnames:
    ws = wb["Sheet1"]
    print("\nExisting formulas/values in Sheet1 G:P where anything is non-empty (first 30 rows):")
    for r in range(1, min(ws.max_row, 30) + 1):
        vals = [ws.cell(r, c).value for c in range(7, 17)]
        if any(v is not None and v != "" for v in vals):
            print(r, vals)
