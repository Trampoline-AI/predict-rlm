```repl
import os
from collections import defaultdict
from openpyxl import load_workbook

# Load input
infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
print("Original sheet names:", original_sheetnames)

ws_data = wb["DATI"]
ws_out = wb["Foglio1"]

# Build lookup: ID -> list of TOT values in original sheet order
by_id = defaultdict(list)
for r in range(2, ws_data.max_row + 1):
    tot = ws_data.cell(r, 10).value   # J
    idv = ws_data.cell(r, 11).value   # K
    if idv is not None and tot not in (None, ""):
        by_id[idv].append(tot)

print("Available IDs in DATI:", sorted(by_id.keys()))
for k in sorted(by_id.keys()):
    print(f"ID {k}: {len(by_id[k])} results, last10={by_id[k][-10:]}")

# Show current target cells before modification
print("\nCurrent Foglio1 target area before writing:")
for r in range(1, ws_out.max_row + 1):
    e = ws_out.cell(r, 5).value
    gp = [ws_out.cell(r, c).value for c in range(7, 17)]
    if r <= 5 or e is not None:
        print(f"Row {r}: E={e!r}, G:P={gp}")

# Fill Foglio1 G:P based on ID in column E
rows_written = []
rows_skipped_correct = []
rows_unknown_id = []

for r in range(2, ws_out.max_row + 1):
    idv = ws_out.cell(r, 5).value  # E
    if idv in (None, ""):
        continue
    
    if idv not in by_id:
        rows_unknown_id.append((r, idv))
        continue
    
    seq = by_id[idv][-10:]  # last 10, oldest->newest among the last 10
    
    # If fewer than 10, right-align so most recent lands in P (header 1)
    target_vals = [None] * 10
    start = 10 - len(seq)
    for i, v in enumerate(seq):
        target_vals[start + i] = v
    
    existing = [ws_out.cell(r, c).value for c in range(7, 17)]
    
    if existing == target_vals:
        rows_skipped_correct.append(r)
        continue
    
    for i, c in enumerate(range(7, 17)):
        ws_out.cell(r, c).value = target_vals[i]
    rows_written.append((r, idv, target_vals))

print("\nRows already correct and left unchanged:", rows_skipped_correct)
print("Rows written:", [(r, idv) for r, idv, _ in rows_written])
print("Rows with unknown ID:", rows_unknown_id)

# Save output
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if recalculate changed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames and len(wb_after.sheetnames) == len(original_sheetnames):
    for i, expected_name in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = expected_name
    wb_after.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify after recalculation using data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)

ws_verify = wb_verify["Foglio1"]

print("\nVerification of Foglio1!G:P:")
for r in range(2, ws_verify.max_row + 1):
    idv = ws_verify.cell(r, 5).value
    if idv in (None, ""):
        continue
    vals = [ws_verify.cell(r, c).value for c in range(7, 17)]
    expected = None
    if idv in by_id:
        seq = by_id[idv][-10:]
        expected = [None] * 10
        start = 10 - len(seq)
        for i, v in enumerate(seq):
            expected[start + i] = v
    print(f"Row {r}: ID={idv}, G:P={vals}, expected={expected}")

# Store for submission next turn
output_path = outfile
print("\nReady to submit:", output_path)
