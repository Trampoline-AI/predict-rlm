```repl
import os
from openpyxl import load_workbook
from openpyxl.styles import PatternFill

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

# Load workbook and identify exact target range
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Determine actual last data row from columns A:B
last_data_row = 1
for r in range(2, ws.max_row + 1):
    if ws.cell(r, 1).value is not None or ws.cell(r, 2).value is not None:
        last_data_row = r

print("Original sheet names:", orig_sheetnames)
print("Target sheet:", ws.title)
print("Header H1:", ws["H1"].value)
print("Last data row based on A:B:", last_data_row)
print("Target range:", f"H2:H{last_data_row}")

print("\nCurrent H formulas/values before change:")
for r in range(2, min(last_data_row, 10) + 1):
    print(r, ws[f"H{r}"].coordinate, ws[f"H{r}"].value)

# Build a single self-contained formula for H2:Hlast_data_row
# This returns the next Type whose Quantity is non-zero, with IFERROR -> blank.
data_a = f"$A$2:$A${last_data_row}"
data_b = f"$B$2:$B${last_data_row}"

green_fill = PatternFill(start_color="FF92D050", end_color="FF92D050", fill_type="solid")

for r in range(2, last_data_row + 1):
    formula = (
        f'=IFERROR(INDEX({data_a},MATCH(0,INDEX(COUNTIF($H$1:H{r-1},{data_a})+({data_b}=0),0),0)),"")'
    )
    ws[f"H{r}"] = formula
    ws[f"H{r}"].fill = green_fill

print("\nNew H formulas written:")
for r in range(2, min(last_data_row, 10) + 1):
    print(r, ws[f"H{r}"].coordinate, ws[f"H{r}"].value)

wb.save(outfile)
print("\nSaved to:", outfile, "exists:", os.path.exists(outfile), "size:", os.path.getsize(outfile))

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice renamed them
wb_after = load_workbook(outfile)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc; restoring...")
    for i, orig_name in enumerate(orig_sheetnames):
        wb_after.worksheets[i].title = orig_name
    wb_after.save(outfile)
    wb_after = load_workbook(outfile)
print("Final sheet names:", wb_after.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
ws_formula = wb_formula[orig_sheetnames[0]]
wb_values = load_workbook(outfile, data_only=True)
ws_values = wb_values[orig_sheetnames[0]]

expected = []
for r in range(2, last_data_row + 1):
    q = ws_values.cell(r, 2).value
    t = ws_values.cell(r, 1).value
    if isinstance(q, (int, float)) and q != 0:
        expected.append(t)

actual = [ws_values[f"H{r}"].value for r in range(2, last_data_row + 1)]
nonblank_actual = [v for v in actual if v not in (None, "")]
print("\nExpected non-zero Type list:", expected)
print("Actual nonblank H values:", nonblank_actual)

print("\nDetailed verification H2:H{}:".format(last_data_row))
for r in range(2, last_data_row + 1):
    f = ws_formula[f"H{r}"].value
    v = ws_values[f"H{r}"].value
    fill = ws_formula[f"H{r}"].fill
    fill_rgb = fill.start_color.rgb if fill.fill_type == "solid" else None
    print(r, ws_formula[f"H{r}"].coordinate, "formula:", f, "value:", v, "fill:", fill.fill_type, fill_rgb)

# Basic checks
print("\nChecks:")
print("H column header still:", ws_formula["H1"].value)
print("Nonblank actual count:", len(nonblank_actual))
print("Expected count:", len(expected))
print("Matches expected sequence:", nonblank_actual == expected)
