import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:")
print(instruction)

path = input_spreadsheet
print("\nInput path:", path, "exists:", os.path.exists(path), "size:", os.path.getsize(path))

wb = load_workbook(path)
print("\nSheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        vals.append(ws.cell(r, c).value)
    return vals

for ws in wb.worksheets:
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    headers = row_values(ws, 1, ws.max_column)
    print("Row1 headers/values:", headers)
    if ws.max_row >= 2:
        print("Row2 values:", row_values(ws, 2, ws.max_column))
    # print first 10 rows and last 5 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        print(r, row_values(ws, r, ws.max_column))
    start_last = max(1, ws.max_row - 4)
    print("Last rows:")
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, ws.max_column))

    # show cells with formulas in used range
    formula_cells = []
    for row in ws.iter_rows():
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("="):
                formula_cells.append((cell.coordinate, cell.value))
    print("Formula cells count:", len(formula_cells))
    print("First up to 20 formula cells:", formula_cells[:20])

    # merged cells if any
    if ws.merged_cells.ranges:
        print("Merged ranges:", list(ws.merged_cells.ranges))
