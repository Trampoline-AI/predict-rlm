import os
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load fresh workbook
wb2 = load_workbook(input_path)
original_sheetnames = wb2.sheetnames[:]
ws = wb2[original_sheetnames[0]]

# Determine rows to keep: last occurrence of each value in column B
target_col = 2  # verified from inspection
last_row_for_value = {}
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, target_col).value
    last_row_for_value[v] = r

rows_to_keep = sorted(last_row_for_value.values())
rows_to_delete = [r for r in range(1, ws.max_row + 1) if r not in rows_to_keep]

print("Original sheetnames:", original_sheetnames)
print("Rows to keep (original row numbers):", rows_to_keep)
print("Rows to delete (original row numbers):", rows_to_delete)

# Delete bottom-up so row indices remain valid
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

print("After deletion: max_row =", ws.max_row, "max_col =", ws.max_column)
print("Remaining rows before save:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Save
wb2.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if needed
wb_check = load_workbook(output_path)
print("Sheetnames after recalc/reload:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheetnames:
    # Rename sheets back by position
    for i, original_name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    print("Renamed sheets back to original:", original_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheetnames:", wb_verify.sheetnames)

wsv = wb_verify[original_sheetnames[0]]
verified_rows = []
for r in range(1, wsv.max_row + 1):
    verified_rows.append([wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)])

print("Verified final rows:")
for i, row in enumerate(verified_rows, start=1):
    print(i, row)

# Sanity checks
final_b = [wsv.cell(r, 2).value for r in range(1, wsv.max_row + 1)]
print("Final column B values:", final_b)

# Ensure they are exactly the last occurrences from the original
expected_rows = [
    ['DATA 3', 1],
    ['DATA 6', 2],
    ['DATA 9', 3],
    ['DATA 10', 4],
    ['DATA 12', 5],
]
print("Expected rows:", expected_rows)
print("Match expected:", verified_rows == expected_rows)

output_spreadsheet = output_path
