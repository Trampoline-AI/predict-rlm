import os, json, math, statistics
from collections import Counter, defaultdict
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input:", path)
print("Instruction:", instruction)

wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_cols+1)]

for ws in wb.worksheets:
    print("\n--- SHEET ---", ws.title)
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Find first 3 non-empty rows to help identify header
    nonempty_rows = []
    for r in range(1, min(ws.max_row, 20)+1):
        vals = row_values(ws, r, ws.max_column)
        if any(v not in (None, "") for v in vals):
            nonempty_rows.append((r, vals))
    print("First non-empty rows (up to 10 shown):")
    for r, vals in nonempty_rows[:10]:
        print(r, vals)
    
    headers = row_values(ws, 1, ws.max_column)
    print("Row 1 headers/values:", headers)
    
    # sample first 10 rows
    print("First 10 rows:")
    for r in range(1, min(ws.max_row, 10)+1):
        print(r, row_values(ws, r, ws.max_column))
    
    # sample last 5 rows
    print("Last 5 rows:")
    for r in range(max(1, ws.max_row-4), ws.max_row+1):
        print(r, row_values(ws, r, ws.max_column))
    
    # Analyze duplicates by column excluding header row
    print("Duplicate analysis by column (rows 2:max_row):")
    for c in range(1, ws.max_column+1):
        vals = []
        for r in range(2, ws.max_row+1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                vals.append(v)
        if not vals:
            continue
        distinct = len(set(vals))
        dup_count = len(vals) - distinct
        # only print interesting columns
        if dup_count > 0:
            sample_dups = [item for item, cnt in Counter(vals).items() if cnt > 1][:10]
            print(f"  Col {get_column_letter(c)} header={ws.cell(1,c).value!r}: nonempty={len(vals)} distinct={distinct} dup_count={dup_count} sample_dup_values={sample_dups}")
