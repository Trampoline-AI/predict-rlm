import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter, column_index_from_string

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Original sheet names:", orig_sheet_names)

def row_values(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    return [ws.cell(r, c).value for c in range(1, mc+1)]

def nonempty_header_row(ws, max_scan=10):
    # find likely header row among first few rows
    best_row, best_count = 1, -1
    for r in range(1, min(max_scan, ws.max_row) + 1):
        vals = row_values(ws, r, ws.max_column)
        count = sum(v not in (None, "") for v in vals)
        if count > best_count:
            best_row, best_count = r, count
    return best_row

inspection = {}

for s in wb.sheetnames:
    ws = wb[s]
    header_row = nonempty_header_row(ws)
    headers = row_values(ws, header_row, ws.max_column)
    inspection[s] = {
        "max_row": ws.max_row,
        "max_col": ws.max_column,
        "header_row": header_row,
        "headers": headers,
    }
    print("\n=== SHEET:", s, "===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column, "header_row guess:", header_row)
    header_map = {get_column_letter(i+1): headers[i] for i in range(len(headers))}
    print("Headers by column:", header_map)

    # print first 8 rows
    print("First rows:")
    for r in range(1, min(ws.max_row, 8) + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))
    # print last 5 rows
    print("Last rows:")
    start_last = max(1, ws.max_row - 4)
    for r in range(start_last, ws.max_row + 1):
        print(r, row_values(ws, r, min(ws.max_column, 12)))

    # inspect column J values/formulas and nearby columns
    if ws.max_column >= 10:
        print("Sample J column values/formulas and nearby H:J/L data:")
        data_start = min(header_row + 1, ws.max_row)
        sample_rows = list(range(data_start, min(ws.max_row, data_start + 7) + 1))
        if ws.max_row > data_start + 10:
            sample_rows += list(range(max(data_start, ws.max_row - 4), ws.max_row + 1))
        seen = set()
        for r in sample_rows:
            if r in seen: 
                continue
            seen.add(r)
            vals = {get_column_letter(c): ws.cell(r, c).value for c in range(max(1, 8), min(ws.max_column, 12)+1)}
            print("Row", r, vals)

        # print formulas specifically in J
        print("Existing formulas in J (first/last non-empty examples):")
        j_examples = []
        for r in range(1, ws.max_row + 1):
            v = ws.cell(r, 10).value
            if v not in (None, ""):
                j_examples.append((r, v))
        print("Count non-empty J cells:", len(j_examples))
        print("First up to 10 J examples:", j_examples[:10])
        print("Last up to 10 J examples:", j_examples[-10:])

        # search headers of interest
        header_lookup = {}
        for idx, h in enumerate(headers, start=1):
            if isinstance(h, str):
                header_lookup[h.strip().lower()] = idx
        print("Matched header lookup candidates:",
              {k:v for k,v in header_lookup.items() if any(term in k for term in ["remark", "outstanding", "prepaid", "over due", "overdue", "amount"])})
