import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.utils.cell import range_boundaries

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

ws = wb[original_sheet_names[0]]

# Confirm target layout again
headers = [ws.cell(5, c).value for c in range(1, ws.max_column + 1)]
print("Header row 5:", headers)
print("J header:", ws["J5"].value)
print("Existing J formulas before change:")
for r in range(6, 11):
    print(r, ws[f"J{r}"].value)

# Determine data rows from table if present, else from non-empty rows
data_rows = []
table_ref = None
if ws.tables and "Table2" in ws.tables:
    t = ws.tables["Table2"]
    table_ref = t.ref
    min_col, min_row, max_col, max_row = range_boundaries(table_ref)
    data_rows = list(range(min_row + 1, max_row + 1))  # skip header row
else:
    for r in range(6, ws.max_row + 1):
        if any(ws.cell(r, c).value not in (None, "") for c in range(1, ws.max_column + 1)):
            data_rows.append(r)

print("Table ref:", table_ref)
print("Target data rows:", data_rows)

# Write new remarks formulas in J only for actual data rows
new_formulas = {}
for r in data_rows:
    old_formula = ws[f"J{r}"].value
    new_formula = f'=IF(B{r}="","",IF(C{r}-E{r}<0,"Prepaid",IF(C{r}-E{r}=0,"",IF(TODAY()-(B{r}+D{r})<90,"Call Customer","Bad Debts"))))'
    ws[f"J{r}"] = new_formula
    new_formulas[r] = (old_formula, new_formula)

print("Written new J formulas:")
for r, (oldf, newf) in new_formulas.items():
    print(f"Row {r}: old={oldf} | new={newf}")

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb_after = load_workbook(output_path)
after_names = wb_after.sheetnames[:]
print("Sheet names after recalc:", after_names)

if after_names != original_sheet_names:
    print("Sheet names changed; restoring...")
    # rename by position to original names
    for idx, orig_name in enumerate(original_sheet_names):
        if idx < len(wb_after.worksheets):
            wb_after.worksheets[idx].title = orig_name
    wb_after.save(output_path)
    print("Restored sheet names:", wb_after.sheetnames)

# Verify formulas and cached values
wb_formula = load_workbook(output_path)
wb_values = load_workbook(output_path, data_only=True)
wsf = wb_formula[original_sheet_names[0]]
wsv = wb_values[original_sheet_names[0]]

print("\nVerification of target cells J6:J10:")
verification = []
for r in data_rows:
    row_info = {
        "row": r,
        "customer": wsv[f"A{r}"].value,
        "invoice_amount": wsv[f"C{r}"].value,
        "amount_received": wsv[f"E{r}"].value,
        "remarks_formula": wsf[f"J{r}"].value,
        "remarks_value": wsv[f"J{r}"].value,
    }
    verification.append(row_info)
    print(row_info)

# Sanity check no target cells are blank
blank_rows = [v["row"] for v in verification if v["remarks_value"] in (None, "")]
print("Blank target rows after recalc:", blank_rows)

# Keep path ready for submission
final_output_path = output_path
print("Final output path ready:", final_output_path)
```
