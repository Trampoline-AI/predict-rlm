Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os

infile = input_spreadsheet
outfile = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(infile))

wb = load_workbook(infile)
src = wb["cdnr"]
dst = wb["b2b, sez, de"]
exp = wb["Expected"]

def row_values(ws, r, max_col=None):
    max_col = max_col or ws.max_column
    return [ws.cell(r, c).value for c in range(1, max_col + 1)]

def row_has_data(ws, r, cols=22):
    return any(ws.cell(r, c).value not in (None, "") for c in range(1, cols + 1))

# Identify actual source data rows
source_rows = [r for r in range(5, src.max_row + 1) if row_has_data(src, r, 22)]
print("Source data rows:", source_rows)

# Identify first empty row in destination without overwriting existing rows
start_row = None
for r in range(5, dst.max_row + 1):
    if not row_has_data(dst, r, 22):
        start_row = r
        break
if start_row is None:
    start_row = dst.max_row + 1

print("Destination first empty row:", start_row)

# Inspect formats/styles to preserve
template_row = start_row - 1 if start_row > 5 else 5
print("Using template row for styles:", template_row)
print("Template L/M number formats:",
      dst[f"L{template_row}"].number_format,
      dst[f"M{template_row}"].number_format)

# Mapping inferred from Expected
# keys are destination columns, values are either source column index or constants
# source indices use 1-based numbering
mapping = {
    1: ("src", 1),   # A <- A
    2: ("src", 2),   # B <- B
    3: ("src", 3),   # C <- C
    4: ("src", 4),   # D <- D
    5: ("src", 9),   # E <- I
    6: ("src", 6),   # F <- F
    7: ("src", 7),   # G <- G
    8: ("const", None),  # H blank
    9: ("const", "Credit Note"),  # I fixed
    10: ("src", 10), # J <- J
    11: ("src", 11), # K <- K
    12: ("neg", 12), # L <- -L
    13: ("neg", 13), # M <- -M
    14: ("src", 14), # N <- N
    15: ("src", 15), # O <- O
    16: ("src", 16), # P <- P
    17: ("src", 17), # Q <- Q
    18: ("src", 18), # R <- R
    19: ("src", 19), # S <- S
    20: ("src", 20), # T <- T
    21: ("src", 21), # U <- U
    22: ("src", 22), # V <- V
}

# Before writing, print current destination target area
print("\nDestination target area before writing:")
for r in range(start_row, start_row + max(len(source_rows), 3)):
    print(r, row_values(dst, r, 22))

# Append rows
for i, src_r in enumerate(source_rows):
    dst_r = start_row + i

    # Copy style from template row to preserve formatting/appearance
    for c in range(1, dst.max_column + 1):
        src_style_cell = dst.cell(template_row, c)
        dst_cell = dst.cell(dst_r, c)
        dst_cell._style = copy(src_style_cell._style)
        if src_style_cell.has_style:
            dst_cell.number_format = src_style_cell.number_format
            dst_cell.font = copy(src_style_cell.font)
            dst_cell.fill = copy(src_style_cell.fill)
            dst_cell.border = copy(src_style_cell.border)
            dst_cell.alignment = copy(src_style_cell.alignment)
            dst_cell.protection = copy(src_style_cell.protection)

    # Write mapped values
    for dc in range(1, 23):
        kind, spec = mapping[dc]
        cell = dst.cell(dst_r, dc)
        if kind == "src":
            cell.value = src.cell(src_r, spec).value
        elif kind == "const":
            cell.value = spec
        elif kind == "neg":
            val = src.cell(src_r, spec).value
            if val in (None, ""):
                cell.value = val
            else:
                try:
                    cell.value = -abs(float(val))
                except Exception:
                    cell.value = val

    # Explicitly preserve L/M number formats from destination template row
    dst.cell(dst_r, 12).number_format = dst.cell(template_row, 12).number_format
    dst.cell(dst_r, 13).number_format = dst.cell(template_row, 13).number_format

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Verify sheet names after recalc, rename back if needed
wb_after = load_workbook(outfile)
original_sheetnames = ['b2b, sez, de', 'cdnr', 'Expected']
print("Sheet names after recalc:", wb_after.sheetnames)

if wb_after.sheetnames != original_sheetnames:
    # rename by position if names changed
    for idx, expected_name in enumerate(original_sheetnames):
        wb_after.worksheets[idx].title = expected_name
    wb_after.save(outfile)
    print("Renamed sheets back to original names:", wb_after.sheetnames)

# Reload for verification
wb_val = load_workbook(outfile, data_only=True)
dst_val = wb_val["b2b, sez, de"]
exp_val = wb_val["Expected"]

print("\nDestination target area after writing:")
for r in range(start_row, start_row + len(source_rows)):
    print(r, row_values(dst_val, r, 22))

# Verify exact target cells/rows against Expected
mismatches = []
for r in range(1, max(dst_val.max_row, exp_val.max_row) + 1):
    for c in range(1, 23):
        dv = dst_val.cell(r, c).value
        ev = exp_val.cell(r, c).value
        if dv != ev:
            mismatches.append((r, c, dv, ev))
            if len(mismatches) <= 15:
                print("Mismatch:", f"{get_column_letter(c)}{r}", "out=", dv, "exp=", ev)

print("Total mismatches between destination and Expected over A:V:", len(mismatches))

# Specific verification for required columns H, I, L, M
print("\nVerification of H, I, L, M on appended rows:")
for r in range(start_row, start_row + len(source_rows)):
    print(
        r,
        {
            "H": dst_val[f"H{r}"].value,
            "I": dst_val[f"I{r}"].value,
            "L": dst_val[f"L{r}"].value,
            "M": dst_val[f"M{r}"].value,
        }
    )

# Additional sanity checks
all_nonblank_i = all(dst_val[f"I{r}"].value == "Credit Note" for r in range(start_row, start_row + len(source_rows)))
all_blank_h = all(dst_val[f"H{r}"].value in (None, "") for r in range(start_row, start_row + len(source_rows)))
print("All appended I cells are 'Credit Note':", all_nonblank_i)
print("All appended H cells are blank:", all_blank_h)

output_spreadsheet = outfile
```
