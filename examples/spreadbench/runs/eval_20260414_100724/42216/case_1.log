import os, json, math, statistics
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

path = input_spreadsheet
print("Input path:", path)
wb = load_workbook(path)
print("Sheet names:", wb.sheetnames)

def show_sheet(ws, sample_first=10, sample_last=5):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    # find non-empty rows/cols more realistically
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                nonempty_cols.add(c)
        if row_has:
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows))
    print("Non-empty cols:", [f"{get_column_letter(c)}" for c in sorted(nonempty_cols)])
    
    # Print first 15 rows x all used cols
    used_cols = sorted(nonempty_cols) if nonempty_cols else list(range(1, ws.max_column+1))
    if not used_cols:
        return
    min_c, max_c = min(used_cols), max(used_cols)
    headers = [ws.cell(1, c).value for c in range(min_c, max_c + 1)]
    print("Row 1 values:", headers)
    
    def row_vals(r):
        return [ws.cell(r, c).value for c in range(min_c, max_c + 1)]
    
    first_rows = list(range(1, min(ws.max_row, sample_first) + 1))
    print("\nFirst rows:")
    for r in first_rows:
        print(r, row_vals(r))
    
    if ws.max_row > sample_first:
        print("\nLast rows:")
        start = max(sample_first + 1, ws.max_row - sample_last + 1)
        for r in range(start, ws.max_row + 1):
            print(r, row_vals(r))

for ws in wb.worksheets:
    show_sheet(ws)

# additionally inspect merged cells and formulas
for ws in wb.worksheets:
    print(f"\nSheet {ws.title} merged ranges:", list(ws.merged_cells.ranges)[:20])
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((r, c, v))
    print(f"Formula cells in {ws.title}:", formulas[:20], "count=", len(formulas))
