```repl
import os
from copy import copy
from datetime import datetime, timedelta
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Pre-write Group A month rows:", [ws.cell(r,1).value for r in range(3,14)])
print("Pre-write Group B last existing date:", ws["A261"].value)

# --- Add April row in Group A without shifting Group B ---
# Shift existing month rows 6:13 down to 7:14 (blank rows 14-16 are available)
for src_row in range(13, 5, -1):
    dst_row = src_row + 1
    for c in range(1, 33):  # A:AF
        src = ws.cell(src_row, c)
        dst = ws.cell(dst_row, c)
        dst.value = src.value
        if src.has_style:
            dst._style = copy(src._style)
        if src.number_format:
            dst.number_format = src.number_format
        if src.font:
            dst.font = copy(src.font)
        if src.fill:
            dst.fill = copy(src.fill)
        if src.border:
            dst.border = copy(src.border)
        if src.alignment:
            dst.alignment = copy(src.alignment)
        if src.protection:
            dst.protection = copy(src.protection)
        if src.hyperlink:
            dst._hyperlink = copy(src.hyperlink)
        if src.comment:
            dst.comment = copy(src.comment)

# Clear row 6 values, keep style pattern from old row
for c in range(1, 33):
    ws.cell(6, c).value = None

ws["A6"] = "1951-04"
# For April, keep zeros as blanks in Group A -> since no April source exists, leave B:AF blank

print("Post-shift Group A month rows:", [ws.cell(r,1).value for r in range(3,15)])
print("April row preview A6:AF6:", [ws.cell(6, c).value for c in range(1, 10)])

# --- Build lookup from Group A ---
source_map = {}
for r in range(3, 15):  # rows with Jan-Dec after April insertion
    ym = ws.cell(r, 1).value
    if isinstance(ym, str) and ym.startswith("1951-"):
        year, month = map(int, ym.split("-"))
        for day in range(1, 32):
            source_map[(year, month, day)] = ws.cell(r, day + 1).value

# --- Extend Group B dates through 1951-11-16 ---
date_rows = []
for r in range(19, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, datetime):
        date_rows.append((r, v))

last_row = date_rows[-1][0]
last_date = date_rows[-1][1]
target_end = datetime(1951, 11, 16)

date_style = copy(ws["A19"]._style)
data_style = copy(ws["B19"]._style)
a_numfmt = ws["A19"].number_format
b_numfmt = ws["B19"].number_format

while last_date.date() < target_end.date():
    last_row += 1
    last_date = last_date + timedelta(days=1)
    a = ws.cell(last_row, 1)
    b = ws.cell(last_row, 2)
    a.value = last_date
    a._style = copy(date_style)
    a.number_format = a_numfmt
    b._style = copy(data_style)
    b.number_format = b_numfmt
    b.value = None

print("Extended Group B through row", last_row, "date", ws.cell(last_row,1).value)

# --- Fill Group B Data ---
drop_markers = {-9999, -99999, "-9999", "-99999", "M"}
na_markers = {"NA"}

filled_samples = []
for r in range(19, last_row + 1):
    d = ws.cell(r, 1).value
    if not isinstance(d, datetime):
        continue

    val = source_map.get((d.year, d.month, d.day), None)

    if val in drop_markers:
        out = None
    elif val in na_markers:
        out = None
    elif val in (None, ""):
        out = 0
    else:
        out = val

    # April specifically should be 0s in Group B, not blanks
    if d.month == 4 and out is None:
        out = 0

    ws.cell(r, 2).value = out

    if d.strftime("%Y-%m-%d") in {
        "1951-01-04", "1951-04-01", "1951-04-15",
        "1951-07-12", "1951-09-05", "1951-10-15",
        "1951-11-03", "1951-11-16"
    }:
        filled_samples.append((r, d.strftime("%Y-%m-%d"), val, out))

print("Key mapping samples (row, date, source, written):")
for item in filled_samples:
    print(item)

wb.save(outfile)
print("Saved to:", outfile)

recalc_result = await recalculate(outfile)
print("Recalculate:", recalc_result)

# Restore sheet names if LibreOffice changed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_check.sheetnames, "-> restoring", orig_sheetnames)
    current_names = wb_check.sheetnames[:]
    for idx, target_name in enumerate(orig_sheetnames):
        wb_check[current_names[idx]].title = target_name
    wb_check.save(outfile)
else:
    print("Sheet names preserved:", wb_check.sheetnames)

# --- Verification ---
ver = load_workbook(outfile, data_only=True)
wsv = ver[orig_sheetnames[0]]

print("Verified sheet names:", ver.sheetnames)
print("Verified Group A months rows 3:14:", [wsv.cell(r,1).value for r in range(3,15)])
print("Verified April row A6:K6:", [wsv.cell(6, c).value for c in range(1, 12)])

def find_row_for_date(target_dt):
    for r in range(19, wsv.max_row + 1):
        v = wsv.cell(r, 1).value
        if isinstance(v, datetime) and v.date() == target_dt.date():
            return r
    return None

check_dates = [
    datetime(1951,1,4),
    datetime(1951,4,1),
    datetime(1951,4,15),
    datetime(1951,7,12),
    datetime(1951,9,5),
    datetime(1951,10,15),
    datetime(1951,11,3),
    datetime(1951,11,16),
]
for dt in check_dates:
    r = find_row_for_date(dt)
    print(dt.strftime("%Y-%m-%d"), "row", r, "value", None if r is None else wsv.cell(r,2).value)

print("Last 5 Group B rows:")
for r in range(wsv.max_row - 4, wsv.max_row + 1):
    print(r, wsv.cell(r,1).value, wsv.cell(r,2).value)
