from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math, statistics

input_path = input_spreadsheet
print("Instruction:", instruction)
print("Input path exists:", os.path.exists(input_path), input_path)

# Load workbook twice: formulas view and data_only view
wb = load_workbook(input_path)
wb_values = load_workbook(input_path, data_only=True)

original_sheet_names = wb.sheetnames
print("Original sheet names:", original_sheet_names)

def first_nonempty_row(ws, max_check_rows=10):
    for r in range(1, min(ws.max_row, max_check_rows) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            return r, vals
    return None, []

for sname in wb.sheetnames:
    ws = wb[sname]
    wsv = wb_values[sname]
    print(f"\n--- Sheet: {sname} ---")
    print("Dimensions:", ws.max_row, "rows x", ws.max_column, "cols")
    header_row_idx, header_vals = first_nonempty_row(ws, max_check_rows=10)
    print("First non-empty row index:", header_row_idx)
    if header_row_idx:
        headers = [ws.cell(header_row_idx, c).value for c in range(1, ws.max_column + 1)]
        print("Column headers/first non-empty row values:", headers)
    # Print first 10 and last 5 rows
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_print = []
    seen = set()
    for r in first_rows + last_rows:
        if r not in seen:
            rows_to_print.append(r)
            seen.add(r)
    for r in rows_to_print:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    # Specific target cell
    print(f"{sname}!B7 formula-view:", ws["B7"].value)
    print(f"{sname}!B7 data-only:", wsv["B7"].value)
