for r in range(1, 6):
    row_vals = [ws_values.cell(r, c).value for c in range(1, 3)]
    print(f"Row {r}: {row_vals}")
for r in target_rows:
    verified[f"B{r}"] = ws_values[f'B{r}'].value

print("\nTarget cell verification:")
