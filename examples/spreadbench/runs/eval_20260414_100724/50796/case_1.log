from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os
from copy import copy

# Load workbook
input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

print("Original sheet names:", original_sheetnames)
print("Target output range before writing:")
for r in range(1, 6):
    print(f"Row {r}:", [ws.cell(r, c).value for c in range(1, 3)])

# Verify target cells and current contents
target_rows = range(2, 6)
for r in target_rows:
    print(f"Before: A{r}={ws[f'A{r}'].value!r}, B{r}={ws[f'B{r}'].value!r}")

# Write SUMIF formulas into B2:B5
# Sum preorder quantities in C12:C22 where item name in B12:B22 matches A-row item
for r in target_rows:
    formula = f'=SUMIF($B$12:$B$22,A{r},$C$12:$C$22)'
    ws[f'B{r}'] = formula
    print(f"Wrote B{r} -> {formula}")

# Save output
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names still match original
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)
if wb_check.sheetnames != original_sheetnames:
    # rename back by position
    for i, original_name in enumerate(original_sheetnames):
        wb_check.worksheets[i].title = original_name
    wb_check.save(output_path)
    print("Renamed sheets back to original names:", original_sheetnames)

# Verify formulas in normal mode
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheetnames[0]]
print("\nFormulas in target cells:")
for r in target_rows:
    print(f"B{r} formula:", ws_formula[f'B{r}'].value)

# Verify evaluated results in data_only mode
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheetnames[0]]
print("\nVerified output values:")
