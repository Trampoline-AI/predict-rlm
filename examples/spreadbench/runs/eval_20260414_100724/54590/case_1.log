from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string, get_column_letter

path = input_spreadsheet

# Load both formula view and cached-value view
wb_formula = load_workbook(path)
wb_data = load_workbook(path, data_only=True)

wsf = wb_formula[wb_formula.sheetnames[0]]
wsd = wb_data[wb_data.sheetnames[0]]

# Helper to print selected columns for a row range
cols = ["A","B","C","GK","GL","GM","GN","GO","GP","GQ","GR","GS","GT"]
def show_rows(ws, start, end, title):
    print(f"\n{title}")
    print(" | ".join(cols))
    for r in range(start, end + 1):
        vals = []
        for col in cols:
            vals.append(repr(ws[f"{col}{r}"].value))
        print(f"r{r}: " + " | ".join(vals))

show_rows(wsf, 24, 37, "FORMULA VIEW rows 24:37")
show_rows(wsd, 3, 21, "DATA_ONLY rows 3:21")
show_rows(wsd, 24, 37, "DATA_ONLY rows 24:37")

# Print exact current formulas/values in key cells
for cell in ["GK29", "GO29", "GR29", "GK28", "GK30", "GR8", "GR13", "GR18", "GR21"]:
    print(cell, "formula_view=", wsf[cell].value, "data_only=", wsd[cell].value)

# Find any formulas in row 29 across a wider area to infer summary pattern
print("\nNon-empty cells in row 29 from GI:GT (formula view):")
for c in range(column_index_from_string("GI"), column_index_from_string("GT") + 1):
    cell = wsf.cell(29, c)
    if cell.value is not None:
        print(f"{get_column_letter(c)}29 = {cell.value}")

# Compute the intended sum from cached values as a sanity check:
# sum GK where GO == "Yes" plus sum GR where GO == "Yes"
