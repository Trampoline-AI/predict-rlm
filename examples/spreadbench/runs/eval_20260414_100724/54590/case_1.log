    return x if isinstance(x, (int, float)) else 0

matching_rows = []
sum_gk = 0
sum_gr = 0
for r in range(3, 22):
    go = wsd[f"GO{r}"].value
    gk = wsd[f"GK{r}"].value
    gr = wsd[f"GR{r}"].value
    if isinstance(go, str) and go.strip().lower() == "yes":
        matching_rows.append((r, go, gk, gr))
        sum_gk += as_num(gk)
        sum_gr += as_num(gr)

print("\nRows with GO='Yes' from data_only:", matching_rows)
print("Sanity sums -> GK:", sum_gk, "GR:", sum_gr, "Total:", sum_gk + sum_gr)
