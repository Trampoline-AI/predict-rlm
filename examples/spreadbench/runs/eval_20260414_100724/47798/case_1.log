import os, json, re, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("Instruction:", instruction)

input_path = input_spreadsheet
filename = os.path.basename(input_path)

wb = load_workbook(input_path)
print("Workbook sheets:", wb.sheetnames)

def row_values(ws, r, max_cols=None):
    max_cols = max_cols or ws.max_column
    vals = []
    for c in range(1, max_cols + 1):
        vals.append(ws.cell(r, c).value)
    return vals

workbook_summary = {}

for ws in wb.worksheets:
    # find effective last row/col with any non-empty values
    eff_last_row = 0
    eff_last_col = 0
    for r in range(1, ws.max_row + 1):
        row_has = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v not in (None, ""):
                row_has = True
                eff_last_col = max(eff_last_col, c)
        if row_has:
            eff_last_row = r
    
    headers_r1 = row_values(ws, 1, eff_last_col or ws.max_column)
    headers_r2 = row_values(ws, 2, eff_last_col or ws.max_column) if eff_last_row >= 2 else []
    sample_first_rows = {}
    for r in range(1, min(eff_last_row, 10) + 1):
        sample_first_rows[r] = row_values(ws, r, eff_last_col or ws.max_column)
    sample_last_rows = {}
    start_last = max(1, eff_last_row - 4)
    for r in range(start_last, eff_last_row + 1):
        sample_last_rows[r] = row_values(ws, r, eff_last_col or ws.max_column)
    
    workbook_summary[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "effective_last_row": eff_last_row,
        "effective_last_col": eff_last_col,
        "headers_row1": headers_r1,
        "headers_row2": headers_r2,
        "first_rows": sample_first_rows,
        "last_rows": sample_last_rows,
    }

# Print compactly
for sheet_name, info in workbook_summary.items():
    print("\n--- SHEET:", sheet_name, "---")
    print("max_row/max_col:", info["max_row"], info["max_column"])
    print("effective_last_row/effective_last_col:", info["effective_last_row"], info["effective_last_col"])
    print("Row1:", info["headers_row1"])
    if any(v not in (None, "") for v in info["headers_row2"]):
        print("Row2:", info["headers_row2"])
    print("First rows:")
    for r, vals in info["first_rows"].items():
        print(r, vals)
    print("Last rows:")
    for r, vals in info["last_rows"].items():
        print(r, vals)

# Search the workbook for cells containing "Collection-" and for existing formulas mentioning it
matches = []
formula_matches = []
for ws in wb.worksheets:
    for row in ws.iter_rows():
        for cell in row:
            v = cell.value
            if isinstance(v, str):
                if "Collection-" in v:
                    matches.append((ws.title, cell.coordinate, v))
                if v.startswith("=") and "Collection-" in v:
                    formula_matches.append((ws.title, cell.coordinate, v))

print("\nCells containing 'Collection-':", len(matches))
for item in matches[:20]:
    print(item)

print("\nFormula cells mentioning 'Collection-':", len(formula_matches))
for item in formula_matches[:20]:
    print(item)

# Also inspect blank / candidate output columns by checking headers and first data rows
for ws in wb.worksheets:
    print(f"\nColumn map for sheet {ws.title}:")
    for c in range(1, (workbook_summary[ws.title]['effective_last_col'] or ws.max_column) + 1):
        print(c, get_column_letter(c), ws.cell(1, c).value, "| row2:", ws.cell(2, c).value, "| row3:", ws.cell(3, c).value)
