Code:
```repl
import os, re, shutil
from openpyxl import load_workbook

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, filename)
os.makedirs(output_dir, exist_ok=True)

# Re-open fresh workbook for modification
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

print("Verifying target area before writing:")
for r in range(1, ws.max_row + 1):
    print(r, {"A": ws[f"A{r}"].value, "B": ws[f"B{r}"].value})

# Validate that existing example answers follow the expected extraction rule
def extract_collection_py(text):
    if not isinstance(text, str):
        return None
    m = re.search(r"Collection-(.*?)(?:,|$)", text)
    return m.group(1).strip() if m else None

print("\nChecking existing example answers:")
for r in range(2, ws.max_row + 1):
    src = ws[f"A{r}"].value
    existing = ws[f"B{r}"].value
    inferred = extract_collection_py(src)
    print(f"Row {r}: inferred={inferred!r}, existing={existing!r}")

# Fill only blank target cells in column B, preserving existing correct values
filled_rows = []
for r in range(2, ws.max_row + 1):
    src = ws.cell(r, 1).value  # column A / Tags
    tgt = ws.cell(r, 2)        # column B / Collection
    if src not in (None, "") and tgt.value in (None, ""):
        # Extract text after "Collection-" until first comma, or end of string if no comma
        tgt.value = (
            f'=IFERROR(TRIM(MID(A{r},SEARCH("Collection-",A{r})+11,'
            f'IFERROR(FIND(",",A{r},SEARCH("Collection-",A{r}))-SEARCH("Collection-",A{r})-11,'
            f'LEN(A{r})-SEARCH("Collection-",A{r})-10))),"")'
        )
        filled_rows.append(r)

print("\nRows filled with formula:", filled_rows)
for r in filled_rows:
    print(f"B{r} formula:", ws[f"B{r}"].value)

# Save output
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    print("Restoring original sheet names...")
    for i, desired in enumerate(original_sheetnames):
        wb_after.worksheets[i].title = desired
    wb_after.save(output_path)
    print("Restored sheet names:", wb_after.sheetnames)

# Verify formulas and evaluated values
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula["Sheet1"]

wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values["Sheet1"]

print("\nFinal verification of target cells B2:B7:")
for r in range(2, ws_values.max_row + 1):
    print(
        f"Row {r}:",
        {
            "A": ws_values[f"A{r}"].value,
            "B_value": ws_values[f"B{r}"].value,
            "B_formula": ws_formula[f"B{r}"].value,
        }
    )

# Extra sanity check: compare evaluated values with Python extraction
mismatches = []
for r in range(2, ws_values.max_row + 1):
    py_val = extract_collection_py(ws_values[f"A{r}"].value)
    xl_val = ws_values[f"B{r}"].value
    if (py_val or "") != (xl_val or ""):
        mismatches.append((r, py_val, xl_val))

print("\nMismatch check:", mismatches if mismatches else "No mismatches")
print("Output file ready:", output_path)
```
