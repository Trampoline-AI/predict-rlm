from openpyxl import load_workbook
import os, shutil, json

src = input_spreadsheet
base = os.path.basename(src)
test_dir = "/sandbox/output/output_spreadsheet"

candidates = {
    "sumif_literal": {
        "D3": '=SUMIF($F$2:$U$2,"REVENUE",$F3:$U3)',
        "E3": '=SUMIF($F$2:$U$2,"GP",$F3:$U3)',
    },
    "sumif_header_ref": {
        "D3": '=SUMIF($F$2:$U$2,D$2,$F3:$U3)',
        "E3": '=SUMIF($F$2:$U$2,E$2,$F3:$U3)',
    },
    "sumproduct_literal": {
        "D3": '=SUMPRODUCT(($F$2:$U$2="REVENUE")*($F3:$U3))',
        "E3": '=SUMPRODUCT(($F$2:$U$2="GP")*($F3:$U3))',
    },
    "dynamic_sumif_index": {
        "D3": '=SUMIF($F$2:INDEX($2:$2,COUNTA($2:$2)+1),D$2,$F3:INDEX($3:$3,COUNTA($2:$2)+1))',
        "E3": '=SUMIF($F$2:INDEX($2:$2,COUNTA($2:$2)+1),E$2,$F3:INDEX($3:$3,COUNTA($2:$2)+1))',
    },
}

results = {}

for name, formulas in candidates.items():
    test_path = os.path.join(test_dir, f"test_{name}_{base}")
    wb = load_workbook(src)
    ws = wb["Sheet1"]
    ws["D3"] = formulas["D3"]
    ws["E3"] = formulas["E3"]
    wb.save(test_path)
    recalc_result = await recalculate(test_path)
    
    wb_formula = load_workbook(test_path, data_only=False)
    wb_data = load_workbook(test_path, data_only=True)
    wf = wb_formula["Sheet1"]
    wd = wb_data["Sheet1"]
    results[name] = {
        "recalc": recalc_result,
        "formula_D3": wf["D3"].value,
        "formula_E3": wf["E3"].value,
        "value_D3": wd["D3"].value,
        "value_E3": wd["E3"].value,
    }

print(json.dumps(results, default=str, indent=2))

# Also print the expected totals again from current sheet values for reference
wb_in = load_workbook(src, data_only=True)
ws_in = wb_in["Sheet1"]
rev = gp = 0
for c in range(6, ws_in.max_column + 1):
    hdr = ws_in.cell(2, c).value
    val = ws_in.cell(3, c).value
    if isinstance(val, (int, float)):
        if hdr == "REVENUE":
            rev += val
        elif hdr == "GP":
            gp += val
print("Expected revenue:", rev)
print("Expected GP:", gp)
