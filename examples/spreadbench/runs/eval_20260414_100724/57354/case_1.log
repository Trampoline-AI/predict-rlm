```repl
from openpyxl import load_workbook
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Load original workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Reconfirm target cells and nearby labels before writing
print("Sheet names:", wb.sheetnames)
print("D2:", ws["D2"].value, "E2:", ws["E2"].value)
print("Before -> D3:", ws["D3"].value, "E3:", ws["E3"].value)

# Dynamic formulas: sum all row-3 values whose row-2 header matches D2/E2,
# expanding automatically as new columns are added to the right.
# Start at F to exclude the TOTAL block in B:E and avoid circular references.
rev_formula = '=SUMIF($F$2:INDEX($F$2:$XFD$2,1,COUNTA($F$2:$XFD$2)),D$2,$F3:INDEX($F3:$XFD3,1,COUNTA($F$2:$XFD$2)))'
gp_formula  = '=SUMIF($F$2:INDEX($F$2:$XFD$2,1,COUNTA($F$2:$XFD$2)),E$2,$F3:INDEX($F3:$XFD3,1,COUNTA($F$2:$XFD$2)))'

ws["D3"] = rev_formula
ws["E3"] = gp_formula

print("Written formulas:")
print("D3:", ws["D3"].value)
print("E3:", ws["E3"].value)

# Save
wb.save(outfile)
print("Saved:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculate changed them
wb_post = load_workbook(outfile)
if wb_post.sheetnames != original_sheetnames:
    print("Sheet names changed:", wb_post.sheetnames, "-> restoring to", original_sheetnames)
    if len(wb_post.sheetnames) == len(original_sheetnames):
        for current, desired in zip(wb_post.sheetnames, original_sheetnames):
            wb_post[current].title = desired
        wb_post.save(outfile)

# Verify formulas and cached values
wb_formula = load_workbook(outfile, data_only=False)
wb_values = load_workbook(outfile, data_only=True)

wsf = wb_formula["Sheet1"]
wsv = wb_values["Sheet1"]

print("After recalc/formula view:")
print("D3 formula:", wsf["D3"].value)
print("E3 formula:", wsf["E3"].value)

print("After recalc/value view:")
print("D3 value:", wsv["D3"].value)
print("E3 value:", wsv["E3"].value)

# Print the exact relevant range for final verification
for r in range(2, 4):
    vals_formula = [wsf.cell(r, c).value for c in range(2, 22)]
    vals_value = [wsv.cell(r, c).value for c in range(2, 22)]
    print(f"Formula workbook row {r} B:U ->", vals_formula)
    print(f"Value workbook   row {r} B:U ->", vals_value)

output_spreadsheet = outfile
```
