from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outfile = os.path.join("/sandbox/output/output_spreadsheet", filename)

# Inspect current target area carefully
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

print("Original sheetnames:", orig_sheetnames)
print("Target area B1:U3 before change:")
for r in range(1, 4):
    vals = [ws.cell(r, c).value for c in range(2, 22)]
    print(f"Row {r}:", vals)

print("Current target cells:")
for coord in ["D2", "E2", "D3", "E3", "I3", "M3", "Q3", "U3"]:
    print(coord, "=", ws[coord].value)

# Compute expected totals from existing data for sanity-checking
# Use a data_only workbook so GP formula cells contribute actual numeric values if cached.
wb_data_in = load_workbook(infile, data_only=True)
ws_data_in = wb_data_in[orig_sheetnames[0]]

header_to_sum = {"REVENUE": 0, "GP": 0}
for c in range(6, ws.max_column + 1):  # start at F to exclude total block B:E
    hdr = ws.cell(2, c).value
    val = ws_data_in.cell(3, c).value
    if hdr in header_to_sum and isinstance(val, (int, float)):
        header_to_sum[hdr] += val
print("Expected totals from current data_only values:", header_to_sum)

# Write dynamic formulas into the exact target cells
# Start from F to avoid circular references in the B:E total block.
ws["D3"] = '=SUMIF($F$2:$XFD$2,D$2,$F3:$XFD3)'
ws["E3"] = '=SUMIF($F$2:$XFD$2,E$2,$F3:$XFD3)'

print("Written formulas:")
print("D3 =", ws["D3"].value)
print("E3 =", ws["E3"].value)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc; if sheet names changed, restore originals
wb_post = load_workbook(outfile)
if wb_post.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_post.sheetnames)
    if len(wb_post.sheetnames) == len(orig_sheetnames):
        for old_name, desired_name in zip(wb_post.sheetnames, orig_sheetnames):
            wb_post[old_name].title = desired_name
        wb_post.save(outfile)
        print("Restored sheet names to:", orig_sheetnames)
    else:
        print("Unexpected sheet-name mismatch; leaving as-is.")

# Verify formulas and cached values
wb_verify_formula = load_workbook(outfile, data_only=False)
wb_verify_data = load_workbook(outfile, data_only=True)
wsf = wb_verify_formula[orig_sheetnames[0]]
wsd = wb_verify_data[orig_sheetnames[0]]

print("Verification - formulas:")
print("D3 formula:", wsf["D3"].value)
print("E3 formula:", wsf["E3"].value)

print("Verification - cached values:")
print("D3 value:", wsd["D3"].value)
print("E3 value:", wsd["E3"].value)

# Print the relevant range after change
print("Relevant range B2:U3 after change (formula workbook):")
for r in range(2, 4):
    vals = [wsf.cell(r, c).value for c in range(2, 22)]
    print(f"Row {r}:", vals)

output_spreadsheet = outfile
