from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook:", path)
print("Sheet names:", wb.sheetnames)

def display(v):
    if v is None:
        return None
    return str(v)

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    
    # Determine used rows more realistically
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in row_vals):
            nonempty_rows.append(r)
    print("Non-empty row count:", len(nonempty_rows), "first:", nonempty_rows[:10], "last:", nonempty_rows[-10:] if nonempty_rows else [])
    
    # Print first 10 rows
    first_rows = list(range(1, min(ws.max_row, 10) + 1))
    last_rows = list(range(max(1, ws.max_row - 4), ws.max_row + 1))
    rows_to_show = []
    seen = set()
    for r in first_rows + last_rows:
        if r not in seen:
            rows_to_show.append(r)
            seen.add(r)
    
    for r in rows_to_show:
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        trimmed = vals[:min(len(vals), 20)]
        print(f"Row {r}: {trimmed}")
    
    # print row 1-5 with column letters
    print("\nColumn letters and first 5 row values:")
    for c in range(1, ws.max_column + 1):
        col_letter = get_column_letter(c)
        sample = [ws.cell(r, c).value for r in range(1, min(ws.max_row, 5) + 1)]
        print(f"{col_letter} ({c}): {sample}")
        if c >= 30:
            print("... stopping detailed column preview at 30 columns")
            break
    
    # Explicit row 3 inspection across all columns
    print("\nDetailed row 3:")
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(3, c)
        print(f"{get_column_letter(c)}3 = {cell.value!r}")
