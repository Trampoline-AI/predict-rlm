import os
from openpyxl import load_workbook

# Reload source workbook fresh
src_path = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src_path))

wb = load_workbook(src_path)
orig_sheet_names = wb.sheetnames[:]
ws = wb[orig_sheet_names[0]]

print("Original sheet names:", orig_sheet_names)
print("Target column header G1:", ws["G1"].value)
print("Current G2:G23 before writing:", [ws[f"G{r}"].value for r in range(2, 24)])

# Inspect number formats near target / helper cells to mimic style
print("Number formats sample:",
      {"G2": ws["G2"].number_format, "P3": ws["P3"].number_format, "J3": ws["J3"].number_format})

# Python mirror of intended logic for verification
goal_headers = [ws.cell(2, c).value for c in range(10, 14)]   # J:M
var_table = [[ws.cell(r, c).value for c in range(10, 14)] for r in range(3, 7)]  # rows 3:6, cols J:M
metric_headers = [ws.cell(2, c).value for c in range(16, 21)]  # P:T
payout_grid = [[ws.cell(r, c).value for c in range(16, 21)] for r in range(3, 7)]  # P3:T6

print("Goal headers:", goal_headers)
print("Variance threshold table:", var_table)
print("Metric headers:", metric_headers)
print("Payout grid:", payout_grid)

def approx_match(value, thresholds):
    """Largest index i such that thresholds[i] <= value, clamped to first/last."""
    if value is None:
        return None
    idx = 0
    for i, t in enumerate(thresholds):
        if t is None:
            continue
        if value >= t:
            idx = i
    return idx

def expected_incentive(goal, variance, metric2):
    if variance is None or variance < 0:
        return 0
    goal_idx = approx_match(goal, goal_headers)
    var_thresholds = [row[goal_idx] for row in var_table]
    var_idx = approx_match(variance, var_thresholds)
    metric_idx = approx_match(metric2, metric_headers)
    return payout_grid[var_idx][metric_idx]

# Preview expected outputs in Python before writing formulas
preview = []
for r in range(2, ws.max_row + 1):
    a = ws[f"A{r}"].value
    if a in (None, ""):
        continue
    goal = ws[f"D{r}"].value
    variance = ws[f"E{r}"].value
    metric2 = ws[f"F{r}"].value
    exp = expected_incentive(goal, variance, metric2)
    preview.append((r, a, goal, variance, metric2, exp))
print("Preview expected incentive rows:")
for row in preview:
    print(row)

# Write Excel formulas into the exact target cells G2:G(last employee row)
# Logic:
# - if variance < 0 => 0
# - goal bucket index = MATCH(Dx,$J$2:$M$2,1)
# - variance row = MATCH(Ex, OFFSET($J$3,0,goal_idx-1,4,1),1)
# - metric bucket index = IF(Fx<$P$2,1,MATCH(Fx,$P$2:$T$2,1))
# - incentive = INDEX($P$3:$T$6, variance_row, metric_bucket_index)
written = []
for r in range(2, ws.max_row + 1):
    if ws[f"A{r}"].value in (None, ""):
        continue
    formula = (
        f'=IF(E{r}<0,0,'
        f'INDEX($P$3:$T$6,'
        f'MATCH(E{r},OFFSET($J$3,0,MATCH(D{r},$J$2:$M$2,1)-1,4,1),1),'
        f'IF(F{r}<$P$2,1,MATCH(F{r},$P$2:$T$2,1))'
        f'))'
    )
    ws[f"G{r}"] = formula
    ws[f"G{r}"].number_format = ws["P3"].number_format or "0%"
    written.append((f"G{r}", formula))

print("Written formulas:")
for item in written[:10]:
    print(item)
print("... total written:", len(written))

# Save initial output
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# After recalc, restore original sheet names if changed
wb_post = load_workbook(out_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)
if post_names != orig_sheet_names and len(post_names) == len(orig_sheet_names):
    for old, new in zip(post_names, orig_sheet_names):
        wb_post[old].title = new
    wb_post.save(out_path)
    print("Restored sheet names to:", orig_sheet_names)
else:
    print("No sheet rename fix needed.")

# Verify formulas and cached values
wb_formula = load_workbook(out_path, data_only=False)
ws_formula = wb_formula[orig_sheet_names[0]]
wb_values = load_workbook(out_path, data_only=True)
ws_values = wb_values[orig_sheet_names[0]]

print("\nVerification of target cells G2:G23:")
verification_rows = []
for r in range(2, 24):
    if ws_values[f"A{r}"].value in (None, ""):
        continue
    formula = ws_formula[f"G{r}"].value
    value = ws_values[f"G{r}"].value
    trimmed_ok = (not isinstance(value, str)) or (value == value.strip())
    verification_rows.append((r, ws_values[f"A{r}"].value, formula, value, trimmed_ok))
    print((r, ws_values[f"A{r}"].value, value, formula))

# Sanity-check against Python expected values
mismatches = []
for r, emp, formula, cached, trimmed_ok in verification_rows:
    exp = expected_incentive(ws_values[f"D{r}"].value, ws_values[f"E{r}"].value, ws_values[f"F{r}"].value)
    if cached != exp:
        mismatches.append((r, emp, cached, exp, formula))
print("\nMismatch count vs Python logic:", len(mismatches))
if mismatches:
    for mm in mismatches[:10]:
        print("MISMATCH:", mm)

# Additional checks required by task
none_targets = [r for r, emp, formula, cached, trimmed_ok in verification_rows if cached in (None, "")]
print("Blank/None target rows:", none_targets)
print("All expected sheets present:", load_workbook(out_path).sheetnames)

# Keep final path ready for SUBMIT if verification looks good
