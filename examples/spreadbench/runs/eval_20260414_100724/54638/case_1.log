import os
from copy import copy
from openpyxl import load_workbook
from openpyxl.styles import PatternFill, Border, Side

src = input_spreadsheet
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(src))

# Load source workbook
wb = load_workbook(src)
original_sheetnames = wb.sheetnames[:]
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Styles
thin = Side(style="thin", color="000000")
thin_border = Border(left=thin, right=thin, top=thin, bottom=thin)
no_border = Border()
yellow_fill = PatternFill(fill_type="solid", start_color="FFFFFF00", end_color="FFFFFF00")

# Remove visible worksheet gridlines where appropriate
ws1.sheet_view.showGridLines = False
ws2.sheet_view.showGridLines = False

# Ensure Sheet2 hidden
ws2.sheet_state = "hidden"

# Convert Sheet1 used cells to Calibri while preserving size/bold/etc.
for row in ws1.iter_rows(min_row=1, max_row=ws1.max_row, min_col=1, max_col=ws1.max_column):
    for cell in row:
        f = copy(cell.font)
        f.name = "Calibri"
        cell.font = f

# Recreate formulas in column A exactly through A150
for r in range(2, 151):
    ws1[f"A{r}"] = f'=IF(Sheet2!A{r}="","",Sheet2!A{r})'

# Column A borders only through row 13
for r in range(1, 14):
    ws1[f"A{r}"].border = thin_border
for r in range(14, ws1.max_row + 1):
    ws1[f"A{r}"].border = no_border

# Preserve B1 content/font but do not alter its fill beyond existing content
# Insert non-dynamic array-style unique-list formula into B2:B150
for r in range(2, 151):
    prev_row = r - 1
    formula = (
        '=IFERROR('
        'INDEX($A$2:$A$150,'
        '_xlfn.AGGREGATE(15,6,'
        '(ROW($A$2:$A$150)-ROW($A$2)+1)/'
        f'(COUNTIF($B$1:B{prev_row},$A$2:$A$150)=0)/'
        '($A$2:$A$150<>""),1)'
        '),'
        '""'
        ')'
    )
    ws1[f"B{r}"] = formula
    ws1[f"B{r}"].fill = yellow_fill
    ws1[f"B{r}"].border = thin_border
    # make sure font is Calibri
    f = copy(ws1[f"B{r}"].font)
    f.name = "Calibri"
    ws1[f"B{r}"].font = f

# Also ensure header fonts in A1:B1 are Calibri
for coord in ["A1", "B1"]:
    f = copy(ws1[coord].font)
    f.name = "Calibri"
    ws1[coord].font = f

# Save
wb.save(out_path)
print("Saved initial output to:", out_path)

# Recalculate formulas
recalc_result = await recalculate(out_path)
print("Recalculate:", recalc_result)

# Restore sheet names if recalculation changed them
wb_post = load_workbook(out_path)
post_names = wb_post.sheetnames[:]
print("Sheet names after recalc:", post_names)

if post_names != original_sheetnames and len(post_names) == len(original_sheetnames):
    for i, expected in enumerate(original_sheetnames):
        wb_post.worksheets[i].title = expected
    wb_post.save(out_path)
    print("Restored original sheet names:", original_sheetnames)

# Verification
wb_formula = load_workbook(out_path)
wb_values = load_workbook(out_path, data_only=True)
vf1 = wb_formula["Sheet1"]
vd1 = wb_values["Sheet1"]
vf2 = wb_formula["Sheet2"]

print("\nVERIFICATION")
print("Final sheet names:", wb_formula.sheetnames)
print("Sheet1 gridlines visible?:", vf1.sheet_view.showGridLines)
print("Sheet2 state:", vf2.sheet_state)

print("\nA2:A6 formulas:")
for r in range(2, 7):
    print(r, vf1[f"A{r}"].value)

print("\nB2:B12 formulas and recalculated values:")
for r in range(2, 13):
    print(r, {
        "formula": vf1[f"B{r}"].value,
        "value": vd1[f"B{r}"].value
    })

print("\nExpected unique outputs B2:B9:")
for r in range(2, 10):
    print(r, vd1[f"B{r}"].value)

print("\nTail check B146:B150 values:")
for r in range(146, 151):
    print(r, vd1[f"B{r}"].value)

print("\nStyle checks:")
for coord in ["A1", "A13", "A14", "B2", "B10", "B150"]:
    c = vf1[coord]
    print(coord, {
        "font": c.font.name,
        "fill": c.fill.fill_type,
        "fg": c.fill.fgColor.rgb,
        "border": (c.border.left.style, c.border.right.style, c.border.top.style, c.border.bottom.style),
    })

output_spreadsheet = out_path
print("\nPrepared output_spreadsheet:", output_spreadsheet)
