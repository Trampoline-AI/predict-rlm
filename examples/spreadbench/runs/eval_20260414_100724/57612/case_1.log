Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

# Reload fresh workbook
wb = load_workbook(input_spreadsheet)
original_sheet_names = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine target rows based on actual used data in column C/D starting from row 4
target_rows = []
for r in range(4, ws.max_row + 1):
    c_val = ws.cell(r, 3).value
    d_val = ws.cell(r, 4).value
    if c_val is not None or d_val is not None:
        target_rows.append(r)

print("Target rows:", target_rows)
print("Before update:")
for r in target_rows:
    print(f"Row {r}: C{r}={ws.cell(r,3).value!r}, D{r}={ws.cell(r,4).value!r}")

# Update formulas in column D for all relevant rows
for r in target_rows:
    # Only write for rows with a numeric/input value in C
    if ws.cell(r, 3).value is not None:
        formula = (
            f'=IF(AND(C{r}>=5,C{r}<=6),5,'
            f'IF(AND(C{r}>=3,C{r}<=4),3.75,'
            f'IF(AND(C{r}>=1,C{r}<=2),1,0)))'
        )
        ws.cell(r, 4).value = formula

print("\nAfter formula update:")
for r in target_rows:
    print(f"D{r} formula -> {ws.cell(r,4).value}")

# Save to output with same filename
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_spreadsheet))
wb.save(output_path)
print("\nSaved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if LibreOffice changed them
wb_check = load_workbook(output_path)
print("Sheet names after recalc:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheet_names:
    # rename by position to original names
    for i, name in enumerate(original_sheet_names):
        if i < len(wb_check.worksheets):
            wb_check.worksheets[i].title = name
    wb_check.save(output_path)
    print("Renamed sheets back to:", original_sheet_names)

# Verify formulas
wb_formula = load_workbook(output_path, data_only=False)
ws_formula = wb_formula[original_sheet_names[0]]

print("\nVerified formulas in target cells:")
for r in target_rows:
    print(f"D{r}: {ws_formula.cell(r,4).value}")

# Verify computed values
wb_values = load_workbook(output_path, data_only=True)
ws_values = wb_values[original_sheet_names[0]]

print("\nVerified computed values in target cells:")
verification = []
for r in target_rows:
    c_val = ws_values.cell(r, 3).value
    d_val = ws_values.cell(r, 4).value
    verification.append((r, c_val, d_val))
    print(f"Row {r}: C={c_val!r}, D={d_val!r}")

# Basic sanity check for expected outputs
def expected_from_c(v):
    if v is None:
        return None
    if 5 <= v <= 6:
        return 5
    if 3 <= v <= 4:
        return 3.75
    if 1 <= v <= 2:
        return 1
    return 0

mismatches = []
for r, c_val, d_val in verification:
    exp = expected_from_c(c_val)
    if d_val != exp:
        mismatches.append((r, c_val, d_val, exp))

print("\nMismatches:", mismatches)

# Keep path for submit
final_output_spreadsheet = output_path
print("final_output_spreadsheet:", final_output_spreadsheet)
```
