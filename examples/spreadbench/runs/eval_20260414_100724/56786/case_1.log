import os, shutil, math
from pathlib import Path
from openpyxl import load_workbook

infile = Path(input_spreadsheet)
outdir = Path("/sandbox/output/output_spreadsheet")
outdir.mkdir(parents=True, exist_ok=True)
outfile = outdir / infile.name

# Load workbook normally
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Determine actual data rows (only rows with data in A or B or C)
data_rows = [r for r in range(4, ws.max_row + 1) if any(ws.cell(r, c).value not in (None, "") for c in (1,2,3))]
first_data_row = min(data_rows)
last_data_row = max(data_rows)

print("Original sheetnames:", original_sheetnames)
print("Target sheet:", ws.title)
print("Target header row 3:", [ws.cell(3,c).value for c in range(1,4)])
print("Data rows:", first_data_row, "to", last_data_row, "count:", len(data_rows))
print("Current sample target cells before write:")
for r in [4,5,69,70,71,72,80,99,196,200]:
    print(r, ws[f"A{r}"].value, ws[f"B{r}"].value, ws[f"C{r}"].value)

# Write formulas into existing column C only for real data rows
# Logic:
# - blank for first row (no previous rows)
# - blank until at least 365 days from first date
# - average values in prior rows whose date >= current date - 365
# - exclude current row by stopping ranges at row-1
ws["C4"] = ""

for r in range(first_data_row + 1, last_data_row + 1):
    # only write if row has actual source data
    if ws[f"A{r}"].value in (None, "") and ws[f"B{r}"].value in (None, ""):
        continue
    prev_r = r - 1
    formula = (
        f'=IF(OR(A{r}="",$A$4="",A{r}-$A$4<365),"",'
        f'IFERROR('
        f'SUMPRODUCT(($A$4:A{prev_r}>=A{r}-365)*($B$4:B{prev_r}))'
        f'/SUMPRODUCT(--($A$4:A{prev_r}>=A{r}-365))'
        f',""))'
    )
    ws[f"C{r}"] = formula

# Keep formatting consistent by copying number format from column B
for r in range(first_data_row, last_data_row + 1):
    ws[f"C{r}"].number_format = ws[f"B{r}"].number_format

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(str(outfile))
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculate changed them
wb_after = load_workbook(outfile)
print("Sheetnames after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # restore by position
    for i, old_name in enumerate(original_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = old_name
    wb_after.save(outfile)
    print("Restored sheetnames to:", original_sheetnames)

# Verify formulas are present in target cells
wb_formula = load_workbook(outfile, data_only=False)
wsf = wb_formula["Sheet1"]
print("\nWritten formulas in sample target cells:")
for r in [5,70,71,72,80,99,196,200]:
    print(f"C{r}:", wsf[f"C{r}"].value)

# Verify recalculated values
wb_values = load_workbook(outfile, data_only=True)
wsv = wb_values["Sheet1"]

print("\nVerified sample recalculated target cells:")
for r in [4,5,69,70,71,72,80,99,196,200]:
    print(
        r,
        "A=", wsv[f"A{r}"].value,
        "B=", wsv[f"B{r}"].value,
        "C=", wsv[f"C{r}"].value,
    )

# Also compute Python checks for example rows to confirm plausibility
from statistics import mean

def py_roll_avg(row):
    cur_date = ws[f"A{row}"].value
    if cur_date is None or ws["A4"].value is None:
        return None
    if (cur_date - ws["A4"].value).days < 365:
        return None
    vals = []
    for rr in range(4, row):
        d = ws[f"A{rr}"].value
        v = ws[f"B{rr}"].value
        if d is not None and v is not None and (cur_date - d).days <= 365:
            vals.append(v)
    return None if not vals else sum(vals) / len(vals)

print("\nPython verification against example rows:")
for r in [70,71,72,80,99]:
    print(
        f"Row {r}",
        "python_avg=", py_roll_avg(r),
        "excel_cached=", wsv[f"C{r}"].value
    )

# Count nonblank outputs in actual data rows
nonblank_c = sum(1 for r in range(first_data_row, last_data_row + 1) if wsv[f"C{r}"].value not in (None, ""))
blank_c = (last_data_row - first_data_row + 1) - nonblank_c
print("\nOutput counts in C4:C%d" % last_data_row, "nonblank:", nonblank_c, "blank:", blank_c)

output_spreadsheet = str(outfile)
print("Prepared output_spreadsheet:", output_spreadsheet)
```
