from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Workbook sheets:", wb.sheetnames)

for ws in wb.worksheets:
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_col:", ws.max_column)
    
    # Find actual non-empty rows and cols for better inspection
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_has_data = False
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if v is not None:
                if isinstance(v, str) and v == "":
                    continue
                row_has_data = True
                nonempty_cols.add(c)
        if row_has_data:
            nonempty_rows.append(r)
    print("nonempty row count:", len(nonempty_rows))
    print("nonempty col count:", len(nonempty_cols), "cols:", [get_column_letter(c) for c in sorted(nonempty_cols)])
    
    # Header candidates: first 3 rows
    for r in range(1, min(4, ws.max_row + 1)):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", vals)
    
    # First 10 non-empty rows
