1. Inspect the current cached values / compute expected weekday numbers and names from column A.
2. Write correct formulas for all populated date rows in B:C.
3. Save to the output folder with the same filename.
4. Recalculate.
5. Reload and verify B2:C16 and sheet names.

To avoid locale-dependent issues with `TEXT(...,"DDDD")` and avoid the broken `WEEKDAY`-on-weekday-number logic, I'll use:
- Column B: `=WEEKDAY(Arow,2)`  (Monday=1 … Sunday=7)
- Column C: `=CHOOSE(WEEKDAY(Arow,2),"Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday")`

This keeps the file dynamic and should work in LibreOffice.
Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from datetime import datetime
import os

infile = input_spreadsheet
orig_wb = load_workbook(infile, data_only=False)
orig_sheetnames = orig_wb.sheetnames[:]
ws = orig_wb["WEEKDAY"]

# Inspect expected outputs from actual dates before modifying
day_names = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
print("Original sheet names:", orig_sheetnames)
print("Target sheet:", ws.title)
print("Target headers:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])
print("Target range to write: B2:C{}".format(ws.max_row))

print("\nCurrent values/formulas in target area before writing:")
for r in range(2, ws.max_row + 1):
    a = ws[f"A{r}"].value
    b = ws[f"B{r}"].value
    c = ws[f"C{r}"].value
    py_day_no = a.weekday() + 1 if isinstance(a, datetime) else None  # Monday=1
    py_day = day_names[py_day_no - 1] if py_day_no else None
    print(f"Row {r}: A={a}, B={b!r}, C={c!r}, expected -> B={py_day_no}, C={py_day}")

# Write formulas for all rows with a date in column A
for r in range(2, ws.max_row + 1):
    a = ws[f"A{r}"].value
    if isinstance(a, datetime):
        ws[f"B{r}"] = f"=WEEKDAY(A{r},2)"
        ws[f"C{r}"] = (
            f'=CHOOSE(WEEKDAY(A{r},2),"Monday","Tuesday","Wednesday",'
            f'"Thursday","Friday","Saturday","Sunday")'
        )

outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))
orig_wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
post_wb = load_workbook(outfile)
print("Sheet names after recalc:", post_wb.sheetnames)
if post_wb.sheetnames != orig_sheetnames:
    for idx, expected in enumerate(orig_sheetnames):
        if idx < len(post_wb.worksheets):
            post_wb.worksheets[idx].title = expected
    post_wb.save(outfile)
    print("Renamed sheets back to:", orig_sheetnames)

# Verification with cached values
verify_wb = load_workbook(outfile, data_only=True)
print("Verified sheet names:", verify_wb.sheetnames)
vws = verify_wb[orig_sheetnames[0]]

print("\nVerified target cells B2:C{} after recalc:".format(vws.max_row))
all_ok = True
for r in range(2, vws.max_row + 1):
    a = vws[f"A{r}"].value
    b = vws[f"B{r}"].value
    c = vws[f"C{r}"].value
    exp_b = a.weekday() + 1 if isinstance(a, datetime) else None
    exp_c = day_names[exp_b - 1] if exp_b else None
    print(f"Row {r}: A={a}, B={b!r}, C={c!r}, expected=({exp_b}, {exp_c})")
    if isinstance(a, datetime):
        if b != exp_b or c != exp_c or c is None or (isinstance(c, str) and c.strip() == ""):
            all_ok = False

print("\nVerification passed:", all_ok)

# Also show stored formulas in output workbook
formula_wb = load_workbook(outfile, data_only=False)
fws = formula_wb[orig_sheetnames[0]]
print("\nStored formulas in first few target rows:")
for r in range(2, min(fws.max_row, 6) + 1):
    print(r, fws[f"B{r}"].value, " | ", fws[f"C{r}"].value)
```
