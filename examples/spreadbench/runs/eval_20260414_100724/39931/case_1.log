output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Confirm target/source regions before writing
print("Original sheet names:", orig_sheetnames)
print("Target region before write:")
for r in range(4, 7):
    print(r, [ws.cell(r, c).value for c in range(2, 7)])

# Fill blank target cells C4:F6 using two-criteria lookup
written = []
for r in range(4, 7):      # rows with x/y/z
    row_key = ws[f"B{r}"].value
    if row_key is None or str(row_key).strip() == "":
        continue
    for c in range(3, 7):  # columns C:F with headers A:D
        col_key = ws.cell(3, c).value
        cell = ws.cell(r, c)
        if cell.value is None or cell.value == "":
            formula = f'=SUMIFS($K$3:$K$22,$I$3:$I$22,$B{r},$J$3:$J$22,{get_column_letter(c)}$3)'
            cell.value = formula
            written.append((cell.coordinate, formula))

print("Written formulas:")
for item in written:
    print(item)

# Save
