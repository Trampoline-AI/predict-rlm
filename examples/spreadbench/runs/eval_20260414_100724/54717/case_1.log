```repl
import os
from openpyxl import load_workbook

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

# Load source workbook
wb = load_workbook(infile)
original_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]

# Identify actual data bounds from inspected layout
# numeric level rows in col A
level_rows = []
for r in range(1, ws.max_row + 1):
    v = ws.cell(r, 1).value
    if isinstance(v, (int, float)):
        level_rows.append(r)

first_level_row = min(level_rows)   # expected 3
last_level_row = max(level_rows)    # expected 82

# owner columns from row 2 in B:P
first_owner_col = 2
last_owner_col = 16

print("Using data bounds:")
print(" first_level_row =", first_level_row, "last_level_row =", last_level_row)
print(" owner header range =", (first_owner_col, last_owner_col))
print("Target/input cells before write:")
for ref in ["S4", "S6", "S8", "S10"]:
    print(ref, "=", ws[ref].value)

# Build dynamic formula for S10
# Sum from selected start row to end row in the selected owner column.
formula = (
    '=IFERROR('
    'SUM('
    f'INDEX($B${first_level_row}:$P${last_level_row},MATCH(MIN($S$6,$S$8),$A${first_level_row}:$A${last_level_row},0),MATCH($S$4,$B$2:$P$2,0))'
    ':'
    f'INDEX($B${first_level_row}:$P${last_level_row},MATCH(MAX($S$6,$S$8),$A${first_level_row}:$A${last_level_row},0),MATCH($S$4,$B$2:$P$2,0))'
    '),'
    '""'
    ')'
)
ws["S10"] = formula

print("Written formula to S10:")
print(ws["S10"].value)

# Save
wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore sheet names if recalculation changed them
wb_post = load_workbook(outfile)
print("Sheet names after recalc:", wb_post.sheetnames)

if wb_post.sheetnames != original_sheetnames:
    # rename back by position
    for i, old_name in enumerate(original_sheetnames):
        if i < len(wb_post.worksheets):
            wb_post.worksheets[i].title = old_name
    wb_post.save(outfile)
    print("Restored sheet names to:", original_sheetnames)

# Verify with formulas visible
wb_verify_formula = load_workbook(outfile, data_only=False)
wsf = wb_verify_formula["Sheet1"]
print("Verified formula in S10:", wsf["S10"].value)

# Verify computed result with data_only after recalc
wb_verify = load_workbook(outfile, data_only=True)
wsv = wb_verify["Sheet1"]

print("Verified target/input cells after recalc:")
for ref in ["S4", "S6", "S8", "S10"]:
    print(ref, "=", wsv[ref].value)

# Additional sanity check in Python against current input values
owner = wsv["S4"].value
start_level = wsv["S6"].value
end_level = wsv["S8"].value

# Need original values workbook (not data_only) for manual cross-check
wb_manual = load_workbook(outfile, data_only=False)
wsm = wb_manual["Sheet1"]

# find owner column
owner_col = None
for c in range(first_owner_col, last_owner_col + 1):
    if wsm.cell(2, c).value == owner:
        owner_col = c
        break

# map level to row
level_to_row = {}
for r in range(first_level_row, last_level_row + 1):
    level_to_row[wsm.cell(r, 1).value] = r

manual_sum = None
if owner_col and start_level in level_to_row and end_level in level_to_row:
    r1 = level_to_row[min(start_level, end_level)]
    r2 = level_to_row[max(start_level, end_level)]
    manual_sum = sum(
        wsm.cell(r, owner_col).value
        for r in range(r1, r2 + 1)
        if isinstance(wsm.cell(r, owner_col).value, (int, float))
    )

print("Manual cross-check:")
print(" owner =", owner, "owner_col =", owner_col)
print(" start_level =", start_level, "end_level =", end_level)
print(" manual_sum =", manual_sum)
print(" recalculated S10 =", wsv["S10"].value)
