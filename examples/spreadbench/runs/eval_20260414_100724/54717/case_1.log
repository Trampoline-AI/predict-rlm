def row_vals(ws, r, max_cols=None):
    mc = max_cols or ws.max_column
    vals = []
    for c in range(1, mc + 1):
        v = ws.cell(r, c).value
        vals.append(v)
    return vals

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"Dimensions: rows={ws.max_row}, cols={ws.max_column}")
    headers = row_vals(ws, 1, ws.max_column)
    print("Row1 values / headers:")
    print(headers)

    # detect actual non-empty rows/cols roughly
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        if any(ws.cell(r, c).value is not None for c in range(1, ws.max_column + 1)):
            nonempty_rows.append(r)
    if nonempty_rows:
        print(f"Non-empty rows span: {min(nonempty_rows)} to {max(nonempty_rows)} (count {len(nonempty_rows)})")
    else:
        print("No non-empty rows")
        continue

    # print first 10 non-empty rows and last 5 non-empty rows
    first_rows = nonempty_rows[:10]
    last_rows = nonempty_rows[-5:]
    printed = set()
    print("\nFirst non-empty rows:")
    for r in first_rows:
        printed.add(r)
        print(f"Row {r}: {row_vals(ws, r, ws.max_column)}")
    print("\nLast non-empty rows:")
    for r in last_rows:
        if r not in printed:
            print(f"Row {r}: {row_vals(ws, r, ws.max_column)}")

    # formulas
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print(f"\nFormula cells found: {len(formulas)}")
    for item in formulas[:30]:
        print("  ", item)
    if len(formulas) > 30:
        print("  ...")

    # bordered cells (used area only)
    bordered = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            cell = ws.cell(r, c)
            b = cell.border
            if any(side.style is not None for side in [b.left, b.right, b.top, b.bottom]):
                bordered.append((f"{get_column_letter(c)}{r}", cell.value,
                                 b.left.style, b.right.style, b.top.style, b.bottom.style))
    print(f"Bordered cells found: {len(bordered)}")
    for item in bordered[:40]:
        print("  ", item)
    if len(bordered) > 40:
        print("  ...")

    # merged ranges
    if ws.merged_cells.ranges:
        print("Merged ranges:", [str(rng) for rng in ws.merged_cells.ranges])
    else:
        print("Merged ranges: none")
