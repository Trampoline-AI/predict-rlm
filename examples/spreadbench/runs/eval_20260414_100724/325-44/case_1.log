from openpyxl import load_workbook
from itertools import product
import re, os, shutil

wb = load_workbook(input_spreadsheet)
ws_in = wb["Input"]
ws_out = wb["Output"]

print("Output sheet currently populated rows:")
for r in range(1, ws_out.max_row + 1):
    vals = [ws_out.cell(r, c).value for c in range(1, ws_out.max_column + 1)]
    if any(v is not None and v != "" for v in vals):
        print(f"Row {r}: {vals}")
        for c in range(1, ws_out.max_column + 1):
            v = ws_out.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                print(f"  formula at {ws_out.cell(r,c).coordinate}: {v}")

# Parse filter expressions
eq_pat = re.compile(r'\("([^"]+)"\s*=\s*"([^"]*)"\)')
list_pat = re.compile(r'\("([^"]+)"\s+IN LIST\s+([^)]+)\)')

def normalize_list_token(token):
    token = str(token).strip()
    if token == "":
        return None
    # omit leading zeros for numeric-like tokens
    if re.fullmatch(r'\d+', token):
        return int(token)
    return token.strip('"')

def parse_filter(filter_text):
    result = {}
    if not filter_text:
        return result
    for key, val in eq_pat.findall(filter_text):
        result[key] = [val]
    for key, vals in list_pat.findall(filter_text):
        parts = [normalize_list_token(x) for x in vals.split(",")]
        parts = [x for x in parts if x is not None]
        result[key] = parts
    return result

# Inspect parsed input rows
parsed_rows = []
for r in range(2, ws_in.max_row + 1):
    row = {
        "wtype_id": ws_in.cell(r, 1).value,
        "name": ws_in.cell(r, 2).value,
        "status": ws_in.cell(r, 3).value,
        "filter": ws_in.cell(r, 4).value,
    }
    parsed = parse_filter(row["filter"])
    parsed_rows.append((r, row, parsed))
    print(f"Input row {r} parsed -> {parsed}")

# Build expanded output rows only for columns present in Output
target_headers = [ws_out.cell(1, c).value for c in range(1, ws_out.max_column + 1)]
print("Target headers:", target_headers)

expanded = []
for r, base_row, parsed in parsed_rows:
    org_vals = parsed.get("orgId", [None])
    care_vals = parsed.get("careType", [None])
    spec_vals = parsed.get("specialtyId", [None])
    ctx_vals = parsed.get("contextId", [None])
    for org, care, spec, ctx in product(org_vals, care_vals, spec_vals, ctx_vals):
        expanded.append([
            base_row["wtype_id"],
            base_row["name"],
            base_row["status"],
            org,
            care,
            spec,
            ctx,
        ])

print("\nExpanded rows to write:")
for i, row in enumerate(expanded, start=2):
    print(f"Output row {i}: {row}")

# Rewrite Output sheet contents below header
# clear existing data rows across current used range
for r in range(2, ws_out.max_row + 1):
    for c in range(1, ws_out.max_column + 1):
        ws_out.cell(r, c).value = None

for out_r, rowvals in enumerate(expanded, start=2):
    for c, val in enumerate(rowvals, start=1):
        ws_out.cell(out_r, c).value = val

# Save to output path with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("\nSaved to:", out_path)

# Recalculate
orig_sheetnames = wb.sheetnames[:]
recalc_result = await recalculate(out_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore sheet names if changed
wb2 = load_workbook(out_path)
print("Sheet names after recalc:", wb2.sheetnames)
if wb2.sheetnames != orig_sheetnames and len(wb2.sheetnames) == len(orig_sheetnames):
    for idx, name in enumerate(orig_sheetnames):
        wb2.worksheets[idx].title = name
    wb2.save(out_path)
    print("Restored original sheet names:", orig_sheetnames)

# Verify output values using data_only
wbv = load_workbook(out_path, data_only=True)
print("\nVerified Output sheet rows:")
wsv = wbv["Output"]
for r in range(1, max(wsv.max_row, len(expanded)+1) + 1):
    vals = [wsv.cell(r, c).value for c in range(1, wsv.max_column + 1)]
    if r == 1 or any(v is not None and v != "" for v in vals):
        print(f"Row {r}: {vals}")

output_spreadsheet = out_path
