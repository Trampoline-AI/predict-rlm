from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Input file:", input_spreadsheet)
print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

def sheet_summary(ws):
    print(f"\n=== Sheet: {ws.title} ===")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find non-empty rows and cols more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        print("first non-empty row:", nonempty_rows[0], "last non-empty row:", nonempty_rows[-1])
    
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Row 1 headers/values:")
    for c, h in enumerate(headers, start=1):
        print(f"  {get_column_letter(c)}1 = {h!r}")
    
    # Also inspect row 2 in case headers start later
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row 2 values:")
        for c, v in enumerate(row2, start=1):
            print(f"  {get_column_letter(c)}2 = {v!r}")
    
    # First 10 rows
    print("\nFirst rows:")
    for r in range(1, min(ws.max_row, 10) + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # Last 5 rows
    start_last = max(1, ws.max_row - 4)
    print("\nLast rows:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")

for s in wb.sheetnames:
    sheet_summary(wb[s])
