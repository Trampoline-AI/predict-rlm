import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

input_path = input_spreadsheet
print("Input path:", input_path)
print("Instruction:", instruction)

wb = load_workbook(input_path)
orig_sheet_names = wb.sheetnames
print("Sheet names:", orig_sheet_names)

def sheet_info(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    headers = [ws.cell(1, c).value for c in range(1, max_col + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Dimensions:", max_row, "rows x", max_col, "cols")
    print("Headers:", headers)
    
    # First 10 rows
    first_n = min(max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, row_vals)
    
    # Last 5 rows
    start_last = max(1, max_row - 4)
    print(f"Last rows {start_last} to {max_row}:")
    for r in range(start_last, max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, max_col + 1)]
        print(r, row_vals)

for ws in wb.worksheets:
    sheet_info(ws)

# Inspect the target sheet in more detail
if "Imported Data" in wb.sheetnames:
    ws = wb["Imported Data"]
    print("\nDetailed inspection of 'Imported Data'")
    print("Max row:", ws.max_row, "Max col:", ws.max_column)
    print("Column letters and headers:")
    for c in range(1, ws.max_column + 1):
        print(c, get_column_letter(c), ws.cell(1, c).value)
    
    print("\nCurrent values in E1:E15:")
    for r in range(1, min(15, ws.max_row) + 1):
        print(f"E{r} =", ws[f"E{r}"].value)
    
    # Count candidate deletions
    candidates = []
    non_numeric = []
    for r in range(2, ws.max_row + 1):
        val = ws.cell(r, 5).value
        if val is None or val == "":
            continue
        try:
            num = float(val)
            if num < 1:
                candidates.append((r, val))
        except Exception:
            non_numeric.append((r, val))
    print("\nRows where Column E < 1 (first 20 shown):", candidates[:20])
    print("Total candidate rows to delete:", len(candidates))
    print("Non-numeric nonblank values in Column E (first 20 shown):", non_numeric[:20])
else:
    print("ERROR: 'Imported Data' sheet not found")
