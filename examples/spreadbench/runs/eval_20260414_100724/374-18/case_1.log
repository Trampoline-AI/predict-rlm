os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Fresh load from input
wb = load_workbook(input_path)
original_sheet_names = wb.sheetnames[:]
print("Original sheet names:", original_sheet_names)

# Determine target worksheet
target_sheet_name = "Imported Data"
if target_sheet_name in wb.sheetnames:
    ws = wb[target_sheet_name]
    resolved_target = target_sheet_name
else:
    # Only one sheet exists, so use it as the imported-data sheet
    if len(wb.sheetnames) == 1:
        resolved_target = wb.sheetnames[0]
        ws = wb[resolved_target]
    else:
        raise ValueError("Instruction references 'Imported Data' but workbook has multiple sheets and no exact match.")

print("Resolved target sheet:", resolved_target)
print("Before deletion - max_row:", ws.max_row, "max_col:", ws.max_column)
print("Header row:", [ws.cell(1, c).value for c in range(1, ws.max_column + 1)])

# Print full current data because it's small
print("Current rows before deletion:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Identify rows to delete: data rows only, column E numeric values < 1
rows_to_delete = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(r, 5).value
    if val is None or val == "":
        continue
    try:
        if float(val) < 1:
            rows_to_delete.append((r, val))
    except Exception:
        pass

print("Rows to delete based on Column E < 1:", rows_to_delete)

# Delete bottom-up
for r, _ in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

print("After deletion (in-memory) - max_row:", ws.max_row)
print("Rows after deletion:")
for r in range(1, ws.max_row + 1):
    print(r, [ws.cell(r, c).value for c in range(1, ws.max_column + 1)])

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload and ensure sheet names still match original
wb_check = load_workbook(output_path)
print("Sheet names after recalc reload:", wb_check.sheetnames)

if wb_check.sheetnames != original_sheet_names:
    # restore original names in original order if counts match
    if len(wb_check.sheetnames) == len(original_sheet_names):
        for ws_obj, orig_name in zip(wb_check.worksheets, original_sheet_names):
            ws_obj.title = orig_name
        wb_check.save(output_path)
        print("Restored original sheet names:", original_sheet_names)
