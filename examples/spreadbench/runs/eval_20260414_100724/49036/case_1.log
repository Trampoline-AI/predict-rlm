```repl
from openpyxl import load_workbook
import os, re, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook for editing
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Dashboard"]

# Reconfirm target/source cells before writing
print("Before write:")
for coord in ["B5", "B6", "B8"]:
    print(coord, "=", ws[coord].value, "| numfmt:", ws[coord].number_format)

# Build formula to parse the number before the first space in B6 and B5
formula_b8 = '=IF(OR(B5="",B6=""),"",IFERROR(VALUE(LEFT(B6,FIND(" ",B6)-1))/VALUE(LEFT(B5,FIND(" ",B5)-1)),""))'
ws["B8"] = formula_b8
ws["B8"].number_format = '0% "WIN RATE"'

# Preserve existing alignment/fill/font style context from nearby cells if needed
for attr in ["alignment", "font", "fill", "border", "protection"]:
    setattr(ws["B8"], attr, getattr(ws["B6"], attr))

print("\nWritten:")
print("B8 formula =", ws["B8"].value)
print("B8 number_format =", ws["B8"].number_format)

# Save output workbook
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Restore sheet names if recalculate changed them
wb_after = load_workbook(outfile)
if wb_after.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames, "-> restoring", orig_sheetnames)
    for i, desired in enumerate(orig_sheetnames):
        if i < len(wb_after.worksheets):
            wb_after.worksheets[i].title = desired
    wb_after.save(outfile)

# Verify after recalc
wb_verify_formula = load_workbook(outfile)
wb_verify_data = load_workbook(outfile, data_only=True)
print("\nAfter recalc verification:")
print("Sheets:", wb_verify_formula.sheetnames)

vf = wb_verify_formula["Dashboard"]
vd = wb_verify_data["Dashboard"]

for coord in ["B5", "B6", "B8"]:
    print(
        coord,
        "formula/value=", vf[coord].value,
        "| cached(data_only)=", vd[coord].value,
        "| numfmt=", vf[coord].number_format
    )

# If formula did not evaluate, compute fallback numeric value from cached B5/B6 text and write literal
if vd["B8"].value in (None, ""):
    print("\nB8 did not evaluate; applying Python fallback.")
    b5_text = vd["B5"].value
    b6_text = vd["B6"].value
    print("Cached B5:", b5_text)
    print("Cached B6:", b6_text)

    def leading_number(x):
        if x is None:
            return None
        m = re.search(r'[-+]?\d*\.?\d+', str(x))
        return float(m.group()) if m else None

    n5 = leading_number(b5_text)
    n6 = leading_number(b6_text)
    print("Parsed numeric B5:", n5, "Parsed numeric B6:", n6)

    if n5 not in (None, 0) and n6 is not None:
        wb_fix = load_workbook(outfile)
        ws_fix = wb_fix["Dashboard"]
        ws_fix["B8"] = n6 / n5
        ws_fix["B8"].number_format = '0% "WIN RATE"'
        for attr in ["alignment", "font", "fill", "border", "protection"]:
            setattr(ws_fix["B8"], attr, getattr(ws_fix["B6"], attr))
        wb_fix.save(outfile)
        print("Fallback literal written to B8:", n6 / n5)

        # no second recalculate per instruction if already done; just reload to verify literal
        wb_verify_formula = load_workbook(outfile)
        wb_verify_data = load_workbook(outfile, data_only=True)
        vf = wb_verify_formula["Dashboard"]
        vd = wb_verify_data["Dashboard"]
        print("Post-fallback B8 formula/value=", vf["B8"].value, "| cached(data_only)=", vd["B8"].value, "| numfmt=", vf["B8"].number_format)

output_spreadsheet = outfile
print("\nPrepared output_spreadsheet =", output_spreadsheet)
