from openpyxl import load_workbook
from openpyxl.styles import PatternFill
from copy import copy
import os

input_path = input_spreadsheet
output_path = os.path.join("/sandbox/output/output_spreadsheet", os.path.basename(input_path))

# Load workbook
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb["DATABASE Countries"]

# Identify exact target rows in Revenue column F based on non-empty Countries column E
target_rows = [r for r in range(4, ws.max_row + 1) if ws[f"E{r}"].value not in (None, "")]
print("Target rows count:", len(target_rows), "range:", (target_rows[0], target_rows[-1]))

# Print current key formulas/values before modification
def disp_formula(cell):
    v = cell.value
    return getattr(v, "text", v)

key_rows = [4, 5, 104]
uk_rows = [r for r in target_rows if str(ws[f"E{r}"].value).strip() == "United Kingdom"]
if uk_rows:
    key_rows.append(uk_rows[0])
key_rows = sorted(set([r for r in key_rows if r <= ws.max_row]))

print("Before change:")
for r in key_rows:
    print(r, ws[f"E{r}"].value, "F formula/value:", disp_formula(ws[f"F{r}"]))

# Apply revised formula and requested styling
fill = PatternFill(start_color="FFFFC7CE", end_color="FFFFC7CE", fill_type="solid")

for r in target_rows:
    # Exact-match SUMPRODUCT on local currency, then convert to USD
    formula = f'=IF(E{r}="",0,IFERROR(SUMPRODUCT(--(TRIM($A$4:$A$36)=TRIM(E{r})),$B$4:$B$36)/$B$2,0))'
    cell = ws[f"F{r}"]
    cell.value = formula
    cell.fill = fill
    new_font = copy(cell.font)
    new_font.color = "FF9C0006"
    cell.font = new_font

# Save and recalculate
wb.save(output_path)
recalc_result = await recalculate(output_path)
print("Recalculate:", recalc_result)

# Restore original sheet names if recalculate changed them
wb_check = load_workbook(output_path)
if wb_check.sheetnames != original_sheetnames and len(wb_check.sheetnames) == len(original_sheetnames):
    for idx, old_name in enumerate(original_sheetnames):
        wb_check.worksheets[idx].title = old_name
    wb_check.save(output_path)
    print("Restored sheet names:", wb_check.sheetnames)
else:
    print("Sheet names after recalc:", wb_check.sheetnames)

# Reload for verification
wb_formula = load_workbook(output_path)
ws_formula = wb_formula["DATABASE Countries"]
wb_val = load_workbook(output_path, data_only=True)
ws_val = wb_val["DATABASE Countries"]

# Compute expected values from source data for sanity check
rate = ws_val["B2"].value
source_map = {}
for r in range(4, 37):
    country = ws_formula[f"A{r}"].value
    amt = ws_formula[f"B{r}"].value
    if country not in (None, "") and isinstance(amt, (int, float)):
        key = str(country).strip()
        source_map[key] = source_map.get(key, 0) + amt

print("Rate B2:", rate)
print("Source totals:", source_map)

# Verify key targets
verify_rows = [4, 5, 104]
if uk_rows:
    verify_rows.append(uk_rows[0])
verify_rows = sorted(set(verify_rows))

print("After change verification:")
for r in verify_rows:
    country = ws_formula[f"E{r}"].value
    formula = ws_formula[f"F{r}"].value
    value = ws_val[f"F{r}"].value
    fill_rgb = ws_formula[f"F{r}"].fill.fgColor.rgb if ws_formula[f"F{r}"].fill.fill_type else None
    font_rgb = ws_formula[f"F{r}"].font.color.rgb if ws_formula[f"F{r}"].font.color and ws_formula[f"F{r}"].font.color.type == "rgb" else None
    expected = 0
    if country not in (None, "") and rate not in (None, 0):
        expected = source_map.get(str(country).strip(), 0) / rate
    print({
        "row": r,
        "country": country,
        "formula": formula,
        "value": value,
        "expected": expected,
        "fill": fill_rgb,
        "font": font_rgb,
    })

# Broad verification: no blanks/errors in target F cells
bad = []
nonzero = []
for r in target_rows:
    v = ws_val[f"F{r}"].value
    if v in (None, ""):
        bad.append((r, ws_formula[f"E{r}"].value, v))
    if isinstance(v, str) and v.startswith("#"):
        bad.append((r, ws_formula[f"E{r}"].value, v))
    if isinstance(v, (int, float)) and abs(v) > 1e-12:
        nonzero.append((r, ws_formula[f"E{r}"].value, v))

print("Blank/error target cells count:", len(bad))
print("Nonzero results:", nonzero[:20])
print("Output saved to:", output_path)
