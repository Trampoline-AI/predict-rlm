```repl
from openpyxl import load_workbook
from openpyxl.formula.translate import Translator
from openpyxl.styles import Font, Alignment
from copy import copy
import os, math

infile = input_spreadsheet
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, os.path.basename(infile))

wb = load_workbook(infile)
wbd = load_workbook(infile, data_only=True)
orig_sheetnames = wb.sheetnames[:]
ws = wb["Sheet1"]
wsd = wbd["Sheet1"]

def is_blank_row(ws, r, max_col=None):
    max_col = max_col or ws.max_column
    return all(ws.cell(r, c).value in (None, "") for c in range(1, max_col + 1))

def last_nonempty_row(ws):
    for r in range(ws.max_row, 0, -1):
        if not is_blank_row(ws, r):
            return r
    return 0

def detect_blocks(ws, last_row):
    blocks = []
    start = None
    in_block = False
    for r in range(1, last_row + 1):
        blank = is_blank_row(ws, r)
        if not blank and not in_block:
            start = r
            in_block = True
        elif blank and in_block:
            blocks.append((start, r - 1))
            in_block = False
    if in_block:
        blocks.append((start, last_row))
    return blocks

def to_num(v):
    if isinstance(v, (int, float)) and not isinstance(v, bool):
        return float(v)
    try:
        if v is None or v == "":
            return None
        return float(v)
    except Exception:
        return None

def row_sort_key(r):
    dv = to_num(wsd.cell(r, 4).value)
    if dv is not None:
        return dv
    # fallback from B + C if cache missing
    bv = to_num(ws.cell(r, 2).value)
    cv = to_num(ws.cell(r, 3).value)
    if bv is not None and cv is not None:
        return bv + cv
    return None

def snapshot_row(ws, r, max_col):
    row = []
    for c in range(1, max_col + 1):
        cell = ws.cell(r, c)
        row.append({
            "value": cell.value,
            "style": copy(cell._style),
            "number_format": cell.number_format,
            "font": copy(cell.font),
            "fill": copy(cell.fill),
            "border": copy(cell.border),
            "alignment": copy(cell.alignment),
            "protection": copy(cell.protection),
            "hyperlink": copy(cell.hyperlink) if cell.hyperlink else None,
            "comment": copy(cell.comment) if cell.comment else None,
            "data_type": cell.data_type,
            "source_coord": cell.coordinate,
        })
    rd = ws.row_dimensions[r]
    row_meta = {
        "height": rd.height,
        "hidden": rd.hidden,
        "outlineLevel": rd.outlineLevel,
        "collapsed": rd.collapsed,
    }
    return {"orig_row": r, "cells": row, "row_meta": row_meta, "sort_key": row_sort_key(r)}

last_row = last_nonempty_row(ws)
blocks = detect_blocks(ws, last_row)
max_col = ws.max_column

print("Original blocks:", blocks)

# Snapshot and sort each block by evaluated D descending; nonnumeric rows, if any, go last preserving order
sorted_blocks = []
for (s, e) in blocks:
    snaps = [snapshot_row(ws, r, max_col) for r in range(s, e + 1)]
    snaps_sorted = sorted(
        snaps,
        key=lambda x: (x["sort_key"] is None, -(x["sort_key"] if x["sort_key"] is not None else 0), x["orig_row"])
    )
    sorted_blocks.append(snaps_sorted)

# Clear used region values/comments/hyperlinks before rewrite
for r in range(1, last_row + 1):
    for c in range(1, max_col + 1):
        cell = ws.cell(r, c)
        cell.value = None
        cell.comment = None
        cell._hyperlink = None

# Determine a blank-row style template from existing separator rows if available
blank_template_row = None
for r in range(1, last_row + 1):
    if is_blank_row(load_workbook(infile)["Sheet1"], r):  # small file, okay here for template detection
        blank_template_row = r
        break
# reload template workbook just once
tmpl_wb = load_workbook(infile)
tmpl_ws = tmpl_wb["Sheet1"]

# Rewrite sequentially with exactly one blank row between blocks
target_row = 1
new_blocks = []

for bi, block in enumerate(sorted_blocks, start=1):
    start_row = target_row
    for snap in block:
        # apply row dimensions
        meta = snap["row_meta"]
        ws.row_dimensions[target_row].height = meta["height"]
        ws.row_dimensions[target_row].hidden = meta["hidden"]
        ws.row_dimensions[target_row].outlineLevel = meta["outlineLevel"]
        ws.row_dimensions[target_row].collapsed = meta["collapsed"]

        for c, cell_snap in enumerate(snap["cells"], start=1):
            dest = ws.cell(target_row, c)
            src_val = cell_snap["value"]

            # translate formulas to new row so they keep row-correct references
            if isinstance(src_val, str) and src_val.startswith("="):
                try:
                    new_val = Translator(src_val, origin=cell_snap["source_coord"]).translate_formula(dest.coordinate)
                except Exception:
                    new_val = src_val
            else:
                new_val = src_val

            dest.value = new_val
            dest._style = copy(cell_snap["style"])
            dest.number_format = cell_snap["number_format"]
            dest.font = copy(cell_snap["font"])
            dest.fill = copy(cell_snap["fill"])
            dest.border = copy(cell_snap["border"])
            dest.alignment = copy(cell_snap["alignment"])
            dest.protection = copy(cell_snap["protection"])
            if cell_snap["hyperlink"]:
                dest._hyperlink = copy(cell_snap["hyperlink"])
            if cell_snap["comment"]:
                dest.comment = copy(cell_snap["comment"])
        target_row += 1

    end_row = target_row - 1
    new_blocks.append((start_row, end_row))

    # exactly one blank row between blocks
    if bi < len(sorted_blocks):
        if blank_template_row:
            ws.row_dimensions[target_row].height = tmpl_ws.row_dimensions[blank_template_row].height
            ws.row_dimensions[target_row].hidden = tmpl_ws.row_dimensions[blank_template_row].hidden
            ws.row_dimensions[target_row].outlineLevel = tmpl_ws.row_dimensions[blank_template_row].outlineLevel
            ws.row_dimensions[target_row].collapsed = tmpl_ws.row_dimensions[blank_template_row].collapsed
            # copy blank row styles from template row
            for c in range(1, max_col + 1):
                src = tmpl_ws.cell(blank_template_row, c)
                dest = ws.cell(target_row, c)
                dest._style = copy(src._style)
                dest.number_format = src.number_format
                dest.font = copy(src.font)
                dest.fill = copy(src.fill)
                dest.border = copy(src.border)
                dest.alignment = copy(src.alignment)
                dest.protection = copy(src.protection)
                dest.value = None
                dest.comment = None
                dest._hyperlink = None
        target_row += 1

needed_last_row = target_row - 1

# Clear any leftover rows in prior used range below new data
for r in range(needed_last_row + 1, last_row + 1):
    for c in range(1, max_col + 1):
        cell = ws.cell(r, c)
        cell.value = None
        cell.comment = None
        cell._hyperlink = None

# Enforce automatic calculation
try:
    wb.calculation.calcMode = "auto"
    wb.calculation.fullCalcOnLoad = True
    wb.calculation.forceFullCalc = True
except Exception as e:
    print("Calc mode set warning:", e)

# Recheck D:E:F formatting on data rows
for s, e in new_blocks:
    for r in range(s, e + 1):
        for c in [4, 5, 6]:
            cell = ws.cell(r, c)
            cell.font = copy(cell.font)
            cell.font = cell.font.copy(bold=True) if hasattr(cell.font, "copy") else Font(
                name=cell.font.name, sz=cell.font.sz, b=True, i=cell.font.i, color=cell.font.color,
                underline=cell.font.underline, strike=cell.font.strike, charset=cell.font.charset,
                outline=cell.font.outline, shadow=cell.font.shadow, condense=cell.font.condense,
                extend=cell.font.extend, family=cell.font.family, scheme=cell.font.scheme,
                vertAlign=cell.font.vertAlign
            )
            cell.alignment = copy(cell.alignment)
            cell.alignment = cell.alignment.copy(horizontal="center") if hasattr(cell.alignment, "copy") else Alignment(
                horizontal="center", vertical=cell.alignment.vertical, textRotation=cell.alignment.textRotation,
                wrapText=cell.alignment.wrapText, shrinkToFit=cell.alignment.shrinkToFit, indent=cell.alignment.indent
            )
            cell.number_format = "0.#"

wb.save(outfile)
print("Saved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc:", recalc_result)

# Restore original sheet names if LibreOffice changed them
post_wb = load_workbook(outfile)
if post_wb.sheetnames != orig_sheetnames and len(post_wb.sheetnames) == len(orig_sheetnames):
    for idx, name in enumerate(orig_sheetnames):
        post_wb.worksheets[idx].title = name
    post_wb.save(outfile)
    print("Restored sheet names:", post_wb.sheetnames)

# Verification
vbf = load_workbook(outfile)
vbd = load_workbook(outfile, data_only=True)
vws = vbf["Sheet1"]
vwsd = vbd["Sheet1"]

def verify_blocks(ws, last_row):
    return detect_blocks(ws, last_row)

v_last = last_nonempty_row(vws)
v_blocks = verify_blocks(vws, v_last)
print("Verified blocks:", v_blocks)

# verify sort order in each block
sort_checks = []
for s, e in v_blocks:
