import os, json, textwrap
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

print("INPUT:", input_spreadsheet)
print("INSTRUCTION:")
print(instruction)

wb = load_workbook(input_spreadsheet)
orig_sheet_names = wb.sheetnames
print("\nSheet names:", orig_sheet_names)

def sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    headers = [ws.cell(1, c).value for c in range(1, ws.max_column + 1)]
    print("Headers row 1:", headers)
    
    # also inspect row 2 in case headers start there
    if ws.max_row >= 2:
        row2 = [ws.cell(2, c).value for c in range(1, ws.max_column + 1)]
        print("Row 2:", row2)
    
    # print first 10 rows
    first_n = min(ws.max_row, 10)
    print(f"First {first_n} rows:")
    for r in range(1, first_n + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # print last 5 rows
    start_last = max(1, ws.max_row - 4)
    print(f"Last rows {start_last}:{ws.max_row}:")
    for r in range(start_last, ws.max_row + 1):
        vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # print cells with formulas in used range
    formulas = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formula cells:", formulas[:20], f"(total {len(formulas)})")

for ws in wb.worksheets:
    sheet_summary(ws)
