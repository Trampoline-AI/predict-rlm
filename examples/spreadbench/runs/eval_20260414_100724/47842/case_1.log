import os
from openpyxl import load_workbook

# Reload workbook for editing
wb = load_workbook(input_spreadsheet)
ws = wb["Sheet1"]

print("Pre-edit inspection of target/source columns (rows 1-16):")
for r in range(1, ws.max_row + 1):
    print(r, {"B": ws[f"B{r}"].value, "C": ws[f"C{r}"].value, "F": ws[f"F{r}"].value})

# Write formulas into existing target column F
for r in range(2, ws.max_row + 1):
    formula = f'=IF(OR(B{r}="",C{r}=""),"",IF(EXACT(LEFT(B{r},1),UPPER(LEFT(B{r},1))),UPPER(LEFT(C{r},1)),LOWER(LEFT(C{r},1)))&MID(C{r},2,LEN(C{r})-1))'
    ws[f"F{r}"] = formula

# Save to output with same filename
out_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(out_dir, exist_ok=True)
out_path = os.path.join(out_dir, os.path.basename(input_spreadsheet))
wb.save(out_path)
print("Saved to:", out_path)

# Recalculate
