Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from copy import copy
import os

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
os.makedirs(outdir, exist_ok=True)
outfile = os.path.join(outdir, filename)

wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Inspect exact target area before writing
print("Current target A14:E17 before writing:")
for r in range(14, 18):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Also print source and example blocks for cross-check
print("\nSource A1:E4:")
for r in range(1, 5):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

print("\nExample result A9:E12:")
for r in range(9, 13):
    print(r, [ws.cell(r, c).value for c in range(1, 6)])

# Build output rows: header + deduplicated worker rows
output_rows = []

# Header row unchanged from row 1
header = [ws.cell(1, c).value for c in range(1, 6)]
output_rows.append(header)

# Data rows from rows 2..4 based on actual non-empty source block
for r in range(2, 5):
    row_vals = [ws.cell(r, c).value for c in range(1, 6)]
    site = row_vals[0]
    workers = row_vals[1:]
    seen = set()
    deduped_workers = []
    for w in workers:
        if w is None or w == "":
            deduped_workers.append(None)
        elif w in seen:
            deduped_workers.append(None)
        else:
            deduped_workers.append(w)
            seen.add(w)
    output_rows.append([site] + deduped_workers)

print("\nComputed output rows for A14:E17:")
for i, row in enumerate(output_rows, start=14):
    print(i, row)

# Write values into A14:E17
for r_offset, row_vals in enumerate(output_rows, start=14):
    for c, val in enumerate(row_vals, start=1):
        ws.cell(r_offset, c).value = val

# Optionally copy simple style from example block A9:E12 to A14:E17 when available
for src_r, dst_r in zip(range(9, 13), range(14, 18)):
    for c in range(1, 6):
        src_cell = ws.cell(src_r, c)
        dst_cell = ws.cell(dst_r, c)
        if src_cell.has_style:
            dst_cell._style = copy(src_cell._style)
        if src_cell.number_format:
            dst_cell.number_format = src_cell.number_format
        if src_cell.font:
            dst_cell.font = copy(src_cell.font)
        if src_cell.fill:
            dst_cell.fill = copy(src_cell.fill)
        if src_cell.border:
            dst_cell.border = copy(src_cell.border)
        if src_cell.alignment:
            dst_cell.alignment = copy(src_cell.alignment)
        if src_cell.protection:
            dst_cell.protection = copy(src_cell.protection)

wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalc result:", recalc_result)

# Reload and ensure sheet names preserved
wb2 = load_workbook(outfile)
if wb2.sheetnames != orig_sheetnames:
    print("Sheet names changed after recalc:", wb2.sheetnames, "-> restoring", orig_sheetnames)
    # Rename by position to match originals
    for i, name in enumerate(orig_sheetnames):
        wb2.worksheets[i].title = name
    wb2.save(outfile)

# Verify using data_only after recalculation
wb_check = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_check.sheetnames)
ws_check = wb_check[orig_sheetnames[0]]

print("\nVerified target A14:E17 after save/recalc:")
for r in range(14, 18):
    vals = [ws_check.cell(r, c).value for c in range(1, 6)]
    print(r, vals)

output_spreadsheet = outfile
