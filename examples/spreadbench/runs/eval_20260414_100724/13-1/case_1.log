def fmt(v):
    if isinstance(v, datetime):
        return v.strftime("%Y-%m-%d")
    return v

def norm_date(v):
    if isinstance(v, datetime):
        return v
    if isinstance(v, str):
        for f in ("%m/%d/%Y", "%Y-%m-%d", "%m/%d/%y"):
            try:
                return datetime.strptime(v, f)
            except:
                pass
    return v

def used_last_row_col(ws):
    last_row = 0
    last_col = 0
    for r in range(1, ws.max_row + 1):
