from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

print("Instruction:", instruction)

wb = load_workbook(input_spreadsheet)
print("Workbook sheets:", wb.sheetnames)

def visible_value(v):
    try:
        from openpyxl.worksheet.formula import ArrayFormula
        if isinstance(v, ArrayFormula):
            return f"<ArrayFormula {v.text}>"
    except Exception:
        pass
    return v

def inspect_sheet(ws, sample_head=10, sample_tail=5, max_cols_to_show=None):
    print(f"\n--- Sheet: {ws.title} ---")
    print("max_row:", ws.max_row, "max_column:", ws.max_column)
    
    # Find non-empty rows/cols a bit more accurately
    nonempty_rows = []
    for r in range(1, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None and v != "" for v in row_vals):
            nonempty_rows.append(r)
    print("non-empty row count:", len(nonempty_rows))
    if nonempty_rows:
        first_nonempty = nonempty_rows[0]
        last_nonempty = nonempty_rows[-1]
        print("first non-empty row:", first_nonempty, "last non-empty row:", last_nonempty)
    else:
        print("Sheet appears empty")
        return
    
    # Print first several rows with coordinates
    cols = ws.max_column if max_cols_to_show is None else min(ws.max_column, max_cols_to_show)
    print("\nTop rows:")
    for r in range(1, min(ws.max_row, sample_head) + 1):
        vals = [visible_value(ws.cell(r, c).value) for c in range(1, cols + 1)]
        print(f"Row {r}: {vals}")
    
    print("\nBottom rows:")
    start_tail = max(1, ws.max_row - sample_tail + 1)
    for r in range(start_tail, ws.max_row + 1):
        vals = [visible_value(ws.cell(r, c).value) for c in range(1, cols + 1)]
        print(f"Row {r}: {vals}")
    
    # Candidate header rows: first 5 non-empty rows
    print("\nCandidate header rows (first 5 non-empty):")
    for r in nonempty_rows[:5]:
        vals = [visible_value(ws.cell(r, c).value) for c in range(1, cols + 1)]
        print(f"Row {r}: {vals}")
    
    # Print columns with header names from first 5 rows
    print("\nColumn letters and first 5 row values:")
    for c in range(1, cols + 1):
        vals = [visible_value(ws.cell(r, c).value) for r in range(1, min(5, ws.max_row) + 1)]
        print(f"{get_column_letter(c)}: {vals}")

for s in wb.sheetnames:
    inspect_sheet(wb[s], max_cols_to_show=20)

# Focused search for likely relevant headers/cells
keywords = ["location", "office", "code", "entry", "table"]
print("\n=== Searching all sheets for relevant text ===")
for s in wb.sheetnames:
    ws = wb[s]
    hits = []
    for r in range(1, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str):
                lv = v.lower()
                if any(k in lv for k in keywords):
                    hits.append((r, c, v))
    print(f"\nSheet {s} hits ({len(hits)}):")
    for hit in hits[:50]:
        r, c, v = hit
        print(f"  {get_column_letter(c)}{r}: {v}")

# If specific sheet names exist, print a wider targeted view
for target in ["Entry Tab", "Table Tab"]:
    if target in wb.sheetnames:
        ws = wb[target]
        print(f"\n=== Detailed targeted view for {target} ===")
        for r in range(1, min(ws.max_row, 15) + 1):
            row = []
            for c in range(1, min(ws.max_column, 15) + 1):
                val = visible_value(ws.cell(r, c).value)
                row.append(f"{get_column_letter(c)}{r}={val}")
            print(" | ".join(row))
