Code:
```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os

input_path = input_spreadsheet
filename = os.path.basename(input_path)
output_path = os.path.join("/sandbox/output/output_spreadsheet", filename)

wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]

entry_ws = wb["Entry Tab"]
table_ws = wb["Table Tab"]

# Re-confirm exact target and source areas before writing
print("Entry Tab headers:", entry_ws["B1"].value, entry_ws["E1"].value)
print("Table Tab headers:", table_ws["A1"].value, table_ws["B1"].value)
print("Current target cells before writing:")
for r in range(2, entry_ws.max_row + 1):
    print(f"  B{r}={entry_ws[f'B{r}'].value!r}, E{r}={entry_ws[f'E{r}'].value!r}")

# Determine mapping table extent
table_last_row = 1
for r in range(table_ws.max_row, 1, -1):
    if table_ws.cell(r, 1).value not in (None, "") or table_ws.cell(r, 2).value not in (None, ""):
        table_last_row = r
        break

# Determine relevant entry rows: rows with anything in the location column B
entry_last_row = 1
for r in range(entry_ws.max_row, 1, -1):
    if entry_ws.cell(r, 2).value not in (None, ""):
        entry_last_row = r
        break

print("Detected table range:", f"A2:B{table_last_row}")
print("Detected entry rows:", f"2:{entry_last_row}")

# Write formulas into the designated Office Code column E
for r in range(2, entry_last_row + 1):
    formula = f'=IF(B{r}="","",IFERROR(VLOOKUP(B{r},\'Table Tab\'!$A$2:$B${table_last_row},2,FALSE),""))'
    print(f"Writing E{r}: {formula}")
    entry_ws[f"E{r}"] = formula

wb.save(output_path)
print("Saved workbook to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Re-open and restore sheet names if recalc changed them
wb_after = load_workbook(output_path)
if wb_after.sheetnames != original_sheetnames:
    print("Sheet names changed after recalc:", wb_after.sheetnames)
    for idx, original_name in enumerate(original_sheetnames):
        if idx < len(wb_after.worksheets):
            wb_after.worksheets[idx].title = original_name
    wb_after.save(output_path)
    print("Restored sheet names to:", wb_after.sheetnames)
else:
    print("Sheet names preserved:", wb_after.sheetnames)

# Verification with formulas visible
wb_verify_formula = load_workbook(output_path, data_only=False)
entry_formula_ws = wb_verify_formula["Entry Tab"]
print("Formulas written in target cells:")
for r in range(2, entry_last_row + 1):
    print(f"  E{r} formula = {entry_formula_ws[f'E{r}'].value!r}")

# Verification with calculated values
wb_verify_values = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify_values.sheetnames)
entry_value_ws = wb_verify_values["Entry Tab"]

verified_targets = {}
for r in range(2, entry_last_row + 1):
    loc = entry_value_ws[f"B{r}"].value
    office_code = entry_value_ws[f"E{r}"].value
    verified_targets[f"E{r}"] = office_code
    print(f"  Row {r}: location={loc!r}, office_code={office_code!r}")

# Basic assertions / sanity checks
assert wb_verify_values.sheetnames == original_sheetnames, "Sheet names mismatch after processing"
for r in range(2, entry_last_row + 1):
    if entry_value_ws[f"B{r}"].value not in (None, ""):
        assert entry_value_ws[f"E{r}"].value not in (None, ""), f"E{r} is blank but should have a value"

final_output_spreadsheet = output_path
print("Ready to submit:", final_output_spreadsheet)
```
