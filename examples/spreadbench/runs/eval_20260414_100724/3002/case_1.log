    for r in range(data_start, ws.max_row + 1):
        if ws.cell(r, mat_col).value is not None or ws.cell(r, doc_col).value is not None:
            last_data_row = r

    mat_to_docs = {}
    for r in range(data_start, last_data_row + 1):
        mat = ws.cell(r, mat_col).value
        doc = ws.cell(r, doc_col).value
        if mat is not None and doc is not None:
            mat_to_docs.setdefault(mat, set()).add(doc)

    expected = {}
    for r in range(data_start, last_data_row + 1):
        mat = ws.cell(r, mat_col).value
        doc = ws.cell(r, doc_col).value
        if mat is None and doc is None:
            expected[r] = None
        else:
            expected[r] = "Multiple" if len(mat_to_docs.get(mat, set())) > 1 else "Single"

    mat_letter = get_column_letter(mat_col)
    doc_letter = get_column_letter(doc_col)

    # write formulas in remark column
    for r in range(data_start, last_data_row + 1):
        mat = ws.cell(r, mat_col).value
        doc = ws.cell(r, doc_col).value
        if mat is None and doc is None:
            continue
        ws.cell(r, remark_col).value = (
            f'=IF({mat_letter}{r}="","",'
            f'IF(COUNTIFS(${mat_letter}${data_start}:${mat_letter}${last_data_row},{mat_letter}{r},'
