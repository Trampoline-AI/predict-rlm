    fill = cell.fill
    border = cell.border
    font = cell.font
    
    fill_info = {
        "fill_type": fill.fill_type,
        "fgColor": fill.fgColor.rgb if getattr(fill.fgColor, "type", None) == "rgb" else fill.fgColor.indexed if getattr(fill.fgColor, "type", None) == "indexed" else fill.fgColor.type,
