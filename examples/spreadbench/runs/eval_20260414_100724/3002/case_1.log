def safe_border_summary(cell):
    b = cell.border
    def sty(side):
        return None if side is None else side.style
    return (sty(b.left), sty(b.right), sty(b.top), sty(b.bottom))

def safe_fill_summary(cell):
    f = cell.fill
    rgb = None
    if getattr(f.fgColor, "type", None) == "rgb":
        rgb = f.fgColor.rgb
    return (f.fill_type, rgb)

def build_and_save():
