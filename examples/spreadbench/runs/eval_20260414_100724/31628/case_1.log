from openpyxl import load_workbook
from pathlib import Path
import os

input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load original workbook and capture original sheet names
wb = load_workbook(input_path)
original_sheetnames = wb.sheetnames[:]
ws = wb[original_sheetnames[0]]

# Inspect exact source range again and compute the last entry's day number
source_vals = [ws[f"A{r}"].value for r in range(1, 12)]
print("Source A1:A11:", source_vals)
last_entry = ws["A11"].value
print("Last entry A11:", last_entry, type(last_entry))

# Write static day number to B1
day_num = last_entry.day
print("Writing static day number to B1:", day_num)
print("B1 before:", ws["B1"].value)
ws["B1"] = day_num
print("B1 after write (in-memory):", ws["B1"].value)

# Save
wb.save(output_path)
print("Saved to:", output_path)

# Recalculate
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload after recalc and restore original sheet names if needed
wb_after = load_workbook(output_path)
print("Sheet names after recalc:", wb_after.sheetnames)
if wb_after.sheetnames != original_sheetnames:
    # rename sheets positionally back to original names
    for ws_obj, orig_name in zip(wb_after.worksheets, original_sheetnames):
        ws_obj.title = orig_name
    wb_after.save(output_path)
    print("Renamed sheets back to original:", original_sheetnames)

# Verify with data_only=True
wb_verify = load_workbook(output_path, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[original_sheetnames[0]]

verified_a = [wsv[f"A{r}"].value for r in range(1, 12)]
verified_b1 = wsv["B1"].value

print("Verified A1:A11:", verified_a)
print("Verified B1:", verified_b1, type(verified_b1))
print("B1 blank?", verified_b1 in (None, ""))

# Keep output path for submission
final_output_path = output_path
