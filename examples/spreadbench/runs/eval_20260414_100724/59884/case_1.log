from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
import os, json, math

path = input_spreadsheet
wb = load_workbook(path)
print("Instruction:", instruction)
print("Workbook sheets:", wb.sheetnames)

def cell_display(v):
    if v is None:
        return None
    return v

for ws in wb.worksheets:
    print("\n" + "="*80)
    print(f"Sheet: {ws.title}")
    print(f"max_row={ws.max_row}, max_col={ws.max_column}")
    if ws.merged_cells.ranges:
        print("Merged ranges:", list(ws.merged_cells.ranges)[:10], "..." if len(ws.merged_cells.ranges) > 10 else "")
    else:
        print("Merged ranges: none")
    
    # Find non-empty rows/cols more reliably
    nonempty_rows = []
    nonempty_cols = set()
    for r in range(1, ws.max_row + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        if any(v is not None for v in row_vals):
            nonempty_rows.append(r)
            for c, v in enumerate(row_vals, start=1):
                if v is not None:
                    nonempty_cols.add(c)
    print("Non-empty row count:", len(nonempty_rows))
    print("Non-empty cols:", [f"{get_column_letter(c)}" for c in sorted(nonempty_cols)])
    
    # Print first 10 rows and last 5 non-empty rows
    rows_to_show = []
    rows_to_show.extend(nonempty_rows[:10])
    for r in nonempty_rows[-5:]:
        if r not in rows_to_show:
            rows_to_show.append(r)
    print("Sample rows:")
    for r in rows_to_show:
        vals = [cell_display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {vals}")
    
    # Header guess: first few rows
    print("Header guess rows 1-3:")
    for r in range(1, min(3, ws.max_row) + 1):
        vals = [cell_display(ws.cell(r, c).value) for c in range(1, ws.max_column + 1)]
        print(f"  R{r}: {vals}")
    
    # Print formulas if present in first 15 rows
    formulas = []
    for r in range(1, min(ws.max_row, 20) + 1):
        for c in range(1, ws.max_column + 1):
            v = ws.cell(r, c).value
            if isinstance(v, str) and v.startswith("="):
                formulas.append((f"{get_column_letter(c)}{r}", v))
    print("Formulas in first 20 rows:", formulas[:20] if formulas else "none")
