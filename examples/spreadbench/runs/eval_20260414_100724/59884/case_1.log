```repl
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from collections import OrderedDict
import os, shutil

infile = input_spreadsheet
filename = os.path.basename(infile)
outdir = "/sandbox/output/output_spreadsheet"
outfile = os.path.join(outdir, filename)
os.makedirs(outdir, exist_ok=True)

# Load workbook
wb = load_workbook(infile)
orig_sheetnames = wb.sheetnames[:]
ws = wb[orig_sheetnames[0]]

# Inspect target area width needed
groups = OrderedDict()
for r in range(2, ws.max_row + 1):
    first = ws.cell(r, 1).value
    second = ws.cell(r, 2).value
    if first is None and second is None:
        continue
    if first is None:
        continue
    groups.setdefault(first, []).append(second)

max_seconds = max(len(v) for v in groups.values()) if groups else 0
start_col = 7   # G
start_row = 2   # under headers
end_col = 8 + 1 + max_seconds  # G,H plus I:...
# actually columns used are G,H, then I..(I+max_seconds-1)
end_col = 9 + max_seconds - 1 if max_seconds else 8

print("Computed groups:")
for k, vals in groups.items():
    print(f"  {k}: count={len(vals)}, seconds={vals}")

print("\nPre-write target area G1:M6:")
for r in range(1, 7):
    vals = [ws.cell(r, c).value for c in range(7, 14)]
    print(f"R{r}: {vals}")

# Clear existing output area (old array formula/demo block)
clear_end_row = max(ws.max_row, start_row + len(groups) + 5)
clear_end_col = max(ws.max_column, end_col)
for r in range(start_row, clear_end_row + 1):
    for c in range(start_col, clear_end_col + 1):
        ws.cell(r, c).value = None

# Write headers (preserve same structure/text)
ws["G1"] = "1st"
ws["H1"] = "Occurances"
ws["I1"] = "2nd ->"

# Write grouped structured output starting at row 2
for i, (first, seconds) in enumerate(groups.items(), start=start_row):
    ws.cell(i, 7).value = first
    ws.cell(i, 8).value = len(seconds)
    for j, val in enumerate(seconds, start=9):  # I onward
        ws.cell(i, j).value = val

# Save
wb.save(outfile)
print("\nSaved to:", outfile)

# Recalculate
recalc_result = await recalculate(outfile)
print("Recalculate result:", recalc_result)

# Reload and restore original sheet names if LibreOffice renamed them
wb_check = load_workbook(outfile)
if wb_check.sheetnames != orig_sheetnames and len(wb_check.sheetnames) == len(orig_sheetnames):
    for old, new in zip(orig_sheetnames, wb_check.sheetnames):
        wb_check[new].title = old
    wb_check.save(outfile)
    print("Restored sheet names to:", orig_sheetnames)

# Verify using data_only
wb_verify = load_workbook(outfile, data_only=True)
print("Verified sheet names:", wb_verify.sheetnames)
wsv = wb_verify[orig_sheetnames[0]]

verify_end_col = max(13, end_col)  # at least through M for visibility
verify_end_row = start_row + len(groups) - 1

print("\nPost-write target area G1:{}{}:".format(get_column_letter(verify_end_col), verify_end_row))
for r in range(1, verify_end_row + 1):
    vals = [wsv.cell(r, c).value for c in range(7, verify_end_col + 1)]
    print(f"R{r}: {vals}")

# Explicit target cell verification
print("\nExplicit verification:")
for i in range(start_row, verify_end_row + 1):
    first = wsv.cell(i, 7).value
    occ = wsv.cell(i, 8).value
    seconds = [wsv.cell(i, c).value for c in range(9, end_col + 1)]
    print(f"Row {i}: G{i}={first!r}, H{i}={occ!r}, seconds={seconds!r}")

output_spreadsheet = outfile
