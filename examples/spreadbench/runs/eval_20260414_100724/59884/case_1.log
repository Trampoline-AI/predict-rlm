from openpyxl import load_workbook
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os, shutil

path = input_spreadsheet
wb = load_workbook(path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Also inspect cached/calculated values
wb_data = load_workbook(path, data_only=True)
ws_data = wb_data[wb_data.sheetnames[0]]

print("Sheet names:", wb.sheetnames)
print("Source area A1:C13:")
for r in range(1, min(ws.max_row, 13) + 1):
    vals = [ws.cell(r, c).value for c in range(1, 4)]
    print(f"R{r} A:C -> {vals}")

print("\nTarget/demo area G1:K13 (formula view and data_only view):")
for r in range(1, min(ws.max_row, 13) + 1):
    row_formula = []
    row_data = []
    for c in range(7, 12):
        cell = ws.cell(r, c)
        v = cell.value
