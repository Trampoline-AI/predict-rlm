import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_531-18_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_531-18_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Worksheets
ws_data = wb["Data"]
ws_trans = wb["Transpose"]

# -------------------------------------------------
# Identify date columns in Data sheet (row 6, columns G onward)
header_row = 6
date_cols = []  # list of (col_idx, date_value)
max_col = ws_data.max_column
for col in range(7, max_col + 1):  # column 7 = G
    cell = ws_data.cell(row=header_row, column=col)
    if isinstance(cell.value, (datetime.datetime, datetime.date)):
        date_cols.append((col, cell.value))
    elif isinstance(cell.value, str):
        # try to parse date string if needed
        try:
            parsed = datetime.datetime.fromisoformat(cell.value)
            date_cols.append((col, parsed))
        except Exception:
            pass

# -------------------------------------------------
# Clear existing transposed rows (keep header at row 2)
# Delete rows 3..max_row if any
if ws_trans.max_row > 2:
    ws_trans.delete_rows(3, ws_trans.max_row - 2)

# Write transposed data
out_row = 3  # start after header
for data_row in range(7, ws_data.max_row + 1):
    item = ws_data.cell(row=data_row, column=1).value  # column A
    if item is None:
        continue
    for col_idx, date_val in date_cols:
        qty = ws_data.cell(row=data_row, column=col_idx).value
        # Include zero quantities as well (they may be meaningful)
        # Skip if qty is None
        if qty is None:
            continue
        ws_trans.cell(row=out_row, column=1, value=item)
        ws_trans.cell(row=out_row, column=2, value=date_val)
        ws_trans.cell(row=out_row, column=3, value=qty)
        out_row += 1

# -------------------------------------------------
# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to verify a few target rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Transpose"]
print("Transposed rows written:", ws_check.max_row - 2)  # exclude header rows
# Show first 5 transposed rows
for r in range(3, min(8, ws_check.max_row + 1)):
    print(r, [ws_check.cell(row=r, column=c).value for c in range(1, 4)])

```
