```repl
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.styles import PatternFill
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_39667_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_39667_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# -------------------------------------------------
# 1. Identify header row (first row containing "Pay Item Number")
header_row = None
for r in range(1, ws.max_row + 1):
    if ws.cell(row=r, column=1).value == "Pay Item Number":
        header_row = r
        break
if header_row is None:
    raise ValueError("Could not locate header row with 'Pay Item Number'")

# Data starts after header, ends before next header (row with same text)
data_start = header_row + 1
data_end = None
for r in range(data_start + 1, ws.max_row + 1):
    if ws.cell(row=r, column=1).value == "Pay Item Number":
        data_end = r - 1
        break
if data_end is None:
    # fallback: use last non‑empty row in column A
    data_end = ws.max_row
    while data_end > data_start and ws.cell(row=data_end, column=1).value is None:
        data_end -= 1

# Verify range
print(f"Header row: {header_row}, data rows: {data_start}‑{data_end}")

# -------------------------------------------------
# 2. Write formulas for rows 20‑26 (or up to max row if sheet is shorter)
target_start = 20
target_end = 26
max_row = ws.max_row
if max_row < target_end:
    # extend sheet if needed
    ws.append([None] * ws.max_column)  # ensure at least target_end rows exist

for r in range(target_start, target_end + 1):
    # Column A formula (Pay Item Number)
    formula_a = f'=IF(C{r}="","",INDEX($A${data_start}:$A${data_end},MATCH(C{r},$C${data_start}:$C${data_end},0)))'
    ws.cell(row=r, column=1).value = formula_a

    # Column B formula (UOM)
    formula_b = f'=IF(C{r}="","",INDEX($B${data_start}:$B${data_end},MATCH(C{r},$C${data_start}:$C${data_end},0)))'
    ws.cell(row=r, column=2).value = formula_b

# -------------------------------------------------
# 3. Apply fill color #FFF2CC to columns A & B rows 20‑26
fill = PatternFill(start_color="FFF2CC", end_color="FFF2CC", fill_type="solid")
for r in range(target_start, target_end + 1):
    ws.cell(row=r, column=1).fill = fill
    ws.cell(row=r, column=2).fill = fill

# -------------------------------------------------
# 4. Save workbook
wb.save(output_path)
print("Workbook saved to", output_path)

# -------------------------------------------------
# 5. Recalculate formulas (LibreOffice backend)
# The environment provides an async `recalculate` function.
# We need to await it, but in this REPL block we can use `await`.
await recalculate(output_path)

# -------------------------------------------------
# 6. Reload with data_only=True to verify results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[ws2.sheetnames[0]]

print("Verification values (A,B for rows 20‑26):")
for r in range(target_start, target_end + 1):
    a_val = ws2.cell(row=r, column=1).value
    b_val = ws2.cell(row=r, column=2).value
    c_val = ws2.cell(row=r, column=3).value
    print(f"Row {r}: Description={c_val!r}, PayItem={a_val!r}, UOM={b_val!r}")
