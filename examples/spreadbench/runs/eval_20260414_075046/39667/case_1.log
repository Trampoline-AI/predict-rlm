for r in range(2, max_row+1):
    for c in range(1, max_col+1):
        cell = ws.cell(row=r, column=c)
        fill = cell.fill
        if isinstance(fill, PatternFill) and fill.fgColor.type == 'rgb' and fill.fgColor.rgb == 'FF000000':
            black_rows.append(r)
            break
    # break outer loop if found at least one black cell in the row

