Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os
import shutil

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
# Preserve original filename
filename = os.path.basename(input_path)
output_path = os.path.join(output_dir, filename)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume single sheet

# Determine data extents
max_row = ws.max_row
max_col = ws.max_column

# Base columns (A-H) indices 1-8
BASE_COLS = list(range(1, 9))

# Pair columns: numeric at 11,14,17,20 ; string at 12,15,18,21
pair_numeric_cols = [11, 14, 17, 20]
pair_string_cols = [12, 15, 18, 21]

# Collect rows to append
new_rows = []

for r in range(2, max_row + 1):  # skip header
    # Read base values (A-H)
    base_vals = [ws.cell(row=r, column=c).value for c in BASE_COLS]
    # For each pair, if numeric is not None, create a new row
    for num_col, str_col in zip(pair_numeric_cols, pair_string_cols):
        num_val = ws.cell(row=r, column=num_col).value
        str_val = ws.cell(row=r, column=str_col).value
        if num_val is not None or str_val is not None:
            # Build new row: base columns + numeric (I) + string (J)
            new_row = base_vals + [num_val, str_val]
            new_rows.append(new_row)

# Append new rows after the existing data
out_row = max_row + 1
for row_vals in new_rows:
    for c_idx, val in enumerate(row_vals, start=1):
        ws.cell(row=out_row, column=c_idx, value=val)
    out_row += 1

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload to verify a few of the newly added rows (data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print(f"After processing, total rows: {ws_check.max_row}")
# Show first 5 newly added rows
print("Sample of newly added rows (first 5):")
for r in range(max_row + 1, min(max_row + 6, ws_check.max_row + 1)):
    print([ws_check.cell(row=r, column=c).value for c in range(1, 11)])  # A-J
```
