import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_54925_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_54925_init.xlsx")
os.makedirs(output_dir, exist_ok=True)

# Load workbook (preserve any existing formulas elsewhere)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Reference values
m3 = ws.cell(row=3, column=column_index_from_string('M')).value
n3 = ws.cell(row=3, column=column_index_from_string('N')).value
n4 = ws.cell(row=4, column=column_index_from_string('N')).value
print(f"Reference values -> M3: {m3}, N3: {n3}, N4: {n4}")

# Target column (Q) where the results should appear
col_q = column_index_from_string('Q')
col_h = column_index_from_string('H')
col_k = column_index_from_string('K')
col_b = column_index_from_string('B')

# Iterate over rows 2‑40 (the data range observed earlier)
for r in range(2, 41):
    h_val = ws.cell(row=r, column=col_h).value
    k_val = ws.cell(row=r, column=col_k).value
    b_val = ws.cell(row=r, column=col_b).value
    # Check condition: H == M3 AND (K == N3 OR K == N4)
    if h_val == m3 and (k_val == n3 or k_val == n4):
        ws.cell(row=r, column=col_q).value = b_val
    else:
