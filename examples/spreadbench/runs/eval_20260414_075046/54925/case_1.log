import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_54925_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_54925_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Define the array formula (same as existing) – we will write it to Q2 (the start of the array)
formula = "=IFERROR(INDEX($B$2:$B$40,SMALL(IF(0<($M$3=$H$2:$H$40)*(($N$3=$K$2:$K$40)+($N$4=$K$2:$K$40)),ROW($B$2:$B$40)-2,""),ROW()-1)),"")"

# Write the formula to Q2 (column 17)
ws.cell(row=2, column=column_index_from_string('Q')).value = formula

# Save to output path
wb.save(output_path)

# Recalculate formulas using the provided tool (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only to read computed values
wb_calc = openpyxl.load_workbook(output_path, data_only=True)
ws_calc = wb_calc[wb_calc.sheetnames[0]]

# Print a few result cells from column Q to verify
print("Result values in column Q after recalculation:")
for r in range(2, 12):
    val = ws_calc.cell(row=r, column=column_index_from_string('Q')).value
    print(f"Q{r}: {val}")
```
