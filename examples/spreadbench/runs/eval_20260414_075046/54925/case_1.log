import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_54925_init.xlsx"
wb = openpyxl.load_workbook(wb_path)
ws = wb[wb.sheetnames[0]]

# Helper to get formula text from an ArrayFormula object

def get_formula(cell):
    if cell is None:
        return None
    val = cell.value
    if isinstance(val, str) and val.startswith('='):
        return val
    # openpyxl represents CSE array formulas as a special object
    if hasattr(val, 'text'):
        return val.text
    return None

# Inspect header cell Q1 (column 17)
header_cell = ws.cell(row=1, column=column_index_from_string('Q'))
print('Header Q1 formula:', get_formula(header_cell))

# Inspect a few data cells in column Q to see the formula (should be same array formula object)
for r in range(2, 6):
    cell = ws.cell(row=r, column=column_index_from_string('Q'))
    print(f'Q{r} formula:', get_formula(cell))

# Print the values of M3, N3, N4 for reference
print('M3:', ws.cell(row=3, column=column_index_from_string('M')).value)
print('N3:', ws.cell(row=3, column=column_index_from_string('N')).value)
print('N4:', ws.cell(row=4, column=column_index_from_string('N')).value)
```
