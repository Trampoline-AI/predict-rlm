output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_58147_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# We'll work on the first sheet (Sheet1) as it contains the data.
ws = wb[wb.sheetnames[0]]

# Determine column indices for I and J
col_I = column_index_from_string('I')
col_J = column_index_from_string('J')

# Find the last row that has data in column I (ignore completely empty trailing rows)
max_row = ws.max_row
last_data_row = 1
for r in range(2, max_row + 1):
    if ws.cell(row=r, column=col_I).value is not None:
        last_data_row = r

print(f"Last row with data in column I: {last_data_row}")

# Write formula into column J for each row that has data in column I
for r in range(2, last_data_row + 1):
    # Only write if the source cell is not None (skip blank rows)
    src_val = ws.cell(row=r, column=col_I).value
    if src_val is not None:
        ws.cell(row=r, column=col_J).value = f"=I{r}"
    else:
        # Ensure blank rows stay blank
        ws.cell(row=r, column=col_J).value = None

# Save the modified workbook
