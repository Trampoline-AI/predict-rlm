import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine data extent
max_row = ws.max_row
max_col = ws.max_column

# Build the new formula for B26
# Use SUMPRODUCT with TEXT to compare month names
# Formula string (no leading "=" when assigning via openpyxl)
new_formula = f"=SUMPRODUCT((TEXT(C2:C{max_row},\"mmmm\")=A26)*(I2:I{max_row}))"

# Write the formula into B26
ws["B26"] = new_formula

# Save the modified workbook
wb.save(output_path)
print("Workbook saved with new formula to:", output_path)

# Recalculate formulas (LibreOffice backend)
from pathlib import Path
# The recalculate function is provided by the sandbox environment
result = await recalculate(output_path)
print("Recalculate result:", result)

# Reload the workbook with data_only to read computed values
