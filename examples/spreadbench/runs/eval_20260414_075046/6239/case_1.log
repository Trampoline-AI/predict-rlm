import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb_path = input_spreadsheet  # variable provided by the environment
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Dimensions: rows={max_row}, columns={max_col}")

    # Get headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Helper to extract a row as list of values
    def row_values(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]

    # Print first 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        print(r, row_values(r))

    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        print(r, row_values(r))

    # Detect any formulas in the first few rows
    print("Formulas in first 10 rows (if any):")
    for r in range(1, min(11, max_row+1)):
        for c in range(1, max_col+1):
            cell = ws.cell(row=r, column=c)
            if isinstance(cell.value, str) and cell.value.startswith("="):
                col_letter = get_column_letter(c)
                print(f"Cell {col_letter}{r}: {cell.value}")

print("\nExploration complete.")
```
