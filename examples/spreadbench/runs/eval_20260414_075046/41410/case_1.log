Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# 1. Add helper column E formulas for rows 3‑22
for r in range(3, 23):
    cell = ws.cell(row=r, column=column_index_from_string('E'))
    # Formula: =IF($B{r}="Lighting", COUNTIF($B$3:$B{r}, "Lighting"), "")
    cell.value = f"=IF($B{r}=\"Lighting\", COUNTIF($B$3:$B{r}, \"Lighting\"), \"\")"

# 2. Write target formulas in F4:H6 (rows 4‑6)
for target_row in range(4, 7):
    offset = target_row - 3  # 1,2,3 for the three lighting rows
    # Column F (Item)
    ws.cell(row=target_row, column=column_index_from_string('F')).value = (
        f"=IFERROR(INDEX($B$3:$B$22, MATCH({offset}, $E$3:$E$22, 0)), \"\")"
    )
    # Column G (kW rating)
    ws.cell(row=target_row, column=column_index_from_string('G')).value = (
        f"=IFERROR(INDEX($C$3:$C$22, MATCH({offset}, $E$3:$E$22, 0)), \"\")"
    )
    # Column H (Number)
    ws.cell(row=target_row, column=column_index_from_string('H')).value = (
        f"=IFERROR(INDEX($D$3:$D$22, MATCH({offset}, $E$3:$E$22, 0)), \"\")"
    )

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)
# Save workbook
wb.save(output_path)

# Recalculate formulas using the provided tool
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only=True to verify target cells
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("--- Verified target values (F4:H6) ---")
for r in range(4, 7):
    vals = [ws2.cell(row=r, column=column_index_from_string(col)).value for col in ['F','G','H']]
    print(f"Row {r} F:H =", vals)
