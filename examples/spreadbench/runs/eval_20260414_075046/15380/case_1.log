# 6. Look for columns named "codes2" and "month"
def find_column_by_header(name):
    for idx, hdr in enumerate(header, start=1):
        if isinstance(hdr, str) and hdr.strip().lower() == name.lower():
            return idx
    return None

codes2_col = find_column_by_header("codes2")
