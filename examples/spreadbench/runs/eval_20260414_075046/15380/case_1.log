# 2. Inspect first sheet (assume main data is there)
ws = wb[wb.sheetnames[0]]
print("\n--- Sheet:", ws.title, "---")

# 3. Determine header row (look for non‑empty cells in row 1)
header = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
print("Headers (row 1):", header)

# 4. Print first 5 data rows (row 2‑6) and last 5 rows
