import openpyxl
from openpyxl import load_workbook
import os

# Load the workbook (read-only is fine for inspection)
wb_path = input_spreadsheet
wb = load_workbook(wb_path, data_only=False)  # keep formulas

# Print sheet names
print("Sheet names:", wb.sheetnames)

# For each sheet, print row count, column count, and headers (first row)
for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Get headers from first row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers (row 1):", headers)

    # Sample first 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # Sample last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # Print current values of A1 and B2
    a1 = ws["A1"].value
    b2 = ws["B2"].value
    print(f"Current A1: {a1!r}")
    print(f"Current B2: {b2!r}")

# Close workbook (optional)
wb.close()
```
