import os
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook for editing
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming the target sheet is the active one

# Write formula into B2
formula = (
    "=IF(ISNUMBER(SEARCH(\"4Ozark\",A1)),1,"
    "IF(ISNUMBER(SEARCH(\"3Tall\",A1)),2,"
    "IF(ISNUMBER(SEARCH(\"1Jasper\",A1)),3,"
    "IF(ISNUMBER(SEARCH(\"2GWood\",A1)),4,"
    "IF(ISNUMBER(SEARCH(\"5Dawson\",A1)),5,"
    "IF(ISNUMBER(SEARCH(\"8CPark\",A1)),6,\"\")))))))"
)
ws["B2"].value = formula

# Save to output location
wb.save(output_path)
wb.close()

# Recalculate formulas
from __future__ import print_function
import asyncio

# The recalculate function is provided in the environment
await recalculate(output_path)

# Reload with data_only to read evaluated values
wb2 = load_workbook(output_path, data_only=True)
ws2 = wb2.active
b2_val = ws2["B2"].value
print("After recalculation, B2 =", b2_val)
wb2.close()
