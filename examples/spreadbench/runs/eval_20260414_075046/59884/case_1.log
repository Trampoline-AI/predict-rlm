Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_59884_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_59884_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming the relevant sheet is the first/only one

# Build groups: first_value -> list of (row_index, second_value)
groups = {}
for r in range(2, ws.max_row + 1):
    first = ws.cell(row=r, column=1).value
    second = ws.cell(row=r, column=2).value
    if first is None:
        continue
    groups.setdefault(first, []).append((r, second))

# Write consolidated results
for first_val, rows in groups.items():
    # Determine the first occurrence row (smallest row index)
    first_row = min(r for r, _ in rows)
    count = len(rows)
    second_vals = [sec for _, sec in rows]

    # Write to column 7 (index 7), column 8, then columns 9+
    ws.cell(row=first_row, column=7).value = first_val
    ws.cell(row=first_row, column=8).value = count
    for i, sec in enumerate(second_vals):
        ws.cell(row=first_row, column=9 + i).value = sec

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(str(output_path))

# Verify target cells (print a concise summary)
print("Verification:")
for first_val, rows in groups.items():
    first_row = min(r for r, _ in rows)
    count_cell = ws.cell(row=first_row, column=8).value
    secs = [ws.cell(row=first_row, column=9 + i).value for i in range(len(rows))]
    print(f"First={first_val} -> Count={count_cell}, Seconds={secs}")

# Reload with data_only to ensure formulas were evaluated (if any)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
# Print the same verification from the data‑only view
print("\nData‑only verification:")
for first_val, rows in groups.items():
    first_row = min(r for r, _ in rows)
    count_cell = ws_check.cell(row=first_row, column=8).value
    secs = [ws_check.cell(row=first_row, column=9 + i).value for i in range(len(rows))]
    print(f"First={first_val} -> Count={count_cell}, Seconds={secs}")
```
