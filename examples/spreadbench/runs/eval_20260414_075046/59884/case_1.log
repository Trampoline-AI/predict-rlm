import openpyxl
from openpyxl import load_workbook
from pathlib import Path

# Load the workbook (read-only is fine for inspection)
wb_path = Path("/sandbox/input/input_spreadsheet/1_59884_init.xlsx")
wb = load_workbook(wb_path, data_only=False)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Function to safely get cell value as string
def cell_str(cell):
    return "" if cell.value is None else str(cell.value)

# Iterate over sheets and print basic info
for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Print header row (assume first row is header)
    headers = [cell_str(ws.cell(row=1, column=c)) for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [cell_str(ws.cell(row=r, column=c)) for c in range(1, max_col+1)]
        print(f"{r}: {row_vals}")

    # Print last 5 data rows (if more than 6 rows total)
    if max_row > 6:
        print("Last 5 data rows:")
        for r in range(max_row-4, max_row+1):
            row_vals = [cell_str(ws.cell(row=r, column=c)) for c in range(1, max_col+1)]
            print(f"{r}: {row_vals}")
