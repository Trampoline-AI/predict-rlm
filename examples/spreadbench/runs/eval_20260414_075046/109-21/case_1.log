Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_109-21_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_109-21_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Define column indices (1‑based)
GROUP_COL = 2      # column B
POINTS_COL = 11    # column K
OUTPUT_COL = 26    # column Z (may be beyond current max column)

# Build group mapping: group_id -> list of (row, points)
group_rows = {}   # group_id -> list of (row_idx, points)
singleton_rows = []  # rows with no group id (or empty)
max_row = ws.max_row

for r in range(2, max_row + 1):
    # Skip completely empty rows (all cells None)
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    if all(v is None for v in row_vals):
        continue

    group_val = ws.cell(row=r, column=GROUP_COL).value
    points_val = ws.cell(row=r, column=POINTS_COL).value

    # If points are not numeric, treat as 0 for comparison (but still write N later)
    # We keep the original value for possible debugging.
    if group_val is None or (isinstance(group_val, str) and group_val.strip() == ""):
        # No group identifier → treat as singleton
        singleton_rows.append(r)
    else:
        # Use the raw group value as key (could be int, str, etc.)
        group_key = group_val
        group_rows.setdefault(group_key, []).append((r, points_val))

# Determine Y/N for each row
y_n_map = {}  # row -> "Y" or "N"

# Process groups
for grp, entries in group_rows.items():
    # Find max points in this group, ignoring None values
    # If all points are None, treat max as None and all get N (but spec says Y for singletons only)
    points_vals = [p for (_, p) in entries if isinstance(p, (int, float))]
    if not points_vals:
        # No numeric points → all N
        for r, _ in entries:
            y_n_map[r] = "N"
        continue
    max_points = max(points_vals)
    # Assign Y to any row whose points equal max (including ties)
    for r, p in entries:
        if isinstance(p, (int, float)) and p == max_points:
            y_n_map[r] = "Y"
        else:
            y_n_map[r] = "N"

# Singletons (no group id) get Y
for r in singleton_rows:
    y_n_map[r] = "Y"

# Write results into column Z (OUTPUT_COL)
for r, val in y_n_map.items():
    ws.cell(row=r, column=OUTPUT_COL, value=val)

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Reload workbook with data_only=True to inspect written values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Verify a few rows: print row number and column Z value
print("Verification of column Z (first 10 data rows with output):")
count = 0
for r in range(2, ws2.max_row + 1):
    cell_val = ws2.cell(row=r, column=OUTPUT_COL).value
    if cell_val is not None:
        print(f"Row {r}: {cell_val}")
        count += 1
        if count >= 10:
            break
