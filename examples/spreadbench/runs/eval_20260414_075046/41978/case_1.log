import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb = openpyxl.load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

# Assume the first sheet is the one we need
ws = wb[wb.sheetnames[0]]

# Determine max rows and columns
max_row = ws.max_row
max_col = ws.max_column
print(f"Sheet '{ws.title}' has {max_row} rows and {max_col} columns")

# Print column headers (assume first row is header)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Headers (row 1):", headers)

# Print first 10 data rows (rows 2-11)
print("First 10 data rows:")
for r in range(2, min(12, max_row+1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Print last 5 data rows
print("Last 5 data rows:")
for r in range(max_row-4, max_row+1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Check for merged cells in column I (column 9)
merged_in_I = []
for merged_range in ws.merged_cells.ranges:
    min_col, min_row, max_col, max_row = merged_range.bounds
    if min_col <= 9 <= max_col:
        merged_in_I.append(str(merged_range))
print("Merged cell ranges that include column I:", merged_in_I)

# Print a few cells from column G, J, I to see current values
