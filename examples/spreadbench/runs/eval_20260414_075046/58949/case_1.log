import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (keep formulas)
wb_path = "/sandbox/input/input_spreadsheet/1_58949_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

# Explore each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows (including header): {max_row}, Columns: {max_col}")

    # Get header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers (first 20 shown):", headers[:20])

    # Sample first 5 data rows (rows 2-6)
    print("\nFirst 5 data rows:")
    for r in range(2, min(2 + 5, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}:", row_vals[:20])

    # Sample last 5 data rows (if more than 6 rows total)
    if max_row > 6:
        print("\nLast 5 data rows:")
        start = max(2, max_row - 4)  # ensure we don't include header
        for r in range(start, max_row + 1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
            print(f"Row {r}:", row_vals[:20])

# Save workbook object for later steps
current_wb = wb
