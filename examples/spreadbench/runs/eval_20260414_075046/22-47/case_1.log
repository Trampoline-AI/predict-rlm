Code:
```repl
import openpyxl, os, textwrap, json
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["sheet1"]  # primary sheet

# ----------------------------------------------------------------------
# 1. Collect rows (row index, name, ref) skipping header and empty names
rows = []
for r in range(2, ws.max_row + 1):
    name = ws.cell(row=r, column=column_index_from_string("B")).value
    ref  = ws.cell(row=r, column=column_index_from_string("C")).value
    if name is None or (isinstance(name, str) and name.strip() == ""):
        continue  # skip empty/header rows
    rows.append((r, name, ref))

# ----------------------------------------------------------------------
# 2. Remove duplicates based on (name, ref), keep first occurrence
seen = set()
unique_rows = []
for r_idx, name, ref in rows:
    key = (name, ref)
    if key in seen:
        continue
    seen.add(key)
    unique_rows.append((r_idx, name, ref))

# ----------------------------------------------------------------------
# 3. Determine if helper column J has any non‑empty entries
helper_has_values = any(
    ws.cell(row=r, column=column_index_from_string("J")).value not in (None, "")
    for r, _, _ in unique_rows
)

# ----------------------------------------------------------------------
# 4. Sort according to the rule
if helper_has_values:
    # If J is non‑empty, we would need to prioritize those names.
    # For this dataset J is empty, so this block will not run.
    # (Implemented for completeness)
    # Build order list from J (preserve original order of appearance)
    helper_order = []
    for r in range(2, ws.max_row + 1):
        val = ws.cell(row=r, column=column_index_from_string("J")).value
        if isinstance(val, str) and val.strip():
            helper_order.append(val.strip())
    # Use helper order to assign a priority index; items not in helper get large index
    priority = {name: i for i, name in enumerate(helper_order)}
    def sort_key(item):
        _, name, _ = item
        return (priority.get(name, len(helper_order)),)  # keep original order within same priority
    sorted_rows = sorted(unique_rows, key=sort_key)
else:
    # Fallback: alphabetical sort by name (case‑insensitive)
    sorted_rows = sorted(unique_rows, key=lambda x: str(x[1]).lower())

# ----------------------------------------------------------------------
# 5. Write output into column G (NAME) and H (RANK)
# Clear existing data in G and H from row 2 down to max_row to avoid leftovers
for r in range(2, ws.max_row + 1):
    ws.cell(row=r, column=column_index_from_string("G")).value = None
    ws.cell(row=r, column=column_index_from_string("H")).value = None

# Write sorted data
for idx, (_, name, _) in enumerate(sorted_rows, start=1):
    out_row = idx + 1  # start at row 2
    ws.cell(row=out_row, column=column_index_from_string("G")).value = name
    ws.cell(row=out_row, column=column_index_from_string("H")).value = idx  # rank

# ----------------------------------------------------------------------
# 6. Save, recalculate, reload, and verify
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to see computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["sheet1"]

# Verify a few target cells
print("\nVerification (first 10 rows of G and H):")
for r in range(2, min(12, ws_check.max_row + 1)):
    name_val = ws_check.cell(row=r, column=column_index_from_string("G")).value
    rank_val = ws_check.cell(row=r, column=column_index_from_string("H")).value
    print(f"Row {r}: G={name_val!r}, H={rank_val}")

# Also print total count of written rows
written_rows = sum(1 for r in range(2, ws_check.max_row + 1) if ws_check.cell(row=r, column=column_index_from_string("G")).value is not None)
print("\nTotal written rows in G:", written_rows)
```
