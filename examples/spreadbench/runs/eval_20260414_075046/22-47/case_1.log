Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os, textwrap

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["sheet1"]  # primary sheet

# ----------------------------------------------------------------------
# 1. Gather helper names from column J (non‑empty, stripped)
helper_names = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=column_index_from_string("J")).value
    if isinstance(val, str) and val.strip():
        helper_names.append(val.strip())
helper_set = set(helper_names)  # for quick membership test

# ----------------------------------------------------------------------
# 2. Scan rows, skip empties & header, remove duplicates (B,C)
seen_keys = set()
helper_rows = []   # (name, ref)
other_rows = []    # (name, ref)

for r in range(2, ws.max_row + 1):
    name = ws.cell(row=r, column=column_index_from_string("B")).value
    ref  = ws.cell(row=r, column=column_index_from_string("C")).value

    # Skip completely empty rows
    if name is None:
        continue
    # Skip header rows where B='NAME' and C='REF' (case‑sensitive as seen)
    if isinstance(name, str) and name.strip() == "NAME" and ref == "REF":
        continue
    # Skip cells that are empty strings or whitespace
    if isinstance(name, str) and name.strip() == "":
        continue

    key = (name, ref)
    if key in seen_keys:
        continue  # duplicate, keep first only
    seen_keys.add(key)

    # Decide group based on helper presence
    if isinstance(name, str) and name.strip() in helper_set:
        helper_rows.append((name, ref))
    else:
        other_rows.append((name, ref))

# ----------------------------------------------------------------------
# 3. Combine groups: helper rows first (preserve order), then others
combined = helper_rows + other_rows

# ----------------------------------------------------------------------
# 4. Clear previous output in columns G and H (from row 2 to max_row)
for r in range(2, ws.max_row + 1):
    ws.cell(row=r, column=column_index_from_string("G")).value = None
    ws.cell(row=r, column=column_index_from_string("H")).value = None

# ----------------------------------------------------------------------
# 5. Write sorted names to G and rank to H (starting at row 2)
for idx, (name, _) in enumerate(combined, start=1):
    out_row = idx + 1  # row 2 corresponds to idx=1
    ws.cell(row=out_row, column=column_index_from_string("G")).value = name
    ws.cell(row=out_row, column=column_index_from_string("H")).value = idx

# ----------------------------------------------------------------------
# 6. Save, recalculate, reload (data_only) and verify
wb.save(output_path)

# Recalculate formulas (if any)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to see computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["sheet1"]

print("\nVerification – first 12 rows of G and H:")
for r in range(2, min(14, ws_check.max_row + 1)):
    g_val = ws_check.cell(row=r, column=column_index_from_string("G")).value
    h_val = ws_check.cell(row=r, column=column_index_from_string("H")).value
    print(f"Row {r}: G={g_val!r}, H={h_val}")

# Count total written rows in G
total_written = sum(
    1 for r in range(2, ws_check.max_row + 1)
    if ws_check.cell(row=r, column=column_index_from_string("G")).value is not None
)
print("\nTotal written rows in G:", total_written)
```
