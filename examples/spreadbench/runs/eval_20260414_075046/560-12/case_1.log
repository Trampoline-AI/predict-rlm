Code:
```repl
import openpyxl
from openpyxl.styles import Alignment
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_560-12_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine data range for ITEM column (B). Data starts at row 2.
first_data_row = 2
last_data_row = ws.max_row
item_col = 2  # B

# Write headers at I3 (col 9) and J3 (col 10)
ws.cell(row=3, column=9, value="ITEM")
ws.cell(row=3, column=10, value="Qty")

# Custom order of items
items_order = ["A006", "A004", "A005"]

# Write items and COUNTIF formulas
for idx, code in enumerate(items_order, start=4):  # start at row 4
    ws.cell(row=idx, column=9, value=code)  # ITEM column
    # Build COUNTIF formula referencing column B range
    formula = f"=COUNTIF($B${first_data_row}:$B${last_data_row}, \"{code}\")"
    ws.cell(row=idx, column=10, value=formula)

# Left align the whole output block (I3:J6)
left_align = Alignment(horizontal="left")
for r in range(3, 3 + len(items_order) + 1):  # rows 3 to 6
    for c in (9, 10):
        ws.cell(row=r, column=c).alignment = left_align

# Ensure output directory exists
import os
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of output cells:")
for r in range(3, 7):
    print(f"Row {r}: ITEM={ws_check.cell(r,9).value}, Qty={ws_check.cell(r,10).value}")
```
