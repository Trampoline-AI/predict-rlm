import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_341-40_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_341-40_init.xlsx")

# Load workbook (write mode)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Column indices
col_a = column_index_from_string('A')
col_b = column_index_from_string('B')
col_c = column_index_from_string('C')
col_q = column_index_from_string('Q')

updated = 0
rows_filled = []

# Iterate over data rows
for r in range(2, ws.max_row + 1):
    val_a = ws.cell(row=r, column=col_a).value
    val_b = ws.cell(row=r, column=col_b).value
    val_c = ws.cell(row=r, column=col_c).value
    val_q = ws.cell(row=r, column=col_q).value

    # Check conditions (case‑sensitive as per sample data)
    if val_a == "Government" and val_b == "Germany" and val_c == "Carretera":
        if not val_q:  # empty or None
            ws.cell(row=r, column=col_q).value = "Volkswagen"
            updated += 1
            rows_filled.append(r)

print(f"Rows updated: {updated}")
print(f"Rows filled: {rows_filled[:10]}{'...' if len(rows_filled)>10 else ''}")

# Save to output location
wb.save(output_path)

# Recalculate formulas (none expected, but required by workflow)
await recalculate(output_path)

# Verify by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Print a few verification rows (including one that should have been filled)
print("\nVerification of target rows:")
for r in rows_filled[:5]:  # first few filled rows
    print(f"Row {r} Q value:", ws_check.cell(row=r, column=col_q).value)

# Also verify a row that meets conditions but already had a value (row 3)
print("Row 3 Q value (should already be Volkswagen):", ws_check.cell(row=3, column=col_q).value)
```
