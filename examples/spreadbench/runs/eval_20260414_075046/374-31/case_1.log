1. Load the workbook from the provided path.
2. Locate the first row where column A equals "Code".
3. Scan rows 2 up to (code_row – 1) and collect indices of rows that are completely empty.
4. Delete those rows from the worksheet, iterating from bottom to top to keep indices stable.
5. Save the modified workbook to the output directory with the same filename.
6. Call `recalculate` on the saved file, then reload it (data_only) to verify that the sheet still exists and that no target cells are unexpectedly empty.
7. Finally, submit the path to the output spreadsheet.

The code below follows these steps, using openpyxl for manipulation and the provided `recalculate` async function.
Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Process each sheet (the instruction seems to apply to the main data sheet)
for ws in wb.worksheets:
    # Find the first row where column A contains exactly "Code"
    code_row = None
    for r in range(1, ws.max_row + 1):
        val = ws.cell(row=r, column=1).value
        if isinstance(val, str) and val.strip() == "Code":
            code_row = r
            break

    if code_row is None:
        # No "Code" found; nothing to do on this sheet
        continue

    # Identify completely empty rows above the Code row (excluding header row if any)
    rows_to_delete = []
    for r in range(2, code_row):  # start at row 2 assuming row 1 may be header
        # Check if all cells in the row are None
        is_empty = True
        for c in range(1, ws.max_column + 1):
            if ws.cell(row=r, column=c).value is not None:
                is_empty = False
                break
        if is_empty:
            rows_to_delete.append(r)

    # Delete rows from bottom to top to keep indices correct
    for r in sorted(rows_to_delete, reverse=True):
        ws.delete_rows(r, amount=1)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Reload to verify (data_only to get cached values)
wb_verified = openpyxl.load_workbook(output_path, data_only=True)

# Simple verification: ensure the sheet still exists and print its row count
for name in wb_verified.sheetnames:
    ws = wb_verified[name]
    print(f"Verified sheet '{name}': rows={ws.max_row}, columns={ws.max_column}")

# Submission
SUBMIT(output_spreadsheet=output_path)
