        if isinstance(c_val, (int, float)):
            imp_sum += c_val
        if isinstance(d_val, (int, float)):
            exp_sum += d_val
    sheet_sums[ws.title] = (imp_sum, exp_sum)

# ---------------------------------------------------------------------------
