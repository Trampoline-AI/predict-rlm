# Gather sheet info
sheet_info = {}
for ws in wb.worksheets:
    # Determine header row (assume first row)
    header = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    # Sample first 5 rows (excluding header)
    first_rows = []
    for r in range(2, min(ws.max_row, 6)+1):
