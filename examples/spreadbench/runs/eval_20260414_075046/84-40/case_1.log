```repl
import os, openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_84-40_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_84-40_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Locate the LIST sheet (case‑insensitive)
list_ws = None
for ws in wb.worksheets:
    if ws.title.lower() == "list":
        list_ws = ws
        break
if list_ws is None:
    raise RuntimeError("No sheet named 'list' (case‑insensitive) found in the workbook")

# ---------------------------------------------------------------------------
# 1️⃣ Compute sums for every sheet except the LIST sheet
# ---------------------------------------------------------------------------
sheet_sums = {}
for ws in wb.worksheets:
    if ws.title.lower() == "list":
        continue
    imp_sum = 0
    exp_sum = 0
    # Assume header is row 1, data starts at row 2
    for r in range(2, ws.max_row + 1):
        c_val = ws.cell(row=r, column=3).value  # column C
        d_val = ws.cell(row=r, column=4).value  # column D
        if isinstance(c_val, (int, float)):
            imp_sum += c_val
        if isinstance(d_val, (int, float)):
            exp_sum += d_val
    sheet_sums[ws.title] = (imp_sum, exp_sum)

# ---------------------------------------------------------------------------
# 2️⃣ Write results into the LIST sheet
# ---------------------------------------------------------------------------
# Helper: map existing sheet names in column B to their row numbers (skip the TOTAL row)
name_to_row = {}
for r in range(2, list_ws.max_row + 1):
    name_cell = list_ws.cell(row=r, column=2).value
    if isinstance(name_cell, str) and name_cell.upper() != "TOTAL":
        name_to_row[name_cell] = r

# Determine where to place new rows (first empty row before the TOTAL row)
# Find the row that contains the word TOTAL in column B, if any
 = None
for r in range(2, list_ws.max_row + 1):
    if list_ws.cell(row=r, column=2).value == "TOTAL":
        total_row = r
        break

# Write each sheet's totals
for sheet_name, (imp_total, exp_total) in sheet_sums.items():
    if sheet_name in name_to_row:
        row = name_to_row[sheet_name]
    else:
        # Insert a new row just before the TOTAL row (or at the end if no TOTAL)
        insert_at = total_row if total_row is not None else list_ws.max_row + 1
        list_ws.insert_rows(insert_at)
        row = insert_at
        # After insertion, shift the TOTAL row index down by one if it existed
        if total_row is not None and insert_at <= total_row:
            total_row += 1
        # Write the sheet name into column B
        list_ws.cell(row=row, column=2).value = sheet_name
    # Write import and export totals
    list_ws.cell(row=row, column=3).value = imp_total
    list_ws.cell(row=row, column=4).value = exp_total
    # Write balance formula (C - D) in column E
    list_ws.cell(row=row, column=5).value = f"=C{row}-D{row}"

# ---------------------------------------------------------------------------
# 3️⃣ Save the workbook and trigger recalculation
# ---------------------------------------------------------------------------
wb.save(output_path)

# Recalculate formulas using the provided async helper
await recalculate(output_path)

# ---------------------------------------------------------------------------
# 4️⃣ Verify the written values (load in data_only mode)
# ---------------------------------------------------------------------------
verify_wb = openpyxl.load_workbook(output_path, data_only=True)
verify_ws = verify_wb[verify_ws.title]  # keep the same sheet name
print("--- Verification of LIST sheet (row, sheet name, IMPORT, EXPORT, BALANCE) ---")
for r in range(2, verify_ws.max_row + 1):
    name = verify_ws.cell(row=r, column=2).value
    imp = verify_ws.cell(row=r, column=3).value
    exp = verify_ws.cell(row=r, column=4).value
    bal = verify_ws.cell(row=r, column=5).value
    # Skip completely empty rows (except the TOTAL row which we still want to see)
    if name is None and imp is None and exp is None and bal is None:
        continue
    print(r, name, imp, exp, bal)
