    start = max(2, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        last_rows.append([ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)])
    sheet_info[ws.title] = {
        "max_row": ws.max_row,
        "max_column": ws.max_column,
        "header": header,
        "first_rows": first_rows,
        "last_rows": last_rows,
    }

# Print summary
print("Sheets found:", list(sheet_info.keys()))
for name, info in sheet_info.items():
    print(f"\nSheet: {name}")
    print("Rows:", info["max_row"], "Columns:", info["max_column"])
    print("Header:", info["header"])
    print("First rows:", info["first_rows"])
    print("Last rows:", info["last_rows"])

# Check if 'list' sheet exists and its current data in columns B-E
