    ws_list = wb["list"]
    list_header = [ws_list.cell(row=1, column=c).value for c in range(1, ws_list.max_column+1)]
    print("\n'list' sheet header:", list_header)
    # Show first few rows of columns B-E
    rows = []
    for r in range(2, min(ws_list.max_row, 6)+1):
        rows.append([ws_list.cell(row=r, column=c).value for c in range(2, 6)])  # B-E
    print("First rows B-E in 'list':", rows)
else:
    print("\n'list' sheet not found.")
