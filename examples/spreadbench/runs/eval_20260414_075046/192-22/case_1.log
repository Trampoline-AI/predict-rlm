# 2. For each sheet, report dimensions and headers
for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{name}': max_row={max_row}, max_col={max_col}")

    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Sample first 10 rows (excluding header)
