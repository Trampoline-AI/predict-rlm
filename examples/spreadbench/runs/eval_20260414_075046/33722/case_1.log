Code:
```repl
import os
import openpyxl
from openpyxl.utils import column_index_from_string
from openpyxl.styles import Alignment, Border, Side, NamedStyle
from openpyxl.styles.numbers import FORMAT_NUMBER

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_33722_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_33722_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (write mode)
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume single sheet

# Determine the last data row (we saw max_row = 12 in exploration)
max_row = ws.max_row

# Define border style
thin = Side(border_style='thin', color='000000')
border = Border(left=thin, right=thin, top=thin, bottom=thin)

# Apply formatting and formula to rows 2‑6 in column E
for r in range(2, 7):
    # Build the array formula string.
    # It filters rows from current row r down to max_row where percentile (col C) is between 0 and 0.01.
    # Then takes the median of the corresponding market caps (col B).
    # The formula is entered as a CSE array formula; LibreOffice will evaluate it correctly.
    formula = f"=MEDIAN(IF((C{r}:C${max_row}>=0)*(C{r}:C${max_row}<=0.01),B{r}:B${max_row}))"
    cell = ws.cell(row=r, column=column_index_from_string('E'))
    cell.value = formula
    # Number format: integer, no commas, no decimals
    cell.number_format = FORMAT_NUMBER
    # Alignment left
    cell.alignment = Alignment(horizontal='left')
    # Thin border on all sides
    cell.border = border

# Save to output location
wb.save(output_path)

# Recalculate formulas using the provided helper
await recalculate(output_path)

# Reload with data_only to verify values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print('Verified values in E2:E6 after recalculation:')
for r in range(2, 7):
    print(f"E{r} = {ws_check.cell(row=r, column=column_index_from_string('E')).value}")
```
