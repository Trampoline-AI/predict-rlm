import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb = openpyxl.load_workbook(input_spreadsheet)

print("Workbook loaded.")
print("Sheet names:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (assumed row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # First 5 data rows (rows 2-6)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}:", row_vals)

    # Last 5 data rows
    start_last = max(2, max_row - 4)
    print("Last 5 data rows:")
    for r in range(start_last, max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}:", row_vals)

