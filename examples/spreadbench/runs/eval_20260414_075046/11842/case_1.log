  COUNTIFS(Jul!$A$6:$A$49,$O$3,Jul!$B$6:$AF$49,"P"),
  COUNTIFS(Aug!$A$6:$A$49,$O$3,Aug!$B$6:$AF$49,"P"),
  COUNTIFS(Sep!$A$6:$A$49,$O$3,Sep!$B$6:$AF$49,"P"),
  COUNTIFS(Oct!$A$6:$A$49,$O$3,Oct!$B$6:$AF$49,"P"),
