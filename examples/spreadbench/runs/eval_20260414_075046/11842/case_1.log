This formula uses **COUNTIFS** to count “P” cells in each month where the name column (A) matches the name chosen in O3, then sums the counts across all months.  
We will write this formula into column 27 (AA) for every data row (rows 5 to `max_row`). After saving, we will call `recalculate()` and verify a few cells.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_11842_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_11842_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Ensure Total sheet exists
if "Total" not in wb.sheetnames:
    raise ValueError("Total sheet not found")

total_ws = wb["Total"]

# Determine data rows (starting at row 5, as observed)
start_row = 5
max_row = total_ws.max_row

# Target column index (27 -> AA)
target_col_idx = 27
target_col_letter = get_column_letter(target_col_idx)

# Build the formula string (same for every row)
months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
# Use the same row range for all months (rows 6 to 49 as seen in month sheets)
name_range = "$A$6:$A$49"
day_range = "$B$6:$AF$49"
criteria_name = "$O$3"
criteria_present = "\"P\""

parts = []
for m in months:
    part = f"COUNTIFS({m}!{name_range},{criteria_name},{m}!{day_range},{criteria_present})"
    parts.append(part)
formula = f"=SUM({', '.join(parts)})"

# Write formula to each data row in column AA
for r in range(start_row, max_row + 1):
    cell = total_ws.cell(row=r, column=target_col_idx)
    cell.value = formula

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice + formulas library)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to verify a few rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Total"]
print("Sample totals after recalculation:")
for r in range(start_row, min(start_row+5, max_row+1)):
    val = ws_check.cell(row=r, column=target_col_idx).value
    print(f"Row {r} total:", val)
```
