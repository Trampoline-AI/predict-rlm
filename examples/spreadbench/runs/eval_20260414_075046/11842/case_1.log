import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_11842_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_11842_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Verify required sheets exist
required_sheets = ["Total"] + ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
for s in required_sheets:
    if s not in wb.sheetnames:
        raise ValueError(f"Missing sheet: {s}")

total_ws = wb["Total"]
months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]

# -------------------------------------------------
# 1. Compute per‑person present counts across all months
# -------------------------------------------------
# Initialize a dict for each person we will encounter
person_counts = {}

# Scan month sheets to collect names and count "P"
for month in months:
    ws = wb[month]
    # rows 6‑49 contain attendance data (as observed)
    for r in range(6, 50):
        name = ws.cell(row=r, column=1).value
        if not isinstance(name, str):
            continue
        name = name.strip()
        # Ensure entry exists
        if name not in person_counts:
            person_counts[name] = 0
        # Count "P" in columns B‑AF (columns 2‑32)
        p_cnt = 0
        for c in range(2, 33):
            val = ws.cell(row=r, column=c).value
            if isinstance(val, str) and val.strip().upper() == "P":
                p_cnt += 1
        person_counts[name] += p_cnt

# -------------------------------------------------
# 2. Map each name to its row in the Total sheet
# -------------------------------------------------
# Data rows in Total start at row 5 (observed)
start_row = 5
max_row = total_ws.max_row

# Use the Jan sheet to retrieve the name for each Total row
jan_ws = wb["Jan"]
name_to_row = {}
for r in range(start_row, max_row + 1):
    # The formula in Total!A{r} points to Jan!A{r+1}
    name = jan_ws.cell(row=r + 1, column=1).value
    if isinstance(name, str):
        name_to_row[name.strip()] = r

# -------------------------------------------------
# 3. Write yearly totals into column AA (index 27)
# -------------------------------------------------
target_col_idx = 27  # Column AA
for name, row in name_to_row.items():
    total = person_counts.get(name, 0)
    total_ws.cell(row=row, column=target_col_idx).value = total

# -------------------------------------------------
# 4. Save, recalculate, and verify
# -------------------------------------------------
wb.save(output_path)

# Recalculate formulas using LibreOffice (and fallback library)
recalc_res = await recalculate(output_path)
print("Recalculate result:", recalc_res)

# Reload with data_only=True to read the cached numeric totals
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Total"]
print("Sample totals (column AA) after recalculation:")
for r in range(start_row, min(start_row + 5, max_row + 1)):
    val = ws_check.cell(row=r, column=target_col_idx).value
    print(f"Row {r}: {val}")

# -------------------------------------------------
# 5. Submit the output workbook
# -------------------------------------------------
SUBMIT(output_spreadsheet=output_path)
