import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_11842_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sheet summary
def print_sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {ws.title}")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Print header (first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(row_vals)

    # Print last 5 data rows
    if max_row > 6:
        print("Last 5 data rows:")
        start = max(2, max_row-4)
        for r in range(start, max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(row_vals)

# Iterate sheets
for ws in wb.worksheets:
    print_sheet_summary(ws)

# Print the value of O3 in the Total sheet (if exists)
if "Total" in wb.sheetnames:
    total_ws = wb["Total"]
    o3_val = total_ws["O3"].value
    print("\nValue of O3 in Total sheet:", o3_val)
else:
    print("\nNo sheet named 'Total' found.")
