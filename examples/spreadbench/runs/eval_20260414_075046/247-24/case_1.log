for r in range(2, ws_check.max_row + 1):
    if ws_check.cell(row=r, column=3).value == 1111:
        sample_row = r
        break
if sample_row:
    print(f"Row {sample_row} (Employee ID 1111) Column M value:", ws_check.cell(row=sample_row, column=13).value)
else:
    print("Employee ID 1111 not found after processing.")
