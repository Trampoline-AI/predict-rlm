import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_247-24_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_247-24_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb["Main"]
lookup_ws = wb["Lookup"]

# ---------- Step 1: Deletions & Bill Rate change ----------
# Iterate from bottom to top to safely delete rows
for row in range(ws.max_row, 1, -1):  # skip header row 1
    company = ws.cell(row=row, column=1).value  # Column A
    location = ws.cell(row=row, column=2).value  # Column B

    # 1) Delete rows where Company == 'Motorcycle'
    if company == "Motorcycle":
        ws.delete_rows(row, 1)
        continue  # row is removed, move to next iteration

    # 2) Delete rows where Company == 'Ahmed Sons' and Location == 'Canada'
    if company == "Ahmed Sons" and location == "Canada":
        ws.delete_rows(row, 1)
        continue

    # 3) Change Bill Rate of Resource (Column G) to 180 for National TV & India
    if company == "National TV" and location == "India":
        ws.cell(row=row, column=7).value = 180  # Column G

# ---------- Step 2: Insert two blank rows after each 'Ahmed Sons' ----------
# After deletions, gather rows that need insertion
ahmed_rows = []
for row in range(2, ws.max_row + 1):
    if ws.cell(row=row, column=1).value == "Ahmed Sons":
        ahmed_rows.append(row)

# Insert rows, accounting for shifting indices
offset = 0
for base_row in ahmed_rows:
    insert_at = base_row + 1 + offset  # first blank row
    ws.insert_rows(insert_at, 2)      # insert two rows at once
    offset += 2  # subsequent insertions need to be shifted

# ---------- Step 3: Populate Column M with VLOOKUP ----------
# Determine the new max row after insertions
max_row = ws.max_row
for row in range(2, max_row + 1):
    # Write VLOOKUP formula referencing the Lookup sheet
    formula = f'=VLOOKUP(C{row},Lookup!A:B,2,FALSE)'
    ws.cell(row=row, column=13).value = formula  # Column M is 13

# Save workbook
wb.save(output_path)

# ---------- Step 4: Recalculate formulas ----------
# Use the provided async recalculate function
await recalculate(output_path)

# Reload with data_only to verify a few cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Main"]

# Verification prints (will be shown to the user)
print("Verification after processing:")
print(f"Total rows now (including header): {ws_check.max_row}")
# Show a few rows around the first Ahmed Sons block
for r in range(2, min(12, ws_check.max_row + 1)):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, 14)]
    print(r, row_vals)

# Show a sample VLOOKUP result for a known Employee ID (e.g., 1111)
