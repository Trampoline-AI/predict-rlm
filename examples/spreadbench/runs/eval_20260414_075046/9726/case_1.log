Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.worksheet.formula import ArrayFormula
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet named Sheet1

# Determine the last row that contains Table 1 data (non‑empty Student ID in column A)
max_row_table1 = 0
for r in range(ws.max_row, 0, -1):
    if ws.cell(row=r, column=1).value is not None:
        max_row_table1 = r
        break
if max_row_table1 == 0:
    raise ValueError("Could not locate any data in Table 1 (column A).")

# Build absolute range strings for Table 1 columns
visit_date_range = f"$C$2:$C${max_row_table1}"
student_id_range = f"$A$2:$A${max_row_table1}"

# Iterate over rows to populate Table 2 Visit date (column J = 10)
for r in range(2, ws.max_row + 1):
    student_id_cell = ws.cell(row=r, column=8)   # column H
    submission_cell = ws.cell(row=r, column=9)   # column I
    target_cell = ws.cell(row=r, column=10)      # column J

    # Only act on rows that have a Table 2 Student ID
    if student_id_cell.value is None:
        continue

    # If the target already has a proper date, skip; otherwise write formula
    if target_cell.value is not None and not isinstance(target_cell.value, ArrayFormula):
        # Assume it's already a valid value
        continue

    # Build the row‑specific formula using MAXIFS (LibreOffice requires _xlfn. prefix)
    formula = (
        f"=_xlfn.MAXIFS({visit_date_range},{student_id_range},$H{r},"
        f"{visit_date_range},"<"&$I{r})"
    )
    target_cell.value = formula

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save the workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only=True to verify a few cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification of first few Table 2 Visit dates (column J):")
for r in range(2, min(7, ws_check.max_row + 1)):
    sid = ws_check.cell(r, 8).value
    sub = ws_check.cell(r, 9).value
    visit = ws_check.cell(r, 10).value
    print(f"Row {r}: Student {sid}, Submission {sub}, Visit date (filled) {visit}")
```
