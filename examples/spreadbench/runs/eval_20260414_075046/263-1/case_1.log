The task is to compute, for each distinct material type, the total area = Σ(Width × Height) across all rows, and write the summary into columns 7‑9 starting at row 2 (right below the header).  
We will:
1. Load the workbook (preserving formulas).  
2. Scan rows 2‑max_row, calculate the per‑material totals.  
3. Write the summary: material name → column 7, total area → column 8, `"sqf"` → column 9.  
4. Save the file to the output directory with the same filename.  
5. Call `recalculate()` so LibreOffice evaluates any formulas (none needed for the summary, but required by the workflow).  
6. Reload the saved file with `data_only=True` and print the written summary rows to verify.
Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet as inspected

# Determine data extent
max_row = ws.max_row
max_col = ws.max_column

# Identify columns (1‑indexed)
col_mtrl = 1   # 'Mtrl'
col_width = 2  # 'Width'
col_height = 3 # 'Height'

# Columns for output (as observed)
col_out_mat = 7   # material name
col_out_total = 8 # total area
col_out_unit = 9  # unit label ('sqf')

# Compute totals per material, preserving order of first appearance
totals = {}
order = []  # to keep insertion order
for r in range(2, max_row + 1):
    mat = ws.cell(row=r, column=col_mtrl).value
    width = ws.cell(row=r, column=col_width).value
    height = ws.cell(row=r, column=col_height).value
    # Skip rows where any needed value is missing or not numeric
    if mat is None or width is None or height is None:
        continue
    try:
        area = float(width) * float(height)
    except Exception:
        continue
    if mat not in totals:
        totals[mat] = 0.0
        order.append(mat)
    totals[mat] += area

# Write summary starting at row 2, column 7‑9
start_row = 2
for i, mat in enumerate(order):
    row = start_row + i
    ws.cell(row=row, column=col_out_mat).value = mat
    ws.cell(row=row, column=col_out_total).value = totals[mat]
    ws.cell(row=row, column=col_out_unit).value = "sqf"

# Clear any leftover rows beyond the summary (optional, keep clean)
# Determine last summary row
last_summary_row = start_row + len(order) - 1
for r in range(last_summary_row + 1, max_row + 1):
    ws.cell(row=r, column=col_out_mat).value = None
    ws.cell(row=r, column=col_out_total).value = None
    ws.cell(row=r, column=col_out_unit).value = None

# Save to output path
wb.save(output_path)

# Recalculate formulas (required by workflow)
await recalculate(output_path)

# Verify by reloading data_only and printing the summary rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("\n--- Verification: Summary rows written ---")
for i, mat in enumerate(order):
    r = start_row + i
    mat_val = ws_check.cell(row=r, column=col_out_mat).value
    total_val = ws_check.cell(row=r, column=col_out_total).value
    unit_val = ws_check.cell(row=r, column=col_out_unit).value
    print(f"Row {r}: {mat_val} | {total_val} | {unit_val}")

# Also print a few rows after the summary to ensure they are cleared
if last_summary_row + 1 <= ws_check.max_row:
    print("\nRows after summary (should be empty):")
    for r in range(last_summary_row + 1, min(last_summary_row + 5, ws_check.max_row) + 1):
        print(r, [ws_check.cell(row=r, column=c).value for c in (col_out_mat, col_out_total, col_out_unit)])
```
