```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet  # variable provided by the environment
wb = openpyxl.load_workbook(wb_path, data_only=False)  # load formulas as they are

print("Workbook loaded from:", wb_path)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Iterate over sheets and inspect
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Get headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Function to get row values as list
    def row_values(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]

    # Print first 5 data rows (excluding header)
    first_rows = min(5, max_row - 1)
    print(f"First {first_rows} data rows:")
    for r in range(2, 2 + first_rows):
        print(r, row_values(r))

    # Print last 5 data rows
    last_rows = min(5, max_row - 1)
    if last_rows > 0:
        print(f"Last {last_rows} data rows:")
        for r in range(max_row - last_rows + 1, max_row + 1):
            print(r, row_values(r))

# Print the instruction for reference
print("\nInstruction:")
print(instruction)
