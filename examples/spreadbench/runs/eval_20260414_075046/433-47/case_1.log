        if val is None:
            continue
        # Preserve zero cells
        if val == 0:
            continue
        # Clamp to max
        if max_vals[col] is not None and val > max_vals[col]:
            cell.value = max_vals[col]
            val = max_vals[col]
        # Clamp to min
        if min_vals[col] is not None and val < min_vals[col]:
            cell.value = min_vals[col]
            val = min_vals[col]

    # ---- Step 2: Balance residual ----
    residual = ws.cell(row=r, column=residual_col).value
    if residual is None:
        continue
    try:
        residual = float(residual)
