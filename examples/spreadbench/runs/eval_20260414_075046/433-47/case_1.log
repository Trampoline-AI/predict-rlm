import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_433-47_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_433-47_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Identify column indices for units and residuals
unit_cols = [2, 3, 4, 5, 6]          # B, C, D, E, F
residual_col = 9                    # I

# Read min and max rows (rows 20 and 21)
min_row = 20
max_row = 21
min_vals = {}
max_vals = {}
for col in unit_cols:
    min_vals[col] = ws.cell(row=min_row, column=col).value
    max_vals[col] = ws.cell(row=max_row, column=col).value

# Process data rows (2 through 18, inclusive)
for r in range(2, 19):  # row 19 is empty, stop before min/max rows
    # Skip rows that are label rows (e.g., if column A contains text)
    label = ws.cell(row=r, column=1).value
    if isinstance(label, str) and label.lower() in ("min", "max"):
        continue

    residual = ws.cell(row=r, column=residual_col).value
    if residual is None:
        continue  # nothing to do

    # Ensure residual is numeric
    try:
        residual = float(residual)
    except (TypeError, ValueError):
        continue

    # Positive residual: need to add to units (1→5)
    if residual > 0:
        for col in unit_cols:  # forward order
            cell = ws.cell(row=r, column=col)
            cur = cell.value
            if cur is None:
                cur = 0
            # Do not modify zero cells
            if cur == 0:
                continue
            max_allowed = max_vals[col]
            # Compute how much we can add without exceeding max
            addable = max_allowed - cur
            if addable <= 0:
                continue
            add_amount = min(residual, addable)
            cell.value = cur + add_amount
            residual -= add_amount
            if abs(residual) < 1e-9:  # residual balanced
                break

    # Negative residual: need to subtract from units (5→1)
    elif residual < 0:
        for col in reversed(unit_cols):  # reverse order
            cell = ws.cell(row=r, column=col)
            cur = cell.value
            if cur is None:
                cur = 0
            # Do not modify zero cells
            if cur == 0:
                continue
            min_allowed = min_vals[col]
            # Compute how much we can subtract without dropping below min
            subtrahable = cur - min_allowed
            if subtrahable <= 0:
                continue
            sub_amount = min(-residual, subtrahable)
            cell.value = cur - sub_amount
            residual += sub_amount
            if abs(residual) < 1e-9:
                break

    # After adjustments, set residual cell to 0
    ws.cell(row=r, column=residual_col).value = 0

# Ensure all residual cells (including any beyond data rows) are 0
for r in range(2, ws.max_row + 1):
    ws.cell(row=r, column=residual_col).value = 0

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
from await recalculate
await recalculate(output_path)

# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Verify residuals are zero and unit values respect min/max
issues = []
for r in range(2, 19):
    resid = ws_check.cell(row=r, column=residual_col).value
    if resid not in (0, 0.0):
        issues.append(f"Row {r} residual not zero: {resid}")
    for col in unit_cols:
        val = ws_check.cell(row=r, column=col).value
        if val is None:
            continue
        if val < min_vals[col] - 1e-9 or val > max_vals[col] + 1e-9:
            issues.append(f"Row {r} col {col} value {val} out of bounds [{min_vals[col]}, {max_vals[col]}]")

print("Verification issues:", issues if issues else "None")
