import openpyxl
from openpyxl.utils import get_column_letter

# Load the input spreadsheet
input_path = "/sandbox/input/input_spreadsheet/1_35739_init.xlsx"
wb = openpyxl.load_workbook(input_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Focus on Sheet1 (as referenced in instruction)
ws = wb["Sheet1"]

# Determine dimensions
max_row = ws.max_row
max_col = ws.max_column
print(f"Sheet1 dimensions: rows={max_row}, cols={max_col}")

# Print header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Header row:", headers)

# Helper to print a row slice
def print_rows(start, end):
    for r in range(start, end+1):
        vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}: {vals}")

# Print first 5 data rows (rows 2-6)
print("\nFirst 5 data rows:")
print_rows(2, min(6, max_row))

# Print last 5 data rows (if more than 6 rows total)
if max_row > 6:
    print("\nLast 5 data rows:")
    print_rows(max_row-4, max_row)
else:
    print("\nNot enough rows for a 'last 5' sample.")
