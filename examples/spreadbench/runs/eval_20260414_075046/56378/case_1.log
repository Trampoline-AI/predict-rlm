import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_56378_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows for a sheet
def inspect_sheet(ws, max_samples=5):
    # Determine max column from header row
    max_col = ws.max_column
    # Header row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"Headers for sheet '{ws.title}':")
    print(headers)
    # First few rows
    print("First rows:")
    for r in range(2, min(ws.max_row, max_samples+1)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Last few rows
    start_last = max(2, ws.max_row - max_samples + 1)
    print("Last rows:")
    for r in range(start_last, ws.max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Inspect each sheet
for title in wb.sheetnames:
    ws = wb[title]
    inspect_sheet(ws)

# Identify columns of interest in Frame 1 (if it exists)
frame1 = None
frame2 = None
for title in wb.sheetnames:
    if "frame 1" in title.lower():
        frame1 = wb[title]
    if "frame 2" in title.lower():
        frame2 = wb[title]

if frame1:
    # Find column indices for product name and QUANTITY UNITS
    headers = [frame1.cell(row=1, column=c).value for c in range(1, frame1.max_column+1)]
    prod_col = None
    qty_col = None
    for idx, h in enumerate(headers, start=1):
        if isinstance(h, str):
            if h.strip().lower() in ("product", "product name", "item"):
                prod_col = idx
            if h.strip().lower() == "quantity units":
                qty_col = idx
    print("Frame 1 product column:", prod_col, get_column_letter(prod_col) if prod_col else None)
    print("Frame 1 QUANTITY UNITS column:", qty_col, get_column_letter(qty_col) if qty_col else None)

if frame2:
    # Show columns O:R (15-18) headers
    o_r_headers = [frame2.cell(row=1, column=c).value for c in range(15, 19)]
    print("Frame 2 columns O:R headers:", o_r_headers)
```
