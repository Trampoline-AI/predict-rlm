Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_14240_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_14240_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet as inspected

# Define corrected formula
correct_formula = "=SUMPRODUCT(($A$4:$A$75=$R$4)*($B$4:$B$75=$S$4)*($C$3:$P$3=$T$4),$C$4:$P$75)"

# Replace SUMPRODUCT formulas in column U (21)
col_idx = 21  # column U
for row in range(1, ws.max_row + 1):
    cell = ws.cell(row=row, column=col_idx)
    if isinstance(cell.value, str) and cell.value.upper().startswith("=SUMPRODUCT"):
        # Replace with corrected formula
        cell.value = correct_formula

# Save to output location
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to see computed values
wb_calc = openpyxl.load_workbook(output_path, data_only=True)
ws_calc = wb_calc.active

# Print a few sample values from column U to verify
print("Sample results from column U after correction:")
for r in [1, 4, 10, 20, 40, 60, 75]:
    val = ws_calc.cell(row=r, column=col_idx).value
    print(f"U{r}: {val}")

# Also verify that the formula text is present in the non‑data_only version
wb_form = openpyxl.load_workbook(output_path, data_only=False)
ws_form = wb_form.active
print("\nFormula in U4 after replacement:", ws_form.cell(row=4, column=col_idx).value)
```
