import openpyxl
from openpyxl.utils import column_index_from_string
import os
import asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_5835_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_5835_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Identify header row (first row with any non‑empty cell)
max_row = ws.max_row
max_col = ws.max_column
header_row = None
for r in range(1, max_row + 1):
    if any(ws.cell(row=r, column=c).value is not None for c in range(1, max_col + 1)):
        header_row = r
        break
if header_row is None:
    raise RuntimeError("Header row not found")

# Column indices for C and I
col_c = column_index_from_string('C')
col_i = column_index_from_string('I')

# Helper to safely convert a cell value to float (treat None/blank as 0)
def to_float(val):
    if isinstance(val, (int, float)):
        return float(val)
    try:
        return float(val)
    except (TypeError, ValueError):
        return 0.0

# Process each data row
for r in range(header_row + 1, max_row + 1):
    cell_c = ws.cell(row=r, column=col_c)
    cell_i = ws.cell(row=r, column=col_i)

    val_c = cell_c.value
    val_i = cell_i.value

    # Determine if both are empty/None
    if val_c is None and val_i is None:
        # leave C as is (blank)
        continue

    # Compute sum, treating non‑numeric as 0
    sum_val = to_float(val_c) + to_float(val_i)

    # If both were originally empty, skip; otherwise write sum
    cell_c.value = sum_val

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Reload with data_only to verify results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Verify a few rows (first 5 data rows) for column C
print("Verification of column C after summation (first 5 data rows):")
for r in range(header_row + 1, min(header_row + 6, ws2.max_row + 1)):
    print(f"Row {r}: C = {ws2.cell(row=r, column=col_c).value}")

# Also verify the last data row
last_row = ws2.max_row
print(f"Row {last_row}: C = {ws2.cell(row=last_row, column=col_c).value}")
