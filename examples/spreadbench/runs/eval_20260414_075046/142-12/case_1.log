```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet contains the data

col_f = 6  # Column F
col_j = 10  # Column J

changed_rows = []

# Iterate over data rows (skip header row 1)
for row in range(2, ws.max_row + 1):
    val_f = ws.cell(row=row, column=col_f).value
    val_j = ws.cell(row=row, column=col_j).value

    # Condition 1: exact match in column F
    if val_f != "Marble Slab Creamery":
        continue

    # Condition 2: column J is a whole number (no cents)
    if isinstance(val_j, (int, float)):
        if val_j != int(val_j):
            continue
    else:
        continue  # not a number

    # Both conditions met – update column F
    ws.cell(row=row, column=col_f).value = "Georgia State WH"
    changed_rows.append(row)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (if any)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Verify changes by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Rows updated (should show new text in column F):")
for r in changed_rows:
    print(f"Row {r}: F={ws_check.cell(r, col_f).value!r}, J={ws_check.cell(r, col_j).value!r}")

# Also print a few rows that were NOT changed for sanity
print("Sample unchanged rows (2-5):")
for r in range(2, 6):
    print(f"Row {r}: F={ws_check.cell(r, col_f).value!r}, J={ws_check.cell(r, col_j).value!r}")
```
