Code:
```repl
import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_82-30_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_82-30_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Sheet references
ws_manual = wb["Manual Result"]
ws_numbers = wb["Numbers"]

# -------------------------------------------------
# 1. Extract the target values from Manual Result (A‑F, rows 2..max)
# -------------------------------------------------
target_vals = []  # list of rows, each row is a list of up to 6 values
for r in range(2, ws_manual.max_row + 1):
    row_vals = []
    for c in range(1, 7):  # columns A‑F
        val = ws_manual.cell(row=r, column=c).value
        # Only keep whole numbers (ignore None or non‑integers)
        if isinstance(val, (int, float)):
            if isinstance(val, float):
                if val.is_integer():
                    val = int(val)
                else:
                    continue
            row_vals.append(int(val))
        else:
            row_vals.append(None)
    target_vals.append(row_vals)

print(f"Extracted {len(target_vals)} rows of target data from Manual Result.")

# -------------------------------------------------
# 2. Write the values into Numbers sheet (starting at row 1)
# -------------------------------------------------
# Clear any existing data in the area we will fill
max_needed_rows = len(target_vals)
for r in range(1, max_needed_rows + 1):
    for c in range(1, 7):
        ws_numbers.cell(row=r, column=c).value = None

# Populate
for i, row_vals in enumerate(target_vals, start=1):
    for c, val in enumerate(row_vals, start=1):
        ws_numbers.cell(row=i, column=c).value = val

# -------------------------------------------------
# 3. Save, recalculate, and verify
# -------------------------------------------------
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas (if any) and reload with cached values
await recalculate(output_path)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_numbers_check = wb_check["Numbers"]
ws_manual_check = wb_check["Manual Result"]

# Print first 5 rows of Numbers for quick verification
print("\nFirst 5 rows of Numbers after writing:")
for r in range(1, min(6, ws_numbers_check.max_row + 1)):
    vals = [ws_numbers_check.cell(row=r, column=c).value for c in range(1, 7)]
    print(f"Row {r}:", vals)

# Compare with Manual Result rows 2‑6
print("\nComparison with Manual Result (rows 2‑6):")
for r in range(2, min(7, ws_manual_check.max_row + 1)):
    manual_vals = [ws_manual_check.cell(row=r, column=c).value for c in range(1, 7)]
    numbers_vals = [ws_numbers_check.cell(row=r-1, column=c).value for c in range(1, 7)]
    print(f"Row {r-1} Numbers: {numbers_vals} | Manual: {manual_vals}")
```
