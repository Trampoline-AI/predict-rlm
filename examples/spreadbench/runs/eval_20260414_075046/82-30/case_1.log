import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb_path = "/sandbox/input/input_spreadsheet/1_82-30_init.xlsx"
wb = openpyxl.load_workbook(wb_path)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print sheet summary
def print_sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Rows: {ws.max_row}, Columns: {ws.max_column}")
    # Header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print("Headers:", headers)
    # First 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(ws.max_row, 6) + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    # Last 5 data rows
    print("Last 5 data rows:")
    start = max(2, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)

# Summarize each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print_sheet_summary(ws)
