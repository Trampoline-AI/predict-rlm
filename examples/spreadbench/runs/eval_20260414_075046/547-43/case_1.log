import openpyxl
import os
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheets
ws_emp = wb["Emp"]
ws_lookup = wb["Lookup"]
ws_expected = wb["Expected"]

# ---- Build lookup dictionary ----
lookup_dict = {}
# Assume header row is row 1
lookup_max_row = ws_lookup.max_row
for r in range(2, lookup_max_row + 1):
    var = ws_lookup.cell(row=r, column=1).value
    cat = ws_lookup.cell(row=r, column=2).value
    sub = ws_lookup.cell(row=r, column=3).value
    if var is not None:
        lookup_dict[var] = (cat, sub)

# ---- Determine variable columns in Emp ----
# Header row is row 1
emp_max_col = ws_emp.max_column
header_vals = [ws_emp.cell(row=1, column=c).value for c in range(1, emp_max_col + 1)]
# Find index of 'Jobid'
try:
    jobid_idx = header_vals.index('Jobid') + 1  # 1‑based column index
except ValueError:
    raise RuntimeError("'Jobid' column not found in Emp sheet")

# Variable columns are everything after Jobid
var_cols = []
for c in range(jobid_idx + 1, emp_max_col + 1):
    var_name = ws_emp.cell(row=1, column=c).value
    if var_name:
        var_cols.append((c, var_name))

# ---- Prepare Expected sheet ----
# Clear existing data rows (keep header row)
max_row_expected = ws_expected.max_row
if max_row_expected > 1:
    ws_expected.delete_rows(2, max_row_expected - 1)

# Write transposed data
out_row = 2  # start after header
emp_max_row = ws_emp.max_row
for r in range(2, emp_max_row + 1):
    # Constant fields from Emp
    seqno = ws_emp.cell(row=r, column=1).value
    empno = ws_emp.cell(row=r, column=2).value
    ename = ws_emp.cell(row=r, column=3).value
    jobid = ws_emp.cell(row=r, column=4).value
    for col_idx, var_name in var_cols:
        value = ws_emp.cell(row=r, column=col_idx).value
        cat, sub = lookup_dict.get(var_name, (None, None))
        # Write to Expected
        ws_expected.cell(row=out_row, column=1, value=seqno)
        ws_expected.cell(row=out_row, column=2, value=empno)
        ws_expected.cell(row=out_row, column=3, value=ename)
        ws_expected.cell(row=out_row, column=4, value=jobid)
        ws_expected.cell(row=out_row, column=5, value=var_name)
        ws_expected.cell(row=out_row, column=6, value=cat)
        ws_expected.cell(row=out_row, column=7, value=sub)
        ws_expected.cell(row=out_row, column=8, value=value)
        out_row += 1

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify a few cells
from pathlib import Path
await recalculate(output_path)
# Reload with data_only to read cached values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Expected"]
print("Verification – first few rows of Expected:")
for r in range(2, min(7, ws_check.max_row + 1)):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, 9)]
    print(f"Row {r}:", row_vals)
