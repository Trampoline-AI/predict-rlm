import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to safely get cell value as string or None
def cell_val(cell):
    return cell.value if cell.value is not None else None

# Explore each sheet
for ws in wb.worksheets:
    print(f"\n--- Sheet: {ws.title} ---")
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Print header row (row 1)
