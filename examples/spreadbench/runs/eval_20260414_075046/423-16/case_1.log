import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.styles import PatternFill

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_423-16_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print sheet summary
def print_sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet '{ws.title}' ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Print header row (row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Summaries for all sheets
for ws in wb.worksheets:
    print_sheet_summary(ws)

# Specific inspection of column A fill colors in 'Test' sheet
if 'Test' in wb.sheetnames:
    ws_test = wb['Test']
    print("\nColumn A fill colors in 'Test' sheet (row, fill color):")
    for r in range(2, ws_test.max_row+1):
        cell = ws_test.cell(row=r, column=1)  # column A
        fill = cell.fill
        # openpyxl stores solid fills in fgColor.rgb (may include alpha)
        rgb = fill.fgColor.rgb if fill.fgColor.type == "rgb" else None
        if rgb:
            # Normalize to 6‑digit hex (ignore leading alpha if present)
            hex_color = rgb[-6:]
            print(r, hex_color)
        else:
            print(r, None)
else:
    print("Sheet 'Test' not found.")
