Code:
```repl
import openpyxl
from openpyxl.styles import PatternFill, Border, Side
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_423-16_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_423-16_init.xlsx"

# Load workbook (read/write mode)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Ensure target sheets exist
if 'Test' not in wb.sheetnames or 'master' not in wb.sheetnames:
    raise ValueError("Required sheets 'Test' and/or 'master' not found.")

ws_test = wb['Test']
ws_master = wb['master']

# Helper to get hex fill color (ignoring alpha)
def get_fill_hex(cell):
    fill = cell.fill
    if fill is None:
        return None
    fg = fill.fgColor
    if fg.type == "rgb" and fg.rgb:
        # rgb may be like 'FF00FFFF00' (alpha + RGB) or just 'FFFF00'
        return fg.rgb[-6:]  # last 6 chars are the RGB
    return None

# Collect yellow‑filled, non‑blank values from column A (starting at row 2)
yellow_values = []
for r in range(2, ws_test.max_row + 1):
    cell = ws_test.cell(row=r, column=1)  # column A
    hex_color = get_fill_hex(cell)
    if hex_color == "FFFF00":
        val = cell.value
        if val is not None and str(val).strip() != "":
            yellow_values.append(val)

# Write transposed values into master row 1, starting at column A
yellow_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
thin = Side(border_style="thin", color="000000")
border = Border(left=thin, right=thin, top=thin, bottom=thin)

for idx, val in enumerate(yellow_values):
    col_idx = idx + 1  # 1‑based column index (A=1)
    target_cell = ws_master.cell(row=1, column=col_idx)
    target_cell.value = val
    target_cell.fill = yellow_fill
    target_cell.border = border

# Save to output location
import os
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas (if any) and reload data_only for verification
await recalculate(output_path)  # this returns a status string, we ignore it here

# Reload the workbook with data_only=True to read cached values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['master']

# Print the resulting row 1 values (up to the number of transposed cells)
print("Master row 1 after transposition:")
row_vals = [ws_check.cell(row=1, column=c).value for c in range(1, len(yellow_values)+1)]
print(row_vals)
```
