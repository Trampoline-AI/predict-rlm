```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_3413_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_3413_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Define the formula template (using relative row references for E and F)
formula_template = "=IF(COUNTIFS($A$3:$A$7, {E}, $B$3:$B$7, {F})>0," \
                   "SUMIFS($C$3:$C$7, $A$3:$A$7, {E}, $B$3:$B$7, {F})," \
                   "SUMIF($A$3:$A$7, {E}, $C$3:$C$7))"

# Write formulas into G3:G6
for row in range(3, 7):  # rows 3,4,5,6
    e_cell = ws.cell(row=row, column=5)  # column E
    f_cell = ws.cell(row=row, column=6)  # column F
    # Build cell references like E3, F3
    e_ref = f"{e_cell.column_letter}{row}"
    f_ref = f"{f_cell.column_letter}{row}"
    formula = formula_template.format(E=e_ref, F=f_ref)
    ws.cell(row=row, column=7).value = formula  # column G

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
from __future__ import annotations
import asyncio

# The recalculate function is provided by the environment; we need to await it.
# Use the async call:
await recalculate(output_path)

# Reload the workbook with data_only to see evaluated values
wb_eval = openpyxl.load_workbook(output_path, data_only=True)
ws_eval = wb_eval[wb_eval.sheetnames[0]]

# Print the evaluated results for G3:G6
print("Evaluated values in G3:G6 after recalculation:")
for row in range(3, 7):
    val = ws_eval.cell(row=row, column=7).value
    print(f"G{row} =", val)
