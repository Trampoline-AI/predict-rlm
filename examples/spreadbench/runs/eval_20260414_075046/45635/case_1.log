import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_45635_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_45635_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume single sheet

# Helper to build formula for a given column letter
def build_formula(col_letter):
    # Build the formula string with the specific column for the first SUM
    formula = f"""=IF(
    SUM({col_letter}2:{col_letter}4)=MAX(SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4)),
    IF(
        COUNTIF(
            {{SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4)}},
            MAX(SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4))
        )=1,
        6,
        IF(
            COUNTIF(
                {{SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4)}},
                MAX(SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4))
            )=2,
            3,
            IF(
                COUNTIF(
                    {{SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4)}},
                    MAX(SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4))
                )=3,
                2,
                0
            )
        )
    ),
    0
)"""
    return formula

# Write formulas to rows 5,6,7 in columns B-E
for col_idx in range(2, 6):  # B=2, C=3, D=4, E=5
    col_letter = get_column_letter(col_idx)
    formula = build_formula(col_letter)
    for row in (5, 6, 7):
        ws.cell(row=row, column=col_idx).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to verify results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active
for row in (5, 6, 7):
    vals = [ws2.cell(row=row, column=col).value for col in range(2, 6)]
    print(f"Row {row} values:", vals)
```
