import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_45635_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_45635_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume single sheet

# Define formula string (as described)
formula = """=IF(
    SUM(B2:B4)=MAX(SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4)),
    IF(
        COUNTIF(
            {SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4)},
            MAX(SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4))
        )=1,
        6,
        IF(
            COUNTIF(
                {SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4)},
                MAX(SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4))
            )=2,
            3,
            IF(
                COUNTIF(
                    {SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4)},
                    MAX(SUM($B$2:$B$4),SUM($C$2:$C$4),SUM($D$2:$D$4),SUM($E$2:$E$4))
                )=3,
                2,
                0
            )
        )
    ),
    0
)"""

# Write formula to B5:E5
for col_idx in range(2, 6):  # B=2, C=3, D=4, E=5
    cell = ws.cell(row=5, column=col_idx)
    cell.value = formula

# Copy to rows 6 and 7
for row in (6, 7):
    for col_idx in range(2, 6):
        ws.cell(row=row, column=col_idx).value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

