import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print a range of rows
def print_rows(ws, start, end):
    for r in range(start, end + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {row_vals}")

# Explore each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Sheet: {name} ---")
    print(f"Max row: {ws.max_row}, Max column: {ws.max_column}")

    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print("Headers:", headers)

    # First few data rows (2-6)
    print("\nFirst data rows:")
    print_rows(ws, 2, min(6, ws.max_row))

    # Last 5 rows
    if ws.max_row > 6:
        print("\nLast 5 rows:")
        print_rows(ws, max(2, ws.max_row - 4), ws.max_row)

    # Sample values from columns B, C, D (columns 2,3,4) for first few rows
    print("\nSample B, C, D values (rows 2-5):")
    for r in range(2, min(6, ws.max_row)):
        b = ws.cell(row=r, column=2).value
        c = ws.cell(row=r, column=3).value
        d = ws.cell(row=r, column=4).value
        print(f"Row {r}: B={b}, C={c}, D={d}")

# Done exploring
