import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas for any existing ones)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume the relevant sheet is the active one (Sheet1)

# Build lookup dictionaries
list1 = {}
list2 = {}
# Determine the last row for lookup lists – we can scan the entire column for non‑None values
max_row = ws.max_row
for r in range(2, max_row + 1):
    # List 1: columns G (7) name, H (8) ID
    name1 = ws.cell(row=r, column=7).value
    id1 = ws.cell(row=r, column=8).value
    if name1 is not None:
        list1[str(name1)] = id1
    # List 2: columns J (10) name, K (11) ID
    name2 = ws.cell(row=r, column=10).value
    id2 = ws.cell(row=r, column=11).value
    if name2 is not None:
        list2[str(name2)] = id2

# Apply logic to column D (4)
for r in range(2, max_row + 1):
    b_val = ws.cell(row=r, column=2).value
    c_val = ws.cell(row=r, column=3).value
    # Determine D according to the rules
    if (b_val is None or str(b_val).strip() == "") and (c_val is None or str(c_val).strip() == ""):
        d_val = None  # keep blank
    else:
        # Check list1 first
        if b_val is not None and str(b_val) in list1:
            d_val = list1[str(b_val)]
        else:
            # Not in list1, check list2 via column C
            if c_val is not None and str(c_val) in list2:
                d_val = list2[str(c_val)]
            else:
                d_val = 2500
    # Write the result (or blank) to column D
    ws.cell(row=r, column=4).value = d_val

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)
# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and reload for verification
await recalculate(output_path)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Print a few sample D values for verification
print("Verification of column D values (rows 2‑10):")
for r in range(2, min(11, ws_check.max_row + 1)):
    print(f"Row {r}: D={ws_check.cell(row=r, column=4).value}")
