Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_50971_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_50971_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# Column indices (1‑based)
col_A = 1
col_B = 2
col_G = 7  # start of target range
col_K = 11

# Gather all rows data (skip header row 1)
rows = list(ws.iter_rows(min_row=2, max_col=ws.max_column, values_only=True))

# Build a mapping from A value to list of B values (preserve order)
from collections import defaultdict

a_to_b = defaultdict(list)
for row in rows:
    a_val = row[col_A - 1]
    b_val = row[col_B - 1]
    if a_val is not None:
        a_to_b[a_val].append(b_val)

# Identify duplicate A values (count > 1)
duplicate_groups = [ (a, b_list) for a, b_list in a_to_b.items() if len(b_list) > 1 ]
# Sort groups by the first occurrence order (use row index of first appearance)
# To preserve original order, we can scan rows again and record first row index for each duplicate A
first_row_index = {}
for idx, row in enumerate(rows, start=2):
    a_val = row[col_A - 1]
    if a_val in a_to_b and len(a_to_b[a_val]) > 1 and a_val not in first_row_index:
        first_row_index[a_val] = idx

# Sort duplicate_groups by first_row_index
duplicate_groups.sort(key=lambda x: first_row_index.get(x[0], 0))

# Write results into G3:K14 (rows 3‑14, columns G‑K)
start_row = 3
max_rows = 12  # 3 to 14 inclusive
max_cols = col_K - col_G + 1  # 5 columns

# Clear the target range first (optional, but ensures no leftover data)
for r in range(start_row, start_row + max_rows):
    for c in range(col_G, col_K + 1):
        ws.cell(row=r, column=c).value = None

# Populate the range
for i, (a_val, b_list) in enumerate(duplicate_groups):
    if i >= max_rows:
        break  # do not exceed target rows
    target_row = start_row + i
    # Write up to max_cols B values across columns G‑K
    for j, b_val in enumerate(b_list[:max_cols]):
        ws.cell(row=target_row, column=col_G + j).value = b_val

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice) to update any dependent cells
# This uses the provided async tool `recalculate`
# Note: we need to await the async function, but in this REPL block we can call it directly

import asyncio

async def recalc_and_verify():
    result = await recalculate(str(output_path))
    print("Recalculate result:", result)
    # Reload with data_only to verify target cells have values
    wb_check = openpyxl.load_workbook(output_path, data_only=True)
    ws_check = wb_check.active
    print("--- Verified target range (G3:K14) ---")
    for r in range(start_row, start_row + max_rows):
        vals = [ws_check.cell(row=r, column=c).value for c in range(col_G, col_K + 1)]
        print(r, vals)

asyncio.run(recalc_and_verify())
