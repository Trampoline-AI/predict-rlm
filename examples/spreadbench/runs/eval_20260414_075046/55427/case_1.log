def inspect_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Dimensions: rows={max_row}, columns={max_col}")
    # Print header row (assume first row is header)
