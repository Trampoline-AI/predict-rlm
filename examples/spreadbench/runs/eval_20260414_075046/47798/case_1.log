import openpyxl
from pathlib import Path

# Load workbook
wb = openpyxl.load_workbook("/sandbox/input/input_spreadsheet/1_47798_init.xlsx", data_only=False)

print("Sheet names:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Get header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Function to get row values as list
    def row_vals(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]

    # First 10 data rows (skip header)
    print("First 10 data rows:")
    for r in range(2, min(2 + 10, max_row + 1)):
        print(r, row_vals(r))

    # Last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row - 4)
    for r in range(start, max_row + 1):
        print(r, row_vals(r))

    # Scan a few rows for "Collection-" substring
    print("Rows containing 'Collection-':")
    count = 0
    for r in range(2, max_row + 1):
        for c in range(1, max_col + 1):
            val = ws.cell(row=r, column=c).value
            if isinstance(val, str) and "Collection-" in val:
                print(f"  Row {r}, Col {c} ({headers[c-1]}): {val}")
                count += 1
                break  # assume only one per row
        if count >= 10:
            break
