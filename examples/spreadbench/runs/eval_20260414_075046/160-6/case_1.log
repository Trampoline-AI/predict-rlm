Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["SH"]  # sheet assumed to exist per inspection

# Identify blank rows (all cells None or empty string) – skip header row (row 1)
blank_rows = []
max_row = ws.max_row
max_col = ws.max_column
for r in range(2, max_row + 1):
    if all((ws.cell(row=r, column=c).value in (None, "")) for c in range(1, max_col + 1)):
        blank_rows.append(r)

print(f"Blank rows to delete (original indices): {blank_rows}")

# Delete rows from bottom to top
for r in reversed(blank_rows):
    ws.delete_rows(r, amount=1)

# Save to output path
wb.save(output_path)
print(f"Saved workbook to {output_path}")

# Recalculate formulas
calc_result = await recalculate(output_path)
print(f"Recalculate result: {calc_result}")

# Verify no blank rows remain
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["SH"]
max_row_check = ws_check.max_row
max_col_check = ws_check.max_column
remaining_blank = []
for r in range(2, max_row_check + 1):
    if all((ws_check.cell(row=r, column=c).value in (None, "")) for c in range(1, max_col_check + 1)):
        remaining_blank.append(r)

print(f"After deletion, blank rows found: {remaining_blank}")
print(f"Final row count: {max_row_check}, column count: {max_col_check}")
```
