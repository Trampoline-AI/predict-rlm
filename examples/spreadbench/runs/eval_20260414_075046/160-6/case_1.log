Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)

# List all sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sheet summary
def print_sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{ws.title}': {max_row} rows, {max_col} columns")
    # Print column headers (first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)
    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

# Summarize each sheet
for ws in wb.worksheets:
    print_sheet_summary(ws)

# Specifically inspect sheet "SH" for blank rows
if "SH" in wb.sheetnames:
    ws_sh = wb["SH"]
    max_row = ws_sh.max_row
    max_col = ws_sh.max_column
    print("\nDetailed blank row check for sheet 'SH':")
    blank_rows = []
    for r in range(2, max_row+1):
        # Consider a row blank if all cells in that row are None or empty string
        if all((ws_sh.cell(row=r, column=c).value in (None, "")) for c in range(1, max_col+1)):
            blank_rows.append(r)
    print(f"Found {len(blank_rows)} blank rows (indices): {blank_rows[:20]}{'...' if len(blank_rows)>20 else ''}")
else:
    print("Sheet 'SH' not found.")
```
