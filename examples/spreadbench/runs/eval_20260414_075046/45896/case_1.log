# Helper to get formula text from a cell, handling ArrayFormula objects
def get_formula(cell):
    if cell.value is None:
        return None
    # openpyxl stores array formulas as an ArrayFormula object with .text attribute
    if hasattr(cell.value, 'text'):
        return cell.value.text
    # regular formula is a string starting with '='
    if isinstance(cell.value, str) and cell.value.startswith('='):
        return cell.value
    return None

