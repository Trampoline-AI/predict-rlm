Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_45896_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_45896_init.xlsx")

# Load workbook (keep formulas for other columns)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
sheet_main = wb["Volym P5_P6_2023"]
sheet_zord = wb["ZORD"]

# Build mapping: material -> list of dates (as Python datetime or numeric)
material_dates = {}
for r in range(2, sheet_zord.max_row + 1):
    mat = sheet_zord.cell(row=r, column=1).value  # column A
    date_val = sheet_zord.cell(row=r, column=3).value  # column C (date column)
    if mat is None or date_val is None:
        continue
    material_dates.setdefault(mat, []).append(date_val)

# Function to format a date value as dd/mm/yyyy
def format_date(val):
    # openpyxl may return datetime.datetime, datetime.date, or Excel serial number
    if isinstance(val, (float, int)):
        # Convert Excel serial number to Python date (Excel epoch 1899-12-30)
        from datetime import datetime, timedelta
        base = datetime(1899, 12, 30)
        dt = base + timedelta(days=val)
        return dt.strftime("%d/%m/%Y")
    elif hasattr(val, "strftime"):
        return val.strftime("%d/%m/%Y")
    else:
        return str(val)

# Write joined dates into column I (9) of the main sheet
for r in range(2, sheet_main.max_row + 1):
    mat = sheet_main.cell(row=r, column=1).value  # material code from column A
    dates = material_dates.get(mat, [])
    # Remove duplicates while preserving order
    seen = set()
    uniq_dates = []
    for d in dates:
        if d not in seen:
            seen.add(d)
            uniq_dates.append(d)
    # Format each date
    formatted = [format_date(d) for d in uniq_dates]
    joined = ", ".join(formatted)
    sheet_main.cell(row=r, column=9).value = joined  # column I

# Save the modified workbook
wb.save(output_path)
print(f"Saved workbook to {output_path}")

# Recalculate (no formulas in column I, but run for completeness)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Verify a few rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[sheet_main.title]
for r in range(2, min(7, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=9).value
    print(f"Row {r} Column I after recalc: {val}")

# Ensure file exists
assert os.path.isfile(output_path), "Output file not found!"
```
