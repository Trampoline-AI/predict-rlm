import openpyxl
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path('/sandbox/output/output_spreadsheet/')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet

# Determine max row
max_row = ws.max_row

# New formula string (for row 2 as example, will be copied to each row)
# =IF(B2="General","Marketing",IF(A2="", "",IF(ISERROR(SEARCH("-",A2,1)),"Sales","Marketing")))
new_formula_template = "=IF(B{row}=\"General\",\"Marketing\",IF(A{row}=\"\",\"\",IF(ISERROR(SEARCH(\"-\",A{row},1)),\"Sales\",\"Marketing\")))"

# Apply formula to column C (3) for all rows starting at 2
for r in range(2, max_row + 1):
    ws.cell(row=r, column=3).value = new_formula_template.format(row=r)

# Save to output location
wb.save(output_path)

# Recalculate formulas using the provided tool
result = await recalculate(str(output_path))
print("Recalculate result:", result)

# Reload with data_only to verify a few cells
