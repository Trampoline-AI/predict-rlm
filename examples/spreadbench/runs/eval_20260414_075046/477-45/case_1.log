import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = f"{output_dir}1_477-45_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume the first sheet is the target

# ----------------------------------------------------------------------
# 1. Build aggregation dictionary keyed by (A, B, C) -> sum of D
# ----------------------------------------------------------------------
agg = {}  # key: (id, brand, typ) -> total sum

for row in range(2, ws.max_row + 1):
    id_val = ws.cell(row=row, column=1).value   # Column A
    brand_val = ws.cell(row=row, column=2).value  # Column B
    type_val = ws.cell(row=row, column=3).value   # Column C
    total_val = ws.cell(row=row, column=4).value  # Column D

    # Skip rows where any of the key columns are None (unlikely but safe)
    if id_val is None or brand_val is None or type_val is None:
        continue

    # Ensure total_val is numeric; treat non‑numeric as 0
    try:
        total_num = float(total_val) if total_val is not None else 0.0
    except (TypeError, ValueError):
        total_num = 0.0

    key = (id_val, brand_val, type_val)
    agg[key] = agg.get(key, 0) + total_num

# ----------------------------------------------------------------------
# 2. Write aggregated results starting at G2 (columns G‑J)
# ----------------------------------------------------------------------
start_row = 2
out_col_ids = {
    "ID": 7,      # G
    "Brand": 8,   # H
    "type": 9,    # I
    "Total": 10   # J
}

# Clear any existing data in the output range (optional but safe)
for r in range(start_row, start_row + len(agg)):
    for c in range(7, 11):
        ws.cell(row=r, column=c).value = None

# Populate rows
current_row = start_row
for (id_val, brand_val, type_val), total_sum in agg.items():
    ws.cell(row=current_row, column=out_col_ids["ID"]).value = id_val
    ws.cell(row=current_row, column=out_col_ids["Brand"]).value = brand_val
    ws.cell(row=current_row, column=out_col_ids["type"]).value = type_val
    ws.cell(row=current_row, column=out_col_ids["Total"]).value = total_sum
    current_row += 1

# ----------------------------------------------------------------------
# 3. Save workbook to output location
# ----------------------------------------------------------------------
wb.save(output_path)
print(f"Saved aggregated workbook to {output_path}")

# ----------------------------------------------------------------------
# 4. Recalculate formulas (if any) and verify first few output cells
# ----------------------------------------------------------------------
# Recalculate using the provided helper
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to see cached values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Print first 5 aggregated rows for verification
print("First 5 aggregated rows (G‑J):")
for r in range(2, min(7, ws_check.max_row + 1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(7, 11)]
    print(f"Row {r}:", vals)
