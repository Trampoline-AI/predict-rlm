```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
input_path = input_spreadsheet  # variable provided by the environment
wb = openpyxl.load_workbook(input_path, data_only=False)

print("=== Workbook Overview ===")
print(f"Sheets: {wb.sheetnames}")

def print_sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Dimensions: rows={max_row}, cols={max_col}")

    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Helper to get row values as list
    def row_vals(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]

    # First 5 data rows (skip header)
    first_rows = [row_vals(r) for r in range(2, min(2+5, max_row+1))]
    print("First 5 data rows:")
    for r in first_rows:
        print(r)

    # Last 5 data rows (skip header)
    start_last = max(2, max_row-4)
    last_rows = [row_vals(r) for r in range(start_last, max_row+1)]
    print("Last 5 data rows:")
    for r in last_rows:
        print(r)

# Summarize each sheet
for ws in wb.worksheets:
    print_sheet_summary(ws)

print("\n=== Instruction ===")
print(instruction)
```
