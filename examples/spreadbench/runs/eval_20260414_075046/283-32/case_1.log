Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (preserve formulas, though we will write literals)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Helper to extract data rows (excluding header) as tuples

def rows_as_tuples(ws):
    rows = []
    max_col = ws.max_column
    # start from row 2 (skip header)
    for r in range(2, ws.max_row + 1):
        # collect values for all columns up to max_col
        vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        # skip completely empty rows
        if all(v is None for v in vals):
            continue
        rows.append(tuple(vals))
    return rows

# Get rows from Sheet1 and Sheet2
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]
rows1 = rows_as_tuples(ws1)
rows2 = rows_as_tuples(ws2)

set1 = set(rows1)
set2 = set(rows2)

# Differences
only_in_1 = sorted(set1 - set2)  # rows removed in Sheet2
only_in_2 = sorted(set2 - set1)  # rows added in Sheet2

# Write to Sheet3 and Sheet4 (starting at row 1, no headers)
ws3 = wb["Sheet3"]
ws4 = wb["Sheet4"]

# Clear any existing content just in case
for ws in (ws3, ws4):
    for row in ws.iter_rows():
        for cell in row:
            cell.value = None

# Helper to write list of tuples to a sheet

def write_rows(ws, rows):
    for i, row_vals in enumerate(rows, start=1):  # start at row 1
        for j, val in enumerate(row_vals, start=1):
            ws.cell(row=i, column=j, value=val)

write_rows(ws3, only_in_1)
write_rows(ws4, only_in_2)

# Save workbook to output path
wb.save(output_path)

# Recalculate formulas (none expected, but follow workflow)
await recalculate(output_path)

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws3_check = wb_check["Sheet3"]
ws4_check = wb_check["Sheet4"]

print("Verification: Sheet3 rows written:", ws3_check.max_row)
print("Verification: Sheet4 rows written:", ws4_check.max_row)

# Show a few rows from each for sanity

def preview(ws, n=5):
    rows = []
    for r in range(1, min(ws.max_row, n) + 1):
        rows.append([ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)])
    return rows

print("Sheet3 preview (first rows):", preview(ws3_check, 5))
print("Sheet4 preview (first rows):", preview(ws4_check, 5))
```
