import openpyxl
from openpyxl.styles import Font, PatternFill
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_47827_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_47827_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path)
sheet_name = "3 straights to 3 boxed"
ws = wb[sheet_name]

# Prepare styling
bold_font = Font(bold=True)
fill = PatternFill(start_color="EBF1DE", end_color="EBF1DE", fill_type="solid")

# Process rows
max_row = ws.max_row
for r in range(2, max_row + 1):
    # Read three numbers; if any is None, skip this row
    a = ws.cell(row=r, column=2).value  # strai_1 (B)
    b = ws.cell(row=r, column=3).value  # strai_2 (C)
    c = ws.cell(row=r, column=4).value  # strai_3 (D)
    if a is None or b is None or c is None:
        continue
    # Ensure they are integers (or can be cast)
    try:
        nums = sorted([int(a), int(b), int(c)])
    except Exception:
        # If conversion fails, skip
        continue
    # Build three‑digit string
    three_digit = f"{nums[0]}{nums[1]}{nums[2]}"
    # Write to column G (7)
    cell = ws.cell(row=r, column=7)
    cell.value = three_digit
    cell.font = bold_font
    cell.fill = fill

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(str(output_path))

# Reload with data_only to check column G values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[sheet_name]
print("Verification of column G values after recalculation:")
for r in range(2, ws_check.max_row + 1):
    val = ws_check.cell(row=r, column=7).value
    if val is not None:
        print(f"Row {r}: {val}")

# End of code block
```
