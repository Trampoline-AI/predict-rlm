import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read-only is fine for inspection)
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=True)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Choose the first sheet (or you can iterate all)
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Get headers from first row (up to column M)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers (first 20 columns):", headers[:20])

    # Define column range F (6) to M (13)
    start_col = 6
    end_col = 13

    # Helper to extract a row slice as list
    def row_slice(r):
        return [ws.cell(row=r, column=c).value for c in range(start_col, end_col+1)]

    # Print first 5 data rows (excluding header)
    print("\nFirst 5 rows (F-M):")
    for r in range(2, min(7, max_row+1)):
        print(f"Row {r}:", row_slice(r))

    # Print last 5 rows (F-M)
    print("\nLast 5 rows (F-M):")
    for r in range(max(max_row-4, 2), max_row+1):
        print(f"Row {r}:", row_slice(r))
