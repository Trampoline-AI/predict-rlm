import os, openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))
os.makedirs(output_dir, exist_ok=True)

# Load workbook for inspection (including formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Helper to get values for columns F-M (6-13) for a given row
def row_vals(r):
    return [ws.cell(row=r, column=c).value for c in range(6, 14)]

# Inspect a few rows in the target range to understand why they may not be considered empty
print("Inspecting rows 14‑20 (F-M values):")
for r in range(14, 21):
    print(f"Row {r}:", row_vals(r))

# Determine rows to delete: all cells in F-M are empty (None, "", or a formula that evaluates to empty)
rows_to_delete = []
for r in range(14, ws.max_row + 1):
    vals = row_vals(r)
    # Treat None or empty string as empty; also treat a formula that is an empty string after stripping
    if all(v is None or (isinstance(v, str) and v.strip() == "") for v in vals):
        rows_to_delete.append(r)

print("Rows identified for deletion:", rows_to_delete)

# Delete rows in reverse order to keep indices stable
for r in reversed(rows_to_delete):
    ws.delete_rows(r)

# Save modified workbook
wb.save(output_path)
print(f"Workbook saved to {output_path}")

# Recalculate formulas (async call)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only=True to verify final state
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Final row count (including header):", ws_check.max_row)
# Show the remaining rows' F-M values for the first few rows after header
print("Remaining rows 2‑10 (F-M):")
for r in range(2, min(11, ws_check.max_row + 1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(6, 14)]
    print(f"Row {r}:", vals)
