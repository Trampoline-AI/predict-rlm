ws_check = wb_check[wb_check.sheetnames[0]]
print("\nVerification of column C after recalculation (first 10 rows):")
for r in range(2, min(12, ws_check.max_row+1)):
    val = ws_check.cell(row=r, column=col_C).value
    print(f"Row {r}: C={val}")
