import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
from pathlib import Path
import json

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_34210_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook
wb = openpyxl.load_workbook(input_path)
print(f"Workbook loaded. Sheets: {wb.sheetnames}")

# Inspect each sheet (assuming only one sheet, but handle multiple)
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {sheet_name} (rows={max_row}, cols={max_col})")
    # Get header row (row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Sample first 5 data rows (rows 2-6) and last 5 rows (if enough rows)
    sample_rows = []
    for r in range(2, min(7, max_row+1)):
        sample_rows.append([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    if max_row > 7:
        for r in range(max_row-4, max_row+1):
            sample_rows.append([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    print("Sample rows (first few and last few):")
    for row in sample_rows:
        print(row)

# Determine column indices for A and C (should be 1 and 3)
col_A = column_index_from_string('A')
col_C = column_index_from_string('C')
print(f"Column A index: {col_A}, Column C index: {col_C}")

# Apply formula to fill empty cells in column C with value from column A
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    # Start from row 2 assuming row 1 is header
    for r in range(2, max_row + 1):
        cell_C = ws.cell(row=r, column=col_C)
        # Write formula regardless of current content; IF will keep existing non‑empty values
        formula = f"=IF(C{r}="",A{r},C{r})"
        cell_C.value = formula
    print(f"Formulas written to column C in sheet '{sheet_name}' up to row {max_row}.")

# Save workbook to output location
wb.save(output_path)
print(f"Workbook saved to {output_path}")

# Recalculate formulas using the provided tool
result = await recalculate(str(output_path))
print("Recalculate result:", result)

# Reload with data_only to verify a few cells in column C
