import openpyxl
from openpyxl.utils import column_index_from_string
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_34210_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load the original workbook (fresh copy)
wb = openpyxl.load_workbook(input_path)
print(f"Loaded workbook with sheets: {wb.sheetnames}")

# Determine column indices for A and C
col_A = column_index_from_string('A')
col_C = column_index_from_string('C')
print(f"Column indices -> A: {col_A}, C: {col_C}")

# Fill empty cells in column C with the value from column A
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    for r in range(2, max_row + 1):  # assume row 1 is header
        cell_C = ws.cell(row=r, column=col_C)
        cell_A = ws.cell(row=r, column=col_A)
        # Consider a cell empty if its value is None or an empty string
        if cell_C.value is None or (isinstance(cell_C.value, str) and cell_C.value == ""):
            cell_C.value = cell_A.value
    print(f"Processed sheet '{sheet_name}': filled column C up to row {max_row}")

# Save the modified workbook to the output location
wb.save(output_path)
print(f"Workbook saved to {output_path}")

# Recalculate (no formulas, but required by the workflow)
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Reload with data_only to verify a few cells in column C
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("\nVerification of column C after processing (first 10 data rows):")
for r in range(2, min(12, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=col_C).value
    print(f"Row {r}: C = {val}")
