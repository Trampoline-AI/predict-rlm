```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50811_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_50811_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Write the INDEX‑MATCH formula into D21, D22, D23
for row in (21, 22, 23):
    # Build formula with the correct row reference
    formula = f"=INDEX($H$5:$T$6, MATCH(C{row}, $C$5:$C$6, 0), MATCH(B{row}, $F$5:$R$5, 0)*3-2)"
    ws.cell(row=row, column=4).value = formula  # column D = 4

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
await recalculate(output_path)

# Reload with data_only=True to read the computed values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active

# Print the resulting values of D21‑D23
for row in (21, 22, 23):
    val = ws2.cell(row=row, column=4).value
    print(f"D{row} = {val}")

# Clean up (optional)
# wb.close()
# wb2.close()
