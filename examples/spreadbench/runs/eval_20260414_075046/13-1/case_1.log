Code:
```repl
import os
from pathlib import Path
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_13-1_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_13-1_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Get worksheets
ws_ranges = wb["RANGES"]
ws_lists = wb["LISTS"]

# -------------------------------------------------
# 1. Aggregate RANGES data by (DATE, REF)
# -------------------------------------------------
agg = {}  # key: (date, ref) -> sum amount
for row in ws_ranges.iter_rows(min_row=3, max_col=5, values_only=True):
    # row tuple corresponds to columns A-E (A=S.N, B=DATE, C=BATCH, D=REF, E=AMOUNTS)
    _, date, _, ref, amount = row
    if date is None or ref is None or amount is None:
        continue
    key = (date, ref)
    agg[key] = agg.get(key, 0) + amount

# -------------------------------------------------
# 2. Clear old data rows in LISTS (keep header row 2 and TOTAL row)
# -------------------------------------------------
# Find the row that contains the word "TOTAL" in column A
total_row = None
for r in range(3, ws_lists.max_row + 1):
    val = ws_lists.cell(row=r, column=1).value
    if isinstance(val, str) and val.strip().upper() == "TOTAL":
        total_row = r
        break

# If TOTAL row not found, assume it will be appended after existing data
if total_row is None:
    total_row = ws_lists.max_row + 1

# Clear rows 3 .. total_row-1 (old data)
for r in range(3, total_row):
    for c in range(1, 5):  # columns A-D (SN, DATE, REF, AMOUNTS)
        ws_lists.cell(row=r, column=c).value = None

# -------------------------------------------------
# 3. Write aggregated data into LISTS
# -------------------------------------------------
write_row = 3
for idx, ((date, ref), amount) in enumerate(sorted(agg.items()), start=1):
    ws_lists.cell(row=write_row, column=1, value=idx)          # SN
    ws_lists.cell(row=write_row, column=2, value=date)        # DATE
    ws_lists.cell(row=write_row, column=3, value=ref)         # REF
    ws_lists.cell(row=write_row, column=4, value=amount)      # AMOUNTS
    write_row += 1

last_data_row = write_row - 1  # last row with data

# -------------------------------------------------
# 4. Write TOTAL row with SUM formula
# -------------------------------------------------
# Ensure TOTAL row is positioned after the data (overwrite any existing TOTAL row)
ws_lists.cell(row=write_row, column=1, value="TOTAL")
# Formula to sum D column from row 3 to last_data_row
sum_formula = f"=SUM(D3:D{last_data_row})"
ws_lists.cell(row=write_row, column=4, value=sum_formula)

# -------------------------------------------------
# 5. Save and recalculate
# -------------------------------------------------
wb.save(output_path)

# Recalculate formulas (LibreOffice + python formulas library)
recalc_result = await recalculate(str(output_path))
print("Recalculate result:", recalc_result)

# Verify TOTAL cell value after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["LISTS"]
total_val = ws_check.cell(row=write_row, column=4).value
print(f"TOTAL cell (row {write_row}, column D) value after recalculation:", total_val)
```
