if col_client_id is None:
    missing.append("CLIENT_ID")
if col_startdate is None:
    missing.append("STARTDATE")
for i, c in enumerate(prog_cols, start=1):
    if c is None:
        missing.append(f"PRGCode{i}")
if missing:
    raise ValueError(f"Missing required columns: {missing}")

# Date range: last 90 days (approx 3 months)
today = datetime.today()
three_months_ago = today - timedelta(days=90)

client_programs = {}

# Iterate over rows
for row in range(2, ws_read.max_row + 1):
    cid = ws_read.cell(row=row, column=col_client_id).value
    if cid is None:
        continue
    start = ws_read.cell(row=row, column=col_startdate).value
    if not isinstance(start, datetime):
        # If date is stored as string, try to parse
        try:
            start = datetime.strptime(str(start), "%Y-%m-%d")
        except Exception:
            continue
    if not (three_months_ago <= start <= today):
        continue
    # Gather program codes from PRGCode columns (cached values)
    prog_set = set()
    for pc in prog_cols:
        prog = ws_read.cell(row=row, column=pc).value
        if prog is None:
