import openpyxl
from openpyxl.utils import get_column_letter
from datetime import datetime, timedelta
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_59734_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_59734_init.xlsx")

# Load workbook twice: one for reading cached values (data_only=True) and one for writing (data_only=False)
wb_write = openpyxl.load_workbook(input_path, data_only=False)
wb_read = openpyxl.load_workbook(input_path, data_only=True)

# Assume data is in the first sheet (as inspected earlier)
ws_write = wb_write[wb_write.sheetnames[0]]
ws_read = wb_read[wb_read.sheetnames[0]]

# Helper to find column index by header name (case‑insensitive)
def col_index(ws, name):
    for col in range(1, ws.max_column + 1):
        val = ws.cell(row=1, column=col).value
        if isinstance(val, str) and val.strip().lower() == name.lower():
            return col
    return None

# Identify needed columns
