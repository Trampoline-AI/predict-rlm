import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb_path = "/sandbox/input/input_spreadsheet/1_59734_init.xlsx"
wb = openpyxl.load_workbook(wb_path)

# List sheet names
sheet_names = wb.sheetnames
print("Sheet names:", sheet_names)

# Function to print header and sample rows for a sheet
def inspect_sheet(ws, num_rows=5):
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print(f"\n--- Sheet: {ws.title} ---")
    print("Headers:", headers)
    
    # Print first few data rows
    print(f"First {num_rows} data rows:")
    for r in range(2, min(2 + num_rows, ws.max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    
    # Print last few data rows
    print(f"Last {num_rows} data rows:")
    start = max(2, ws.max_row - num_rows + 1)
    for r in range(start, ws.max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)

# Inspect each sheet
for name in sheet_names:
    ws = wb[name]
    inspect_sheet(ws, num_rows=5)
