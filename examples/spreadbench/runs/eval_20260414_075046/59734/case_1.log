if summary_name in wb_write.sheetnames:
    ws_sum = wb_write[summary_name]
    # Clear existing content (keep the sheet object)
    ws_sum.delete_rows(1, ws_sum.max_row)
else:
    ws_sum = wb_write.create_sheet(title=summary_name)

# Write headers
