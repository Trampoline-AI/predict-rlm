import openpyxl
from openpyxl.utils import get_column_letter
from datetime import datetime, timedelta
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_59734_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_59734_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)

# Assume data is in the first sheet
ws = wb[wb.sheetnames[0]]

# Identify column indices by header name (case‑insensitive)
header_row = 1
headers = [ws.cell(row=header_row, column=c).value for c in range(1, ws.max_column + 1)]

def col_index(name):
    for idx, val in enumerate(headers, start=1):
        if isinstance(val, str) and val.strip().lower() == name.lower():
            return idx
    return None

# Columns we need
col_clientid = col_index("ClientID")          # client identifier in client part
col_clientid2 = col_index("CLIENT_ID")       # client identifier in episode part
col_startdate = col_index("STARTDATE")
prog_cols = [col_index(f"PRGCode{i}") for i in range(1,5)]

# Verify we found all needed columns
missing = [n for n, c in [("ClientID", col_clientid),
                               ("CLIENT_ID", col_clientid2),
                               ("STARTDATE", col_startdate)] if c is None]
if missing:
    raise ValueError(f"Missing required columns: {missing}")

# Build a mapping: client_id -> set of program codes from episodes in last 3 months
today = datetime.today()
three_months_ago = today - timedelta(days=90)

client_programs = {}

for row in range(2, ws.max_row + 1):
    # Read the episode‑level client id
    cid = ws.cell(row=row, column=col_clientid2).value
    if cid is None:
        continue
    # Read start date
    start = ws.cell(row=row, column=col_startdate).value
    if not isinstance(start, datetime):
        continue
    if not (three_months_ago <= start <= today):
        continue
    # Collect program codes from the client‑part columns (they may be in the same row)
    prog_set = set()
    for pc in prog_cols:
        prog = ws.cell(row=row, column=pc).value
        if prog is not None and prog != "":
            prog_set.add(str(prog))
    if prog_set:
        client_programs.setdefault(cid, set()).update(prog_set)

# Create (or replace) summary sheet
summary_name = "Client_Program_Summary"
if summary_name in wb.sheetnames:
    ws_sum = wb[summary_name]
    ws_sum.delete_rows(1, ws_sum.max_row)  # clear existing data
else:
    ws_sum = wb.create_sheet(title=summary_name)

# Write headers
ws_sum["A1"] = "ClientID"
ws_sum["B1"] = "Programs_Last3Months"

# Write data
out_row = 2
for cid, prog_set in sorted(client_programs.items()):
    ws_sum.cell(row=out_row, column=1).value = cid
    ws_sum.cell(row=out_row, column=2).value = ", ".join(sorted(prog_set))
    out_row += 1

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and reload for verification
await recalculate(output_path)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[summary_name]

# Print first few rows of the summary for verification
print("Summary sheet preview (first 10 rows):")
for r in range(1, min(11, ws_check.max_row + 1)):
    print([ws_check.cell(row=r, column=c).value for c in (1,2)])
