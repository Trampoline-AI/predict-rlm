```repl
import openpyxl
import os
from pathlib import Path

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(input_path).name

# Load workbook (keep formulas if any)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Helper to build ID → QTY map for a given sheet name
def build_id_qty_map(sheet_name):
    ws = wb[sheet_name]
    id_qty = {}
    for r in range(2, ws.max_row + 1):
        id_val = ws.cell(row=r, column=2).value  # column B = ID
        qty = ws.cell(row=r, column=3).value   # column C = QTY
        # Only store if ID is not None
        if id_val is not None:
            id_qty[id_val] = qty
    return id_qty

sh1_map = build_id_qty_map("SH1")
rp1_map = build_id_qty_map("RP1")

# Process the merging sheet
merge_ws = wb["merging"]
max_row = merge_ws.max_row

for r in range(2, max_row + 1):
    id_val = merge_ws.cell(row=r, column=2).value  # column B = ID
    # Look up QTYs, default to "-"
    sh1_qty = sh1_map.get(id_val, "-")
    rp1_qty = rp1_map.get(id_val, "-")
    # If the retrieved value is None or empty string, also replace with "-"
    if sh1_qty is None or (isinstance(sh1_qty, str) and sh1_qty.strip() == ""):
        sh1_qty = "-"
    if rp1_qty is None or (isinstance(rp1_qty, str) and rp1_qty.strip() == ""):
        rp1_qty = "-"
    # Write to column C (3) and D (4)
    merge_ws.cell(row=r, column=3).value = sh1_qty
    merge_ws.cell(row=r, column=4).value = rp1_qty

# Save to output location
wb.save(output_path)

# Recalculate formulas (none expected, but follow protocol)
await recalculate(str(output_path))

# Verify by reloading data_only and printing first few rows of merging sheet
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["merging"]
print("Verification of merging sheet (first 5 data rows):")
for r in range(2, min(7, ws_check.max_row + 1)):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, 5)]
    print(f"Row {r}:", row_vals)
```
