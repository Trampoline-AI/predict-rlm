import openpyxl
from openpyxl.utils import get_column_letter

# Load the input spreadsheet (read‑only is fine for inspection)
input_path = '/sandbox/input/input_spreadsheet/1_414-20_init.xlsx'
wb = openpyxl.load_workbook(input_path, data_only=False)

print('Sheet names:', wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f'\nSheet: {sheet_name}')
    print(f'  max_row = {max_row}, max_col = {max_col}')
    # Print column A header (first row) and a few sample rows
    header = ws.cell(row=1, column=1).value
    print('  Column A header (row 1):', header)
    # Show first 5 rows of column A
    first_vals = [ws.cell(row=r, column=1).value for r in range(1, min(6, max_row+1))]
    print('  First 5 values in column A:', first_vals)
    # Show last 5 rows of column A
    start_last = max(1, max_row-4)
    last_vals = [ws.cell(row=r, column=1).value for r in range(start_last, max_row+1)]
    print('  Last 5 values in column A:', last_vals)
    # Find first occurrence of "Invoice No." (case‑insensitive)
    target_row = None
    for r in range(1, max_row+1):
        val = ws.cell(row=r, column=1).value
        if isinstance(val, str) and val.strip().lower() == 'invoice no.':
            target_row = r
            break
    if target_row:
        print(f'  First occurrence of "Invoice No." in column A at row {target_row}')
    else:
        print('  "Invoice No." not found in column A')

wb.close()
