import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_43213_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_43213_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is target

# Determine the last row that contains data in column A
max_row = ws.max_row
last_data_row = 1
for r in range(2, max_row + 1):
    val = ws.cell(row=r, column=1).value
    if val is not None and val != "":
        last_data_row = r

# Write rounding average formulas into column B, starting at row 12
start_row = 12
for r in range(start_row, last_data_row + 1):
    # Formula: ROUND(AVERAGE($A$11:A{r}),3)
    formula = f"=ROUND(AVERAGE($A$11:A{r}),3)"
    ws.cell(row=r, column=2, value=formula)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save the workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice) to cache values
await recalculate(output_path)

# Reload the workbook with data_only=True to verify cached results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws.title]

# Print verification for rows 12–15 (or up to last_data_row)
print("Verification of cached averages in column B:")
for r in range(start_row, min(last_data_row + 1, 16)):
