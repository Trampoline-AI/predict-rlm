from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_58701_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_58701_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = load_workbook(input_path)

# Get sheets
ws_entry = wb["Entry Tab"]
ws_table = wb["Table Tab"]

# Determine the last row with data in Entry Tab (assuming contiguous data)
max_row = ws_entry.max_row

# Write VLOOKUP formula into Office Code column (E, column index 5)
for r in range(2, max_row + 1):
    # Only write if the cell is empty or contains an error (to avoid overwriting existing valid data)
    cell = ws_entry.cell(row=r, column=5)
    if cell.value is None or isinstance(cell.value, str) and cell.value.startswith("#"):
        formula = f"=VLOOKUP(B{r}, 'Table Tab'!$A:$B, 2, FALSE)"
        cell.value = formula

# Save to output path
wb.save(output_path)

# Recalculate formulas using LibreOffice (async call)
