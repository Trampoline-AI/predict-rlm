import os, json, openpyxl
from openpyxl.utils import get_column_letter
from pathlib import Path

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_46897_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_46897_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming the first sheet is the target

# Determine current max column to avoid overwriting existing data
max_col = ws.max_column

# Define new columns (K, L, M) – they are after existing I (col 9)
col_K = max_col + 1  # should be 10 (J) but we will use K (11) etc.
# Actually we want K (11), L (12), M (13). Since max_col is 9, we can start at 10.
# We'll place headers in column 10 (J), 11 (K), 12 (L) for clarity.
# But to follow the plan, we'll use K (11), L (12), M (13). Let's compute:
col_K = 11  # K
col_L = 12  # L
col_M = 13  # M

# Write headers
ws.cell(row=1, column=col_K, value="Header")
ws.cell(row=1, column=col_L, value="Value")
ws.cell(row=1, column=col_M, value="Count")

# Example inputs
ws.cell(row=2, column=col_K, value="Fruits")
ws.cell(row=2, column=col_L, value="Apple")

# Write formula in M2
# Formula: =COUNTIF(INDEX($A:$I,0,MATCH(K2,$A$1:$I$1,0)),L2)
formula = '=COUNTIF(INDEX($A:$I,0,MATCH(K2,$A$1:$I$1,0)),L2)'
ws.cell(row=2, column=col_M, value=formula)

# Save workbook to output path
wb.save(output_path)

# Recalculate formulas using provided tool
await recalculate(output_path)

# Reload with data_only to read evaluated result
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data.active
result_value = ws_data.cell(row=2, column=col_M).value
print("Evaluated count in M2:", result_value)

# Also print the formula stored in the original workbook for verification
orig_formula = ws.cell(row=2, column=col_M).value
print("Stored formula in M2:", orig_formula)
