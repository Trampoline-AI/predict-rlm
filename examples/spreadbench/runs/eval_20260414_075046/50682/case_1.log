```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

input_path = "/sandbox/input/input_spreadsheet/1_50682_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_50682_init.xlsx")
os.makedirs(output_dir, exist_ok=True)

wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

part = ws["A2"].value
max_row = ws.max_row
max_col = ws.max_column

matches = []
for r in range(2, max_row+1):
    for c in range(15, max_col):  # O is 15, up to column before the quantity column
        cell = ws.cell(r, c)
        if cell.value == part:
            qty_cell = ws.cell(r, c+1)  # quantity is next column
            qty = qty_cell.value
            if isinstance(qty, (int, float)):
                matches.append((r, get_column_letter(c), qty))

print(f"Found {len(matches)} matches for part {part}:")
for m in matches[:10]:
    print(m)

total = sum(q for _,_,q in matches)
print("Total quantity computed in Python:", total)

# Write a simple SUMPRODUCT formula that covers the exact columns where part numbers reside.
# Determine the last column that contains part numbers (odd columns starting at O).
# We'll assume part numbers are in columns O, Q, S, U, W (15,17,19,21,23) and quantities in P,R,T,V,X (16,18,20,22,24).
# Build ranges accordingly.
part_range = "O2:W"+str(max_row)
qty_range = "P2:X"+str(max_row)
formula = f"=SUMPRODUCT(({part_range}=A2)*({qty_range}))"
ws["M2"] = formula

wb.save(output_path)

# Recalculate and read back value
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("M2 after recalculation:", ws2["M2"].value)
