import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_32902_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming only one sheet

# Target row for Tier calculations (row 8)
target_row = 8

# Write formulas for Tier 1,2,3 in columns C,D,E
ws[f"C{target_row}"] = "=MAX(0, MIN(B{0}, 90000) - 60000) * 0.15".format(target_row)
ws[f"D{target_row}"] = "=MAX(0, MIN(B{0}, 120000) - 90000) * 0.25".format(target_row)
ws[f"E{target_row}"] = "=MAX(0, B{0} - 120000) * 0.35".format(target_row)

# Save to output directory
import os
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)

# Reload with data_only to verify computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Print the computed values for the target row
tier1_val = ws_check[f"C{target_row}"].value
tier2_val = ws_check[f"D{target_row}"].value
tier3_val = ws_check[f"E{target_row}"].value
print(f"Row {target_row} computed Tier bonuses:")
print(f"Tier1 (C{target_row}) = {tier1_val}")
print(f"Tier2 (D{target_row}) = {tier2_val}")
print(f"Tier3 (E{target_row}) = {tier3_val}")

# Also print the total column F for that row
total_val = ws_check[f"F{target_row}"].value
print(f"Total (F{target_row}) = {total_val}")
