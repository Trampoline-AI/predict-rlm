import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook (read‑only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_36191_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

print("Sheet names:", wb.sheetnames)

for ws_name in wb.sheetnames:
    ws = wb[ws_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws_name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Sample first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Sample last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Find column that contains "Result" in its header (case‑insensitive)
    result_col_idx = None
    for idx, hdr in enumerate(headers, start=1):
        if isinstance(hdr, str) and "result" in hdr.lower():
            result_col_idx = idx
            break
    if result_col_idx:
        col_letter = get_column_letter(result_col_idx)
        print(f"Found result column: {col_letter} (index {result_col_idx})")
        # Show current values in that column for first few rows
        print(f"Current values in column {col_letter}:")
        for r in range(2, min(2+5, max_row+1)):
            val = ws.cell(row=r, column=result_col_idx).value
            print(r, val)
    else:
        print("No column header containing 'Result' found.")
