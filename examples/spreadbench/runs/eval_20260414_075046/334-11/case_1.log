Code:
```repl
import openpyxl
from pathlib import Path
import asyncio

# Paths
input_path = Path(input_spreadsheet)  # /sandbox/input/input_spreadsheet/1_334-11_init.xlsx
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_334-11_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
# Find the sheet (case‑insensitive match for 'Imported Data')
target_sheet_name = None
for name in wb.sheetnames:
    if name.lower() == "imported data":
        target_sheet_name = name
        break
if target_sheet_name is None:
    raise ValueError("Sheet matching 'Imported Data' not found.")
ws = wb[target_sheet_name]

# Helper to determine if a row is completely blank
def row_is_blank(row_idx):
    for col in range(1, ws.max_column + 1):
        if ws.cell(row=row_idx, column=col).value is not None:
            return False
    return True

# Delete rows from bottom to top (preserve header row 1)
max_row = ws.max_row
rows_deleted = 0
for r in range(max_row, 1, -1):  # start at max_row, stop at row 2
    # 1) Blank row?
    if row_is_blank(r):
        ws.delete_rows(r)
        rows_deleted += 1
        continue
    # 2) Check column C (index 3)
    cell_val = ws.cell(row=r, column=3).value
    # Only act on numeric values
    if isinstance(cell_val, (int, float)):
        if -1 <= cell_val <= 1:
            ws.delete_rows(r)
            rows_deleted += 1

# Save modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice + python formulas)
await recalculate(str(output_path))

# Verify by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[target_sheet_name]
print(f"After deletion: rows = {ws_check.max_row}, columns = {ws_check.max_column}")
print(f"Rows deleted: {rows_deleted}")

# Show a few remaining rows (header + first 5 data rows)
def row_vals(ws, r):
    return [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]

print("Header:", row_vals(ws_check, 1))
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f"Row {r}:", row_vals(ws_check, r))
