import os
import openpyxl
from openpyxl import load_workbook, Workbook
from openpyxl.worksheet.table import Table, TableColumn, TableStyleInfo

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_56786_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_56786_init.xlsx')

# Load workbook (preserve formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Identify header row (row 3 as seen in exploration) and data start row
header_row = 3
first_data_row = header_row + 1  # row 4

# Determine last row that actually contains data in column A (Date)
max_row = ws.max_row
last_data_row = None
for r in range(max_row, header_row, -1):
    if ws.cell(row=r, column=1).value is not None:
        last_data_row = r
        break
if last_data_row is None:
    raise ValueError('No data rows found in column A')

# Define table range (A3:C{last_data_row})
table_ref = f"A{header_row}:C{last_data_row}"

table = Table(displayName="DataTable", ref=table_ref)

# Table style (optional but makes it look nice)
style = TableStyleInfo(name="TableStyleMedium9", showFirstColumn=False,
                       showLastColumn=False, showRowStripes=True, showColumnStripes=False)

table.tableStyleInfo = style

# Define calculated column for rolling average (column C, third column)
# Formula uses structured references: [Beans Counted] and [Date]
# @ symbol refers to the current row in the Table
calc_formula = "=AVERAGEIFS([Beans Counted], [Date], ">" & [@Date]-365, [Date], "<=" & [@Date])"

# TableColumn objects – we need three columns (Date, Beans Counted, Rolling Avg)
col1 = TableColumn(id=1, name="Date")
col2 = TableColumn(id=2, name="Beans Counted")
col3 = TableColumn(id=3, name="12 month rolling average", formula=calc_formula)

table.tableColumns = [col1, col2, col3]

# Add the table to the worksheet (will replace any existing table with same name)
# First, remove any existing table with the same name to avoid duplicates
existing = [t for t in ws._tables if t.name == table.name]
for t in existing:
    ws._tables.remove(t)

ws.add_table(table)

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice) and verify
from await import recalculate
await recalculate(output_path)

# Reload with data_only to check results
wb2 = load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Print a few sample rolling average values (first 5 data rows)
print('Sample rolling average values (first 5 data rows):')
for r in range(first_data_row, min(first_data_row+5, last_data_row+1)):
    val = ws2.cell(row=r, column=3).value
    print(f'Row {r}:', val)

# Also print last 5 rows to ensure formula works at the end
print('Sample rolling average values (last 5 data rows):')
for r in range(max(last_data_row-4, first_data_row), last_data_row+1):
    val = ws2.cell(row=r, column=3).value
    print(f'Row {r}:', val)
```
