Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_7665_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_7665_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
print("Sheets:", wb.sheetnames)

# We'll work with the first sheet (assume that's the one we need)
ws = wb[wb.sheetnames[0]]

# Basic dimensions
print("Max row:", ws.max_row, "Max column:", ws.max_column)

# Header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
print("Headers:", headers)

# Sample rows: first 5 (excluding header) and last 5
def row_values(r):
    return [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]

first_rows = [row_values(r) for r in range(2, min(7, ws.max_row+1))]
last_rows = [row_values(r) for r in range(max(2, ws.max_row-4), ws.max_row+1)]

print("First 5 data rows:")
for r in first_rows:
    print(r)

print("Last 5 data rows:")
for r in last_rows:
    print(r)

# Identify source column H (column index 8)
col_h_idx = 8
col_h_letter = get_column_letter(col_h_idx)
print(f"Column {col_h_letter} values (first 10):")
for r in range(2, min(12, ws.max_row+1)):
    print(r, ws.cell(row=r, column=col_h_idx).value)

# Target range Q2:V2 (columns 17 to 22)
target_cols = list(range(17, 23))
target_cells = [f"{get_column_letter(c)}2" for c in target_cols]
print("Target cells before writing:", {cell: ws[cell].value for cell in target_cells})

# Determine last row with data in column H (simple scan)
last_row_h = 1
for r in range(ws.max_row, 0, -1):
    if ws.cell(row=r, column=col_h_idx).value not in (None, "", " "):
        last_row_h = r
        break
print("Last non‑empty row in column H:", last_row_h)

# Write formulas into Q2:V2
for idx, col in enumerate(target_cols, start=1):
    cell = ws.cell(row=2, column=col)
    # Build formula
    formula = f'''=IFERROR(INDEX(SORT(UNIQUE(${col_h_letter}$2:${col_h_letter}${last_row_h})),COLUMNS($Q$2:{get_column_letter(col)}2)),"")'''
    cell.value = formula

# Save workbook
wb.save(output_path)
print("Workbook saved to:", output_path)
```
