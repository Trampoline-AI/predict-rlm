import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_49801_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_49801_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # only one sheet

# Verify current C1 value
print("Original C1:", ws["C1"].value)

# Write the combined formula into C1
ws["C1"] = "=LEFT(A1,2) & RIGHT(A1,5)"
print("New C1 formula set to:", ws["C1"].value)

# Save to output location
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas using LibreOffice (async)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to read the computed value
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data.active
print("Computed C1 value after recalculation:", ws_data["C1"].value)
