```repl
import openpyxl
from pathlib import Path

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_510-3_init.xlsx"
output_dir = Path("/sandbox/output/output_spreadsheet")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_510-3_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Data"]  # the sheet is named 'Data'

max_row = ws.max_row

# Helper to copy number format from a source cell to a target cell
def copy_number_format(src_cell, tgt_cell):
    tgt_cell.number_format = src_cell.number_format

# Process each data row (starting at row 2)
for r in range(2, max_row + 1):
    # Cells
    d_cell = ws.cell(row=r, column=4)   # D (original date string)
    e_cell = ws.cell(row=r, column=5)   # E (Year)
    f_cell = ws.cell(row=r, column=6)   # F (Month)
    g_cell = ws.cell(row=r, column=7)   # G (Day)
    h_cell = ws.cell(row=r, column=8)   # H (Total days / serial number)

    # Cleaned date string (remove directionality chars and trim)
    # CHAR(8237)=U+202D, CHAR(8238)=U+202C
    clean_date = f"TRIM(SUBSTITUTE(SUBSTITUTE(D{r},CHAR(8237),\"\"),CHAR(8238),\"\"))"

    # Formulas for Year, Month, Day (numeric)
    e_formula = f"=VALUE(LEFT({clean_date},2))"
    f_formula = f"=VALUE(MID({clean_date},4,2))"
    g_formula = f"=VALUE(RIGHT({clean_date},2))"

    # Formula for total days (Excel serial number)
    # Use the newly calculated Year, Month, Day cells (E,F,G)
    h_formula = f"=DATE(E{r}+2000,F{r},G{r})"

    # Write formulas
    e_cell.value = e_formula
    f_cell.value = f_formula
    g_cell.value = g_formula
    h_cell.value = h_formula

    # Preserve original number formats for D‑G
    copy_number_format(d_cell, d_cell)   # D keeps its original date format
    copy_number_format(e_cell, e_cell)   # E keeps its original format (usually General)
    copy_number_format(f_cell, f_cell)   # F keeps its original format
    copy_number_format(g_cell, g_cell)   # G keeps its original format

    # Set H to General format
    h_cell.number_format = "General"

# Save workbook to output path
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas to cache values
result = await recalculate(str(output_path))
print("Recalculate result:", result)

# Reload with data_only to verify evaluated values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2["Data"]
print("\nVerification (first 5 rows, columns D‑H):")
for r in range(2, min(2 + 5, ws2.max_row + 1)):
    d = ws2.cell(row=r, column=4).value
    e = ws2.cell(row=r, column=5).value
    f = ws2.cell(row=r, column=6).value
    g = ws2.cell(row=r, column=7).value
    h = ws2.cell(row=r, column=8).value
    print(f"Row {r}: D={d!r}, E={e!r}, F={f!r}, G={g!r}, H={h!r}")
```
