```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read‑only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_53383_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# Store summary info
sheet_info = {}

for ws in wb.worksheets:
    name = ws.title
    max_row = ws.max_row
    max_col = ws.max_column
    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    # First 5 data rows (skip header)
    first_rows = []
    for r in range(2, min(7, max_row+1)):
        first_rows.append([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    # Last 5 data rows
    last_rows = []
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        last_rows.append([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    sheet_info[name] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers": headers,
        "first_rows": first_rows,
        "last_rows": last_rows,
    }

# Print summary
for name, info in sheet_info.items():
    print(f"Sheet: {name}")
    print(f"  Rows: {info['max_row']}, Columns: {info['max_col']}")
    print(f"  Headers: {info['headers']}")
    print("  First 5 data rows:")
    for row in info["first_rows"]:
        print("    ", row)
    print("  Last 5 data rows:")
    for row in info["last_rows"]:
        print("    ", row)
    print("-"*40)

# Check for a potential result column (e.g., column C) in each sheet
for ws in wb.worksheets:
    if ws.max_column >= 3:
        col_c_vals = [ws.cell(row=r, column=3).value for r in range(2, ws.max_row+1)]
        # Print a few sample values from column C
        print(f"Sample values in column C of sheet {ws.title}: {col_c_vals[:5]}")
        # If column C is empty or contains formulas, note it
        empty = all(v is None for v in col_c_vals[:5])
        print(f"  First 5 cells in column C empty? {empty}")
    print()
