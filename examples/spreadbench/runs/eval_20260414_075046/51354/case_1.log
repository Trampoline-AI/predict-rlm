print("Verification of next‑month results (rows 2‑6):")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f"Row {r}: A={ws_check.cell(r,1).value} -> E={ws_check.cell(r,5).value}")
wb_check.close()
