Code:
```repl
import os
import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet holds the data

# Target range H2:S28
start_row = 2
end_row = ws.max_row  # 28 per inspection
start_col = 8   # column H
end_col = 19    # column S

# Correct aRGB fill colour (alpha FF + RGB E2EFD0)
fill = PatternFill(start_color="FFE2EFD0", end_color="FFE2EFD0", fill_type="solid")

# Insert formula, fill, and number format into each cell of H2:S28
for r in range(start_row, end_row + 1):
    for c in range(start_col, end_col + 1):
        cell = ws.cell(row=r, column=c)
        # Formula: only for rows where B=1 and column offset <= C (runner count)
        formula = (
            f'=IF($B{r}=1,'
            f'IF(COLUMN()-COLUMN($H$1)+1 <= $C{r},'
            f'OFFSET($G{r},COLUMN()-COLUMN($H$1),0),'
            f'""),'
            f'""'
        )
        cell.value = formula
        cell.fill = fill
        # Use General format so whole numbers appear without decimals,
        # non‑whole numbers keep their fractional part.
        cell.number_format = 'General'

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload workbook with calculated values for verification
wb_calc = openpyxl.load_workbook(output_path, data_only=True)
ws_calc = wb_calc[ws.title]

# Verify a few key cells
sample_cells = ["H2", "I2", "J2", "K2", "L2", "H7", "I7", "J7", "K7", "L7"]
print("\nSample verification (value after recalculation):")
for addr in sample_cells:
    print(f"{addr}: {ws_calc[addr].value}")

# Verify fill colour of H2 (should be the specified colour)
fill_check = ws["H2"].fill.start_color.rgb
print("\nFill colour of H2 (RGB aRGB):", fill_check)

# End of processing – the workbook is ready at output_path
```
