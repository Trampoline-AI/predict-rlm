Plan:
1. Write the letters **a‑z** as headers in row 1, columns **E** onward.
2. In row 5, under each header, write a formula that counts that letter in **D5** using  
   `=LEN(D5)-LEN(SUBSTITUTE(LOWER(D5), "a", ""))` (replace **a** with the appropriate letter). This works in LibreOffice.
3. Save the workbook to the output folder, recalculate formulas, reload with `data_only=True`, and print the resulting counts to verify.
4. Finally, submit the output spreadsheet.
Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook for editing
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# Identify source cell (the text to analyse)
source_row = 5
source_col = 4  # D
source_cell = ws.cell(row=source_row, column=source_col)
print("Source cell:", source_cell.coordinate, "value:", source_cell.value)

# Write headers a-z in row 1, starting at column 5 (E)
start_col = 5  # column E
for i, letter in enumerate("abcdefghijklmnopqrstuvwxyz"):
    col_idx = start_col + i
    header_cell = ws.cell(row=1, column=col_idx)
    header_cell.value = letter
    # Write formula in row 5 under each header
    formula_cell = ws.cell(row=source_row, column=col_idx)
    formula = f'=LEN(D{source_row})-LEN(SUBSTITUTE(LOWER(D{source_row}), "{letter}", ""))'
    formula_cell.value = formula

# Save to output path
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to read computed values
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data.active

# Collect and print counts for a‑z from row 5
counts = {}
for i, letter in enumerate("abcdefghijklmnopqrstuvwxyz"):
    col_idx = start_col + i
    cell = ws_data.cell(row=source_row, column=col_idx)
    counts[letter] = cell.value
print("Letter counts from D5:", counts)
```
