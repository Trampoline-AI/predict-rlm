import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_42515_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

# Helper to print a range of rows
def print_rows(ws, start, end):
    for r in range(start, end + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {row_vals}")

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print("\n=== Sheet:", sheet_name, "===")
    print("Max row:", ws.max_row, "Max column:", ws.max_column)
    # Print header row (assume first row)
    header = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print("Header row values:", header)
    # Print first 5 data rows (excluding header)
    data_start = 2
    data_end = min(ws.max_row, data_start + 4)
    print("First data rows:")
    print_rows(ws, data_start, data_end)
    # Print last 5 rows if more than 6 rows total
    if ws.max_row > data_start + 4:
        print("Last 5 rows:")
        print_rows(ws, ws.max_row - 4, ws.max_row)

    # Search for the specific formula text in the sheet
    formula_cells = []
    for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
        for cell in row:
            if isinstance(cell.value, str) and "SUM(1/((1/B5)*$B$8))" in cell.value.replace(" ", ""):
                formula_cells.append(cell.coordinate)
    if formula_cells:
        print("Found formula cells:", formula_cells)
    else:
        print("Formula not found in this sheet.")
