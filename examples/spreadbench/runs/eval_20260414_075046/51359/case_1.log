Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_51359_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_51359_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet2"]

# Determine the data range in column D (the target column)
# Data starts at row 3; find last non‑empty row in column D
start_row = 3
col_letter = "D"
col_idx = openpyxl.utils.column_index_from_string(col_letter)

# Find last row with a numeric value in column D
last_row = start_row
for r in range(start_row, ws.max_row + 1):
    val = ws.cell(row=r, column=col_idx).value
    if isinstance(val, (int, float)):
        last_row = r

# Build the range string for the formula (e.g., D3:D13)
data_range = f"{col_letter}{start_row}:{col_letter}{last_row}"

# Write header in F1
ws["F1"] = "TotalRuns>=2"

# Write the formula in F2
# The formula uses FREQUENCY to get run lengths of 1s in column D
# and then sums only those lengths that are >=2.
# LibreOffice supports FREQUENCY; we wrap with SUMPRODUCT to avoid array‑enter requirement.
formula = (
    f"=SUMPRODUCT("
    f"(FREQUENCY(IF({data_range}=1,ROW({data_range})),IF({data_range}=0,ROW({data_range})))>=2)*"
    f"FREQUENCY(IF({data_range}=1,ROW({data_range})),IF({data_range}=0,ROW({data_range})))"
    f")"
)
ws["F2"] = formula

# Save to output directory
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify the result
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet2"]
result = ws_check["F2"].value
print("Result in F2 after recalculation:", result)
```
