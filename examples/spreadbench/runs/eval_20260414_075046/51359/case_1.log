    print("\n=== Last 5 rows ===")
    start = max(2, ws.max_row - 4)  # start before header
    for r in range(start, ws.max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(row_vals)

# Identify columns that contain only 0/1 values (potential target)
candidate_cols = []
for c in range(1, ws.max_column + 1):
    col_vals = [ws.cell(row=r, column=c).value for r in range(2, ws.max_row + 1)]
    # Check if all non‑None values are 0 or 1
    if all(v in (0, 1, None) for v in col_vals):
        candidate_cols.append((c, get_column_letter(c)))

print("\nColumns that appear to contain only 0/1 values:", candidate_cols)
