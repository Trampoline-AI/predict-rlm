import openpyxl
from pathlib import Path

# Load the input spreadsheet path
input_path = Path(input_spreadsheet)
print(f"Loading workbook from: {input_path}")

# Open workbook in read-only mode for inspection
wb = openpyxl.load_workbook(input_path, data_only=False)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Iterate over sheets and print basic info
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {sheet_name}")
    print(f"Rows: {max_row}, Columns: {max_col}")
    # Get header row (assume first row contains headers)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(row_vals)
    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(row_vals)

