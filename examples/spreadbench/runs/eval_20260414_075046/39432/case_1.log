import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read-only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_39432_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print("\n--- Sheet:", sheet_name, "---")
    print("Max row:", ws.max_row, "Max column:", ws.max_column)

    # Print header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print("Headers:", headers)

    # Print first 5 data rows (rows 2-6)
    print("First 5 data rows:")
    for r in range(2, min(ws.max_row, 6) + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)

    # Print last 5 data rows (excluding header)
    start_last = max(2, ws.max_row - 4)
    print("Last 5 data rows:")
    for r in range(start_last, ws.max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
