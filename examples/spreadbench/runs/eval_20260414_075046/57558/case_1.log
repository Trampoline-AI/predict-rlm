import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_57558_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_57558_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets
lookup_ws = wb["RateHurdles"]
target_ws = wb["Deposits"]

# Determine the last row with data in Deposits (ignore completely empty rows)
max_row = target_ws.max_row
# Ensure we only write into rows that have a Type (column B) value
for r in range(2, max_row + 1):
    type_cell = target_ws.cell(row=r, column=2)   # column B
    if type_cell.value is None:
        # stop if we hit a blank type (assume data ends)
        continue

    # Build the SUMIFS formula
    formula = (
        "=SUMIFS(RateHurdles!E:E, RateHurdles!C:C, B{row}, "
        "RateHurdles!D:D, C{row}, RateHurdles!A:A, \"<=\"&D{row}, "
        "RateHurdles!B:B, \">=\"&D{row})"
    ).format(row=r)

    # Write formula into column A (Commission Rate)
    target_ws.cell(row=r, column=1).value = formula

# Save to output location
wb.save(output_path)
wb.close()

# Recalculate formulas (LibreOffice backend)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to see evaluated values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2["Deposits"]

print("\nEvaluated Commission Rates:")
for r in range(2, ws2.max_row + 1):
    rate = ws2.cell(row=r, column=1).value
    print(f"Row {r}: {rate}")

wb2.close()
