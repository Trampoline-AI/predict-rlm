    print(f"Row {r}: {ws_data.cell(row=r, column=track_col_idx).value}")

print("Last 5 Track No values after recalculation:")
start = max(2, ws_data.max_row - 4)
for r in range(start, ws_data.max_row + 1):
    print(f"Row {r}: {ws_data.cell(row=r, column=track_col_idx).value}")
