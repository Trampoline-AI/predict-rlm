import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_16511_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_16511_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
print("Workbook loaded:", input_path)

# List sheet names
print("Sheet names:", wb.sheetnames)

# For each sheet, print row count and column headers
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {sheet_name}")
    print(f"  Max row: {max_row}, Max column: {max_col}")

    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("  Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("  First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"    Row {r}: {row_vals}")

    # Print last 5 data rows
    print("  Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"    Row {r}: {row_vals}")

# Save a copy (unchanged) to output path for later steps
wb.save(output_path)
print("Saved copy to:", output_path)
