```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read‑only is fine for inspection)
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

print("Workbook loaded from:", wb_path)

# 1. List sheet names
print("\nSheet names:", wb.sheetnames)

# 2. For each sheet, print row count and column headers
for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # 3. Sample rows: first 5 and last 5 (excluding header)
    sample_start = []
    for r in range(2, min(2+5, max_row+1)):
        sample_start.append([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    print("First 5 data rows:", sample_start)

    sample_end = []
    start_last = max(2, max_row-4)
    for r in range(start_last, max_row+1):
        sample_end.append([ws.cell(row=r, column=c).value for c in range(1, max_col+1)])
    print("Last 5 data rows:", sample_end)

    # 4. Find cells containing "SUM" (case‑insensitive) or array formulas
    sum_cells = []
    for row in ws.iter_rows(min_row=2, max_row=max_row, max_col=max_col):
        for cell in row:
            if isinstance(cell.value, str) and "SUM" in cell.value.upper():
                sum_cells.append((cell.coordinate, cell.value))
            # Detect ArrayFormula objects
            if hasattr(cell.value, "text") and "SUM" in cell.value.text.upper():
                sum_cells.append((cell.coordinate, cell.value.text))
    print(f"Cells with SUM in formula ({len(sum_cells)}):", sum_cells[:10])

    # 5. Print A13 (row 13, column 1) if it exists
    if max_row >= 13:
        a13 = ws.cell(row=13, column=1).value
        print("Value of A13:", a13)
    else:
        print("Sheet has fewer than 13 rows; no A13.")
```
