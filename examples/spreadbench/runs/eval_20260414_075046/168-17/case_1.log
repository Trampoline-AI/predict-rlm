Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path('/sandbox/input/input_spreadsheet/1_168-17_init.xlsx')
output_dir = Path('/sandbox/output/output_spreadsheet/')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / '1_168-17_init.xlsx'

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Target sheet
sheet_name = 'Statement'
if sheet_name not in wb.sheetnames:
    raise ValueError(f"Sheet '{sheet_name}' not found in workbook")
ws = wb[sheet_name]

# Determine first row containing 'Invoice No.'
target = 'Invoice No.'
first_row = None
for r in range(1, ws.max_row + 1):
    val = ws.cell(row=r, column=1).value
    if isinstance(val, str) and val.strip() == target:
        first_row = r
        break

if first_row is None:
    raise ValueError(f"'{target}' not found in column A of sheet '{sheet_name}'")

# Delete all rows before the first occurrence
rows_to_delete = first_row - 1
if rows_to_delete > 0:
    ws.delete_rows(1, rows_to_delete)
    print(f"Deleted {rows_to_delete} rows from sheet '{sheet_name}'.")
else:
    print("No rows need to be deleted.")

# Save to output path
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas (if any)
await recalculate(str(output_path))

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[sheet_name]
print("After recalculation, A1 value:", ws_check['A1'].value)
```
