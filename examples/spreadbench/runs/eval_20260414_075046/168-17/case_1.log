import openpyxl
from pathlib import Path

# Load the workbook
wb_path = Path('/sandbox/input/input_spreadsheet/1_168-17_init.xlsx')
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print('Sheet names:', wb.sheetnames)

# Find the 'Statement' sheet
sheet_name = 'Statement'
if sheet_name not in wb.sheetnames:
    print(f"Sheet '{sheet_name}' not found!")
else:
    ws = wb[sheet_name]
    # Print dimensions
    print(f"Sheet '{sheet_name}' dimensions: rows={ws.max_row}, columns={ws.max_column}")
    # Print header row (first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print('Header row:', headers)
    # Print first 5 data rows (excluding header)
    print('First 5 data rows:')
    for r in range(2, min(ws.max_row, 6) + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    # Print last 5 data rows
    print('Last 5 data rows:')
    start = max(2, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    # Scan column A for first occurrence of 'Invoice No.'
    target = 'Invoice No.'
    first_row = None
    for r in range(1, ws.max_row + 1):
        cell_val = ws.cell(row=r, column=1).value
        if isinstance(cell_val, str) and cell_val.strip() == target:
            first_row = r
            break
    if first_row is None:
        print(f"'{target}' not found in column A.")
    else:
        print(f"First occurrence of '{target}' found at row {first_row}.")
