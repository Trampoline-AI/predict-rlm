import openpyxl, json
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = '/sandbox/input/input_spreadsheet/1_48365_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
sheet_names = wb.sheetnames
print('Sheet names:', sheet_names)

# Function to print header and sample rows for a sheet

def inspect_sheet(ws, max_rows=5):
    # Determine max column based on first row
    max_col = ws.max_column
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f'\nSheet: {ws.title}')
    print('Headers:', headers)
    # Print first few rows
    print('First rows:')
    for r in range(2, min(max_rows+2, ws.max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last few rows
    print('Last rows:')
    start = max(ws.max_row - max_rows + 1, 2)
    for r in range(start, ws.max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Inspect each sheet
for name in sheet_names:
    ws = wb[name]
    inspect_sheet(ws)
