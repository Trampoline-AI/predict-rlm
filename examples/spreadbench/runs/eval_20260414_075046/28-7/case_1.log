Code:
```repl
import os, re
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_28-7_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet'
output_path = os.path.join(output_dir, '1_28-7_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume the relevant sheet is the active one

# Determine the column that holds the part numbers.
# Based on inspection, it's column A (index 1). If needed, we could search for the first column containing a value matching '^400-'.
part_col = 1

# Gather ranges to delete
delete_ranges = []  # list of (start_row, end_row) inclusive
max_row = ws.max_row
r = 2  # start after header row
while r <= max_row:
    cell_val = ws.cell(row=r, column=part_col).value
    if isinstance(cell_val, str) and re.fullmatch(r'400-.*-A', cell_val):
        start = r
        # Find the next part number that starts with '400-'
        r_next = r + 1
        while r_next <= max_row:
            next_val = ws.cell(row=r_next, column=part_col).value
            if isinstance(next_val, str) and re.match(r'^400-.*', next_val):
                break
            r_next += 1
        # End is the row before the next part number (or the last row if none found)
        end = r_next - 1
        delete_ranges.append((start, end))
        # Continue scanning from the next part number (or beyond the sheet)
        r = r_next
    else:
        r += 1

# Delete rows from bottom to top to keep indices stable
for start, end in sorted(delete_ranges, key=lambda x: x[0], reverse=True):
    n = end - start + 1
    if n > 0:
        ws.delete_rows(start, amount=n)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

print('Deletion completed.')
print('Deleted ranges:', delete_ranges)
print('New max row:', ws.max_row)
```
