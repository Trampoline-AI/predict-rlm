import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

def move_column_to_B(ws):
    # Find header row (assume first row)
    max_col = ws.max_column
    header_row = 1
    target_header = "0-15"
    orig_col = None
    for c in range(1, max_col + 1):
        val = ws.cell(row=header_row, column=c).value
        if val == target_header:
            orig_col = c
            break
    if orig_col is None:
        # Header not present in this sheet
        return False

    # Insert new column at B (index 2)
    ws.insert_cols(2)

    # After insertion, the original column shifts right by 1
    src_col = orig_col + 1
    dst_col = 2  # column B

    max_row = ws.max_row

    # Copy values (including formulas) from src_col to dst_col
    for r in range(1, max_row + 1):
        src_cell = ws.cell(row=r, column=src_col)
        dst_cell = ws.cell(row=r, column=dst_col)
        dst_cell.value = src_cell.value

    # Delete the now‑duplicate original column
    ws.delete_cols(src_col)

    return True

# Apply to all sheets
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    moved = move_column_to_B(ws)
    if moved:
        print(f"Moved column '0-15' to B in sheet '{sheet_name}'")
    else:
        print(f"No '0-15' header found in sheet '{sheet_name}'")

# Save modified workbook
