Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_203-15_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_203-15_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify the main sheet (first sheet that is not "Output Required")
main_sheet_name = next(name for name in wb.sheetnames if name.lower() != "output required")
main_ws = wb[main_sheet_name]

# Ensure Output Required sheet exists
out_name = "Output Required"
if out_name in wb.sheetnames:
    out_ws = wb[out_name]
else:
    out_ws = wb.create_sheet(title=out_name)

# Clear existing data in Output Required sheet
for row in out_ws.iter_rows(min_row=1, max_row=out_ws.max_row,
                           min_col=1, max_col=out_ws.max_column):
    for cell in row:
        cell.value = None

# 1. Copy headers A1‑G1 from main to output (row 1)
for col_idx in range(1, 8):  # columns A (1) to G (7)
    src = main_ws.cell(row=1, column=col_idx).value
    out_ws.cell(row=1, column=col_idx, value=src)

# 2. Gather distinct allowance names from column H (column 8), preserving order
seen = set()
allowance_vals = []
for row in range(2, main_ws.max_row + 1):
    val = main_ws.cell(row=row, column=8).value
    if val is None:
        continue
    if val not in seen:
        seen.add(val)
        allowance_vals.append(val)

# 3. Write allowance names transposed into row 2 starting at column H (index 8)
start_col = 8  # column H
for i, val in enumerate(allowance_vals):
    out_ws.cell(row=2, column=start_col + i, value=val)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook to output path
wb.save(output_path)

# Recalculate formulas (async)
await recalculate(output_path)

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
out_check = wb_check[out_name]

# Verification output
print("Headers in Output Required (row 1, A‑G):")
print([out_check.cell(row=1, column=c).value for c in range(1, 8)])

print("\nTransposed allowance values (row 2, starting at H):")
for c in range(start_col, start_col + len(allowance_vals)):
    print(f"{get_column_letter(c)}2:", out_check.cell(row=2, column=c).value)
```
