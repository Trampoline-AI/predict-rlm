import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_203-15_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_203-15_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify main sheet (assume the first sheet that is not 'Output Required')
main_sheet_name = None
for name in wb.sheetnames:
    if name.lower() != "output required":
        main_sheet_name = name
        break
if not main_sheet_name:
    raise ValueError("Main sheet not found")
main_ws = wb[main_sheet_name]

# Ensure Output Required sheet exists (create if missing)
output_sheet_name = "Output Required"
if output_sheet_name in wb.sheetnames:
    out_ws = wb[output_sheet_name]
else:
    out_ws = wb.create_sheet(title=output_sheet_name)

# Clear existing data in Output Required sheet (optional but safe)
for row in out_ws.iter_rows(min_row=1, max_row=out_ws.max_row, min_col=1, max_col=out_ws.max_column):
    for cell in row:
        cell.value = None

# 1. Copy headers A1‑G1 from main to output (row 1)
for col_idx in range(1, 8):  # 1‑based index for A‑G
    src_cell = main_ws.cell(row=1, column=col_idx)
    out_ws.cell(row=1, column=col_idx, value=src_cell.value)

# 2. Gather allowance names from column H (starting row 2)
allowance_vals = []
for row in range(2, main_ws.max_row + 1):
    val = main_ws.cell(row=row, column=8).value  # column H = 8
    if val is None:
        # stop at first blank if you want, but continue to collect all non‑blank
        continue
    allowance_vals.append(val)

# 3. Write allowance names transposed into row 2 starting at column H (index 8)
start_col = 8  # column H
for i, val in enumerate(allowance_vals):
    out_ws.cell(row=2, column=start_col + i, value=val)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook to output path
wb.save(output_path)

# Recalculate formulas (async call) – ensure we await it
await recalculate(output_path)

# Reload with data_only to verify target cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
out_check = wb_check[output_sheet_name]

# Print verification info (headers and first few allowance cells)
print("Verification - Headers in Output Required:")
print([out_check.cell(row=1, column=c).value for c in range(1, 8)])
print("Verification - Allowance values transposed (row 2, cols H‑):")
for c in range(start_col, start_col + len(allowance_vals)):
    print(f"{get_column_letter(c)}2:", out_check.cell(row=2, column=c).value)
