import openpyxl
from openpyxl.utils import get_column_letter
import datetime
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_58942_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_58942_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Define timeline range
start_date = datetime.date(2018, 1, 1)
end_date   = datetime.date(2020, 12, 31)
total_days = (end_date - start_date).days + 1  # inclusive
target_max_row = 1 + total_days  # header row + data rows

# Write formulas for Timeline (column A)
for r in range(2, target_max_row + 1):
    ws.cell(row=r, column=1).value = "=DATE(2018,1,1)+ROW()-2"

# Write formulas for SourceDate (column B) and SourceValue (column C)
lookup_range = "$E$2:$F$6"
date_lookup_range = "$E$2:$E$6"
for r in range(2, target_max_row + 1):
    # SourceDate (B) – returns the date if found, else blank
    ws.cell(row=r, column=2).value = f'=IFERROR(VLOOKUP(A{r},{date_lookup_range},1,FALSE),"")'
    # SourceValue (C) – returns the corresponding value if found, else blank
    ws.cell(row=r, column=3).value = f'=IFERROR(VLOOKUP(A{r},{lookup_range},2,FALSE),"")'

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
await recalculate(output_path)

# Verify a few rows after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Sample verification (first 5 rows after header):")
for r in range(2, 7):
    date_val = ws_check.cell(row=r, column=1).value
    src_date = ws_check.cell(row=r, column=2).value
    src_val  = ws_check.cell(row=r, column=3).value
    print(f"Row {r}: Timeline={date_val}, SourceDate={src_date}, SourceValue={src_val}")

print("... last 5 rows:")
for r in range(target_max_row-4, target_max_row+1):
    date_val = ws_check.cell(row=r, column=1).value
    src_date = ws_check.cell(row=r, column=2).value
    src_val  = ws_check.cell(row=r, column=3).value
    print(f"Row {r}: Timeline={date_val}, SourceDate={src_date}, SourceValue={src_val}")
