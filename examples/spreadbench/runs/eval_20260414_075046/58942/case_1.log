import openpyxl
from openpyxl.utils import get_column_letter
import datetime
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_58942_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_58942_init.xlsx")

# Load workbook with formulas
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# --- Diagnostics: print source data types ---
print("Source cells (E2:E6) values and types:")
for r in range(2, 7):
    cell = ws.cell(row=r, column=5)  # column E
    print(f"E{r}:", cell.value, type(cell.value))

print("\nSource cells (F2:F6) values and types:")
for r in range(2, 7):
    cell = ws.cell(row=r, column=6)  # column F
    print(f"F{r}:", cell.value, type(cell.value))

# --- Verify a specific row where a match should exist ---
# Row for date 2019-01-03 (should be row 369 given timeline start 2018-01-01)
target_row = 2 + (datetime.date(2019,1,3) - datetime.date(2018,1,1)).days
print(f"\nTarget row for 2019-01-03 is {target_row}")

# Load the recalculated file (or recalculate if not yet)
# Ensure we have the latest formulas written (they were written in previous step)
# Save current state (in case we need to recalc)
wb.save(output_path)
await recalculate(output_path)

# Reload with data only to see evaluated results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("\nValues after recalculation for target row:")
print("Timeline (A):", ws_check.cell(row=target_row, column=1).value)
print("SourceDate (B):", ws_check.cell(row=target_row, column=2).value)
print("SourceValue (C):", ws_check.cell(row=target_row, column=3).value)

# --- Print formulas for a few rows to verify correctness ---
print("\nFormulas in first few rows (A2:C5):")
for r in range(2, 6):
    a_form = ws.cell(row=r, column=1).value
    b_form = ws.cell(row=r, column=2).value
    c_form = ws.cell(row=r, column=3).value
    print(f"Row {r}: A={a_form}, B={b_form}, C={c_form}")

# If VLOOKUP is failing, we will replace with Python-computed values for the known source dates.
# Build a dict of source date -> value
source_dict = {}
for r in range(2, 7):
    date_cell = ws.cell(row=r, column=5).value  # E column
    val_cell = ws.cell(row=r, column=6).value   # F column
    if isinstance(date_cell, datetime.datetime) or isinstance(date_cell, datetime.date):
        # Normalize to date (strip time)
        date_key = date_cell.date() if isinstance(date_cell, datetime.datetime) else date_cell
        source_dict[date_key] = val_cell

print("\nSource mapping (date -> value):")
for k, v in source_dict.items():
    print(k, "->", v)

# --- Apply Python-computed values for SourceDate and SourceValue ---
# Write timeline formulas (as before) but write actual values for B and C using the dict.
start_date = datetime.date(2018, 1, 1)
end_date   = datetime.date(2020, 12, 31)
total_days = (end_date - start_date).days + 1
target_max_row = 1 + total_days

for r in range(2, target_max_row + 1):
    # Timeline formula (keep as formula)
    ws.cell(row=r, column=1).value = "=DATE(2018,1,1)+ROW()-2"
    # Compute the date for this row
    cur_date = start_date + datetime.timedelta(days=r-2)
    # Write SourceDate (B) as the date if present, else blank
    if cur_date in source_dict:
        ws.cell(row=r, column=2).value = cur_date
        ws.cell(row=r, column=3).value = source_dict[cur_date]
    else:
        ws.cell(row=r, column=2).value = None
        ws.cell(row=r, column=3).value = None

# Save and recalc again
wb.save(output_path)
await recalculate(output_path)

# Reload for final verification
wb_final = openpyxl.load_workbook(output_path, data_only=True)
ws_final = wb_final[wb_final.sheetnames[0]]

print("\nFinal verification (first 5 rows after header):")
for r in range(2, 7):
    print(r, ws_final.cell(r,1).value, ws_final.cell(r,2).value, ws_final.cell(r,3).value)

print("\nFinal verification (target row 369 for 2019-01-03):")
print(ws_final.cell(369,1).value, ws_final.cell(369,2).value, ws_final.cell(369,3).value)

print("\nLast 5 rows:")
for r in range(target_max_row-4, target_max_row+1):
    print(r, ws_final.cell(r,1).value, ws_final.cell(r,2).value, ws_final.cell(r,3).value)
