Code:
```repl
import openpyxl
import os
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_57445_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_57445_init.xlsx")
os.makedirs(output_dir, exist_ok=True)

# Load workbook (preserve formulas for any other cells)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Locate worksheets (case‑insensitive)
pricing_ws = None
pkg_ws = None
for name in wb.sheetnames:
    low = name.lower()
    if "pricing" in low:
        pricing_ws = wb[name]
    if "package" in low and "weight" in low:
        pkg_ws = wb[name]

if pricing_ws is None or pkg_ws is None:
    raise RuntimeError("Required worksheets not found.")

# -------------------------------------------------------------------------
# 1. Load Package & Weight Data into a list of dicts for fast lookup
# -------------------------------------------------------------------------
pkg_records = []
for r in range(2, pkg_ws.max_row + 1):  # data starts at row 2
    pkg_type = pkg_ws.cell(row=r, column=column_index_from_string('A')).value
    weight_from = pkg_ws.cell(row=r, column=column_index_from_string('B')).value
    weight_to = pkg_ws.cell(row=r, column=column_index_from_string('C')).value
    price = pkg_ws.cell(row=r, column=column_index_from_string('D')).value
    # Only keep rows that have a valid package type and price
    if pkg_type is not None and price is not None:
        pkg_records.append({
            "type": pkg_type,
            "from": weight_from,
            "to": weight_to,
            "price": price
        })

# -------------------------------------------------------------------------
# 2. For each row in Pricing, compute the matching price and write it to E
# -------------------------------------------------------------------------
col_c = column_index_from_string('C')
col_d = column_index_from_string('D')
col_e = column_index_from_string('E')

for r in range(2, pricing_ws.max_row + 1):
    pkg_type = pricing_ws.cell(row=r, column=col_c).value
    weight = pricing_ws.cell(row=r, column=col_d).value

    matched_price = 0  # default if no match
    if pkg_type is not None and weight is not None:
        for rec in pkg_records:
            if rec["type"] == pkg_type and rec["from"] <= weight <= rec["to"]:
                matched_price = rec["price"]
                break  # first match is enough

    # Write the price (as a literal value) into column E
    pricing_ws.cell(row=r, column=col_e).value = matched_price

# -------------------------------------------------------------------------
# 3. Save, recalculate, and verify
# -------------------------------------------------------------------------
wb.save(output_path)

# Recalculate (not strictly needed for literal values, but keep the step)
await recalculate(output_path)

# Reload with data_only=True to read the cached values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[pricing_ws.title]

print("\nVerification – first 5 rows of column E (Post Cost):")
for r in range(2, min(7, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=col_e).value
    print(f"Row {r}: E={val}")

print("\nVerification – last 5 rows of column E (Post Cost):")
for r in range(max(2, ws_check.max_row - 4), ws_check.max_row + 1):
    val = ws_check.cell(row=r, column=col_e).value
    print(f"Row {r}: E={val}")
