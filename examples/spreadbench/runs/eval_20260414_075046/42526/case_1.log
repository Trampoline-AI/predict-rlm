ws2 = wb2[wb2.sheetnames[0]]

# Print a few sample rows to verify mapping
print("Sample evaluated points:")
for r in [2, 3, 4, 5, 12, 14, 15]:  # a selection of rows
    val = ws2.cell(row=r, column=1).value
    pts = ws2.cell(row=r, column=2).value
    print(f"Row {r}: value={val}, points={pts}")
