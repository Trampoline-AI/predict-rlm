import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook (read/write mode)
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Use the first sheet (assuming that's the one we need)
ws = wb[wb.sheetnames[0]]

# Determine dimensions
max_row = ws.max_row
max_col = ws.max_column
print(f"Sheet '{ws.title}' dimensions: {max_row} rows, {max_col} columns")

# Print header row (assume first row is header)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Headers:", headers)

# Helper to print a range of rows

def print_rows(start, end):
    for r in range(start, end+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

# Print first 5 data rows (excluding header)
print("\nFirst 5 data rows:")
print_rows(2, min(6, max_row))

# Print last 5 data rows
