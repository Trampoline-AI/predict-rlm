Code:
```repl
import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_178-22_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_178-22_init.xlsx")

# Load workbook
wb = load_workbook(input_path)

# Ensure Sheet2 exists (create or clear)
if "Sheet2" in wb.sheetnames:
    ws_out = wb["Sheet2"]
    # Clear existing rows (keep sheet but remove all cells)
    ws_out.delete_rows(1, ws_out.max_row)  # remove everything
else:
    ws_out = wb.create_sheet("Sheet2")

# Reference Sheet1
ws_in = wb["Sheet1"]

# Copy headers from Sheet1 (row 1) to Sheet2 row 2 (A2)
for col in range(1, ws_in.max_column + 1):
    header = ws_in.cell(row=1, column=col).value
    ws_out.cell(row=2, column=col, value=header)

# Collect matching rows
matching_rows = []
for r in range(2, ws_in.max_row + 1):
    item = ws_in.cell(row=r, column=2).value  # column B
    cls = ws_in.cell(row=r, column=3).value   # column C
    if item == "TELIVISION" or cls in ("CLASS III", "CLASS IV"):
        # Extract entire row values (columns 1..max_column)
        row_vals = [ws_in.cell(row=r, column=c).value for c in range(1, ws_in.max_column + 1)]
        matching_rows.append(row_vals)

# Write matching rows to Sheet2 starting at row 3
out_row = 3
for row_vals in matching_rows:
    for col, val in enumerate(row_vals, start=1):
        ws_out.cell(row=out_row, column=col, value=val)
    out_row += 1

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Verify: reload with data_only=True and print a quick summary
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet2"]
print("Sheet2 headers:", [ws_check.cell(row=2, column=c).value for c in range(1, ws_check.max_column+1)])
print("Number of data rows written:", ws_check.max_row - 2)
# Print first few rows of data for sanity
for r in range(3, min(3+5, ws_check.max_row+1)):
    print(r, [ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column+1)])
