import openpyxl
from pathlib import Path
from openpyxl.utils import get_column_letter

# Paths (same as previous iteration)
input_path = Path("/sandbox/input/input_spreadsheet/1_208-20_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_208-20_init.xlsx"

# Load workbook (the copy we saved earlier)
wb = openpyxl.load_workbook(output_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Identify header row (row 2) and data start row
header_row = 2
data_start = header_row + 1
max_row = ws.max_row
max_col = ws.max_column

# Helper to get cell value (including formulas as strings)
def get_cell_value(row, col):
    cell = ws.cell(row=row, column=col)
    return cell.value

# Extract all data rows into a list of lists
data_rows = []
for r in range(data_start, max_row + 1):
    row_vals = [get_cell_value(r, c) for c in range(1, max_col + 1)]
    data_rows.append(row_vals)

# Sort by column 5 (E) descending; treat None as very small
def sort_key(row):
    val = row[4]  # column 5 is index 4 (0‑based)
    # If the value is a formula (string starting with '=') we cannot evaluate it here,
    # but column E should contain numbers or None, not formulas.
    if isinstance(val, (int, float)):
        return val
    else:
        # None or non‑numeric -> treat as -inf
        return float("-inf")

data_rows.sort(key=sort_key, reverse=True)

# Write sorted rows back to the sheet
for i, row_vals in enumerate(data_rows, start=data_start):
    for c, val in enumerate(row_vals, start=1):
        ws.cell(row=i, column=c).value = val

# Save the workbook
