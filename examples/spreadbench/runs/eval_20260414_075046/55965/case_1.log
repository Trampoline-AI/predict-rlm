import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_55965_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print header and sample rows
def print_sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"\n=== Sheet: {ws.title} ===")
    print("Headers:", headers)
    # First 5 data rows (skip header)
    print("First 5 rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Last 5 rows
    print("Last 5 rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Iterate over all sheets
for ws in wb.worksheets:
    print_sheet_summary(ws)

# 2. Inspect specific columns of interest
# Assume Sheet1 exists; find it
sheet1 = wb["Sheet1"] if "Sheet1" in wb.sheetnames else None
if sheet1:
    # Show column E (ID) sample
    print("\nSheet1 column E (ID) sample values:")
    for r in range(2, min(7, sheet1.max_row+1)):
        print(f"E{r} =", sheet1.cell(row=r, column=5).value)
    # Show columns G-P (target area) sample
    print("\nSheet1 columns G-P (target) sample values (first 5 rows):")
    for r in range(2, min(7, sheet1.max_row+1)):
        vals = [sheet1.cell(row=r, column=c).value for c in range(7, 17)]  # G=7, P=16
        print(f"Row {r} G-P:", vals)

# Identify the data sheet (the one that is not Sheet1)
data_sheet = None
for name in wb.sheetnames:
    if name != "Sheet1":
        data_sheet = wb[name]
        break
if data_sheet:
    print(f"\nAssumed data sheet: {data_sheet.title}")
    # Show column K (ID) sample
    print("Data sheet column K (ID) sample values:")
    for r in range(2, min(7, data_sheet.max_row+1)):
        print(f"K{r} =", data_sheet.cell(row=r, column=11).value)
    # Show a few columns G-P of data sheet as well (just to see if they hold any data)
    print("\nData sheet columns G-P sample values (first 5 rows):")
    for r in range(2, min(7, data_sheet.max_row+1)):
        vals = [data_sheet.cell(row=r, column=c).value for c in range(7, 17)]
        print(f"Row {r} G-P:", vals)
else:
    print("No second sheet found besides Sheet1.")
