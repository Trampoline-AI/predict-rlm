Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_55965_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_55965_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify sheets (Foglio1 is the target, DATI is the source)
if "Foglio1" not in wb.sheetnames:
    raise ValueError("Target sheet 'Foglio1' not found")
if "DATI" not in wb.sheetnames:
    raise ValueError("Source sheet 'DATI' not found")

target_ws = wb["Foglio1"]
source_ws = wb["DATI"]

# Helper to get column values (1‑indexed column) for a given row range

def get_col_values(ws, col_idx, start_row, end_row):
    return [ws.cell(row=r, column=col_idx).value for r in range(start_row, end_row + 1)]

# 1. Collect IDs from Foglio1 column E (index 5), rows 2..max_row
target_ids = set()
for r in range(2, target_ws.max_row + 1):
    val = target_ws.cell(row=r, column=5).value
    if val is not None:
        target_ids.add(val)

# 2. Scan DATI rows, keep those where column K (index 11) is in target_ids
matching_rows = []  # list of row numbers in source_ws that match
for r in range(2, source_ws.max_row + 1):
    id_val = source_ws.cell(row=r, column=11).value  # column K
    if id_val in target_ids:
        matching_rows.append(r)

# 3. Take the last 10 matching rows (or fewer if not enough)
last_10 = matching_rows[-10:]

# 4. Copy columns G‑P (indices 7‑16) from each selected source row into Foglio1 rows 2‑... sequentially
start_target_row = 2
for i, src_row in enumerate(last_10):
    tgt_row = start_target_row + i
    # Ensure target row exists (openpyxl will create cells as needed)
    for col_idx in range(7, 17):  # 7 to 16 inclusive
        src_val = source_ws.cell(row=src_row, column=col_idx).value
        target_ws.cell(row=tgt_row, column=col_idx).value = src_val

# Save to output directory (create if needed)
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
# Note: recalculate is an async function; we will call it in the next turn after this block.
print(f"Saved modified workbook to {output_path}")
print(f"Number of target rows written: {len(last_10)}")
print(f"Target rows start at {start_target_row}, end at {start_target_row + len(last_10) - 1}")
