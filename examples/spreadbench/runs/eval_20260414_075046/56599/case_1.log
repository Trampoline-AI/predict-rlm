os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_56599_init.xlsx')

# Load workbook (the one we previously saved with the formula in B2)
wb = openpyxl.load_workbook(output_path)
ws = wb[wb.sheetnames[0]]

# Helper to recalc and reload data_only for verification
async def recalc_and_reload():
    await recalculate(output_path)
    wb_data = openpyxl.load_workbook(output_path, data_only=True)
    ws_data = wb_data[ws.title]
    return ws_data['B2'].value, ws_data['M5'].value

# 1. Test with a valid slip number (first slip in the sheet)
ws['M5'].value = 5871001  # known start slip from row 6
wb.save(output_path)
# Recalculate and check B2
b2_val, m5_val = await recalc_and_reload()
print('After setting M5=5871001 -> B2:', b2_val, 'M5:', m5_val)

# 2. Reset M5 to blank and verify error message
ws['M5'].value = None
wb.save(output_path)
b2_val, m5_val = await recalc_and_reload()
print('After clearing M5 -> B2:', b2_val, 'M5:', m5_val)

# 3. Ensure final workbook is saved (already saved above)
print('Final workbook saved at', output_path)
