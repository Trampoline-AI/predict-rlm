Code:
```repl
import openpyxl
import re
import os
from pathlib import Path

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_585-41_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
output_path = os.path.join(output_dir, "1_585-41_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb["Sheet1"]

# Process cells A1:H1 (row 1, columns 1-8)
for col in range(1, 9):
    cell = ws.cell(row=1, column=col)
    val = cell.value
    if isinstance(val, str):
        # Keep only digits and decimal points
        cleaned = re.sub(r'[^0-9.]', '', val)
        cell.value = cleaned
    # If numeric (int/float), leave as is

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload with data_only to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2["Sheet1"]
updated_vals = [ws2.cell(row=1, column=col).value for col in range(1, 9)]
print("Updated A1:H1 values:", updated_vals)
```
