import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook with formulas
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume single sheet

max_row = ws.max_row
max_col = ws.max_column

# Define lookup range (template rows 2‑6, columns B‑H)
lookup_range = "$B$2:$H$6"

# Helper to get column letter
def col_letter(idx): return get_column_letter(idx)

# Scan rows to detect any missing/invalid class entries
problem_rows = []
for r in range(2, max_row + 1):
    day_val = ws.cell(row=r, column=2).value  # column B
    if not isinstance(day_val, (int, float)):
        continue  # skip rows without a numeric day
    for c in range(3, 9):  # columns C‑H
        cell = ws.cell(row=r, column=c)
        if cell.value is None:
            problem_rows.append((r, c, "empty"))
        elif isinstance(cell.value, str) and cell.value.startswith("#"):
            problem_rows.append((r, c, "error"))

print(f"Found {len(problem_rows)} problem cells (empty or error).")
if problem_rows:
    # Show a few examples
    for i, (r, c, typ) in enumerate(problem_rows[:10]):
        print(f"Row {r} Col {col_letter(c)} ({typ}): {ws.cell(r, c).value}")

# If any errors are due to day >5, replace with IFERROR+MOD formula
for r, c, typ in problem_rows:
    day_val = ws.cell(row=r, column=2).value
    # Build formula with IFERROR and MOD to wrap day into 1‑5 range
    col_index = c - 1  # VLOOKUP column index relative to B
    formula = (
        f"=IFERROR(VLOOKUP($B{r}, {lookup_range}, {col_index}, FALSE), "
        f"VLOOKUP(MOD($B{r}-1,5)+1, {lookup_range}, {col_index}, FALSE))"
    )
    ws.cell(row=r, column=c).value = formula

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to verify values
