            remaining_errors.append((r, c, v))

print(f"Remaining error cells after fix: {len(remaining_errors)}")
if remaining_errors:
    for r, c, v in remaining_errors[:5]:
        print(f"Row {r} Col {col_letter(c)}: {v}")
