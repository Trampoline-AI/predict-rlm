import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assuming single sheet as observed

max_row = ws.max_row
max_col = ws.max_column

# Define the lookup range (template rows 2‑6, columns B‑H)
lookup_start_row = 2
lookup_end_row = 6
lookup_start_col = 2  # column B
lookup_end_col = 8    # column H
lookup_range = f"${get_column_letter(lookup_start_col)}${lookup_start_row}:${get_column_letter(lookup_end_col)}${lookup_end_row}"

# Fill formulas for rows 7‑(max_row-1) (skip header and template rows, also skip final row with text)
for r in range(lookup_end_row + 1, max_row + 1):
    day_val = ws.cell(row=r, column=2).value  # column B
    # Skip rows where day is not a number (e.g., final text row)
    if not isinstance(day_val, (int, float)):
        continue
    # For each period column C‑H (3‑8)
    for c in range(3, 9):
        cell = ws.cell(row=r, column=c)
        if cell.value is None:
            # column index for VLOOKUP (relative to column B as 1)
            col_index = c - 1  # B=1, C=2, etc.
            cell.value = f"=VLOOKUP($B{r}, {lookup_range}, {col_index}, FALSE)"

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas (LibreOffice backend)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to see evaluated values
