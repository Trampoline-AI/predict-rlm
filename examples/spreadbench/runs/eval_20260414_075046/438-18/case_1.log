import openpyxl
from openpyxl import load_workbook
import os
import asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_438-18_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_438-18_init.xlsx")

# Load workbook (keep formulas, though we will write literals)
wb = load_workbook(input_path, data_only=False)

# Identify sheets (the output sheet is named "OUPUT" in the file)
ws_in = wb["INPUT"]
ws_out = wb["OUPUT"]

# Mapping for origin replacement
origin_map = {
    "UNATIDE STATES AMERICAN": "USA",
    "FRANCE": "FRA",
    "KOREA": "KOR",
    "GERMANY": "GR",
    "ITALY": "IT",
}

# Ensure output sheet has enough rows (it already does, but just in case)
if ws_out.max_row < ws_in.max_row:
    ws_out.append([None] * ws_out.max_column)  # extend if needed

# Copy and replace data
for r in range(2, ws_in.max_row + 1):
    item = ws_in.cell(row=r, column=1).value          # A
    brands = ws_in.cell(row=r, column=3).value        # C
    typ = ws_in.cell(row=r, column=5).value           # E
    origin = ws_in.cell(row=r, column=6).value       # F
    # Replace origin using mapping; if not found, keep original
    new_origin = origin_map.get(origin, origin)

    # Write to OUPUT (columns A-D)
    ws_out.cell(row=r, column=1).value = item
    ws_out.cell(row=r, column=2).value = brands
    ws_out.cell(row=r, column=3).value = typ
    ws_out.cell(row=r, column=4).value = new_origin

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload with data_only to verify
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check["OUPUT"]
print("\n--- Verification: OUPUT sheet rows ---")
for r in range(2, ws_check.max_row + 1):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column + 1)]
    print(r, row_vals)
```
