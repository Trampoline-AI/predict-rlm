import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_38703_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_38703_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# 1. Unmerge all merged cells
merged_ranges = list(ws.merged_cells.ranges)
for mr in merged_ranges:
    ws.unmerge_cells(str(mr))

# 2. Write unique count formula into H10
# Formula: =SUMPRODUCT(1/COUNTIF(E2:E10, E2:E10))
ws["H10"] = "=SUMPRODUCT(1/COUNTIF(E2:E10, E2:E10))"

# Save to output path
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to read the computed value
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("H10 computed value after recalculation:", ws2["H10"].value)
```
