import openpyxl, os, json
from openpyxl.utils import get_column_letter, column_index_from_string

# Load the workbook (read/write mode)
wb_path = '/sandbox/input/input_spreadsheet/1_55049_init.xlsx'
wb = openpyxl.load_workbook(wb_path)
print('Workbook sheets:', wb.sheetnames)

# Function to print sheet overview

def sheet_overview(ws, max_rows=5):
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f'\nSheet: {ws.title}')
    print('Headers:', headers)
    # Print first few data rows
    print('First data rows:')
    for r in range(2, min(2+max_rows, ws.max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)
    # Print last few data rows
    if ws.max_row > max_rows+2:
        print('Last data rows:')
        for r in range(ws.max_row-max_rows+1, ws.max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
            print(r, row_vals)

# Iterate over sheets and show overview
for ws in wb.worksheets:
    sheet_overview(ws)
