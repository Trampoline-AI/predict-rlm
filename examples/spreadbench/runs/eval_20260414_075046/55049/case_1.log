import openpyxl, os
from openpyxl.utils import get_column_letter, column_index_from_string

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_55049_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_55049_init.xlsx')

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Identify sheets
ws1 = wb['book1']
ws2 = wb['book2']

# Determine the last row with data in book2 (ignoring completely empty rows at bottom)
# We'll scan column A which always has the Place ID when present.
max_row_book2 = ws2.max_row
while max_row_book2 > 1 and ws2.cell(row=max_row_book2, column=1).value is None:
    max_row_book2 -= 1
print(f'book2 data rows: 2 to {max_row_book2}')

# Build absolute range strings for columns A, H, I, J in book2
row_start = 2  # assuming row 1 is header
row_end = max_row_book2
col_A_range = f'book2!$A${row_start}:${{row_end}}'
col_H_range = f'book2!$H${row_start}:${{row_end}}'
col_I_range = f'book2!$I${row_start}:${{row_end}}'
col_J_range = f'book2!$J${row_start}:${{row_end}}'

# Write formula into book1 column B for each data row (starting at row 2)
for r in range(2, ws1.max_row + 1):
    place_id = ws1.cell(row=r, column=1).value
    # Skip rows where Place ID is None
    if place_id is None:
        continue
    # Construct formula using SUMPRODUCT to sum H+I+J where A matches.
    # Using absolute references to the ranges defined above.
    formula = f"=SUMPRODUCT(({col_A_range}=book1!A{r})*({col_H_range}+{col_I_range}+{col_J_range}))"
    ws1.cell(row=r, column=2).value = formula

# Save workbook to output path
wb.save(output_path)
print('Workbook saved to', output_path)

# Recalculate formulas (LibreOffice) using provided tool
# The recalculate function is async; we will await it in the next turn.
