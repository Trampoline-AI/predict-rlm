1. Load the workbook.
2. Determine the current month and year.
3. For each sheet, identify column indices whose header (row 1) is a datetime earlier than the current month/year.
4. Delete those columns, processing from rightmost to leftmost to keep indices stable.
5. Save the modified workbook to the output directory with the same filename.
6. Call `recalculate` on the saved file, reload it with `data_only=True`, and print the remaining headers for verification.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
from datetime import datetime, date
import os
import shutil

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Current month/year
today = date.today()
cur_year = today.year
cur_month = today.month

def is_earlier(dt):
    """Return True if dt (datetime or date) is earlier than current month/year."""
    if isinstance(dt, datetime):
        dt_year = dt.year
        dt_month = dt.month
    elif isinstance(dt, date):
        dt_year = dt.year
        dt_month = dt.month
    else:
        return False
    return (dt_year < cur_year) or (dt_year == cur_year and dt_month < cur_month)

# Process each sheet
for ws in wb.worksheets:
    max_col = ws.max_column
    # Collect column indices to delete (1‑based)
    cols_to_delete = []
    for col_idx in range(1, max_col + 1):
        header_val = ws.cell(row=1, column=col_idx).value
        if is_earlier(header_val):
            cols_to_delete.append(col_idx)
    # Delete from rightmost to leftmost to avoid shifting
    for col_idx in sorted(cols_to_delete, reverse=True):
        ws.delete_cols(col_idx, amount=1)

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload with data_only to verify headers after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)

print("Verification of remaining headers after deletion:")
for ws in wb_check.worksheets:
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print(f"Sheet '{ws.title}': {headers}")

# Clean up the original workbook object
del wb, wb_check
```
