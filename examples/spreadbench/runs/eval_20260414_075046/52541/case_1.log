import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string

# Load the workbook
wb_path = input_spreadsheet  # path provided by the environment
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n=== Sheet: {sheet_name} ===")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # 2. Print header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # 3. Find column indexes for relevant columns
    def col_idx(name):
        try:
            return headers.index(name) + 1
        except ValueError:
            return None

    idx_overdue = col_idx("Over Due Days")
    idx_amount = col_idx("Amount Outstanding")
    idx_remarks = col_idx("Remarks")  # might be column J or named "Remarks"
    print("Column indices -> Over Due Days:", idx_overdue,
          "Amount Outstanding:", idx_amount,
          "Remarks:", idx_remarks)

    # 4. Print first 5 data rows (excluding header)
    print("\nFirst 5 data rows:")
    for r in range(2, min(2 + 5, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(r, row_vals)

    # 5. Print last 5 data rows
    print("\nLast 5 data rows:")
    start = max(2, max_row - 4)
    for r in range(start, max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(r, row_vals)

    # 6. Print sample formulas in the remarks column (if any)
    if idx_remarks:
        print("\nSample formulas/values in Remarks column:")
        for r in range(2, min(2 + 5, max_row + 1)):
            cell = ws.cell(row=r, column=idx_remarks)
            print(f"R{r}C{idx_remarks} ->", cell.value)
