import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_50796_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Determine dimensions
max_row = ws.max_row
max_col = ws.max_column

# Add header for new column D (index 4) if not already present
header_cell = ws.cell(row=1, column=4)
header_cell.value = "Sum if TV"

# Fill column D with IF formula per row
for r in range(2, max_row + 1):
    ws.cell(row=r, column=4).value = f'=IF(B{r}="TV",C{r},0)'

# Add a total sum row after the last data row
total_row = max_row + 1
ws.cell(row=total_row, column=4).value = f'=SUM(D2:D{max_row})'
ws.cell(row=total_row, column=3).value = "Total TV"

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only=True to read evaluated values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Verify the total cell value
total_value = ws_check.cell(row=total_row, column=4).value
print(f"Total TV (cell D{total_row}) after recalculation:", total_value)
