ws = wb.active  # the main sheet is active

# Helper to write a SUMIFS formula for a given row (category) and year column
def make_sumifs(start_row, end_row, keyword, col_c, col_f, start_date_cell, end_date_cell=None):
    """
    Returns a SUMIFS formula string.
    - start_row, end_row: rows for the data range (e.g., 8‑37)
    - keyword: string to match in column H (e.g., "*PE*")
    - col_c, col_f: column letters for values and dates (e.g., "C", "F")
    - start_date_cell: cell reference for lower bound date (e.g., "$K$43")
    - end_date_cell: optional cell reference for upper bound date (e.g., "$L$43")
    """
    # Build range strings with absolute references
    val_range = f"${col_c}${start_row}:${col_c}${end_row}"
    crit_range = f"${col_h}${start_row}:${col_h}${end_row}"
    date_range = f"${col_f}${start_row}:${col_f}${end_row}"
    # Criteria parts
    crit1 = f'"{keyword}"'  # text match
    crit2 = f">=\"&{start_date_cell}"
    if end_date_cell:
        crit3 = f"<\"&{end_date_cell}"
        formula = f"=SUMIFS({val_range},{crit_range},\"{keyword}\",{date_range},{crit2},{date_range},{crit3})"
    else:
        formula = f"=SUMIFS({val_range},{crit_range},\"{keyword}\",{date_range},{crit2})"
    return formula

# Define the groups with their row offsets and keyword
groups = [
    {"label_row": 39, "data_start": 8, "data_end": 37, "keyword": "*PE*"},   # PE group rows 40‑42
    {"label_row": 44, "data_start": 8, "data_end": 37, "keyword": "*GS*"},   # GF group rows 45‑47
    {"label_row": 49, "data_start": 8, "data_end": 37, "keyword": "*CC*"},   # CC group rows 50‑52
]

# The category rows are three rows after each label row (Rentals, Sales, Commercial)
