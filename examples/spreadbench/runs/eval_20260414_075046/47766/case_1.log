# Year columns K‑O correspond to column indices 11‑15
year_cols = list(range(11, 16))  # 11=K, 12=L, 13=M, 14=N, 15=O

# Write formulas for each group
for grp in groups:
    label_row = grp["label_row"]
    data_start = grp["data_start"]
    data_end = grp["data_end"]
    keyword = grp["keyword"]
    for offset in category_offsets:
        row = label_row + offset  # actual row for Rentals/Sales/Commercial
        for idx, col_idx in enumerate(year_cols):
            # Determine start date cell (row 43, same column)
            start_date_cell = f"${get_column_letter(col_idx)}$43"
            # Determine end date cell (next column) unless this is the last year column
            if idx < len(year_cols) - 1:
                end_date_cell = f"${get_column_letter(year_cols[idx + 1])}$43"
            else:
                end_date_cell = None
            # Build formula
            formula = make_sumifs(
                start_row=data_start,
                end_row=data_end,
                keyword=keyword,
                col_c="C",
                col_f="F",
                start_date_cell=start_date_cell,
                end_date_cell=end_date_cell,
            )
            # Write formula into the cell (column = col_idx, row = row)
            ws.cell(row=row, column=col_idx, value=formula)

# Save to output directory
