import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read-only is fine for inspection)
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=False)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print sheet summary
def print_sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{ws.title}': rows={max_row}, columns={max_col}")

    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # First 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # Last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

# 2. Iterate through sheets and print summaries
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print_sheet_summary(ws)

# 3. Specific check for the target column in Sheet1 (column C)
sheet1 = wb["Sheet1"]
col_c_letter = get_column_letter(3)  # column index 3 = C
print("\nValues currently in column C of Sheet1 (first 10 rows):")
for r in range(1, min(11, sheet1.max_row+1)):
    val = sheet1.cell(row=r, column=3).value
    print(f"C{r}:", val)

# 4. Check Data sheet ranges used in the example formula
data_ws = wb["Data"]
print("\nData sheet dimensions:")
print(f"Rows: {data_ws.max_row}, Columns: {data_ws.max_column}")

# Show a small portion of the Data sheet to verify ranges
print("Data sheet sample (rows 2-5, columns B-E):")
for r in range(2, 6):
    row_vals = [data_ws.cell(row=r, column=c).value for c in range(2, 6)]
    print(f"Row {r}:", row_vals)

# Save nothing inspection (no changes made)
wb.close()
