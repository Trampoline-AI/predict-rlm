Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# --- Step 1: Aggregate Amount per unique ID (columns A and D) ---
id_amounts = {}
for row in range(2, ws.max_row + 1):
    id_val = ws.cell(row=row, column=1).value  # Column A
    amt_val = ws.cell(row=row, column=4).value  # Column D
    if id_val is None:
        continue  # skip empty rows
    # Ensure amount is numeric; treat non‑numeric as 0
    try:
        amt = float(amt_val) if amt_val is not None else 0.0
    except (TypeError, ValueError):
        amt = 0.0
    id_amounts[id_val] = id_amounts.get(id_val, 0.0) + amt

# --- Step 2: Determine where to place the summary table ---
# Find first completely empty column after existing data (max_column)
# We'll start at max_column + 1 (should be column K in this file)
start_col = ws.max_column + 1
id_header_col = start_col
total_header_col = start_col + 1

# Write headers
ws.cell(row=1, column=id_header_col).value = "Unique ID"
ws.cell(row=1, column=total_header_col).value = "Total Amount"

# Write each ID and its total
out_row = 2
for uid, total in sorted(id_amounts.items()):
    ws.cell(row=out_row, column=id_header_col).value = uid
    ws.cell(row=out_row, column=total_header_col).value = total
    out_row += 1

# --- Step 3: Save the workbook ---
wb.save(output_path)

# --- Step 4: Recalculate formulas (LibreOffice) ---
recalc_result = await recalculate(output_path)  # async call
print("Recalculate result:", recalc_result)

# --- Step 5: Verify the written values ---
# Reload with data_only to see cached results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Collect verification data
verification = []
for r in range(2, out_row):
    uid = ws_check.cell(row=r, column=id_header_col).value
    total = ws_check.cell(row=r, column=total_header_col).value
    verification.append((uid, total))

print("Verification (first 10 rows):", verification[:10])
```
