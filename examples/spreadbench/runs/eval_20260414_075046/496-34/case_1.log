import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (keep formulas)
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)

print("Sheet names:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Helper to fetch a row as list
    def row_vals(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]

    # First 5 data rows (rows 2‑6)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row + 1)):
        print(f"Row {r}:", row_vals(r))

    # Last 5 data rows (excluding header)
    print("Last 5 data rows:")
    start = max(2, max_row - 4)
    for r in range(start, max_row + 1):
        print(f"Row {r}:", row_vals(r))

    # Detect merged cells overlapping columns F‑H (6‑8)
    merged_f_to = []
    for rng in ws.merged_cells.ranges:
        # rng.min_col / max_col are numeric column indices (1‑based)
        if max(rng.min_col, 6) <= min(rng.max_col, 8):
            merged_f_to.append(str(rng))
    if merged_f_to:
        print("Merged cell ranges in columns F‑H:", merged_f_to)
    else:
        print("No merged cells in columns F‑H.")
