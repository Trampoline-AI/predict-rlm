import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet  # variable provided by the environment
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Explore each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Print column headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Function to get row values as list
    def row_values(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]

    # Print first 5 data rows (rows 2-6)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row + 1)):
        print(f"Row {r}:", row_values(r))

    # Print last 5 data rows (excluding header)
    print("Last 5 data rows:")
    start = max(2, max_row - 4)
    for r in range(start, max_row + 1):
        print(f"Row {r}:", row_values(r))

    # Check for merged cells in columns F:H (6-8)
    merged_in_f_to = [rng for rng in ws.merged_cells.ranges if any(
        get_column_letter(cell.column) in ["F", "G", "H"] for cell in rng.cells)]
    if merged_in_f_to:
        print("Merged cell ranges in columns F-H:", merged_in_f_to)
    else:
        print("No merged cells in columns F-H.")
