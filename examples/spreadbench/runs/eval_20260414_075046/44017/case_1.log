```repl
import os
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# Column indices
col_AD = column_index_from_string('AD')
col_AO = column_index_from_string('AO')
col_Q = column_index_from_string('Q')   # baseline start
offset = col_AD - col_Q  # should be 13 (AD->Q)

# Helper to build formula for a given month column and row
def build_formula(row, month_col_idx):
    month_letter = get_column_letter(month_col_idx)
    # Baseline column = month column - offset
    baseline_idx = month_col_idx - offset
    baseline_letter = get_column_letter(baseline_idx)
    # Cells references
    start_date = f"$L{row}"
    month_header = f"{month_letter}$9"
    baseline_cell = f"{baseline_letter}{row}"
    freq_cell = f"$J{row}"
    # Percentage cells (absolute column letters)
    perc_M = f"$M{row}"
    perc_N = f"$N{row}"
    perc_O = f"$O{row}"
    perc_P = f"$P{row}"
    # Formula string
    formula = (
        f"=IF({start_date}<={month_header},"
        f"{baseline_cell}*"
        f"(1+IFERROR(CHOOSE(MIN(4,1+INT(DATEDIF({start_date},{month_header},\"M\")/{freq_cell})),"
        f"{perc_M},{perc_N},{perc_O},{perc_P}),0)),"
        f"\"\")"
    )
    return formula

# Write formulas for all rows >=14 and columns AD-AO
first_data_row = 14
last_row = ws.max_row

for r in range(first_data_row, last_row + 1):
    for col_idx in range(col_AD, col_AO + 1):
        cell = ws.cell(row=r, column=col_idx)
        cell.value = build_formula(r, col_idx)

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice + python formulas)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to verify a few cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Verify first few rows for columns AD and AO
print("\nVerification samples (rows 14-16, columns AD and AO):")
for r in range(14, 17):
    val_AD = ws_check.cell(row=r, column=col_AD).value
    val_AO = ws_check.cell(row=r, column=col_AO).value
    print(f"Row {r}: AD={val_AD}, AO={val_AO}")

# If any of the verified cells are None, raise an error for debugging
if any(ws_check.cell(row=r, column=col_AD).value is None for r in range(14, 17)):
    raise RuntimeError("Verification failed: some AD cells are empty after recalculation.")
if any(ws_check.cell(row=r, column=col_AO).value is None for r in range(14, 17)):
    raise RuntimeError("Verification failed: some AO cells are empty after recalculation.")
```
