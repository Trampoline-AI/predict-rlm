The next step is to verify that the allocations are consistent with the inventory data (total allocated per item should not exceed total incoming). We will compute the totals in Python and print a summary. If everything matches, we will submit the output spreadsheet.
Code:
```python
import os
import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (formulas present)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

max_row_ws1 = ws1.max_row

# Write allocation formula into column H (8) for each data row
for r in range(2, max_row_ws1 + 1):
    formula = (
        f"=MAX(0, MIN(G{r}, "
        f"SUMIF(Sheet2!$B:$B, D{r}, Sheet2!$D:$D) - "
        f"SUMIFS($H$2:H{r-1}, $D$2:D{r-1}, D{r})))"
    )
    ws1.cell(row=r, column=8).value = formula

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas using LibreOffice backend
await recalculate(output_path)

# Reload workbook with evaluated values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
ws_inv = wb_check["Sheet2"]

# Verify allocations: compute total incoming per item and total allocated per item
incoming_totals = {}
for r in range(2, ws_inv.max_row + 1):
    item_code = ws_inv.cell(r, 2).value
    qty = ws_inv.cell(r, 4).value
    if item_code is None or qty is None:
        continue
    incoming_totals[item_code] = incoming_totals.get(item_code, 0) + qty

allocated_totals = {}
for r in range(2, ws_check.max_row + 1):
    item_code = ws_check.cell(r, 4).value
    allocated = ws_check.cell(r, 8).value
    if item_code is None or allocated is None:
        continue
    allocated_totals[item_code] = allocated_totals.get(item_code, 0) + allocated

print("Incoming totals per item code:")
for code, qty in incoming_totals.items():
    print(f"{code}: {qty}")

print("\nAllocated totals per item code (after formula evaluation):")
for code, qty in allocated_totals.items():
    print(f"{code}: {qty}")

# Show a few sample rows with allocation results
print("\nSample allocation rows (first 10):")
for r in range(2, min(12, ws_check.max_row + 1)):
    print(f"Row {r}: Order No={ws_check.cell(r,1).value}, Item code={ws_check.cell(r,4).value}, Order Qty={ws_check.cell(r,7).value}, Allocated={ws_check.cell(r,8).value}")
```
