import os
import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Re‑load the workbook we previously saved (contains BN values)
wb = openpyxl.load_workbook(output_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Column indices
col_BL = column_index_from_string('BL')   # 64
col_BN = column_index_from_string('BN')   # 66

# Correct fill (ARGB – include alpha FF)
fill_style = PatternFill(start_color="FF0070C0", end_color="FF0070C0", fill_type="solid")

# Apply fill where BL = "LAG" and BN is populated (non‑None, non‑empty)
for r in range(2, ws.max_row + 1):
    bl_cell = ws.cell(row=r, column=col_BL)
    bn_cell = ws.cell(row=r, column=col_BN)
    if bl_cell.value == "LAG" and bn_cell.value not in (None, "", " "):
        bl_cell.fill = fill_style

# Save changes
wb.save(output_path)

# Recalculate (required by workflow)
await recalculate(output_path)

# Reload with data_only to verify BN values (fills are not retained in data_only mode,
# so we check fills on the original workbook object)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Verification of BN values and BL fill for rows where BL='LAG':")
for r in range(2, ws_check.max_row + 1):
    if ws_check.cell(row=r, column=col_BL).value == "LAG":
        bn_val = ws_check.cell(row=r, column=col_BN).value
        # Check fill on the original (non‑data_only) workbook
        fill_rgb = ws.cell(row=r, column=col_BL).fill.start_color.rgb
        fill_applied = fill_rgb == "FF0070C0"
        print(f"Row {r}: BN='{bn_val}', BL fill applied={fill_applied}")
```
