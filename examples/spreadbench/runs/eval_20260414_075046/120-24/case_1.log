import os
import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas, we will write values)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume single sheet

# Column indices
col_BL = column_index_from_string('BL')   # 64
col_BG = column_index_from_string('BG')   # 33
col_AY = column_index_from_string('AY')   # 51
col_BN = column_index_from_string('BN')   # 66

# Sets for quick lookup
bg_allowed = {
    "OCOGS - Spares - Transfer Price Overhead",
    "OFSS - ORCL Consulting Prod Cost I/C"
}
ay_allowed = {"BOA_033E", "BOA_011G"}

# Fill style for BL cells
fill_style = PatternFill(start_color="0070C0", end_color="0070C0", fill_type="solid")

# Process rows
for r in range(2, ws.max_row + 1):
    bl_val = ws.cell(row=r, column=col_BL).value
    bg_val = ws.cell(row=r, column=col_BG).value
    ay_val = ws.cell(row=r, column=col_AY).value

    # Only act when BL == "LAG" and BG matches one of the two strings
    if bl_val == "LAG" and bg_val in bg_allowed:
        # Determine which string to write into BN
        if ay_val in ay_allowed:
            bn_value = "OCOGS - Spares - Transfer Price Overhead"
        else:
            bn_value = "OFSS - ORCL Consulting Prod Cost I/C"

        # Write to BN
        ws.cell(row=r, column=col_BN).value = bn_value

        # Apply fill to BL cell (since BN is now populated)
        ws.cell(row=r, column=col_BL).fill = fill_style

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (required by workflow)
await recalculate(output_path)

# Reload with data_only to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Verify a few rows (matching rows we identified earlier)
print("Verification of BN values and BL fill for rows where BL='LAG':")
for r in range(2, ws_check.max_row + 1):
    if ws_check.cell(row=r, column=col_BL).value == "LAG":
        bn_val = ws_check.cell(row=r, column=col_BN).value
        # Openpyxl does not keep fill info when loading data_only, so we check the original workbook for fill
        fill_present = ws.cell(row=r, column=col_BL).fill.start_color.rgb == "FF0070C0"
        print(f"Row {r}: BN='{bn_val}', BL fill applied={fill_present}")
```
