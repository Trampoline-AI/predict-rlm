import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = input_spreadsheet  # e.g., /sandbox/input/input_spreadsheet/initial.xlsx
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "initial.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Determine max row for clearing later
max_row = ws.max_row

# Formula template (will replace row number dynamically)
# Uses two‑criteria MATCH for primary (B2) and secondary (B3) headers.
formula_template = (
    '=IFERROR('
    'ROUND('
    'INDEX($BD$3:$BR$81, '
    'MATCH($A{row}, $BD$3:$BD$81, 0), '
    'MATCH(1, ($BD$2:$BR$2=$B$2)*($BD$3:$BR$3=$B$3), 0)'
    '), 0), '
    '"-")'
)

# Write formulas into D4:D7
for r in range(4, 8):
    cell = ws[f"D{r}"]
    cell.value = formula_template.format(row=r)

# Clear any values below row 7 in columns C and D
for r in range(8, max_row + 1):
    ws[f"C{r}"].value = None
    ws[f"D{r}"].value = None

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only=True to read evaluated values
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data[ws.title]  # same sheet name

# Verify D4:D7 values
print("Evaluated D4:D7 values after recalculation:")
for r in range(4, 8):
    print(f"D{r}:", ws_data[f"D{r}"].value)
```
