import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_463-17_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_463-17_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active

# Helper: get first empty row in column D (row 1 is header)
def first_empty_row_in_column(col_idx):
    for r in range(2, ws.max_row + 2):
        if ws.cell(row=r, column=col_idx).value in (None, ""):
            return r
    return ws.max_row + 1

first_empty = first_empty_row_in_column(4)  # column D = 4
print(f"First empty row in column D: {first_empty}")

# Gather company -> count from columns A and B
company_counts = {}
for r in range(2, ws.max_row + 1):
    name = ws.cell(row=r, column=1).value
    cnt = ws.cell(row=r, column=2).value
    if name is not None and cnt is not None:
        company_counts[name] = int(cnt)

print("Company counts:", company_counts)

# Count existing occurrences in column D up to the row before first empty
existing_counts = {}
for r in range(2, first_empty):
    val = ws.cell(row=r, column=4).value
    if val is not None:
        existing_counts[val] = existing_counts.get(val, 0) + 1

print("Existing counts in column D:", existing_counts)

# Build list of missing entries preserving original order (A column order)
missing_entries = []
for r in range(2, ws.max_row + 1):
    name = ws.cell(row=r, column=1).value
    if name is None:
        continue
    total_needed = company_counts.get(name, 0)
    already = existing_counts.get(name, 0)
    to_add = total_needed - already
    if to_add > 0:
        missing_entries.extend([name] * to_add)
        # Update existing_counts so later rows don't double‑count
        existing_counts[name] = existing_counts.get(name, 0) + to_add

print(f"Missing entries to write ({len(missing_entries)}):", missing_entries[:10], "...")

# Write missing entries into column D starting at first_empty
row = first_empty
for entry in missing_entries:
    ws.cell(row=row, column=4, value=entry)
    row += 1

# Save to output path
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas (if any) and verify
import asyncio

async def recalc_and_verify():
    # Recalculate using the provided tool
    result = await recalculate(output_path)
    print("Recalculate result:", result)

    # Reload with data_only to see cached values
    wb2 = openpyxl.load_workbook(output_path, data_only=True)
    ws2 = wb2.active

    # Print a few rows from column D to verify
    print("Column D after recalculation (rows 2-30):")
    for r in range(2, 31):
        print(f"D{r} = {ws2.cell(r, 4).value}")

await recalc_and_verify()
