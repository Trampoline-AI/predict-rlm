Code:
```repl
import openpyxl
from openpyxl.styles import PatternFill
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_379-36_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_379-36_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# Process each sheet
for ws in wb.worksheets:
    max_row = ws.max_row
    for r in range(2, max_row + 1):  # assume header is row 1
        cell_E = ws.cell(row=r, column=5)   # column E
        cell_F = ws.cell(row=r, column=6)   # column F
        cell_H = ws.cell(row=r, column=8)   # column H

        # 1. Update column E based on the text and amount
        if isinstance(cell_E.value, str) and cell_E.value == "Georgia Its Tax":
            # Determine if column F is a whole number (no pennies)
            val = cell_F.value
            if isinstance(val, (int, float)):
                if val == int(val):
                    cell_E.value = "Georgia WH Tax"
                else:
                    cell_E.value = "Georgia Sales Tax"
            else:
                # If not numeric, leave as is (or could set to Sales Tax as fallback)
                cell_E.value = "Georgia Sales Tax"

        # 2. Ensure column H is empty and has no background colour
        cell_H.value = None
        cell_H.fill = PatternFill(fill_type=None)  # clear any fill

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify a few rows after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
for ws in wb_check.worksheets:
    print(f"\nVerification for sheet: {ws.title}")
    # Show first 5 rows where column E was possibly changed
    for r in range(2, min(ws.max_row, 7)):
        e_val = ws.cell(row=r, column=5).value
        f_val = ws.cell(row=r, column=6).value
        h_val = ws.cell(row=r, column=8).value
        print(f"Row {r}: E={e_val!r}, F={f_val!r}, H={h_val!r}")
```
