import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_469-9_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_469-9_init.xlsx")

# Load workbook (write mode, keep formulas)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Write headers for new columns H and I
ws.cell(row=1, column=8, value="Debits")   # Column H
ws.cell(row=1, column=9, value="Credits")  # Column I

max_row = ws.max_row

# Write formulas for each data row
for r in range(2, max_row + 1):
    # Column H (Debits): absolute value if amount > 0
    ws.cell(row=r, column=8).value = f"=IF(C{r}>0,ABS(C{r}),\"\")"
    # Column I (Credits): absolute value if amount < 0
    ws.cell(row=r, column=9).value = f"=IF(C{r}<0,ABS(C{r}),\"\")"

# Save to output path
wb.save(output_path)

# Recalculate formulas using LibreOffice (via provided tool)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload workbook with data_only to read evaluated values
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data[wb_data.sheetnames[0]]

# Verify a few rows of the new columns
print("\nVerification of new columns (first 5 data rows):")
for r in range(2, min(7, ws_data.max_row + 1)):
    debit = ws_data.cell(row=r, column=8).value
    credit = ws_data.cell(row=r, column=9).value
    amount = ws_data.cell(row=r, column=3).value
    print(f"Row {r}: Amount={amount}, Debits={debit}, Credits={credit}")
```
