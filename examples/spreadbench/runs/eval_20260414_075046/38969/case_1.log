```repl
import os
from pathlib import Path
from openpyxl import load_workbook
from openpyxl.utils import column_index_from_string, get_column_letter

# Paths
input_path = Path('/sandbox/input/input_spreadsheet/1_38969_init.xlsx')
output_dir = Path('/sandbox/output/output_spreadsheet/')
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (read/write)
wb = load_workbook(filename=input_path, data_only=False)
print('Sheet names:', wb.sheetnames)

# Use the first sheet (assuming only one)
ws = wb[wb.sheetnames[0]]

# Determine max row/col
max_row = ws.max_row
max_col = ws.max_column
print(f'Max row: {max_row}, max col: {max_col}')

# Print header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print('Headers:', headers)

# Show sample rows: first 5 and last 5 (excluding header)
print('First 5 data rows:')
for r in range(2, min(2+5, max_row+1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

print('Last 5 data rows:')
for r in range(max(max_row-4, 2), max_row+1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Identify column indexes for S, U, and R (target)
col_S = column_index_from_string('S')
col_U = column_index_from_string('U')
col_R = column_index_from_string('R')
print('Column indices -> S:', col_S, 'U:', col_U, 'R:', col_R)

# Build the formula string (no leading '=')
# Formula: IF(ISERROR(S2),"Upload",IF(AND(U2>=-1,U2<=1),"Do not Upload",IF(U2>1,"to Check","")))
formula_template = "=IF(ISERROR({s}),\"Upload\",IF(AND({u}>=-1,{u}<=1),\"Do not Upload\",IF({u}>1,\"to Check\",\"\")))"

# Write formula to each row in column R, starting at row 2
for r in range(2, max_row+1):
    s_cell = f"S{r}"
    u_cell = f"U{r}"
    ws.cell(row=r, column=col_R).value = formula_template.format(s=s_cell, u=u_cell)

# Save to output path
wb.save(output_path)
print('Saved workbook to', output_path)

# Recalculate formulas using LibreOffice (async call)
# Note: we need to await recalculate, but in this REPL block we can just schedule it.
# We'll store the result in a variable for later verification.
recalc_result = await recalculate(str(output_path))
print('Recalculate result:', recalc_result)

# Reload with data_only to see evaluated values
wb2 = load_workbook(filename=output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
# Verify a few rows (2, 3, last row)
for r in [2, 3, max_row]:
    val = ws2.cell(row=r, column=col_R).value
    print(f'Row {r} column R evaluated value:', val)
```
