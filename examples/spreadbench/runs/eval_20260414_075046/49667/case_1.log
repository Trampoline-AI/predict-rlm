output_path = os.path.join(output_dir, "1_49667_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row
max_col = ws.max_column

# Column letters for reference
col_F = get_column_letter(column_index_from_string("F"))  # "F"
col_AT = get_column_letter(column_index_from_string("AT"))  # "AT"

# Pre‑build the static parts of the formulas (row‑independent)
header_range = "$F$1:$AT$1"   # time headers
slot_range_template = "${F}${row}:${AT}${row}"  # will be formatted per row

for r in range(2, max_row + 1):
    # Build the per‑row range strings
    slot_range = f"$F${r}:$AT${r}"
    
    # ----- First block -----
    # Start1: first "m"
    start1_formula = (
        f'=IFERROR(INDEX({header_range}, MATCH("m", {slot_range}, 0)), "")'
    )
    # Finish1: column after last "m" of first block
    finish1_formula = (
        f'=IFERROR(INDEX({header_range}, MATCH(2, 1/({slot_range}="m"), 0) + 1), "")'
    )
    
    # ----- Second block -----
    # Compute the column index of the last "m" in the first block (relative to the whole sheet)
    # This is used inside the formula; we embed it directly.
    # last1_col = MATCH(2,1/(F2:AT2="m"),0)
    # offset = last1_col - COLUMN($F$1) + 1
    # start2 range = OFFSET(F2,0,offset,1,45-offset)
    # start2 = MATCH("m", start2_range,0) + offset
    # finish2 = MATCH(2,1/(start2_range="m"),0) + offset + 1
    
    start2_formula = (
        f'=IFERROR('
        f'INDEX({header_range}, '
        f'  MATCH("m", '
        f'    OFFSET($F${r}, 0, '
        f'      MATCH(2, 1/({slot_range}="m"), 0) - COLUMN($F$1) + 1, '
        f'      1, '
        f'      45 - (MATCH(2, 1/({slot_range}="m"), 0) - COLUMN($F$1) + 1) '
        f'    ), 0 '
        f'  ) + MATCH(2, 1/({slot_range}="m"), 0) - COLUMN($F$1) + 1 '
        f'), "")'
    )
    
    finish2_formula = (
        f'=IFERROR('
        f'INDEX({header_range}, '
        f'  MATCH(2, 1/('
        f'    OFFSET($F${r}, 0, '
        f'      MATCH(2, 1/({slot_range}="m"), 0) - COLUMN($F$1) + 1, '
        f'      1, '
        f'      45 - (MATCH(2, 1/({slot_range}="m"), 0) - COLUMN($F$1) + 1) '
        f'    ) = "m", '
        f'  0 '
        f'  ) '
        f'  + MATCH(2, 1/({slot_range}="m"), 0) - COLUMN($F$1) + 1 '
        f'  + 1 '
        f'), "")'
    )
    
    # Write formulas into columns B‑E (2‑5)
    ws.cell(row=r, column=2).value = start1_formula
    ws.cell(row=r, column=3).value = finish1_formula
    ws.cell(row=r, column=4).value = start2_formula
    ws.cell(row=r, column=5).value = finish2_formula

# Save workbook
