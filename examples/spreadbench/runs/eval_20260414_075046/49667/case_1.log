import openpyxl
from openpyxl.utils import column_index_from_string
import os
import datetime

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_49667_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_49667_init.xlsx")

# Load workbook (keep formulas, though we will overwrite target cells with values)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

max_row = ws.max_row
max_col = ws.max_column

# Helper: convert a time string like "08:00" to Excel numeric time (fraction of a day)
def time_str_to_excel_fraction(t_str):
    # t_str may already be a datetime.time object; handle both
    if isinstance(t_str, datetime.time):
        h, m = t_str.hour, t_str.minute
    else:
        # Assume format "HH:MM"
        parts = str(t_str).split(":")
        if len(parts) != 2:
            return None
        h, m = int(parts[0]), int(parts[1])
    return (h * 3600 + m * 60) / 86400  # seconds in a day

# Build a list of header times (columns F through AT) as numeric fractions
header_start_col = column_index_from_string("F")  # 6
header_end_col = column_index_from_string("AT")   # 46
header_times = []  # index 0 corresponds to column F
for col in range(header_start_col, header_end_col + 1):
    val = ws.cell(row=1, column=col).value
    frac = time_str_to_excel_fraction(val)
    header_times.append(frac)

# Process each data row
for r in range(2, max_row + 1):
    # Extract the row values for columns F‑AT
    row_vals = [ws.cell(row=r, column=c).value for c in range(header_start_col, header_end_col + 1)]

    # Identify contiguous blocks of 'm'
    blocks = []
    i = 0
    while i < len(row_vals):
        if row_vals[i] == 'm':
            start_idx = i  # zero‑based index within header_times
            # advance until the block ends
            while i < len(row_vals) and row_vals[i] == 'm':
                i += 1
            end_idx = i - 1  # last 'm' index
            blocks.append((start_idx, end_idx))
            if len(blocks) == 2:  # we only need up to two blocks
                break
        else:
            i += 1

    # Prepare values for columns B‑E
    # Default to None (blank) if a block does not exist
    start1_val = finish1_val = start2_val = finish2_val = None

    if len(blocks) >= 1:
        s0, e0 = blocks[0]
        start1_val = header_times[s0]          # time at first 'm'
        # finish is the time of the column *after* the last 'm' of the block
        if e0 + 1 < len(header_times):
            finish1_val = header_times[e0 + 1]
    if len(blocks) >= 2:
        s1, e1 = blocks[1]
        start2_val = header_times[s1]
        if e1 + 1 < len(header_times):
            finish2_val = header_times[e1 + 1]

    # Write the numeric values (or leave blank)
    ws.cell(row=r, column=2).value = start1_val   # B
    ws.cell(row=r, column=3).value = finish1_val  # C
    ws.cell(row=r, column=4).value = start2_val   # D
    ws.cell(row=r, column=5).value = finish2_val  # E

# Save the workbook
wb.save(output_path)

# Recalculate (no formulas, but required by workflow)
await recalculate(output_path)

# Reload with data_only to verify the written numeric values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Verification of B‑E after processing (first 5 data rows):")
for r in range(2, min(7, ws_check.max_row + 1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(2, 6)]
    # Convert numeric Excel time back to HH:MM string for readable output
    def fmt(val):
        if isinstance(val, (int, float)):
            total_seconds = int(round(val * 86400))
            h = total_seconds // 3600
            m = (total_seconds % 3600) // 60
            return f"{h:02d}:{m:02d}"
        return None
    print(f"Row {r}: {[fmt(v) for v in vals]}")
```
