import openpyxl
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_32255_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_32255_init.xlsx")

# Load workbook with formulas retained
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

max_row = ws.max_row

# Helper to create the adjusted formula

def adjusted_formula(orig_formula: str, row: int) -> str:
    """Wrap the original IF formula with an ISBLANK check on column A.
    Example: orig_formula='=IF(A10<0,1,0)' -> '=IF(ISBLANK(A10),"",IF(A10<0,1,0))'
    """
    a_ref = f"A{row}"
    inner = orig_formula.lstrip("=")
    return f"=IF(ISBLANK({a_ref}),\"\",{inner})"

# Iterate over all data rows (starting at row 2)
for r in range(2, max_row + 1):
    a_cell = ws.cell(row=r, column=1)  # column A
    if a_cell.value is None:
        # Columns B, C, D are 2, 3, 4
        for col_idx in range(2, 5):
            cell = ws.cell(row=r, column=col_idx)
            if isinstance(cell.value, str) and cell.value.startswith("="):
                # Ensure the formula references the same row's column A
                if f"A{r}" in cell.value:
                    cell.value = adjusted_formula(cell.value, r)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas using the provided async helper
await recalculate(output_path)

# Verify values after recalculation (data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification after recalculation (rows 10-13, cols B-D):")
for r in range(10, 14):
    vals = [ws_check.cell(row=r, column=c).value for c in range(2, 5)]
    print(f"Row {r}: {vals}")

# Verify the actual formulas (data_only=False)
wb_form = openpyxl.load_workbook(output_path, data_only=False)
ws_form = wb_form[wb_form.sheetnames[0]]
print("\nFormulas in rows 10-13, cols B-D:")
for r in range(10, 14):
    forms = [ws_form.cell(row=r, column=c).value for c in range(2, 5)]
    print(f"Row {r}: {forms}")
