Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50952_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assume single sheet

max_row = ws.max_row
max_col = ws.max_column

# Helper to get cell value safely

def get_val(row, col):
    return ws.cell(row=row, column=col).value

# Build a list of rows with their ID and comment for quick lookup
rows_data = []
for r in range(2, max_row + 1):
    id_val = get_val(r, 1)  # column A
    comment = get_val(r, 2)  # column B
    rows_data.append({"row": r, "id": id_val, "comment": comment})

# Process each row to fill column G (7)
for r in range(2, max_row + 1):
    param1 = get_val(r, 5)  # column E
    param2 = get_val(r, 6)  # column F
    # If either parameter is missing, skip
    if not param1 or not param2:
        continue
    # Normalise to lower case strings for case‑insensitive search
    p1 = str(param1).lower()
    p2 = str(param2).lower()
    found_id = None
    for row_info in rows_data:
        comment = row_info["comment"]
        if comment is None:
            continue
        cmt = str(comment).lower()
        if p1 in cmt and p2 in cmt:
            found_id = row_info["id"]
            break
    # Write the found ID into column G if we have a match
    if found_id is not None:
        ws.cell(row=r, column=7, value=found_id)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)
# Save workbook
wb.save(output_path)

# Recalculate formulas (none expected, but required by workflow)
await recalculate(output_path)

# Reload with data_only to verify written values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification of column G (Found ID) after processing:")
for r in range(2, ws_check.max_row + 1):
    print(f"Row {r}: {ws_check.cell(row=r, column=7).value}")
```
