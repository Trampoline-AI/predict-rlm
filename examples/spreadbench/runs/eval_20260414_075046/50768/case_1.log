import openpyxl
from openpyxl.utils import get_column_letter

wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)
ws = wb.active  # only one sheet

max_row = ws.max_row
max_col = ws.max_column

print(f"Sheet: {ws.title}, max_row={max_row}, max_col={max_col}")

# Collect rows that contain any non‑None value
non_empty_rows = []
for r in range(1, max_row + 1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
    if any(v is not None for v in row_vals):
        non_empty_rows.append((r, row_vals))

print("\nRows with any data (row index, values):")
for r, vals in non_empty_rows:
    # Show a concise view: replace long strings with truncated version
    short_vals = [str(v)[:30] if isinstance(v, str) else v for v in vals]
    print(f"{r:>2}: {short_vals}")

# Find the header row for the Risk Assessment table (contains 'ID' and 'Impact')
risk_header_row = None
for r, vals in non_empty_rows:
    if any(str(v).strip().lower() == 'id' for v in vals):
        risk_header_row = r
        break
print(f"\nDetected Risk Assessment header row: {risk_header_row}")

# Find the header row for the Matrix table (contains 'Impact' and 'Liklihood')
matrix_header_row = None
for r, vals in non_empty_rows:
    # Look for a row that has both 'Impact' and 'Liklihood' (or 'Likelihood')
    has_impact = any(str(v).strip().lower() == 'impact' for v in vals)
    has_likelihood = any(str(v).strip().lower() in ('likelihood', 'liklihood') for v in vals)
    if has_impact and has_likelihood:
        matrix_header_row = r
        break
print(f"Detected Matrix header row: {matrix_header_row}")

# Print the matrix area (assuming it starts at matrix_header_row and spans next 4 rows/cols)
if matrix_header_row:
    print("\nMatrix area (rows {}‑{}):".format(matrix_header_row, matrix_header_row+4))
    for r in range(matrix_header_row, min(matrix_header_row+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"{r:>2}: {row_vals}")
