Code:
```repl
import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_45372_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_45372_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# Define fill
fill = PatternFill(start_color="FFC000", end_color="FFC000", fill_type="solid")

# Write formulas to E2:E14 (data rows)
for row in range(2, 15):  # 2 through 14 inclusive
    time_cell = ws.cell(row=row, column=1)   # A
    b_cell = ws.cell(row=row, column=2)      # B
    c_cell = ws.cell(row=row, column=3)      # C
    e_cell = ws.cell(row=row, column=5)      # E target
    
    # Build formula string
    # =IF(ISBLANK(A2),"",IF(A2<TIME(9,45,0),IF(B2=0,"",B2),IF(C2=0,"",C2)))
    formula = (
        f"=IF(ISBLANK({time_cell.coordinate}),\"\","
        f"IF({time_cell.coordinate}<TIME(9,45,0),"
        f"IF({b_cell.coordinate}=0,\"\",{b_cell.coordinate}),"
        f"IF({c_cell.coordinate}=0,\"\",{c_cell.coordinate})))"
    )
    e_cell.value = formula
    e_cell.fill = fill

# Row 15 is the total row – keep its existing formula but apply fill
total_cell = ws.cell(row=15, column=5)
total_cell.fill = fill

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Verify a few cells
print("Verification of column E after recalculation:")
for r in range(2, 16):
    val = ws_check.cell(row=r, column=5).value
    print(f"E{r}:", val)

# Also print the formulas (data_only=False) for a couple of rows to ensure they were set
wb_formulas = openpyxl.load_workbook(output_path, data_only=False)
ws_formulas = wb_formulas[wb_formulas.sheetnames[0]]
print("\nFormulas in column E (data rows):")
for r in range(2, 15):
    print(f"E{r} formula:", ws_formulas.cell(row=r, column=5).value)
```
