import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_209-30_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_209-30_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb["Data to Import"]  # target sheet

# Determine last row with data in column C (3)
col_c = 3
last_row = 1
for row in range(ws.max_row, 1, -1):
    if ws.cell(row=row, column=col_c).value not in (None, ""):
        last_row = row
        break

print(f"Target rows: 2 to {last_row}")

# Remove last three characters from each postcode in column C
for row in range(2, last_row + 1):
    cell = ws.cell(row=row, column=col_c)
    val = cell.value
    if isinstance(val, str) and len(val) >= 3:
        new_val = val[:-3]  # strip last three characters
        cell.value = new_val
    # else: leave as is (blank, None, or short string)

# Save to output path
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas (if any) and reload data_only for verification
await recalculate(output_path)
