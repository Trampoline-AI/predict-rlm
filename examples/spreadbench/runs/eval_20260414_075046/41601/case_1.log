1. Load the workbook (already saved to the output folder).
2. For every data row (row 2 to max_row) in the 'Students' sheet, write the formula `=INDIRECT(A{row} & "!C2")` into column E (the existing Age column).
3. Save the workbook.
4. Call `recalculate()` on the saved file to evaluate formulas.
5. Reload the workbook with `data_only=True` and verify that column E now contains non‑None values for a few rows.
6. Print a few sample values to confirm the change.

After verification we will submit the output spreadsheet path.
Code:
```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load the workbook (write mode)
wb = openpyxl.load_workbook(input_path)
ws = wb["Students"]  # we know the sheet exists

# Determine the column index for the Age column (header "Age")
# Header row is row 1
age_col_idx = None
for col in range(1, ws.max_column + 1):
    hdr = ws.cell(row=1, column=col).value
    if isinstance(hdr, str) and hdr.strip().lower() in ["age", "age (years)", "student age"]:
        age_col_idx = col
        break
if age_col_idx is None:
    # fallback to column E (5) as seen in the inspection
    age_col_idx = 5

age_col_letter = get_column_letter(age_col_idx)
print(f"Target age column: {age_col_letter}")

# Write the generic INDIRECT formula for each data row
for row in range(2, ws.max_row + 1):
    # Build formula string using the name in column A (column 1)
    formula = f'=INDIRECT(A{row} & "!C2")'
    ws.cell(row=row, column=age_col_idx).value = formula

# Save the modified workbook
wb.save(output_path)
print("Workbook saved with formulas to:", output_path)

# Recalculate formulas using the provided tool
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to read evaluated values
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data["Students"]

# Verify a few rows
print("Sample evaluated ages after recalculation:")
for row in range(2, min(7, ws_data.max_row + 1)):
    val = ws_data.cell(row=row, column=age_col_idx).value
    print(f"{age_col_letter}{row} = {val}")

# Save again after verification (no changes, just to ensure file is up‑to‑date)
wb_data.save(output_path)
```
