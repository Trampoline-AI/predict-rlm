import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import datetime

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_333-29_init.xlsx"
output_path = "/sandbox/output/output_spreadsheet/1_333-29_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

# --- Step 1: Identify first "Yes" or "NA" in column P of sheet A ---
ws_A = wb["A"]
col_P = column_index_from_string("P")
first_yes_na_row = None
for r in range(2, ws_A.max_row + 1):
    val = ws_A.cell(row=r, column=col_P).value
    if isinstance(val, str) and val.strip() in ("Yes", "NA"):
        first_yes_na_row = r
        break

if first_yes_na_row is None:
    raise ValueError("No cell with 'Yes' or 'NA' found in column P of sheet A.")

# --- Step 2: Search upward in column L for the first 100 ---
col_L = column_index_from_string("L")
target_row = None
for r in range(first_yes_na_row - 1, 1, -1):  # walk upwards, stop before header
    val = ws_A.cell(row=r, column=col_L).value
    # Accept numeric 100 (int or float)
    if isinstance(val, (int, float)) and val == 100:
        target_row = r
        break

if target_row is None:
    raise ValueError("No value 100 found above the first Yes/NA in column L.")

# --- Step 3: Retrieve date from column F of that row ---
col_F = column_index_from_string("F")
date_value = ws_A.cell(row=target_row, column=col_F).value
if not isinstance(date_value, (datetime.datetime, datetime.date)):
    raise ValueError(f"Expected a date in A!F{target_row}, got {date_value!r}")

# --- Step 4: Find matching row in sheet B where column C equals A!F1 ---
ws_B = wb["B"]
lookup_text = ws_A["F1"].value  # e.g., "Silver"
col_C_B = column_index_from_string("C")
match_row_B = None
for r in range(2, ws_B.max_row + 1):
    if ws_B.cell(row=r, column=col_C_B).value == lookup_text:
        match_row_B = r
        break

if match_row_B is None:
    raise ValueError(f"Value '{lookup_text}' from A!F1 not found in column C of sheet B.")

# --- Step 5: Write the date into column F of the matching row in sheet B ---
col_F_B = column_index_from_string("F")  # "Last 100 Date" column
ws_B.cell(row=match_row_B, column=col_F_B).value = date_value

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas (if any) and verify the written date
import asyncio
await recalculate(output_path)

# Reload with data_only to read cached values
wb_verified = openpyxl.load_workbook(output_path, data_only=True)
ws_B_verified = wb_verified["B"]
written = ws_B_verified.cell(row=match_row_B, column=col_F_B).value
print(f"Verification: Sheet B, cell {get_column_letter(col_F_B)}{match_row_B} = {written}")

# Final save (after verification) – already saved, but ensure any changes persisted
wb_verified.save(output_path)
```
