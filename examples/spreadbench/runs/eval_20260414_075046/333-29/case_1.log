print("Sheet names:", wb.sheetnames)

# Helper to print a few rows from a sheet
def print_sheet_summary(ws, max_rows=5):
    # Determine column headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print(f"Headers (row 1) for sheet '{ws.title}':")
    print(headers)
    # Print first few data rows (excluding header)
    print(f"First {max_rows} data rows:")
    for r in range(2, min(ws.max_row, max_rows + 1) + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    # Print last few data rows
    print(f"Last {max_rows} data rows:")
    start = max(2, ws.max_row - max_rows + 1)
    for r in range(start, ws.max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(r, row_vals)

# 2. Summarize sheet A
if "A" in wb.sheetnames:
    ws_A = wb["A"]
    print("\n--- Sheet A Summary ---")
    print_sheet_summary(ws_A)
    # Print specific cells needed for the logic
    print("\nCell F1 (sheet A):", ws_A["F1"].value)
    # Show a few values from column P and L to understand data
    col_P = column_index_from_string("P")
    col_L = column_index_from_string("L")
    col_F = column_index_from_string("F")
    print("\nSample values from column P (first 10 rows):")
    for r in range(2, min(ws_A.max_row, 11)):
        print(r, ws_A.cell(row=r, column=col_P).value)
    print("\nSample values from column L (first 10 rows):")
    for r in range(2, min(ws_A.max_row, 11)):
        print(r, ws_A.cell(row=r, column=col_L).value)
else:
    print("Sheet 'A' not found!")

# 3. Summarize sheet B
if "B" in wb.sheetnames:
    ws_B = wb["B"]
    print("\n--- Sheet B Summary ---")
    print_sheet_summary(ws_B)
    # Show a few values from column C
    col_C = column_index_from_string("C")
    print("\nSample values from column C (first 10 rows):")
    for r in range(2, min(ws_B.max_row, 11)):
        print(r, ws_B.cell(row=r, column=col_C).value)
else:
    print("Sheet 'B' not found!")

# Save a copy for safety (we will overwrite later after confirming target)
output_path = "/sandbox/output/output_spreadsheet/1_333-29_init.xlsx"
