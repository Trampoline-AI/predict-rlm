Code:
```repl
import openpyxl
import os
from openpyxl.utils import column_index_from_string

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Formula Required"]

# Data rows start at row 3 (first two rows are header/info)
first_data_row = 3
last_data_row = ws.max_row

# Target columns D (4) to G (7)
for r in range(first_data_row, last_data_row + 1):
    for col_idx in range(4, 8):  # 4=D,5=E,6=F,7=G
        # Column index for B‑lookup (range starts at column B)
        # D → 2, E → 3, F → 4, G → 5  → col_idx - 2
        col_index_B = col_idx - 2
        # Column index for C‑lookup (range starts at column A)
        # D → 3, E → 4, F → 5, G → 6  → col_idx - 1
        col_index_C = col_idx - 1
        formula = (
            f'=IF(NOT(ISBLANK(B{r})),'
            f'VLOOKUP(B{r},Grouping!$B$2:$I$7,{col_index_B},FALSE),'
            f'VLOOKUP(C{r},Grouping!$A$2:$I$7,{col_index_C},FALSE))'
        )
        ws.cell(row=r, column=col_idx).value = formula

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Verify a few target cells after recalculation (load data_only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Formula Required"]
print("Verification of columns D‑G for first 5 data rows:")
for r in range(first_data_row, min(first_data_row + 5, last_data_row + 1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(4, 8)]
    print(f"Row {r}: D={vals[0]}, E={vals[1]}, F={vals[2]}, G={vals[3]}")

print("Output saved to:", output_path)
```
