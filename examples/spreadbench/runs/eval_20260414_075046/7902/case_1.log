import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

print("Workbook loaded from", wb_path)
print("Sheet names:", wb.sheetnames)

# Function to print sheet summary
def summarize_sheet(ws):
    print(f"--- Sheet: {ws.title} ---")
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Rows: {max_row}, Columns: {max_col}")
    # Print header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Look for any existing formulas in column C (since VLOOKUP references C3)
    col_c_vals = []
    for r in range(2, max_row+1):
        cell = ws.cell(row=r, column=3)  # column C
        if isinstance(cell.value, str) and cell.value.startswith('='):
            col_c_vals.append((r, cell.value))
    if col_c_vals:
        print("Sample formulas in column C:")
        for r, val in col_c_vals[:5]:
            print(f"C{r} = {val}")
    else:
        print("No formulas found in column C.")

# Summarize each sheet
for ws in wb.worksheets:
    summarize_sheet(ws)
```
