import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_56953_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_56953_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Define formulas for columns I-L (9-12)
# Row offset for AGGREGATE: ROW(A1) will be 1 in row 2, 2 in row 3, etc.
# We'll use ROW(A1) + (row_index-2) to get correct offset.
# Simpler: use ROW(A1) in each row because when copied down, ROW(A1) becomes ROW(A2), etc.
# But we write explicit formula per row using ROW(A1) which changes automatically when copied.
# We'll write the same formula in each cell; Excel will adjust ROW(A1) to the row's relative position.
formula_I = "=IFERROR(INDEX($A$2:$A$15,AGGREGATE(15,6,IF($A$2:$A$15=$F$2,ROW($A$2:$A$15)-ROW($A$2)+1),ROW(A1))),\"\")"
formula_J = "=IFERROR(INDEX($B$2:$B$15,AGGREGATE(15,6,IF($A$2:$A$15=$F$2,ROW($A$2:$A$15)-ROW($A$2)+1),ROW(A1))),\"\")"
formula_K = "=IFERROR(INDEX($C$2:$C$15,AGGREGATE(15,6,IF($A$2:$A$15=$F$2,ROW($A$2:$A$15)-ROW($A$2)+1),ROW(A1))),\"\")"
formula_L = "=IFERROR(INDEX($D$2:$D$15,AGGREGATE(15,6,IF($A$2:$A$15=$F$2,ROW($A$2:$A$15)-ROW($A$2)+1),ROW(A1))),\"\")"

# Write formulas to I2:L13 (rows 2-13, columns 9-12)
for r in range(2, 14):  # 2 to 13 inclusive
    ws.cell(row=r, column=9).value = formula_I   # I
    ws.cell(row=r, column=10).value = formula_J  # J
    ws.cell(row=r, column=11).value = formula_K  # K
    ws.cell(row=r, column=12).value = formula_L  # L

# Save to output path
wb.save(output_path)

# Recalculate formulas using the provided tool
import asyncio
result = await recalculate(output_path)
print("Recalculate result:", result)

# Reload with data_only to see computed values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

print("Values after recalculation (I2:L13):")
for r in range(2, 14):
    vals = [ws2.cell(row=r, column=c).value for c in range(9, 13)]
    print(r, vals)
