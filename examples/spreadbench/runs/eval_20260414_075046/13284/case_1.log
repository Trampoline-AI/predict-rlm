import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb_path = "/sandbox/input/input_spreadsheet/initial.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print sheet summary
def print_sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{ws.title}': {max_row} rows, {max_col} columns")
    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # First 5 data rows
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Last 5 data rows (if enough rows)
    if max_row > 6:
        print("Last 5 data rows:")
        for r in range(max(max_row-4, 2), max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(r, row_vals)

# 2. Summarize each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print_sheet_summary(ws)

# Identify target column in Base sheet (column E) and source column in Streets sheet (column F)
base_ws = wb["Base"]
streets_ws = wb["Streets"]
print("\nTarget column in 'Base' (E):", get_column_letter(5))
print("Source column in 'Streets' (F):", get_column_letter(6))

# Show a few values from those columns to confirm they exist
print("\nSample values from Base column E (target) - first 5 rows:")
for r in range(2, 7):
    print(r, base_ws.cell(row=r, column=5).value)

print("\nSample values from Streets column F (source) - first 5 rows:")
for r in range(2, 7):
    print(r, streets_ws.cell(row=r, column=6).value)
