import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/initial.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "initial.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)
base_ws = wb["Base"]
streets_ws = wb["Streets"]

# Helper to normalize strings
def norm(s):
    return str(s).strip().lower() if s is not None else None

# Build candidate list from Streets (only rows where Start and End are present)
streets_candidates = []
for r in range(2, streets_ws.max_row + 1):
    street_name = norm(streets_ws.cell(row=r, column=2).value)   # B
    start_val = streets_ws.cell(row=r, column=3).value        # C
    end_val = streets_ws.cell(row=r, column=4).value          # D
    assistente = streets_ws.cell(row=r, column=6).value       # F
    if street_name is None or start_val is None or end_val is None:
        continue
    try:
        start_num = float(start_val)
        end_num = float(end_val)
    except (TypeError, ValueError):
        continue
    streets_candidates.append({
        "street": street_name,
        "start": start_num,
        "end": end_num,
        "assistente": assistente,
    })

# Debug: print a few normalized street names from both sheets
print("Sample normalized street names (Base rows 2‑5):")
for r in range(2, 6):
    print(r, norm(base_ws.cell(row=r, column=3).value))
print("Sample normalized street names (Streets rows 2‑5):")
for r in range(2, 6):
    print(r, norm(streets_ws.cell(row=r, column=2).value))

# Lookup function using normalized keys
def find_assistente(base_street_raw, base_number_raw):
    base_street = norm(base_street_raw)
    if base_street is None or base_number_raw is None:
        return None
    try:
        num = float(base_number_raw)
    except (TypeError, ValueError):
        return None
    for cand in streets_candidates:
        if cand["street"] == base_street and cand["start"] <= num <= cand["end"]:
            return cand["assistente"]
    return None

# Write results into Base column E (5)
for r in range(2, base_ws.max_row + 1):
    base_street = base_ws.cell(row=r, column=3).value   # C
    base_number = base_ws.cell(row=r, column=4).value   # D
    result = find_assistente(base_street, base_number)
    base_ws.cell(row=r, column=5).value = result

# Ensure output directory exists and save
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify a few rows after recalculation
wb_check = openpyxl.load_workbook(output_path, data_only=True)
base_check = wb_check["Base"]
print("\nVerification after fixing lookup (Base column E):")
for r in range(2, min(7, base_check.max_row + 1)):
    print(f"Row {r}:", base_check.cell(row=r, column=5).value)
print(f"Row {base_check.max_row} (last):", base_check.cell(row=base_check.max_row, column=5).value)
