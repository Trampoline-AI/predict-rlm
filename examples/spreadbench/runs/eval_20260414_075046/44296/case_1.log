import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_44296_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_44296_init.xlsx')

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)

# Identify sheets
ws1 = wb['Sheet1']
ws2 = wb['Sheet2']

# Determine the data range in Sheet1 for the unit values (columns L to R, rows 2 to max)
first_data_row = 2
last_data_row = ws1.max_row
# Columns: L=12, R=18
col_start = 12
col_end = 18

# Build the absolute range strings for the formula
values_range = f"Sheet1!${openpyxl.utils.get_column_letter(col_start)}${first_data_row}:${openpyxl.utils.get_column_letter(col_end)}${last_data_row}"
state_range = f"Sheet1!${openpyxl.utils.get_column_letter(2)}${first_data_row}:${openpyxl.utils.get_column_letter(2)}${last_data_row}"
year_header_range = f"Sheet1!${openpyxl.utils.get_column_letter(col_start)}$1:${openpyxl.utils.get_column_letter(col_end)}$1"

# Write formula into column D of Sheet2 for each data row (starting at row 2)
for r in range(2, ws2.max_row + 1):
    # Only write if the cell is empty or contains an error
    cell = ws2.cell(row=r, column=4)  # column D
    if cell.value is None or isinstance(cell.value, str) and cell.value.startswith('#'):
        state_cell = f"A{r}"
        year_cell = f"B{r}"
        formula = f"=INDEX({values_range}, MATCH({state_cell}, {state_range}, 0), MATCH({year_cell}, {year_header_range}, 0))"
        cell.value = formula

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas using the provided tool
result = await recalculate(output_path)
print('Recalculate result:', result)

# Reload with data_only=True to verify formulas are present (not evaluating here)
wb_check = load_workbook(output_path, data_only=False)
ws2_check = wb_check['Sheet2']
print('Sample formulas in Sheet2 column D:')
for r in range(2, min(7, ws2_check.max_row + 1)):
    print(f"Row {r}:", ws2_check.cell(row=r, column=4).value)
