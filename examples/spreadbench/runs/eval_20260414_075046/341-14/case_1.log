import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_341-14_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
sheet_names = wb.sheetnames
print("Sheet names:", sheet_names)

def inspect_sheet(ws):
    # Determine max row and column
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{ws.title}': {max_row} rows, {max_col} columns")
    
    # Print header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    
    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)
    
    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

# Inspect each sheet
for name in sheet_names:
    ws = wb[name]
    inspect_sheet(ws)

# Save a copy (not modifying yet)
output_path = "/sandbox/output/output_spreadsheet/1_341-14_init.xlsx"
wb.save(output_path)
print("\nWorkbook saved to:", output_path)
