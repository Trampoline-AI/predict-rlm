import os
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50526_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_50526_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet

# Formula (array formula for LibreOffice)
formula = (
    '=IFERROR('
    'INDEX($B$1:$G$1, '
    'SMALL('
    'IF(($A$2:$A$3=$B$6)*($B$2:$G$3>0), '
    'COLUMN($B$2:$G$3)-COLUMN($B$2)+1), '
    'ROW(A1))), '
    '"" )'
)

# Write formula into B9 and copy down for enough rows (max possible matches = number of data columns = 6)
start_row = 9
num_matches = 6  # columns B‑G
for i in range(num_matches):
    cell = ws.cell(row=start_row + i, column=column_index_from_string('B'))
    cell.value = formula

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to see evaluated results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active

# Print results for verification
print("Evaluated results (B9‑B14):")
for r in range(start_row, start_row + num_matches):
    print(f"B{r}:", ws2[f"B{r}"].value)

# Ensure the output file is the one we will submit
print("Output saved to:", output_path)
```
