import os
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50526_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_50526_init.xlsx")

# Load workbook (preserve any existing formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# 1. Get lookup key from B6
lookup_key = ws["B6"].value
print("Lookup key (B6):", lookup_key)

# 2. Find the row(s) in column A that match the lookup key
# In the sample data, keys are in rows 2‑3; we will scan all rows from row 2 to max_row
matching_row = None
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=column_index_from_string("A")).value
    if val == lookup_key:
        matching_row = r
        break

if matching_row is None:
    print("No matching row found for key:", lookup_key)
    matching_row = 2  # fallback to avoid errors

# 3. Determine data columns (B‑G in the sample). We'll use the header row (row 1) to get column range.
header_row = 1
first_data_col = column_index_from_string("B")
last_data_col = column_index_from_string("G")

# Collect headers where the cell in the matching row > 0
matched_headers = []
for col in range(first_data_col, last_data_col + 1):
    cell_val = ws.cell(row=matching_row, column=col).value
    if isinstance(cell_val, (int, float)) and cell_val > 0:
        header = ws.cell(row=header_row, column=col).value
        matched_headers.append(header)

print("Matched headers for key", lookup_key, ":", matched_headers)

# 4. Write results into column B starting at row 9
start_row = 9
max_rows = last_data_col - first_data_col + 1  # maximum possible matches (6)
for i in range(max_rows):
    target_cell = ws.cell(row=start_row + i, column=column_index_from_string("B"))
    if i < len(matched_headers):
        target_cell.value = matched_headers[i]
    else:
        target_cell.value = ""  # blank for remaining rows

# Save workbook
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate (to update any other formulas)
await recalculate(output_path)

# Reload with data_only to verify values
wb_eval = openpyxl.load_workbook(output_path, data_only=True)
ws_eval = wb_eval.active

print("Evaluated results (B9‑B14):")
for r in range(start_row, start_row + max_rows):
    print(f"B{r}:", ws_eval[f"B{r}"].value)
```
