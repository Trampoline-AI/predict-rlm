import os
import openpyxl
from openpyxl.utils import column_index_from_string
from openpyxl.worksheet.formula import ArrayFormula
import asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_50526_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_50526_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming a single sheet

# Array‑formula text (LibreOffice compatible)
array_formula_text = (
    '=IFERROR('
    'INDEX($B$1:$G$1, '
    'SMALL('
    'IF(($A$2:$A$3=$B$6)*($B$2:$G$3>0), '
    'COLUMN($B$2:$G$3)-COLUMN($B$2)+1), '
    'ROW(A1))), '
    '"" )'
)

# Write the array formula into B9 and copy down for up to 6 matches (columns B‑G)
start_row = 9
max_matches = 6  # number of possible matches = number of data columns
col_idx = column_index_from_string('B')
for i in range(max_matches):
    cell = ws.cell(row=start_row + i, column=col_idx)
    cell.value = ArrayFormula(array_formula_text)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice + formulas library)
await recalculate(output_path)

# Reload with data_only to view evaluated results
wb_eval = openpyxl.load_workbook(output_path, data_only=True)
ws_eval = wb_eval.active

print("Evaluated results (B9‑B14):")
for r in range(start_row, start_row + max_matches):
    print(f"B{r}:", ws_eval[f"B{r}"].value)

print("Output saved to:", output_path)
```
