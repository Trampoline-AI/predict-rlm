import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write)
wb_path = "/sandbox/input/input_spreadsheet/1_66-24_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. List sheet names
print("Sheets:", wb.sheetnames)

# Helper to print sheet summary
def print_sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{ws.title}': rows={max_row}, cols={max_col}")

    # Header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # First 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Print summary for each sheet
for ws in wb.worksheets:
    print_sheet_summary(ws)

# Verify that column E (5) contains dates in the 'Imported Data' sheet
if "Imported Data" in wb.sheetnames:
    ws_imp = wb["Imported Data"]
    dates = [ws_imp.cell(row=r, column=5).value for r in range(2, ws_imp.max_row+1)]
    # Show a few date samples
    print("\nSample dates from column E (Imported Data):", dates[:5])
else:
    print("Sheet 'Imported Data' not found!")

# Verify that column Z (26) exists in the target sheet
if "Items Older than 30 days" in wb.sheetnames:
    ws_target = wb["Items Older than 30 days"]
    print("\nColumn Z header in target sheet:", ws_target.cell(row=1, column=26).value)
else:
    print("Sheet 'Items Older than 30 days' not found!")
