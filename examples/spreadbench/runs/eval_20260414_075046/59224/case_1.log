import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_59224_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_59224_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row
max_col = ws.max_column

# Write new formulas in column E (5) from row 4 to max_row
for r in range(4, max_row + 1):
    # Build formula string for this row
    # Note: we need the absolute row numbers for the current row's C and D cells
    c_cell = f"C{r}"
    d_cell = f"D{r}"
    # OFFSET ranges: start one row below current row, height = max_row - r
    height = max_row - r
    # If height is 0, there are no rows below; the OFFSET will be a zero‑height range, which SUMPRODUCT treats as 0.
    formula = (
        f'=IF(AND($B$2>{c_cell},$B$2<{d_cell}),"Select Period",'
        f'IF(SUMPRODUCT(($B$2>OFFSET($C$4,1,0,{height},1))*'
        f'($B$2<OFFSET($D$4,1,0,{height},1)))>0,"Select Period","Do Not Select"))'
    )
    ws.cell(row=r, column=5).value = formula

# Save to output location
wb.save(output_path)

# Recalculate formulas using the provided tool
await recalculate(output_path)

# Reload with data_only to see evaluated results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Print a few sample rows from column E to verify
print("Sample evaluated values in column E after recalculation:")
for r in range(4, min(4+10, max_row+1)):
    print(f"Row {r}: {ws2.cell(row=r, column=5).value}")

# Also print the last row to ensure lower rows still work
print(f"Row {max_row}: {ws2.cell(row=max_row, column=5).value}")
