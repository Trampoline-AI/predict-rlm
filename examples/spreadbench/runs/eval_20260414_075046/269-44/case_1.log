import openpyxl
from pathlib import Path

# Load workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path)
ws = wb.active  # only one sheet, named Sheet1

# Show rows 7-14 for inspection
print("Rows 7-14 before deletion:")
for r in range(7, 15):
    print(r, ws.cell(row=r, column=1).value)

# Identify rows to delete: four rows before each "Chassis"
chassis_rows = [r for r in range(2, ws.max_row + 1)
                if isinstance(ws.cell(row=r, column=1).value, str) and
                ws.cell(row=r, column=1).value.strip() == "Chassis"]
print("Chassis rows:", chassis_rows)

rows_to_delete = set()
for cr in chassis_rows:
    start = max(2, cr - 4)  # avoid header row
    rows_to_delete.update(range(start, cr))
print("Rows to delete (unsorted):", rows_to_delete)

# Delete rows in descending order to keep indices valid
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

# Verify remaining rows after deletion
print("\nRemaining rows after deletion (showing column A values):")
for r in range(1, ws.max_row + 1):
    print(r, ws.cell(row=r, column=1).value)

# Save to output directory
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / Path(wb_path).name
wb.save(output_path)

# Recalculate formulas (if any)
calc_result = await recalculate(str(output_path))
print("Recalculate result:", calc_result)

# Reload with data_only to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active
print("\nFinal check (column A values):")
for r in range(1, ws2.max_row + 1):
    print(r, ws2.cell(row=r, column=1).value)
```
