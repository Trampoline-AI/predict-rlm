import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming single sheet

# Determine data range (rows 5 to max_row, columns C to I)
start_row = 5
end_row = ws.max_row  # 84 as observed
# Write formulas into summary cells (row 25, columns F-I)
summary_row = 25
category_cols = ['F', 'G', 'H', 'I']
for col in category_cols:
    cell_ref = f"{col}{summary_row}"
    # Build formula: count rows where Yes column C has "x" and the category column is not empty
    formula = f'=COUNTIFS(C{start_row}:C{end_row}, "x", {col}{start_row}:{col}{end_row}, "<>")'
    ws[cell_ref] = formula

# Save to output path
wb.save(output_path)

# Recalculate formulas
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to verify totals
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.active
totals = {col: ws2[f"{col}{summary_row}"].value for col in category_cols}
print("Summary totals after recalculation:", totals)
