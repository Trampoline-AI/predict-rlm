import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_38074_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

# 1. Read J2 value
j2_cell = ws.cell(row=2, column=column_index_from_string('J'))
j2_value = j2_cell.value
print("J2 value:", j2_value)

# 2. Write formula to K2:K5
col_K = column_index_from_string('K')
col_A = column_index_from_string('A')
col_B = column_index_from_string('B')
col_C = column_index_from_string('C')
col_E = column_index_from_string('E')
col_G = column_index_from_string('G')

for r in range(2, 6):  # rows 2 to 5 inclusive
    # Build formula:
    # =IF(EXACT(A2,$J$2), ROUND(B2 - (IFNA(C2,0) + IFNA(E2,0) + IFNA(G2,0)),0), "")
    # LibreOffice requires IFNA as _xlfn.IFNA, but IFNA is available with prefix.
    # Use IFERROR to treat blanks as 0: IFERROR(C2,0) works.
    # We'll use IFERROR for compatibility.
    formula = f"""=IF(EXACT(A{r},$J$2), ROUND(B{r} - (IFERROR(C{r},0) + IFERROR(E{r},0) + IFERROR(G{r},0)),0), "")"""
    ws.cell(row=r, column=col_K).value = formula
    # Set number format to integer (no decimals)
    ws.cell(row=r, column=col_K).number_format = '0'

# Save to output path
wb.save(output_path)

# Recalculate formulas
import asyncio
await recalculate(output_path)

# Reload with data_only to verify results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("Verified K2:K5 values after recalculation:")
for r in range(2, 6):
    print(f"K{r}:", ws2.cell(row=r, column=col_K).value)
