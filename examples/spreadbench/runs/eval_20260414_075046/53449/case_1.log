import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_53449_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_53449_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine dimensions
max_row = ws.max_row
max_col = ws.max_column

# Header for new column "Test" in column G (index max_col+1)
test_col_idx = max_col + 1
test_col_letter = get_column_letter(test_col_idx)
ws.cell(row=1, column=test_col_idx, value="Test")

# Write formula for each data row
for r in range(2, max_row + 1):
    # Formula uses relative row number
    formula = f'=IF(ISNUMBER(SEARCH("Covid Test",F{r})),"X","")'
    ws.cell(row=r, column=test_col_idx, value=formula)

# Save to output path
wb.save(output_path)
wb.close()

# Recalculate formulas (LibreOffice fallback)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to see evaluated values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[ws2.sheetnames[0]]

# Print sample values from the new "Test" column
print("\nSample values in 'Test' column after recalculation:")
for r in range(2, min(7, ws2.max_row + 1)):
    val = ws2.cell(row=r, column=test_col_idx).value
    print(f"Row {r}: {val}")

# Also print last few rows to ensure coverage
if ws2.max_row > 6:
    print("\nLast few rows:")
    for r in range(ws2.max_row - 4, ws2.max_row + 1):
        val = ws2.cell(row=r, column=test_col_idx).value
        print(f"Row {r}: {val}")

wb2.close()
