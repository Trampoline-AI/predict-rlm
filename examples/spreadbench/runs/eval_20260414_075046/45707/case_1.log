import openpyxl
import datetime
import os

output_path = "/sandbox/output/output_spreadsheet/1_45707_init.xlsx"

# Load workbook with evaluated values after recalculation
wb = openpyxl.load_workbook(output_path, data_only=True)
ws = wb.active

max_row = ws.max_row
print(f"Sheet: {ws.title}, max_row: {max_row}, max_column: {ws.max_column}")

# Helper to safely get day from a cell value

def get_day(val):
    if isinstance(val, (datetime.date, datetime.datetime)):
        return val.day
    return None

# Find rows where the next day's date is the 1st of a month
rows_with_first = []
for r in range(2, max_row):  # up to max_row-1 because we look at r+1
    next_date = ws.cell(row=r+1, column=1).value
    if get_day(next_date) == 1:
        rows_with_first.append(r)

print("Rows where the next day's date is the 1st of a month:", rows_with_first)

# Print details for those rows (up to first 10 for brevity)
for r in rows_with_first[:10]:
    cur_date = ws.cell(row=r, column=1).value
    next_date = ws.cell(row=r+1, column=1).value
    d_val = ws.cell(row=r, column=4).value
    print(f"Row {r}: A{r}={cur_date} (day={get_day(cur_date)}), "
          f"A{r+1}={next_date} (day={get_day(next_date)}), D{r}={d_val}")

# Also print a few D values for rows that are not first‑day cases to show they are blank
print("\nSample D values for rows 2‑10 (should be blank if not first‑day):")
for r in range(2, min(11, max_row+1)):
    print(f"D{r}:", ws.cell(row=r, column=4).value)
