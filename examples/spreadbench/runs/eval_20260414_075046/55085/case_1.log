if "Result" not in wb.sheetnames:
    raise RuntimeError("Sheet 'Result' not found in workbook")

ws = wb["Result"]

# Helper to build INDEX/MATCH formula
def build_formula(lookup_col, crit_col, crit_row):
    """
    lookup_col: column letter in Master-RM to retrieve (e.g., 'I' or 'K')
    crit_col: column letter in Master-RM that holds the first criterion (e.g., 'B')
    crit_row: column letter in Master-RM that holds the second criterion (e.g., 'H')
    Returns a formula string for the current cell in Result sheet.
    """
    # The criteria cells are in the same column as the formula cell, rows 2 and 3.
    # We'll use relative column reference ($G$2, $G$3, etc.) by inserting the column letter later.
    # The formula will be:
    # =INDEX('Master-RM'!I:I, MATCH(1, ('Master-RM'!$B:$B=$G$2)*('Master-RM'!$H:$H=$G$3), 0))
    return f"=INDEX('Master-RM'!{lookup_col}:{lookup_col}, MATCH(1, ('Master-RM'!${crit_col}:${crit_col}=${{{{col_letter}}}$2)*('Master-RM'!${crit_row}:${crit_row}=${{{{col_letter}}}$3), 0))"

# Write formulas for columns G‑L (7‑12) in row 10
# Mapping: G‑I -> lookup column I, criteria columns B and H
#          J‑L -> lookup column K, same criteria columns
for col_idx in range(7, 13):  # 7=G, 12=L
    col_letter = openpyxl.utils.get_column_letter(col_idx)
    if col_idx <= 9:  # G, H, I -> use column I from Master-RM
        lookup = "I"
    else:  # J, K, L -> use column K from Master-RM
        lookup = "K"
    # Criteria columns in Master-RM: B (first), H (second)
    formula = f"=INDEX('Master-RM'!{lookup}:{lookup}, MATCH(1, ('Master-RM'!$B:$B=${col_letter}$2)*('Master-RM'!$H:$H=${col_letter}$3), 0))"
    ws[f"{col_letter}10"] = formula

