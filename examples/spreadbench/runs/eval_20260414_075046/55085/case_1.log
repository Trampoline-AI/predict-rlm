import openpyxl
from openpyxl.utils import get_column_letter
import asyncio

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_55085_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_55085_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Ensure the target sheet exists
if "Result" not in wb.sheetnames:
    raise RuntimeError("Sheet 'Result' not found in workbook")

ws = wb["Result"]

# Write INDEX/MATCH formulas into G10‑L10
for col_idx in range(7, 13):          # 7=G, 12=L
    col_letter = get_column_letter(col_idx)
    # Choose lookup column: I for G‑I, K for J‑L
    lookup_col = "I" if col_idx <= 9 else "K"
    formula = (
        f"=INDEX('Master-RM'!{lookup_col}:{lookup_col}, "
        f"MATCH(1, ('Master-RM'!$B:$B=${col_letter}$2)*"
        f"('Master-RM'!$H:$H=${col_letter}$3), 0))"
    )
    ws[f"{col_letter}10"] = formula

# Save the modified workbook to the output location
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
await recalculate(output_path)

# Reload with data_only=True to read the evaluated values
wb_verified = openpyxl.load_workbook(output_path, data_only=True)
ws_verified = wb_verified["Result"]

# Verify that G10‑L10 now contain non‑None values
missing = []
for col_idx in range(7, 13):
    col_letter = get_column_letter(col_idx)
    val = ws_verified[f"{col_letter}10"].value
    if val is None:
        missing.append(f"{col_letter}10")

print("Missing values after recalculation:", missing)

if missing:
    raise RuntimeError(f"Target cells still empty after recalculation: {missing}")

# All target cells have values; ready for submission
