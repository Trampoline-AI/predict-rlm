wb_path = "/sandbox/input/input_spreadsheet/1_55085_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sheet summary
def summarize_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{ws.title}': rows={max_row}, cols={max_col}")

    # Get headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Summarize each sheet
for ws in wb.worksheets:
    summarize_sheet(ws)

# Locate the cell with the formula 'Master-RM'!I12 in the Result sheet
if 'Result' in wb.sheetnames:
    ws_res = wb['Result']
    # Search for the exact formula string (without leading =)
    target_cells = []
    for row in ws_res.iter_rows(min_row=1, max_row=ws_res.max_row,
                               min_col=1, max_col=ws_res.max_column):
        for cell in row:
            if isinstance(cell.value, str) and cell.value.strip() == "'Master-RM'!I12":
                target_cells.append(cell.coordinate)
    if target_cells:
        print("\nCells in 'Result' containing the exact formula string \"'Master-RM'!I12\":")
        for coord in target_cells:
            print(coord, ws_res[coord].value)
    else:
        print("\nNo cell in 'Result' contains the exact formula string \"'Master-RM'!I12\".")
else:
    print("\nSheet 'Result' not found.")
