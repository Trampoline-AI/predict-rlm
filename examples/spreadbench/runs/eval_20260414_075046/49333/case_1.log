            # Desired: =VLOOKUP(TRIM(F2),Sheet2!$G$2:$J$<last>,2,FALSE)
            # Build new formula manually to avoid accidental extra "="
            col_idx = c - column_index_from_string("G") + 2  # 2 for G, 3 for H, 4 for I
            new_formula = f"=VLOOKUP(TRIM({key_cell.coordinate}),{lookup_range},{col_idx},FALSE)"
            cell.value = new_formula

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice + formulas library)
await recalculate(output_path)

# Verify a few rows after recalculation (load with data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("Verification of rows 2‑4, columns G‑I after recalculation:")
for r in range(2, 5):
    vals = [ws_check.cell(row=r, column=c).value for c in lookup_cols]
    print(f"Row {r}: {vals}")

# Final save (already saved)
