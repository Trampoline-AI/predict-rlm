ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row
max_col = ws.max_column

# Track already written C values that satisfied the condition
seen = set()

for r in range(2, max_row + 1):
    val_a = ws.cell(row=r, column=1).value
    val_b = ws.cell(row=r, column=2).value
    val_c = ws.cell(row=r, column=3).value

    # Determine what should go into column D
    if val_a == val_b and val_c is not None:
        if val_c not in seen:
            ws.cell(row=r, column=4).value = val_c
            seen.add(val_c)
        else:
            ws.cell(row=r, column=4).value = None
    else:
        ws.cell(row=r, column=4).value = None

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify column D values after recalculation
