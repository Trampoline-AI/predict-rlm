1. Load the workbook from the provided path.
2. List all sheet names.
3. For each sheet, print the maximum row and column counts.
4. Read the first row to get column headers.
5. Print the first 5 data rows and the last 5 data rows (excluding the header) to see the data range.
6. Identify any existing formulas in column B (or any blank column) that might already be intended for the output.

This exploration will let us determine the exact target column for the price lookup formula.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
print("Sheet names:", wb.sheetnames)

for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {name}")
    print(f"  Max row: {max_row}, Max column: {max_col}")

    # Get headers from first row
    headers = [ws.cell(row=1, column=col).value for col in range(1, max_col + 1)]
    print("  Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("  First 5 data rows:")
    for r in range(2, min(2 + 5, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"    Row {r}: {row_vals}")

    # Print last 5 data rows
    print("  Last 5 data rows:")
    start = max(2, max_row - 4)
    for r in range(start, max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"    Row {r}: {row_vals}")

    # Check column B for existing formulas or values
    col_b_vals = [ws.cell(row=r, column=2).value for r in range(2, max_row + 1)]
    sample_nonempty = [v for v in col_b_vals if v not in (None, "")]
    print(f"  Sample non-empty values in column B (up to 5): {sample_nonempty[:5]}")
```
