Code:
```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_41265_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_41265_init.xlsx"

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Define row ranges
keyword_rows = range(2, 7)   # A2:A6, B2:B6
root_rows = range(2, 6)      # D2:D5

# Pre‑collect keyword -> search volume mapping
keyword_to_volume = {}
for r in keyword_rows:
    kw = ws.cell(row=r, column=1).value  # Column A
    vol = ws.cell(row=r, column=2).value  # Column B
    if kw is not None:
        keyword_to_volume[str(kw).strip()] = vol if isinstance(vol, (int, float)) else 0

# Compute per‑root sums and write to column E
for r in root_rows:
    root_val = ws.cell(row=r, column=4).value  # Column D
    sum_vol = 0
    if root_val is not None:
        root_str = str(root_val).strip()
        # Exact match only
        if root_str in keyword_to_volume:
            sum_vol = keyword_to_volume[root_str]
    ws.cell(row=r, column=5).value = sum_vol  # Column E

# Compute total of E2:E5 and write to E6
total = sum(ws.cell(row=r, column=5).value or 0 for r in root_rows)
ws.cell(row=6, column=5).value = total  # E6

# Save workbook
wb.save(output_path)

# Recalculate (in case any formulas exist) and verify
await recalculate(str(output_path))

# Verify written values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
verified = [ws_check.cell(row=r, column=5).value for r in range(2, 7)]
print("Verified E2:E6 values:", verified)
```
