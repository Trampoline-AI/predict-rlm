```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_165-23_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_165-23_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # Sheet1

# Determine rows to keep (where column C == "#N/A")
keep_rows = set()
for r in range(2, ws.max_row + 1):
    cell_val = ws.cell(row=r, column=3).value
    if cell_val == "#N/A":
        keep_rows.add(r)

# Delete rows where column C is NOT "#N/A"
# Iterate from bottom to top to avoid shifting
for r in range(ws.max_row, 1, -1):
    if r not in keep_rows:
        ws.delete_rows(r, 1)

# Save to output location
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify by reloading with data_only=True and printing a few rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("After deletion:")
print("Max row:", ws_check.max_row)
# Print first few rows (including header row)
for r in range(1, min(6, ws_check.max_row + 1)):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column + 1)]
    print(f"Row {r}:", row_vals)

# Print rows where column C is "#N/A" to confirm they were kept
print("\nRows with #N/A in column C:")
for r in range(2, ws_check.max_row + 1):
    if ws_check.cell(row=r, column=3).value == "#N/A":
        print(f"Row {r} column C:", ws_check.cell(row=r, column=3).value)
