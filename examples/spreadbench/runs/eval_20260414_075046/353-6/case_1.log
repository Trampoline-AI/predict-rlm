import os
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Identify rows to delete where column I ("communication_reason") == "Hub Notes"
col_i = 9  # column I
rows_to_delete = []
for r in range(2, ws.max_row + 1):  # skip header row
    cell_val = ws.cell(row=r, column=col_i).value
    if isinstance(cell_val, str) and cell_val.strip().lower() == "hub notes":
        rows_to_delete.append(r)

# Delete rows from bottom to top to keep indices correct
for r in reversed(rows_to_delete):
    ws.delete_rows(r)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (async)
await recalculate(output_path)

# Verify the result by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print(f"After deletion: {ws_check.max_row} rows (including header).")
# Helper to display a row's values
def row_vals(row):
    return [ws_check.cell(row=row, column=c).value for c in range(1, ws_check.max_column + 1)]

print("Header row:", row_vals(1))
print("First few data rows after deletion:")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f"Row {r}:", row_vals(r))
