Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook (read-only is fine for inspection)
wb_path = '/sandbox/input/input_spreadsheet/1_48975_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print('Sheet names:', wb.sheetnames)

# Function to print header and sample rows

def print_sheet_summary(ws, max_rows=5):
    # Assume first row is header
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print(f"\nSheet '{ws.title}' summary:")
    print('Headers:', headers)
    total_rows = ws.max_row
    print('Total rows (including header):', total_rows)
    # Print first few data rows (skip header)
    print('First data rows:')
    for r in range(2, min(2 + max_rows, total_rows + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(r, row_vals)
    # Print last few data rows
    print('Last data rows:')
    start = max(2, total_rows - max_rows + 1)
    for r in range(start, total_rows + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(r, row_vals)

# Iterate over sheets and print summaries
for ws in wb.worksheets:
    print_sheet_summary(ws)
```
