```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_57262_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_57262_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Write correct formulas to T11:T15 based on F and G
for row in range(11, 16):
    # Build formula string with proper quoting
    formula = f'=IF(AND(F{row}="",G{row}=""),"",F{row}*8+G{row}*10)'
    ws.cell(row=row, column=20).value = formula  # column T is 20

# Ensure output directory exists and save
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
await recalculate(output_path)

# Reload with data_only=True to see computed values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Print the resulting values for rows 11-15 in column T
print("Final price point values after recalculation:")
for row in range(11, 16):
    val = ws2.cell(row=row, column=20).value
    print(f"Row {row} T{row}: {val}")
```
