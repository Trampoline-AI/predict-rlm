import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook (read‑only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_599-9_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. List sheet names and dimensions
print("Sheets and dimensions:")
for name in wb.sheetnames:
    ws = wb[name]
    print(f" - {name}: rows={ws.max_row}, cols={ws.max_column}")

# Assume the first sheet is the main data sheet
ws = wb[wb.sheetnames[0]]

# 2. Determine headers (assume first row)
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
print("\nHeaders (row 1):")
for idx, h in enumerate(headers, start=1):
    print(f" {get_column_letter(idx)}: {h}")

# 3. Helper to safely get cell value (including formulas)
def cell_val(cell):
    return cell.value

# 4. Sample first 5 data rows (skip header)
print("\nFirst 5 data rows (columns G and K):")
for r in range(2, min(7, ws.max_row + 1)):
    g = cell_val(ws.cell(row=r, column=column_index_from_string('G')))
    k = cell_val(ws.cell(row=r, column=column_index_from_string('K')))
    print(f" Row {r}: G={g!r}, K={k!r}")

# 5. Sample last 5 data rows
