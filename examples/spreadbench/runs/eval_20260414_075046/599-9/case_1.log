Code:
```repl
import os
import openpyxl
from openpyxl.utils import column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_599-9_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_599-9_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

g_col = column_index_from_string('G')
k_col = column_index_from_string('K')

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    # Iterate data rows (assume header at row 1)
    for r in range(2, max_row + 1):
        cell_g = ws.cell(row=r, column=g_col)
        if cell_g.value is not None:
            # Copy the value to column K
            ws.cell(row=r, column=k_col).value = cell_g.value

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice compatibility)
await recalculate(output_path)

# Verify a few rows after recalculation (load with data_only=True)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
for sheet_name in wb_check.sheetnames:
    ws = wb_check[sheet_name]
    print(f"Verification for sheet {sheet_name} (first 3 data rows):")
    for r in range(2, min(5, ws.max_row + 1)):
        g = ws.cell(row=r, column=g_col).value
        k = ws.cell(row=r, column=k_col).value
        print(f" Row {r}: G={g!r}, K={k!r}")
