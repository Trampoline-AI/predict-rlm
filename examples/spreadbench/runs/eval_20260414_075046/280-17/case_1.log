Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter
from collections import Counter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook for editing (keep formulas etc.)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

max_row = ws.max_row
max_col = ws.max_column

# Identify the target column: first column (excluding header) that has duplicate values
target_col_idx = None
for c in range(1, max_col + 1):
    col_vals = [ws.cell(row=r, column=c).value for r in range(2, max_row + 1)]
    # filter out None
    col_vals = [v for v in col_vals if v is not None]
    if not col_vals:
        continue
    counts = Counter(col_vals)
    if any(cnt > 1 for cnt in counts.values()):
        target_col_idx = c
        break

if target_col_idx is None:
    raise ValueError("No column with duplicate values found.")

target_col_letter = get_column_letter(target_col_idx)
print(f"Target column identified: {target_col_letter} (index {target_col_idx})")

# Map each value to its last row index
last_row_for_value = {}
for r in range(2, max_row + 1):
    val = ws.cell(row=r, column=target_col_idx).value
    if val is None:
        continue
    last_row_for_value[val] = r

rows_to_keep = set(last_row_for_value.values())
print(f"Rows to keep (last occurrence of each unique value): {sorted(rows_to_keep)}")

# Delete rows not in rows_to_keep, iterating from bottom to top
for r in range(max_row, 1, -1):
    if r not in rows_to_keep:
        ws.delete_rows(r)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas using the provided tool
await recalculate(output_path)

# Verify by reloading with data_only and printing remaining rows
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("After deletion, remaining rows (including header):")
for r in ws_check.iter_rows(min_row=1, max_row=ws_check.max_row, values_only=True):
    print(r)
```
