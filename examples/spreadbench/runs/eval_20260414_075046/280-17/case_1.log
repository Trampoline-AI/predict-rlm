```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read-only is fine for inspection)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=True)
print("Sheet names:", wb.sheetnames)

# Use the first sheet (assuming that's the one we need)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row
max_col = ws.max_column
print(f"Rows: {max_row}, Columns: {max_col}")

# Get header row (assume first row contains headers)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Headers (first 20):", headers[:20])

# Print first 10 data rows (excluding header)
print("\nFirst 10 data rows:")
for r in range(2, min(2+10, max_row+1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Print last 5 data rows
print("\nLast 5 data rows:")
for r in range(max_row-4, max_row+1):
    if r < 2:
        continue
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(r, row_vals)

# Identify columns with duplicate values (simple scan)
from collections import Counter
duplicate_columns = []
for c in range(1, max_col+1):
    col_vals = [ws.cell(row=r, column=c).value for r in range(2, max_row+1)]
    # filter out None
    col_vals = [v for v in col_vals if v is not None]
    if not col_vals:
        continue
    counts = Counter(col_vals)
    # if any value appears more than once, consider it a duplicate column
    if any(cnt > 1 for cnt in counts.values()):
        duplicate_columns.append((c, get_column_letter(c), headers[c-1]))

print("\nColumns with duplicate values (index, letter, header):", duplicate_columns)
