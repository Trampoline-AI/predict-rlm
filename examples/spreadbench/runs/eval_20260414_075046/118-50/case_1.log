import os
from openpyxl import load_workbook, Workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_118-50_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_118-50_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # assume the first sheet is the target

# Determine data range
max_row = ws.max_row
max_col = ws.max_column

# --- 1. Sort column A alphabetically (excluding header) ---
# Collect values from column A (row 2 .. max_row)
col_a_vals = [ws.cell(row=r, column=1).value for r in range(2, max_row + 1)]

# Filter out None values (just in case) and sort
sorted_vals = sorted([v for v in col_a_vals if v is not None], key=lambda x: str(x).upper())

# Write sorted values back to column A
for idx, val in enumerate(sorted_vals, start=2):
    ws.cell(row=idx, column=1).value = val

# If there were blank rows after the last non‑empty value, clear them
for r in range(2 + len(sorted_vals), max_row + 1):
    ws.cell(row=r, column=1).value = None

# --- 2. Find pattern matches and transform ---
pattern = "PEA"  # the example pattern; can be changed if needed

for r in range(2, 2 + len(sorted_vals)):
    word = ws.cell(row=r, column=1).value
    if not isinstance(word, str):
        continue
    # Check if the last three letters match the pattern (case‑insensitive)
    if word[-3:].upper() == pattern.upper():
        # Transform: move 5th character (index 4) to the front
        if len(word) >= 5:
            transformed = word[4] + word[:4] + word[5:]
        else:
            # If word shorter than 5 chars, just keep as is
            transformed = word
        # Write original word to column C (index 3) and transformed to column D (index 4)
        ws.cell(row=r, column=3).value = word
        ws.cell(row=r, column=4).value = transformed
    else:
        # Ensure blanks for non‑matches
        ws.cell(row=r, column=3).value = None
        ws.cell(row=r, column=4).value = None

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)  # noqa: E999 (async call handled by the environment)

# Reload with data_only to check results
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Verify a few rows (first 5 matches) and print summary
matches = []
for r in range(2, ws_check.max_row + 1):
    orig = ws_check.cell(row=r, column=3).value
    trans = ws_check.cell(row=r, column=4).value
    if orig or trans:
        matches.append((r, orig, trans))

print(f"Total matches written: {len(matches)}")
print("Sample matches (row, original, transformed):")
for sample in matches[:5]:
    print(sample)
