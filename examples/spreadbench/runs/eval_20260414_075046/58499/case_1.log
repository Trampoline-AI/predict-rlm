import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_58499_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_58499_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row
max_col = ws.max_column

# Define columns
col_A = 1  # Branches
col_I = 9  # Checked tick
col_J = 10  # Output list (UntickedBranches)
col_K = 11  # Helper rank (UntickedRank)

# Write headers
ws.cell(row=1, column=col_J, value="UntickedBranches")
ws.cell(row=1, column=col_K, value="UntickedRank")

# Fill helper column K with cumulative count of unticked rows
for r in range(2, max_row + 1):
    # Formula: =IF(Ir<>"ü",COUNTIF($I$2:Ir,"<>ü"),"")
    formula_k = f"=IF(I{r}<\"ü\",COUNTIF($I$2:I{r},\"<>ü\"),\"\")"
    ws.cell(row=r, column=col_K, value=formula_k)

# Fill output column J with the list of unticked branches
for r in range(2, max_row + 1):
    # Formula: =IFERROR(INDEX($A$2:$A${max_row},MATCH(ROW()-ROW($J$2)+1,$K$2:$K${max_row},0)) ,"")
    formula_j = f"=IFERROR(INDEX($A$2:$A${max_row},MATCH(ROW()-ROW($J$2)+1,$K$2:$K${max_row},0)),\"\")"
    ws.cell(row=r, column=col_J, value=formula_j)

# Ensure output directory exists
import os
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas using the provided tool
await recalculate(output_path)

# Reload with data_only to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Verification of column J (UntickedBranches):")
for r in range(2, max_row + 1):
    val = ws_check.cell(row=r, column=col_J).value
    print(f"Row {r}: {val!r}")
