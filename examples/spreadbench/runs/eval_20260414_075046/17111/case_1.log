```repl
# After confirming column positions, we will write the correct formulas.
# Assuming:
#   Column A in Sheet1 = Name
#   Column B in Sheet1 = Type (values "HD" or "SD")
#   Column C in Sheet1 = Status (e.g., "Completed", "Not Completed")
#   Column D in Sheet1 = Amount (numeric)
# The Summary sheet will have:
#   Column A = Name (already filled)
#   Column B = HD sum (we will write formula)
#   Column C = SD sum (we will write formula)
#   Column F = Status (criteria; may be blank to include both)

ws_summary = wb['Summary']
max_row_sum = ws_summary.max_row
max_col_sum = ws_summary.max_column

# Helper to write formula into a cell
def write_sumif(ws, row, type_col_letter, name_cell, status_cell):
    """
    ws: worksheet (Summary)
    row: int, row number
    type_col_letter: 'B' for HD, 'C' for SD
    name_cell: e.g., 'A2'
    status_cell: e.g., 'F2' (Status column)
    """
    # Build criteria strings
    # Type criteria is the header of the column (HD or SD)
    type_header = ws[f"{type_col_letter}1"].value  # e.g., "HD" or "SD"
    # If status cell is blank, we want to include both Completed and Not Completed.
    # We'll use SUMIFS with two status criteria combined via + (i.e., sum of two SUMIFS)
    # Formula pattern:
    # =SUMIFS(Sheet1!$D:$D, Sheet1!$A:$A, NameCell, Sheet1!$B:$B, "HD", Sheet1!$C:$C, "Completed")
    #   +IFS(Sheet1!$D:$D, Sheet1!$A:$A, NameCell, Sheet1!$B:$B, "HD", Sheet1!$C:$C, "Not Completed")
    # If status cell contains a specific status, just one SUMIFS.

    # Escape double quotes inside the string
    name_ref = name_cell
    status_ref = status_cell

    # Build the formula string
    # Use absolute references for the lookup ranges, relative for the name/status cells.
    base_range = "Sheet1!$D:$D"
    name_range = "Sheet1!$A:$A"
    type_range = "Sheet1!$B:$B"
    status_range = "Sheet1!$C:$C"

    # If status cell is empty, we sum both statuses
    # We'll embed an IF to test emptiness:
    # =IF(F2="", SUMIFS(...,"Completed") + SUMIFS(...,"Not Completed"), SUMIFS(...,F2))
    # Note: LibreOffice requires IFERROR for missing values; but IF works fine.

    formula = (
        f"=IF({status_ref}=\"\", "
        f"SUMIFS({base_range}, {name_range}, {name_ref}, {type_range}, \"{type_header}\", {status_range}, \"Completed\") + "
        f"SUMIFS({base_range}, {name_range}, {name_ref}, {type_range}, \"{type_header}\", {status_range}, \"Not Completed\"), "
        f"SUMIFS({base_range}, {name_range}, {name_ref}, {type_range}, \"{type_header}\", {status_range}, {status_ref}))"
    )
    # Write formula to the target cell
    target_cell = f"{type_col_letter}{row}"
    ws[target_cell] = formula

# Loop over data rows (starting at row 2) and write formulas for HD (col B) and SD (col C)
for r in range(2, max_row_sum + 1):
    name_cell = f"A{r}"
    status_cell = f"F{r}"  # Assuming Status is column F (based on header list)
    # Write HD formula (column B)
    write_sumif(ws_summary, r, "B", name_cell, status_cell)
    # Write SD formula (column C)
    write_sumif(ws_summary, r, "C", name_cell, status_cell)

# Save to output directory
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_17111_init.xlsx')
wb.save(output_path)

# Recalculate formulas and verify a few cells
await recalculate(output_path)

# Reload with data_only to see computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['Summary']
print('Sample computed sums (first 5 rows):')
for r in range(2, min(7, ws_check.max_row+1)):
    print(r, ws_check[f'B{r}'].value, ws_check[f'C{r}'].value)
