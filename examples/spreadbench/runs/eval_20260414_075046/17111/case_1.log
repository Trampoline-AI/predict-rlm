Code:
```repl
import os, openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_17111_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, '1_17111_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Worksheets
ws_sum = wb['Summary']
ws_data = wb['Sheet1']

# Determine max rows in Summary (skip header)
max_row = ws_sum.max_row

# Helper to write the appropriate SUMIFS formula for a given type column (HD or SD)
def write_sumif(row, type_col_letter):
    # Header of the type column (e.g., "HD" or "SD")
    type_header = ws_sum[f"{type_col_letter}1"].value
    name_cell = f"A{row}"
    status_cell = f"F{row}"  # Status column in Summary (based on earlier inspection)

    # Build formula using correct Sheet1 column layout:
    # Amount: D, Name: B, Type: C, Status: A
    amount_range = "Sheet1!$D:$D"
    name_range = "Sheet1!$B:$B"
    type_range = "Sheet1!$C:$C"
    status_range = "Sheet1!$A:$A"

    # Formula:
    # =IF(F2="", SUMIFS(amount_range, name_range, A2, type_range, "HD", status_range, "Completed")
    #                + SUMIFS(..., status_range, "Not Completed"),
    #          SUMIFS(amount_range, name_range, A2, type_range, "HD", status_range, F2))
    formula = (
        f"=IF({status_cell}=\"\", "
        f"SUMIFS({amount_range}, {name_range}, {name_cell}, {type_range}, \"{type_header}\", {status_range}, \"Completed\") + "
        f"SUMIFS({amount_range}, {name_range}, {name_cell}, {type_range}, \"{type_header}\", {status_range}, \"Not Completed\"), "
        f"SUMIFS({amount_range}, {name_range}, {name_cell}, {type_range}, \"{type_header}\", {status_range}, {status_cell}))"
    )
    ws_sum[f"{type_col_letter}{row}"] = formula

# Write formulas for each data row (starting at row 2)
for r in range(2, max_row + 1):
    write_sumif(r, "B")  # HD column
    write_sumif(r, "C")  # SD column

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
await recalculate(output_path)

# Reload with data_only to see computed values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['Summary']

# Print a few sample computed sums for verification
print("Sample computed sums (first 5 data rows):")
for r in range(2, min(7, ws_check.max_row + 1)):
    hd_val = ws_check[f"B{r}"].value
    sd_val = ws_check[f"C{r}"].value
    print(f"Row {r}: HD = {hd_val}, SD = {sd_val}")
```
