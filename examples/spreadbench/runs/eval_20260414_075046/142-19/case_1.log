wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row
max_col = ws.max_column

def is_blank(cell):
    """Return True if a cell is considered blank (None or empty/whitespace string)."""
    val = cell.value
    if val is None:
        return True
    if isinstance(val, str) and val.strip() == "":
        return True
    return False

# Process each contiguous non‑blank block in column A (column 1)
row = 2  # start after header
while row <= max_row:
    # Skip blank rows
    while row <= max_row and is_blank(ws.cell(row=row, column=1)):
        row += 1
    if row > max_row:
        break

    # Start of a block
    block_start = row
    block_data = []  # list of (val_a, val_b)
    while row <= max_row and not is_blank(ws.cell(row=row, column=1)):
        val_a = ws.cell(row=row, column=1).value
        val_b = ws.cell(row=row, column=2).value
        block_data.append((val_a, val_b))
        row += 1
    block_end = row - 1

    # Sort block by column A (string order, case‑sensitive)
    sorted_block = sorted(block_data, key=lambda x: x[0] if x[0] is not None else "")

    # Write sorted values back to the same rows in order
    for offset, (new_a, new_b) in enumerate(sorted_block):
        target_row = block_start + offset
        ws.cell(row=target_row, column=1).value = new_a
        ws.cell(row=target_row, column=2).value = new_b

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (if any) and reload for verification
await recalculate(output_path)
wb_verified = openpyxl.load_workbook(output_path, data_only=True)
wsv = wb_verified[wb_verified.sheetnames[0]]

def print_rows(start, end):
    for r in range(start, end + 1):
        print(r, [wsv.cell(row=r, column=c).value for c in range(1, 3)])

print("First sorted block (rows 2‑10):")
print_rows(2, 10)

# Find the last non‑blank block start for verification
# Scan from bottom upwards to locate the last block start
last_block_start = None
r = max_row
while r >= 2:
    if not is_blank(wsv.cell(row=r, column=1)):
        # walk up to the start of this block
        while r >= 2 and not is_blank(wsv.cell(row=r, column=1)):
            r -= 1
        last_block_start = r + 1
        break
    r -= 1

if last_block_start:
    last_block_end = max_row
    # adjust end to the last non‑blank row
    while last_block_end >= last_block_start and is_blank(wsv.cell(row=last_block_end, column=1)):
        last_block_end -= 1
    print(f"Last sorted block (rows {last_block_start}‑{last_block_end}):")
    print_rows(last_block_start, last_block_end)
else:
    print("No non‑blank block found at the bottom of the sheet.")
