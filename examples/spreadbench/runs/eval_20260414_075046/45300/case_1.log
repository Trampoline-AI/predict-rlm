import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Load the input workbook
input_path = "/sandbox/input/input_spreadsheet/1_45300_init.xlsx"
wb = openpyxl.load_workbook(input_path, data_only=False)  # keep formulas

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Use the first sheet (assuming only one)
ws = wb[wb.sheetnames[0]]

# Determine max rows and columns
max_row = ws.max_row
max_col = ws.max_column
print(f"Rows: {max_row}, Columns: {max_col}")

# Print header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Headers:", headers)

# Print first 5 data rows and last 5 data rows (excluding header)
def row_to_list(r):
    return [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]

print("First 5 data rows:")
for r in range(2, min(2+5, max_row+1)):
    print(r, row_to_list(r))

print("Last 5 data rows:")
for r in range(max(max_row-4, 2), max_row+1):
    print(r, row_to_list(r))

# Identify source column: look for a column containing 'FT' in its values
source_col_idx = None
for c in range(1, max_col+1):
    for r in range(2, max_row+1):
        val = ws.cell(row=r, column=c).value
        if isinstance(val, str) and "FT" in val:
            source_col_idx = c
            break
    if source_col_idx:
        break

if source_col_idx:
    print(f"Detected source column: {get_column_letter(source_col_idx)} (index {source_col_idx})")
else:
    print("No column containing 'FT' found in sample data.")

# Ensure column B exists for output (index 2)
target_col_idx = column_index_from_string('B')
print(f"Target column for output: B (index {target_col_idx})")

# Apply transformation: for each row, truncate at first 'FT' occurrence
for r in range(2, max_row+1):
    src_cell = ws.cell(row=r, column=source_col_idx)
    src_val = src_cell.value
    if isinstance(src_val, str):
        ft_pos = src_val.find("FT")
        if ft_pos != -1:
            new_val = src_val[:ft_pos]  # keep text before 'FT'
        else:
            new_val = src_val
    else:
        new_val = src_val  # non-string unchanged
    ws.cell(row=r, column=target_col_idx).value = new_val

# Save to output directory with same filename
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_45300_init.xlsx")
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas
import asyncio
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to verify column B values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print("Verification - first 5 rows of column B:")
for r in range(2, min(7, ws2.max_row+1)):
    print(r, ws2.cell(row=r, column=target_col_idx).value)

print("Verification - last 5 rows of column B:")
for r in range(max(ws2.max_row-4, 2), ws2.max_row+1):
    print(r, ws2.cell(row=r, column=target_col_idx).value)
```
