```repl
import openpyxl
from openpyxl.styles import PatternFill
from itertools import combinations
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_254-34_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_254-34_init.xlsx")

# Load workbook (preserve styles)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify the 'Before' sheet (case‑insensitive)
ws = None
for name in wb.sheetnames:
    if name.lower() == "before":
        ws = wb[name]
        break
if ws is None:
    raise ValueError("Sheet named 'Before' not found")

# Gather values and their row numbers (skip header row 1)
values = []
rows = []
for r in range(2, ws.max_row + 1):
    cell = ws.cell(row=r, column=1)  # column A
    val = cell.value
    # Ensure numeric (ignore blanks / non‑numeric)
    if isinstance(val, (int, float)):
        values.append(val)
        rows.append(r)

# Target sum range
low, high = 994108, 994112

# Find all rows that belong to any valid combination
valid_rows = set()

# Brute‑force all subsets (2^n). n= len(values) is small (≈15).
# We'll iterate over combination lengths to avoid building the full power set at once.
for k in range(1, len(values) + 1):
    for combo in combinations(range(len(values)), k):
        s = sum(values[i] for i in combo)
        if low <= s <= high:
            # Record the actual row numbers for these indices
            for i in combo:
                valid_rows.add(rows[i])

# Apply green fill to each qualifying cell in column A
green_fill = PatternFill(start_color="00FF00", end_color="00FF00", fill_type="solid")
for r in valid_rows:
    ws.cell(row=r, column=1).fill = green_fill

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook to output location
wb.save(output_path)

# Recalculate (no formulas, but required by workflow)
await recalculate(output_path)

# Reload with data_only to verify (fills are not part of data_only, but we check that the file exists)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws.title]
print(f"Number of highlighted rows: {len(valid_rows)}")
print("Highlighted row numbers (first 10):", sorted(list(valid_rows))[:10])
```
