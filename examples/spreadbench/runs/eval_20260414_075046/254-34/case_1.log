import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_254-34_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas and styles

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows
def print_sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {ws.title}")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # Print last 5 data rows
    start_last = max(2, max_row-4)
    print("Last 5 data rows:")
    for r in range(start_last, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # If this is the 'before' sheet, also inspect cell fill colors for first few rows
    if ws.title.lower() == "before":
        print("Sample cell fill colors (first 10 rows, columns A-E):")
        for r in range(2, min(12, max_row+1)):
            colors = []
            for c in range(1, min(6, max_col+1)):
                cell = ws.cell(row=r, column=c)
                fill = cell.fill
                # openpyxl stores fill colors in fgColor
                color = fill.fgColor.rgb if fill.fgColor else None
                colors.append(color)
            print(f"Row {r} colors:", colors)

# Iterate through sheets
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print_sheet_summary(ws)
```
