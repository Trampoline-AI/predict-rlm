```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["INPUTS"]

# Determine the last row with a label in column A (skip header rows)
max_row = ws.max_row
last_data_row = 1
for r in range(2, max_row + 1):
    val = ws.cell(row=r, column=1).value
    if val is not None and str(val).strip() != "":
        last_data_row = r

print(f"Data rows in column A go up to row {last_data_row}")

# Update formulas in columns C (3) to G (7) for rows starting at 15 up to last_data_row
for row in range(15, last_data_row + 1):
    # Build the relative row lookup reference (e.g., INPUTS!A15)
    lookup_row_ref = f"INPUTS!A{row}"
    for col_idx, header_col in zip(range(3, 8), ["C", "D", "E", "F", "G"]):
        # Header row is always row 3, column header cell reference like INPUTS!C3
        header_ref = f"INPUTS!{header_col}3"
        # Build the new formula string (LibreOffice requires _xlfn.IFNA prefix)
        formula = f"=_xlfn.IFNA(INDEX(Sheet2!C3:G20,MATCH({lookup_row_ref},Sheet2!A3:A20,0),MATCH({header_ref},Sheet2!C1:G1,0)),0)"
        ws.cell(row=row, column=col_idx).value = formula

# Save to output location
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Reload with data_only to verify a few cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["INPUTS"]
print("Sample recalculated values:")
for r in range(15, min(15+5, last_data_row+1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(3, 8)]
    print(f"Row {r}: {vals}")
```
