import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_52964_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_52964_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

# Determine the last row with data (excluding possible completely empty trailing rows)
last_row = ws.max_row

# Build the formula string (LibreOffice compatible)
formula = '=IFERROR(INDEX(U:U, MATCH(A2, Q:Q, 0)) - INDEX(Y:Y, MATCH(A2, Q:Q, 0)), 0)'

# Write to C2 and D2 as a demonstration, then fill down
for col_letter in ["C", "D"]:   # user asked for C2 and D2 (and other cells)
    # Write header row formula (row 2)
    ws[f"{col_letter}2"] = formula
    # Fill down to last row
    for r in range(3, last_row + 1):
        # Adjust the row reference inside the formula (A2 → A3, etc.)
        # We can use relative references by removing the row number, but to keep it simple we rewrite per row.
        row_formula = formula.replace("A2", f"A{r}")
        ws[f"{col_letter}{r}"] = row_formula

# Save workbook to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice + python formulas library)
await recalculate(output_path)

# Reload with data_only to read computed values
wb_calc = openpyxl.load_workbook(output_path, data_only=True)
ws_calc = wb_calc[ws_calc.sheetnames[0]]

# Verify a few sample rows for C and D
samples = []
for r in [2, 3, 4, 5, last_row]:
    samples.append((r, ws_calc[f"C{r}"].value, ws_calc[f"D{r}"].value))

print("Sample results (row, C, D):")
for s in samples:
    print(s)

# Explanation of array constants (will be printed for the user)
explanation = """
Array constants in Excel/LibreOffice formulas:

- {5,9} : When used as the column_index argument of VLOOKUP (or inside INDEX), this array tells the function to return two columns at once – the 5th and the 9th column of the lookup table. In a SUMPRODUCT context it can be used to multiply two separate columns together in a single expression.

- {-1,1} : This array is often used inside SUMPRODUCT to apply a sign change. For example, SUMPRODUCT(A1:A10, {-1,1}) would multiply the first element of A by -1 and the second by +1, then sum the results. It is a compact way to compute (‑value) + (value) without writing separate formulas.

Both constants are just literal arrays; they are not ranges. They are evaluated by the calculation engine as a small set of numbers that can be combined with other arrays or ranges.
"""
print(explanation)
```
