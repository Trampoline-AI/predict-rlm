import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read‑only for inspection)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
print("Sheet names:", wb.sheetnames)

# We'll inspect the first sheet (assuming the data is there)
ws = wb[wb.sheetnames[0]]

# Determine max row and column (including possible empty trailing rows)
max_row = ws.max_row
max_col = ws.max_column
print(f"Rows: {max_row}, Columns: {max_col}")

# Read header row (assume first row is header)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Headers:", headers)

# Helper to print a row as list of values

def row_values(r):
    return [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]

# Print first 5 data rows (rows 2‑6)
print("First 5 data rows:")
for r in range(2, min(2+5, max_row+1)):
    print(r, row_values(r))

# Print last 5 data rows (if enough rows)
print("Last 5 data rows:")
start = max(2, max_row-4)
for r in range(start, max_row+1):
    print(r, row_values(r))
