print("Result sheet columns:", num_cols)

# Starting row for new data
next_row = result_ws.max_row + 1
for uid in missing_ids:
    # Write ID in column A
    result_ws.cell(row=next_row, column=1, value=uid)
    # Ensure other columns are empty (openpyxl defaults to None, but we set explicitly)
    for col in range(2, num_cols + 1):
        result_ws.cell(row=next_row, column=col, value=None)
    next_row += 1

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and reload for verification
