import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_395-36_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheet names (exact)
main_ws = wb["Main unique ID"]
result_ws = wb["Result what i am getting"]

# Helper to collect IDs from a sheet (first column, starting at row 2)
def collect_ids(ws):
    ids = []
    for row in range(2, ws.max_row + 1):
        val = ws.cell(row=row, column=1).value
        if val is not None:
            ids.append(val)
    return ids

main_ids = set(collect_ids(main_ws))
result_ids = set(collect_ids(result_ws))

missing_ids = sorted(main_ids - result_ids)  # sorted for deterministic order
print("Missing IDs to add:", missing_ids)

# Append rows for each missing ID
# Determine the number of columns in result sheet (should be 15)
