import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_12864_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_12864_init.xlsx")
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Determine number of data rows in Sheet1 (assume header in row 1)
max_row = ws1.max_row

# Add / overwrite headers for new columns E (5) and F (6)
ws1.cell(row=1, column=5, value="Date")   # Column E
ws1.cell(row=1, column=6, value="Data")   # Column F

# Write formulas for each data row
for r in range(2, max_row + 1):
    # Lookup value from Sheet1 column D (Existing Data Fields)
