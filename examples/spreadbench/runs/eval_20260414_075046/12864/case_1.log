import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook (read‑only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_12864_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# 1. Sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print sheet summary
def sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (assume first row contains headers)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # First 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Summarize each sheet
for ws in wb.worksheets:
    sheet_summary(ws)

# Identify column indices for B, C, D on each sheet (just for reference)
for ws in wb.worksheets:
    col_B = column_index_from_string('B')
    col_C = column_index_from_string('C')
    col_D = column_index_from_string('D')
    print(f"\n{ws.title} column indices -> B:{col_B}, C:{col_C}, D:{col_D}")

# Close workbook (not strictly needed in this REPL)
wb.close()
```
