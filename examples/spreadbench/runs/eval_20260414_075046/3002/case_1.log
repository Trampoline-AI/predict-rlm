Code:
```repl
import openpyxl
from openpyxl.styles import PatternFill, Border
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_3002_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_3002_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# ----------------------------------------------------------------------
# 1. Locate header row and column indices (already known but recompute for safety)
header_row = None
for r in range(1, min(20, ws.max_row + 1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    if ("Mat Doc" in row_vals) and ("Doc No" in row_vals) and ("Remark" in row_vals):
        header_row = r
        break
if header_row is None:
    raise ValueError("Header row with required columns not found.")

# Map column names to 1‑based indices
headers = [ws.cell(row=header_row, column=c).value for c in range(1, ws.max_column + 1)]
col_idx = {name: idx + 1 for idx, name in enumerate(headers) if name}
matdoc_col = col_idx["Mat Doc"]
docno_col = col_idx["Doc No"]
remark_col = col_idx["Remark"]

# Data range (first data row after header)
first_data_row = header_row + 1
last_data_row = ws.max_row

# ----------------------------------------------------------------------
# 2. Write duplicate‑check formula into Remark column for each data row
# Build absolute range strings using the actual last row
matdoc_range = f"${get_column_letter(matdoc_col)}${first_data_row}:${get_column_letter(matdoc_col)}${last_data_row}"
docno_range = f"${get_column_letter(docno_col)}${first_data_row}:${get_column_letter(docno_col)}${last_data_row}"

for r in range(first_data_row, last_data_row + 1):
    # Current row references (relative)
    matdoc_cell = f"${get_column_letter(matdoc_col)}${r}"
    docno_cell = f"${get_column_letter(docno_col)}${r}"
    formula = f"""=IF(COUNTIFS({matdoc_range},{matdoc_cell},{docno_range},{docno_cell})>1,"Multiple","Single")"""
    ws.cell(row=r, column=remark_col).value = formula

# ----------------------------------------------------------------------
# 3. Clear all fill colour and border formatting in the used range
for r in range(1, ws.max_row + 1):
    for c in range(1, ws.max_column + 1):
        cell = ws.cell(row=r, column=c)
        # Reset fill to default (no colour)
        cell.fill = PatternFill(fill_type=None)
        # Reset border to default (no borders)
        cell.border = Border()

# ----------------------------------------------------------------------
# 4. Save to output location
import os
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# ----------------------------------------------------------------------
# 5. Recalculate formulas
await recalculate(output_path)

# ----------------------------------------------------------------------
# 6. Reload with data_only=True to verify a few Remark cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

print("\nVerification of Remark column (first 5 data rows):")
for r in range(first_data_row, min(first_data_row + 5, last_data_row + 1)):
    val = ws_check.cell(row=r, column=remark_col).value
    print(f"Row {r}: {val}")

print("\nVerification of Remark column (last 5 data rows):")
start = max(first_data_row, last_data_row - 4)
for r in range(start, last_data_row + 1):
    val = ws_check.cell(row=r, column=remark_col).value
    print(f"Row {r}: {val}")
