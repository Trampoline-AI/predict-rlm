import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_3002_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows
def inspect_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"\nSheet: {ws.title}")
    print("Headers:", headers)
    # Find column indices for relevant columns
    def col_idx(name):
        try:
            return headers.index(name) + 1  # 1-indexed
        except ValueError:
            return None
    remark_idx = col_idx("Remark")
    matdoc_idx = col_idx("Mat Doc")
    docno_idx = col_idx("Doc No")
    print(f"Column indices -> Remark: {remark_idx}, Mat Doc: {matdoc_idx}, Doc No: {docno_idx}")

    # Print first 5 data rows (excluding header)
    print("\nFirst 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}: {row_vals}")

    # Print last 5 data rows
    print("\nLast 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}: {row_vals}")

    # Sample Remark values if column exists
    if remark_idx:
        print("\nSample Remark values (first 5 rows):")
        for r in range(2, min(2+5, max_row+1)):
            print(f"Row {r}: {ws.cell(row=r, column=remark_idx).value}")

# Inspect each sheet
for ws in wb.worksheets:
    inspect_sheet(ws)
