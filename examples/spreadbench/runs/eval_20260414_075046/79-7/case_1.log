Code:
```repl
import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_79-7_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_79-7_init.xlsx")

# Load workbook (preserve formulas, though none exist)
wb = load_workbook(input_path, data_only=False)

# Iterate over all sheets and all cells, removing double quotes
for ws in wb.worksheets:
    for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
        for cell in row:
            val = cell.value
            if isinstance(val, str):
                # Replace all double‑quote characters
                new_val = val.replace('"', '')
                # Only write back if changed (avoid unnecessary writes)
                if new_val != val:
                    cell.value = new_val

# Save modified workbook
wb.save(output_path)

# Recalculate formulas (no formulas here, but required by workflow)
await recalculate(output_path)

# Reload with data_only=True to verify results
wb_check = load_workbook(output_path, data_only=True)

# Print cleaned rows for verification
ws_check = wb_check["Sheet1"]
print("Cleaned data rows:")
for r in range(2, ws_check.max_row + 1):
    print(f"Row {r}:", ws_check.cell(row=r, column=1).value)
```
