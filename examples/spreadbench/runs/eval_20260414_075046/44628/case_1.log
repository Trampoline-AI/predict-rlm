```repl
import openpyxl
from openpyxl import load_workbook

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_44628_init.xlsx"
wb = load_workbook(wb_path, data_only=False)  # keep formulas
print("Workbook loaded from:", wb_path)

# List sheet names
sheet_names = wb.sheetnames
print("Sheet names:", sheet_names)

# Use the first sheet (assuming data is there)
ws = wb[sheet_names[0]]
print("Active sheet:", ws.title)

# Dimensions
max_row = ws.max_row
max_col = ws.max_column
print(f"Dimensions: rows={max_row}, columns={max_col}")

# Helper to convert column index to letter
from openpyxl.utils import get_column_letter

# Print header row (assume row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Headers:", headers)

# Print first 10 data rows (excluding header)
print("\nFirst 10 data rows:")
for r in range(2, min(2+10, max_row+1)):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(f"Row {r}:", row_vals)

# Print last 5 data rows
print("\nLast 5 data rows:")
start_last = max(2, max_row-4)
for r in range(start_last, max_row+1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(f"Row {r}:", row_vals)

# Print current values in target range D3:G3
target_cells = ["D3", "E3", "F3", "G3"]
print("\nCurrent values in D3:G3:")
for cell_ref in target_cells:
    cell = ws[cell_ref]
    print(f"{cell_ref}: {cell.value}")

# Save workbook back (no changes yet)
output_path = "/sandbox/output/output_spreadsheet/1_44628_init.xlsx"
wb.save(output_path)
print("Saved copy to:", output_path)
