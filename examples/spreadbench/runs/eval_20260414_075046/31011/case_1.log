```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb = openpyxl.load_workbook(input_spreadsheet)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# We'll work with the first sheet (adjust if multiple)
ws = wb[wb.sheetnames[0]]
print(f"Active sheet: {ws.title}")

# 2. Dimensions
print("Max row:", ws.max_row, "Max column:", ws.max_column)

# 3. Header row (row 1) values up to max column
headers = [ws.cell(row=1, column=col).value for col in range(1, ws.max_column + 1)]
print("Header row (row 1) values:", headers)

# Helper to print a row as list
def row_values(r):
    return [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]

# 4. Sample first 5 data rows (rows 2-6)
print("\nFirst 5 data rows (rows 2-6):")
for r in range(2, min(7, ws.max_row + 1)):
    print(f"Row {r}:", row_values(r))

# 5. Sample last 5 data rows
print("\nLast 5 data rows:")
start = max(2, ws.max_row - 4)
for r in range(start, ws.max_row + 1):
    print(f"Row {r}:", row_values(r))

# 6. Print reference cells
cells_to_check = ["P6", "Q6", "R3", "R4", "R6"]
print("\nReference cell values:")
for cell in cells_to_check:
    print(f"{cell}: {ws[cell].value}")

# Save (no changes) just to be safe
wb.save("/sandbox/output/temp_inspection.xlsx")
```
