import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_54590_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Use the first sheet (assuming only one)
ws = wb[wb.sheetnames[0]]
print(f"Active sheet: {ws.title}")

# Determine max rows and columns
max_row = ws.max_row
max_col = ws.max_column
print(f"Max row: {max_row}, Max column: {max_col}")

# Print column headers (row 1)
headers = [ws.cell(row=1, column=col).value for col in range(1, max_col+1)]
print("Headers (first row):")
for idx, header in enumerate(headers, start=1):
    col_letter = get_column_letter(idx)
    print(f"{col_letter}{idx}: {header}")

# Helper to print a row as a dict of column letters to values
def row_to_dict(r):
    return {get_column_letter(c): ws.cell(row=r, column=c).value for c in range(1, max_col+1)}

# Print first 5 data rows (excluding header)
print("\nFirst 5 data rows:")
for r in range(2, min(7, max_row+1)):
    print(f"Row {r}:", row_to_dict(r))

# Print last 5 data rows
print("\nLast 5 data rows:")
start = max(2, max_row-4)
for r in range(start, max_row+1):
    print(f"Row {r}:", row_to_dict(r))

# Verify presence of columns GK, GR, GO
col_letters = {"GK": None, "GR": None, "GO": None}
for idx in range(1, max_col+1):
    col_letter = get_column_letter(idx)
    if col_letter in col_letters:
        col_letters[col_letter] = idx
print("\nColumn indices:", col_letters)

# Print current value/formula in GK29 if exists
cell_gk29 = ws["GK29"]
print("\nCurrent GK29 value:", cell_gk29.value)

# Print a few sample cells from GO column to see 'yes' values
print("\nSample GO column values (rows 2-6):")
for r in range(2, 7):
    print(f"GO{r}:", ws[f"GO{r}"].value)

# Save workbook (no changes yet)
wb.save(wb_path)
```
