Code:
```repl
import openpyxl
import os

# Paths
input_path = input_spreadsheet  # /sandbox/input/input_spreadsheet/1_55979_init.xlsx
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_55979_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Target sheet (named "Calc")
calc_ws = wb["Calc"]

# Write the supplier‑lookup formula into B7
formula = (
    '=IF(NOT(ISERROR(VLOOKUP($A$10,Supplier_1!$A:$A,1,FALSE))),"Supplier_1",'
    'IF(NOT(ISERROR(VLOOKUP($A$10,Supplier_2!$A:$A,1,FALSE))),"Supplier_2",'
    'IF(NOT(ISERROR(VLOOKUP($A$10,Supplier_3!$A:$A,1,FALSE))),"Supplier_3","Not found")))'
)
calc_ws["B7"].value = formula

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice + python formulas)
await recalculate(output_path)

# Reload with cached values to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
check_ws = wb_check["Calc"]
print("B7 after recalculation:", check_ws["B7"].value)
```
