import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)

print("Sheets:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print(f"\n--- Sheet: {sheet_name} ---")
    # Determine max rows and columns (use max_row, max_column)
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Rows: {max_row}, Columns: {max_col}")
    # Print header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Print first 5 data rows (row 2 to 6)
    print("First 5 rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last 5 data rows (if more than 6 rows)
    if max_row > 6:
        print("Last 5 rows:")
        for r in range(max_row-4, max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(r, row_vals)
    # Check cells I12 and I13 (column I = 9)
    for target_row in [12, 13]:
        cell = ws.cell(row=target_row, column=9)
        print(f"Cell I{target_row}: value={cell.value}, data_type={cell.data_type}")
