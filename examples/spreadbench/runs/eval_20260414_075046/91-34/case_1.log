Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
from pathlib import Path

# Paths
input_path = Path(input_spreadsheet)
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / input_path.name

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
sheet_name = wb.sheetnames[0]
ws = wb[sheet_name]

# Identify header row (the first row that contains a non‑None value in column 2)
header_row_idx = 1
for r in range(1, ws.max_row + 1):
    if ws.cell(row=r, column=2).value is not None:
        header_row_idx = r
        break

# Build header list from that row
headers = [ws.cell(row=header_row_idx, column=c).value for c in range(1, ws.max_column + 1)]

# Helper to get column index by header name (1‑based)
def col_idx(name):
    try:
        return headers.index(name) + 1
    except ValueError:
        return None

# Column indices
last_name_col = col_idx("Last Name")
first_name_col = col_idx("First Name")
dob_col = col_idx("Date Of Birth")
dup_col = col_idx("Duplicate?")
rel_col = col_idx("Relationship")

missing = [c for c, n in [("Last Name", last_name_col),
                           ("First Name", first_name_col),
                           ("Date Of Birth", dob_col),
                           ("Duplicate?", dup_col),
                           ("Relationship", rel_col)] if n is None]
if missing:
    raise RuntimeError(f"Missing required columns: {missing}")

# Collect rows where Duplicate? == "Yes"
dup_rows = []  # list of (row_index, key_tuple, relationship)
for r in range(header_row_idx + 1, ws.max_row + 1):
    if ws.cell(row=r, column=dup_col).value == "Yes":
        key = (ws.cell(row=r, column=last_name_col).value,
               ws.cell(row=r, column=first_name_col).value,
               ws.cell(row=r, column=dob_col).value)
        rel = ws.cell(row=r, column=rel_col).value
        dup_rows.append((r, key, rel))

# Group rows by key
from collections import defaultdict
grouped = defaultdict(list)  # key -> list of (row, relationship)
for row, key, rel in dup_rows:
    grouped[key].append((row, rel))

# Determine which rows to delete (one per qualifying group)
rows_to_delete = []
for key, entries in grouped.items():
    # If any entry has Relationship == "Employee", skip this group
    if any(rel == "Employee" for _, rel in entries):
        continue
    # Otherwise, delete the first row in the group
    rows_to_delete.append(entries[0][0])

# Delete rows from bottom to top
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

print(f"Deleted {len(rows_to_delete)} rows.")
if rows_to_delete:
    print("Rows removed:", rows_to_delete)

# Save workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(str(output_path))

# Verify by reloading with data_only=True and printing a few rows around deletions
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[sheet_name]

print("\nSample rows after deletion (first 5 data rows):")
for r in range(header_row_idx + 1, min(ws_check.max_row, header_row_idx + 5) + 1):
    vals = [ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column + 1)]
    print(r, vals)
```
