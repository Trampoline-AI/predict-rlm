```repl
import openpyxl
from openpyxl.utils import column_index_from_string

# Load the workbook
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
print("Sheet names:", wb.sheetnames)

# Assume primary sheet is the first one
ws = wb[wb.sheetnames[0]]

# Get headers from first row
headers = [ws.cell(row=1, column=col).value for col in range(1, ws.max_column + 1)]
print("Headers:", headers)

# Helper to get column index by header name
def col_idx(name):
    try:
        return headers.index(name) + 1  # 1-indexed for openpyxl
    except ValueError:
        return None

# Print first 5 data rows (row 2 onward)
print("\nFirst 5 data rows:")
for r in range(2, min(ws.max_row, 6) + 1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    print(r, row_vals)

# Print last 5 data rows
print("\nLast 5 data rows:")
start = max(2, ws.max_row - 4)
for r in range(start, ws.max_row + 1):
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    print(r, row_vals)

# Identify rows where Duplicate? == "Yes"
dup_col = col_idx("Duplicate?")
if dup_col:
    print("\nRows with Duplicate? = Yes (show up to 10):")
    count = 0
    for r in range(2, ws.max_row + 1):
        if ws.cell(row=r, column=dup_col).value == "Yes":
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
            print(r, row_vals)
            count += 1
            if count >= 10:
                break
else:
    print("Column 'Duplicate?' not found.")
