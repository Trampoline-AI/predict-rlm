Code:
```repl
import os
import openpyxl
from openpyxl.styles import Font, Border, Side, Alignment

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_58484_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_58484_init.xlsx")
os.makedirs(output_dir, exist_ok=True)

# Load workbook fresh
wb = openpyxl.load_workbook(input_path)
ws = wb["Sheet1"]

max_row = ws.max_row
max_col = ws.max_column

# ------------------------------------------------------------------
# 1. Apply bold + thin border + wrap‑text to heading cells in row 4
thin = Side(style="thin")
border = Border(left=thin, right=thin, top=thin, bottom=thin)
for c in range(1, max_col + 1):
    cell = ws.cell(row=4, column=c)
    # Ensure wrap‑text for all cells in row 4
    cell.alignment = Alignment(wrap_text=True)
    if cell.value is not None:
        cell.font = Font(bold=True)
        cell.border = border

# ------------------------------------------------------------------
# 2. Clear any values and borders from column G (index 7)
col_g = 7
for r in range(1, max_row + 1):
    cell = ws.cell(row=r, column=col_g)
    cell.value = None
    cell.border = Border()   # no borders

# ------------------------------------------------------------------
# 3. Identify rows where D == 5551234 (as string or number) and E non‑blank
transfer_number = 5551234
matching_rows = []
for r in range(2, max_row + 1):   # data starts at row 2
    d_cell = ws.cell(row=r, column=4)
    e_cell = ws.cell(row=r, column=5)

    # Compare both numeric and string representations
    d_val = d_cell.value
    if d_val is None:
        continue
    # Normalise to string for safe comparison
    d_str = str(d_val).strip()
    if d_str != str(transfer_number):
        continue

    e_val = e_cell.value
    if e_val is None or str(e_val).strip() == "":
        continue

    matching_rows.append(r)

if not matching_rows:
    raise ValueError("No rows found where D == 5551234 and E is non‑blank.")

last_match_row = max(matching_rows)
total_transfers = len(matching_rows)

# ------------------------------------------------------------------
# 4. Write the total count as a literal number into column H (index 8) of the last matching row
col_h = 8
ws.cell(row=last_match_row, column=col_h).value = total_transfers

# ------------------------------------------------------------------
# Save, recalculate, and verify
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only to read the computed value
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
result_val = ws_check.cell(row=last_match_row, column=col_h).value
print(f"Verification: H{last_match_row} = {result_val} (expected {total_transfers})")
```
