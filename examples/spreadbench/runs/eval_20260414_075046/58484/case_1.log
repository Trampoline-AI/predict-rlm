```repl
import os
import openpyxl
from openpyxl.styles import Font, Border, Side, Alignment
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_58484_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_58484_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb["Sheet1"]

max_row = ws.max_row
max_col = ws.max_column

# 1. Apply bold + thin border to heading cells in row 4 (cells that have a value)
thin = Side(style="thin")
border = Border(left=thin, right=thin, top=thin, bottom=thin)
for c in range(1, max_col + 1):
    cell = ws.cell(row=4, column=c)
    if cell.value is not None:
        # bold
        cell.font = Font(bold=True)
        # border
        cell.border = border
        # wrap text
        cell.alignment = Alignment(wrap_text=True)
    else:
        # still ensure wrap text is on for empty cells in row 4 (as per instruction)
        cell.alignment = Alignment(wrap_text=True)

# 2. Clear any values and borders from column G (column index 7)
col_g = 7
for r in range(1, max_row + 1):
    cell = ws.cell(row=r, column=col_g)
    # clear value
    if cell.value is not None:
        cell.value = None
    # remove border (set to no border)
    cell.border = Border()

# 3. Identify rows where D == 5551234 and E is non‑blank
transfer_number = 5551234
matching_rows = []
for r in range(2, max_row + 1):  # assuming data starts at row 2
    d_val = ws.cell(row=r, column=4).value
    e_val = ws.cell(row=r, column=5).value
    if d_val == transfer_number and e_val not in (None, ""):
        matching_rows.append(r)

if not matching_rows:
    raise ValueError("No matching rows found for transfer number 5551234 with non‑blank column E")

last_match_row = max(matching_rows)

# 4. Write COUNTIFS formula into column H of the last matching row
col_h = 8
formula = f"=COUNTIFS(D2:D{max_row}, {transfer_number}, E2:E{max_row}, \"<>\")"
ws.cell(row=last_match_row, column=col_h).value = formula

# Save workbook to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only to verify the formula result
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
result_val = ws_check.cell(row=last_match_row, column=col_h).value
print(f"Verification: H{last_match_row} (formula result) = {result_val}")
```
