last_row = ws.max_row

# Write nested IF formula into column G (Points) for each data row starting at row 4
for row in range(4, last_row + 1):
    total_cell = ws.cell(row=row, column=6)   # Column F = 6
    points_cell = ws.cell(row=row, column=7)  # Column G = 7

    # Only write formula if there is a Total value (skip completely empty rows)
    if total_cell.value is not None:
        # Build formula string (Excel syntax, LibreOffice compatible)
