        "stock": run["stock"],
        "date": dates[0] if dates else None,               # first date
        "open": opens[0] if opens else None,               # opening price from first row
        "high": max(numeric_highs) if numeric_highs else None,
        "low":  min(numeric_lows)  if numeric_lows  else None,
        "close": closes[-1] if closes else None,           # closing price from last row
        "volume": sum(numeric_vols)
    }
    summaries.append(summary)

# ----------------------------------------------------------------------
# 3. Write summaries to the output sheet (clear old data first)
# ----------------------------------------------------------------------
# Delete all rows after the header (row 1) if any
if output_ws.max_row > 1:
    output_ws.delete_rows(2, output_ws.max_row - 1)

out_row = 2
for s in summaries:
    output_ws.cell(row=out_row, column=1, value=s["date"])
    output_ws.cell(row=out_row, column=2, value=s["stock"])
    output_ws.cell(row=out_row, column=3, value=s["open"])
    output_ws.cell(row=out_row, column=4, value=s["high"])
    output_ws.cell(row=out_row, column=5, value=s["low"])
    output_ws.cell(row=out_row, column=6, value=s["close"])
    output_ws.cell(row=out_row, column=7, value=s["volume"])
    out_row += 1

# ----------------------------------------------------------------------
# 4. Save, recalculate, and verify
# ----------------------------------------------------------------------
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Reload with cached values to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
check_ws = wb_check["output"]
print("--- Verified output rows (data only) ---")
for r in range(2, check_ws.max_row + 1):
    vals = [check_ws.cell(row=r, column=c).value for c in range(1, 8)]
    print(f"Row {r}:", vals)
