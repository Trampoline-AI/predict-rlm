import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_61-4_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_61-4_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
input_ws = wb["input"]
output_ws = wb["output"]

# Column indices (1‑based)
# Left side (source of Change)
COL_DATE_L = 1
COL_STOCK_L = 2
COL_OPEN_L = 3
COL_HIGH_L = 4
COL_LOW_L = 5
COL_CLOSE_L = 6
COL_VOLUME_L = 7
COL_CHANGE = 8

# Right side (data to summarise)
COL_DATE_R = 11
COL_STOCK_R = 12
COL_OPEN_R = 13
COL_HIGH_R = 14
COL_LOW_R = 15
COL_CLOSE_R = 16
COL_VOLUME_R = 17

# Helper to get cell value safely

def cell_val(ws, row, col):
    return ws.cell(row=row, column=col).value

# Build runs per stock
runs = []  # each entry: dict with stock, rows (list of row numbers), summary placeholders

current_stock = None
current_run_rows = []
for r in range(2, input_ws.max_row + 1):
    stock = cell_val(input_ws, r, COL_STOCK_L)
    change = cell_val(input_ws, r, COL_CHANGE)
    # If stock changes, flush any ongoing run
    if stock != current_stock:
        if current_run_rows:
            runs.append({"stock": current_stock, "rows": current_run_rows})
            current_run_rows = []
        current_stock = stock
    # Determine if this row is part of a negative run
    if isinstance(change, (int, float)) and change < 0:
        current_run_rows.append(r)
    else:
        # End of a negative run
        if current_run_rows:
            runs.append({"stock": current_stock, "rows": current_run_rows})
            current_run_rows = []
# Flush final run if any
if current_run_rows:
    runs.append({"stock": current_stock, "rows": current_run_rows})

# Compute summary for each run using right‑side columns
summaries = []
for run in runs:
    rows = run["rows"]
    if not rows:
        continue
    # Extract values from right side
    dates = [cell_val(input_ws, r, COL_DATE_R) for r in rows]
    opens = [cell_val(input_ws, r, COL_OPEN_R) for r in rows]
    closes = [cell_val(input_ws, r, COL_CLOSE_R) for r in rows]
    highs = [cell_val(input_ws, r, COL_HIGH_R) for r in rows]
    lows = [cell_val(input_ws, r, COL_LOW_R) for r in rows]
    volumes = [cell_val(input_ws, r, COL_VOLUME_R) for r in rows]
    # Summarise
    summary = {
        "stock": run["stock"],
        "date": dates[0],  # first date of the run (as it appears in sheet)
        "open": opens[0],
        "high": max(highs) if highs else None,
        "low": min(lows) if lows else None,
        "close": closes[-1],
        "volume": sum(v for v in volumes if isinstance(v, (int, float)))
    }
    summaries.append(summary)

# Write to output sheet – clear existing data rows (keep header row 1)
# Delete rows beyond header
if output_ws.max_row > 1:
    output_ws.delete_rows(2, output_ws.max_row - 1)

# Write summaries starting at row 2
out_row = 2
for s in summaries:
    output_ws.cell(row=out_row, column=1, value=s["date"])
    output_ws.cell(row=out_row, column=2, value=s["stock"])
    output_ws.cell(row=out_row, column=3, value=s["open"])
    output_ws.cell(row=out_row, column=4, value=s["high"])
    output_ws.cell(row=out_row, column=5, value=s["low"])
    output_ws.cell(row=out_row, column=6, value=s["close"])
    output_ws.cell(row=out_row, column=7, value=s["volume"])
    out_row += 1

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)
# Reload with data_only to see cached values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
check_ws = wb_check["output"]
print("--- Verified output rows ---")
for r in range(2, check_ws.max_row + 1):
    vals = [check_ws.cell(row=r, column=c).value for c in range(1, 8)]
    print(f"Row {r}:", vals)
