# Identify sheets (names as observed)
ws1 = wb["Sheet1"]
ws2 = wb["Sheet2"]

# Build lookup from Sheet2: first occurrence only
lookup = {}
for r in range(2, ws2.max_row + 1):
    track = ws2.cell(row=r, column=4).value  # column D (Track)
    race = ws2.cell(row=r, column=8).value   # column H (Race#)
    if track is None or race is None:
        continue
    key = (str(track).strip(), race)
    if key in lookup:
        # Already have first occurrence; skip later duplicates
        continue
    lookup[key] = {
        "top": ws2.cell(row=r, column=9).value,   # column I (Top)
        "num1": ws2.cell(row=r, column=10).value, # column J (1)
        "num2": ws2.cell(row=r, column=11).value, # column K (2)
        "num3": ws2.cell(row=r, column=12).value, # column L (3)
        "num4": ws2.cell(row=r, column=13).value, # column M (4)
    }

# Process Sheet1 rows
for r in range(2, ws1.max_row + 1):
    meet = ws1.cell(row=r, column=4).value  # column D (Meet)
    race = ws1.cell(row=r, column=7).value  # column G (Race#)
    if meet is None or race is None:
        continue
    key = (str(meet).strip(), race)
    src = lookup.get(key)
    if not src:
        # No matching data; leave cells unchanged
        continue

    # Write Top into column H (8)
    ws1.cell(row=r, column=8).value = src["top"]

    # Concatenate numeric columns J-M into a string for column I (9)
    parts = [
        str(src["num1"] or ""),
        str(src["num2"] or ""),
        str(src["num3"] or ""),
        str(src["num4"] or "")
    ]
    ws1.cell(row=r, column=9).value = "/".join(parts)

# Save modified workbook
wb.save(output_path)
wb.close()

# Recalculate formulas (LibreOffice fallback)
