import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_97-36_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_97-36_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb.active  # assuming single sheet

# Find first row containing 'domestic' (case‑insensitive)
search_str = "domestic"
first_match_row = None
for row in ws.iter_rows(min_row=1, max_row=ws.max_row, max_col=ws.max_column):
    for cell in row:
        val = cell.value
        if isinstance(val, str) and search_str.lower() in val.lower():
            first_match_row = cell.row
            break
    if first_match_row is not None:
        break

print("First matching row:", first_match_row)

# Delete rows above the match (if any)
if first_match_row is not None and first_match_row > 1:
    rows_to_delete = first_match_row - 1
    ws.delete_rows(1, rows_to_delete)
    print(f"Deleted rows 1 through {first_match_row - 1}")
else:
    print("No rows to delete (match at first row or not found).")

# Save modified workbook
wb.save(output_path)
print("Saved modified workbook to:", output_path)

# Recalculate formulas (if any)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Verify by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
new_first_val = ws_check.cell(row=1, column=1).value
print("New first row value:", new_first_val)
