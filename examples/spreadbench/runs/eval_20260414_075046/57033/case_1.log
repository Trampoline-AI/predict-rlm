```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb = openpyxl.load_workbook(input_spreadsheet)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print a range of rows compactly
def print_rows(ws, start, end):
    for r in range(start, end + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}: {row_vals}")

# 2. Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Sheet: {name} ---")
    print(f"Max row: {ws.max_row}, Max column: {ws.max_column}")

    # Header row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print("Headers:", headers)

    # First few data rows (2-6)
    print("First data rows (2-6):")
    print_rows(ws, 2, min(6, ws.max_row))

    # Last 5 rows (if more than 6 rows total)
    if ws.max_row > 6:
        print("Last 5 rows:")
        start = max(2, ws.max_row - 4)
        print_rows(ws, start, ws.max_row)

# 3. Focus on Sheet4, cells K2:K7
if "Sheet4" in wb.sheetnames:
    ws4 = wb["Sheet4"]
    print("\n--- Values in Sheet4 K2:K7 ---")
    for r in range(2, 8):
        cell = ws4.cell(row=r, column=11)  # column K = 11
        val = cell.value
        formula = cell.value if isinstance(cell.value, str) and cell.value.startswith("=") else None
        fill = cell.fill.fgColor.rgb if cell.fill and cell.fill.fgColor else None
        print(f"K{r}: value={val!r}, formula={formula!r}, fill={fill}")
else:
    print("Sheet4 not found.")
```
