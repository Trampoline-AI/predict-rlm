Code:
```repl
import os
import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_57033_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb["Sheet4"]

# Define fill colour (solid) – LibreOffice expects 6‑digit RGB; openpyxl uses 8‑digit ARGB, so prepend "FF"
fill = PatternFill(start_color="FF66CC", end_color="FF66CC", fill_type="solid")

# Write formula to K2:K7 (column 11)
for r in range(2, 8):  # rows 2 through 7 inclusive
    formula = (
        f'=IFERROR('
        f'INDEX(CBtrans!I:I, '
        f'SUMPRODUCT((CBtrans!A:A=B{r})*'
        f'(CBtrans!C:C=C{r})*'
        f'(CBtrans!E:E=J{r})*'
        f'ROW(CBtrans!A:A))), '
        f'"NO MATCH")'
    )
    cell = ws.cell(row=r, column=11)  # column K = 11
    cell.value = formula
    cell.fill = fill

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only to verify results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2["Sheet4"]
print("Verification of K2:K7 after recalculation:")
for r in range(2, 8):
    val = ws2.cell(row=r, column=11).value
    print(f"K{r}: {val!r}")
```
