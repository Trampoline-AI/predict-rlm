import openpyxl
from openpyxl.utils import get_column_letter
from decimal import Decimal, getcontext

# -------------------------------------------------
# 1. Load workbook
# -------------------------------------------------
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=False)

# -------------------------------------------------
# 2. Find target sheet (case‑insensitive)
# -------------------------------------------------
target_name = "Final Recon Items"
sheet_name = None
for name in wb.sheetnames:
    if name.lower() == target_name.lower():
        sheet_name = name
        break
if sheet_name is None:
    raise RuntimeError(f"Sheet '{target_name}' not found. Available: {wb.sheetnames}")

ws = wb[sheet_name]

# -------------------------------------------------
# 3. Gather column D values (row 2 .. max_row)
# -------------------------------------------------
max_row = ws.max_row
amounts = []
for r in range(2, max_row + 1):
    val = ws.cell(row=r, column=4).value
    # Treat None as 0 (should not happen for data rows)
    if val is None:
        continue
    amounts.append(Decimal(str(val)))   # use Decimal for precise sum

# -------------------------------------------------
# 4. Compute sum and decide whether to delete rows
# -------------------------------------------------
tolerance = Decimal("1e-6")
total = sum(amounts)
print(f"Total sum of column D (Decimal) = {total}")

if abs(total) <= tolerance:
    # Delete all data rows (rows 2..max_row)
    rows_to_delete = max_row - 1  # exclude header
    if rows_to_delete > 0:
        ws.delete_rows(2, rows_to_delete)
        print(f"Deleted {rows_to_delete} data rows because sum is within tolerance {tolerance}.")
    else:
        print("No data rows to delete.")
else:
    print(f"Sum {total} exceeds tolerance {tolerance}; no rows deleted.")

# -------------------------------------------------
# 5. Save to output directory
# -------------------------------------------------
output_dir = "/sandbox/output/output_spreadsheet"
import os
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(wb_path))
wb.save(output_path)

# -------------------------------------------------
# 6. Recalculate formulas and verify
