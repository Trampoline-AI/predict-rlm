import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string

# Load the workbook (read only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_58687_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# We'll inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Sheet: {name} ---")
    # Determine max row/col (considering non‑empty cells)
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Dimensions: rows={max_row}, cols={max_col}")

    # Find first non‑empty row (header)
    header_row = None
    for r in range(1, max_row + 1):
        if any(ws.cell(row=r, column=c).value is not None for c in range(1, max_col + 1)):
            header_row = r
            break
    if header_row is None:
        print("Empty sheet")
        continue

    # Print header row values
    headers = [ws.cell(row=header_row, column=c).value for c in range(1, max_col + 1)]
    print(f"Header row {header_row}: {headers}")

    # Print first 5 data rows after header
    print("First 5 data rows:")
    for r in range(header_row + 1, min(header_row + 6, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}: {row_vals}")

    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(header_row + 1, max_row - 4)
    for r in range(start, max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}: {row_vals}")

    # Print column B values for rows 9‑13 (example indices)
    print("Column B values rows 9‑13:")
    for r in range(9, 14):
        val = ws.cell(row=r, column=2).value
        print(f"B{r} = {val}")

    # Also print any other non‑empty cells in column B
    col_b_vals = []
    for r in range(1, max_row + 1):
        v = ws.cell(row=r, column=2).value
        if v is not None:
            col_b_vals.append((r, v))
    print(f"All non‑empty cells in column B ({len(col_b_vals)} total):", col_b_vals[:10], "...")  # show first few
