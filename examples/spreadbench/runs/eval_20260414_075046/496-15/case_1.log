```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb = openpyxl.load_workbook(input_spreadsheet)
print(f"Workbook loaded from {input_spreadsheet}")

# List sheet names
print("Sheets:", wb.sheetnames)

# Explore each sheet
for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (assume first row contains headers)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Function to get row values as list
    def row_vals(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]

    # First 5 data rows (rows 2-6 if they exist)
    first_rows = [row_vals(r) for r in range(2, min(2 + 5, max_row + 1))]
    print("First 5 data rows:")
    for r, vals in enumerate(first_rows, start=2):
        print(f"Row {r}:", vals)

    # Last 5 data rows (excluding header)
    start_last = max(2, max_row - 4)
    last_rows = [row_vals(r) for r in range(start_last, max_row + 1)]
    print("Last 5 data rows:")
    for r, vals in enumerate(last_rows, start=start_last):
        print(f"Row {r}:", vals)

# Save workbook back (no changes yet) to ensure we have a writable copy later
# (We'll reuse the same workbook object for later modifications.)
