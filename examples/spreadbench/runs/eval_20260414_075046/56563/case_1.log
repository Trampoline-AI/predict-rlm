import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_56563_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_56563_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify the sheet and cell to modify
sheet_name = "AB"
ws = wb[sheet_name]

# Verify current formula in C14
print("Before:", ws["C14"].value)

# Write the new formula that ignores #NUM errors
ws["C14"].value = "=SUMPRODUCT(--ISNUMBER(C2:C13), C2:C13)"

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice & formulas)
await recalculate(str(output_path))

# Reload with data_only=True to read computed values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[sheet_name]
print("After recalculation, C14 value:", ws2["C14"].value)
