    print("Headers:", headers)
    # Print first few data rows (2-6)
    for r in range(2, min(7, ws.max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    # Search for the exact formula string
    for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
        for cell in row:
            if isinstance(cell.value, str) and cell.value.strip().upper() == "=SUM(C2:C13)":
                print(f"Found target formula in cell {cell.coordinate} with value {cell.value}")
