import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string

# Load the workbook
wb_path = '/sandbox/input/input_spreadsheet/1_1925_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)  # load with formulas

# List sheet names
print('Sheet names:', wb.sheetnames)

# Function to summarize a sheet
def summarize_sheet(ws, num_rows=5):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Sheet '{ws.title}': max_row={max_row}, max_col={max_col}")
    # Print header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print('Headers (row 1):', headers)
    # Print first few rows (excluding header)
    print('First rows:')
    for r in range(2, min(2+num_rows, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last few rows
    print('Last rows:')
    start = max(2, max_row - num_rows + 1)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Summarize each sheet
for ws in wb.worksheets:
    summarize_sheet(ws)
    print('-'*40)

# Specific cells of interest
ws1 = wb['Sheet1']
ws2 = wb['Sheet2']
print('Sheet1!C5 (date):', ws1['C5'].value)
print('Sheet1!B6 (item):', ws1['B6'].value)

# Print row 5 of Sheet2 (dates across columns)
row5_vals = [ws2.cell(row=5, column=c).value for c in range(1, ws2.max_column+1)]
print('Sheet2 row 5 (dates):', row5_vals)

# Find which column in Sheet2 matches the date in Sheet1!C5
target_date = ws1['C5'].value
matched_col = None
for idx, val in enumerate(row5_vals, start=1):
    if val == target_date:
        matched_col = idx
        break
print('Matched column index in Sheet2 for date', target_date, ':', matched_col, '(letter:', get_column_letter(matched_col) if matched_col else None, ')')

# Show a sample of the matched column values (excluding header rows)
if matched_col:
    col_letter = get_column_letter(matched_col)
    col_vals = [ws2.cell(row=r, column=matched_col).value for r in range(6, min(6+10, ws2.max_row+1))]
    print(f'Sample values in Sheet2 column {col_letter} (rows 6-...):', col_vals)
