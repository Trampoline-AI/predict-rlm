import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet contains the data

# Determine data bounds
min_row = 2  # assuming row 1 is header
max_row = ws.max_row
id_col = 1   # A
amt_col = 2  # B
out_col = 4  # D (target column)

# Step 1: compute max per ID
id_to_max = {}
for r in range(min_row, max_row + 1):
    id_val = ws.cell(row=r, column=id_col).value
    amt_val = ws.cell(row=r, column=amt_col).value
    if id_val is None or amt_val is None:
        continue
    # Ensure numeric amount
    try:
        amt_num = float(amt_val)
    except (TypeError, ValueError):
        continue
    if id_val not in id_to_max or amt_num > id_to_max[id_val]:
        id_to_max[id_val] = amt_num

# Step 2: write results into column D
for r in range(min_row, max_row + 1):
    id_val = ws.cell(row=r, column=id_col).value
    amt_val = ws.cell(row=r, column=amt_col).value
    target_cell = ws.cell(row=r, column=out_col)
    # Default to blank
    target_cell.value = ""
    if id_val is None or amt_val is None:
        continue
    try:
        amt_num = float(amt_val)
    except (TypeError, ValueError):
        continue
    # If this amount equals the max for its ID, write it
    if id_val in id_to_max and amt_num == id_to_max[id_val]:
        # Preserve original formatting (if any) by writing the raw value
        target_cell.value = amt_num

# Save to output location
wb.save(output_path)

# Recalculate formulas (none added, but follow required workflow)
await recalculate(output_path)

# Verify by reloading with data_only=True and printing column D values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification of column D (row, value):")
for r in range(min_row, max_row + 1):
    val = ws_check.cell(row=r, column=out_col).value
    if val not in (None, ""):
        print(f"Row {r}: {val}")

# End of processing
```
