```repl
import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_384-4_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_384-4_init.xlsx")

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)

# Get sheets
ws_source = wb["Source"]
ws_source2 = wb["Source2"]
ws_result = wb["Result"]

# Collect values from Source (column B)
source_vals = []
for row in ws_source.iter_rows(min_row=2, max_col=2, values_only=True):
    # row = (Item, Value)
    val = row[1]
    if val is not None:
        source_vals.append(val)

# Collect values from Source2 (column A)
source2_vals = set()
for row in ws_source2.iter_rows(min_row=2, max_col=1, values_only=True):
    val = row[0]
    if val is not None:
        source2_vals.add(val)

# Determine values to write to Result
result_vals = []
seen = set()
for val in source_vals:
    if val in seen:
        continue  # ensure uniqueness
    # Rule: include if val not in Source2, unless val == 2
    if val not in source2_vals:
        if val == 2:
            # exclude because not in both sources
            continue
        result_vals.append(val)
        seen.add(val)
    else:
        # val is in both sources
        if val == 2:
            result_vals.append(val)
            seen.add(val)
        # other values present in both are ignored per instruction

# Write results to Result sheet (starting at row 2, column A)
for idx, val in enumerate(result_vals, start=2):
    ws_result.cell(row=idx, column=1, value=val)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

