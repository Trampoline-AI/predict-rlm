1. Load the workbook from the path given in `input_spreadsheet`.
2. List all sheet names.
3. For each sheet, report the number of rows and columns.
4. Print the header row (row 1) to see column titles.
5. Print the first 5 data rows and the last 5 data rows (excluding the header) to see the actual data.
6. Specifically print the values in column B for the first few rows to verify the character we’ll be checking.

This exploration will let us confirm the correct target column and the data layout before we implement the row‑deletion logic in a later iteration.
Code:
```repl
import openpyxl
import os
from pathlib import Path

# Load the workbook (read‑only not fine for inspection)
wb_path = Path(input_spreadsheet)
wb = openpyxl.load_workbook(wb_path, data_only=False)

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows (including header): {max_row}, Columns: {max_col}")

    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # First 5 data rows (rows 2‑6)
    print("First 5 data rows:")
    for r in range(2, min(2 + 5, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}:", row_vals)

    # Last 5 data rows (excluding header)
    print("Last 5 data rows:")
    start = max(2, max_row - 4)
    for r in range(start, max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}:", row_vals)

    # Show first few values in column B (column index 2)
    print("Column B values (first 10 rows, including header):")
    for r in range(1, min(11, max_row + 1)):
        val = ws.cell(row=r, column=2).value
        print(f"B{r}:", val)

# Close workbook (not strictly necessary in openpyxl)
wb.close()
```
