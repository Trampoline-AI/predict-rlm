Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_297-42_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_297-42_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas if any)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Target sheet
combined_ws = wb['combined']
# Find first empty row (should be 2 since only header exists)
first_row = combined_ws.max_row + 1  # max_row is 1 now, so first_row = 2
print('First empty row in combined sheet:', first_row)

# List of source sheets (all except 'combined')
source_sheets = [name for name in wb.sheetnames if name != 'combined']
print('Source sheets to copy from:', source_sheets)

# Counter for total rows copied
total_copied = 0

# Iterate over each source sheet and copy rows
for sheet_name in source_sheets:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    # Copy rows 2..max_row
    for r in range(2, max_row + 1):
        # Write each column value to combined sheet
        for c in range(1, max_col + 1):
            src_cell = ws.cell(row=r, column=c)
            combined_ws.cell(row=first_row, column=c).value = src_cell.value
        first_row += 1
        total_copied += 1

print('Total rows copied:', total_copied)

# Save to output location
wb.save(output_path)
print('Workbook saved to', output_path)

# Recalculate formulas (required by workflow)
await recalculate(output_path)

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
combined_check = wb_check['combined']
print('After reload - combined sheet max_row:', combined_check.max_row)
# Print first 5 data rows from combined (rows 2-6)
print('First 5 data rows in combined:')
for r in range(2, min(7, combined_check.max_row + 1)):
    row_vals = [combined_check.cell(row=r, column=c).value for c in range(1, combined_check.max_column + 1)]
    print(r, row_vals)
# Print last 5 data rows
if combined_check.max_row > 6:
    print('Last 5 data rows in combined:')
    for r in range(combined_check.max_row - 4, combined_check.max_row + 1):
        row_vals = [combined_check.cell(row=r, column=c).value for c in range(1, combined_check.max_column + 1)]
        print(r, row_vals)
```
