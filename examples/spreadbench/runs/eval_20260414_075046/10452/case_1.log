Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_10452_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_10452_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assuming single sheet

max_row = ws.max_row
max_col = ws.max_column

# Determine target column for filtered results (choose next empty column after existing ones)
# We'll use column F (index 6) which appears empty in the sample data.
target_col_idx = 6  # column F
target_col_letter = get_column_letter(target_col_idx)

# Write header
ws[f"{target_col_letter}1"] = "PK Filtered"

# Write formula for each data row
for r in range(2, max_row + 1):
    source_cell = ws.cell(row=r, column=2)  # column B as source
    # Build formula: =IF(LEFT(B2,2)="PK",B2,"")
    formula = f"=IF(LEFT({source_cell.coordinate},2)=\"PK\",{source_cell.coordinate},\"\")"
    ws[f"{target_col_letter}{r}"] = formula

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only=True to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Collect verification info
verified = True
for r in range(2, max_row + 1):
    src_val = ws_check.cell(row=r, column=2).value
    out_val = ws_check.cell(row=r, column=target_col_idx).value
    # Expected: out_val should be src_val if src_val starts with 'PK', else None/blank
    if isinstance(src_val, str) and src_val.startswith('PK'):
        if out_val != src_val:
            print(f"Row {r}: expected '{src_val}' but got '{out_val}'")
            verified = False
    else:
        if out_val not in (None, ""):
            print(f"Row {r}: expected blank but got '{out_val}'")
            verified = False

print("Verification passed:" , verified)
```

