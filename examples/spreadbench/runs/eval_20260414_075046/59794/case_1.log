import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_59794_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_59794_init.xlsx")

# Load workbook (write mode)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine data bounds
min_row = 3  # data starts after two header rows
max_row = ws.max_row
target_start_col = 3  # column C
target_end_col = 11   # column K
max_target_cols = target_end_col - target_start_col + 1

def clean_token(tok):
    """Return empty string for placeholder '-' otherwise stripped token."""
    if tok is None:
        return ""
    t = str(tok).strip()
    return "" if t == "-" else t

# Process each data row
for r in range(min_row, max_row + 1):
    src_cell = ws.cell(row=r, column=1)  # column A
    raw = src_cell.value
    if raw is None:
        continue  # nothing to split
    # Split on '/', clean tokens
    tokens = [clean_token(t) for t in str(raw).split("/")]
    # Write tokens into columns C-K
    for i in range(max_target_cols):
        col_idx = target_start_col + i
        if i < len(tokens):
            val = tokens[i] or None  # write None for empty strings
        else:
            val = None
        ws.cell(row=r, column=col_idx).value = val

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)

# Reload with data_only to check results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]

# Print a verification snippet for rows 3‑5, columns C‑K
print("Verification of split results (rows 3‑5, cols C‑K):")
for r in range(3, 6):
    vals = [ws_check.cell(row=r, column=c).value for c in range(target_start_col, target_end_col+1)]
    print(f"Row {r}:", vals)
