```
=D{row}*IF(B{row}<37.5,2,1.5)
```

We will replace the existing value in every cell of column E (rows 2 through max_row) of the **master** sheet with this formula, leaving the other sheets unchanged. After writing the formulas, we will save the workbook to the output directory, run `recalculate()` to evaluate formulas, and then reload the file (data_only) to verify that the formulas were written correctly.
Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_47933_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_47933_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Update only the 'master' sheet, column E (index 5)
if "master" in wb.sheetnames:
    ws = wb["master"]
    max_row = ws.max_row
    # Write corrected formula for each data row
    for r in range(2, max_row + 1):
        formula = f"=D{r}*IF(B{r}<37.5,2,1.5)"
        ws.cell(row=r, column=5).value = formula
else:
    raise ValueError("Sheet named 'master' not found in workbook.")

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
await recalculate(output_path)

# Reload with data_only=True to verify formulas are present (values will be cached after recalculation)
wb_check = openpyxl.load_workbook(output_path, data_only=False)
ws_check = wb_check["master"]
print("Sample corrected formulas in column E:")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f"E{r}:", ws_check.cell(row=r, column=5).value)

# Also show the cached computed values after recalculation
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data["master"]
print("\nCached computed values in column E (after recalculation):")
for r in range(2, min(7, ws_data.max_row + 1)):
    print(f"E{r} value:", ws_data.cell(row=r, column=5).value)
