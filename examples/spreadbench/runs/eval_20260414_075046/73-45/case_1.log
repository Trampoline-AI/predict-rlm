```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook (read-only is fine for inspection)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)

# 1. List all sheet names and row counts
print("Sheet names and row counts:")
for ws in wb.worksheets:
    # Determine max row (including possible empty rows at bottom)
    max_row = ws.max_row
    max_col = ws.max_column
    print(f" - {ws.title}: rows={max_row}, cols={max_col}")

# 2. Print column headers (first row) for the first sheet
ws = wb.worksheets[0]
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
print("\nColumn headers (first row) of sheet", ws.title)
print(headers)

# Helper to get column index for 'BD'
bd_col_idx = column_index_from_string('BD')
bd_col_letter = get_column_letter(bd_col_idx)
print(f"\nColumn BD is index {bd_col_idx} ({bd_col_letter})")

# 3. Print first 5 rows of column BD (excluding header)
print("\nFirst 5 data rows in column BD:")
for r in range(2, min(ws.max_row, 6) + 1):
    val = ws.cell(row=r, column=bd_col_idx).value
    print(f"Row {r}: {val}")

# 4. Print last 5 rows of column BD (excluding header)
print("\nLast 5 data rows in column BD:")
start_row = max(2, ws.max_row - 4)
for r in range(start_row, ws.max_row + 1):
    val = ws.cell(row=r, column=bd_col_idx).value
    print(f"Row {r}: {val}")

# 5. Check if there is an existing column for patterns (maybe a named range or header)
# Look for any header containing the word 'pattern' (case-insensitive)
pattern_cols = []
for idx, hdr in enumerate(headers, start=1):
    if isinstance(hdr, str) and 'pattern' in hdr.lower():
        pattern_cols.append((idx, hdr))
print("\nColumns with 'pattern' in header:", pattern_cols)
```
