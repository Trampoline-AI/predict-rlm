Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_23-24_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_23-24_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# 1. Build set of words from column I (column 9)
col_i_words = set()
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=9).value
    if isinstance(val, str):
        col_i_words.add(val.strip())

print(f"Collected {len(col_i_words)} unique words from column I.")

# 2. Identify rows to delete (where column A matches any word in column I)
rows_to_delete = []
for r in range(2, ws.max_row + 1):
    a_val = ws.cell(row=r, column=1).value
    if isinstance(a_val, str) and a_val.strip() in col_i_words:
        rows_to_delete.append(r)

print(f"Rows marked for deletion: {len(rows_to_delete)}")

# 3. Delete rows in reverse order to keep indices stable
for r in reversed(rows_to_delete):
    ws.delete_rows(r, 1)

# 4. Save workbook to output location
wb.save(output_path)
print(f"Saved modified workbook to {output_path}")

# 5. Recalculate formulas (LibreOffice)
# This is an async call; we use `await` directly as the REPL runs in an async loop.
await recalculate(output_path)

# 6. Reload with data_only=True to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print(f"After deletion: max_row = {ws2.max_row}, max_column = {ws2.max_column}")

# Show a few rows after deletion (first 5 data rows)
print("First 5 data rows after deletion:")
for r in range(2, min(7, ws2.max_row + 1)):
    row_vals = [ws2.cell(row=r, column=c).value for c in range(1, ws2.max_column + 1)]
    print(r, row_vals)

# Show a few rows near the bottom
print("Last 5 data rows after deletion:")
for r in range(max(ws2.max_row - 4, 2), ws2.max_row + 1):
    row_vals = [ws2.cell(row=r, column=c).value for c in range(1, ws2.max_column + 1)]
    print(r, row_vals)
