import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read-only not needed for inspection)
wb = openpyxl.load_workbook(input_spreadsheet)
print("Sheet names:", wb.sheetnames)

for name in wb.sheetnames:
    ws = wb[name]
    # Determine max rows/cols
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {name} - max_row: {max_row}, max_col: {max_col}")
    # Print header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Helper to get row values as list
    def row_vals(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    # Print first 5 data rows (excluding header)
    print("First 5 rows:")
    for r in range(2, min(2+5, max_row+1)):
        print(r, row_vals(r))
    # Print last 5 rows
    print("Last 5 rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        print(r, row_vals(r))
