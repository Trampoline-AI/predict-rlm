import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path)
print(f"Workbook loaded from: {wb_path}")

# List sheet names
print("Sheet names:", wb.sheetnames)

# Assume we work on the first sheet (adjust if needed)
ws = wb[wb.sheetnames[0]]
print(f"Working on sheet: {ws.title}")

# Row and column counts
max_row = ws.max_row
max_col = ws.max_column
print(f"Rows (including header): {max_row}")
print(f"Columns: {max_col}")

# Print header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print("Header row:", headers)

# Helper to print a row as list of values
def row_values(r):
    return [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]

# Print first 5 data rows (rows 2-6)
print("\nFirst 5 data rows:")
for r in range(2, min(2+5, max_row+1)):
    print(f"Row {r}:", row_values(r))

# Print last 5 data rows
print("\nLast 5 data rows:")
start_last = max(2, max_row-4)
for r in range(start_last, max_row+1):
    print(f"Row {r}:", row_values(r))

# Print column A values for those sample rows to see groups
print("\nColumn A values for first 5 rows:")
for r in range(2, min(2+5, max_row+1)):
    print(f"Row {r} A:", ws.cell(row=r, column=1).value)

print("\nColumn A values for last 5 rows:")
for r in range(start_last, max_row+1):
    print(f"Row {r} A:", ws.cell(row=r, column=1).value)
```
