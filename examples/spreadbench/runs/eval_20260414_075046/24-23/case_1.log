Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (full mode, we will modify)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Target group labels to delete
targets = {"@9T", "SAL", "T9A"}

# Delete rows from bottom to top (skip header row 1)
max_row = ws.max_row
deleted = 0
for row in range(max_row, 1, -1):  # start at max_row down to 2
    cell_val = ws.cell(row=row, column=1).value
    if cell_val in targets:
        ws.delete_rows(row)
        deleted += 1

print(f"Deleted {deleted} rows containing {targets}")

# Save to output location
wb.save(output_path)
print(f"Saved modified workbook to {output_path}")

# Recalculate formulas (if any)
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Verify: reload with data_only to see final state
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]

# Print new row count and a few sample rows to confirm deletion
new_max_row = ws_check.max_row
print(f"New total rows (including header): {new_max_row}")

# Show first 5 data rows after deletion
print("\nFirst 5 data rows after deletion:")
for r in range(2, min(7, new_max_row+1)):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column+1)]
    print(f"Row {r}:", row_vals)

# Ensure no target groups remain in column A (sample check)
print("\nChecking column A for any remaining target values (first 20 rows):")
found = False
for r in range(2, min(22, new_max_row+1)):
    val = ws_check.cell(row=r, column=1).value
    if val in targets:
        print(f"Row {r} still has {val}")
        found = True
if not found:
    print("No target group values found in the sampled rows.")
```
