Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify the collection sheet and other data sheets
collection_sheet_name = "COLLECTION"
data_sheet_names = [sn for sn in wb.sheetnames if sn != collection_sheet_name]

# Helper to get column index by header name (case‑insensitive)
def header_to_index(ws):
    mapping = {}
    for col in range(1, ws.max_column + 1):
        val = ws.cell(row=1, column=col).value
        if isinstance(val, str):
            mapping[val.strip().upper()] = col
    return mapping

# Aggregate sums
agg = {}  # key tuple -> {"SALE": float, "RET": float}
for sn in data_sheet_names:
    ws = wb[sn]
    hdr = header_to_index(ws)
    # Determine which columns exist
    has_sale = "SALE" in hdr
    has_ret = "RET" in hdr
    # Required key columns
    key_cols = ["ITEM", "BR", "TY", "OR"]
    if not all(k in hdr for k in key_cols):
        continue  # skip sheets without proper key columns
    for row in range(2, ws.max_row + 1):
        # Build key
        key = tuple(ws.cell(row=row, column=hdr[k]).value for k in key_cols)
        if key[0] is None:
            continue  # skip empty rows
        # Initialize aggregation entry
        if key not in agg:
            agg[key] = {"SALE": 0.0, "RET": 0.0}
        # Add SALE if present
        if has_sale:
            sale_val = ws.cell(row=row, column=hdr["SALE"]).value
            if isinstance(sale_val, (int, float)):
                agg[key]["SALE"] += float(sale_val)
        # Add RET if present
        if has_ret:
            ret_val = ws.cell(row=row, column=hdr["RET"]).value
            if isinstance(ret_val, (int, float)):
                agg[key]["RET"] += float(ret_val)

# Write to COLLECTION sheet
ws_coll = wb[collection_sheet_name]

# Ensure header row has the expected columns (add missing ones)
expected_headers = ["ITEM", "BR", "TY", "OR", "SALE", "RET", "BALANCE"]
current_headers = [ws_coll.cell(row=1, column=c).value for c in range(1, ws_coll.max_column + 1)]
# Extend columns if needed
for idx, hdr in enumerate(expected_headers, start=1):
    if idx > ws_coll.max_column:
        ws_coll.cell(row=1, column=idx).value = hdr
    else:
        ws_coll.cell(row=1, column=idx).value = hdr

# Clear existing data rows (starting at row 2)
for r in range(2, ws_coll.max_row + 1):
    for c in range(1, len(expected_headers) + 1):
        ws_coll.cell(row=r, column=c).value = None

# Write aggregated rows
sorted_keys = sorted(agg.keys(), key=lambda k: (k[0] if isinstance(k[0], (int, float)) else 0, k[1:] ))
row_idx = 2
for key in sorted_keys:
    sale_total = agg[key]["SALE"]
    ret_total = agg[key]["RET"]
    # Write key columns
    for col_idx, value in enumerate(key, start=1):
        ws_coll.cell(row=row_idx, column=col_idx).value = value
    # Write totals
    ws_coll.cell(row=row_idx, column=5).value = sale_total
    ws_coll.cell(row=row_idx, column=6).value = ret_total
    # Write BALANCE formula (E - F)
    ws_coll.cell(row=row_idx, column=7).value = f"=E{row_idx}-F{row_idx}"
    row_idx += 1

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to verify a few cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[collection_sheet_name]
print("Verification (first 5 rows):")
for r in range(2, min(7, ws_check.max_row + 1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(1, 8)]
    print(r, vals)

# End of script
