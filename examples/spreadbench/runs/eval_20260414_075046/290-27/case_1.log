Code:
```repl
import re
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet is the target

col_B_idx = 2
col_B_letter = get_column_letter(col_B_idx)

# Regex to extract the numeric part (sequence of digits)
num_regex = re.compile(r"\d+")

# Track modifications for verification
modified_cells = []

for r in range(2, ws.max_row + 1):  # start after header row
    cell = ws.cell(row=r, column=col_B_idx)
    val = cell.value
    if isinstance(val, str):
        # If the string contains any alphabetic character, we process it
        if any(ch.isalpha() for ch in val):
            match = num_regex.search(val)
            if match:
                num_str = match.group()
                # Convert to int (or keep as string if you prefer)
                cell.value = int(num_str)
                modified_cells.append((r, val, cell.value))
            else:
                # No digits found – leave as is (or set to None)
                pass

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
calc_result = await recalculate(output_path)

# Reload with data_only to check results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]

# Verify a few rows: first few, last few, and the rows we modified
print("=== Verification after transformation ===")
# First 5 data rows
print("\nFirst 5 data rows (Column B):")
for r in range(2, 7):
    print(f"B{r} = {ws2.cell(row=r, column=col_B_idx).value}")

# Last 5 data rows
print("\nLast 5 data rows (Column B):")
for r in range(ws2.max_row - 4, ws2.max_row + 1):
    print(f"B{r} = {ws2.cell(row=r, column=col_B_idx).value}")

# Show modified cells
print("\nModified cells (row, original, new):")
for r, orig, new in modified_cells[:20]:
    print(f"Row {r}: '{orig}' -> {new}")

# Summary
print(f"\nTotal modified cells in column {col_B_letter}: {len(modified_cells)}")
