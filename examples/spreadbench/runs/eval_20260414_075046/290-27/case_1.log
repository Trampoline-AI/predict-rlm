import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path)

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

for ws_name in wb.sheetnames:
    ws = wb[ws_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws_name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Get header row (assume first row contains headers)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Determine column index for column B (should be 2)
    col_B_idx = 2
    col_B_letter = get_column_letter(col_B_idx)

    # Helper to get row values as list
    def row_values(row_num):
        return [ws.cell(row=row_num, column=c).value for c in range(1, max_col + 1)]

    # Print first 5 data rows (excluding header)
    sample_start = min(5, max_row - 1)
    print("\nFirst data rows:")
    for r in range(2, 2 + sample_start):
        print(f"Row {r}:", row_values(r))

    # Print last 5 data rows (if more than 6 rows total)
    if max_row > 6:
        print("\nLast data rows:")
        for r in range(max_row - 4, max_row + 1):
            print(f"Row {r}:", row_values(r))

    # Print column B values for those sample rows
    print("\nColumn B values (first rows):")
    for r in range(2, 2 + sample_start):
        print(f"B{r} =", ws.cell(row=r, column=col_B_idx).value)

    if max_row > 6:
        print("\nColumn B values (last rows):")
        for r in range(max_row - 4, max_row + 1):
            print(f"B{r} =", ws.cell(row=r, column=col_B_idx).value)
