```repl
import os
from openpyxl import load_workbook
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Identify target column (header "Min Price > 0")
target_header = "Min Price > 0"
target_col = None
for c in range(1, ws.max_column + 1):
    if ws.cell(row=1, column=c).value == target_header:
        target_col = c
        break
if target_col is None:
    raise ValueError(f"Header '{target_header}' not found")

# Columns to evaluate: B (2) through N (14) – i.e., start_col=2, end_col=target_col-1
start_col = 2
end_col = target_col - 1

# Pre‑compute header references for columns B‑N (e.g., $B$1, $C$1, …)
header_refs = []
for col in range(start_col, end_col + 1):
    col_letter = get_column_letter(col)
    header_refs.append(f"${col_letter}$1")

# Build the per‑row formula dynamically
def build_formula(row_num: int) -> str:
    # Helper to create the repeated IF fragment for a given column
    def if_fragment(col_letter: str, header_ref: str) -> str:
        return (
            f"IF({col_letter}{row_num}>0,"
            f"IF({col_letter}{row_num}=MIN($B{row_num}:$N{row_num}),{header_ref}&\",\",\"\"),\"\""
        )
    # Assemble the concatenated IFs
    concat_parts = []
    for col in range(start_col, end_col + 1):
        col_letter = get_column_letter(col)
        header_ref = header_refs[col - start_col]
        concat_parts.append(if_fragment(col_letter, header_ref))
    concat_str = " & ".join(concat_parts)

    # Full formula with LEN/LEFT trimming
    formula = (
        f"=IF(LEN({concat_str})=0,"
        f"\"\","
        f"LEFT({concat_str},LEN({concat_str})-1))"
    )
    return formula

# Write formula into each data row
for r in range(2, ws.max_row + 1):
    ws.cell(row=r, column=target_col).value = build_formula(r)

# Save to output location
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify results by reloading with data_only=True
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification of column O (Min Price > 0) values after recalculation:")
for r in range(2, ws_check.max_row + 1):
    val = ws_check.cell(row=r, column=target_col).value
    print(f"Row {r}: {val}")

# Clean up references
del wb, ws, wb_check, ws_check
```
