import os
import openpyxl
from openpyxl import load_workbook

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # only one sheet

# Determine target column (Min Price > 0) – find header index
header_row = 1
target_header = "Min Price > 0"
target_col = None
for c in range(1, ws.max_column + 1):
    if ws.cell(row=header_row, column=c).value == target_header:
        target_col = c
        break
if target_col is None:
    raise ValueError(f"Header '{target_header}' not found")

# Columns to evaluate: from column after 'Product name' (col 2) up to column before target (col target_col-1)
start_col = 2  # 'Amazon'
end_col = target_col - 1  # last numeric column before target

# Write formula for each data row
for r in range(2, ws.max_row + 1):
    # Build the formula string with the correct row number
    formula = (
        f"=_xlfn.TEXTJOIN(\",\",TRUE,"
        f"IF((B{r}:N{r}>0)*(B{r}:N{r}=MIN(IF(B{r}:N{r}>0,B{r}:N{r}))),"
        f"$B$1:$N$1,\"\"))"
    )
    ws.cell(row=r, column=target_col).value = formula

# Save to output location
wb.save(output_path)

