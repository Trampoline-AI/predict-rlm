import openpyxl
from openpyxl import load_workbook

# Load the workbook
wb_path = input_spreadsheet  # variable provided by the environment
wb = load_workbook(wb_path, data_only=False)  # keep formulas

print(f"Workbook loaded from: {wb_path}")

# List sheet names
print("Sheets:", wb.sheetnames)

# Explore each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows (including header): {max_row}")
    print(f"Columns: {max_col}")

    # Get header row values
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Function to safely get a row as list of values
    def row_values(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]

    # Print first 5 data rows (if they exist)
    first_rows = min(5, max_row - 1)
    print("First data rows:")
    for r in range(2, 2 + first_rows):
        print(r, row_values(r))

    # Print last 5 data rows (if they exist)
    if max_row > 6:
        print("Last data rows:")
        for r in range(max_row - 4, max_row + 1):
            print(r, row_values(r))
```
