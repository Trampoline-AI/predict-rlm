Code:
```repl
import openpyxl
from openpyxl.styles import Border, Side, Font
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_39903_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_39903_init.xlsx")

# Load workbook
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Define border style (thin on all sides)
thin = Side(border_style="thin", color="000000")
border = Border(left=thin, right=thin, top=thin, bottom=thin)

# Define font
font = Font(name="Courier New", size=9)

def count_valid_bins(cell_value):
    """Return number of locations in the string that do NOT start with X or Z."""
    if not isinstance(cell_value, str):
        return 0
    # Split by commas
    parts = cell_value.split(",")
    count = 0
    for part in parts:
        part = part.strip()
        if not part:
            continue
        # Extract location before colon (if any)
        loc = part.split(":", 1)[0].strip()
        if not loc:
            continue
        first_char = loc[0].upper()
        if first_char not in ("X", "Z"):
            count += 1
    return count

# Process rows 2-6
for row in range(2, 7):
    b_cell = ws.cell(row=row, column=2)  # column B
    c_cell = ws.cell(row=row, column=3)  # column C (target)
    count = count_valid_bins(b_cell.value)
    c_cell.value = count
    # Apply formatting
    c_cell.border = border
    c_cell.font = font

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate (no formulas, but follow the workflow)
await recalculate(output_path)

# Reload to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]
print("Verification of C2:C6 after write:")
for r in range(2, 7):
    print(f"C{r} =", ws_check.cell(row=r, column=3).value)
```
