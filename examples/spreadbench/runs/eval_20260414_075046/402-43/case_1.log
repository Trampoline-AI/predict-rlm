import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string

# Load workbook
wb_path = "/sandbox/input/input_spreadsheet/1_402-43_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

# We'll inspect the first sheet (assuming the data is there)
