import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path)

print(f"Workbook loaded from {wb_path}")
print("Sheet names:", wb.sheetnames)

for ws_name in wb.sheetnames:
    ws = wb[ws_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {ws_name}")
    print(f"Rows: {max_row}, Columns: {max_col}")
    # Print header row (assume first row contains headers)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers (first row):", headers)
    # Sample first 5 data rows (row 2 onward)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Sample last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Specific cells I12 (column 9) and J23 (column 10)
    i12 = ws.cell(row=12, column=9)
    j23 = ws.cell(row=23, column=10)
    print(f"Cell I12 (R12C9) value: {i12.value!r}, type: {type(i12.value)}")
    print(f"Cell J23 (R23C10) value: {j23.value!r}, type: {type(j23.value)}")
    # If J23 contains a formula, show it
    if isinstance(j23.value, str) and j23.value.startswith('='):
        print(f"J23 current formula: {j23.value}")
    else:
        print("J23 does not contain a formula.")
