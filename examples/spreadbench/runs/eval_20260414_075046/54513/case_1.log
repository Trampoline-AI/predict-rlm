Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_54513_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_54513_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet1"]

# Locate original price cell (found earlier as C8)
orig_cell = ws["C8"]
orig_price = orig_cell.value
print("Original price cell:", orig_cell.coordinate, "value:", orig_price)

# Determine target column for discounted price
# Prefer column D if empty; otherwise find first empty column after max_column
target_col_idx = None
header_row = 1
data_row = 8

# Check column D (index 4)
if ws.cell(row=header_row, column=4).value is None and ws.cell(row=data_row, column=4).value is None:
    target_col_idx = 4
else:
    # Find first column after current max that is completely empty (header and data row)
    col = ws.max_column + 1
    while True:
        if ws.cell(row=header_row, column=col).value is None and ws.cell(row=data_row, column=col).value is None:
            target_col_idx = col
            break
        col += 1

target_col_letter = get_column_letter(target_col_idx)
target_cell = f"{target_col_letter}{data_row}"
print("Target cell for discounted price:", target_cell)

# Write formula: =C8*0.45   (or =C8*(1-0.55))
ws[target_cell] = f"={orig_cell.coordinate}*0.45"

# Optionally write a header in row 1 for this column
header_cell = f"{target_col_letter}{header_row}"
if ws[header_cell].value is None:
    ws[header_cell] = "Discounted Price"

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify the computed value
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
computed = ws_check[target_cell].value
print("Computed discounted price (data_only):", computed)
