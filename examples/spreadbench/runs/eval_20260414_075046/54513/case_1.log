First, we will:
1. Load the workbook from the provided path.
2. List all sheet names.
3. For each sheet, report the number of rows and columns.
4. Print the header row (row 1) to see column names.
5. Print the first 5 data rows and the last 5 data rows for context.
6. Search for any cell containing the exact value 34.99 (or a column header that suggests price) and print its location.

This exploratory step will give us the exact target cells/columns where we should write the discounted‑price formula.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_54513_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print a range of rows
def print_rows(ws, start, end):
    rows = []
    for r in range(start, end + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        rows.append(row_vals)
    for i, rv in enumerate(rows, start=start):
        print(f"Row {i}: {rv}")

# Explore each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Sheet: {name} ---")
    print(f"Rows: {ws.max_row}, Columns: {ws.max_column}")

    # Header row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print("Headers:", headers)

    # First 5 data rows (skip header)
    print("\nFirst 5 data rows:")
    print_rows(ws, 2, min(6, ws.max_row))

    # Last 5 data rows (if more than 6 rows total)
    if ws.max_row > 6:
        print("\nLast 5 data rows:")
        print_rows(ws, max(2, ws.max_row - 4), ws.max_row)

    # Search for the exact price 34.99
    found = []
    for r in range(2, ws.max_row + 1):
        for c in range(1, ws.max_column + 1):
            val = ws.cell(row=r, column=c).value
            if isinstance(val, (int, float)) and abs(val - 34.99) < 1e-6:
                found.append((r, get_column_letter(c), val))
    if found:
        print("\nCells containing 34.99:")
        for r, col, val in found:
            print(f"  {col}{r}")
    else:
        print("\nNo cell with value 34.99 found.")
```
