# Function to print a range of rows (as list of values)
def rows_to_list(ws, start, end):
    rows = []
    for r in range(start, end + 1):
        row = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        rows.append(row)
    return rows

# 2. Inspect each sheet
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Sheet: {name} ---")
    print(f"Rows: {ws.max_row}, Columns: {ws.max_column}")

    # Header row (assume first row)
    header = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column + 1)]
    print("Header:", header)

    # First 5 data rows (rows 2-6)
    first_rows = rows_to_list(ws, 2, min(6, ws.max_row))
    print("First data rows (up to 5):")
    for r in first_rows:
        print(r)

    # Last 5 data rows (excluding header)
    if ws.max_row > 2:
        start_last = max(2, ws.max_row - 4)
        last_rows = rows_to_list(ws, start_last, ws.max_row)
        print("Last data rows (up to 5):")
        for r in last_rows:
            print(r)
    else:
        print("No data rows beyond header.")

    # 3. Search for the INDEX formula
    found = False
    for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith("=INDEX"):
                print(f"Found INDEX formula in cell {cell.coordinate}: {cell.value}")
                found = True
    if not found:
        print("No INDEX formula found in this sheet.")
