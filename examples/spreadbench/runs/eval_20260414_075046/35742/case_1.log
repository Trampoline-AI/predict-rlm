# Print sheet information
print(f"Workbook loaded from: {wb_path}")
print("Sheet names:", wb.sheetnames)

# For each sheet, print dimensions and headers
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {sheet_name}")
    print(f"  Max row: {max_row}, Max column: {max_col}")

    # Get header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("  Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("  First 5 data rows:")
    for r in range(2, min(2 + 5, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"    Row {r}: {row_vals}")

    # Print last 5 data rows
    start_last = max(2, max_row - 4)
    print("  Last 5 data rows:")
    for r in range(start_last, max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"    Row {r}: {row_vals}")

# Also print the instruction for reference
print("\nInstruction:")
print(instruction)
