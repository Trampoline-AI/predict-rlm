import os
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import asyncio
from sandbox import recalculate  # provided utility for formula recalculation

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_359-21_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
print("Workbook loaded. Sheet names:", wb.sheetnames)

# Identify the sheet used by the macro (named "Delete" in the macro)
sheet_name = "Delete"
if sheet_name not in wb.sheetnames:
    sheet_name = wb.sheetnames[0]  # fallback to first sheet
    print(f"Sheet 'Delete' not found, using first sheet: {sheet_name}")
else:
    print(f"Using sheet: {sheet_name}")

ws = wb[sheet_name]

# Determine column index for the header "TYPE" (case‑insensitive)
header_row = 1
max_col = ws.max_column
type_col_idx = None
for col in range(1, max_col + 1):
    val = ws.cell(row=header_row, column=col).value
    if isinstance(val, str) and val.strip().lower() == "type":
        type_col_idx = col
        break

if type_col_idx is None:
    # If not found, default to column 2 (as seen in the sample data)
    type_col_idx = 2
    print("Header 'TYPE' not found; defaulting to column 2")
else:
    print(f"Found 'TYPE' header in column {type_col_idx} ({get_column_letter(type_col_idx)})")

# Collect rows where the TYPE column is empty (None or blank string)
rows_to_delete = []
max_row = ws.max_row
for r in range(2, max_row + 1):  # start after header
    cell_val = ws.cell(row=r, column=type_col_idx).value
    if cell_val is None or (isinstance(cell_val, str) and cell_val.strip() == ""):
        rows_to_delete.append(r)

print(f"Rows identified for deletion (empty TYPE): {rows_to_delete}")

# Delete rows in reverse order to avoid shifting indices
for r in sorted(rows_to_delete, reverse=True):
    ws.delete_rows(r, 1)

print(f"Deletion complete. New max row: {ws.max_row}")

# Save the modified workbook
wb.save(output_path)
print("Saved modified workbook to:", output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[sheet_name]
print("Verification after recalculation:")
print("Row count (including header):", ws_check.max_row)
print("First few data rows after deletion:")
for r in range(2, min(7, ws_check.max_row + 1)):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, ws_check.max_column + 1)]
    print(f"Row {r}:", row_vals)
