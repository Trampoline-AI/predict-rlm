Code:
```repl
import openpyxl
from openpyxl import load_workbook

# Load the workbook
wb_path = input_spreadsheet
wb = load_workbook(wb_path, data_only=False)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows for a sheet
def print_sheet_summary(ws, max_samples=5):
    # Determine max row and column
    max_row = ws.max_row
    max_col = ws.max_column
    # Get column letters for printing
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print(f"\nSheet '{ws.title}' summary:")
    print("Headers:", headers)
    # Print first few rows
    print(f"First {max_samples} data rows:")
    for r in range(2, min(1+max_samples, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Print last few rows
    if max_row > max_samples+1:
        print(f"Last {max_samples} data rows:")
        start = max(2, max_row - max_samples + 1)
        for r in range(start, max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(r, row_vals)

# Iterate through sheets and print summaries
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print_sheet_summary(ws)

# Close workbook (optional, as openpyxl does not require explicit close)
```
