Code:
```repl
import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet as observed

# Determine column indices (1‑based)
col_A = 1
col_B = 2
col_I = 9  # "Result" column

# Scan rows to collect names per source
names_source1 = set()
names_source2 = set()
current_source = None  # will be "Source 1" or "Source 2"

for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=col_A, max_col=col_B):
    r = row[0].row
    cell_A = row[0].value
    cell_B = row[1].value

    # Detect source header rows
    if isinstance(cell_A, str) and cell_A.strip().startswith("Source"):
        # e.g., "Source 1" or "Source 2"
        current_source = cell_A.strip()
        continue  # header row, no name to record

    # Data rows have a name in column B and blank column A
    if cell_B and cell_A is None:
        name = str(cell_B).strip()
        if current_source == "Source 1":
            names_source1.add(name)
        elif current_source == "Source 2":
            names_source2.add(name)
        # else: unknown source; ignore

# Write result into column I for each data row
for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=col_B, max_col=col_I):
    r = row[0].row
    cell_B = row[0].value  # column B
    cell_A = ws.cell(row=r, column=col_A).value  # column A
    # Skip header rows (where column A contains "Source …")
    if isinstance(cell_A, str) and cell_A.strip().startswith("Source"):
        continue
    # Process only rows that have a name in column B and blank column A
    if cell_B and cell_A is None:
        name = str(cell_B).strip()
        if name in names_source1 and name in names_source2:
            result = "Both"
        elif name in names_source1:
            result = "Only Source1"
        elif name in names_source2:
            result = "Only Source2"
        else:
            result = "Unknown"
        ws.cell(row=r, column=col_I, value=result)

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(output_path)

# Reload with data_only to verify results
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check.active

# Print verification of column I values for all rows that have a name
print("Verification of column I (Result) values:")
for r in range(2, ws_check.max_row + 1):
    name = ws_check.cell(row=r, column=col_B).value
    col_A = ws_check.cell(row=r, column=col_A).value
    if name and col_A is None:
        result = ws_check.cell(row=r, column=col_I).value
        print(f"Row {r}: Name={name} -> Result={result}")

# End of script
