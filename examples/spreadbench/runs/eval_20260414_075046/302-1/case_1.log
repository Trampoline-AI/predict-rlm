Code:
```repl
import openpyxl
from openpyxl import load_workbook

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_302-1_init.xlsx"
wb = load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows
def print_sheet_info(ws, max_samples=5):
    print(f"\n--- Sheet: {ws.title} ---")
    # Determine max column and row
    max_row = ws.max_row
    max_col = ws.max_column
    # Header (first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # First few rows
    print("First rows:")
    for r in range(2, min(max_row, max_samples+1)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Last few rows
    if max_row > max_samples+1:
        print("Last rows:")
        start = max(2, max_row - max_samples + 1)
        for r in range(start, max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(r, row_vals)

# Iterate over sheets
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    print_sheet_info(ws)

# Save workbook (no changes yet) to ensure we can reload later if needed
output_path = "/sandbox/output/output_spreadsheet/1_302-1_init.xlsx"
wb.save(output_path)
print("\nWorkbook saved to:", output_path)
```
