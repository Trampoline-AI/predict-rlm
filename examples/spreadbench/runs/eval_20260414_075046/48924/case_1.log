import openpyxl
from pathlib import Path
import datetime

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_48924_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_48924_init.xlsx"

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# 1. Gather dates from column A (skip header)
dates_in_a = []
for r in range(2, ws.max_row + 1):
    val = ws.cell(row=r, column=1).value
    if isinstance(val, (datetime.datetime, datetime.date)):
        # Ensure we work with datetime.date objects for consistency
        dates_in_a.append(val.date() if isinstance(val, datetime.datetime) else val)

if not dates_in_a:
    raise ValueError("No dates found in column A.")

# 2. Determine min and max dates
min_date = min(dates_in_a)
max_date = max(dates_in_a)

# 3. Generate full date range
total_days = (max_date - min_date).days + 1
full_range = [min_date + datetime.timedelta(days=i) for i in range(total_days)]

# 4. Compute missing dates
present_set = set(dates_in_a)
missing_dates = [d for d in full_range if d not in present_set]

# 5. Write missing dates into column C (index 3), starting at row 2
# First, clear existing values in column C up to the larger of original max_row or needed rows
max_target_row = max(ws.max_row, len(missing_dates) + 1)
for r in range(2, max_target_row + 1):
    ws.cell(row=r, column=3).value = None  # clear

# Now write missing dates
for idx, miss_date in enumerate(missing_dates, start=2):
    ws.cell(row=idx, column=3).value = miss_date  # openpyxl will store as date

# Save to output location
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
await recalculate(str(output_path))

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]

# Print verification: first few missing dates written to column C
print("Missing dates written to column C (first 10):")
for r in range(2, min(12, ws_check.max_row + 1)):
    val = ws_check.cell(row=r, column=3).value
    print(r, val)

# Also print total count
print("Total missing dates:", len(missing_dates))
```
