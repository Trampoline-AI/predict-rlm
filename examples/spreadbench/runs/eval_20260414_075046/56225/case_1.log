import openpyxl
from openpyxl.utils import get_column_letter
import os
from datetime import datetime

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_56225_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_56225_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# ------------------------------------------------------------------
# 1. Inspect the formula in G2 and the values of M3 and N5
ws_mech = wb["mechanic"]
g2_cell = ws_mech.cell(row=2, column=7)   # G2
m3_val = ws_mech.cell(row=3, column=13).value  # M3
n5_val = ws_mech.cell(row=5, column=14).value  # N5

print("G2 formula:", g2_cell.value)
print("M3 value :", m3_val)
print("N5 value :", n5_val)

# ------------------------------------------------------------------
# 2. Compute the expected sum in Python (name contains M3, date == N5)
ws_data = wb["data"]
max_row_data = ws_data.max_row

# Helper to convert time difference to hours (float)
def time_to_hours(t):
    return t.hour + t.minute/60 + t.second/3600

total_sum = 0.0
for r in range(2, max_row_data + 1):
    date_val = ws_data.cell(row=r, column=1).value   # A
    name_val = ws_data.cell(row=r, column=3).value   # C
    time_in = ws_data.cell(row=r, column=5).value   # E
    time_out = ws_data.cell(row=r, column=6).value  # F

    # Skip rows with missing data
    if not (date_val and name_val and time_in and time_out):
        continue

    # Compare date (ignore time part)
    if isinstance(date_val, datetime):
        date_cmp = date_val.date()
    else:
        date_cmp = date_val

    if isinstance(n5_val, datetime):
        target_date = n5_val.date()
    else:
        target_date = n5_val

    # Name match using substring (case‑insensitive)
    if (m3_val and m3_val.lower() in str(name_val).lower()
        and date_cmp == target_date):
        # Compute hours from time_out - time_in
        # Convert times to datetime for subtraction
        dt_in = datetime.combine(datetime.min, time_in)
        dt_out = datetime.combine(datetime.min, time_out)
        diff = (dt_out - dt_in).total_seconds() / 3600.0
        total_sum += diff

print("Python‑computed expected sum:", total_sum)

# ------------------------------------------------------------------
# 3. Write the computed sum as a static value into G2 (overwrite formula)
ws_mech.cell(row=2, column=7).value = total_sum

# ------------------------------------------------------------------
# 4. Save workbook
wb.save(output_path)

# ------------------------------------------------------------------
# 5. Recalculate formulas (even though G2 now holds a static value)
await recalculate(output_path)

# ------------------------------------------------------------------
# 6. Verify by reloading with data_only=True
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["mechanic"]
g2_val = ws_check.cell(row=2, column=7).value
print("Verified G2 value after reload:", g2_val)

# Also print a few per‑mechanic sums to confirm they remain
print("\nPer‑mechanic sums (first 5 rows, columns B‑E):")
for r in range(2, 7):
    vals = [ws_check.cell(row=r, column=c).value for c in range(2, 6)]
    print(f"Row {r}:", vals)
