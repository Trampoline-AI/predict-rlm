import os
import pathlib
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
pathlib.Path(output_dir).mkdir(parents=True, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet1"]

max_col = ws.max_column
max_row = ws.max_row

# Helper to check if a row is completely blank (all cells None)
def is_blank_row(r):
    return all(ws.cell(row=r, column=c).value is None for c in range(1, max_col + 1))

# Identify blocks (list of lists of row indices)
blocks = []
current_block = []
for r in range(2, max_row + 1):  # assume header at row 1
    if is_blank_row(r):
        if current_block:
            blocks.append(current_block)
            current_block = []
    else:
        current_block.append(r)
# Append last block if file ends without trailing blank rows
if current_block:
    blocks.append(current_block)

print(f"Detected {len(blocks)} blocks")

# Process each block: sort rows by D (B+C) descending
write_row = 2  # start writing after header
for block_idx, block in enumerate(blocks, start=1):
    # Extract row data and compute D value
    rows_data = []
    for r in block:
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        # Compute D = B + C (columns 2 and 3)
        b = ws.cell(row=r, column=2).value
        c = ws.cell(row=r, column=3).value
        try:
            d_val = float(b) + float(c) if (b is not None and c is not None) else None
        except Exception:
            d_val = None
        rows_data.append((d_val, row_vals))
    # Sort descending, treating None as very small
    rows_data.sort(key=lambda x: (x[0] is not None, x[0]), reverse=True)
    # Write sorted rows back
    for d_val, row_vals in rows_data:
        for col_idx, val in enumerate(row_vals, start=1):
            ws.cell(row=write_row, column=col_idx).value = val
        write_row += 1
    # After each block, insert a single blank row (except after last block)
    if block_idx < len(blocks):
        for col in range(1, max_col + 1):
            ws.cell(row=write_row, column=col).value = None
        write_row += 1

# Clear any rows beyond the last written row up to original max_row
for r in range(write_row, max_row + 1):
    for col in range(1, max_col + 1):
        ws.cell(row=r, column=col).value = None

# Save to output path
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas using the provided tool
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to verify sorting (optional quick check)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
# Print first few rows of each block to confirm descending D
print("\nVerification of first 3 blocks (first 5 rows each):")
row_ptr = 2
for blk in range(1, min(4, len(blocks) + 1)):
    print(f"Block {blk}:")
    for i in range(5):
        if row_ptr > ws_check.max_row:
            break
        d_val = ws_check.cell(row=row_ptr, column=4).value
        print(f"  Row {row_ptr} D={d_val}")
        row_ptr += 1
    # skip the blank separator
    row_ptr += 1
