Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl import Workbook

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_108-24_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_108-24_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Source and destination sheets
src = wb["BZTB"]
dest = wb["Tema UV COS"]  # sheet already exists

# Define prefixes (strip any surrounding whitespace)
prefixes = ["COS Pass", "COS Comm", "COS W/S"]

# Helper to test description
def description_matches(desc: str) -> bool:
    if not isinstance(desc, str):
        return False
    desc_stripped = desc.strip()
    # Check startswith any of the prefixes
    if not any(desc_stripped.startswith(p) for p in prefixes):
        return False
    # Check contains "Used"
    if "Used" not in desc_stripped:
        return False
    return True

# Collect matching rows
matched_rows = []
for r in range(2, src.max_row + 1):
    val_a = src.cell(row=r, column=1).value
    desc = src.cell(row=r, column=2).value
    # Exclude ID 398726
    if val_a == "398726" or val_a == 398726:
        continue
    if description_matches(desc):
        # Grab columns A-D
        row_vals = [src.cell(row=r, column=c).value for c in range(1, 5)]
        matched_rows.append(row_vals)

# Write to destination starting at row 1
for idx, row_vals in enumerate(matched_rows, start=1):
    for c, val in enumerate(row_vals, start=1):
        dest.cell(row=idx, column=c).value = val

# Save to output path
wb.save(output_path)

# Recalculate formulas (if any) using provided tool
await recalculate(output_path)

# Reload with data_only to verify
wb_check = openpyxl.load_workbook(output_path, data_only=True)
dest_check = wb_check["Tema UV COS"]
print("Destination sheet now has rows:", dest_check.max_row)
# Print first 5 rows of destination for verification
for r in range(1, min(6, dest_check.max_row + 1)):
    vals = [dest_check.cell(row=r, column=c).value for c in range(1,5)]
    print(f"Row {r}:", vals)
```
