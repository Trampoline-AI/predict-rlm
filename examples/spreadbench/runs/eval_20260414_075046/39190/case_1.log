import os
import openpyxl
from openpyxl.styles import PatternFill
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_39190_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_39190_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming single sheet as discovered

# Build set of values from column F (6)
f_values = set()
for row in range(2, ws.max_row + 1):
    val = ws.cell(row=row, column=6).value
    if val is not None:
        f_values.add(val)

# Prepare highlight fill (yellow)
highlight_fill = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")

# Apply logic to column C (3)
for row in range(2, ws.max_row + 1):
    a_val = ws.cell(row=row, column=1).value
    target_cell = ws.cell(row=row, column=3)

    # Determine if we need to write "Delete"
    if a_val in f_values:
        # Only write if cell is empty or not already "Delete"
        if target_cell.value != "Delete":
            target_cell.value = "Delete"
        # Apply highlight
        target_cell.fill = highlight_fill
    else:
        # Ensure non‑matching rows have no fill (optional)
        if target_cell.fill.patternType == "solid":
            target_cell.fill = openpyxl.styles.PatternFill(fill_type=None)

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any)
await recalculate(output_path)

# Verify: reload with data_only=True and print rows where column C == "Delete"
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Rows with 'Delete' in column C:")
for row in range(2, ws_check.max_row + 1):
    if ws_check.cell(row=row, column=3).value == "Delete":
        print(f"Row {row}: A={ws_check.cell(row=row, column=1).value}, "
              f"F={ws_check.cell(row=row, column=6).value}")

# End of script
```
