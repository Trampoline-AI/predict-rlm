import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Worksheets
ws_data = wb["Data"]
ws_lookup = wb["Lookup"]

# Determine the last row in Lookup (including possible empty rows)
max_row_lookup = ws_lookup.max_row

# Write the OFFSET formula into column B for each row that has a year in column A
for r in range(2, max_row_lookup + 1):
    year_cell = ws_lookup.cell(row=r, column=1)  # column A
