import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print('Sheet names:', wb.sheetnames)

# Function to print sheet info

def print_sheet_info(ws, max_rows=10):
    # Determine header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print(f"Sheet '{ws.title}': rows={ws.max_row}, cols={ws.max_column}")
    print('Headers:', headers)
    # Print first few rows
    print('First rows:')
    for r in range(2, min(ws.max_row, max_rows)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)
    # Print last few rows
    print('Last rows:')
    start = max(2, ws.max_row - max_rows + 1)
    for r in range(start, ws.max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)

# Inspect each sheet
for title in wb.sheetnames:
    ws = wb[title]
    print_sheet_info(ws)
```
