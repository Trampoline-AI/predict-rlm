# Helper to print a row's values with column letters

def print_row(ws, row_num):
    values = []
    for col in range(1, ws.max_column + 1):
        cell = ws.cell(row=row_num, column=col)
        values.append((get_column_letter(col), cell.value))
    print(f"Row {row_num} values:")
    for col_letter, val in values:
        if val is not None:
            print(f"  {col_letter}: {val}")

# Inspect the year row (row 4) and the target data row (row 14)
