print(f"Lookup sheet has {max_row_lookup} rows (including header).")

# Show a few rows of Lookup to confirm layout
for r in range(2, min(max_row_lookup, 8) + 1):
    year = ws_lookup.cell(row=r, column=1).value
    val = ws_lookup.cell(row=r, column=2).value
    print(f"Lookup row {r}: Year={year}, Current B={val}")
