import openpyxl, os

# Paths (same as before)
input_path = '/sandbox/input/input_spreadsheet/1_31202_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_31202_init.xlsx')

# Load the workbook with evaluated values (data_only=True)
wb = openpyxl.load_workbook(output_path, data_only=True)
ws = wb['NOMINA']

# Column indices (1‑based)
COL_WORKER = 4   # D
COL_DEDUC = 7   # G
COL_ADDIT = 8   # H
COL_DEBT = 10   # J

# Gather rows per worker
worker_rows = {}
for row in range(2, ws.max_row + 1):
    worker = ws.cell(row=row, column=COL_WORKER).value
    if worker is None:
        continue
    deductions = ws.cell(row=row, column=COL_DEDUC).value or 0
    additions = ws.cell(row=row, column=COL_ADDIT).value or 0
    debt = ws.cell(row=row, column=COL_DEBT).value
    worker_rows.setdefault(worker, []).append({
        'row': row,
        'deductions': deductions,
        'additions': additions,
        'debt': debt,
    })

# Print summary for each worker (first 5 rows per worker)
for worker, rows in worker_rows.items():
    print(f"\nWorker: {worker} (total rows: {len(rows)})")
    for r in rows[:5]:
        print(f"  Row {r['row']}: Deductions={r['deductions']}, Additions={r['additions']}, Debt={r['debt']}")
    # Also show last row for the worker
    if len(rows) > 5:
        last = rows[-1]
        print(f"  ... last row {last['row']}: Deductions={last['deductions']}, Additions={last['additions']}, Debt={last['debt']}")

# Specifically check the worker mentioned in the sample (JESUS MAGAÑA)
target = 'JESUS MAGAÑA'
if target in worker_rows:
    print(f"\nDetailed rows for {target}:")
    for r in worker_rows[target]:
        print(f"  Row {r['row']}: Deductions={r['deductions']}, Additions={r['additions']}, Debt={r['debt']}")
else:
    print(f"\nWorker {target} not found in the sheet.")
