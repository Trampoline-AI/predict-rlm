# We'll work with the first sheet (assuming that's the main data sheet)
ws = wb[wb.sheetnames[0]]
print('Active sheet:', ws.title)
print('Max row:', ws.max_row, 'Max column:', ws.max_column)

# Print header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
print('Headers:', headers)

# Helper to print a range of rows

def print_rows(start, end):
    for r in range(start, end+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f'Row {r}:', row_vals)

# Print first 5 data rows (assuming header is row 1)
print('\nFirst 5 data rows:')
print_rows(2, min(6, ws.max_row))

# Print last 5 data rows
if ws.max_row > 6:
    print('\nLast 5 data rows:')
    start = max(2, ws.max_row-4)
    print_rows(start, ws.max_row)

# Also inspect column H and I values for a few rows to see existing content/formatting
