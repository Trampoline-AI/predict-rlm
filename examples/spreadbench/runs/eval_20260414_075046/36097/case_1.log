for r in range(2, min(7, ws.max_row+1)):
    h = ws.cell(row=r, column=column_index_from_string('H')).value
    i = ws.cell(row=r, column=column_index_from_string('I')).value
    print(f'Row {r}: H={h}, I={i}')
