    for r in range(2, min(7, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}:", row_vals)

    # Print last 5 data rows
    print("Last 5 data rows:")
    start_last = max(2, max_row - 4)
    for r in range(start_last, max_row + 1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(f"Row {r}:", row_vals)

    # Inspect columns B, D, F for formulas and fill colors
    for col_letter in ["B", "D", "F"]:
        col_idx = openpyxl.utils.column_index_from_string(col_letter)
        print(f"\nColumn {col_letter} formulas and fills:")
        for r in range(2, max_row + 1):
            cell = ws.cell(row=r, column=col_idx)
            if isinstance(cell.value, str) and cell.value.startswith("="):
                fill = cell.fill
                fill_color = fill.start_color.rgb if fill and fill.start_color else None
                print(f"  R{r}{col_letter}: formula={cell.value}, fill={fill_color}")
