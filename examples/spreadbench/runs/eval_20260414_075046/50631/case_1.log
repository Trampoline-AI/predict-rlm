import openpyxl
from openpyxl.utils import get_column_letter
from pathlib import Path

# Load workbook
wb_path = Path("/sandbox/input/input_spreadsheet/1_50631_init.xlsx")
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Explore each sheet (likely only Sheet1)
for ws in wb.worksheets:
    print("\n--- Sheet:", ws.title, "---")
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Dimensions: rows={max_row}, cols={max_col}")

    # Get headers from first row
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Print first 5 data rows (rows 2-6)
