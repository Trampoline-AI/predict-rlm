Code:
```repl
import os
import openpyxl

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_382-10_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_382-10_init.xlsx")

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["Sheet1"]  # based on inspection

# Clear column A cells that are not exactly "Comments"
for row in range(2, ws.max_row + 1):
    cell = ws.cell(row=row, column=1)  # Column A
    # cell.value may be a formula object; compare its string representation
    if cell.value != "Comments":
        cell.value = None

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Verify: reload with data_only to see evaluated values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Sheet1"]
print("Verification of column A after clearing (first 10 rows):")
for row in range(2, min(ws_check.max_row, 11) + 1):
    print(f"Row {row}: {ws_check.cell(row=row, column=1).value}")

# Also print the last few rows to ensure the formula was cleared
print("Verification of column A (last 5 rows):")
start = max(2, ws_check.max_row - 4)
for row in range(start, ws_check.max_row + 1):
    print(f"Row {row}: {ws_check.cell(row=row, column=1).value}")
```
