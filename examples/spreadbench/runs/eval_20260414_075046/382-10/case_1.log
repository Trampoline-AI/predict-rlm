Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_382-10_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows for a sheet
def inspect_sheet(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Max row: {ws.max_row}, Max column: {ws.max_column}")
    
    # Header row (assume first row is header)
    headers = [ws.cell(row=1, column=col).value for col in range(1, ws.max_column + 1)]
    print("Headers:", headers)
    
    # Print first 5 data rows (rows 2-6)
    print("First 5 data rows:")
    for row in range(2, min(ws.max_row, 6) + 1):
        values = [ws.cell(row=row, column=col).value for col in range(1, ws.max_column + 1)]
        print(f"Row {row}:", values)
    
    # Print last 5 data rows (if more than 6 rows)
    if ws.max_row > 6:
        print("Last 5 data rows:")
        start = max(2, ws.max_row - 4)
        for row in range(start, ws.max_row + 1):
            values = [ws.cell(row=row, column=col).value for col in range(1, ws.max_column + 1)]
            print(f"Row {row}:", values)

# Inspect each sheet
for ws in wb.worksheets:
    inspect_sheet(ws)
```
