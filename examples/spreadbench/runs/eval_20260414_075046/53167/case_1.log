import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read-only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_53167_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

print("Sheet names:", wb.sheetnames)

for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{name}': rows={max_row}, cols={max_col}")

    # Print header row (assume first row)
    headers = [ws.cell(row=1, column=col).value for col in range(1, max_col+1)]
    print("Headers:", headers)

    # Helper to print a row as list of values
    def row_vals(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]

    # First 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        print(r, row_vals(r))

    # Last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        print(r, row_vals(r))

    # Show column E values (index 5)
    col_e_vals = [ws.cell(row=r, column=5).value for r in range(2, max_row+1)]
    print("Column E sample values (first 10):", col_e_vals[:10])
    print("Column E sample values (last 10):", col_e_vals[-10:])
