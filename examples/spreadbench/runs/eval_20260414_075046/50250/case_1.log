Code:
```repl
import openpyxl
from openpyxl import load_workbook
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook for editing (data_only=False to keep formulas)
wb = load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Reference value from G2
ref_val = ws.cell(row=2, column=7).value  # column G = 7
print("Reference value (G2):", ref_val)

total = 0
# Iterate over all rows with data (starting at row 2)
for row in range(2, ws.max_row + 1):
    a_val = ws.cell(row=row, column=1).value   # column A
    b_val = ws.cell(row=row, column=2).value   # column B
    if a_val == ref_val or b_val == ref_val:
        # Check columns C (3), D (4), E (5)
        for col in (3, 4, 5):
            cell_val = ws.cell(row=row, column=col).value
            if isinstance(cell_val, (int, float)):
                total += cell_val

print("Computed total to H2:", total)

# Write result to H2 (column 8)
ws.cell(row=2, column=8, value=total)

# Save to output path
wb.save(output_path)

# Recalculate formulas (even though we wrote a static value)
await recalculate(output_path)

# Verify the saved value (load with data_only=True)
wb_check = load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verified H2 value after save:", ws_check.cell(row=2, column=8).value)
```
