print("Value in G2:", g2_val)

# Function to get a row as list of values
def row_values(row_idx):
    return [ws.cell(row=row_idx, column=c).value for c in range(1, ws.max_column + 1)]

# Print first 5 data rows (rows 2‑6)
print("\nFirst 5 data rows:")
for r in range(2, min(ws.max_row, 6) + 1):
    print(f"Row {r}:", row_values(r))

# Print last 5 data rows
