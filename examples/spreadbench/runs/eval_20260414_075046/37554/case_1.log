import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_37554_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_37554_init.xlsx")

# Load workbook with formulas (data_only=False)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Verify existing formula in F2 (for debugging)
cell_f2 = ws["F2"]
print("Before modification, F2 raw value type:", type(cell_f2.value))
if isinstance(cell_f2.value, openpyxl.worksheet.formula.ArrayFormula):
    print("Existing ArrayFormula text:", cell_f2.value.text)
else:
    print("Existing F2 value:", cell_f2.value)

