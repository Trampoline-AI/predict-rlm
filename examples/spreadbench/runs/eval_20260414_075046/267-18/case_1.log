        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)
    # Print last 5 rows
    print('Last 5 rows:')
    start = max(2, ws.max_row-4)
    for r in range(start, ws.max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(r, row_vals)
    # Inspect column G (7) fill for first few rows
    print('Column G fill colors (first 10 rows):')
    for r in range(2, min(ws.max_row, 11)):
        cell = ws.cell(row=r, column=7)  # column G
        fill = cell.fill
        # openpyxl stores fill colors as a PatternFill with fgColor
        color = fill.fgColor.rgb if fill.fgColor else None
