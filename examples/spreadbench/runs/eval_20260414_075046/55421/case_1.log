import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_55421_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_55421_init.xlsx')

# Load workbook (read formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row
col_a = column_index_from_string('A')
col_d = column_index_from_string('D')
col_e = column_index_from_string('E')
col_f = column_index_from_string('F')

# Gather MRN‑level info
mrn_info = {}
for r in range(2, max_row + 1):
    mrn = ws.cell(row=r, column=col_a).value
    status = ws.cell(row=r, column=col_d).value
    date = ws.cell(row=r, column=col_e).value
    if mrn is None:
        continue
    info = mrn_info.setdefault(mrn, {'statuses': set(), 'no_show_date': False})
    if status:
        info['statuses'].add(status)
    if status == 'No Show' and date is not None:
        info['no_show_date'] = True

# Compute expected text per row
expected = {}
for r in range(2, max_row + 1):
    mrn = ws.cell(row=r, column=col_a).value
    if mrn is None:
        expected[r] = ''
        continue
    info = mrn_info.get(mrn, {})
    statuses = info.get('statuses', set())
    no_show_date = info.get('no_show_date', False)
    # Apply the priority rules
    if 'Sch' in statuses and 'No Show' in statuses:
        val = 'NS/SCHED'
    elif 'No Show' in statuses and no_show_date:
        val = 'NO ACTION NEEDED'
    elif 'Sch' in statuses and 'No Show' not in statuses:
        val = 'FUTURE'
    else:
        val = ''
    expected[r] = val

# Print a sample comparison (first 7 rows)
print('Row | MRN      | Status   | Date          | Current F               | Expected')')
for r in range(2, min(9, max_row + 1)):
    mrn = ws.cell(row=r, column=col_a).value
    status = ws.cell(row=r, column=col_d).value
    date = ws.cell(row=r, column=col_e).value
    current_f = ws.cell(row=r, column=col_f).value
    exp = expected[r]
    print(f'{r:<3} | {mrn!s:<8} | {status!s:<8} | {str(date):<15} | {str(current_f):<22} | {exp}')

# Overwrite column F with the expected static values (if they differ)
for r, val in expected.items():
    ws.cell(row=r, column=col_f).value = val

# Ensure output directory exists and save
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)

# Recalculate formulas (none now, but required by workflow)
await recalculate(output_path)

# Reload with data_only=True to verify
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
print('\nVerification after reload (first 7 rows):')
for r in range(2, min(9, ws2.max_row + 1)):
    print(f'F{r}:', ws2.cell(row=r, column=col_f).value)
