Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the input workbook (read/write)
wb_path = "/sandbox/input/input_spreadsheet/1_36764_init.xlsx"
wb = openpyxl.load_workbook(wb_path)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print header row and sample data
def inspect_sheet(ws):
    # Find first non‑empty row (assume header is row 1)
    header_row = 1
    headers = [ws.cell(row=header_row, column=c).value for c in range(1, ws.max_column + 1)]
    print(f"Sheet '{ws.title}': max_row={ws.max_row}, max_column={ws.max_column}")
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(ws.max_row + 1, 7)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
        print(r, row_vals)

    # Print last 5 data rows (if more than 6 rows)
    if ws.max_row > 6:
        print("Last 5 data rows:")
        for r in range(max(2, ws.max_row - 4), ws.max_row + 1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
            print(r, row_vals)

# Inspect each sheet
for ws in wb.worksheets:
    inspect_sheet(ws)

# 2. Print current value of cell C2 in the first sheet
first_ws = wb.worksheets[0]
c2_val = first_ws["C2"].value
print(f"Current value of {first_ws.title}!C2:", c2_val)
```
