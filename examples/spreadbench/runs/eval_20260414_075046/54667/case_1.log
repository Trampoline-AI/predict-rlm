Code:
```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
# Assume the first sheet is the target (as inspected)
ws = wb.worksheets[0]

# Update formulas in G3:G58
for r in range(3, 59):  # inclusive of 58
    # Build formula string
    formula = f"=IF(D{r}=E{r},M{r},IFERROR(VLOOKUP(C{r},DATA!$A:$E,5,0),\"\"))"
    ws.cell(row=r, column=7).value = formula

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)
# Save workbook
wb.save(output_path)

# Recalculate formulas using LibreOffice fallback
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only to see evaluated values for a few rows
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2.worksheets[0]
print("Sample evaluated values after recalculation:")
for r in range(3, 9):
    print(f"G{r} = {ws2.cell(row=r, column=7).value}")
