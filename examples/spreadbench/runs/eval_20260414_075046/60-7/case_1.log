import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read-only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_60-7_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sheet summary
def summarize_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {ws.title}")
    print(f"  Max row: {max_row}, Max column: {max_col}")
    # Header row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("  Headers:", headers)
    # First 5 data rows (skip header)
    print("  First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"    Row {r}: {row_vals}")
    # Last 5 data rows
    print("  Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"    Row {r}: {row_vals}")

# Summarize each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    summarize_sheet(ws)

# Identify target cell(s) in Consolidated Tracker where output is expected
# Look for a column header that suggests output, e.g., "Net Activity" or similar
consolidated_ws = wb["Consolidated Tracker"] if "Consolidated Tracker" in wb.sheetnames else None
if consolidated_ws:
    # Print header row
    max_col = consolidated_ws.max_column
    headers = [consolidated_ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("\nConsolidated Tracker headers:", headers)
    # Print a few rows to see where the user indicated output location
    print("Consolidated Tracker sample rows (first 5):")
    for r in range(2, min(7, consolidated_ws.max_row+1)):
        row_vals = [consolidated_ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"    Row {r}: {row_vals}")
else:
    print("Consolidated Tracker sheet not found.")
