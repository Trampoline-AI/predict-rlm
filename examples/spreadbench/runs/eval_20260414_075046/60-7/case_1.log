```repl
import openpyxl
from pathlib import Path

# Paths
input_path = Path("/sandbox/input/input_spreadsheet/1_60-7_init.xlsx")
output_dir = Path("/sandbox/output/output_spreadsheet/")
output_dir.mkdir(parents=True, exist_ok=True)
output_path = output_dir / "1_60-7_init.xlsx"

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Helper to extract rows (as tuples) from a sheet, skipping the header (row 2)
def get_data_rows(ws):
    rows = []
    for r in range(3, ws.max_row + 1):  # data starts at row 3 (row 2 is header)
        # Stop if the first cell is None and the whole row appears empty
        if ws.cell(row=r, column=1).value is None:
            # check if all cells are None, then break
            if all(ws.cell(row=r, column=c).value is None for c in range(1, ws.max_column + 1)):
                continue
        row_vals = tuple(ws.cell(row=r, column=c).value for c in range(1, 6))  # first 5 columns
        rows.append(row_vals)
    return rows

# Extract data
existing_ws = wb["Existing Task"]
additions_ws = wb["Additions"]
retired_ws = wb["Retired"]
consolidated_ws = wb["Consolidated Tracker"]

existing_rows = get_data_rows(existing_ws)
additions_rows = get_data_rows(additions_ws)
retired_rows = set(get_data_rows(retired_ws))  # use set for fast lookup

# Combine Existing + Additions
combined = existing_rows + additions_rows

# Subtract retired rows (exact match on all five columns)
net_rows = [row for row in combined if row not in retired_rows]

# Write net rows into Consolidated Tracker, starting at row 3, columns A-E
start_row = 3
for i, row_vals in enumerate(net_rows):
    out_row = start_row + i
    for col_idx, value in enumerate(row_vals, start=1):  # columns 1-5
        consolidated_ws.cell(row=out_row, column=col_idx).value = value

# If there were leftover rows from a previous run, clear them
# (clear rows after the last written row up to previous max row)
for r in range(start_row + len(net_rows), consolidated_ws.max_row + 1):
    for c in range(1, 6):
        consolidated_ws.cell(row=r, column=c).value = None

# Save to output location
wb.save(output_path)

# Recalculate formulas (if any) using the provided tool
await recalculate(str(output_path))

# Reload with data_only=True to verify values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["Consolidated Tracker"]
print("Verification - first few rows in Consolidated Tracker:")
for r in range(3, min(3 + len(net_rows), ws_check.max_row + 1)):
    vals = [ws_check.cell(row=r, column=c).value for c in range(1, 6)]
    print(f"Row {r}: {vals}")

# Also print total count of net rows
print("Total net rows written:", len(net_rows))
