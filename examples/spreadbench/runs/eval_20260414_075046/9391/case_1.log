import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_9391_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sheet summary
def summarize_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet '{ws.title}' ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # First few data rows (rows 2-6)
    print("First few data rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # Last few rows (last 5)
    print("Last few data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

# Summarize each sheet
for ws in wb.worksheets:
    summarize_sheet(ws)

# Specific cell B1 on 'Front' sheet
if 'Front' in wb.sheetnames:
    front_ws = wb['Front']
    b1_val = front_ws['B1'].value
    print("\nFront!B1 value:", b1_val)
else:
    print("\nSheet 'Front' not found.")

# Sample values from column A and F on 'Data' sheet
if 'Data' in wb.sheetnames:
    data_ws = wb['Data']
    print("\nSample values from Data!A (dates) and Data!F (values):")
    for r in range(2, min(7, data_ws.max_row+1)):
        date_val = data_ws.cell(row=r, column=1).value  # column A
        f_val = data_ws.cell(row=r, column=6).value    # column F
        print(f"Row {r}: A={date_val}, F={f_val}")
else:
    print("\nSheet 'Data' not found.")
