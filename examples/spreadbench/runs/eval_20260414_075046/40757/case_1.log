```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_40757_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_40757_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]

# Determine data range (rows 3 through the row before the first empty row after data)
# From exploration we know rows 3‑8 hold the data.
data_start = 3
data_end = 8  # inclusive

# Write SUMIFS formulas for July (row 10) and August (row 11)
for row in [10, 11]:
    month_cell = ws.cell(row=row, column=1)  # column A contains month name
    result_cell = ws.cell(row=row, column=2)  # column B will hold the sum
    # Build formula string
    formula = (
        f"=SUMIFS(${get_column_letter(2)}${data_start}:${get_column_letter(2)}${data_end}, "
        f"TEXT(${get_column_letter(1)}${data_start}:${get_column_letter(1)}${data_end},\"mmmm\"), "
        f"${get_column_letter(1)}{row}, "
        f"${get_column_letter(2)}${data_start}:${get_column_letter(2)}${data_end}, \"<>0\")"
    )
    result_cell.value = formula

# Save to output path
wb.save(output_path)

# Recalculate formulas using the provided tool
await recalculate(output_path)

# Reload with data_only to check results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[wb2.sheetnames[0]]
july_sum = ws2.cell(row=10, column=2).value
aug_sum = ws2.cell(row=11, column=2).value
print("July sum (computed):", july_sum)
print("August sum (computed):", aug_sum)
```
