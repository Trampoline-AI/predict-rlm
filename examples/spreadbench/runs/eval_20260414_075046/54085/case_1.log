Code:
```repl
import openpyxl, os
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_54085_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_54085_init.xlsx')

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook for editing
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume first sheet

# Determine last row with data (use max_row)
max_row = ws.max_row

# Write formula to column C (index 3) for rows 2..max_row
for r in range(2, max_row + 1):
    formula = f"=IF(B{r}=$A$2,\"\",B{r})"
    ws.cell(row=r, column=3).value = formula

# Save to output location
wb.save(output_path)

# Recalculate formulas using the provided tool
await recalculate(output_path)

# Reload with data_only=True to verify results
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print('Verification of C2:C4 after recalculation:')
for r in range(2, 5):
    val = ws_check.cell(row=r, column=3).value
    print(f'C{r}:', val)
```
