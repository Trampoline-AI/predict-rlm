import openpyxl, os, json, sys
from openpyxl.utils import get_column_letter

# Load the workbook (read_only for inspection)
wb_path = '/sandbox/input/input_spreadsheet/1_54085_init.xlsx'
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
sheet_names = wb.sheetnames
print('Sheet names:', sheet_names)

# We'll inspect the first sheet (assuming that's the target)
ws = wb[sheet_names[0]]

# Determine max rows and columns
max_row = ws.max_row
max_col = ws.max_column
print(f'Worksheet "{ws.title}" has {max_row} rows and {max_col} columns')

# Print header row (row 1)
headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
print('Headers:', headers)

# Function to print a range of rows

def print_rows(start, end):
    for r in range(start, end+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f'Row {r}:', row_vals)

# Print first 5 data rows (excluding header)
print('\nFirst 5 data rows:')
print_rows(2, min(6, max_row))

# Print last 5 data rows
