import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string

# Load the workbook
input_path = "/sandbox/input/input_spreadsheet/1_10747_init.xlsx"
wb = openpyxl.load_workbook(input_path, data_only=False)  # keep formulas

# Gather sheet info
sheet_info = {}
for ws in wb.worksheets:
    # Determine max row/col (considering possible empty rows)
    max_row = ws.max_row
    max_col = ws.max_column
    # Get headers from first row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    sheet_info[ws.title] = {
        "max_row": max_row,
        "max_col": max_col,
        "headers": headers,
    }

print("=== Sheet Overview ===")
for name, info in sheet_info.items():
    print(f"Sheet: {name}")
    print(f"  Rows: {info['max_row']}, Columns: {info['max_col']}")
    print(f"  Headers: {info['headers']}")

# For each sheet, print first 5 rows and last 5 rows (excluding header)
def print_rows(ws, start, end):
    rows = []
    for r in range(start, end+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        rows.append(row_vals)
    return rows

for ws in wb.worksheets:
    print(f"\n--- Data preview for sheet: {ws.title} ---")
    total_rows = ws.max_row
    # First data rows (skip header row 1)
    first_rows = print_rows(ws, 2, min(6, total_rows))
    print("First rows (2-6):")
    for r in first_rows:
        print(r)
    # Last rows
    if total_rows > 7:
        last_start = max(2, total_rows-4)
        last_rows = print_rows(ws, last_start, total_rows)
        print(f"Last rows ({last_start}-{total_rows}):")
        for r in last_rows:
            print(r)

# Search for cells containing the problematic IF formula
print("\n=== Cells containing the IF formula ===")
for ws in wb.worksheets:
    for row in ws.iter_rows(min_row=2, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
        for cell in row:
            if isinstance(cell.value, str) and cell.value.strip().upper().startswith("IF("):
                # Show a snippet of the formula
                print(f"Sheet: {ws.title}, Cell: {cell.coordinate}, Formula: {cell.value}")

# Identify the target cell(s) where the result should be placed.
# Look for columns I and J (year and share) and any column that seems to hold the result (maybe column K or L)
print("\n=== Column indices for I and J ===")
for ws in wb.worksheets:
    # Find column numbers for headers "Year" and "Share" if present
    for col_idx, header in enumerate(sheet_info[ws.title]["headers"], start=1):
        if isinstance(header, str):
            hdr = header.strip().lower()
            if hdr in ("year", "yr", "year " "y"):
                print(f"Sheet {ws.title}: Year header at column {get_column_letter(col_idx)}")
            if hdr in ("share", "share no", "share number", "share_no"):
                print(f"Sheet {ws.title}: Share header at column {get_column_letter(col_idx)}")
