import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_10747_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_10747_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming the only sheet is the target

# Verify the cell that currently holds the bad formula
bad_cell = ws["K6"]
print("Original K6 value:", bad_cell.value)

# Write the corrected SUMIFS formula
# Using full column references is safe in LibreOffice and keeps the formula dynamic
new_formula = "=SUMIFS(C:C, A:A, I3, B:B, J3)"
ws["K6"].value = new_formula
print("New formula written to K6:", ws["K6"].value)

# Save to output location
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas using the provided tool
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload the workbook in data_only mode to read the computed value
wb_data = openpyxl.load_workbook(output_path, data_only=True)
ws_data = wb_data.active
result_value = ws_data["K6"].value
print("Computed value in K6 after recalculation:", result_value)
```
