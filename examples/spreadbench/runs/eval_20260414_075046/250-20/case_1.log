import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
input_path = "/sandbox/input/input_spreadsheet/1_250-20_init.xlsx"
wb = openpyxl.load_workbook(input_path, data_only=False)  # keep formulas

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print header and sample rows for a sheet
def inspect_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Get header row (assume first row)
    headers = [ws.cell(row=1, column=col).value for col in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Inspect each sheet
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    inspect_sheet(ws)
