output_path = os.path.join(output_dir, "1_50324_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheets
ws_dat = wb["Datensatz"]
ws_an = wb["Analyse"]

# Determine total customers (rows 4..max_row)
total_customers = ws_dat.max_row - 3  # because row 3 is header

# Define range for Datensatz product headers (row 3, columns D-K)
header_start_col = column_index_from_string("D")
header_end_col = column_index_from_string("K")
header_row = 3

# Define Analyse matrix bounds
row_start = 5  # first product row in Analyse (C column)
row_end = ws_an.max_row  # should be 12 for 8 products
col_start = column_index_from_string("D")
col_end = column_index_from_string("K")

# Write formula into each cell of the Analyse matrix
for r in range(row_start, row_end + 1):
    for c in range(col_start, col_end + 1):
        # Build formula string
        # $C{r} refers to the row product name
        # {col_letter}$4 refers to the column product name
        col_letter = get_column_letter(c)
        formula = (
            f"=ROUND("
            f"COUNTIFS("
            f"OFFSET(Datensatz!$D$4,0,MATCH($C{r},Datensatz!$D$3:$K$3,0)-1,{total_customers},1),\">0\","
            f"OFFSET(Datensatz!$D$4,0,MATCH({col_letter}$4,Datensatz!$D$3:$K$3,0)-1,{total_customers},1),\">0\")"
            f"/ROWS(Datensatz!$C$4:$C${ws_dat.max_row}),9)"
        )
        ws_an.cell(row=r, column=c).value = formula

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice)
# Note: recalculate is an async function provided by the environment.
# We will call it and then reload the workbook data‑only to verify.
