import os
import openpyxl
from openpyxl.styles import PatternFill

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_56419_init.xlsx")

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)
ws = wb[wb.sheetnames[0]]  # assume a single sheet

# Define the fill for rows where Quantity is non-zero
fill_nonzero = PatternFill(start_color="92D050", end_color="92D050", fill_type="solid")

# Iterate over data rows (starting at row 2)
for row in range(2, ws.max_row + 1):
    # Build the single formula for this row
    formula = f"=IFERROR(IF(B{row}<>0, A{row}, \"\"), \"\")"
    ws.cell(row=row, column=8).value = formula  # Column H (index 8)

    # Apply background color if Quantity is non-zero (and not None)
    qty = ws.cell(row=row, column=2).value
    if qty is not None and qty != 0:
        ws.cell(row=row, column=8).fill = fill_nonzero
    # else: leave the fill as default (do not assign None)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas using LibreOffice backend
await recalculate(output_path)

# Verify by reloading with data_only=True and printing first few values of column H
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]
print("Verification of column H (first 10 data rows):")
for r in range(2, min(12, ws_check.max_row + 1)):
    print(f"Row {r}:", ws_check.cell(row=r, column=8).value)
