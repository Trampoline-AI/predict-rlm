wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['2022']
print('\n--- Cached numeric values (data_only) for first three categories ---')
for r in range(category_start, min(category_start + 3, ws_check.max_row + 1)):
    cat = ws_check.cell(row=r, column=1).value
    print(f'Row {r} (Category: {cat})')
    for c in range(month_start_col, month_end_col + 1):
        val = ws_check.cell(row=r, column=c).value
        print(f'  {get_column_letter(c)}{r}: {val}')

# ---------------------------------------------------------------------
# 5. Verify that the formulas are present (load with data_only=False).
wb_form = openpyxl.load_workbook(output_path, data_only=False)
ws_form = wb_form['2022']
print('\n--- Formula strings after write (first three categories) ---')
for r in range(category_start, min(category_start + 3, ws_form.max_row + 1)):
    cat = ws_form.cell(row=r, column=1).value
    print(f'Row {r} (Category: {cat})')
    for c in range(month_start_col, month_end_col + 1):
        cell = ws_form.cell(row=r, column=c)
        print(f'  {get_column_letter(c)}{r}: {repr(cell.value)}')
