import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_46121_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_46121_init.xlsx')

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Get sheets
ws_tx = wb['Transactions']
ws_out = wb['2022']

# Identify month header row (row 2) and category start row (first row where column A has a value and row>2)
month_row = 2
category_start_row = None
for r in range(3, ws_out.max_row + 1):
    if ws_out.cell(row=r, column=1).value:
        category_start_row = r
        break
if category_start_row is None:
    raise ValueError('Could not find first category row in 2022 sheet')

# Identify month columns (B through M) – we will stop at the column before the "Total" column (which is N)
month_start_col = column_index_from_string('B')
month_end_col = column_index_from_string('M')  # inclusive

# Write SUMIFS formulas for each category row and each month column
for r in range(category_start_row, ws_out.max_row + 1):
    category = ws_out.cell(row=r, column=1).value
    if not category:
        # stop when we hit a blank category row
        continue
    for c in range(month_start_col, month_end_col + 1):
        month_cell = ws_out.cell(row=month_row, column=c)
        month_name = month_cell.value
        if not month_name:
            continue
        target_cell = ws_out.cell(row=r, column=c)
        # Only write if the cell is empty or contains an error/placeholder
        if target_cell.value is None or isinstance(target_cell.value, str) and target_cell.value.startswith('=') is False:
            # Build formula
            # Use absolute references for the Transactions ranges
            formula = f"=SUMIFS(Transactions!$C:$C, Transactions!$A:$A, {get_column_letter(c)}${month_row}, Transactions!$D:$D, ${get_column_letter(1)}${r})"
            target_cell.value = formula

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(output_path)

# Reload with data_only to verify a few cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check['2022']

print('Verification of a few cells after recalculation:')
for r in range(category_start_row, min(category_start_row+3, ws_check.max_row+1)):
    for c in range(month_start_col, month_end_col+1):
        val = ws_check.cell(row=r, column=c).value
        print(f"Cell {get_column_letter(c)}{r}: {val}")
