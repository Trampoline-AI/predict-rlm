```repl
import openpyxl
from openpyxl.utils import column_index_from_string
import os
import re

# ----------------------------------------------------------------------
# Paths
# ----------------------------------------------------------------------
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# ----------------------------------------------------------------------
# Load workbook (keep formulas)
# ----------------------------------------------------------------------
wb = openpyxl.load_workbook(input_path, data_only=False)

# ----------------------------------------------------------------------
# 1. Extract ordered invoice numbers from SH1 (column D)
# ----------------------------------------------------------------------
sh1 = wb["SH1"]
invoice_col = column_index_from_string("D")  # 4
invoice_numbers = []

# Define a simple pattern for invoice numbers (e.g., starts with A followed by digits)
invoice_pattern = re.compile(r"^A\d+$", re.IGNORECASE)

for row in range(2, sh1.max_row + 1):
    col_a_val = sh1.cell(row=row, column=1).value  # column A (used to detect header rows)
    val = sh1.cell(row=row, column=invoice_col).value
    # Keep rows where column A is empty (or None) and column D looks like an invoice
    if col_a_val is None and isinstance(val, str):
        val_str = val.strip()
        if invoice_pattern.match(val_str):
            invoice_numbers.append(val_str)

print("Extracted invoice numbers from SH1 (order):", invoice_numbers)

# ----------------------------------------------------------------------
# 2. Populate DATA column D based on SH1 invoice numbers
# ----------------------------------------------------------------------
data_ws = wb["DATA"]
col_D = column_index_from_string("D")  # 4
col_E = column_index_from_string("E")  # 5 (sheet name)
col_A = column_index_from_string("A")  # 1 (row type, used for TOTAL)

inv_idx = 0
current_invoice = invoice_numbers[inv_idx] if invoice_numbers else None

for r in range(2, data_ws.max_row + 1):
    sheet_name = data_ws.cell(row=r, column=col_E).value
    row_type = data_ws.cell(row=r, column=col_A).value

    # Detect TOTAL rows – they delimit blocks
    if isinstance(row_type, str) and row_type.strip().upper() == "TOTAL":
        # Advance to next invoice number for the following block
        if inv_idx + 1 < len(invoice_numbers):
            inv_idx += 1
            current_invoice = invoice_numbers[inv_idx]
        else:
            current_invoice = None
        continue  # Do not write into TOTAL rows

    # Process only rows that belong to the target sheet name
    if isinstance(sheet_name, str) and sheet_name.strip() == "SH1":
        if current_invoice is not None:
            target_cell = data_ws.cell(row=r, column=col_D)
            existing = target_cell.value
            # Write only if the cell is empty or holds a different value
            if existing is None or (isinstance(existing, str) and existing.strip() != current_invoice):
                target_cell.value = current_invoice

# ----------------------------------------------------------------------
# 3. Save to output path
# ----------------------------------------------------------------------
wb.save(output_path)
print("Workbook saved to:", output_path)

# ----------------------------------------------------------------------
# 4. Recalculate formulas (LibreOffice) and verify target cells
# ----------------------------------------------------------------------
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only=True to read cached formula results
wb2 = openpyxl.load_workbook(output_path, data_only=True)
data_ws2 = wb2["DATA"]

def show_rows(ws, start, end):
    for r in range(start, end + 1):
        sheet_name = ws.cell(row=r, column=col_E).value
        if sheet_name == "SH1":
            d_val = ws.cell(row=r, column=col_D).value
            a_val = ws.cell(row=r, column=col_A).value
            print(f"Row {r}: D={d_val}, A={a_val}")

print("\n--- Verification: first 10 rows where E='SH1' ---")
show_rows(data_ws2, 2, min(11, data_ws2.max_row))

print("\n--- Verification: last 5 rows where E='SH1' ---")
last_start = max(2, data_ws2.max_row - 4)
show_rows(data_ws2, last_start, data_ws2.max_row)

# ----------------------------------------------------------------------
# 5. Ensure sheet names unchanged after recalculation
# ----------------------------------------------------------------------
if wb2.sheetnames != wb.sheetnames:
    print("Sheet names changed after recalculation! Restoring original names.")
    for old_name, new_name in zip(wb.sheetnames, wb2.sheetnames):
        ws = wb2[new_name]
        ws.title = old_name
    wb2.save(output_path)
    print("Restored sheet names and saved again.")
