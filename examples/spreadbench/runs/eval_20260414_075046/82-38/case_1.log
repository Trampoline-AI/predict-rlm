import openpyxl
from openpyxl.utils import column_index_from_string
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# ----------------------------------------------------------------------
# 1. Extract ordered invoice numbers from SH1 (column D)
# ----------------------------------------------------------------------
sh1 = wb["SH1"]
invoice_col = 4  # D
invoice_numbers = []

for row in range(2, sh1.max_row + 1):  # start after header row
    val = sh1.cell(row=row, column=invoice_col).value
    # Keep only non‑empty strings that are not known non‑invoice labels
    if isinstance(val, str) and val.strip() != "":
        # Exclude known section labels that appear in column D
        if val.upper() not in {"INVOICE NO", "TYPE", "TOTAL", "DISCOUNT", "NET"}:
            invoice_numbers.append(val.strip())

print("Extracted invoice numbers from SH1 (order):", invoice_numbers)

# ----------------------------------------------------------------------
# 2. Populate DATA column D based on SH1 invoice numbers
# ----------------------------------------------------------------------
data_ws = wb["DATA"]
col_D = 4  # D
col_E = 5  # E (sheet name)
col_A = 1  # A (row type, used to detect TOTAL)

# Keep an index into invoice_numbers
inv_idx = 0
current_invoice = invoice_numbers[inv_idx] if invoice_numbers else None

# Iterate rows
for r in range(2, data_ws.max_row + 1):
    sheet_name = data_ws.cell(row=r, column=col_E).value
    row_type = data_ws.cell(row=r, column=col_A).value

    # If we hit a TOTAL row, advance to next invoice number
    if isinstance(row_type, str) and row_type.strip().upper() == "TOTAL":
        # Advance invoice index only if there is a next one
        if inv_idx + 1 < len(invoice_numbers):
            inv_idx += 1
            current_invoice = invoice_numbers[inv_idx]
        else:
            current_invoice = None
        # Do NOT write into TOTAL rows
        continue

    # Process only rows where column E matches the target sheet name
    if isinstance(sheet_name, str) and sheet_name.strip() == "SH1":
        # Write invoice number if we have one
        if current_invoice is not None:
            target_cell = data_ws.cell(row=r, column=col_D)
            existing = target_cell.value
            # Write only if empty or different
            if existing is None or (isinstance(existing, str) and existing.strip() != current_invoice):
                target_cell.value = current_invoice
                # Optional: keep a note that we filled it
                # target_cell.comment = openpyxl.comments.Comment("Filled by script", "Mercury")
        # If no invoice left, leave cell as‑is
    # else: rows with other sheet names are ignored (leave D untouched)

# ----------------------------------------------------------------------
# 3. Save to output path
# ----------------------------------------------------------------------
wb.save(output_path)
print("Workbook saved to:", output_path)

# ----------------------------------------------------------------------
# 4. Recalculate formulas (LibreOffice) and verify target cells
# ----------------------------------------------------------------------
# Recalculate using the provided tool
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload with data_only=True to read cached values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
data_ws2 = wb2["DATA"]

# Verify a few rows (first 10 and last 5) for column D where E == "SH1"
def show_rows(ws, start, end):
    for r in range(start, end + 1):
        sheet_name = ws.cell(row=r, column=col_E).value
        if sheet_name == "SH1":
            print(f"Row {r}: D={ws.cell(r, col_D).value}, A={ws.cell(r, col_A).value}")

print("\n--- Verification: first 10 rows (E='SH1') ---")
show_rows(data_ws2, 2, min(11, data_ws2.max_row))

print("\n--- Verification: last 5 rows (E='SH1') ---")
last_start = max(2, data_ws2.max_row - 4)
show_rows(data_ws2, last_start, data_ws2.max_row)

# ----------------------------------------------------------------------
# 5. Ensure sheet names unchanged after recalculation
# ----------------------------------------------------------------------
if wb2.sheetnames != wb.sheetnames:
    print("Sheet names changed after recalculation! Restoring original names.")
    for old, new in zip(wb.sheetnames, wb2.sheetnames):
        ws = wb2[new]
        ws.title = old
    wb2.save(output_path)
    print("Restored sheet names and saved again.")
