This will give us the information needed to safely delete the target columns in a later iteration.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=False)

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

for ws in wb.worksheets:
    print("\n=== Sheet:", ws.title, "===")
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Dimensions: {max_row} rows x {max_col} columns")
    
    # Header row (first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Header row values (first 20 shown):", headers[:20])
    
    # Find columns containing '/description' in header
    target_cols = [c for c, val in enumerate(headers, start=1) if isinstance(val, str) and "/description" in val]
    if target_cols:
        col_letters = [get_column_letter(c) for c in target_cols]
        print("Columns with '/description' in header:", list(zip(col_letters, target_cols)))
    else:
        print("No columns with '/description' in header.")
    
    # Sample first 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals[:10])  # show first 10 columns for brevity
    
    # Sample last 5 data rows
    print("Last 5 data rows:")
    start_last = max(2, max_row-4)
    for r in range(start_last, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals[:10])  # show first 10 columns for brevity
