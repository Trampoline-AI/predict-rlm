found = {val: None for val in required_values}

for ws in wb.worksheets:
    print(f"\n--- Scanning sheet '{ws.title}' ---")
    for r in range(1, ws.max_row + 1):
        val = ws.cell(row=r, column=1).value
        if val in required_values and found[val] is None:
            found[val] = r
            print(f"Found value {val} at new row {r}")

# Report any missing values
