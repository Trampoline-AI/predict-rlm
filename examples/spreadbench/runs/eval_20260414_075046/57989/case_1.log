import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_57989_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_57989_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume single sheet

# Identify synthesis table header row (row 24) and driver start row (row 25)
header_row = 24
driver_start_row = 25

# Determine last driver row (stop when column A is empty)
last_row = ws.max_row
driver_rows = []
for r in range(driver_start_row, last_row + 1):
    val = ws.cell(row=r, column=1).value
    if val is None:
        # stop at first empty driver name
        break
    driver_rows.append(r)

# Weekday columns in the synthesis table: B (2) to H (8)
weekday_cols = list(range(2, 9))  # 2..8 inclusive

# Write the SUMPRODUCT formula for each driver and weekday column
for r in driver_rows:
    driver_cell_ref = f"$A{r}"
    for c in weekday_cols:
        col_letter = get_column_letter(c)
        # Build formula string
        formula = (
            f"=SUMPRODUCT((INDEX($A$1:$U$21,MATCH({driver_cell_ref},$A$1:$A$21,0),0)<>\"\")"
            f"*($A$1:$U$1={col_letter}$24))"
        )
        ws.cell(row=r, column=c).value = formula

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice + python formulas)
await recalculate(output_path)

# Reload with data_only=True to verify a few cells
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[ws_check.sheetnames[0]]

print("\nVerification of a few target cells after recalculation:")
for r in driver_rows[:5]:  # first 5 drivers
    row_vals = [ws_check.cell(row=r, column=c).value for c in weekday_cols]
    print(f"Driver row {r} values (B‑H):", row_vals)

# Also print the formula in one of the cells to confirm it was written correctly
sample_row = driver_rows[0] if driver_rows else None
if sample_row:
    sample_formula = ws.cell(row=sample_row, column=2).value
    print("\nSample formula written to B{}:".format(sample_row), sample_formula)

# Save again (just in case)
wb_check.save(output_path)
