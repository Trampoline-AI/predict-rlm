import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = "/sandbox/input/input_spreadsheet/1_57989_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sheet overview
def sheet_overview(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet '{ws.title}': {max_row} rows, {max_col} columns")
    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # First 5 data rows (excluding header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)
    # Last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

# Iterate over sheets
for ws in wb.worksheets:
    sheet_overview(ws)

# Additionally, search for any cell containing "COUNTA(" to see existing formula attempts
print("\nSearching for cells with 'COUNTA(' in their formula:")
for ws in wb.worksheets:
    for row in ws.iter_rows(min_row=1, max_row=ws.max_row, min_col=1, max_col=ws.max_column):
        for cell in row:
            if isinstance(cell.value, str) and "COUNTA(" in cell.value.upper():
                print(f"Sheet '{ws.title}' Cell {cell.coordinate}: {cell.value}")

# Save a copy (just in case)
wb.save("/sandbox/output/output_spreadsheet/1_57989_init.xlsx")
