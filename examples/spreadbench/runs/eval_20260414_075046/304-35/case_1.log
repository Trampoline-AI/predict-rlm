import openpyxl
from openpyxl.utils import column_index_from_string
from openpyxl.styles.fills import PatternFill

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_304-35_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = output_dir + "1_304-35_init.xlsx"

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Identify the target sheet – use the only sheet available ("start")
ws = wb.active  # default to the first sheet
print(f"Operating on sheet: {ws.title}")

# Column indices
col_a = column_index_from_string('A')
col_e = column_index_from_string('E')
col_f = column_index_from_string('F')

# 1. Clear column F where column E is empty (or yellow highlighted)
cleared_rows = []
for r in range(2, ws.max_row + 1):  # assume header in row 1
    cell_e = ws.cell(row=r, column=col_e)
    cell_f = ws.cell(row=r, column=col_f)
    # Detect empty E
    e_empty = cell_e.value in (None, "")
    # Detect yellow fill (RGB FFFF00) – optional, may be None
    is_yellow = False
    if isinstance(cell_e.fill, PatternFill) and cell_e.fill.fgColor:
        rgb = cell_e.fill.fgColor.rgb
        if rgb and rgb.upper().endswith("FFFF00"):
            is_yellow = True
    if e_empty or is_yellow:
        if cell_f.value not in (None, ""):
            cell_f.value = None
            cleared_rows.append(r)

print(f"Cleared column F in rows: {cleared_rows[:20]}{'...' if len(cleared_rows)>20 else ''}")

# 2. Propagate column A values downwards while column F is non‑empty
#    Stop when a row with empty column F is encountered.
#    Do not overwrite rows that already have the same index value.
current_a = None
propagated_rows = []
for r in range(2, ws.max_row + 1):
    cell_a = ws.cell(row=r, column=col_a)
    cell_f = ws.cell(row=r, column=col_f)
    # Stop if column F is empty
    if cell_f.value in (None, ""):
        print(f"Stopping propagation at row {r} because column F is empty.")
        break
    # Update current_a if this row has a non‑empty A
    if cell_a.value not in (None, ""):
        current_a = cell_a.value
        # No need to write – already present
        continue
    # If A is empty and we have a current value, write it (unless it's a duplicate index)
    if current_a is not None:
        # Check if the target cell already contains the same value (duplicate index)
        if cell_a.value != current_a:
            cell_a.value = current_a
            propagated_rows.append(r)

print(f"Propagated column A into rows: {propagated_rows[:20]}{'...' if len(propagated_rows)>20 else ''}")

# Save the modified workbook
wb.save(output_path)
print(f"Workbook saved to {output_path}")

# Recalculate formulas (if any) and verify
import asyncio
from sandbox import recalculate  # assuming recalculate is available as described

async def recalc_and_verify():
    # Recalculate formulas
    result = await recalculate(output_path)
    print(f"Recalculate result: {result}")
    # Reload with data_only to read cached values
    wb2 = openpyxl.load_workbook(output_path, data_only=True)
    ws2 = wb2[ws.title]
    # Verify a few rows after modifications
    print("\nVerification (first 10 rows after changes):")
    for r in range(2, min(12, ws2.max_row + 1)):
        a = ws2.cell(r, col_a).value
        e = ws2.cell(r, col_e).value
        f = ws2.cell(r, col_f).value
        print(f"Row {r}: A={a}, E={e}, F={f}")

# Run the async verification
asyncio.run(recalc_and_verify())
