Code:
```repl
import openpyxl
import os

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_408-5_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = os.path.join(output_dir, '1_408-5_init.xlsx')

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # single sheet

# Column indices (1‑based)
COL_C = 3  # Reference
COL_D = 4  # Amount
COL_E = 5  # Match Ref and Val

# ---------- 1. Compute sum of D where E == 0 ----------
sum_zero = 0.0
for r in range(2, ws.max_row + 1):
    e_val = ws.cell(row=r, column=COL_E).value
    if e_val == 0:
        d_val = ws.cell(row=r, column=COL_D).value
        if isinstance(d_val, (int, float)):
            sum_zero += d_val

print(f"Computed sum (D where E==0): {sum_zero}")

# ---------- 2. Delete rows ----------
# Iterate backwards to avoid index shift
for r in range(ws.max_row, 1, -1):
    # Gather row values
    row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column + 1)]
    # Blank row?
    if all(v is None or (isinstance(v, str) and v.strip() == '') for v in row_vals):
        ws.delete_rows(r)
        continue
    e_val = ws.cell(row=r, column=COL_E).value
    c_val = ws.cell(row=r, column=COL_C).value
    # Delete if E == 0 and not a 'BR1 Sales' row
    if e_val == 0 and not (isinstance(c_val, str) and c_val.strip() == 'BR1 Sales'):
        ws.delete_rows(r)
        continue

# ---------- 3. Append new row with 'BR1 Sales' and the sum ----------
new_row_idx = ws.max_row + 1
ws.cell(row=new_row_idx, column=COL_C).value = 'BR1 Sales'
ws.cell(row=new_row_idx, column=COL_D).value = sum_zero
# (Column E left blank; can be set to 0 if desired)

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook
wb.save(output_path)

# Recalculate formulas
await recalculate(output_path)

# Verify the newly added row
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("Verification after recalculation:")
print(f"Row {new_row_idx}: C = {ws_check.cell(row=new_row_idx, column=COL_C).value}, "
      f"D = {ws_check.cell(row=new_row_idx, column=COL_D).value}")
```
