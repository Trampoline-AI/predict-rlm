selected_entity = entity_cell.value
print('Selected entity (COVER!B12):', selected_entity)

# 2. Row headers in COVER rows 18-23 (column A)
row_headers = [cover.cell(row=r, column=1).value for r in range(18, 24)]
print('COVER row headers (A18:A23):', row_headers)

# 3. Column sub‑headers in COVER row 13 (B13:E13)
col_headers = [cover.cell(row=13, column=c).value for c in range(2, 6)]
