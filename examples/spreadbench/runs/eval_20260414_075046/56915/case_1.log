entity_to_row = {}
for r in range(1, data.max_row + 1):
    val = data.cell(row=r, column=1).value
    if isinstance(val, str):
        entity_to_row[val.strip()] = r
print('Number of entities in DATA:', len(entity_to_row))

# 5. Determine which DATA columns correspond to COVER B‑E.
# In DATA, row 12 contains merged headers; the first merged block B12:E12 aligns with COVER B‑E.
# We'll assume a direct column mapping: COVER B->DATA B, C->DATA C, D->DATA D, E->DATA E.
