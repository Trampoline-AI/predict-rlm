```repl
import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string

# Load the workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print('Sheet names:', wb.sheetnames)

# Function to print first and last few rows of a sheet

def print_sample(ws, max_rows=5):
    rows = list(ws.iter_rows(values_only=True))
    total = len(rows)
    print(f"Sheet '{ws.title}' has {total} rows")
    # Print header row (assume first row is header)
    print('Header row (row 1):', rows[0])
    # Print first few rows after header
    print('First rows:')
    for r in rows[1:1+max_rows]:
        print(r)
    # Print last few rows
    if total > max_rows+1:
        print('Last rows:')
        for r in rows[-max_rows:]:
            print(r)

# Inspect COVER sheet
if 'COVER' in wb.sheetnames:
    cover_ws = wb['COVER']
    print('\n--- COVER sheet sample ---')
    print_sample(cover_ws)
    # Print row 13 (header row for columns) and column A (row headers)
    print('Row 13 values:', [cover_ws.cell(row=13, column=c).value for c in range(1, cover_ws.max_column+1)])
    print('Column A values (first 20 rows):', [cover_ws.cell(row=r, column=1).value for r in range(1, min(21, cover_ws.max_row+1))])
else:
    print('COVER sheet not found')

# Inspect DATA sheet
if 'DATA' in wb.sheetnames:
    data_ws = wb['DATA']
    print('\n--- DATA sheet sample ---')
    print_sample(data_ws)
    # Show merged cell ranges
    print('Merged cell ranges in DATA:', list(data_ws.merged_cells.ranges))
else:
    print('DATA sheet not found')
```
