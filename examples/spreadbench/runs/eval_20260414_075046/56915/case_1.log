```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = output_dir + '1_56915_init.xlsx'

# Load workbook (preserve formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
cover = wb['COVER']
data = wb['DATA']

# 1. Selected entity
selected_entity = cover['B12'].value
print('Selected entity (COVER!B12):', selected_entity)

# 2. Find the merged block in DATA row 12 that matches the selected entity
matched_block = None
for mr in data.merged_cells.ranges:
    # merged range is like "B12:E12"
    # Get top‑left cell of the range
    start_cell = data.cell(row=mr.min_row, column=mr.min_col)
    header_val = start_cell.value
    if isinstance(header_val, str) and header_val.strip() == str(selected_entity).strip():
        matched_block = mr
        break

if not matched_block:
    # If not found, list all header values for debugging
    headers = []
    for mr in data.merged_cells.ranges:
        cell = data.cell(row=mr.min_row, column=mr.min_col)
        headers.append((mr.coord, cell.value))
    print('Entity not found in merged headers. Available headers:', headers)
    raise RuntimeError('Selected entity not found in DATA header blocks.')

print('Matched merged block:', matched_block.coord)

# Determine the four columns belonging to the block
col_start = matched_block.min_col
col_end   = matched_block.max_col
block_cols = list(range(col_start, col_end + 1))
print('Block columns (indices):', block_cols, [get_column_letter(c) for c in block_cols])

# 3. Build a map from entity name (trimmed) to DATA row number
entity_to_row = {}
for r in range(1, data.max_row + 1):
    val = data.cell(row=r, column=1).value
    if isinstance(val, str):
        entity_to_row[val.strip()] = r

# 4. Process each row in COVER (A18:A23)
for cover_row in range(18, 24):
    entity_name = cover.cell(row=cover_row, column=1).value
    if not isinstance(entity_name, str):
        print(f'Row {cover_row} column entity name is not a string: {entity_name}')
        continue
    key = entity_name.strip()
    data_row = entity_to_row.get(key)
    if not data_row:
        print(f'Entity "{key}" not found in DATA column A')
        continue

    # Write the four values from the matched block
    for i, data_col in enumerate(block_cols):
        # COVER columns B‑E correspond to i = 0‑3
        cover_col = 2 + i  # B=2, C=3, D=4, E=5
        val = data.cell(row=data_row, column=data_col).value
        # Round numeric values to 2 decimals
        if isinstance(val, (int, float)):
            val = round(val, 2)
        target = cover.cell(row=cover_row, column=cover_col)
        target.value = val
        # Apply number format for columns C and E (3 and 5)
        if cover_col in (3, 5):
            target.number_format = '0.00'

# Save the workbook
wb.save(output_path)
print('Workbook saved to', output_path)

# Recalculate formulas (if any) and verify target cells
import asyncio
# Recalculate using the provided tool
calc_result = await recalculate(output_path)
print('Recalculate result:', calc_result)

# Reload with data_only to see computed values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
cover2 = wb2['COVER']
print('--- Verification of B18:E23 ---')
for r in range(18, 24):
    row_vals = [cover2.cell(row=r, column=c).value for c in range(2, 6)]
    print(f'Row {r}:', row_vals)
