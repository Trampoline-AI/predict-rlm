    entity_key = entity_name.strip()
    data_row = entity_to_row.get(entity_key)
    if not data_row:
        print(f'Entity "{entity_key}" not found in DATA')
        continue
    for col_idx, cover_col in enumerate(range(2, 6), start=2):
        # Get value from DATA same row and column
        val = data.cell(row=data_row, column=cover_col).value
        # Round to 2 decimals if numeric
