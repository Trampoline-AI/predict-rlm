```repl
import openpyxl
from pathlib import Path

# Load the workbook (read/write)
wb_path = Path("/sandbox/input/input_spreadsheet/1_39515_init.xlsx")
wb = openpyxl.load_workbook(wb_path)

print("Workbook loaded from:", wb_path)

# List sheet names
print("Sheets:", wb.sheetnames)

# Function to safely get cell value (including formulas)
def cell_val(cell):
    return cell.value if cell.value is not None else ""

# Explore each sheet
for ws in wb.worksheets:
    print("\n=== Sheet:", ws.title, "===")
    # Determine header row (assume first row)
    headers = [cell_val(ws.cell(row=1, column=c)) for c in range(1, ws.max_column + 1)]
    print("Headers (first row):", headers)
    print("Total rows:", ws.max_row, "Total columns:", ws.max_column)
    
    # Print first 5 data rows (excluding header)
    print("\nFirst 5 data rows:")
    for r in range(2, min(ws.max_row, 6) + 1):
        row_vals = [cell_val(ws.cell(row=r, column=c)) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    
    # Print last 5 data rows
    print("\nLast 5 data rows:")
    start = max(2, ws.max_row - 4)
    for r in range(start, ws.max_row + 1):
        row_vals = [cell_val(ws.cell(row=r, column=c)) for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    
    # Show column O (column 15) values for first few rows if exists
    if ws.max_column >= 15:
        print("\nColumn O values (first 5 rows):")
        for r in range(2, min(ws.max_row, 6) + 1):
            cell = ws.cell(row=r, column=15)
            print(f"O{r}:", cell.value)
