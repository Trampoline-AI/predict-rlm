import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_227-40_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_227-40_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # assume a single sheet

# Helper to clean duplicates within a row (columns B‑E)
def clean_row(values):
    seen = set()
    cleaned = []
    for v in values:
        if v is None:
            cleaned.append(None)
        elif v in seen:
            cleaned.append("")          # replace duplicate with empty string
        else:
            seen.add(v)
            cleaned.append(v)
    return cleaned

# Source rows containing the original data (rows 2‑4)
source_start, source_end = 2, 4
# Target start row for the result
target_start = 14

# Process each source row and write cleaned data to the target area
for src_r, tgt_r in zip(
    range(source_start, source_end + 1),
    range(target_start, target_start + (source_end - source_start) + 1)
):
    # Column A (Site Name) stays unchanged
    ws.cell(row=tgt_r, column=1).value = ws.cell(row=src_r, column=1).value

    # Columns B‑E: clean duplicates
    original_vals = [ws.cell(row=src_r, column=c).value for c in range(2, 6)]
    cleaned_vals = clean_row(original_vals)
    for idx, val in enumerate(cleaned_vals, start=2):
        ws.cell(row=tgt_r, column=idx).value = val

# Ensure row 17 is blank (as requested)
for c in range(1, 6):
    ws.cell(row=17, column=c).value = None

# Save the modified workbook
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas (if any) using the sandbox helper
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# Reload the workbook with data_only to verify the target range
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Values in A14:E17 after processing:")
for r in range(14, 18):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, 6)]
    print(f"Row {r}:", row_vals)
