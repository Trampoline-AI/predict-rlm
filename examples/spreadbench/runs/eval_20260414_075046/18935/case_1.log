import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=False)  # load formulas as text

print(f"Workbook loaded from: {wb_path}")
print("Sheet names:")
for name in wb.sheetnames:
    print(f" - {name}")

# Function to print sheet summary

def print_sheet_summary(ws, max_rows_to_show=5):
    print(f"\nSheet: {ws.title}")
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Dimensions: rows={max_row}, columns={max_col}")
    # Header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Print first few data rows (skip header)
    print(f"First {max_rows_to_show} data rows:")
    for r in range(2, min(2+max_rows_to_show, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)
    # Print last few data rows
    if max_row > max_rows_to_show + 1:
        print(f"Last {max_rows_to_show} data rows:")
        start = max(max_row - max_rows_to_show + 1, 2)
        for r in range(start, max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(f"Row {r}:", row_vals)
    # Scan for any formulas in the sheet
    formula_cells = []
    for row in ws.iter_rows(min_row=1, max_row=max_row, min_col=1, max_col=max_col):
        for cell in row:
            if isinstance(cell.value, str) and cell.value.startswith('='):
                formula_cells.append((cell.coordinate, cell.value))
    if formula_cells:
        print(f"Found {len(formula_cells)} formula cells (showing up to 10):")
        for coord, f in formula_cells[:10]:
            print(f"  {coord}: {f}")
    else:
        print("No formula cells found.")

# Iterate over all sheets and print summary
for ws in wb.worksheets:
    print_sheet_summary(ws)

# Save a copy of the workbook (unchanged) to the output directory for later use
output_dir = "/sandbox/output/output_spreadsheet/"
import os
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(wb_path))
wb.save(output_path)
print(f"\nSaved a copy of the original workbook to: {output_path}")
```
