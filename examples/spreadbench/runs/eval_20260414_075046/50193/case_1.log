import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
sheet_name = "RS.Food"
ws = wb[sheet_name]

max_row = ws.max_row
max_col = ws.max_column

# Build formula template using the actual max row
# We'll use f-strings to insert max_row into the absolute range.
formula_template = (
    '=IF(I{r}="","",'
    'SUMPRODUCT((I$2:I{max} = I{r}) * (B$2:B{max} > B{r})) + '
    'SUMPRODUCT((I$2:I{r} = I{r}) * (B$2:B{r} = B{r}))'
    ')'
)

# Write formula into column K (11) for each data row
for r in range(2, max_row + 1):
    cell = ws.cell(row=r, column=11)  # Column K
    # Replace any existing ArrayFormula with our new formula
    cell.value = formula_template.format(r=r, max=max_row)

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice + formulas library)
await recalculate(output_path)

# Reload with data_only to see evaluated values
wb2 = openpyxl.load_workbook(output_path, data_only=True)
ws2 = wb2[sheet_name]

# Verify a few rows: first 10 and a few later rows
def print_rank_samples(start, end):
    for r in range(start, end + 1):
        rank = ws2.cell(row=r, column=11).value
        item = ws2.cell(row=r, column=2).value  # Net Sales
        cls = ws2.cell(row=r, column=9).value   # Item Class (I)
        print(f"Row {r}: Class={cls}, NetSales={item}, Rank={rank}")

print("\nSample ranks (first 10 rows):")
print_rank_samples(2, min(11, max_row))

if max_row > 20:
    print("\nSample ranks (rows 20‑25):")
    print_rank_samples(20, min(25, max_row))

# Also check for duplicate ranks within the same class
# (simple check: collect ranks per class for first 100 rows)
from collections import defaultdict
rank_per_class = defaultdict(list)
for r in range(2, min(101, max_row + 1)):
    cls = ws2.cell(row=r, column=9).value
    rank = ws2.cell(row=r, column=11).value
    if cls is not None and rank is not None:
        rank_per_class[cls].append(rank)

print("\nDuplicate rank check (first 100 rows):")
for cls, ranks in rank_per_class.items():
    dup = len(ranks) != len(set(ranks))
    print(f"Class {cls}: {'duplicates' if dup else 'unique'} ranks ({len(ranks)} rows)")

# Save again (already saved) – final output path is ready for submission
