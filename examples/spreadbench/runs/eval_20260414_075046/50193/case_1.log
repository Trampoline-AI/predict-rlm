import openpyxl
from openpyxl.utils import get_column_letter
import os
from collections import defaultdict

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook with formulas (data_only=False)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb["RS.Food"]

max_row = ws.max_row
max_col = ws.max_column

# ----------------------------------------------------------------------
# Step 1: Inspect column J (Item Class) to ensure it contains values
# ----------------------------------------------------------------------
print("=== Column J (Item Class) raw and evaluated values for rows 6‑10 ===")
for r in range(6, 11):
    # Raw (may be formula)
    raw_cell = ws.cell(row=r, column=10)  # Column J
    raw_val = raw_cell.value
    # Evaluated value after recalculation (we'll recalc later)
    print(f"Row {r}: raw = {raw_val}")

# Recalculate to get evaluated values (LibreOffice + formulas library)
await recalculate(input_path)

# Reload with data_only=True to see evaluated values
wb_data = openpyxl.load_workbook(input_path, data_only=True)
ws_data = wb_data["RS.Food"]

print("\n=== Evaluated Column J values after recalculation (rows 6‑10) ===")
for r in range(6, 11):
    eval_val = ws_data.cell(row=r, column=10).value
    print(f"Row {r}: evaluated = {eval_val}")

# ----------------------------------------------------------------------
# Step 2: Write new sequential rank formula into column K (11)
# ----------------------------------------------------------------------
# Build the formula template with the actual max row inserted.
# Using f‑string placeholders for row (r) and max row (max_row).
formula_template = (
    '=IF(J{r}="","",'
    '1 + SUMPRODUCT(($J$2:$J{max}=J{r})*($B$2:$B{max}>B{r})) '
    '+ SUMPRODUCT(($J$2:$J{r}=J{r})*($B$2:$B{r}=B{r}))'
    ')'
)

for r in range(2, max_row + 1):
    ws.cell(row=r, column=11).value = formula_template.format(r=r, max=max_row)

# Save the modified workbook to the output location
wb.save(output_path)

# ----------------------------------------------------------------------
# Step 3: Recalculate and verify the new ranks
# ----------------------------------------------------------------------
await recalculate(output_path)

# Reload with data_only=True to read evaluated ranks
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check["RS.Food"]

def print_rank_samples(start, end):
    for r in range(start, end + 1):
        net = ws_check.cell(row=r, column=2).value
        cls = ws_check.cell(row=r, column=10).value   # Column J = Item Class
        rank = ws_check.cell(row=r, column=11).value
        print(f"Row {r}: Class={cls}, NetSales={net}, Rank={rank}")

print("\n=== Sample ranks (first 10 data rows) ===")
print_rank_samples(2, min(11, max_row))

if max_row > 20:
    print("\n=== Sample ranks (rows 20‑25) ===")
    print_rank_samples(20, min(25, max_row))

# ----------------------------------------------------------------------
# Step 4: Check for duplicate ranks within each class (first 200 rows)
# ----------------------------------------------------------------------
duplicates = False
rank_per_class = defaultdict(list)
for r in range(2, min(201, max_row + 1)):
    cls = ws_check.cell(row=r, column=10).value
    rank = ws_check.cell(row=r, column=11).value
    if cls is not None and rank is not None:
        rank_per_class[cls].append(rank)

print("\n=== Duplicate rank check (first 200 rows) ===")
for cls, ranks in rank_per_class.items():
    if len(ranks) != len(set(ranks)):
        duplicates = True
        print(f"Class '{cls}': DUPLICATES found ({len(ranks)} rows)")
    else:
        print(f"Class '{cls}': unique ranks ({len(ranks)} rows)")

if not duplicates:
