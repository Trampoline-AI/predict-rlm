import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read/write mode)
wb_path = "/sandbox/input/input_spreadsheet/1_545-35_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

print("Workbook loaded from:", wb_path)
print("Sheet names:", wb.sheetnames)

for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {sheet_name} ---")
    print(f"Rows (including header): {max_row}, Columns: {max_col}")

    # Print header row (assume first row contains headers)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print("Headers:", headers)

    # Helper to safely get cell value as string
    def cell_str(cell):
        return "" if cell.value is None else str(cell.value)

    # Print first 5 data rows (rows 2‑6)
    print("\nFirst 5 data rows:")
    for r in range(2, min(7, max_row + 1)):
        row_vals = [cell_str(ws.cell(row=r, column=c)) for c in range(1, max_col + 1)]
        print(f"Row {r}:", row_vals)

    # Print last 5 data rows (if more than 6 rows total)
    if max_row > 6:
        start = max(2, max_row - 4)
        print("\nLast 5 data rows:")
        for r in range(start, max_row + 1):
            row_vals = [cell_str(ws.cell(row=r, column=c)) for c in range(1, max_col + 1)]
            print(f"Row {r}:", row_vals)

    # Quick scan for non‑numeric cells in the first few columns
    print("\nSample scan for non‑numeric entries (first 10 rows, first 5 columns):")
    for r in range(2, min(12, max_row + 1)):
        for c in range(1, min(6, max_col + 1)):
            val = ws.cell(row=r, column=c).value
            if isinstance(val, str):
                # Check if the string contains any non‑digit characters
                if any(ch not in "0123456789" for ch in val):
                    col_letter = get_column_letter(c)
                    print(f"  Cell {col_letter}{r} = '{val}' (non‑numeric)")
