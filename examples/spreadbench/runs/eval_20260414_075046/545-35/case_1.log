We will:
1. Load the input workbook.
2. For each sheet, walk through all data rows (row 2 to max_row) and all columns (1 to max_col).  
   - If the cell value is a string and contains any character that is not a digit, replace the cell’s value with the integer 0.
3. Save the modified workbook to the output directory, keeping the same filename.
4. Call `recalculate()` on the saved file to let LibreOffice evaluate any formulas (none expected, but required by the workflow).
5. Reload the workbook with `data_only=True` and print a few rows to confirm that non‑numeric entries have become 0.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_545-35_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_545-35_init.xlsx")

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path, data_only=False)

def is_non_numeric_string(s: str) -> bool:
    """Return True if s contains any character that is not a digit."""
    return any(ch not in "0123456789" for ch in s)

# Iterate over all sheets and replace non‑numeric strings with 0
for ws in wb.worksheets:
    max_row = ws.max_row
    max_col = ws.max_column
    for r in range(2, max_row + 1):          # start at row 2 (skip header)
        for c in range(1, max_col + 1):
            cell = ws.cell(row=r, column=c)
            val = cell.value
            if isinstance(val, str):
                if is_non_numeric_string(val):
                    cell.value = 0   # write numeric zero

# Save the modified workbook
wb.save(output_path)
print(f"Workbook saved to {output_path}")

# Recalculate formulas (if any) using the provided tool
result = await recalculate(output_path)
print("Recalculate result:", result)

# Reload with data_only=True to see evaluated values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

# Helper to display a row as list of values
def row_vals(row_idx):
    return [ws_check.cell(row=row_idx, column=c).value for c in range(1, ws_check.max_column + 1)]

# Print first 5 data rows after cleaning
print("\nFirst 5 data rows after cleaning (rows 2‑6):")
for r in range(2, min(7, ws_check.max_row + 1)):
    print(f"Row {r}:", row_vals(r))

# Print a few sample cells that originally had non‑numeric data
sample_cells = ["C3", "D4", "E5", "F6"]
print("\nSample cells after cleaning:")
for addr in sample_cells:
    cell = ws_check[addr]
    print(f"{addr}: {cell.value}")

# Verify that any remaining string cells are either empty or numeric strings
remaining_strings = []
for r in range(2, ws_check.max_row + 1):
    for c in range(1, ws_check.max_column + 1):
        v = ws_check.cell(row=r, column=c).value
        if isinstance(v, str) and v.strip() != "":
            remaining_strings.append((get_column_letter(c) + str(r), v))
print("\nRemaining non‑empty string cells (should be none):", remaining_strings[:5])
```
