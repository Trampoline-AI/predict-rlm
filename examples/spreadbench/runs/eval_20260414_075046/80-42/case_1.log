Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas & styles)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Destination sheet (actual name in workbook)
dest_sheet_name = "Consolidate_ALL"
if dest_sheet_name not in wb.sheetnames:
    raise KeyError(f"Destination sheet '{dest_sheet_name}' not found in workbook.")
ws_dest = wb[dest_sheet_name]

# Determine first empty row in destination (column A must be empty)
next_row = ws_dest.max_row + 1
while ws_dest.cell(row=next_row, column=1).value is not None:
    next_row += 1

# Mapping of source column index -> destination column index (1‑based)
# Source columns: Date(1), Name(3), Description(4), Parent Node(5), Parent Description(6),
# CC External Code(7), Available in CORE(14), OAL CC Type(15), CC Default for LOB(16),
# CC Fiscal Recharge Owner(17), Ancestor List(18)
# Destination columns: 1‑12 (with 12 being Sheet Name)
mapping = [
    (1, 1),   # Date -> A
    (3, 2),   # Name -> B
    (4, 3),   # Description -> C
    (5, 4),   # Parent Node -> D
    (6, 5),   # Parent Description -> E
    (7, 6),   # CC External Code -> F
    (14, 7),  # Available in CORE -> G
    (15, 8),  # OAL CC Type -> H
    (16, 9),  # CC Default for LOB -> I
    (17, 10), # CC Fiscal Recharge Owner -> J
    (18, 11), # Ancestor List -> K
]

source_sheets = ["Jack", "Henry", "Richard"]

# Helper to copy style from source cell to target cell

def copy_style(src_cell, tgt_cell):
    tgt_cell.font = src_cell.font
    tgt_cell.fill = src_cell.fill
    tgt_cell.border = src_cell.border
    tgt_cell.alignment = src_cell.alignment
    tgt_cell.number_format = src_cell.number_format
    tgt_cell.protection = src_cell.protection

# Iterate over each source sheet and copy rows
for src_name in source_sheets:
    ws_src = wb[src_name]
    for src_row in range(2, ws_src.max_row + 1):
        tgt_row = next_row
        next_row += 1
        # Copy each mapped column
        for src_col, tgt_col in mapping:
            src_cell = ws_src.cell(row=src_row, column=src_col)
            tgt_cell = ws_dest.cell(row=tgt_row, column=tgt_col)
            tgt_cell.value = src_cell.value
            copy_style(src_cell, tgt_cell)
        # Write originating sheet name into column 12 (L)
        sheet_name_cell = ws_dest.cell(row=tgt_row, column=12)
        sheet_name_cell.value = src_name
        # Apply a simple style (optional) – we just copy the style from column 1 of the source row
        ref_cell = ws_src.cell(row=src_row, column=1)
        copy_style(ref_cell, sheet_name_cell)

# Save to output path
wb.save(output_path)
wb.close()

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload with data_only=True to verify a few rows (optional verification)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[dest_sheet_name]
print(f"After consolidation, first few rows in '{dest_sheet_name}':")
for r in range(ws_check.max_row - 4, ws_check.max_row + 1):
    vals = [ws_check.cell(row=r, column=c).value for c in range(1, 13)]
    print(f"Row {r}: {vals}")
wb_check.close()
```
