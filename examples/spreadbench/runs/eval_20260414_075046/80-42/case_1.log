import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.styles import PatternFill

# Load workbook
wb_path = input_spreadsheet  # provided variable
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas & styles

print("=== Sheet Names ===")
print(wb.sheetnames)

def cell_fill_color(cell):
    """Return a hex string of the cell's fill color if present, else None."""
    fill = cell.fill
    if isinstance(fill, PatternFill) and fill.fgColor and fill.fgColor.type == "rgb":
        return fill.fgColor.rgb
    return None

def print_sheet_summary(ws):
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"max_row: {ws.max_row}, max_column: {ws.max_column}")

    # Header row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, ws.max_column+1)]
    print("Headers:", headers)

    # First 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(ws.max_row, 6)+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
        print(f"Row {r}: {row_vals}")

    # Last 5 data rows (if more than 6 rows total)
    if ws.max_row > 6:
        print("Last 5 data rows:")
        start = max(2, ws.max_row-4)
        for r in range(start, ws.max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, ws.max_column+1)]
            print(f"Row {r}: {row_vals}")

    # Identify yellow-highlighted columns by scanning first few rows
    yellow_rgb = "FFFFFF00"  # typical Excel yellow (ARGB without alpha)
    yellow_cols = set()
    for r in range(2, min(ws.max_row, 10)+1):
        for c in range(1, ws.max_column+1):
            cell = ws.cell(row=r, column=c)
            color = cell_fill_color(cell)
            if color and color.upper().endswith("FFFF00"):  # ignore leading alpha
                yellow_cols.add(c)
    if yellow_cols:
        cols_letters = [get_column_letter(c) for c in sorted(yellow_cols)]
        print("Columns with yellow fill (based on first rows):", cols_letters)
    else:
        print("No yellow fill detected in first rows.")

# Iterate sheets
for ws in wb.worksheets:
    print_sheet_summary(ws)

# Close workbook (optional)
wb.close()
