```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Load workbook (keep formulas & styles)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Destination sheet name (as observed in the file)
dest_sheet_name = "Consolidate_ALL"
if dest_sheet_name not in wb.sheetnames:
    raise KeyError(f"Destination sheet '{dest_sheet_name}' not found.")
ws_dest = wb[dest_sheet_name]

# Find first empty row in column A of destination sheet
next_row = ws_dest.max_row + 1
while ws_dest.cell(row=next_row, column=1).value is not None:
    next_row += 1

# Mapping: (source column index, destination column index)
# Source columns (1‑based): Date(1), Name(3), Description(4), Parent Node(5),
# Parent Description(6), CC External Code(7), Available in CORE(14),
# OAL CC Type(15), CC Default for LOB(16), CC Fiscal Recharge Owner(17),
# Ancestor List(18)
# Destination columns: A‑K (1‑11); column L (12) will hold the sheet name
mapping = [
    (1, 1),   # Date -> A
    (3, 2),   # Name -> B
    (4, 3),   # Description -> C
    (5, 4),   # Parent Node -> D
    (6, 5),   # Parent Description -> E
    (7, 6),   # CC External Code -> F
    (14, 7),  # Available in CORE -> G
    (15, 8),  # OAL CC Type -> H
    (16, 9),  # CC Default for LOB -> I
    (17, 10), # CC Fiscal Recharge Owner -> J
    (18, 11), # Ancestor List -> K
]

source_sheets = ["Jack", "Henry", "Richard"]

# Helper to copy value and number format (skip full style to avoid proxy errors)
def copy_cell_content(src_cell, tgt_cell):
    tgt_cell.value = src_cell.value
    # Preserve number format (e.g., dates, currency)
    tgt_cell.number_format = src_cell.number_format

# Process each source sheet
for src_name in source_sheets:
    ws_src = wb[src_name]
    for src_row in range(2, ws_src.max_row + 1):
        tgt_row = next_row
        next_row += 1
        # Copy mapped columns
        for src_col, tgt_col in mapping:
            src_cell = ws_src.cell(row=src_row, column=src_col)
            tgt_cell = ws_dest.cell(row=tgt_row, column=tgt_col)
            copy_cell_content(src_cell, tgt_cell)
        # Write originating sheet name into column L (12)
        name_cell = ws_dest.cell(row=tgt_row, column=12)
        name_cell.value = src_name
        # Optionally copy number format from source column 1 (Date) for consistency
        ref_cell = ws_src.cell(row=src_row, column=1)
        name_cell.number_format = ref_cell.number_format

# Save the modified workbook to the output location
wb.save(output_path)
wb.close()

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Verify by loading with data_only=True and printing the last few rows of the destination sheet
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[dest_sheet_name]

print("\nVerification – last 5 rows of consolidated data (columns A‑L):")
for r in range(ws_check.max_row - 4, ws_check.max_row + 1):
    row_vals = [ws_check.cell(row=r, column=c).value for c in range(1, 13)]
    print(f"Row {r}: {row_vals}")

wb_check.close()
