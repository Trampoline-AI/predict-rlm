After identifying the yellow columns, we will also verify that the Consolidated_ALL sheet has blank rows after its existing data (its `max_row` is 3999, so we will start appending at row 4000). Finally, we will print a concise summary of the yellow columns for each source sheet and the next empty row in Consolidated_ALL.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load workbook (keep formulas & styles)
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)

def cell_is_yellow(cell):
    """Return True if cell fill is the standard Excel yellow (RGB FFFFF00)."""
    fill = cell.fill
    # PatternFill with solid fill uses fgColor.type == "rgb"
    if fill is None:
        return False
    if hasattr(fill, "fgColor") and fill.fgColor:
        # color may be ARGB; ignore alpha if present
        rgb = fill.fgColor.rgb
        if rgb:
            # Normalize to 6‑character hex (drop leading alpha if length 8)
            rgb = rgb[-6:].upper()
            return rgb == "FFFF00"
    return False

def find_yellow_columns(ws):
    """Return a sorted list of column letters that have any yellow cell."""
    yellow_cols = set()
    for row in ws.iter_rows(min_row=2, max_row=ws.max_row, max_col=ws.max_column):
        for cell in row:
            if cell_is_yellow(cell):
                yellow_cols.add(cell.column)  # numeric index
    return [get_column_letter(c) for c in sorted(yellow_cols)]

# Sheets to inspect (source sheets)
source_names = ["Jack", "Henry", "Richard"]
for name in source_names:
    ws = wb[name]
    yellow = find_yellow_columns(ws)
    print(f"\nSource sheet '{name}':")
    if yellow:
        print(f"  Yellow columns (by letter): {yellow}")
    else:
        print("  No yellow fill detected in any cell.")

# Determine next empty row in Consolidated_ALL (first row where column A is empty)
cons_ws = wb["Consolidated_ALL"]
next_row = cons_ws.max_row + 1
# Ensure column A at that row is truly empty (in case of stray blanks)
while cons_ws.cell(row=next_row, column=1).value is not None:
    next_row += 1
print(f"\nConsolidated_ALL next empty row for appending: {next_row}")

wb.close()
```
