```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = '/sandbox/input/input_spreadsheet/1_58904_init.xlsx'
output_dir = '/sandbox/output/output_spreadsheet/'
output_path = output_dir + '1_58904_init.xlsx'

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # Assuming single sheet

# Identify header row (row 1) and data range
header_row = 1
max_row = ws.max_row
max_col = ws.max_column

# Map column letters to their index (C=3, D=4, ...)
col_indices = {}
for col in range(1, max_col + 1):
    header_val = ws.cell(row=header_row, column=col).value
    if isinstance(header_val, str) and header_val.strip():
        col_indices[header_val.strip()] = col

# Find rows that start with 'Sum X' in column A
sum_rows = {}
for r in range(2, max_row + 1):
    label = ws.cell(row=r, column=1).value
    if isinstance(label, str) and label.startswith('Sum '):
        # Extract the letter after 'Sum '
        letter = label.split(' ')[1]
        sum_rows[letter] = r

# For each letter column, write a SUMPRODUCT formula in the corresponding Sum row
for letter, col_idx in col_indices.items():
    if letter in sum_rows:
        sum_row = sum_rows[letter]
        # Build range string for data (exclude header and sum rows)
        # Assume data rows are between header+1 and the row before the first Sum row
        # Find first Sum row index to limit range
        first_sum_row = min(sum_rows.values())
        data_start = header_row + 1
        data_end = first_sum_row - 1
        # Excel range like C2:C12
        col_letter = get_column_letter(col_idx)
        data_range = f"{col_letter}{data_start}:{col_letter}{data_end}"
        # Formula to extract numeric part and sum where left char matches letter
        formula = f"=SUMPRODUCT((LEFT({data_range},1)="{letter}")*VALUE(RIGHT({data_range},LEN({data_range})-1)))"
        ws.cell(row=sum_row, column=col_idx, value=formula)
        print(f"Wrote formula for letter {letter} in cell {col_letter}{sum_row}")

# Save to output path
wb.save(output_path)

# Recalculate formulas
from sandbox import recalculate
await recalculate(output_path)

# Verify results (load with data_only)
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("\nVerification of sum cells:")
for letter, sum_row in sum_rows.items():
    col_idx = col_indices[letter]
    col_letter = get_column_letter(col_idx)
    val = ws_check.cell(row=sum_row, column=col_idx).value
    print(f"{col_letter}{sum_row} (Sum {letter}) = {val}")
```
