import openpyxl
from pathlib import Path

# Load the workbook (read/write mode)
input_path = Path('/sandbox/input/input_spreadsheet/1_230-16_init.xlsx')
wb = openpyxl.load_workbook(input_path)

print('Workbook loaded from', input_path)
print('Sheet names:', wb.sheetnames)

# For each sheet, inspect headers and sample rows
for sheet_name in wb.sheetnames:
    ws = wb[sheet_name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f'\nSheet: {sheet_name}')
    print(f'  Max row: {max_row}, Max column: {max_col}')
    # Read header row (assume first row is header)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col + 1)]
    print('  Headers:', headers)
    # Function to get row values as list
    def row_vals(r):
        return [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
    # Print first 5 data rows (excluding header)
    print('  First 5 rows:')
    for r in range(2, min(2+5, max_row+1)):
        print(f'    Row {r}:', row_vals(r))
    # Print last 5 rows
    if max_row > 6:
        print('  Last 5 rows:')
        for r in range(max_row-4, max_row+1):
            print(f'    Row {r}:', row_vals(r))
    else:
        print('  Not enough rows for a "last 5" sample.')
