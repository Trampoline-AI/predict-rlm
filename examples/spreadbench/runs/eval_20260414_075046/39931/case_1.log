import openpyxl
from openpyxl import load_workbook

# Load the workbook (read_only for fast inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_39931_init.xlsx"
wb = load_workbook(wb_path, data_only=False)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# Helper to get column letters from header row
def get_headers(ws):
    headers = {}
    for cell in ws[1]:
        if cell.value is not None:
            headers[cell.column] = str(cell.value).strip()
    return headers

# 2. For each sheet, print header and sample rows
for name in wb.sheetnames:
    ws = wb[name]
    print(f"\n--- Sheet: {name} ---")
    headers = get_headers(ws)
    print("Headers (col index -> name):", headers)

    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Print first 5 data rows (skip header)
    print("First 5 rows:")
    for r in range(2, min(7, max_row + 1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
        print(r, row_vals)

    # Print last 5 rows
    if max_row > 7:
        print("Last 5 rows:")
        for r in range(max(max_row - 4, 2), max_row + 1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col + 1)]
            print(r, row_vals)

# Close workbook
wb.close()
```
