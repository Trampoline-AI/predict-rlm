```repl
import openpyxl
from openpyxl.utils import get_column_letter
from openpyxl.styles import Font, Fill, Border, Alignment, Protection
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_177-6_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_177-6_init.xlsx")

# Load workbook (keep formulas & styles)
wb = openpyxl.load_workbook(input_path, data_only=False)

data_ws = wb["DATA"]
# Ensure combined sheet exists; if not, create it
if "combined" in wb.sheetnames:
    combined_ws = wb["combined"]
else:
    combined_ws = wb.create_sheet("combined")

# Clear existing data rows in combined sheet (keep header row)
if combined_ws.max_row > 1:
    combined_ws.delete_rows(2, combined_ws.max_row - 1)

# Copy header from DATA to combined (row 1)
max_col = data_ws.max_column
header_vals = [data_ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
for c, val in enumerate(header_vals, start=1):
    combined_ws.cell(row=1, column=c).value = val
    # also copy style of header cells
    src_cell = data_ws.cell(row=1, column=c)
    tgt_cell = combined_ws.cell(row=1, column=c)
    tgt_cell.font = src_cell.font
    tgt_cell.fill = src_cell.fill
    tgt_cell.border = src_cell.border
    tgt_cell.alignment = src_cell.alignment
    tgt_cell.number_format = src_cell.number_format
    tgt_cell.protection = src_cell.protection

# Group rows by ComboKey (column H = index 8)
from collections import defaultdict

groups = defaultdict(list)  # key -> list of row numbers
for r in range(2, data_ws.max_row + 1):
    key = data_ws.cell(row=r, column=8).value
    if key is None:
        continue
    groups[key].append(r)

# Helper to copy style from source to target cell
def copy_style(src, tgt):
    tgt.font = src.font
    tgt.fill = src.fill
    tgt.border = src.border
    tgt.alignment = src.alignment
    tgt.number_format = src.number_format
    tgt.protection = src.protection

# Write merged rows to combined sheet
out_row = 2
for key, rows in groups.items():
    # Use the first row as the representative for columns A-H and formatting
    first = rows[0]
    # Columns A-H (1-8) copy values and style
    for c in range(1, 9):
        src_cell = data_ws.cell(row=first, column=c)
        tgt_cell = combined_ws.cell(row=out_row, column=c)
        tgt_cell.value = src_cell.value
        copy_style(src_cell, tgt_cell)
    # Columns I-R (9-18) compute sum of numeric values
    for c in range(9, max_col+1):
        total = 0.0
        has_number = False
        for r in rows:
            val = data_ws.cell(row=r, column=c).value
            # Treat non‑breaking space or empty as 0
            if isinstance(val, (int, float)):
                total += float(val)
                has_number = True
            elif isinstance(val, str):
                # ignore whitespace or non‑breaking space
                if val.strip() and val != '\xa0':
                    # try to convert to float if possible
                    try:
                        total += float(val.replace(',', ''))
                        has_number = True
                    except ValueError:
                        pass
        tgt_cell = combined_ws.cell(row=out_row, column=c)
        # If the sum is zero (or no numeric values), leave blank
        if not has_number or abs(total) < 1e-9:
            tgt_cell.value = None
        else:
            # Round to 2 decimals as required
            tgt_cell.value = round(total, 2)
        # Apply number format: two decimals, no commas
        tgt_cell.number_format = "0.00"
        # Copy style from the first row's cell for visual consistency (font, fill, etc.)
        src_cell = data_ws.cell(row=first, column=c)
        copy_style(src_cell, tgt_cell)
    out_row += 1

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)
print("Workbook saved to", output_path)

# Recalculate formulas (if any) and verify
await recalculate(output_path)
# Reload with data_only to read cached values
wb_check = openpyxl.load_workbook(output_path, data_only=True)
check_ws = wb_check["combined"]
print("--- Verification sample (first 5 merged rows) ---")
for r in range(2, min(7, check_ws.max_row+1)):
    vals = [check_ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
    print(f"Row {r}:", vals)
