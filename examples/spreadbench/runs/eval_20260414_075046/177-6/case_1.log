import os
import openpyxl
from collections import defaultdict
from openpyxl.styles import Font, Fill, Border, Alignment, Protection

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_177-6_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
