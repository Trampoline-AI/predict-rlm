if "combined" in wb.sheetnames:
    combined_ws = wb["combined"]
else:
    combined_ws = wb.create_sheet("combined")

# ----------------------------------------------------------------------
# 1. Prepare combined sheet: keep header, clear old data rows
# ----------------------------------------------------------------------
header_row = 1
max_col = data_ws.max_column  # should be 18 (A:R)

# Copy header values and style from DATA to combined (row 1)
for c in range(1, max_col + 1):
    src = data_ws.cell(row=header_row, column=c)
    tgt = combined_ws.cell(row=header_row, column=c)
    tgt.value = src.value
    tgt.font = src.font
    tgt.fill = src.fill
    tgt.border = src.border
    tgt.alignment = src.alignment
    tgt.number_format = src.number_format
    tgt.protection = src.protection

# Delete any rows below the header in combined (if any)
if combined_ws.max_row > header_row:
    combined_ws.delete_rows(header_row + 1, combined_ws.max_row - header_row)

# ----------------------------------------------------------------------
# 2. Group rows in DATA by ComboKey (column H, index 8)
# ----------------------------------------------------------------------
col_h = 8  # Column H
groups = defaultdict(list)  # key -> list of row numbers (int)

for r in range(2, data_ws.max_row + 1):
    cell = data_ws.cell(row=r, column=col_h)
    key = cell.value
    # Convert to string for hashing; keep None as is (will be ignored)
    if key is None:
        continue
    key_str = str(key)  # ensures hashable
    groups[key_str].append(r)

# ----------------------------------------------------------------------
# Helper: copy style from source cell to target cell
# ----------------------------------------------------------------------
def copy_style(src_cell, tgt_cell):
    tgt_cell.font = src_cell.font
    tgt_cell.fill = src_cell.fill
    tgt_cell.border = src_cell.border
    tgt_cell.alignment = src_cell.alignment
    tgt_cell.number_format = src_cell.number_format
    tgt_cell.protection = src_cell.protection

# ----------------------------------------------------------------------
# 3. Write merged rows into combined sheet
# ----------------------------------------------------------------------
out_row = 2  # start after header
for key, rows in groups.items():
    # Use the first row in the group as the reference for values & formatting
    first_row = rows[0]

    # Columns A‑H (1‑8): copy value and style directly
    for c in range(1, 9):
        src = data_ws.cell(row=first_row, column=c)
        tgt = combined_ws.cell(row=out_row, column=c)
        tgt.value = src.value
        copy_style(src, tgt)

    # Columns I‑R (9‑18): sum numeric values across the group
    for c in range(9, max_col + 1):
        total = 0.0
        has_number = False
        for r in rows:
            val = data_ws.cell(row=r, column=c).value
            # Treat None, empty string, non‑breaking space as zero
            if val is None:
                continue
            if isinstance(val, (int, float)):
                total += float(val)
                has_number = True
            elif isinstance(val, str):
                # Strip whitespace and non‑breaking space
                stripped = val.strip().replace('\xa0', '')
                if stripped == "":
                    continue
                # Try to parse as float (ignore commas)
                try:
                    total += float(stripped.replace(',', ''))
                    has_number = True
                except ValueError:
                    # Non‑numeric string – ignore
                    continue
        tgt = combined_ws.cell(row=out_row, column=c)
        # If no numeric data or sum is effectively zero, leave blank
        if not has_number or abs(total) < 1e-9:
            tgt.value = None
        else:
            tgt.value = round(total, 2)
        # Apply required number format: two decimals, no commas
        tgt.number_format = "0.00"
        # Preserve style from the first row's cell for visual consistency
        src = data_ws.cell(row=first_row, column=c)
        copy_style(src, tgt)

    out_row += 1

# ----------------------------------------------------------------------
# 4. Save, recalculate, and verify
# ----------------------------------------------------------------------
os.makedirs(output_dir, exist_ok=True)
wb.save(output_path)
print("Workbook saved to:", output_path)

# Recalculate formulas (if any) and then reload with data_only=True
await recalculate(output_path)

# Reload for verification
