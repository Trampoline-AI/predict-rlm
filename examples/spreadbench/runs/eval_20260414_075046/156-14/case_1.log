Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (read/write)
wb = openpyxl.load_workbook(input_path)

target_sheets = ["99250", "99251", "99252"]
target_text = "to be processed"
col_f_index = 6  # column F

# Delete rows from row 6 onward where column F matches target_text
for sheet_name in target_sheets:
    if sheet_name not in wb.sheetnames:
        print(f"Warning: sheet {sheet_name} not found")
        continue
    ws = wb[sheet_name]
    max_row = ws.max_row
    # iterate backwards to avoid index shift when deleting
    for r in range(max_row, 5, -1):  # stop at row 6 (inclusive)
        cell_val = ws.cell(row=r, column=col_f_index).value
        if isinstance(cell_val, str) and cell_val == target_text:
            ws.delete_rows(r, 1)
            print(f"Deleted row {r} in sheet {sheet_name}")

# Save modified workbook
wb.save(output_path)
print("Saved modified workbook to:", output_path)

# Recalculate formulas
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Verify that no remaining rows >=6 contain the target text
wb_check = openpyxl.load_workbook(output_path, data_only=True)
for sheet_name in target_sheets:
    ws = wb_check[sheet_name]
    rows_with_text = []
    for r in range(6, ws.max_row + 1):
        val = ws.cell(row=r, column=col_f_index).value
        if isinstance(val, str) and val == target_text:
            rows_with_text.append(r)
    if rows_with_text:
        print(f"Sheet {sheet_name} still has target text in rows: {rows_with_text}")
    else:
        print(f"Sheet {sheet_name} verification passed – no target text found from row 6 onward.")
