The plan:
1. Load the input workbook.
2. Trim header strings for columns A‑F.
3. For each data row (2 … max_row):
   - Collect headers where the cell value is “Y”.
   - Join them with “, ”.
   - Write the result into column G.
4. Save the workbook to `/sandbox/output/output_spreadsheet/1_51680_init.xlsx`.
5. Call `await recalculate` on the saved file.
6. Reload the file with `data_only=True` and print column G values for all rows to confirm.
Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter

# Paths
input_path = input_spreadsheet  # provided variable
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas, though we will write literals)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet

# --- Step 1: read and clean headers (A-F) ---
headers = []
for col_idx in range(1, 7):  # columns 1..6 = A..F
    val = ws.cell(row=1, column=col_idx).value
    if isinstance(val, str):
        cleaned = val.strip()
    else:
        cleaned = str(val).strip() if val is not None else ""
    headers.append(cleaned)

print("Cleaned headers:", headers)

# --- Step 2: compute column G for each data row ---
max_row = ws.max_row
for row_idx in range(2, max_row + 1):
    y_headers = []
    for col_idx in range(1, 7):
        cell_val = ws.cell(row=row_idx, column=col_idx).value
        if isinstance(cell_val, str) and cell_val.strip().upper() == "Y":
            y_headers.append(headers[col_idx - 1])
    # Join with comma and space
    result = ", ".join(y_headers) if y_headers else ""
    ws.cell(row=row_idx, column=7).value = result  # column G

# --- Step 3: save to output path ---
wb.save(output_path)
print("Saved workbook to:", output_path)

# --- Step 4: recalculate (no formulas, but required by workflow) ---
recalc_result = await recalculate(output_path)
print("Recalculate result:", recalc_result)

# --- Step 5: reload with data_only to verify ---
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check.active
print("\nColumn G values after processing:")
for row_idx in range(2, ws_check.max_row + 1):
    val = ws_check.cell(row=row_idx, column=7).value
    print(f"G{row_idx}:", val)
```
