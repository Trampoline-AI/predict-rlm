import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (keep formulas)
wb_path = "/sandbox/input/input_spreadsheet/1_440-24_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)

# 1. List sheet names
print("Sheet names:", wb.sheetnames)

# We'll work with the first sheet (adjust later if needed)
ws = wb[wb.sheetnames[0]]
print("\nWorking on sheet:", ws.title)

# 2. Determine dimensions
max_row = ws.max_row
max_col = ws.max_column
