Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_440-24_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_440-24_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]  # Assuming the relevant sheet is the first one

max_row = ws.max_row

# Copy values from column H to column B for each data row (starting at row 2)
for r in range(2, max_row + 1):
    source_val = ws.cell(row=r, column=8).value  # Column H
    # Write the value (or None) into column B
    ws.cell(row=r, column=2).value = source_val

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save the modified workbook
wb.save(output_path)

# Recalculate formulas (LibreOffice)
await recalculate(output_path)

# Reload with data_only=True to verify the copy
wb_check = openpyxl.load_workbook(output_path, data_only=True)
ws_check = wb_check[wb_check.sheetnames[0]]

print("Verification (first 5 rows after copy):")
for r in range(2, min(7, ws_check.max_row + 1)):
    val_B = ws_check.cell(row=r, column=2).value
    val_H = ws_check.cell(row=r, column=8).value
    print(f"Row {r}: B={val_B} | H={val_H} | Match={'✅' if val_B == val_H else '❌'}")

# Also check last 5 rows
print("Verification (last 5 rows after copy):")
for r in range(max(2, ws_check.max_row - 4), ws_check.max_row + 1):
    val_B = ws_check.cell(row=r, column=2).value
    val_H = ws_check.cell(row=r, column=8).value
    print(f"Row {r}: B={val_B} | H={val_H} | Match={'✅' if val_B == val_H else '❌'}")
```
