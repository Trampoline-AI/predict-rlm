```repl
import openpyxl
from openpyxl import load_workbook

# Load the workbook (read-only is fine for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_188-39_init.xlsx"
wb = load_workbook(wb_path, data_only=False)

# Print sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sheet overview
def print_sheet_overview(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {ws.title}")
    print(f"Dimensions: rows={max_row}, cols={max_col}")

    # Get header row (assume row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (row 2 onward)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)

# Iterate over all sheets
for ws in wb.worksheets:
    print_sheet_overview(ws)
```
