```repl
import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load the workbook (read/write)
wb_path = "/sandbox/input/input_spreadsheet/1_54144_init.xlsx"
wb = openpyxl.load_workbook(wb_path)

# List sheet names
print("Sheets:", wb.sheetnames)

# Helper to print a preview of a sheet
def preview_sheet(ws, max_rows=10):
    # Print headers (first row)
    headers = [cell.value for cell in ws[1]]
    print("Headers:", headers)
    # Print first few data rows
    for r in range(2, min(ws.max_row, max_rows) + 1):
        row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
        print(f"Row {r}:", row_vals)
    # Print last few rows if many rows
    if ws.max_row > max_rows:
        print("... last rows ...")
        for r in range(ws.max_row - max_rows + 1, ws.max_row + 1):
            row_vals = [ws.cell(r, c).value for c in range(1, ws.max_column + 1)]
            print(f"Row {r}:", row_vals)

# Inspect Data sheet
data_ws = wb["Data"]
print("\n--- Data sheet preview ---")
preview_sheet(data_ws, max_rows=8)

# Inspect Report sheet
report_ws = wb["Report"]
print("\n--- Report sheet preview ---")
preview_sheet(report_ws, max_rows=8)

# Find the cell that likely contains concatenated truck names
# Look for a cell with a long string containing commas or spaces
concatenated_cells = []
for r in range(2, report_ws.max_row + 1):
    for c in range(1, report_ws.max_column + 1):
        val = report_ws.cell(r, c).value
        if isinstance(val, str) and ("," in val or " " in val):
            # Simple heuristic: long string > 10 chars
            if len(val) > 10:
                concatenated_cells.append((r, c, val))
if concatenated_cells:
    print("\nPotential concatenated truck name cells (row, col, preview):")
    for r, c, val in concatenated_cells[:5]:
        print(f"  R{r}{get_column_letter(c)}: {val[:50]}...")
else:
    print("\nNo obvious concatenated string found.")
