import openpyxl
from openpyxl.utils import get_column_letter
import os

# Paths
input_path = input_spreadsheet  # e.g., /sandbox/input/input_spreadsheet/1_1818_init.xlsx
output_dir = "/sandbox/output/output_spreadsheet"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, os.path.basename(input_path))

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Get sheets
ws_data = wb["Data"]
ws_summary = wb["Summary"]

# Determine data range (assume row 2 to max_row)
data_max_row = ws_data.max_row
# Ensure we have at least rows up to 66 as seen earlier; use actual max_row
row_start = 2
row_end = data_max_row

# Build the array formulas (Excel 2013 style)
# Note: These are array formulas; the user must confirm with Ctrl+Shift+Enter.
student_number_formula = (
    '=IFERROR('
    'INDEX(Data!B${start}:B${end}, '
    'SMALL('
    'IF(Data!$D${start}:$D${end}="Lowest Performing", '
    'ROW(Data!$D${start}:$D${end})-ROW(Data!$D${start})+1), '
    'ROWS($B${start}:B2))'
    '), "")'
).format(start=row_start, end=row_end)

student_name_formula = (
    '=IFERROR('
    'INDEX(Data!C${start}:C${end}, '
    'SMALL('
    'IF(Data!$D${start}:$D${end}="Lowest Performing", '
    'ROW(Data!$D${start}:$D${end})-ROW(Data!$D${start})+1), '
    'ROWS($C${start}:C2))'
    '), "")'
).format(start=row_start, end=row_end)

# Write formulas starting at row 3 (below headers) and copy down enough rows
first_output_row = 3
# Estimate maximum possible matches (worst case: all rows)
max_output_rows = data_max_row - row_start + 1

for i in range(max_output_rows):
    r = first_output_row + i
    # Student Number column B
    ws_summary.cell(row=r, column=2).value = student_number_formula
    # Student Name column C
    ws_summary.cell(row=r, column=3).value = student_name_formula

# Save to output path
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with data_only to read evaluated values
wb_eval = openpyxl.load_workbook(output_path, data_only=True)
ws_sum_eval = wb_eval["Summary"]

# Print first few rows of the Summary sheet (rows 3‑10)
print("Summary sheet evaluated values (rows 3-10):")
for r in range(3, 11):
    num = ws_sum_eval.cell(row=r, column=2).value
    name = ws_sum_eval.cell(row=r, column=3).value
    print(f"Row {r}: Number={num}, Name={name}")
