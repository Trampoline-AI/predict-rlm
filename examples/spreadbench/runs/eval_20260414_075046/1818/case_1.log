# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)

# Sheets
ws_data = wb["Data"]
ws_summary = wb["Summary"]

# Determine data range
row_start = 2
row_end = ws_data.max_row  # expected 66

# -------------------------------------------------
# 1. Inspect distinct Performance values (trimmed)
# -------------------------------------------------
perf_vals = [ws_data.cell(row=r, column=4).value for r in range(row_start, row_end+1)]
distinct = sorted({str(v).strip() for v in perf_vals if v is not None})
print("Distinct Performance values (trimmed):", distinct)

# -------------------------------------------------
# 2. Write robust helper column (E) in Data sheet
# -------------------------------------------------
for r in range(row_start, row_end + 1):
    # Trim whitespace and compare exactly
    helper_formula = f'=IF(TRIM($D{r})="Lowest Performing", COUNTIF($D${row_start}:D{r}, "Lowest Performing"), "")'
    ws_data.cell(row=r, column=5).value = helper_formula  # column E

# -------------------------------------------------
# 3. Write lookup formulas in Summary sheet (B = C)
# -------------------------------------------------
first_output_row = 3
max_output_rows = row_end - row_start + 1  # worst‑case rows to fill

for i in range(max_output_rows):
    r = first_output_row + i

    # Student Number (column B)
    num_formula = (
        f'=IFERROR('
        f'INDEX(Data!B${row_start}:B${row_end}, '
        f'MATCH(ROW()-2, Data!E${row_start}:E${row_end}, 0)'
        f'), "")'
    )
    # Student Name (column C)
    name_formula = (
        f'=IFERROR('
        f'INDEX(Data!C${row_start}:C${row_end}, '
        f'MATCH(ROW()-2, Data!E${row_start}:E${row_end}, 0)'
        f'), "")'
    )
    ws_summary.cell(row=r, column=2).value = num_formula   # B column
    ws_summary.cell(row=r, column=3).value = name_formula  # C column

# -------------------------------------------------
# 4. Save, recalculate, reload, and verify
# -------------------------------------------------
wb.save(output_path)

# Recalculate formulas (LibreOffice fallback)
calc_result = await recalculate(output_path)
print("Recalculate result:", calc_result)

# Reload with evaluated values (data_only=True)
wb_eval = openpyxl.load_workbook(output_path, data_only=True)
ws_sum_eval = wb_eval["Summary"]

print("Summary evaluated values (rows 3‑12):")
for r in range(3, 13):
    num = ws_sum_eval.cell(row=r, column=2).value
    name = ws_sum_eval.cell(row=r, column=3).value
    print(f"Row {r}: Number={num}, Name={name}")

# Also dump helper column values for sanity check (first 10 rows)
print("Helper column E values (first 15 rows):")
for r in range(row_start, row_start+15):
    val = ws_data.cell(row=r, column=5).value
    print(f"Row {r}: E={val}")
