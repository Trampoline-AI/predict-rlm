import openpyxl, os, json
from openpyxl.utils import get_column_letter

# Load the workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)

# List sheet names
print("Sheet names:", wb.sheetnames)

# Function to print sheet summary

def sheet_summary(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"Sheet '{ws.title}': rows={max_row}, cols={max_col}")
    # Print headers (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)
    # Sample first 5 rows (excluding header)
    sample_start = 2
    sample_end = min(max_row, sample_start+4)
    print("First rows:")
    for r in range(sample_start, sample_end+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(r, row_vals)
    # Sample last 5 rows
    if max_row > 6:
        print("Last rows:")
        for r in range(max(max_row-4, sample_start), max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(r, row_vals)

# Summarize each sheet
for ws in wb.worksheets:
    sheet_summary(ws)

# Check for Summary sheet existence
if 'Summary' in wb.sheetnames:
    print("Summary sheet already exists.")
else:
    print("No Summary sheet found.")
