# Choose output column – we previously identified column Q (index 17) as empty
output_col_index = 17
output_col_letter = get_column_letter(output_col_index)
output_cell = ws[f"{output_col_letter}1"]

# Build formula: =SUM(INDIRECT(ADDRESS($S$6, target_col_index) & ":" & ADDRESS($S$8, target_col_index)))
# LibreOffice requires column index as number, so we embed the number directly.
