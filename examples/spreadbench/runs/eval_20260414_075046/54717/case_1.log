import openpyxl
from openpyxl.utils import get_column_letter, column_index_from_string

wb_path = "/sandbox/input/input_spreadsheet/1_54717_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row
max_col = ws.max_column

# Locate start and end row numbers (already known to be in S6 and S8)
start_row_cell = ws["S6"]
end_row_cell = ws["S8"]
start_row = start_row_cell.value
end_row = end_row_cell.value

print(f"Start row (S6): {start_row}")
print(f"End row (S8): {end_row}")

# Scan for any cell containing "P1" or "P2"
candidate_cells = []
for r in range(1, max_row + 1):
    for c in range(1, max_col + 1):
        val = ws.cell(row=r, column=c).value
        if isinstance(val, str):
            low = val.lower()
            if "p1" in low or "p2" in low:
                candidate_cells.append((r, c, val))

print("\nCells containing 'P1' or 'P2':")
for r, c, v in candidate_cells[:20]:
    print(f"{get_column_letter(c)}{r} = '{v}'")

# Determine target column
target_col_index = None
target_col_letter = None

if candidate_cells:
    # Assume the first candidate cell holds the column identifier (could be a header name or letter)
    # Try to interpret its value:
    cand_val = candidate_cells[0][2].strip()
    # If it's a single letter, treat as column letter
    if len(cand_val) == 1 and cand_val.isalpha():
        target_col_letter = cand_val.upper()
        target_col_index = column_index_from_string(target_col_letter)
    else:
        # Try to match it to a header name in row 1
        header_map = {}
        for c in range(1, max_col + 1):
            hdr = ws.cell(row=1, column=c).value
            if isinstance(hdr, str):
                header_map[hdr.strip()] = c
        if cand_val in header_map:
            target_col_index = header_map[cand_val]
            target_col_letter = get_column_letter(target_col_index)

# If still not found, default to the first meaningful data column (column B, index 2)
if target_col_index is None:
    # Choose column B (index 2) as fallback – this holds the "No Age" data
    target_col_index = 2
    target_col_letter = get_column_letter(target_col_index)
