ws = wb[wb.sheetnames[0]]  # assume first sheet

max_row = ws.max_row
max_col = ws.max_column

# Function to print cell info

def cell_info(r, c):
    val = ws.cell(row=r, column=c).value
    if val is None:
        return None
    return f"{get_column_letter(c)}{r} = {val!r}"

# Scan for any cells that contain keywords suggesting they hold config parameters
keywords = ["start", "end", "row", "col", "column", "P1", "P2", "border", "level", "auto prime", "auto", "prime"]
config_cells = []
for r in range(1, max_row+1):
    for c in range(1, max_col+1):
        val = ws.cell(row=r, column=c).value
        if isinstance(val, str):
            low = val.lower()
            if any(k in low for k in keywords):
                config_cells.append(cell_info(r,c))
        # also capture cells that contain a single column letter (e.g., "B")
        if isinstance(val, str) and len(val.strip())==1 and val.strip().isalpha():
            # could be a column identifier
            config_cells.append(cell_info(r,c))

print("Potential config cells (keyword matches or column letters):")
for info in config_cells[:50]:
    print(info)

# Also locate any empty cell that could be intended for the result (e.g., header "Result" or similar)
result_candidates = []
for r in range(1, max_row+1):
    for c in range(1, max_col+1):
        val = ws.cell(row=r, column=c).value
        if val is None:
            # check if the header row above (row 1) has a label like "Result" or "Sum"
            header = ws.cell(row=1, column=c).value
            if isinstance(header, str) and ('sum' in header.lower() or 'result' in header.lower()):
                result_candidates.append(cell_info(r,c))

print("\nPotential result cells (under a header containing 'sum' or 'result'):")
for info in result_candidates[:20]:
    print(info)
