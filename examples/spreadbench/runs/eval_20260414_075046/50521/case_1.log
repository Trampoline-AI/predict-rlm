Reasoning: We need to understand the spreadsheet structure before implementing any formula. In this first iteration we will load the workbook, list all sheet names, print the number of rows and columns for each sheet, display the header row (first row) and show a few sample rows from the top and bottom of the data. This will let us identify where the product order numbers are, which columns are numeric, and where we can place the new formula column.
Code:
```repl
import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read-only is fine for inspection)
wb = openpyxl.load_workbook(input_spreadsheet, data_only=False)
print("Workbook loaded from", input_spreadsheet)

# List sheet names
print("Sheet names:", wb.sheetnames)

for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\nSheet: {name}")
    print(f"  max_row = {max_row}, max_col = {max_col}")
    # Print column headers (assume first row contains headers)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("  Headers (first row):", headers)
    # Print first 5 data rows (row 2 onward)
    print("  First 5 data rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"    Row {r}:", row_vals)
    # Print last 5 data rows
    if max_row > 7:
        print("  Last 5 data rows:")
        for r in range(max_row-4, max_row+1):
            row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
            print(f"    Row {r}:", row_vals)
