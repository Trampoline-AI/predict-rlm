import openpyxl
from openpyxl.utils import get_column_letter

# Load the workbook (read‑only for inspection)
wb_path = "/sandbox/input/input_spreadsheet/1_516-46_init.xlsx"
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

print("Sheet names:", wb.sheetnames)

for name in wb.sheetnames:
    ws = wb[name]
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {name} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Print header row (row 1)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers:", headers)

    # Print first 5 data rows (rows 2‑6)
    print("First 5 data rows:")
    for r in range(2, min(7, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # Print last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # Check column H (8) for existing data
    col_h_vals = [ws.cell(row=r, column=8).value for r in range(2, max_row+1)]
    non_empty_h = [(r, val) for r, val in zip(range(2, max_row+1), col_h_vals) if val not in (None, "")]
    print(f"Non‑empty cells in column H (should be empty): {non_empty_h[:5]}")
