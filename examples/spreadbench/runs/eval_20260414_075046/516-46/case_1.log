Steps:
1. Load the workbook.
2. Scan rows 2‑max_row, reading columns A‑E.
3. For each brand, collect all rows, find the latest date, and sum the quantities of rows that have that latest date. Keep the batch and origin from the first row of that date (they are identical per brand in the sample).
4. Clear columns H‑L (rows 2‑max_row) to avoid leftover values.
5. Write the aggregated rows to columns H‑L, starting at row 2. The order will be alphabetical by brand for reproducibility.
6. Save the workbook to the output directory with the same filename.
7. Call `recalculate` on the saved file.
8. Reload the file with `data_only=True` and print the first few rows of the result (columns H‑L) to verify that values are present.

The code below implements these steps and prints a short verification of the written output.
Code:
```repl
import os
import openpyxl
from openpyxl.utils import get_column_letter
from datetime import datetime

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_516-46_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
os.makedirs(output_dir, exist_ok=True)
output_path = os.path.join(output_dir, "1_516-46_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb.active  # assume single sheet as inspected

max_row = ws.max_row

# ---------- 1. Scan source data (A‑E) ----------
brand_data = {}  # brand -> list of (date, batch, origin, qty)
for r in range(2, max_row + 1):
    date = ws.cell(row=r, column=1).value
    brand = ws.cell(row=r, column=2).value
    batch = ws.cell(row=r, column=3).value
    origin = ws.cell(row=r, column=4).value
    qty = ws.cell(row=r, column=5).value

    if brand is None:
        continue  # skip empty rows
    # Ensure qty is numeric
    try:
        qty = float(qty) if qty is not None else 0.0
    except Exception:
        qty = 0.0

    brand_data.setdefault(brand, []).append((date, batch, origin, qty))

# ---------- 2. Aggregate per brand on last date ----------
aggregated = []  # list of (date, brand, batch, origin, total_qty)
for brand in sorted(brand_data.keys()):
    rows = brand_data[brand]
    # Find the latest date (ignore None)
    dates = [d for (d, _, _, _) in rows if isinstance(d, datetime)]
    if not dates:
        continue
    last_date = max(dates)

    # Sum qty for rows with that date
    total_qty = sum(qty for (d, _, _, qty) in rows if d == last_date)
    # Take batch/origin from first matching row
    for (d, batch, origin, _) in rows:
        if d == last_date:
            agg_batch, agg_origin = batch, origin
            break
    else:
        agg_batch = agg_origin = None

    aggregated.append((last_date, brand, agg_batch, agg_origin, total_qty))

# ---------- 3. Clear target columns H‑L ----------
for r in range(2, max_row + 1):
    for c in range(8, 13):  # H=8, L=12
        ws.cell(row=r, column=c).value = None

# ---------- 4. Write aggregated results ----------
out_row = 2
for (date, brand, batch, origin, qty) in aggregated:
    ws.cell(row=out_row, column=8).value = date
    ws.cell(row=out_row, column=9).value = brand
    ws.cell(row=out_row, column=10).value = batch
    ws.cell(row=out_row, column=11).value = origin
    ws.cell(row=out_row, column=12).value = qty
    out_row += 1

# Save workbook
wb.save(output_path)

# ---------- 5. Recalculate formulas ----------
await recalculate(output_path)

# ---------- 6. Verify by reloading data_only ----------
vb = openpyxl.load_workbook(output_path, data_only=True)
vws = vb.active
print("Verification – first few result rows (H‑L):")
for r in range(2, min(2 + len(aggregated), vws.max_row + 1)):
    vals = [vws.cell(row=r, column=c).value for c in range(8, 13)]
    print(f"Row {r}:", vals)
```
