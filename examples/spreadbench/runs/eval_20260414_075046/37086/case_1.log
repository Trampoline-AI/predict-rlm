for idx, header in enumerate(headers, start=1):
    if isinstance(header, str) and header.strip().lower() == 'total':
        total_col_idx = idx
        break
print('Total column index:', total_col_idx)

# Identify the column that contains values 'A' and 'B' (likely column1)
