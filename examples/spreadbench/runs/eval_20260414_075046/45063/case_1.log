import openpyxl
from openpyxl.utils import column_index_from_string, get_column_letter

# Load workbook
wb_path = input_spreadsheet
wb = openpyxl.load_workbook(wb_path, data_only=False)  # keep formulas

# 1. Sheet names
print("Sheet names:", wb.sheetnames)

# Helper to print sheet summary
def summarize_sheet(ws):
    max_row = ws.max_row
    max_col = ws.max_column
    print(f"\n--- Sheet: {ws.title} ---")
    print(f"Rows: {max_row}, Columns: {max_col}")

    # Header row (assume first row)
    headers = [ws.cell(row=1, column=c).value for c in range(1, max_col+1)]
    print("Headers (row 1):", headers)

    # First 5 data rows (skip header)
    print("First 5 data rows:")
    for r in range(2, min(2+5, max_row+1)):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

    # Last 5 data rows
    print("Last 5 data rows:")
    start = max(2, max_row-4)
    for r in range(start, max_row+1):
        row_vals = [ws.cell(row=r, column=c).value for c in range(1, max_col+1)]
        print(f"Row {r}:", row_vals)

# Summarize each sheet
for ws in wb.worksheets:
    summarize_sheet(ws)

# Specific checks for the instruction
# Assume sheet1 is the first sheet, sheet2 is the second (if names differ, adjust)
sheet1 = wb[wb.sheetnames[0]]
sheet2 = wb[wb.sheetnames[1]]

# Print column A values from sheet1 (out‑of‑stock list)
print("\nColumn A values from Sheet1 (first 10):")
for r in range(2, min(12, sheet1.max_row+1)):
    print(f"A{r}:", sheet1.cell(row=r, column=1).value)

# Print columns A and B from sheet2 (product and quantity)
