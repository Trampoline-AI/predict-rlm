```repl
import openpyxl
import os
from openpyxl.utils import get_column_letter

# Paths
input_path = "/sandbox/input/input_spreadsheet/1_52532_init.xlsx"
output_dir = "/sandbox/output/output_spreadsheet/"
output_path = os.path.join(output_dir, "1_52532_init.xlsx")

# Load workbook (keep formulas)
wb = openpyxl.load_workbook(input_path, data_only=False)
ws = wb[wb.sheetnames[0]]

max_row = ws.max_row  # expected 8
max_col = ws.max_column  # expected 8

# Write the win‑count formula into column H (8) for each player row (2..max_row)
for r in range(2, max_row + 1):
    formula = (
        f"=SUMPRODUCT((B{r}=MAX(B$2:B${max_row}))"
        f"+(C{r}=MAX(C$2:C${max_row}))"
        f"+(D{r}=MAX(D$2:D${max_row}))"
        f"+(E{r}=MAX(E$2:E${max_row}))"
        f"+(F{r}=MAX(F$2:F${max_row}))"
        f"+(G{r}=MAX(G$2:G${max_row})))"
    )
    ws.cell(row=r, column=8).value = formula

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# Save workbook with formulas
wb.save(output_path)

# Recalculate formulas (LibreOffice backend)
await recalculate(output_path)

# Reload workbook with calculated values
wb_calc = openpyxl.load_workbook(output_path, data_only=True)
ws_calc = wb_calc[wb_calc.sheetnames[0]]

# Verify column H values (win counts)
col_h_vals = [ws_calc.cell(row=r, column=8).value for r in range(2, max_row + 1)]
print("Calculated win counts (column H):", col_h_vals)
```
